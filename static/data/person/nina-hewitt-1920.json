ation_country":"United States","end_type":"death_of_spouse","children_ids":[]},{"marriage_number":3,"spouse_id":"X02489","date_month":1,"date_day":1,"location_country":"United States","end_type":"death","end_year":2008,"children_ids":[]}],"tags":["hooker_talcott_descent","military","lawyer","yale_graduate","wwii","banker"],"sources":[{"label":"Talcott Stanley obituary, Hartford Courant, April 2008"},{"label":"FindAGrave"}],"institutions":[{"institution_id":"INST085","institution_blurb":"Honorary Trustee of NBMAA — museum founded by his grandfather H03203 in 1903."},{"institution_id":"INST052","institution_blurb":"Board President; awarded the Goodwin Medal for 50 years of service."},{"institution_id":"INST022","institution_blurb":"Yale Law School, class of 1947."},{"institution_id":"INST043","institution_blurb":"Williams College, class of 1940."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"family_connection","related_id":"T02192","display_label":"Cousins — she excavated Athens while he stewarded Hartford art","link_text":"Lucy Talcott"}],"narrative_blocks":[{"number":1,"category":"military","header":"Signal Intelligence Service","body":"Talcott Stanley enlisted in the US Army on July 10, 1942 at Hartford, serving as a First Lieutenant in the Signal Intelligence Service — the precursor to the NSA, doing codebreaking and signals work. He married Nina Brower Hewitt on December 15, 1945, then enrolled at Yale Law School, graduating in 1947. Their first child was born in New Haven before the family moved to West Hartford."},{"number":2,"category":"legacy","header":"His grandfather founded the museum he served","body":"Talcott Stanley served on the board of the Wadsworth Atheneum for fifty years and was awarded its prestigious Goodwin Medal. He was also Honorary Trustee of the New Britain Museum of American Art — founded in 1903 by his grandfather John Butler Talcott — and Board President of the Newington Children's Hospital, where his father Philip served as President of the Board of Trustees. He took early retirement from Connecticut Bank & Trust in 1973 to devote himself full-time to these institutions."},{"number":3,"category":"character","header":"A quiet man who shaped Hartford's cultural life","body":"His obituary described Talcott as \"a quiet man whose kindness, intelligence and thoughtful perspective on events and people enriched and entertained those around him.\" He loved the dinner table, the ski slopes, golf, and racing his sloop Bagheera. He was a member of Asylum Hill Congregational Church for 58 years and died peacefully at the Caleb-Hitchcock Health Care Center in Bloomfield on April 15, 2008, his family close at hand. SOURCE: Hartford Courant obituary, 2008."},{"number":4,"category":"military","header":"Codebreaking lieutenant in WWII Signal Intelligence Service","body":"Talcott served as a First Lieutenant in the Army's Signal Intelligence Service during World War II, the unit responsible for cryptanalysis and the institutional predecessor of the National Security Agency. He enlisted at Hartford on 10 July 1942."},{"number":5,"category":"legacy","header":"Goodwin Medal for fifty years at the Wadsworth","body":"Stanley served the Wadsworth Atheneum for fifty years on its board, ultimately as president, and received the museum's Goodwin Medal in recognition. The Hartford institution sat at the center of his civic life alongside service to the New Britain Museum his grandfather founded."},{"number":6,"category":"legacy","header":"Engineered merger of family foundation into regional foundation","body":"For forty-five years Talcott served on the board of the Alix W. Stanley Foundation, the family vehicle named for his aunt, and was instrumental in steering its merger into the Community Foundation of Greater New Britain. The decision moved the family's grantmaking into permanent regional infrastructure rather than keeping it in private family control."},{"number":7,"category":"character","header":"Sailed sloop Bagheera; Asylum Hill member 58 years","body":"Outside his Wadsworth Atheneum and Connecticut banking life, Talcott raced a sloop named Bagheera and was a 58-year communicant of Asylum Hill Congregational Church in Hartford. His weekend life — the boat, Sunday at Asylum Hill, the ski slopes, and a quiet table of friends — ran in parallel to the civic stewardship he is better-remembered for."}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Talcott","last_name":"Stanley","married_names":[],"display_name":"Talcott Stanley"},"military_service":[{"war":"World War II","war_id":"WAR008","rank":"First Lieutenant","rank_end":"First Lieutenant","rank_year_start":1942,"unit":"Signal Intelligence Service, U.S. Army","notes":"Enlisted 10 July 1942 at Hartford CT. Signal Intelligence Service was the Army's cryptanalysis arm — the predecessor unit of the National Security Agency."}],"education":[{"school_name":"Kingswood School","type":"secondary","notes":"Early schooling."},{"school_name":"Hotchkiss School","type":"secondary","notes":"Preparatory school graduate."},{"institution_id":"INST043","dates":"1936-1940","type":"undergraduate","notes":"Williams College class of 1940."},{"institution_id":"INST022","dates":"1945-1947","type":"law","notes":"Yale Law School, J.D. 1947."}],"career":[{"role":"Attorney","organization":"private practice","location":"West Hartford, Connecticut","start_year":1947,"end_year":1953,"notes":"Practiced law for six years before joining banking."},{"role":"Trust Officer","organization":"Connecticut Bank & Trust","location":"Hartford, Connecticut","start_year":1953,"end_year":1973,"notes":"Took early retirement 1973 to focus on community boards and family."}],"slug":"talcott-stanley-td0074"},"TD0109":{"id":"TD0109","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"display_name":"Peter Stanley","first_name":"Peter","last_name":"Stanley","ma