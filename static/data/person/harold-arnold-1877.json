 Hopkinton Cemetery Hopkinton New Hampshire. He married Dorothy Spoor of Pueblo Colorado in 1942 — she later served as Vice President of the Penny Pitou travel agency in Concord NH."}],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[{"war":"World War II","war_id":"WAR002","side":"American","rank_start":"2nd Lieutenant","rank_end":"2nd Lieutenant","unit":"United States Army","service_years":"WWII","awards":["Purple Heart"],"notes":"2nd Lieutenant United States Army during World War II. Recipient of the Purple Heart for wounds received in service."}],"education":[{"school_name":"Bowdoin College","role":"student","degree":"BA","graduation_year":1939,"notes":"Class of 1939; Alpha Delta Phi fraternity; first freshman to play on varsity hockey team; later honored 1992 as \"Number One Hockey Fan.\" Only one Hooker-tree person currently documented at Bowdoin so no INST entry per §9 2+ rule."},{"school_name":"Yale University School of Forestry","role":"student","degree":"Master of Forestry","graduation_year":1941,"notes":"M.F. 1941"}],"career":[],"bio":{"display_name":"Charles Ingersoll Arnold","first_name":"Charles","last_name":"Arnold","middle_name":"Ingersoll","married_names":[],"nickname":"Ingy","gender":"male"},"slug":"charles-arnold-1915"},"I01310":{"id":"I01310","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker_bool":false},"parents":{},"tags":[],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"HD5137","date_year":1942,"end_type":"death_of_spouse","end_year":1982,"children_ids":[]}],"number_of_marri