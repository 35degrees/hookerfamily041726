 Jennett Hepburn 1815. Two children: Lewis Eliphalet Parsons (HD1672, later provisional Governor of Alabama) and Fanny Jennette Parsons (HD1673, married Underground Railroad operator Seth Gates). Died September 2, 1827 at Chippewa (Chippawa), Ontario age 38. (Hinsdale family history; FindAGrave; WikiTree)","body":"Erastus Parsons moved from Broome County NY to Upper Canada in 1824 and cast the first iron ploughs made in Canada before dying at 38.","number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Erastus Parsons","first_name":"Erastus","last_name":"Parsons","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"erastus-parsons-1789"},"X00539":{"id":"X00539","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1795},"death":{},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1671","children_ids":["HD1672","HD1673"],"marriage_number":1,"date_year":1815,"date_month":10,"date_day":23,"location_city":"Wilkes-Barre","location_state":"Pennsylvania"}],"gender":"female","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Jennett Hepburn","first_name":"Jennett","maiden_name":"Hepburn","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"jennett-hepburn-1795"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}