t_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00868","mother_id":"HD2600"},"tags":[],"sources":[{"short":"Online vital records; The Record LXXI; EH 1909"}],"birth":{"year":1867,"month":3,"day":24,"city":"New Orleans","state":"Louisiana","country":"USA"},"death":{"year":1948,"month":7,"day":15,"city":"New York","state":"New York","country":"USA","age":81},"marriages":[{"spouse_id":"X00869","children_ids":["HD2604","HD2605","HD2606"],"marriage_number":1,"date_year":1895,"date_month":1,"date_day":10,"location_city":"New Orleans","location_state":"Louisiana"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["dynastic_link"],"notable_blurb":"Granddaughter of Polk; mother of UNICEF Nobel director"},"cross_connections":[],"bio":{"display_name":"Frances Devereux Huger","first_name":"Frances","middle_name":"Devereux","maiden_name":"Huger","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"place":"Metairie Cemetery","city":"New Orleans","state":"Louisiana"},"narrative_blocks":[{"number":1,"category":"family","header":"Her son accepted a Nobel Prize","body":"Her youngest son, Henry Richardson Labouisse Jr., directed UNICEF and accepted the 1965 Nobel Peace Prize on its behalf — and married Ève Curie, daughter of Marie. Frances herself was a granddaughter of Bishop-General Leonidas Polk, the “fighting bishop” of the Confederacy."},{"number":2,"category":"marriage","header":"Married Henry Richardson Labouisse, 1895 New Orleans","body":"Frances 'Fannie' Huger married Henry Richardson Labouisse Sr. on January 10, 1895 at New Orleans. They raised three sons in Louisiana: William Huger (HD2604), John Witherspoon (HD2605), and Henry Richardson Labouisse Jr. (HD2606). She lived to see Henry Jr. become a US ambassador, dying in Manhattan in 1948 at age 81 before his UNICEF tenure."}],"slug":"frances-huger-1867"},"X00868":{"id":"X00868","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["civil_war","confederate","military"],"sources":[{"short":"FindAGrave William Elliott Huger Sr","url":"https://www.findagrave.com/memorial/70632956/william_elliott-huger"},{"short":"American Aristocracy: John Middleton Huger","url":"https://americanaristocracy.com/people/john-middleton-huger"},{"short":"Times Picayune obit, July 7, 1901, page 4"},{"short":"The Daily Picayune obit, July 4, 1901, page 10"},{"short":"Sons of Confederate Veterans (military service records)"}],"birth":{"year":1841,"month":4,"day":27,"city":"Spring Hill","county":"Barbour County","state":"Alabama","country":"USA"},"death":{"year":1901,"month":7,"day":3,"city":"New York","state":"New York","country":"USA","age":60},"gender":"male","notable":{"is_notable":true,"notable_category":["military","finance"],"notable_blurb":"Stock Exchange president; Confederate veteran","primary_url":"https://americanaristocracy.com/people/john-middleton-huger","primary_url_label":"American Aristocracy (re: father Col. John M. Huger)"},"number_of_marriages":1,"marriages":[{"spouse_id":"HD2600","spouse_name":"Elizabeth Devereux Polk","marriage_number":1,"date_year":1864,"children_ids":["HD2608","HD2603","HD2609","HD2610","HD2611","HD2612"],"end_type":"death","end_year":1901,"notes":"Bidirectional marriage record synced from HD2600 in Stage 6Y-269."}],"parents":{},"cross_connections":[],"bio":{"display_name":"William Elliott Huger","first_name":"William","last_name":"Huger","middle_name":"Elliott","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779658861/huger_ikvbw1.png"},"residence":{"city":"New Orleans","state":"Louisiana","country":"USA","address_note":"Funeral from 3645 Coliseum Street, New Orleans (his late residence)"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Civil War","side":"Confederate","rank":"1st Lieutenant","units":["Co. B, 1st Special (Rightor's) Battalion, Louisiana Infantry","Co. I, Dreux's Battery, Louisiana Artillery","ADC on General's Staff"],"postwar_associations":["Sons of Confederate Veterans","Louisiana Division Camp No. 2, United Confederate Veterans (Army of Tennessee Association) — president"]}],"burial":{"place":"Metairie Cemetery","city":"New Orleans","state":"Louisiana","country":"USA"},"narrative_blocks":[{"number":1,"category":"career","header":"President of the New York Stock Exchange","body":"William Elliott Huger rose to the presidency of the New York Stock Exchange in the late nineteenth century. He died at age 60 on July 3, 1901 in New York City; his funeral was held from his New Orleans residence at 3645 Coliseum Street. He was buried beside his wife at Metairie Cemetery, New Orleans."},{"number":2,"category":"military","header":"First Lieutenant, Louisiana Confederate infantry and artillery","body":"Huger served as 1st Lieutenant in Co. B of the 1st Special (Rightor's) Battalion Louisiana Infantry and in Co. I of Dreux's Battery Louisiana Artillery during the Civil War, plus as aide-de-camp on the General's Staff. He maintained a postwar association with the Louisiana Division Camp No. 2 of the United Confederate Veterans for the rest of his life. He served as president of the Army of Tennessee Association in Louisiana."},{"number":3,"category":"family","header":"Father a Seminole War and Civil War Colonel","body":"His father Col. John Middleton Huger was appointed Adjutant General with the rank of Major under Gen. Moore in the brigade of North Alabama troops at the outbreak of the 1835 Seminole War, where he distinguished himself in many acts of bravery. He served as Confederate Colonel under Gen. Braxton Bragg in the Civil War and afterward retired to large sugar plantations on Red River and Côte Blanche Island in Louisiana. Col. Huger died in Manhattan at 537 Fifth Avenue and was a longtime schoolmate and lifelong friend of Hamilton Fish."},{"number":4,"category":"family","header":"Grandfather a US Senator; great-grandfather a Signer","body":"His grandfather Judge Daniel Elliott Huger served as United States Senator from South Carolina in the antebellum period. His great-grandfather on the maternal side was Arthur Middleton — one of South Carolina's four signers of the Declaration of Independence in 1776. The Hugers themselves descended from French Huguenots who emigrated to South Carolina in the sixteenth and seventeenth centuries."}],"slug":"william-huger-1841"},"HD2600":{"id":"HD2600","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00867","mother_id":"HD2594"},"tags":[],"sources":[{"short":"Online vital records; The Record LXXI; EH 1909"}],"birth":{"year":1843},"death":{"year":1918},"marriages":[{"spouse_id":"X00868","children_ids":["HD2608","HD2603","HD2609","HD2610","HD2611","HD2612"],"marriage_number":1,"date_year":1864}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Devereux Polk","first_name":"Elizabeth","middle_name":"Devereux","maiden_name":"Polk","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Married NYSE president William Elliott Huger, 1864","body":"Elizabeth Devereux Polk married William Elliott Huger in 1864 — joining her father Bishop/General Leonidas Polk's Confederate line with the Huger family of South Carolina antebellum public men. The marriage produced six children, including Frances Devereux 'Fannie' Huger Labouisse (HD2603). Through Frances's son Henry Richardson Labouisse Jr., the union would extend to UNICEF's 1965 Nobel Peace Prize and into the Curie scientific dynasty."}],"slug":"elizabeth-polk-1843"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}