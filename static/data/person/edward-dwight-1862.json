ss_connections":[],"bio":{"display_name":"Theodore Woolsey Dwight","nickname":"Ted","first_name":"Theodore","last_name":"Dwight","middle_name":"Woolsey","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"theodore-dwight-1901"},"HD1992":{"id":"HD1992","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1827,"month":4,"day":8,"city":"Catskill","county":"Greene","state":"New York","country":"United States"},"death":{"year":1904,"month":3,"day":6,"city":"Oregon","county":"Dane","state":"Wisconsin","country":"United States"},"parents":{"father_id":"HD1967","mother_id":"X00638"},"marriages":[{"spouse_id":"X00644","children_ids":["HD2010","HD2011"],"marriage_number":1,"date_year":1848}],"tags":["farmer","republican_party","politician"],"sources":[{"label":"Wikipedia — Edward W. Dwight","url":"https://en.wikipedia.org/wiki/Edward_W._Dwight"},{"label":"WikiTree — Edward Woolsey Dwight outreach","url":"https://www.wikitree.com/wiki/Bizony-2"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["politics","agriculture"],"notable_blurb":"American farmer, frontier pioneer, and politician","primary_url":"https://en.wikipedia.org/wiki/Edward_W._Dwight","primary_url_label":"Wikipedia"},"cross_connections":[],"bio":{"display_name":"Edward Woolsey Dwight","first_name":"Edward","last_name":"Dwight","middle_name":"Woolsey","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Wisconsin frontier farmer for fifty-six years","body":"At twenty-one he married Elizabeth Foote and moved to Spring Prairie WI in Walworth County to farm. He spent the rest of his life — 56 years — as a Wisconsin farmer, far from the Dwight family's Yale-Hamilton-Columbia intellectual axis his brothers Theodore William and Benjamin Woodbridge occupied."},{"number":2,"category":"family","header":"Outlived four siblings in the Wisconsin countryside","body":"By the time he died at 76 in 1904 he had outlived all four of his siblings — Sophia (1863), Mary (1864), Theodore William (1892), and Benjamin Woodbridge (1889). He was buried in Oregon, Dane County WI, far from the family plot at Grove Street and Sunset Hill Cemetery."},{"number":3,"category":"adventure","header":"Whaling schooner at fifteen, year on Atlantic","body":"At fifteen he left his father's home and went to Boston, where he signed up on the whaling schooner Council and spent a year sailing the Atlantic Ocean. He returned to Boston and went to Clinton NY to work on a farm — the start of a 60-year agricultural career across three states."},{"number":4,"category":"politics","header":"Wisconsin State Assembly Republican, 1860","body":"He was active in the Republican Party and held various offices, culminating in his election to a single one-year term in the Wisconsin State Assembly in 1860 — Lincoln's election year. Dane County lost a seat in the subsequent assembly and he did not return to elected office for two decades."},{"number":5,"category":"politics","header":"Greenback Party presidential elector, 1880","body":"After the Civil War he spent a great deal of time studying financial questions. The result was a political pivot: in 1880 he served as a United States Presidential elector for the Greenback Party — a populist third party advocating greenback paper currency and against the gold standard. His brothers Theodore William and Benjamin Woodbridge remained Republican."}],"slug":"edward-dwight-1827"},"X00644":{"id":"X00644","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1827},"death":{"year":1905},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1992","children_ids":["HD2010","HD2011"],"marriage_number":1,"date_year":1848}],"gender":"female","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Foote","first_name":"Elizabeth","maiden_name":"Foote","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elizabeth-foote-1827"},"HD1967":{"id":"HD1967","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1780,"month":2,"day":10,"city":"Northampton","state":"Massachusetts","country":"United States"},"death":{"year":1850,"month":5,"day":18,"city":"Clinton","county":"Oneida","state":"New York","country":"United States"},"parents":{"father_id":"H00914","mother_id":"X00636"},"marriages":[{"spouse_id":"X00638","children_ids":["HD1988","HD1989","HD1990","HD1991","HD1992","HD1997_e"],"marriage_number":1,"date_year":1815}],"tags":["physician"],"sources":[],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Benjamin Woolsey Dwight","first_name":"Benjamin","last_name":"Dwight","middle_name":"Woolsey","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST027"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Physician","end_year":1831},{"role":"Treasurer","organization":"Hamilton College","location":"Clinton, NY","start_year":1831}],"narrative_blocks":[{"number":1,"category":"career","header":"Physician who became treasurer of Hamilton College","body":"A physician in Massachusetts and New York, in 1831 he relocated to Clinton NY to become treasurer of Hamilton College — where his brother Sereno Edwards Dwight would serve as the college's third president two years later. His daughter-line married into the Hamilton academic community."},{"number":2,"category":"family","header":"Father of Columbia Law School's founding dean","body":"Two of his sons became major American scholars: Benjamin Woodbridge Dwight, an educator and author, and Theodore William Dwight, who founded the Columbia Law School and served as its first dean for over thirty years. The Dwight line of academic prominence ran through his household."}],"slug":"benjamin-dwight-1780"},"X00638":{"id":"X00638","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1793},"death":{"year":1861},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1967","children_ids":["HD1988","HD1989","HD1990","HD1991","HD1992","HD1997_e"],"marriage_number":1,"date_year":1815}],"gender":"female","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sophia Woodbridge Strong","first_name":"Sophia","middle_name":"Woodbridge","maiden_name":"Strong","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779208807/sophiawoodbridgedwight_d9bvjj.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married as an invalid, expecting to die","body":"Weakened by a severe cold made worse by 'too unremitted attention to some favorite tasks in embroidery she had imposed upon herself,' she could not sit up and coughed blood with any exertion. In spring 1815 she was married to physician Benjamin Woolsey Dwight at her uncle's house in South Hadley MA in her sick gown, expecting to live only a little while."},{"number":2,"category":"family","header":"Recovered through her physician husband's care","body":"Her new husband, a trained physician, applied vigorous medical means over several months and she recovered her strength enough to enjoy comfortable health for many years afterward. She lived another forty-six years and bore five children including the future founder of Columbia Law School Theodore William Dwight and the educator-genealogist Benjamin Woodbridge Dwight."},{"number":3,"category":"family","header":"Mother of Yale, Hamilton, and Columbia educators","body":"Her six children spanned the New England intellectual elite: Benjamin Woodbridge Dwight (Yale Theology + genealogist), Theodore William Dwight (Columbia Law founder), Sophia (cousin marriage), Mary (Chicago Judge Anthony's first wife), Edward Woolsey (Wisconsin Greenback Party), and Elizabeth (Mary's widower's second wife)."},{"number":4,"category":"family","header":"Daughters' generation pioneered sister-replacement marriages","body":"Three of her daughters' generation in the Dwight family practiced sister-replacement marriage as a stabilization strategy after tuberculosis-era widow-hood: Julia Dwight then Mary Woolsey Dwight to Dr. Lyman (1847+1855); her own daughter Mary then Elizabeth to Judge Anthony (1852+1865); cousin Lucy Waterman then Elizabeth Adams to Rev. Edward Strong Dwight (1849+1864)."}],"slug":"sophia-strong-1793"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}