able_category":[]},"cross_connections":[],"bio":{"display_name":"Captain Joseph St. John","first_name":"Joseph","last_name":"St. John","title":"Captain","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"character","header":"Earned 'Blue Sheep' nickname by dyeing his flock","body":"Tradition holds that Capt. Joseph Saint John attempted to dye a sheep blue to create a matching flock — and the rains washed it out, leaving him with the lasting nickname 'The Blue Sheep.' He was a large landowner in Norwalk and among its founding civic leaders, serving as Selectman, Rate Constable, Fence Viewer, and Captain of the 1st Company of the Norwalk trainband (1748)."},{"number":2,"category":"legacy","header":"Wife Susanna's epitaph: Rachel's face, Leah's fruitful womb","body":"When Susanna Selleck Saint John died in December 1749 at forty, Capt. Joseph commissioned a tombstone epitaph comparing her to Rachel ('face'), Leah ('fruitful womb'), Abigail ('wisdom'), Lydia ('faithful heart'), and Martha ('care'). The epitaph — one of the most elaborate in the East Norwalk churchyard — captures how colonial Norwalk elites memorialized women through accumulated biblical virtues."}],"slug":"joseph-st-john-1703"},"H00253":{"id":"H00253","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1709,"month":9,"day":3,"city":"Stamford","state":"Connecticut"},"death":{"year":1749,"month":12,"day":4,"city":"Norwalk","state":"Connecticut"},"burial":{"cemetery_id":"CEM002","plot_notes":"East Norwalk Historical Cemetery, Norwalk, Fairfield, Connecticut"},"parents":{"father_id":"I00129","mother_id":"H00094"},"marriages":[{"children_ids":["HD0364","H00479","H00478","HD0367","H00481","H00482"],"spouse_id":"X00215","marriage_number":1,"date_year":1733}],"gravestone_inscription":"Susanna St. John, ye wife of Capt. Joseph St. John died December ye 4th, 1749 aged 40 years and 2 months. \"She that lies at rest within this tomb / Had Rachel's face and Leah's fruitful womb, / Abigail's wisdom, Lydia's faithful heart / With Martha's care — we hope Mary's better part.\"","tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 253"}],"enslaved_persons":[{"name":"Jenny","description":"Enslaved woman. Listed in estate inventory of Joseph St. John, Dec 7, 1756."},{"name":"London","description":"Enslaved man. Listed in estate inventory of Joseph St. John, Dec 7, 1756."},{"name":"Peter","description":"Enslaved boy. Listed in estate inventory of Joseph St. John, Dec 7, 1756."}],"cross_connections":[],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Susannah Selleck St. John","first_name":"Susannah","last_name":"St. John","married_names":["St. John"],"maiden_name":"Selleck"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Her mother died one month after her birth","body":"She was born September 3, 1709 in Norwalk. Her mother Hannah Hooker died October 5, 1709 — barely one month later, age nineteen, of complications from childbirth."},{"number":2,"category":"marriage","header":"Married 'The Blue Sheep' captain in 1729","body":"She married Capt. Joseph St. John in 1729 — known as 'The Blue Sheep' for the local tradition that he once dyed a sheep blue, though the rains washed it out. He served as Norwalk selectman seven times across thirty years."},{"number":3,"category":"social_reform","header":"Three generations of slaveholding descendants","body":"After her death, her husband's 1756 estate inventory listed three enslaved people: Jenny, London, and Peter. Three consecutive generations of her descendants held enslaved people — including grandson William St. John, who sent his enslaved man Dover to the Continental Army in his own place."}],"slug":"susannah-st-john-1709"},"I00129":{"id":"I00129","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1686,"month":9,"day":12,"city":"Stamford","state":"Connecticut"},"death":{"year":1772,"month":1,"day":15,"city":"Stamford","state":"Connecticut"},"parents":{"mother_research_notes":"Abigail Gold (also Gould)","father_research_notes":"Jonathan Selleck of Stamford"},"marriages":[{"spouse_id":"H00094","children_ids":["H00253"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1709,"date_year":1708,"date_month":8,"date_day":12},{"children_ids":[],"spouse_id":"X01166","marriage_number":2,"date_year":1710,"date_month":12,"date_day":2},{"children_ids":[],"spouse_id":"X01167","marriage_number":3,"date_year":1713,"date_month":1,"date_day":1,"location_city":"Hempstead","location_state":"New York"}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 94"}],"gender":"male","tags":[],"number_of_marriages":3,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Nathan Selleck I","first_name":"Nathan","last_name":"Selleck","suffix":"I","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"nathan-selleck-i-1686"},"H00094":{"id":"H00094","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1690,"month":6,"day":8,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00029","mother_id":"I00057"},"tags":["posthumous_birth","died_in_childbirth"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 94"}],"death":{"year":1709,"month":10,"day":5,"city":"Stamford","county":"Fairfield","state":"Connecticut","country":"United States","cause":"childbirth complications (died one month after daughter born Sept 3, 1709)"},"marriages":[{"marriage_number":1,"spouse_id":"I00129","date_year":1708,"date_month":8,"date_day":12,"location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1709,"children_ids":["H00253"]}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Born after her father died","body":"Her father William Hooker died in 1689; she was born June 8, 1690, after his death. Her mother Susanna Fenn Blackleach died around 1698 — leaving Susannah an orphan at approximately eight years old. She was raised in the Farmington household through the end of the seventeenth century."},{"number":2,"category":"death","header":"Died in childbirth at nineteen","body":"Her daughter Susannah was born on September 3, 1709. On October 5, 1709 — barely one month later — she died in Stamford at age 19. The cause is almost certainly childbirth complications."}],"cross_connections":[],"bio":{"display_name":"Susannah Hooker Selleck","first_name":"Susannah","last_name":"Selleck","married_names":["Selleck"],"maiden_name":"Hooker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[]