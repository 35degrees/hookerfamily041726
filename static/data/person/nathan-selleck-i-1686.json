amford"},"marriages":[{"spouse_id":"H00094","children_ids":["H00253"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1709,"date_year":1708,"date_month":8,"date_day":12},{"children_ids":[],"spouse_id":"X01166","marriage_number":2,"date_year":1710,"date_month":12,"date_day":2},{"children_ids":[],"spouse_id":"X01167","marriage_number":3,"date_year":1713,"date_month":1,"date_day":1,"location_city":"Hempstead","location_state":"New York"}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 94"}],"gender":"male","tags":[],"number_of_marriages":3,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Nathan Selleck I","first_name":"Nathan","last_name":"Selleck","suffix":"I","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"nathan-selleck-i-1686"},"H00094":{"id":"H00094","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1690,"month":6,"day":8,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00029","mother_id":"I00057"},"tags":["posthumous_birth","died_in_childbirth"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 94"}],"death":{"year":1709,"month":10,"day":5,"city":"Stamford","county":"Fairfield","state":"Connecticut","country":"United States","cause":"childbirth complications (died one month after daughter born Sept 3, 1709)"},"marriages":[{"marriage_number":1,"spouse_id":"I00129","date_year":1708,"date_month":8,"date_day":12,"location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1709,"children_ids":["H00253"]}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Born after her father died","body":"Her father William Hooker died in 1689; she was born June 8, 1690, after his death. Her mother Susanna Fenn Blackleach died around 1698 — leaving Susannah an orphan at approximately eight years old. She was raised in the Farmington household through the end of the seventeenth century."},{"number":2,"category":"death","header":"Died in childbirth at nineteen","body":"Her daughter Susannah was born on September 3, 1709. On October 5, 1709 — barely one month later — she died in Stamford at age 19. The cause is almost certainly childbirth complications."}],"cross_connections":[],"bio":{"display_name":"Susannah Hooker Selleck","first_name":"Susannah","last_name":"Selleck","married_names":["Selleck"],"maiden_name":"Hooker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"susannah-selleck-1690"},"H00253":{"id":"H00253","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1709,"month":9,"day":3,"city":"Stamford","state":"Connecticut"},"death":{"year":1749,"month":12,"day":4,"city":"Norwalk","state":"Connecticut"},"burial":{"cemetery_id":"CEM002","plot_notes":"East Norwalk Historical Cemetery, Norwalk, Fairfield, Connecticut"},"parents":{"father_id":"I00129","mother_id":"H00094"},"marriages":[{"children_ids":["HD0364","H00479","H00478","HD0367","H00481","H00482"],"spouse_id":"X00215","marriage_number":1,"date_year":1733}],"gravestone_inscription":"Susanna St. John, ye wife of Capt. Joseph St. John died December ye 4th, 1749 aged 40 years and 2 months. \"She that lies at rest within this tomb / Had Rachel's face and Leah's fruitful womb, / Abigail's wisdom, Lydia's faithful heart / With Martha's care — we hope Mary's better part.\"","tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 253"}],"enslaved_persons":[{"name":"Jenny","description":"Enslaved woman. Listed in estate inventory of Joseph St. John, Dec 7, 1756."},{"name":"London","description":"Enslaved man. Listed in estate inventory of Joseph St. John, Dec 7, 1756."},{"name":"Peter","description":"Enslaved boy. Listed in estate inventory of Joseph St. John, Dec 7, 1756."}],"cross_connections":[],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Susannah Selleck St. John","first_name":"Susannah","last_name":"St. John","married_names":["St. John"],"maiden_name":"Selleck"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Her mother died one month after her birth","body":"She was born September 3, 1709 in Norwalk. Her mother Hannah Hooker died October 5, 1709 — barely one month later, age nineteen, of complications from childbirth."},{"number":2,"category":"marriage","header":"Married 'The Blue Sheep' captain in 1729","body":"She married Capt. Joseph St. John in 1729 — known as 'The Blue Sheep' for the local tradition that he once dyed a sheep blue, though the rains washed it out. He served as Norwalk selectman seven times across thirty years."},{"number":3,"category":"social_reform","header":"Three generations of slaveholding descendants","body":"After her death, her husband's 1756 estate inventory listed three enslaved people: Jenny, London, and Peter. Three consecutive generations of her descendants held enslaved people — including grandson William St. John, who sent his enslaved man Dover to the Continental Army in his own place."}],"slug":"susannah-st-john-1709"},"X00215":{"id":"X00215","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"label":"St. John Genealogy (Alexander, 1907)","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"}],"birth":{"year":1703},"death":{"year":1756},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00253","date_year":1733,"children_ids":["HD0364","H00479","H00478","HD0367","H00481","H00482"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Captain Joseph St. John","first_name":"Joseph","last_name":"St. John","title":"Captain","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"character","header":"Earned 'Blue Sheep' nickname by dyeing his flock","body":"Tradition holds that Capt. Joseph Saint John attempted to dye a sheep blue to create a matching flock — and the rains washed it out, leaving him with the lasting nickname 'The Blue Sheep.' He was a large landowner in Norwalk and among its founding civic leaders, serving as Selectman, Rate Constable, Fence Viewer, and Captain of the 1st Company of the Norwalk trainband (1748)."},{"number":2,"category":"legacy","header":"Wife Susanna's epitaph: Rachel's face, Leah's fruitful womb","body":"When Susanna Selleck Saint John died in December 1749 at forty, Capt. Joseph commissioned a tombstone epitaph comparing her to Rachel ('face'), Leah ('fruitful womb'), Abigail ('wisdom'), Lydia ('faithful heart'), and Martha ('care'). The epitaph — one of the most elaborate in the East Norwalk churchyard — captures how colonial Norwalk elites memorialized women through accumulated biblical virtues."}],"slug":"joseph-st-john-1703"},"HD0364":{"id":"HD0364","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1733,"month":12,"day":6,"city":"Norwalk","state":"Connecticut"},"parents":{"mother_id":"H00253","father_research_notes":"Capt. Joseph St. John of Norwalk","father_id":"X00215"},"tags":["died_young"],"sources":[],"death":{"year":1741,"month":4,"day":18,"city":"Norwalk","state":"Connecticut"},"gender":"female","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sarah St. John","first_name":"Sarah","maiden_name":"St. John","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Sarah died young","body":"Sarah died in 1741 at the age of seven."}],"slug":"sarah-st-john-1733"},"H00479":{"id":"H00479","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1736,"city":"Norwalk","state":"Connecticut"},"parents":{"mother_id":"H00253","father_research_notes":"Capt. Joseph St. John of Norwalk","father_id":"X00215"},"tags":["revolutionary_war","slaveholder","moral_complexity"],"sources":[{"short":"Edward Hooker 1909","page":"H00253 branch"},{"label":"St. John Genealogy — entry 141","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"}],"death":{"year":1785,"month":5,"day":9,"city":"Norwalk","state":"Connecticut"},"political_offices":[{"title":"Selectman Norwalk","notes":"1763-64, 1766, 1772-73, 1775-78, 1782-84"},{"title":"Member CT House of Representatives","dates":"1778-1785"},{"title":"Major, 9th CT Regiment","dates":"May 1775"},{"title":"Lt. Colonel, 9th CT Militia","dates":"May 1777"},{"title":"Justice of the Peace","dates":"May 1777"}],"enslaved_persons":[{"name":"Peter","description":"Enslaved man. Listed in 1786 estate inventory."},{"name":"Phyllis","description":"Enslaved woman. Listed in 1786 estate inventory."}],"marriages":[{"spouse_id":"X00216","children_ids":["H01238","H01239","H01237","H01240","H01236"],"marriage_number":1,"date_year":1757,"date_month":12,"date_day":9}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"military_service":[{"war":"American Revolutionary War","rank":"Lt. Col.","unit":"9th Regiment, Connecticut Militia","notes":"Capt. 1st Co. Norwalk May 1761; Major 9th Regt. May 1775; Major 1st Batt. Col. Whiting Nov 1776; Lt. Col. 9th Regt. May 1777. On committee of Articles of Confederation 1777.","war_id":"WAR004"}],"bio":{"display_name":"Lt. Col. Stephen Saint John","first_name":"Stephen","last_name":"St. John","title":"Lieutenant Colonel","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778792414/stephenstjohnesq-resized_cvqbdg.png","photo_notes":"Portrait of Lt. Col. Stephen Saint John Esq.","bio_blurb":"Norwalk officer of the Connecticut 9th"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"former_ids":["HD0365"],"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave #44152495. Stone: 'Lt Col command of the 9th Reg of Foot Guard of the State of Connecticut who departed this life May the 9th 1785, in the 50th year of his age.'"},"narrative_blocks":[{"number":1,"category":"military","header":"Led Connecticut's 9th Regiment of Foot as Lt.","body":"Stephen Saint John rose to Lieutenant Colonel in command of the 9th Regiment of Foot, Guard of the State of Connecticut — a rank inscribed on his tombstone in East Norwalk Historical Cemetery. His family's marriage alliances connected two of Norwalk's most prominent dynasties: the Saint Johns married into the Fitches across two consecutive generations."},{"number":2,"category":"military","header":"He sent no substitute; his brother did","body":"A Connecticut selectman and Revolutionary officer, he led the colony’s 9th Regiment of Foot. When the war came, an enslaved man named Dover was sent to fight in the Continental Army in place of his brother — while his own household still held two people, Peter and Phyllis, at his death."}],"career":[{"role":"Selectman","organization":"Norwalk, Connecticut","notes":"1763-1784"},{"role":"Representative","organization":"Connecticut House","notes":"1778-1785"},{"role":"Lt. Colonel","organization":"9th Connecticut Regiment"}],"slug":"stephen-st-john-1736"},"H00478":{"id":"H00478","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"descent_paths_to_thomas":1,"is_progenitor":false},"birth":{"year":1743,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"parents":{"father_name":"Capt. Joseph St. John of Norwalk","mother_id":"H00253","mother_name":"Susannah Selleck St. John","father_research_notes":"Capt. Joseph St. John of Norwalk CT; d. 1756. His estate included enslaved people.","father_id":"X00215"},"tags":[],"sources":[{"label":"FindAGrave — Susannah St. John Lockwood","url":"https://www.findagrave.com/memorial/155694447/eliphalet-lockwood"}],"death":{"year":1810,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"marriages":[{"marriage_number":1,"spouse_id":"X00218","date_year":1776,"date_month":6,"date_day":8,"location_city":"Norwalk","location_county":"Fairfield County","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1810,"children_ids":["H01229","H01230","H01231","H01232","H01233","H01234","H01235"]}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Susannah St. John Lockwood","first_name":"Susannah","last_name":"Lockwood","maiden_name":"St. John","married_names":["Lockwood"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["HD0366"],"is_placeholder":false,"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave — East Norwalk Historical Cemetery"},"education":[],"career":[],"narrative_blocks":[{"number":1,"category":"family","header":"Orphaned at six; married the town's future captain","body":"Her mother Susannah Selleck died in December 1749 when Susannah was barely six, and her father Capt. Joseph St. John died in 1756 when she was thirteen, leaving her to grow up in Norwalk without either parent. She married Captain Eliphalet Lockwood at thirty-three — he would go on to lose his home to British torches and organize the city's first volunteer fire department."}],"slug":"susannah-lockwood-1743"},"HD0367":{"id":"HD0367","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1742},"parents":{"mother_id":"H00253","father_research_notes":"Capt. Joseph St. John of Norwalk","father_id":"X00215"},"tags":["never_married","named_for_hooker"],"sources":[],"death":{"year":1782,"month":3,"day":10,"city":"Norwalk","state":"Connecticut"},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Hooker St. John","first_name":"Hooker","last_name":"St. John","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"hooker-st-john-1742"},"H00481":{"id":"H00481","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1744,"month":4,"day":7,"city":"Norwalk","state":"Connecticut"},"parents":{"mother_id":"H00253","father_research_notes":"Capt. Joseph St. John of Norwalk","father_id":"X00215"},"tags":["yale_graduate","revolutionary_war","slaveholder","moral_complexity"],"sources":[{"label":"St. John Genealogy — entry 144","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"},{"label":"DAR Patriot Ancestor A099267","url":"https://services.dar.org/Public/DAR_Research/search_adb/?action=full&p_id=A099267"}],"death":{"year":1800,"month":2,"day":1,"city":"Norwalk","state":"Connecticut"},"marriages":[{"children_ids":["H01241","H01242","H01246","H01243","H01244","H01245"],"spouse_id":"X00217","marriage_number":1,"date_year":1777,"date_month":6,"date_day":19}],"enslaved_persons":[{"name":"Dover","description":"Enslaved man, jointly owned with brother Stephen. On June 3, 1777, William sent Dover to fight in the Continental Army in his stead, receiving half-ownership of Dover as credit from Stephen. \"Received of my brother Stephen St. John, the one half of his Negro boy named Dover, now inlisted into the Continental Service, for the one half of which boy I am obliged to pay sixty dollars on demand, to exempt me from all actual service. William St. John.\" William was a Loyalist; his wife's 1800 census shows 1 enslaved person still in household."}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"education":[{"notes":"A.B. 1766, A.M. 1769. Same class as Jared Ingersoll and Jonathan Ingersoll.","school_name":"Yale College","graduation_year":1766,"institution_id":"INST022"}],"bio":{"display_name":"William St. John","first_name":"William","last_name":"St. John","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1762-1766","institution_blurb":"Yale A.B. 1766, A.M. 1769 — same class as Hons. Jared and Jonathan Ingersoll of Connecticut."}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["HD0368"],"burial":{"cemetery_id":"CEM002","plot_notes":"East Norwalk Historical Cemetery. FA confirmation."},"narrative_blocks":[{"number":1,"category":"education","header":"Yale class of 1766","body":"William Saint John graduated Yale with A.B. 1766 and A.M. 1769, in the same class as Hon. Jared and Jonathan Ingersoll — two of Connecticut's most prominent legal and political figures — and served as private tutor in the wealthy Phillipse family of Phillipse, New York. He was described by contemporaries as 'a very fine looking, superior man, a person of fine address and manners, presiding handsomely at his own table.'"},{"number":2,"category":"legacy","header":"Two verdicts: DAR Patriot Ancestor and colonial Loyalist","body":"One chronicler records that Saint John 'was a Loyalist and was sent to New York with the Army,' yet he is simultaneously honored as a DAR Patriot Ancestor (A099267) for Civil Service during the Revolution — a tension common among colonial Norwalk families divided by the conflict. In June 1777 he received from his brother Stephen 'the one half of his Negro boy named Dover, now inlisted into the Continental Service,' paying sixty dollars to exempt himself from actual military service."},{"number":3,"category":"death","header":"Suffered heavy losses when Tryon burned Norwalk, 1779","body":"William Saint John suffered significant property losses in General Tryon's burning of Norwalk in July 1779, the same raid that destroyed or damaged much of the town. He died February 1, 1800, in his fifty-sixth year — survived by his wife Mary Esther Belden, who would outlive him by fifty years, dying at ninety-seven in 1850."}],"slug":"william-st-john-1744"},"H00482":{"id":"H00482","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1745,"city":"Norwalk","state":"Connecticut"},"death":{"year":1771,"month":5,"day":4,"cause":"Drowned"},"parents":{"mother_id":"H00253","father_research_notes":"Capt. Joseph St. John","father_id":"X00215"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 482"}],"gender":"unknown","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"education":[{"notes":"Tutor at Yale at time of death","school_name":"Yale College","institution_id":"INST022"}],"bio":{"display_name":"Buckingham St. John","first_name":"Buckingham","last_name":"St. John","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"