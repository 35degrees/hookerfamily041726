e":"Heart attack"},"burial":{"cemetery_id":"CEM076"},"parents":{"father_id":"H02976","mother_id":"X02046"},"marriages":[{"marriage_number":1,"spouse_id":"X02050","children_ids":["HD3014"],"end_type":"death_of_spouse","end_year":1914,"date_year":1897},{"marriage_number":2,"spouse_id":"X02051","children_ids":[],"date_year":1918}],"number_of_marriages":2,"tags":["new_york_migration"],"sources":[{"short":"The Daily Messenger, Canandaigua NY, Feb 24 1953"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"He outlived both his wives","body":"Herbert Safford Gillette married twice: first to Gertrude May Courter (died 1914), then to Gertrude Fiege (died June 7, 1951). Herbert died February 22, 1953 — less than two years after his second wife. He had lived in East Bloomfield, New York for 21 years when he died of a heart attack at 77.","number":1}],"cross_connections":[],"bio":{"display_name":"Herbert Safford Gillette","first_name":"Herbert","last_name":"Gillette","married_names":[],"middle_name":"Safford"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"herbert-gillette-1875"},"H02977":{"id":"H02977","is_placeholder":false,"gender":"male","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1842,"month":8,"day":1,"city":"Bloomfield","state":"Connecticut"},"death":{"year":1865,"month":1,"day":16,"city":"Fort Fisher","county":"New Hanover County","state":"North Carolina","cause":"Killed at the capture of Fort Fisher — explosion of the magazine"},"parents":{"father_id":"I00173","mother_id":"H01625"},"marriages":[],"number_of_marriages":0,"tags":["civil_war","killed_in_action","named_for_hooker"],"sources":[{"label":"Hartford obituary — Death of Paymaster Gillette, 1865"},{"label":"NY State Military Museum — CDV photograph collection"},{"short":"EH 1909","page":"Entry 2977"}],"notable":{"is_notable":false,"notable_category":[]},"burial":{"cemetery_id":"CEM073","plot_notes":"Hooker family plot"},"narrative_blocks":[{"header":"Killed the morning after Fort Fisher surrendered","body":"Robert Hooker Gillette was paymaster aboard the U.S.S. Gettysburg during both assaults on Fort Fisher. On the morning of January 16, 1865 — after the battle was over and the fort had surrendered — he went in with others to inspect the damage. Drunk Federal soldiers, sailors, and marines, carrying torches and firing weapons, accidentally ignited the Confederate powder magazine.","number":1},{"header":"He had traveled to China and California before","body":"Before the war, Robert had traveled to China, California and other distant fields before turning 18. He helped recruit two companies of men, then joined the 14th Connecticut as a Captain — but a fever from exposure at Harpers Ferry shattered his health and he resigned his commission. In 1863 he was appointed assistant paymaster in the Navy, serving aboard blockade ships along the North Carolina coast.","number":2}],"cross_connections":[],"bio":{"display_name":"Paymaster Robert Hooker Gillette","first_name":"Robert","last_name":"Gillette","married_names":[],"middle_name":"Hooker","title":"Paymaster","photo_url":"https://images.findagrave.com/photos/2019/146/10462312_b03bf344-bc8b-461e-b891-0b39c81e001b.jpeg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"robert-gillette-1842"},"H02978":{"id":"H02978","is_placeholder":false,"gender":"female","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1845,"month":6,"day":24,"city":"Bloomfield","state":"Connecticut"},"death":{"year":1845,"month":8,"day":27},"parents":{"father_id":"I00173","mother_id":"H01625"},"marriages":[],"number_of_marriages":0,"tags":["died_in_infancy","named_for_hooker"],"sources":[{"short":"EH 1909","page":"Entry 2978"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"Died in infancy — year unknown","body":"Mary Hooker Gillette was born June 24, 1845 in Bloomfield, Connecticut. EH 1909 records her death as August 27 of an unspecified year — most likely within days or weeks of her birth. The year in the EH text is cut off.","number":1}],"cross_connections":[],"bio":{"display_name":"Mary Hooker Gillette","first_name":"Mary","last_name":"Gillette","maiden_name":"Gillette","married_names":[],"middle_name":"Hooker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-gillette-1845"},"H02979":{"id":"H02979","is_placeholder":false,"gender":"male","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1853,"month":7,"day":24,"city":"Hartford","state":"Connecticut"},"death":{"year":1937,"month":4,"day":29,"city":"Hartford","state":"Connecticut"},"parents":{"father_id":"I00173","mother_id":"H01625"},"marriages":[{"marriage_number":1,"spouse_id":"X02047","end_type":"death_of_spouse","end_year":1888,"children_ids":[],"date_year":1882,"date_month":6,"date_day":1}],"number_of_marriages":1,"tags":["artist","author","named_for_hooker","inventor"],"sources":[{"label":"Wikipedia — William Gillette","url":"https://en.wikipedia.org/wiki/William_Gillette"},{"label":"Gillette Castle State Park","url":"https://en.wikipedia.org/wiki/Gillette_Castle_State_Park"}],"notable":{"is_notable":true,"notable_category":["arts","literature"],"notable_blurb":"Defined Sherlock Holmes on stage; built famed castle","primary_url":"https://en.wikipedia.org/wiki/William_Gillette","primary_url_label":"Wikipedia"},"cross_connections":[{"type":"mentor_student","related_id":"X02039","display_label":"Twain got him his first acting job at the Globe, 1875","link_text":"Mark Twain"}],"burial":{"cemetery_id":"CEM073"},"landmarks":[{"landmark_id":"LM036","landmark_blurb":"Built Gillette Castle 1914-1919 as his home; designed it himself including 47 unique locks, secret passages, and a miniature railway."}],"institutions":[{"institution_id":"INST022","institution_blurb":"No formal Yale degree; educated Hartford High School, College of the City of New York, and Boston University."}],"narrative_blocks":[{"number":1,"category":"career","header":"Defined Sherlock Holmes on stage for thirty years","body":"He performed Sherlock Holmes more than 1,300 times across more than thirty years, in his own 1899 stage adaptation written with Conan Doyle's blessing. The play established Holmes's deerstalker silhouette and 'Elementary, my dear Watson' as cultural shorthand."},{"number":2,"category":"legacy","header":"Invented Holmes's iconic curved calabash pipe","body":"Sidney Paget's straight pipe from the Strand illustrations was impractical on stage, so he introduced the curved calabash. He needed to speak his lines while smoking, and the curved stem freed his mouth — the pipe became Holmes's most enduring visual signature."},{"number":3,"category":"character","header":"Built a 24-room castle above the Connecticut River","body":"He designed every detail of his East Haddam fieldstone castle himself between 1914 and 1919 — 47 unique trick-locked doors, secret passages, mirrors above the great hall to spy on arriving guests, and a spring-loaded bar. It is now Gillette Castle State Park."}],"bio":{"display_name":"William Hooker Gillette","first_name":"William","last_name":"Gillette","married_names":[],"middle_name":"Hooker","photo_url":"https://www.wikitree.com/photo.php/8/86/Gillette-574.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"artworks":[],"quotes":[],"military_service":[],"slug":"william-gillette-1853"},"X02047":{"id":"X02047","is_placeholder":false,"gender":"female","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1860,"month":8,"day":3,"city":"Detroit","state":"Michigan"},"death":{"year":1888,"month":9,"day":1,"city":"Cos Cob","state":"Connecticut","cause":"Died age 28"},"parents":{"father_research_notes":"David A. Nickles","mother_research_notes":"Pamela Merrick Nickles"},"marriages":[{"marriage_number":1,"spouse_id":"H02979","children_ids":[],"date_year":1882,"date_month":6,"date_day":1}],"number_of_marriages":1,"tags":[],"sources":[{"short":"EH 1909","page":"Entry 2979"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"She died at 28","body":"Helen Nickles Gillette married William Hooker Gillette on June 1, 1882 in Windsor, Ontario. She died on September 1, 1888 at Cos Cob, Connecticut, age 28. William Gillette never remarried.","number":1}],"cross_connections":[],"bio":{"display_name":"Helen Nickles Gillette","first_name":"Helen","last_name":"Gillette","maiden_name":"Nickles","married_names":["Gillette"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"hel