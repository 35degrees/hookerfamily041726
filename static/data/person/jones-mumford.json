er children of Detroit, married Charles B. Northrup in 1867, and carried both the Mumford and Winder names as testament to her mother's brief life."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"History of Descendants of Elder John Strong, Vol. 1 (1871)","url":"https://dn720908.ca.archive.org/0/items/historyofdescend0001dwig/historyofdescend0001dwig.pdf"},{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"eliza-mumford-1822"},"HD4634":{"id":"HD4634","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Eliza","middle_name":"M","last_name":"Northrop","maiden_name":"Mumford","married_names":["Northrop"],"gender":"female","display_name":"Eliza M. Mumford Northrop"},"birth":{"year":1843,"month":8,"day":23,"city":"New York","county":"New York County","state":"New York","country":"United States"},"baptism":{},"death":{"year":1930,"month":12,"day":1,"city":"Detroit","county":"Wayne County","state":"Michigan","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM484","plot_notes":"Woodmere Cemetery Detroit per FA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"generation_from_john_talcott":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00921","mother_id":"H02019"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00971","location_country":"United States","children_ids":["HD4714","HD4715"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Orphaned at ten months; lived eighty-seven years","body":"Eliza M. Mumford was born on August 23, 1843 in New York City, and her mother Eliza Hooker Strong died in Rochester in June 1844 when she was only ten months old — leaving her to be raised by her father Samuel Jones Mumford, who himself died in September 1850 when she was seven. She went on to outlive both parents by many decades, dying in Detroit on December 1, 1930 at age eighty-seven, having lived from Manhattan's antebellum world through the Civil War, the settling of the West, and the first World War."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"eliza-northrop-1843"},"I00971":{"id":"I00971","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Charles","middle_name":"Barzellac","last_name":"Northrop","married_names":[],"gender":"male","display_name":"Charles Barzellac Northrop"},"birth":{"year":1836,"month":5,"day":11,"state":"New York","country":"United States"},"baptism":{},"death":{"year":1901,"month":1,"day":16,"city":"Detroit","county":"Wayne County","state":"Michigan","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM484","plot_notes":"Woodmere Cemetery Detroit per FA"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4634","location_country":"United States","c