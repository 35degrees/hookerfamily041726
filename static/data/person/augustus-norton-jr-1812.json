:[{"number":1,"category":"military","header":"Mustered as Private at age sixteen","body":"Zebul Norton enlisted as a Private in Captain James Peck's Company, 3rd Battalion under Colonel Roger Enos in Wooster's Brigade of the Connecticut State Troops on September 17, 1777 — at age sixteen. He served the Revolutionary cause and returned home to Connecticut, where he married Rhoda Norton in 1782 and fathered four children before dying about 1803."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"zebul-norton-1761"},"HD3441":{"id":"HD3441","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Rhoda","last_name":"Norton","maiden_name":"Norton","married_names":["Norton"],"gender":"female","display_name":"Rhoda Norton"},"birth":{"year":1763,"city":"Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1840,"month":4,"city":"Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":6,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H00398","mother_id":"X02452"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02456","date_year":1782,"date_month":6,"date_day":12,"location_city":"Waterbury","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1803,"children_ids":["HD3442","HD3443","HD3444","HD3445"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Eldest daughter omitted from EH's record","body":"Rhoda Norton was born in 1763 — three years before her brother Josiah, the eldest child whom Edward Hooker named in his 1909 genealogy. WikiTree documents Rhoda's marriage to Zebul Norton in Waterbury in 1782 and four children. The reason for her omission from EH is not established; she may have been overlooked as a daughter who married out of Connecticut documentation."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"rhoda-norton-1763"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}