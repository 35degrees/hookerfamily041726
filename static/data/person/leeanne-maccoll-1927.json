ources":[],"marriages":[{"marriage_number":1,"spouse_id":"I01305","date_year":1910,"date_month":4,"date_day":28,"end_type":"divorce","children_ids":[]},{"marriage_number":2,"spouse_id":"I01306","date_year":1928,"date_month":6,"date_day":28,"end_type":"death_of_spouse","end_year":1955,"children_ids":["HD5136"]}],"number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1891,"month":3,"day":11,"city":"Flushing","state":"New York","country":"United States"},"death":{"year":1970,"month":4,"day":13,"city":"Palm Beach","state":"Florida","country":"United States","age":79},"residence":{},"burial":{"plot_notes":"Gwynne family plot, Fair Mount Cemetery Chatham NJ (cremated remains)"},"baptism":{},"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Second husband Walter Gwynne uncle of actor","body":"Anita's second husband Walter Lee Gwynne (1881-1955), the New York stockbroker she married in 1928, was the uncle of actor Fred Gwynne (1926-1989) — Herman Munster on The Munsters and Judge Chamberlain Haller in My Cousin Vinny. The Gwynne family connection brought twentieth-century popular culture into the Ingersoll-Bristol-Hooker line. Walter and Anita lived in New York and Bermuda before moving to Delray Beach Florida."},{"number":2,"category":"family","header":"Twice-married after 1910 Minton divorce, NY society","body":"Anita first married Roger Medina Minton of New York on April 28, 1910 at age nineteen — they had one daughter Anita Minton before divorcing. After her divorce she moved to Santa Barbara California briefly before her 1928 second marriage to Walter Gwynne. The two-marriage pattern was unusual for early twentieth-century Ingersoll family women, and her cremated remains were ultimately buried in the Gwynne family plot at Fair Mount Cemetery Chatham New Jersey."},{"number":3,"category":"family","header":"Flushing Queens 1891 to Palm Beach 1970","body":"Anita Ingersoll was born March 11, 1891 in Flushing Queens New York and died April 13, 1970 in Palm Beach Florida at age seventy-nine. She was the daughter of Judge Charles Dennis Ingersoll (NYC lawyer-judge) and Katharine Corse Sanders Varnum Ingersoll. Her brothers and sister Hamilton, Justine continued the New York/Connecticut Ingersoll legal-and-professional traditions."}],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Anita Gwynne","first_name":"Anita","last_name":"Gwynne","maiden_name":"Ingersoll","married_names":["Minton","Gwynne"],"gender":"female","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779825011/anitagwynee_cijrgp.jpg"},"slug":"anita-gwynne-1891"},"HD5129":{"id":"HD5129","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":1,"descent_from_thomas_hooker_bool":true},"parents":{"father_id":"HD5112","mother_id":"I01302"},"tags":["judge","lawyer"],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"I01303","date_year":1885,"date_month":6,"date_day":2,"location_city":"Manhattan","location_state":"New York","location_country":"United States","end_type":"death","end_year":1905,"children_ids":["HD5132","HD5133","HD5134"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1843,"month":1,"day":15,"city":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1905,"month":1,"day":8,"city":"Manhattan","state":"New York","country":"United States","age":61},"residence":{},"burial":{"plot_notes":"Green-Wood Cemetery, Greenwood Heights Brooklyn NY"},"baptism":{},"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"NYC judge continuing Ingersoll legal tradition","body":"Charles Dennis Ingersoll continued the Ingersoll family legal tradition across the New York and Connecticut bars — making him the fourth consecutive generation of Ingersoll lawyers and judges descending from Rev. Jonathan Ingersoll. His grandfather Jonathan Ingersoll Jr. was Lieutenant Governor of Connecticut; his father Charles Anthony Ingersoll was a US federal judge; his uncle Ralph Isaacs Ingersoll was a US Congressman and Minister to Russia; his cousin Charles Roberts Ingersoll became Governor of Connecticut. The Ingersoll legal dynasty spanned 1747-1905 (Rev. Jonathan to Charles Dennis) across five generations."},{"number":2,"category":"family","header":"Married widow Katharine Sanders Varnum, 1885","body":"Charles Dennis married Katharine Corse Sanders Varnum on June 2, 1885 in Manhattan New York — she had previously been married to Robert Taylor Varnum. The couple had three children together: Hamilton Ingersoll (1888-1940), Anita Ingersoll Gwynne (1891-1970), and Justine Ingersoll Arnold (1893-1984). His grandchildren through these three children form the documented twentieth-century Ingersoll-Arnold-Gwynne descendants of the original Connecticut bar family."},{"number":3,"category":"family","header":"New Haven 1843 to Manhattan 1905, Green-Wood Cemetery","body":"Charles Dennis Ingersoll was born January 15, 1843 in New Haven Connecticut and died January 8, 1905 in Manhattan New York at age sixty-one. He is buried at Green-Wood Cemetery in Greenwood Heights Brooklyn New York — breaking the Ingersoll family Grove Street Cemetery tradition through his NYC career. His wife Katharine died in Menton France in 1922."}],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_na