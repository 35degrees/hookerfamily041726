:3,"date_year":1935}],"gender":"male","number_of_marriages":3,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Doctor George Burton Gilbert","first_name":"George","last_name":"Gilbert","title":"Doctor","middle_name":"Burton","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"},{"institution_id":"INST146"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Pioneered collapse therapy for tuberculosis in Colorado","body":"Dr. George Burton Gilbert pioneered collapse therapy for tuberculosis as resident physician at Cragmor Sanatorium in Colorado Springs — the leading early-twentieth-century American TB sanatorium. He worked as associate of Dr. Gerald B. Webb, the era's most prominent American TB physician and a founder of the National Tuberculosis Association. Gilbert earned wide recognition for his TB treatment work across the western American medical community."},{"number":2,"category":"character","header":"Tuberculosis interrupted his Johns Hopkins training","body":"Gilbert was sent to Saranac Lake — the Adirondack TB-treatment village — during his Johns Hopkins Medical School years after contracting tuberculosis himself. He completed the medical degree despite the interruption and later turned his own patient experience into a career treating others with the disease. His Colorado Springs move from his Hartford internship was both for the dry climate and for the Cragmor opportunity."},{"number":3,"category":"character","header":"Attended Saturday morning conferences until the last","body":"Even after ill health forced his retirement from active practice, Gilbert continued unremitting reading of medicine and attended the weekly clinical-pathological staff conference every Saturday morning until the very last week of his life. He died of coronary thrombosis on April 6, 1951 at age sixty-nine. The lifelong-learning discipline reflected the unbroken professional commitment characteristic of early-twentieth-century American physicians."},{"number":4,"category":"family","header":"Yale 1903, Hopkins MD 1907, three marriages","body":"Gilbert graduated Yale College in 1903 — having planned to enter the ministry but received a legacy that enabled medical school at Johns Hopkins instead, where he graduated in 1907. He served as Regional Regent of the American College of Chest Physicians and held memberships in the American Board of Internal Medicine, American Trudeau Society, and American College of Physicians. He had three marriages across his life."}],"slug":"george-gilbert-1881"},"X00378":{"id":"X00378","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1183","date_year":1915,"children_ids":["HD1213"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Elinor Elgin Drane Lillard","first_name":"Elinor Elgin Drane","maiden_name":"Lillard","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elinor-elgin-drane-lillard"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}