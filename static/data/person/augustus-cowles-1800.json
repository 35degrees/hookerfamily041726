ought stepchildren from her first marriage into the Farmington Cowles household."}],"slug":"james-cowles-1723"},"H00287":{"id":"H00287","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1736,"month":2,"day":5,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00102","mother_id":"I00132"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 287"},{"short":"WikiTree (online genealogy)","url":"https://www.wikitree.com/"},{"short":"Connecticut Town Marriage Records pre-1870 (Barbour Collection)"},{"short":"Find a Grave — Memento Mori Cemetery Farmington CT","url":"https://www.findagrave.com/cemetery/53048/memento-mori-cemetery"},{"short":"Edward Hooker 1909"}],"death":{"year":1772,"month":2,"day":27,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM254","plot_notes":"Find a Grave memorial — Memento Mori Cemetery"},"marriages":[{"children_ids":["H00613","H00614","H00615","H00616","H00617","H00618","H00619"],"spouse_id":"X00260","marriage_number":1,"date_year":1753,"date_month":8,"date_day":30,"location_city":"Farmington","location_state":"Connecticut","location_county":"Hartford","location_country":"United States","end_type":"death","end_year":1772}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"family_connection","related_id":"H00232","display_label":"Her second cousin Martha married her husband's older brother Ezekiel.","link_text":"Martha Hooker Cowles"}],"bio":{"display_name":"Abigail Hooker Cowles","first_name":"Abigail","last_name":"Cowles","maiden_name":"Hooker","married_names":["Cowles"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Died at thirty-six leaving seven children","body":"Abigail married James E. Cowles in August 1753 — same Farmington family network that produced her cousin Martha's marriage to James's older brother Ezekiel a decade earlier. She bore seven children between 1754 and 1771 and died at thirty-six in February 1772, eighteen months before her husband remarried Mary Bull."},{"number":2,"category":"marriage","header":"She and her cousin married Cowles brothers","body":"Abigail and her second cousin Martha Hooker Cowles married brothers — Abigail to James E. Cowles in 1753, Martha to Ezekiel Cowles a decade earlier. Both Hooker cousins descended from Rev. Samuel Hooker through different sons; both Cowles brothers were sons of Capt. Isaac Cowles by his third wife Elizabeth Smith."}],"slug":"abigail-cowles-1736"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}