,"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Three wives, three children buried by 1841","body":"Ezra outlived his first two wives — Esther in 1836 and Mary in 1853 — and buried three of his five children before they reached age seven. Only Ezra Leander, born 1844 to his third wife, reached adulthood, and he never married."}],"quotes":[],"sources":[{"label":"FindAGrave memorial 127199478","url":"https://www.findagrave.com/memorial/127199478/ezra-stiles"}],"research_sources":[],"documents":[],"slug":"ezra-stiles-1804"},"HD1446":{"id":"HD1446","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00877","mother_id":"X00468"},"tags":["cousin_marriage"],"sources":[{"short":"Online vital records / Pierpont genealogy"}],"birth":{"year":1805},"death":{"year":1836,"month":9,"day":26,"country":"United States"},"gender":"female","marriages":[{"marriage_number":1,"spouse_id":"H01186","date_year":1829,"date_month":4,"date_day":30,"location_city":"North Haven","location_county":"New Haven County","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1836,"children_ids":["HD4087","HD4088"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"parallel_marriage","related_id":"HD1460","display_label":"Married Stiles brothers; second cousins themselves","link_text":"Lois Pierpont Stiles"}],"bio":{"display_name":"Esther Pierpont Stiles","first_name":"Esther","last_name":"Stiles","maiden_name":"Pierpont","married_names":["Stiles"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"death","header":"Mother and infant buried in same casket, 1836","body":"Esther Pierpont Stiles died September 26, 1836 in North Haven Connecticut at age thirty-one. Her six-month-old daughter Esther Josephine died the following day, September 27 — and per family tradition mother and infant were buried in the same casket. Her only surviving child, son Charles William Stiles born February 1833, died August 7, 1840 at age seven, ending her direct line within four years of her own death."},{"number":2,"category":"family","header":"Cousin marriage; sisters wed Stiles brothers","body":"Esther's 1829 marriage to Ezra Stiles was a documented Pierpont-Stiles cousin marriage — her father Daniel Pierpont and Lois Pierpont Stiles's father Benjamin Pierpont Jr. were first cousins, both grandsons of Joseph Pierpont. That made Esther and her second cousin Lois Pierpont Stiles both Hooker descendants, and the two women married brothers — Ezra and Horace Stiles. Two Hooker-Pierpont cousin marriages between siblings of two intermarried families."},{"number":3,"category":"family","header":"Husband's later marriages also ended in early death","body":"Ezra Stiles outlived Esther by half a century but his second marriage in 1837 also ended in his second wife's death at age forty-two in 1853. His third marriage in 1854 to Frances Elizabeth Johnson produced a third Charles, who likewise died at age six. The repeated pattern across three marriages — early-widowed wives, sons named Charles dying young — marks one of the more striking grief sequences in the Stiles branch records."}],"slug":"esther-stiles-1805"},"HD4087":{"id":"HD4087","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Charles","middle_name":"William","last_name":"Stiles","married_names":[],"gender":"male","display_name":"Charles William Stiles"},"birth":{"year":1833,"month":2,"day":3,"city":"North Haven","county":"New Ha