":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Her daughter Harriet walked the Trail of Tears","body":"Her daughter Harriet Ellsworth traveled to Brainerd Mission in Tennessee as a young woman and met Ainsworth Blunt there. They married in 1822 and spent fifteen years ministering to the Cherokees. When the forced removal came in 1838, Blunt accompanied the tribe on the Trail of Tears until illness forced him back."}],"cross_connections":[],"bio":{"display_name":"Sarah Strong Ellsworth","first_name":"Sarah","last_name":"Ellsworth","maiden_name":"Strong","married_names":["Ellsworth"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-ellsworth-1771"},"H00299":{"id":"H00299","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1743,"month":5,"day":26,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"I00055","mother_id":"H00103"},"tags":["town_clerk","minister","yale_graduate"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 299"}],"cross_connections":[],"death":{"year":1811,"month":11,"day":17,"city":"Portland","county":"Middlesex","state":"Connecticut","country":"United States"},"marriages":[{"spouse_id":"X00134","children_ids":["H00669","H00670","H00671","H00672","H00673","H00674","H00675","H00676"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1785,"date_year":1768,"date_month":11,"date_day":9},{"spouse_id":"X00135","children_ids":["H00677","H00678","H00679","H00680","H00681"],"marriage_number":2,"end_type":"death_of_spouse","end_year":1795,"date_year":1786,"date_month":5,"date_day":14,"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States"},{"children_ids":[],"spouse_id":"X01175","marriage_number":3,"date_year":1797,"date_month":8,"date_day":4,"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States"}],"burial":{"cemetery_id":"CEM108","plot_notes":"Gravestone: \"Rev. Cyprian Strong, D.D. Died Nov. 17th. 1811 In the 68th year of his age, And 44th of his ministry; In morals, exemplary; In doctrine, uncorrupt; In reasoning, profound; In declaring Gods counsel, Perspicuous and solemn; And in death, peaceful.\""},"gender":"male","number_of_marriages":3,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"category":"marriage","header":"Two siblings married two siblings — one ceremony","body":"On November 9, 1768 in Farmington, Cyprian Strong married Sarah Bull, and his sister Elizabeth Strong married Sarah's brother Martin Bull — both weddings on the same day. Two Strong siblings and two Bull siblings, bound together in a single ceremony.","number":1},{"number":2,"category":"career","header":"His gravestone counts 44 years of ministry","body":"He was ordained at Chatham (now Portland) on August 9, 1767 and remained its Congregational pastor until his death on November 17, 1811 — 44 years in the same pulpit. His gravestone records both: \"In the 68th year of his age, And 44th of his ministry; In morals, exemplary; In doctrine, uncorrupt; In reasoning, profound.\""},{"number":3,"category":"career","header":"Yale or Harvard? — the record says Yale","body":"EH, the Strong family book, and Yale archival records all confirm he graduated Yale 1763. The Native Northeast Portal biography states Harvard — this appears to be an error in that source. He served as Farmington Town Clerk 1764-67 immediately after graduation, before ordination."},{"number":4,"category":"legacy","header":"His granddaughter walked the Trail of Tears","body":"His daughter Sarah Strong married Judge John Ellsworth; their daughter Harriet Ellsworth married Ainsworth Blunt at Brainerd Mission, Tennessee, where they ministered to the Cherokees. When the forced removal came in 1838, Blunt accompanied the Cherokees on the Trail of Tears before illness forced him back from the Mississippi. He later became the first mayor of Dalton, Georgia."}],"education":[{"degree":"B.A.","notes":"EH, Strong family book (5345-8), and Yale archival collection all confirm Yale 1763. Native Northeast Portal biography states Harvard — this appears to be an error in that source. Sprague Annals of the American Pulpit vol. I pp. 651-3 contains a life sketch.","school_name":"Yale College","graduation_year":1763,"institution_id":"INST022"}],"bio":{"display_name":"Cyprian Strong","first_name":"Cyprian","last_name":"Strong","married_names":[],"photo_url":"https://images.findagrave.com/photos/2016/99/18878632_1460208376.jpg?size=photos250"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1763"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"cyprian-strong-1743"},"X00134":{"id":"X00134","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1748,"month":10,"day":17,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1785,"month":9,"day":14,"city":"Portland","county":"Middlesex","state":"Connecticut","country":"United States","cause":"sudden death"},"cross_connections":[],"gender":"female","number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"H00299","date_year":1768,"date_month":11,"date_day":9,"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1785,"children_ids":["H00669","H00670","H00671","H00672","H00673","H00674","H00675","H00676"]},{"marriage_number":2,"spouse_id":"I00137","date_year":1717,"date_month":8,"date_day":12,"end_type":"death_of_spouse","end_year":1719,"children_ids":[]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"category":"marriage","header":"Two siblings married two siblings — one ceremony","body":"On November 9, 1768 in Farmington, Cyprian Strong married Sarah Bull, and his sister Elizabeth Strong married Sarah's brother Martin Bull — both weddings on the same day. Two Strong siblings and two Bull siblings, bound together in a single ceremony.","number":1}],"burial":{"cemetery_id":"CEM108"},"bio":{"display_name":"Sarah Bull","first_name":"Sarah","last_name":"Strong","maiden_name":"Bull","married_names":["Strong"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-bull-1748"}},"burialCemetery":{"id":"CEM899","name":"Brainerd Mission Cemetery","county":"Hamilton County","state":"Tennessee","country":"United States","gps":{"lat":35.01,"lng":-85.2131}},"institutionsById":{"INST041":{"id":"INST041","primary_name":"American Board of Commissioners for Foreign Missions (ABCFM)","name":"American Board of Commissioners for Foreign Missions (ABCFM)","alt_names":[],"type":"religious_organization","founding_year":1810,"location":{"city":"Boston","state":"Massachusetts"},"primary_url":"https://en.wikipedia.org/wiki/American_Board_of_Commissioners_for_Foreign_Missions","primary_url_label":"Wikipedia","secondary_url":"https://www.okhistory.org/publications/enc/entry?entry=DW001","secondary_url_label":"Oklahoma Historical Society — Dwight Mission","primary_persons":[],"hooker_connected_people":["H01138","H00914","H01354","HD2376","HD2818","H01418","I01195","H02770","I01197","I01218","I01220","H01355","H00527"],"person_ids":["X00724","X01977","X02115","X02121","X02122","X02862"],"related_institutions":[],"related_landmarks":[],"tags":["missions","native_american_contact","congregationalist"],"sources":[],"notes":"Founded 1810 at Andover Seminary, Massachusetts by prominent Congregationalists. First American foreign missionary society; first missions to China and Ceylon. Yale President Rev. Timothy Dwight IV (H00914) was among the founding figures; Dwight Mission (established 1820 in present-day Arkansas/Oklahoma for the Cherokee) was named in his honor. The board operated Brainerd Mission (Chattanooga TN, est.1817) where Harriet Ellsworth Blunt (X02121) and Ainsworth Blunt (X02122) served the Cherokee. HOOKER TREE CONNECTIONS: 1. Rev. Timothy Dwight IV (H00914) — Yale President 1795-1817; founding ABCFM figure; Dwight Mission named for him. 5th-generation Hooker descendant. 2. Elias Cornelius (X00724) — ABCFM Secretary of Domestic Correspondence 1819-1832; conducted 1817 missionary tour to Creek and Cherokee; m. Mary Ann Hooker (H01355). 3. Rev. Edward William Hooker (H01354) — corporate ABCFM member from 1840. 4. Harriet Ellsworth Blunt (X02121) — served at Brainerd Mission 1821-1837; granddaughter of Rev. Cyprian Strong (H00299). 5. Ainsworth Blunt (X02122) — Brainerd missionary 1822-1837; accompanied Cherokee on Trail of Tears 1838; first mayor of Dalton GA. 6. Dr. Mary Floyd Cushman (HD2818, gen 8) — ABCFM medical missionary in Angola 1922-1953. 7. Samuel Gelston Dwight (HD2376) — ABCFM missionary to Hawaii; children named for ABCFM colleagues Juliette Cooke and Samuel Castle."}},"crossConnections":[]}