{"person":{"id":"I00303","bio":{"display_name":"Doctor Benjamin Faneuil Dunkin Adams","first_name":"Benjamin","middle_name":"Faneuil Dunkin","last_name":"Adams","married_names":[],"title":"Doctor","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777485306/benjaminadams_vrm9zs.jpg"},"birth":{"year":1839,"month":4,"day":13,"city":"Waltham","state":"Massachusetts"},"death":{"year":1895,"month":10,"day":28,"city":"Colorado Springs","state":"Colorado","cause":"tuberculosis (long-term)"},"gender":"male","parents":{"father_name":"Dr. Horatio Adams","mother_name":"Ann Bethune Dunkin"},"marriages":[{"marriage_number":1,"spouse_id":"HD3341","children_ids":["HD3347","HD3348","HD3349"],"date_year":1868,"end_year":1895,"end_type":"death"}],"number_of_marriages":1,"has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["physician","harvard_graduate"],"notable":{"is_notable":true,"notable_category":["medicine","social_reform"],"notable_blurb":"Waltham physician; Colorado College trustee; civic leader","primary_url":"https://www.thecrimson.com/article/1895/11/2/obituary-dr-benjamin-faneuil-dunkin-adams/","primary_url_label":"Harvard Crimson obituary"},"narrative_blocks":[{"number":1,"category":"career","header":"Harvard 1860, Harvard Medical highest honors 1864","body":"He graduated from Harvard in 1860 and immediately began studying medicine with Dr. Jeffries Wyman of Cambridge, soon entering Harvard Medical School. He took his MD in 1864 with the highest honors after surgical interneships at Rainsford Island state hospital and Massachusetts General Hospital, then studied in London and Paris."},{"number":2,"category":"death","header":"Tuberculosis forced retirement to Colorado at 43","body":"Overwork in Waltham broke his health in 1882 and he moved his family to Colorado Spring