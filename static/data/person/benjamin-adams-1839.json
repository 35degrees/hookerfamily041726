research_notes":"Swedish; diplomat","mother_research_notes":"Spanish; baroness"},"marriages":[{"marriage_number":1,"spouse_id":"HD3347","children_ids":["HD3352","HD3353"],"date_year":1916,"location_city":"Boston","location_state":"Massachusetts","end_year":1922,"end_type":"death_of_spouse"}],"number_of_marriages":1,"has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["artist"],"notable":{"is_notable":true,"notable_category":["arts"],"notable_blurb":"German-born sculptor and painter; Diego Rivera mentee","primary_url":"https://en.wikipedia.org/wiki/Marta_Adams","primary_url_label":"Wikipedia"},"narrative_blocks":[{"number":1,"category":"career","header":"Sculptor and painter mentored by Diego Rivera","body":"She apprenticed with sculptor Hans Stangl in Munich from 1925 until 1933, then visited Mexico in 1935 and met Diego Rivera in 1937, who encouraged her oil painting. She moved to Mexico City in 1952; her later work was influenced by pre-Columbian art."},{"number":2,"category":"family","header":"Widowed at 30; husband died of stroke 1922","body":"She married Edward Brinley Adams in Boston in 1916. Six years later he died of stroke on March 24, 1922, leaving her widowed at 30. She returned to Germany in 1925 to begin her artistic apprenticeship."},{"number":3,"category":"legacy","header":"Her work in Harvard, Philadelphia, and Chile museums","body":"Her work is held by the Philadelphia Museum of Art, the Museo de la Solidaridad Salvador Allende in Santiago, Chile, and the Harvard Art Museums. She is buried beside her husband at Mount Feake Cemetery, Waltham — the Adams family ground."}],"cross_connections":[],"sources":[{"url":"https://en.wikipedia.org/wiki/Marta_Adams","label":"Wikipedia — Marta Adams"}],"former_ids":[],"education":[],"career":[],"military_service":[],"institutions":[{"institution_id":"INST002"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"research_tags":[],"quotes":[],"research_sources":[],"documents":[],"is_placeholder":false,"residence":{},"baptism":{},"slug":"marta-arnstem-1891"},"HD3350":{"id":"HD3350","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Benjamin","middle_name":"Faneuil Dunkin","last_name":"Adams","suffix":"II","married_names":[],"gender":"male","display_name":"Benjamin Faneuil Dunkin Adams II","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777487231/benfanueiladams_y1eev1.jpg"},"birth":{"year":1898,"month":5,"day":11,"city":"Concord","county":"Middlesex","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1981,"month":4,"day":22,"city":"Duxbury","county":"Plymouth","state":"Massachusetts","country":"United States"},"residence":{},"burial":{"plot_notes":"Mayflower Cemetery, Duxbury MA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD3347","mother_id":"I00304"},"gender":"male","number_of_marriages":4,"marriages":[{"marriage_number":1,"spouse_id":"I00306","children_ids":["HD3351"],"date_year":1922,"end_year":1923,"end_type":"death_of_spouse"},{"marriage_number":2,"spouse_id":"I00307","children_ids":[],"end_year":1965,"end_type":"death_of_spouse"},{"marriage_number":3,"spouse_id":"I00308","children_ids":[],"end_year":1978,"end_type":"death_of_spouse"},{"marriage_number":4,"spouse_id":"I00309","children_ids":[],"date_year":1980,"end_year":1981,"end_type":"death"}],"education":[{"school_name":"Middlesex School","type":"preparatory","notes":"Middlesex School, Concord MA — preparatory school."},{"institution_id":"INST002","type":"undergraduate","notes":"A.B. Harvard."},{"institution_id":"INST002","school_name":"Harvard Law School","type":"law","notes":"Harvard Law School."}],"career":[{"role":"Partner (retired)","organization":"Hill & Barlow","location":"Boston, Massachusetts","notes":"Boston law firm Hill & Barlow."},{"role":"President","organization":"Cambridge Center for Adult Education","location":"Cambridge, Massachusetts"}],"military_service":[{"war":"World War I","war_id":"WAR007","rank":"Unknown","notes":"Veteran (war service flagged on FindAGrave; war unspecified in source — WWI inferred from age 19-20 at US entry 1917-18)."}],"institutions":[{"institution_id":"INST002","relationship":"alumnus"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["harvard_graduate","lawyer","wwi"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"First wife died in childbirth same day","body":"Benjamin's first wife Rose Bradley died July 20, 1923 in childbirth at age twenty-three — the same day she bore their son Faneuil 'Fan' Adams Jr. Rose was twenty-four at the marriage in 1922 and was dead within a year. Benjamin was twenty-five at her death, and the simultaneous birth and death framed the start of his decades of subsequent widowhood and remarriage."},{"number":2,"category":"family","header":"Four marriages including final at age eighty-two","body":"Benjamin had four marriages across his eighty-three-year life — Rose Bradley in 1922 who died 1923, then Susanne Root, then Helen Weston Thompson, and finally Mary Manning in 1980 at age eighty-two — that final late-life marriage ending within a year by his own April 1981 death. Only the first marriage produced a documented child."},{"number":3,"category":"career","header":"Hill and Barlow partner; Cambridge adult education president","body":"Benjamin earned an A.B. from Harvard followed by Harvard Law School, and retired as a partner at the Boston law firm Hill and Barlow. In civic life he served as President of the Cambridge Center for Adult Education — the long-running Cambridge institution founded in 1938. The combined corporate-law and adult-education leadership tracked the typical second-career trajectory of established Boston-area lawyers."},{"number":4,"category":"family","header":"Born Concord MA 1898, died Duxbury MA 1981","body":"Benjamin Faneuil Dunkin Adams II was born May 11, 1898 in Concord, Middlesex County Massachusetts and died April 22, 1981 in Duxbury, Plymouth County Massachusetts at age eighty-two. He is buried at Mayflower Cemetery, Duxbury — the family ground where Rose Bradley, son Fan Adams Jr., and his mother Rebecca Ames are also interred."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"benjamin-adams-ii-1898"},"HD3352":{"id":"HD3352","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Edward","middle_name":"Brinley","last_name":"Adams","suffix":"Jr.","married_names":[],"gender":"male","display_name":"Edward Brinley Adams Jr."},"birth":{"year":1918},"baptism":{},"death":{"year":1920},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD3347","mother_id":"I00305"},"gender":"male","marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_in_infancy"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"edward-adams-jr-1918"},"HD3353":{"id":"HD3353","former_ids":[],"is_placeholder":false,"has_descendants