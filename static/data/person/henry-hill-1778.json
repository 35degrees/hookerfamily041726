documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00844","mother_id":"X00413"},"tags":["new_york_migration"],"sources":[],"birth":{"year":1785,"month":7,"day":12,"city":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1860,"month":11,"day":23,"city":"Homer","county":"Cortland County","state":"New York","country":"United States","age":75},"marriages":[{"spouse_id":"X00419","children_ids":["HD1332","HD1333","HD1334","HD1335","HD1336","HD1337","HD1338","HD1339","HD1340","HD1341","HD1342"],"marriage_number":1}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Lucy Munson Russell Hill","first_name":"Lucy","last_name":"Hill","maiden_name":"Russell","middle_name":"Munson","married_names":["Hill"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST023"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Eleven children with US Consul to Brazil","body":"Lucy Munson Russell married Henry Hill on January 20, 1807 in Homer, Cortland County New York. Henry was appointed United States Consul to Brazil by President Thomas Jefferson in 1808 — serving at Salvador (Bahia) from 1808 through about 1815-1818, then transferring to Rio de Janeiro. The couple had eleven documented children, many of them born in Brazil during the consulship."},{"number":2,"category":"family","header":"Several daughters born in Brazil 1808-1824","body":"Among Lucy's eleven children, Maria Louisa (1808), Charlotte Henrietta (1824), and others were born in Brazil during Henry's consul years. The Brazilian-birth circumstance was extraordinarily rare for early-nineteenth-century Connecticut-line American women — Lucy's adult life spanned both the Connecticut and Cortland County NY home bases and the Salvador-Rio diplomatic-residence years across two continents."},{"number":3,"category":"family","header":"Outlived husband by nineteen years, buried Buffalo","body":"Henry Hill died July 24, 1841 at age sixty-three; Lucy outlived him by nineteen years, dying November 23, 1860 in Homer New York at age seventy-five. She is buried at Forest Lawn Cemetery in Buffalo New York — the major Buffalo garden cemetery — distinguishing her death-and-burial location from her Connecticut birth and Homer residence."},{"number":4,"category":"family","header":"New Haven CT 1785 to Homer NY 1860","body":"Lucy Munson Russell was born July 12, 1785 in New Haven Connecticut. She died in Homer, Cortland County New York at age seventy-five. Her father Captain William Russell of Middletown CT and her mother set her up to marry into the Hill family whose career took her on the unusual Brazilian-diplomatic-post excursion."}],"slug":"lucy-hill-1785"},"HD1332":{"id":"HD1332","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00419","mother_id":"HD1323"},"tags":[],"sources":[],"birth":{"year":1807},"death":{"year":1834},"gender":"female","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sarah Russell Hill","first_name":"Sarah","middle_name":"Russell","maiden_name":"Hill","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-hill-1807"},"HD1