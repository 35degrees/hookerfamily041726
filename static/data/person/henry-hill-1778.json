ren_ids":[],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Charlotte Henrietta Hill Jacobs","first_name":"Charlotte","last_name":"Jacobs","maiden_name":"Hill","middle_name":"Henrietta","married_names":["Jacobs"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Born Bahia Brazil while father was US Consul","body":"Charlotte Henrietta Hill was born September 23, 1824 in Bahia Brazil while her father Henry Hill was serving as United States Consul to Bahia — a diplomatic post Thomas Jefferson had appointed her father to. Her Brazilian birth was rare among Connecticut-line Hooker descendants of the 1820s; the family returned to the United States during her childhood. She would marry Judge Oliver Phelps Jacobs in Buffalo New York November 22, 1843."},{"number":2,"category":"character","header":"Granddaughter's husband wrote book on Charlotte's birth country","body":"Two generations after Charlotte's Brazilian birth, her granddaughter Annie Jacobs Bullard married Washington Irving Bullard (1881-1948) — who, among other accomplishments, published 'Brazil: The Promising Land,' a book about the very country where Charlotte had been born. Bullard also invented the modern loom used in textile mills worldwide and was a vocal promoter of women's civil rights. The Brazil-birth-to-Brazil-book full circle spanned exactly one century."},{"number":3,"category":"family","header":"Three sons; Killingly Connecticut residence","body":"Charlotte and Judge Oliver Phelps Jacobs had three sons: Edward Hill Jacobs (1845-1922), Frederick Augustus Jacobs (1855-1934), and William Oliver Jacobs (1858-1893). The family settled in Killingly, Windham County Connecticut. Charlotte died March 25, 1896 in Killingly at age seventy-one and was buried at Westfield Cemetery, Danielson, Windham County."}],"slug":"charlotte-jacobs-1824"},"X01644":{"id":"X01644","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1339","children_ids":[]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Judge Oliver Phelps Jacobs","first_name":"Oliver","last_name":"Jacobs","title":"Judge","middle_name":"Phelps","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"oliver-jacobs"},"HD1340":{"id":"HD1340","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00419","mother_id":"HD1323"},"tags":[],"sources":[],"birth":{"year":1824},"gender":"female","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"death":{},"cross_connections":[],"bio":{"display_name":"Caroline Jane Hill Maples","first_name":"Caroline","last_name":"Maples","maiden_name":"Hill","middle_name":"Jane","married_names":["Maples"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"caroline-maples-1824"},"HD1341":{"id":"HD1341","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00419","mother_id":"HD1323"},"tags":[],"sources":[],"birth":{"year":1824},"death":{"year":1875},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Edward Russell Hill","first_name":"Edward","last_name":"Hill","middle_name":"Russell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"edward-hill-1824"},"HD1342":{"id":"HD1342","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00419","mother_id":"HD1323"},"tags":[],"sources":[],"birth":{"year":1826,"month":1,"day":2,"city":"Salvador","state":"Bahia","country":"Brazil"},"death":{"year":1913,"month":6,"day":28,"city":"Chattanooga","county":"Hamilton County","state":"Tennessee","country":"United States","age":87},"gender":"female","marriages":[{"spouse_id":"X01645","children_ids":[],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sophia Joanna Hill Stratton","first_name":"Sophia","last_name":"Stratton","maiden_name":"Hill","middle_name":"Joanna","married_names":["Stratton"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST146"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Born in Brazil during her father's US consulship","body":"Sophia Joanna Hill was born January 2, 1826 in Salvador (Sao Salvador), Bahia, Brazil — while her father Henry Hill was serving as United States Consul to Bahia under Jefferson's 1808 appointment. Her Brazilian birth was extraordinarily rare for early-nineteenth-century Connecticut-line American women. She was one of several Hill daughters born during the family's Salvador-and-Rio diplomatic residence."},{"number":2,"category":"family","header":"Husband domesticated wild elk in Little Valley NY","body":"In 1846 Sophia married Lorenzo Stratton in Ohio. Lorenzo undertook the unusual project of domesticating a herd of wild elk in Little Valley, Cattaraugus County New York — one of the documented mid-nineteenth-century American attempts to bring native cervids under managed husbandry. The elk-herd experiment preceded the family's 1869 migration south to Cumberland County Tennessee where Lorenzo lived out his life at Grassy Cove."},{"number":3,"category":"family","header":"Brazil to Chattanooga TN, lived to eighty-seven","body":"Sophia's life arc spanned three continents and three American regions — born in Brazil, married in Ohio, lived in New York then Tennessee. After Lorenzo's 1884 death at Grassy Cove she eventually settled in Chattanooga where she died June 28, 1913 at age eighty-seven and was buried at Forest Hills Cemetery. Her son Charles Lorenzo Stratton (1849-1942) lived to age ninety-two as a commercial lumberman."}],"slug":"sophia-stratton-1826"},"X01645":{"id":"X01645","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1342","children_ids":[]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"d