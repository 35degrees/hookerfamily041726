former_ids":["HD0615"],"burial":{"cemetery_id":"CEM413","plot_notes":"Springfield Cemetery, Hampden County MA — with wife Rachel Breck and his parents Judge John (H00527) and Sarah Dwight Hooker"},"education":[{"school_name":"Yale College","institution_id":"INST022","degree_or_field":"A.B.","class_year":1814,"notes":"Yale 1814 undergraduate."},{"school_name":"Medical Institution of Yale College","institution_id":"INST022","degree_or_field":"M.D.","class_year":1817,"notes":"Studied medicine at the Medical Institution of Yale College, receiving M.D. in 1817. Practiced afterward with Dr. Eli Ives in New Haven."}],"career":[{"role":"Physician (apprentice/colleague)","organization":"Dr. Eli Ives medical practice","location":"New Haven, CT","start_year":1817,"notes":"Practiced with Dr. Eli Ives — Yale's Professor of Theory and Practice of Medicine, the same chair later occupied (1852-1867) by George's younger brother Worthington Hooker (H01407)."},{"role":"Physician","location":"Syracuse, NY","notes":"Removed to Syracuse, NY where he practiced medicine for several years."},{"role":"Physician","location":"Longmeadow, Hampden County, MA","end_year":1884,"notes":"Returned east to Longmeadow MA where he continued medical practice until his death there 14 March 1884 at age 91."}],"narrative_blocks":[{"number":1,"category":"education","header":"Yale 1817 M.D. under Dr. Eli Ives","body":"After Yale College 1814 he took his medical degree from the Medical Institution of Yale College in 1817, then practiced alongside Dr. Eli Ives in New Haven. Ives — Professor of Theory and Practice of Medicine at Yale until 1852 — would later be succeeded in that chair by George's younger brother Worthington Hooker (H01407)."},{"number":2,"category":"career","header":"Syracuse practice, then Longmeadow homecoming","body":"After his New Haven training he removed to Syracuse, New York, where he practiced medicine for some years before returning east to Longmeadow, Massachusetts. He continued practice at Longmeadow until his death there 14 March 1884 at age 91."},{"number":3,"category":"longevity","header":"Lived ninety-one years to 1884","body":"He was born 7 March 1793 to Judge John Hooker (H00527) and Sarah Dwight Hooker (X00227) at Springfield, and lived past his ninety-first birthday — dying just seven days after it on 14 March 1884 at Longmeadow. He had outlived his celebrated younger brother Dr. Worthington Hooker (H01407) by seventeen years."}],"slug":"george-hooker-1793"},"H02734":{"id":"H02734","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Sarah","middle_name":"Dwight","last_name":"Hooker","married_names":[],"gender":"female","display_name":"Sarah Dwight Hooker"},"birth":{"year":1820,"city":"Longmeadow","county":"Hampden","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1825,"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H01400","mother_id":"I01098"},"number_of_marriages":0,"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_young"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Sarah died young","body":"Sarah died in 1825, aged about five. Her parents gave the name to a sister born three years later."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"sarah-hooker-1820"},"H02735":{"id":"H02735","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Robert","middle_name":"Breck","last_name":"Hooker","ma