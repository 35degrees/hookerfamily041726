year":1931,"end_year":1933}],"military_service":[{"war":"World War I","branch":"US Navy","rank":"Captain","unit":"USS Great Northern; USS Leviathan","notes":"Navy Cross for transporting troops through submarine-infested waters."},{"war":"Spanish-American War","branch":"US Navy","rank":"Lieutenant (j.g.)","unit":"USS Bancroft"}],"narrative_blocks":[{"number":1,"category":"military","header":"He carried an army past the U-boats","body":"Commanding the giant transports Great Northern and Leviathan through waters “infested with enemy submarines and mines,” Phelps ferried troops to Europe and home again, and was awarded the Navy Cross for it."},{"number":2,"category":"military","header":"“Guilty but without culpability”","body":"When the cruiser Louisiana struck a submerged wreck under his command in early 1917, Phelps was tried for culpable negligence and lost ten numbers — but the court’s odd verdict, “guilty but without culpability,” was treated by Navy Secretary Daniels as tantamount to acquittal. It was the only serious mark in forty-eight years of service."},{"number":3,"category":"military","header":"From the President’s yacht to the Yangtze","body":"His forty-eight Navy years ran from executive officer of Theodore Roosevelt’s yacht Mayflower to command of the Yangtze Patrol in China, where Japan decorated him with the Order of the Sacred Treasure."}],"cross_connections":[],"slug":"radm-william-woodward-phelps-hd6279"},"HD6280":{"id":"HD6280","bio":{"display_name":"John Phelps","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781199426/95128618_1438093054_cvaunb.jpg"},"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"has_descendants_documented":true,"number_of_marriages":2,"tags":[],"sources":[],"birth":{"year":1873,"month":7,"day":25,"city":"Baltimore","