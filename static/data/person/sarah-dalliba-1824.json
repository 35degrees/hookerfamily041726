yville (Hamden), Connecticut","start_year":1841,"end_year":1888,"notes":"Modernized and expanded the family arms factory; supplied Civil War muskets to Union Army; sold to Winchester Repeating Arms in 1888, ending 90 years of Whitney firearms manufacturing."},{"role":"Founder","organization":"New Haven Water Company","location":"New Haven, Connecticut","start_year":1860,"notes":"Constructed the dam creating Lake Whitney in 1860 and founded the company that became New Haven's primary water utility."}],"slug":"eli-whitney-iii-1820"},"HD2084":{"id":"HD2084","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2082","mother_id":"X00674"},"tags":["died_in_infancy"],"sources":[],"birth":{"year":1845},"death":{"year":1846},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Eli Whitney","first_name":"Eli","last_name":"Whitney","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"eli-whitney-1845"},"HD2085":{"id":"HD2085","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2082","mother_id":"X00674"},"tags":["yale_graduate"],"sources":[],"birth":{"year":1847,"month":1,"day":22,"city":"New Haven","state":"Connecticut"},"death":{"year":1924,"month":6,"day":12},"orbit_connections":[{"name":"Eli Whitney Debevoise","relationship":"Great-great-grandson of Eli Whitney and Henrietta Frances Edwards (HD2046), through Eli Whitney IV (HD2089) → Anne Farnam Whitney → Eli Whitney Debevoise","notes":"Eli Whitney Debevoise (Dec 14, 1899 – Jun 30, 1990). Yale 1921, Harvard Law 1925. Co-founded law firm Debevoise & Plimpton (1931, with $2,366 in their account). Represented Alger Hiss at his perjury trials. WWII: Chairman of the Alien Enemy Hearing Board. Founder of the International Commission of Jurists. Legal counsel to Ford Motor Company as it became a public corporation. His grandson Eli Whitney Debevoise II (b. 1953, Yale 1974, Harvard Law 1977) was US Executive Director of the World Bank 2007-2009. (Wikipedia; FindAGrave)","primary_url":"https://en.wikipedia.org/wiki/Eli_Whitney_Debevoise","connection_type":"orbit_non_descendant"}],"marriages":[{"spouse_id":"X00677","children_ids":["HD2105","HD2106","HD2107","HD2108","HD2109","HD2110","HD2111"],"marriage_number":1,"date_year":1873,"date_month":10,"date_day":22,"location_city":"New Haven","location_state":"Connecticut"}],"gender":"male","notable":{"is_notable":true,"notable_category":["business"],"notable_blurb":"New Haven civic leader; Yale 1869"},"number_of_marriages":1,"cross_connections":[{"type":"family_orbit","related_id":"X02360","display_label":"his father-in-law, the railroad and canal builder"}],"bio":{"display_name":"Eli Whitney IV","first_name":"Eli","last_name":"Whitney","married_names":[],"suffix":"IV","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777496878/eliwhitneyiv_nwge5c.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST108","relationship":"subject_of_museum","institution_blurb":"Adjacent museum preserving the Whitney Armory site established 1798."},{"institution_id":"INST109","relationship":"president","institution_blurb":"NHWC president role."},{"institution_id":"INST022","relationship":"alumnus","years":"1869"}],"landmarks":[{"landmark_id":"LM060","ro