Windsor."}],"burial":{"cemetery_id":"CEM107","plot_notes":"Palisado Cemetery, Windsor CT — buried 'on one stone' with wife Mary Drake Stiles."},"narrative_blocks":[{"number":1,"category":"career","header":"Windsor shoemaker, brother of silversmith Samuel","body":"Job Stiles was a shoemaker by trade, working in Windsor CT and later Enfield CT. His older brother Samuel Stiles was a Northampton silversmith and clockmaker — together they represent two New England craft trades within the same Stiles family generation."},{"number":2,"category":"family","header":"Died at forty-eight, buried with Mary in Windsor","body":"Job died at Windsor CT on April 13, 1813 at age 48, during the family's roughly decade-long Enfield CT residence (c.1810-1821). His widow Mary Drake Stiles survived him by twenty-six years, dying March 14, 1839 at age 77. They were buried together in the Old Windsor Graveyard with their names inscribed on a single stone."}],"slug":"job-stiles-1765"},"I00624":{"id":"I00624","former_ids":["X01249"],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Mary","last_name":"Stiles","maiden_name":"Drake","married_names":[],"gender":"female","display_name":"Mary Drake Stiles"},"birth":{"year":1761,"month":9,"day":3,"city":"Windsor","county":"Hartford County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1839,"month":3,"day":14,"city":"Windsor","county":"Hartford County","state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM107","plot_notes":"Palisado Cemetery, Windsor CT — 'on one stone' with husband Job Stiles."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Augustine Drake