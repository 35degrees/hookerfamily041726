s_documented":false,"bio":{"first_name":"Elizabeth","maiden_name":"Boardman","married_names":["Whittlesey"],"gender":"female","display_name":"Elizabeth Boardman Whittlesey"},"birth":{"year":1810,"month":5,"day":1,"city":"Middletown","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1863,"month":9,"day":28},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_research_notes":"Daughter of Joseph Boardman of Middletown Conn."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0114","date_year":1840,"date_month":6,"date_day":25,"location_state":"Connecticut","location_country":"United States","children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[{"bib_id":"BIB005","page":"Entry 372 (under George Washington Whittlesey, his second wife)"}],"documents":[],"slug":"elizabeth-boardman-1810"},"HD0097":{"id":"HD0097","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1754,"month":2,"day":24,"city":"Milford","county":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1835,"month":3,"day":15,"county":"Litchfield","state":"Connecticut"},"parents":{"father_id":"I00020","mother_id":"H00142","mother_research_notes":"Susannah Newton Whittlesey Hamlin (H00142, b. Jan 14, 1716, d. May 10, 1803). Per Whittlesey Genealogy #42 child line: Samuel Whittlesey #42 (I00020) m. Susannah Newton Sept 21, 1743; their fourth child was #135 Roger Newton Whittlesey (HD0097). After Samuel's death in 1768, Susannah remarried Hon. Jabez Hamlin of Middletown — hence her 'Hamlin' display name. STAGE 6Y-11 REVERT NOTE: In Stage 6Y-10 I incorrectly 'fixed' this from H00142 to H00143 (Martha Newton Whittlesey). That was backwards — the two Newton sisters married two Whittlesey brothers: Susannah → Samuel #42, Martha → Chauncey #88. Roger Newton's mother is Susannah, NOT Martha. Reverted in 6Y-11 per book #42 confirmation."},"marriages":[{"spouse_id":"I00075","children_ids":["HD0102","HD0103","HD0104","HD0105","HD0106","HD0107","HD0108","HD0109","HD0110","HD0111","HD0112","HD0113","HD0114"],"marriage_number":1,"date_year":1775,"date_month":4,"date_day":23}],"primary_documents":{"enlistment_record":{"date":"January 21, 1776","text":"Signed \"We, the Subscribers, being convinced of the necessity of a body of forces to defeat certain Wicked Purposes formed by the instruments on Ministerial Tyranny do solemnly engage ourselves and enlist as private soldiers...\" Dated at Litchfield. Signed: ROGER N. WHITTELSEY."}},"tags":["revolutionary_war"],"sources":[{"short":"Whittlesey Genealogy","page":"Entry 135 (full bio + Rev War record)"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"open_questions":[{"question":"Is Elisha Whittlesey (b. Mar 8, 1783, Southbury CT; d. Jan 7, 1863) a missing child of Roger Newton Whittlesey?","status":"closed","notes":"Elisha Whittlesey (1783-1863) was born in Southbury CT, studied law under Tapping Reeve at Litchfield CT, moved to Canfield, Mahoning County OH in 1806, served as U.S. Congressman from Ohio and comptroller of the U.S. Treasury. His birth year (1783) falls exactly between documented children HD0105 (Chauncey, b.1781) and HD0106 (Susan, b.1784), suggesting he may be a missing child of this entry. Roger Newton Whittlesey (HD0097) lived in Litchfield County CT — where Tapping Reeve's famous law school was located. If confirmed, Elisha is a gen 6 Hooker descendant, and his 20-year law partnership with Eben Newton (HD2927) — also a gen 6 Hooker descendant — becomes a documented civic_peer cross_connection. Action: Check Whittlesey genealogy for Southbury CT branch; Litchfield County records 1783.","resolution":"Elisha Whittlesey (b. Oct 19, 1783 Washington CT) is Whittlesey book entry #310, son of John Whittlesey (#123, b.1741 Newington CT). His line descends from John Whittlesey of Saybrook through Eliphalet→Eliphalet→John→Elisha — a completely different branch from the project's Whittlesey line (which runs through Rev. Samuel Whittlesey of Wallingford/Milford). Elisha is NOT a Hooker descendant."}],"cross_connections":[],"military_service":[{"war":"American Revolutionary War","active_in_war":true,"rank":"Private","dates":"1776","unit":"Col. Andrew Ward Jr.'s Regiment, Capt. Bezaleel Beebe's Company","notes":"Enlisted Jan 21, 1776 at Litchfield for expedition to New York under Gen. Charles Lee. Eight-week term. His musket was appraised as part of the company arms Jan 26, 1776.","war_id":"WAR004"}],"bio":{"display_name":"Roger Newton Whittlesey","first_name":"Roger","last_name":"Whittlesey","middle_name":"Newton","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"military","header":"Eight-week militia tour to defend New York 1776","body":"Roger enlisted at twenty-one in Capt. Bezaleel Beebe's Company under Col. Andrew Ward Jr. and Maj. Gen. Charles Lee in January 1776 — orders reaching Capt. Beebe on a Sunday, the company armed and on the march toward Fairfield by Saturday. The eight-week tour took him to defend New York City, his only documented Revolutionary service."},{"number":2,"category":"career","header":"Justice of the peace, Litchfield County, many years","body":"After the war Roger settled at South Farms in Litchfield County and served as justice of the peace for many years, the position of standing in the rural Connecticut hierarchy. He worked his farm there until his death at eighty-one in March 1835."},{"number":3,"category":"family","header":"Father of thirteen children with Ann Woodruff","body":"Roger married Ann Woodruff of Litchfield in April 1775, the same month as Lexington, and they raised thirteen children together. The youngest, George Washington Whittlesey, was born in 1799 when Roger was forty-five; Ann lived until 1825."}],"slug":"roger-whittlesey-1754"},"I00075":{"id":"I00075","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1756,"month":4,"day":5,"city":"Litchfield","state":"Connecticut"},"death":{"year":1825,"month":3,"day":7},"parents":{"father_id":"X00078","mother_id":"X01839"},"marriages":[{"spouse_id":"HD0097","children_ids":["HD0102","HD0103","HD0104","HD0105","HD0106","HD0107","HD0108","HD0109","HD0110","HD0111","HD0112","HD0113","HD0114"],"marriage_number":1,"date_year":1775,"date_month":4,"date_day":23}],"sources":[],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Ann Woodruff Whittlesey","first_name":"Ann","last_name":"Whittlesey","married_names":["Whittlesey"],"maiden_name":"Woodruff"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ann-woodruff-1756"},"I00020":{"id":"I00020","classification":{"include_in_pat