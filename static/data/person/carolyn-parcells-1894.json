":"Pickands Mather & Co., Cleveland OH","start_year":1937,"end_year":1969,"notes":"Steel and iron ore industry."},{"role":"Founding President","organization":"Financial Management and Resources Company","start_year":1969,"notes":"Retired from Pickands Mather to found investment management firm."}],"military_service":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1937","institution_blurb":"Yale A.B. 1937; Yale Medal for Distinguished Service; Sterling Fellow."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["yale_graduate","living_or_recent"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"education","header":"Chaired Yale class gifts; won Distinguished Service Medal","body":"For fifteen years Arms chaired his Yale class capital gifts committee — work that earned him the Yale Medal for Distinguished Service and the title of Sterling Fellow of the University. He graduated Yale in the class of 1937 and spent thirty years at Pickands Mather's Cleveland steel operations before founding Financial Management and Resources Company."},{"number":2,"category":"character","header":"Married 73 years; the family called him 'Poppy'","body":"Arms married Betsy Parcells in July 1939 and the marriage lasted until his death at ninety-seven, seventy-three years later — a span longer than most genealogical generations. His family knew him as 'Poppy,' a Pied Piper who shared his passion for sailing, fishing, and lobster pots with children and grandchildren alike."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"charles-arms-1915"},"HD4336":{"id":"HD4336","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"David","middle_name":"Salter","last_name":"Arms","married_names":[],"gender":"male","display_name":"David Salter Arms"},"birth":{"year":1943},"baptism":{},"death":{"year":1999},"residence":{},"burial":{},"classification":{"is_thomas_des