2,"month":9,"day":24,"city":"Rochester","state":"New York","country":"United States"},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"generation_from_john_talcott":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00989","mother_id":"H01264"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01006","date_year":1857,"date_month":1,"date_day":8,"location_country":"United States","children_ids":["H03839","H03840","H03841"]}],"education":[],"career":[{"role":"Physician and Health Officer","organization":"City of Rochester, New York","start_year":1865,"end_year":1902,"notes":"Practicing physician at Rochester after Civil War discharge. Also served as health officer of the city of Rochester."}],"military_service":[{"war":"American Civil War","war_id":"WAR006","side":"United States","rank":"Assistant Surgeon (medical department)","unit":"3rd New York Cavalry (Colonel Mix commanding)","service_years":"1862-1863","discharge_reason":"Injuries received at the Battle of Swan's Quarter, North Carolina, April 30, 1863","role":"Medical department officer; treated wounded through the 1862-1863 campaigns in coastal North Carolina","engagements":["Battle of Swan's Quarter, NC (April 30, 1863) — coastal sound operation where Sperry was wounded"]}],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["army","civil_war","physician"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"military","header":"Discharged from the Civil War at Swan's Quarter","body":"Dr. Moses Sperry served in the medical department of the Third New York Cavalry under Colonel Mix, treating wounded men through the campaigns of 1862-1863, until injuries he received at the Battle of Swan's Quarter, North Carolina forced his discharge in 1863 — a small, overlooked engagement in the coastal war, but the one that ended his service. He returned to Rochester, where he became a practicing physician and eventually health officer of the city, the same skill set he had deployed under fire in the Carolina sounds now directed at the public health of a peacetime industrial city on the Erie Canal."},{"number":2,"category":"career","header":"Returned wounded; became Rochester city health officer","body":"Discharged in 1863 from injuries at Swan's Quarter, Sperry returned to Rochester New York and resumed civilian medical practice. He served as Health Officer of the city — directing Rochester's public-health response to the cholera, smallpox, and tuberculosis threats of the Gilded Age industrial city on the Erie Canal. His wartime cavalry-medicine training carried directly into peacetime municipal sanitation work."},{"number":3,"category":"family","header":"Born Henrietta, died Rochester, both Monroe County","body":"Sperry's life arc traced a tight twelve-mile orbit within Monroe County New York. He was born April 1, 1830 in Henrietta and died September 24, 1902 in Rochester — the same county where he had practiced medicine for nearly forty postwar years. He married Olive Canfield of Bennington NY on January 8, 1857, five years before he marched south with the Third New York Cavalry."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"moses-sperry-1830"},"H03839":{"id":"H03839","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Sarah","middle_name":"Ella","last_name":"Lawton","maiden_name":"Sperry","married_names":["Lawton"],"gender":"female","display_name":"Sarah Ella Lawton"},"birth":{"year":1857