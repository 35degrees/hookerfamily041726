connections":[],"bio":{"display_name":"Dennis Tuttle","first_name":"Dennis","last_name":"Tuttle","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"dennis-tuttle-1797"},"HD1522":{"id":"HD1522","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1488","mother_id":"X00487"},"tags":[],"sources":[{"short":"Online vital records / primary documents"}],"birth":{"year":1800,"month":10,"day":2,"city":"North Haven","county":"New Haven County","state":"Connecticut","country":"United States"},"death":{"year":1884,"month":7,"day":22,"city":"North Haven","county":"New Haven County","state":"Connecticut","country":"United States","age":83},"marriages":[{"spouse_id":"X00488","children_ids":["HD1525"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Zerah Pierpont Tuttle","first_name":"Zerah","last_name":"Tuttle","middle_name":"Pierpont","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST011"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Son Newton became Mormon pioneer to Utah","body":"Zerah's son Newton Tuttle (1825-1905) converted to the Church of Jesus Christ of Latter-day Saints and emigrated to Utah in the William Field Company in 1854. Newton's first wife Lucinda died of cholera at Fort Leavenworth before reaching Utah, and his four-year-old daughter Clara died two days into the overland journey on June 23, 1854. Newton reached Bountiful, Davis County Utah on October 21, 1854 and later served as territorial militiaman during the Utah War of 1857; his diary survives in the LDS Church archives in Salt Lake City."},{"number":2,"category":"family","header":"Named Pierpont for his mother's family","body":"Zerah was given the middle name 'Pierpont' for his mother's Pierpont family line — the same Hooker-line Pierpont ancestry that the project tracks back to John Pierpont of New Haven. His own daughter Eunice Tuttle Pierpont (born 1827) carried the Pierpont name forward another generation as a deliberate naming pattern."},{"number":3,"category":"family","header":"Two marriages across his eighty-three years","body":"Zerah married Maria Todd on April 28, 1824 at North Haven Connecticut; Maria died on April 28, 1860 — exactly thirty-six years later, on the same calendar day as their marriage. He remarried Mary Cook on October 28, 1861 in New Haven Connecticut. The calendar-coincidence of Maria's death-date and their marriage anniversary was either coincidental or noted at the time as a striking anniversary marker."},{"number":4,"category":"family","header":"Born and died at North Haven Connecticut","body":"Zerah Pierpont Tuttle was born October 2, 1800 in North Haven, New Haven County Connecticut and died July 22, 1884 in North Haven at age eighty-three. The lifelong-North Haven residence pattern was characteristic of the Tuttle-Pierpont-Munson cluster of New Haven County families through the nineteenth century."}],"slug":"zerah-tuttle-1800"},"HD1523":{"id":"HD1523","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1488","mother_id":"X00487"},"tags":[],"sources":[{"short":"Online vital records / primary document