nder":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Louisa Charlotte Burr Darius","nickname":"Louisa","first_name":"Louisa","last_name":"Darius","married_names":["Webb","Darius"],"middle_name":"Charlotte","maiden_name":"Burr"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"DNA confirmed her Burr paternity 230 years later","body":"Louisa Charlotte Burr was born around 1788 in Philadelphia to Mary Emmons, during Aaron Burr Jr.'s marriage to Theodosia Bartow Prevost — and Burr kept the relationship hidden. Her descent was suspected for two centuries but only formally confirmed in 2018, when DNA evidence accepted by the Aaron Burr Association established her paternity beyond doubt. She lived to roughly ninety, dying August 16, 1878 in Philadelphia."},{"number":2,"category":"character","header":"Age fifteen, saved Philadelphia mansion from circus fire","body":"Working as a servant for the prominent Philadelphia family of Elizabeth Powel Francis Fisher and her sister Sophia Francis Harrison, Louisa at about age fifteen helped save the Harrison mansion from a 1799 circus fire by soaking blankets and carpets to smother the flames. She later nursed Joshua Fisher, born 1807, who grew deeply attached to her. Upon his 1873 death his estate provided her an annuity and a funeral fund — recognition outside any acknowledged Burr legacy."},{"number":3,"category":"family","header":"Wrote father Burr for Theodosia's portrait miniature","body":"Letters from Louisa to her unacknowledged father Aaron Burr survived among his papers. In one she asked him to lend a miniature portrait of his 'beloved Theodosia' — half-sister Theodosia Burr Alston, lost at sea in 1813 — so that brother John Pierre Burr could copy it. The three unacknowledged Burr children — Louisa, John Pierre, and the recognized Theodosia — had a documented sibling relationship across the color line that Burr never publicly acknowledged."}],"slug":"louisa-darius-1788"},"HD1921":{"id":"HD1921","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1828,"month":3,"day":21,"city":"Philadelphia","state":"Pennsylvania"},"death":{"year":1894,"month":5,"day":7,"city":"Galveston","state":"Texas"},"parents":{"father_id":"X00620","mother_id":"HD1914"},"marriages":[{"spouse_id":"X00625","children_ids":[],"marriage_number":1,"date_year":1845},{"spouse_id":"X00626","children_ids":["HD1950","HD1951","HD1952","HD1953","HD1954","HD1955"],"marriage_number":2,"date_year":1862}],"tags":["author","african_american_literature"],"sources":[{"short":"Wikipedia","note":"Aaron Burr — children section"}],"cross_connections":[],"gender":"female","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Author and writer","primary_url":"https://en.wikipedia.org/wiki/Frank_J._Webb"},"narrative_blocks":[{"header":"The Garies and Their Friends","detail":"Frank J. Webb's novel depicts the lives of free Black and mixed-race families in antebellum Philadelphia — racial violence, anti-Black riots, middle-class aspiration, and the daily texture of life in a free Northern city. It was published in London because no American publisher would take it. Harriet Beecher Stowe, who had championed Frank's wife Mary as a dramatic reader, wrote the preface even while in mourning. Henry, Lord Brougham also wrote an introduction. The novel was dedicated to Lady Noel Byron, who had encouraged Frank during the English tour. It was not published in the United States until 1969 — 112 years after its London debut.","body":"Published in London in 1857, it was the second novel by an African American author. Stowe wrote the preface despite grieving the loss of a son at the time. Not published in the United States until 1969.","number":1},{"header":"Mary E. Webb","detail":"Mary E. Webb was born in New Bedford MA in 1828, her mother having escaped slavery in Virginia. She gained renown in Philadelphia for dramatic readings of Shakespeare and Longfellow. Harriet Beecher Stowe was so impressed that she adapted scenes from Uncle Tom's Cabin specifically for Mary's performances. In 1856, Stowe arranged an English tour for the couple. Longfellow attended a reading and wrote: \"A striking scene, this Cleopatra with a white wreath in her dark hair, and a sweet, musical voice, reading to a great, unimpassioned, immovable Boston audience.\" In England, a London editor agreed to publish Frank's novel. Mary's health collapsed during the tour; she died in Kingston Jamaica in 1859.","body":"Mary Espartero Webb was a celebrated dramatic reader of Shakespeare and Longfellow. Stowe became her patron; Longfellow praised her as \"a Cleopatra with a white wreath.\" The couple toured England in 1856 — the tour led directly to publication of Frank's novel.","number":2}],"number_of_marriages":2,"bio":{"display_name":"Francis Johnson Webb","nickname":"Frank","first_name":"Francis","middle_name":"Johnson","maiden_name":"Webb","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"francis-webb-1828"},"X00625":{"id":"X00625","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1828},"death":{"year":1859},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1