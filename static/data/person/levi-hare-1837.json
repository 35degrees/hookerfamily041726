widows who remarried for economic and social support; her second marriage placed her in the sorghum-molasses trade economy of Walworth County Wisconsin."},{"number":3,"category":"family","header":"Moriah NY 1843 to Elkhorn Wisconsin 1927","body":"Coris Ann Bartlett was born July 21, 1843 in Moriah, Essex County New York — during her father Truman Bartlett's New York years before the family's 1844 migration to Wisconsin. She died April 6, 1927 in Elkhorn, Walworth County Wisconsin at age eighty-three. She is buried at Mount Pleasant Cemetery, Tibbets Wisconsin alongside her parents — a three-generation Wisconsin family cemetery cluster."}],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"coris-hodges-1843"},"HD3196":{"id":"HD3196","former_ids":[],"is_placeholder":false,"gender":"female","has_descendants_documented":false,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"is_easter_egg":false,"include_in_path_calculation":true,"descent_from_thomas_hooker":true},"bio":{"first_name":"Nina","middle_name":"Helena","last_name":"Graff","maiden_name":"Hare","married_names":["Graff"],"gender":"female","display_name":"Nina Helena Hare Graff"},"birth":{"year":1864},"death":{"year":1929},"parents":{"father_id":"X02229","mother_id":"HD3192"},"marriages":[],"tags":[],"sources":[{"short":"Findagrave (via Sam)"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"nina-graff-1864"},"HD3197":{"id":"HD3197","former_ids":[],"is_placeholder":false,"gender":"female","has_descenda