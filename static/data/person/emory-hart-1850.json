t","body":"He served as a magistrate at Marion, Morgan County, Ohio for about fourteen years, and was generally accounted of good judgment and local influence. Both he and his wife Sarah were active church members from early life. The Hart Genealogy of 1875 records that the place was greatly missed and mourned over at his death, so great was the loss."}],"quotes":[],"sources":[{"short":"Andrews, Genealogical History of Deacon Stephen Hart (1875)","url":"https://upload.wikimedia.org/wikipedia/commons/2/25/Geneological_history_of_Deacon_Stephen_Hart_and_his_descendants%2C_1632._1875%2C_%28IA_geneologicalhist01andr%29.pdf"}],"research_sources":[],"documents":[],"slug":"selah-hart-1767"},"I01254":{"id":"I01254","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Sarah","last_name":"Hart","maiden_name":"Walter","married_names":["Hart"],"extra_names":"EH #561 records maiden name as 'Walter'; the Hart Genealogy of 1875 records it as 'Waters'. Both forms attested.","gender":"female","display_name":"Sarah Walter Hart"},"gender":"female","birth":{"year":1766,"month":3,"day":5},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00561","date_year":1793,"date_month":10,"date_day":30,"end_type":"death_of_spouse","end_year":1836,"children_ids":["H01494","H01495","H01496","H01497","H01498","H01499","H01500","H01501","H01502","H01503"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sour