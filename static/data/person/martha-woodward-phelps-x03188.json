ber":1,"spouse_id":"X03188","children_ids":["HD6279","HD6280","HD6283","HD6311"]}],"notable":{"is_notable":true,"notable_category":["military","politics","law"],"notable_blurb":"Medal of Honor recipient, congressman, Baltimore judge","primary_url":"https://en.wikipedia.org/wiki/Charles_E._Phelps","primary_url_label":"Wikipedia"},"cross_connections":[],"education":[{"school_name":"Princeton University","type":"undergraduate"},{"school_name":"Harvard University Law School","type":"law"}],"military_service":[{"war":"Civil War","branch":"Union Army","rank":"Colonel; Brevet Brigadier General","unit":"7th Maryland Infantry","start_year":1861,"end_year":1864,"notes":"Medal of Honor, Laurel Hill, May 8, 1864 (awarded March 30, 1898)."}],"bio":{"display_name":"Charles Edward Phelps","first_name":"Charles","last_name":"Phelps","middle_name":"Edward","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781198757/5996324_fc234efd-02d6-41d1-838c-813b46fdfb60_o9qggr.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"},{"institution_id":"INST023","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"military","header":"Rode to the head of a breaking charge","body":"At Laurel Hill on May 8, 1864, with his column faltering under close artillery fire, Phelps rode to its head and led the assault to within feet of the Confederate works — where he fell severely wounded and was captured. His citation says he placed himself conspicuously in front of the troops."},{"number":2,"category":"military","header":"The Medal of Honor came thirty-four years late","body":"The charge was 1864; the Medal of Honor arrived March 30, 1898, when Phelps was a sixty-four-year-old Baltimore judge. He had passed through four political parties and three careers in the interval."},{"number":3,"category":"family","header":"His mother wrote the nation’s science textbooks","body":"Phelps was the son of Almira Hart Lincoln Phelps, whose botany and chemistry textbooks taught a generation of American students, and the nephew of Emma Hart Willard, the pioneer of women’s education. The family’s Hart line runs back to Farmington."},{"number":4,"category":"family","header":"His half-brother was outlawed by Davis","body":"Charles’s father’s son by his first wife, Gen. John Wolcott Phelps, armed fugitive slaves at New Orleans in 1862 — for which Jefferson Davis declared him an outlaw — returned his commission to Lincoln on principle, and polled 1,045 votes for President in 1880. The half-brothers each wore Union stars."}],"burial":{"cemetery_id":"CEM835","plot_notes":"Woodlawn Cemetery (PM) (N-130)"},"career":[{"role":"Member","organization":"Baltimore City Council","start_year":1860,"end_year":1861},{"role":"US Representative","organization":"Maryland 3rd District","start_year":1865,"end_year":1869},{"role":"Judge","organization":"Circuit Court of Baltimore","start_year":1882,"end_year":1908}],"number_of_marriages":1,"slug":"charles-phelps-1833"},"HD6279":{"id":"HD6279","bio":{"display_name":"RADM William Woodward Phelps","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781199019/radmphelp_rhhmos.png"},"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"has_descendants_documented":true,"number_of_marriages":1,"tags":["navy","ww1","spanish_american_war","navy_cross"],"sources":[],"birth":{"year":1868,"month":11,"day":26,"city":"Baltimore","state":"Maryland"},"death":{"year":1938,"month":5,"day":12,"city":"New York","state":"New York","cause":"heart disease"},"marriages":[{"marriage_number":1,"spouse_id":"X03187","children_ids":["HD6284","HD6285","HD6286"]}],"parents":{"father_id":"H01554","mother_id":"X03188"},"notable":{"is_notable":true,"primary_url":"https://navylog.navymemorial.org/phelps-william-1","primary_url_label":"US Navy Memorial Navy Log","notable_blurb":"Navy Cross; commanded Leviathan; Brooklyn Navy Yard commandant","notable_category":["military"]},"education":[{"school_name":"US Naval Academy","dates":"1889","type":"military"},{"school_name":"Naval War College","dates":"1916"}],"career":[{"role":"Commander","organization":"Yangtze Patrol Force","start_year":1922,"end_year":1924},{"role":"Commandant","organization":"Portsmouth Navy Yard","start_year":1928,"end_year":1931},{"role":"Commandant","organization":"Third Naval District & Brooklyn Navy Yard","start_year":1931,"end_year":1933}],"military_service":[{"war":"World War I","branch":"US Navy","rank":"Captain","unit":"USS Great Northern; USS Leviathan","notes":"Navy Cross for transporting troops through submarine-infested waters."},{"war":"Spanish-American War","branch":"US Navy","rank":"Lieutenant (j.g.)","unit":"USS Bancroft"}],"narrative_blocks":[{"number":1,"category":"military","header":"He carried an army past the U-boats","body":"Commanding the giant transports Great Northern and Leviathan through waters “infested with enemy submarines and mines,” Phelps ferried troops to Europe and home again, and was awarded the Navy Cross for it."},{"number":2,"category":"military","header":"“Guilty but without culpability”","body":"When the cruiser Louisiana struck a submerged wreck under his command in early 1917, Phelps was tried for culpable negligence and lost ten numbers — but the court’s odd verdict, “guilty but without culpability,” was treated by Navy Secretary Daniels as tantamount to acquittal. It was the only serious mark in forty-eight years of service."},{"number":3,"category":"military","header":"From the President’s yacht to the Yangtze","body":"His forty-eight Navy years ran from executive officer of Theodore Roosevelt’s yacht Mayflower to command of the Yangtze Patrol in China, where Japan decorated him with the Order of the Sacred Treasure."}],"cross_connections":[],"slug":"radm-william-woodward-phelps-hd6279"},"X03187":{"id":"X03187","bio":{"display_name":"Susie Southwick Phelps","gender":"female","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781199154/62225503_ae677bdc-621f-49d5-a922-393588cd460b_j3wfp9.jpg"},"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"has_descendants_documented":true,"number_of_marriages":1,"tags":[],"sources":[],"birth":{},"death":{},"marriages":[{"marriage_number":1,"spouse_id":"HD6279","children_ids":["HD6284","HD6285","HD6286"]}],"slug":"susie-southwick-phelps-x03187"},"HD6284":{"id":"HD6284","bio":{"display_name":"Constance Phelps","gender":"female"},"classification":{"include_in_path_calculation":false,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"has_descendants_documented":false,"number_of_marriages":0,"tags":[],"sources":[],"birth":{"year":1900,"month":5,"day":25,"state":"District of Columbia"},"death":{"year":1928,"month":4,"day":26,"city":"Orange","state":"New Jersey"},"marriages":[],"burial":{"cemetery_id":"CEM837"},"parents":{"father_id":"HD6279","mother_id":"X03187"},"slug":"constance-phelps-hd6284"},"HD6285":{"id":"HD6285","bio":{"display_name":"LTJG Woodward Phelps","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781199214/62223876_269e403e-d457-428b-b670-ab3499d13d0b_amm1nm.jpg"},"classification":{"include_in_path_calculation":false,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"has_descendants_documente