1599","children_ids":[],"marriage_number":1}],"tags":["army","wwii","korean_war"],"narrative_blocks":[{"number":1,"category":"military","header":"He served five wars before retiring colonel","body":"Born in China to a Navy family, Angus Wootten joined the Merchant Marine at fifteen during the Second World War, then took an Army commission and served through five conflicts before retiring a lieutenant colonel. In later life he ran an oil company and founded a ministry with his wife."}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Angus Erly","last_name":"Wootten","display_name":"Angus Erly Wootten Sr.","gender":"male","married_names":[],"bio_blurb":"U.S. Army lieutenant colonel","suffix":"Sr."},"military_service":[{"war":"Korean War","active_in_war":true,"rank":"Lieutenant Colonel","role":"U.S. Army; commissioned 1951, served through five conflicts before retiring in 1967","battles":[],"notes":"Joined the Merchant Marine at fifteen during World War II."}],"career":[],"birth":{"year":1929,"month":1,"day":28,"city":"Wuhan","country":"China"},"death":{"year":2020,"month":7,"day":6,"city":"Kissimmee","county":"Osceola","state":"Florida","country":"United States"},"burial":{"cemetery_name":"Arlington National Cemetery","city":"Arlington","county":"Arlington","state":"Virginia","country":"United States"},"slug":"angus-erly-wootten-sr-1929"},"HD5949":{"id":"HD5949","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"include_in_path_calculation":true,"is_easter_egg":false,"generation_from_thomas":12},"notable":{"is_notable":true,"notable_category":["sports"],"notable_blurb":"Hall of Fame high-school basketball coach","primary_url":"https://en.wikipedia.org/wiki/Morgan_Wootten"},"parents":{"father_id":"HD5946","mother_id":"I01597"},"number_of_marriages":0,"marriages":[],"tags":["coach","educator"],"narrative_blocks":[{"number":1,"category":"career","header":"He won over twelve hundred high-school games","body":"In forty-six seasons at DeMatha Catholic High School, Morgan Wootten compiled a 1,274-192 record and never had a losing season. He won five national high-school championships and turned down college offers to stay."},{"number":2,"category":"legacy","header":"He reached the Hall without coaching college","body":"In 2000 Wootten became the first person inducted into the Naismith Basketball Hall of Fame solely as a high-school coach. John Wooden said he knew of no finer coach at any level."},{"number":3,"category":"character","header":"In 1965 his team toppled a dynasty","body":"Wootten gained national fame when his DeMatha team ended the seventy-one-game winning streak of Lew Alcindor's Power Memorial. More than a dozen of his players reached the NBA."},{"number":4,"category":"family","header":"A coaching giant from a photographer's line","body":"Morgan Wootten was born at Duke Hospital while his parents visited his grandmother, the photographer Bayard Wootten, in Chapel Hill. His fame traced back to the same New Bern family of writers and image-makers."},{"category":"career","header":"First high-school-only coach in the Hall","body":"In 2000 Wootten became the first coach inducted into the Naismith Basketball Hall of Fame purely for high-school work, finishing 1,274-192 over 46 years at DeMatha. John Wooden called him the finest coach he knew at any level, and his 1965 team was the only one ever to beat Lew Alcindor's Power Memorial.","number":5}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"parallel_careers","related_id":"HD5928","display_label":"the sportswriter who named the Ivy League"}],"quotes":[],"research_sources":[],"documents":[],"statues":[