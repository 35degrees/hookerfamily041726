[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Marriage united Hooker and Talcott family lines","body":"George Lyman Ingersoll married Catharine 'Kate' L. Talcott on January 12, 1855 in Lanesboro Massachusetts. Kate was the great-great-granddaughter of Samuel Talcott — making their marriage a documented Hooker-Talcott family-line convergence within the tree. Their three children Mary Augusta, George Talcott, and Edwards Platt inherited both lines; Mary Augusta's grandson Talcott Parsons (1902-1979) — the major American sociologist — was named 'Talcott' to honor this maternal Talcott family."},{"number":2,"category":"career","header":"Printer-publisher then Cleveland lawyer","body":"George Lyman Ingersoll began his career as a printer/publisher at Hudson Ohio — the firm Sauver & Ingersoll published 'some of the earliest books in Ohio' and George edited the Ohio Observer for Western Reserve College Professor Henry W. Day. He moved to Cleveland in 1857, studied law, and joined the firm Ingersoll Brothers with his brother Jonathan Edwards Ingersoll. The press-to-bar career arc was characteristic of mid-nineteenth-century midwestern professional formation."},{"number":3,"category":"religion","header":"Three Cleveland Presbyterian churches over career","body":"George Ingersoll was connected successively to three Cleveland Presbyterian congregations across his career — Euclid Avenue Presbyterian, then Cass Avenue Presbyterian, then Beckwith Memorial Church — serving as deacon, treasurer, and session member. The serial congregational moves reflected the typical residential and pastoral shifts of growing Gilded Age Cleveland, where the city's Protestant denominational architecture was being established and rebuilt across decades."},{"number":4,"category":"family","header":"Born Rochester NY 1830, died Cleveland 1910","body":"George Lyman Ingersoll was born February 12 or 13, 1830 in Rochester New York (some records say Buffalo) and attended school in Rochester and at Oberlin Ohio. After Kate's death in 1870 he remarried Cornelia Howard Saunders on July 11, 1871 in Cleveland. He died July 28, 1910 in Cleveland Ohio at about age eighty."}],"slug":"george-ingersoll-1830"},"T01488":{"id":"T01488","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":7,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1832},"death":{"year":1870},"parents":{"father_id":"T01473","mother_id":"X01881"},"marriages":[{"spouse_id":"HD1846","children_ids":["HD1852","HD1853","HD1854"],"marriage_number":1,"date_year":1855,"date_month":1,"date_day":12,"location_city":"Lanesboro","location_state":"Massachusetts"}],"sources":[{"short":"Talcott 1876","page":"Entry 1488"},{"short":"Ingersoll genealogy (Avery 1926)"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Catharine L Talcott","first_name":"Catharine","middle_name":"L","maiden_name":"Talcott","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"catharine-talcott-1832"},"X00599":{"id":"X00599","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1841},"death":{},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1846","children_ids":["HD1855","HD1856","HD1857","HD1858","HD1859","HD1860"],"marriage_number":2,"date_year":1871,"date_month":7,"date_day":11,"location_city":"Cleveland","location_state":"Ohio"}],"gender