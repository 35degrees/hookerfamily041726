d":"H01180","former_ids":["HD3996"],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Laura","last_name":"Mansfield","maiden_name":"Stiles","married_names":["Mansfield"],"gender":"female","display_name":"Laura Stiles Mansfield"},"birth":{"year":1787,"month":11,"day":30,"city":"North Haven","county":"New Haven County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1879,"month":5,"day":19,"city":"North Haven","county":"New Haven County","state":"Connecticut","country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H00454","father_name":"Capt. Isaac Clark Stiles","mother_id":"X01370","mother_name":"Eunice Blakeslee"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00546","date_year":1814,"date_month":12,"date_day":26,"location_city":"North East Village (North Haven)","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1865,"children_ids":["HD3997","HD3998","HD3999","HD4000","HD4001","HD4002","HD4003"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"character","header":"Lived to ninety-two, outlived three of her children","body":"Laura Stiles Mansfield was born in 1787 in Connecticut and died in 1879 at age ninety-one or ninety-two — the longest-lived of her documented Stiles siblings. Of her seven Mansfield children, three died before age fourteen: Mary Elizabeth at thirteen in 1832, Laura Louisa at age two in 1823, and her youngest Laura at age two in 1828."},{"number":1,"category":"family","header":"Two daughters named Laura, both dead at two","body":"Laura bore seven children with Ebenezer Mansfield. Her fourth child Laura Louisa was born 1821 and died at age two in 1823; five years later in 1826 she named a new daughter simply Laura, and that second Laura also died at age two — in November 1828."}],"quotes":[],"sources":[{"label":"FamilySearch person LZGF-NQY","url":"https://ancestors.familysearch.org/en/tree/person/LZGF-NQY"}],"research_sources":[],"documents":[],"slug":"laura-mansfield-1787"},"HD3997":{"id":"HD3997","former_ids":[],"is_placeholder":true,"has_descendants_documented":false,"bio":{"first_name":"Mary","last_name":"Mansfield","married_names":[],"gender":"female","display_name":"Mary Mansfield"},"birth":{"year":1813},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00546","mother_id":"H01180"},"number_of_marriages":0,"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"FamilySearch person KCN8-4RM","url":"https://ancestors.familysearch.org/en/tree/person/KCN8-4RM"}],"research_sources":[],"documents":[],"slug":"mary-mansfield-hd3997"},"HD3998":{"id":"HD3998","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Isaac","last_name":"Mansfield","married_names":[],"gender":"male","display_name":"Isaac Mansfield"},"birth":{"year":1815,"month":11,"day":26,"city":"Hamden","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1895,"month":4,"day":6,"city":"Morris","state":"New York","country":"United States"},"residence":{"city":"Morris","state":"New York","country":"United States"},"burial":{"cemetery_id":"CEM300"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00546","mother_id":"H01180"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00547","date_year":1842,"date_month":5,"date_day":15,"location_state":"New York","location_country":"United States","end_type":"death","end_year":1895,"children_ids":["HD4004","HD4005","HD4006","HD4007","HD4008","HD4009"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Isaac","inspired_by_id":"H00454","description":"First name 'Isaac' honors his maternal grandfather Captain Isaac Clark Stiles (1767-1834). The Stiles-family Isaac name carried forward through his mother Laura Stiles Mansfield's line."}],"artworks":[],"tags":["new_york_migration","politician"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Local-office portfolio in Morris, Otsego County NY","body":"Isaac Mansfield held a layered local-government portfolio in Morris, Otsego County New York: town assessor, supervisor, and Justice of the Peace, plus service on the Board of Education of Morris Union School. The combination — fiscal, executive, judicial, and educational — was characteristic of nineteenth-century Upstate New York village civic leadership where leading citizens rotated through every available board."},{"number":2,"category":"politics","header":"Whig who switched to the Republican Party","body":"Isaac Mansfield was a Whig who later switched to the Republican Party — following the typical mid-nineteenth-century anti-slavery realignment trajectory of Northern Whigs after the 1854 party collapse. The realignment placed him among the antislavery majority of his Otsego County community in the years before and during the Civil War."},{"number":3,"category":"family","header":"Connecticut to New York migration before 1842","body":"Isaac was born November 26, 1815 in Hamden, New Haven County Connecticut, but had migrated to New York State before his May 15, 1842 marriage to Maria Hitchcock. He died April 6, 1895 in Morris, Otsego County New York at age seventy-nine, buried at Harmony Cemetery. The Connecticut-to-Upstate-New-York migration was part of the broader 1830s-40s wave that resettled Connecticut Yankees across Otsego and Chenango Counties."},{"number":4,"category":"family","header":"Named for maternal grandfather Captain Isaac Stiles","body":"Isaac was named for his maternal grandfather Captain Isaac Clark Stiles, carrying the Stiles-family Isaac name forward through his mother Laura Stiles Mansfield's line. He had six children with Maria Hitchcock — including Romaine Stiles Mansfield (Episcopal clergyman) whose son Archibald Romaine Mansfield became the founder of the Seamen's Church Institute."}],"quotes":[],"sources":[{"label":"FamilySearch person KDQ9-D71","url":"https://ancestors.familysearch.org/en/tree/person/KDQ9-D71"},{"label":"FindAGrave Memorial 52492289 (Harmony Cemetery, Morris NY)","url":"https://www.findagrave.com/memorial/52492289/isaac-mansfield"}],"research_sources":[],"documents":[],"slug":"isaac-mansfield-1815"},"I00547":{"id":"I00547","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Maria","last_name":"Mansfield","maiden_name":"Hitchcock","married_names":["Mansfield"],"gender":"female","display_name