er_star"],"narrative_blocks":[{"category":"death","header":"His plane went down off Hong Kong","body":"Named for his uncle the fallen WWI aviator, Quentin landed at Omaha Beach on D-Day while his father landed at Utah. He became a China aviation executive and died at twenty-nine in a Hong Kong plane crash, an end echoing his namesake's.","number":1},{"category":"character","header":"At fourteen he found a new fossil species","body":"As a boy Quentin explored an Arizona cave and unearthed an extinct pronghorn, described as a new species in a museum paper. At nineteen he traveled alone into western China and brought back a thousand rare Naxi manuscripts for the Library of Congress.","number":2},{"category":"literature","header":"His Harvard thesis on a vanishing script","body":"As a student he traveled to the Tibetan borderlands of western China and brought back rare Naxi manuscripts, whose pictographs faintly recall Egyptian hieroglyphs. He made them the subject of his Harvard senior thesis before the Army claimed him.","number":3}],"sources":[],"institutions":[{"institution_id":"INST062","relationship":"alumnus"},{"institution_id":"INST002","relationship":"alumnus"}],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"naming_pattern","related_id":"HD6090","display_label":"the WWI aviator uncle he was named for"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Quentin","last_name":"Roosevelt","display_name":"Maj. Quentin Roosevelt II","gender":"male","bio_blurb":"Soldier and aviation executive; Roosevelt grandson","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780972691/17653540_e969965f-9e4c-4a51-8ad8-72c723f94b26_cvwbd4.jpg","suffix":"II"},"military_service":[{"war":"World War II","branch":"United States Army","rank":"Major","unit":"1st Infantry Division","notes":"Artillery officer; wounded at Kasserine Pass; landed in the first wave at Omaha Beach. Silver Star, Purple Heart, Croix de G