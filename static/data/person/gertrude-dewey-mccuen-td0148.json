ton","state":"Vermont","country":"United States"},"baptism":{},"death":{"year":1877,"month":5,"day":29,"city":"Montpelier","county":"Washington","state":"Vermont","country":"United States"},"residence":{"city":"Montpelier","county":"Washington","state":"Vermont","country":"United States"},"burial":{"cemetery_id":"CEM180","plot_notes":"Green Mount Cemetery, Montpelier VT — Latitude 44.257843, Longitude -72.5944519."},"gender":"male","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_research_notes":"Father Capt. Simeon Dewey (1770-1863), born Hebron CT, settled Berlin VT four miles from Montpelier, lived to age 93. m. Prudence Yemans (1772-1844) on February 27, 1794. Not built — non-tree.","mother_research_notes":"Mother Prudence Yemans Dewey (1772-1844). Not built — non-tree."},"marriages":[{"marriage_number":1,"spouse_id":"TD0138","date_year":1825,"date_month":6,"date_day":9,"location_city":"Berlin","location_state":"Vermont","location_country":"United States","end_type":"death_of_spouse","end_year":1843,"children_ids":["TD0139","TD0140","TD0141","TD0142"]}],"number_of_marriages":1,"tags":["physician"],"research_tags":[],"sources":[{"label":"Wikipedia — Julius Yemans Dewey","url":"https://en.wikipedia.org/wiki/Julius_Yemans_Dewey"},{"label":"FindAGrave — Dr Julius Yemans Dewey","url":"https://www.findagrave.com/memorial/117090576/julius_yemans-dewey"},{"label":"Vermont Historical Society — Dr. Julius Yemans Dewey portrait","url":"https://hub.catalogit.app/vermont-historical-society/folder/entry/dr.-julius-yemans-dewey"}],"research_sources":[],"notable":{"is_notable":true,"notable_category":["medicine","business","religion"],"notable_blurb":"Vermont physician; founded National Life Insurance","primary_url":"https://en.wikipedia.org/wiki/Julius_Yemans_Dewey","primary_url_label":"Wikipedia"},"narrative_blocks":[{"number":1,"category":"business","header":"Founded Vermont's largest life insurance company","body":"Julius founded the National Life Insurance Company at Montpelier in 1850 and served as its president until his death twenty-seven years later. He personally delivered the remittance for the company's first claim, prompting a public thank-you from the surviving family. NLI remains one of the ten oldest insurance companies in the United States."},{"number":2,"category":"family","header":"Married three Susans and one Mary Perrin","body":"After his Berlin sweetheart Mary Polly Perrin died in 1843 leaving four young children, Julius married twice more — both wives named Susan, neither bore him children. His third wife Susan Elizabeth Griggs Lilley had a daughter from a prior marriage who later married Julius's own son Edward — making Edward and his stepsister-in-law husband and wife."},{"number":3,"category":"character","header":"Backed his son's beating from Pangborn the teacher","body":"When eleven-year-old George Dewey led an attack on his Montpelier schoolteacher Z.K. Pangborn — and Pangborn flogged the boys into submission with a stick of stove fuel and walked the bruised George home to explain — Julius listened gravely, then thanked the teacher and asked him to repeat the punishment whenever necessary. George later credited the discipline with saving him from prison."}],"cross_connections":[],"naming_inspiration":[],"education":[{"school_name":"Washington County Grammar School","type":"secondary","notes":"Montpelier VT preparatory study."},{"school_name":"American Literary Scientific and Military Academy (Norwich Military School)","type":"military","notes":"Norwich Military School (later Norwich University) attended pre-medical."},{"school_name":"University of Vermont Medical Department","dates":"graduated 1824","type":"medical","notes":"M.D. class of 1824."}],"career":[{"role":"Physician (general practice)","organization":"Self / private practice","location":"Montpelier, Vermont","start_year":1824,"end_year":1851,"notes":"Practiced as 'most prominent practitioner and one of the leading citizens of the capital of Vermont' until founding NLI."},{"role":"Surgeon","organization":"First Regiment, Vermont State Militia","location":"Vermont"},{"role":"Founder and President","organization":"National Life Insurance Company","location":"Montpelier, Vermont","start_year":1850,"end_year":1877,"notes":"Founded 1850 (some sources 1848). Personally delivered the company's first claim remittance, prompting public thank-you from surviving family. Served as president until his death."},{"role":"Trustee","organization":"Norwich University","location":"Northfield, Vermont","end_year":1877},{"role":"Founder and parishioner","organization":"Christ Episcopal Church (Montpelier VT)","notes":"Documented founder of Christ Episcopal of Montpelier."}],"military_service":[],"institutions":[{"institution_id":"INST112","relationship":"founder","years":"1850-1877","institution_blurb":"Founder and president of the National Life Insurance Company of Montpelier — Vermont's largest life insurer."},{"institution_id":"INST113","relationship":"trustee","institution_blurb":"Trustee of Norwich University; previously attended its predecessor American Literary Scientific and Military Academy."}],"landmarks":[],"artworks":[{"artwork_id":"ART052","role":"subject","blurb":"Vermont Historical Society oil portrait c.1860, gift of Susan Howland estate."}],"documents":[],"quotes":[],"statues":[],"slug":"julius-dewey-1801"},"TD0138":{"id":"TD0138","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"display_name":"Mary Polly Perrin Dewey","first_name":"Mary","middle_name":"Polly","last_name":"Dewey","maiden_name":"Perrin","married_names":["Dewey"],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777670322/marydewey_uh1h5i.jpg","photo_notes":"Portrait. Cloudinary."},"birth":{"year":1799,"month":1,"day":30,"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"baptism":{},"death":{"year":1843,"month":9,"day":30,"city":"Montpelier","county":"Washington","state":"Vermont","country":"United States"},"residence":{"city":"Montpelier","county":"Washington","state":"Vermont","country":"United States"},"burial":{"cemetery_id":"CEM180","plot_notes":"Green Mount Cemetery, Montpelier VT — alongside Julius."},"gender":"female","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":7,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_id":"X01832","mother_id":"T01387"},"marriages":[{"marriage_number":1,"spouse_id":"X02373","date_year":1825,"date_month":6,"date_day":9,"location_city":"Berlin","location_state":"Vermont","location_country":"United States","end_type":"death_of_self","end_year":1843,"children_ids":["TD0139","TD0140","TD0141","TD0142"]}],"number_of_marriages":1,"tags":["replacement_naming"],"research_tags":[],"sources":[{"label":"FindAGrave — Mary Polly Perrin Dewey","url":"https://www.findagrave.com/memorial/117090641/mary_polly-dewey"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"character","header":"Burned the log cabin where she was born","body":"Per family lore, Mary Polly was 'ashamed of having been born in a log cabin' — she and a sister later went up one night and burned the original Perrin cabin to the ground. Her father Zachariah's permanent farm at Scott Hill in Berlin Vermont stood on the same land, but the dirt-floor structure of her birth was gone by her own hand."},{"number":2,"category":"family","header":"Mother of Manila Bay's Admiral, died at forty-four","body":"Mary Polly bore Admiral George Dewey on December 26, 1837 — her third child. He was five years old when she died at age 44 in September 1843 Montpelier Vermont. Her husband Julius later married twice more, but Mary Polly was the mother of all his children."}],"cross_connections":[],"naming_inspiration":[{"name_element":"Mary","description":"Named for her elder sister Mary Perrin (1781-1798), born Hebron CT, who died at age seventeen — four months before her parents named the second baby Mary in her memory. The second Mary was sometimes called Polly to distinguish from her dead namesake."}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"mary-dewey-1799"}},"burialCemetery":{"id":"CEM180","name":"Green Mount Cemetery","city":"Montpelier","county":"Washington","state":"Vermont","country":"United States","gps":"44.257843, -72.5944519","primary_url":"https://www.findagrave.com/cemetery/104036/green-mount-cemetery","hooker_connections":["TD0138","TD0139","TD0140","TD0143","TD0144","TD0145","TD0146","TD0147","TD0148","TD0149","X02373","X02374","X02375"],"notes":"Green Mount Cemetery, Montpelier Vermont — primary burial ground of the Vermont Dewey dynasty. Burial site of Dr. Julius Yemans Dewey (X02373, NLI founder) and his first wife Mary Polly Perrin Dewey (TD0138); their eldest son Charles Dewey (TD0139) and his wife Betsey Tarbox (X02374) and their seven children TD0143-TD0149; second son Edward Dewey (TD0140) and his wife Susan Griggs Lilley (X02375). Three generations of Deweys in a single cemetery. GPS Latitude 44.257843, Longitude -72.5944519."},"institutionsById":{},"crossConnections":[]}