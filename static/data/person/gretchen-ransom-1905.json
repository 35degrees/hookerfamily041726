ooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2683","mother_id":"X00913"},"tags":[],"sources":[],"birth":{"year":1876,"month":2,"day":1},"death":{"year":1957,"month":11,"day":1},"marriages":[{"spouse_id":"X00928","children_ids":["HD2702","HD2703","HD2705"],"marriage_number":1,"date_year":1903}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Kenneth Malcolm Ransom","first_name":"Kenneth","last_name":"Ransom","middle_name":"Malcolm","married_names":[],"nickname":"Cap"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Built his own 30-foot yawl, sailed 8000 miles","body":"At twenty-two in 1898 he built his own thirty-foot yawl 'Gazelle' and sailed her with three companions from Lake Michigan down the Mississippi to New Orleans, across the Gulf, up the Atlantic coast to New York, and through the Erie Canal back to home port St Joseph Michigan. The twenty-month voyage covered more than eight thousand miles."},{"number":2,"category":"career","header":"Indian Rocks Beach bridge tender for 25 years","body":"After his sailing journey he returned in 1910 to Indian Rocks Beach Florida — a stop remembered from the Gazelle voyage. He served as bridge tender at the wooden bridge there for twenty-five years until his 1933 retirement, living in a small cabin midway across the bridge where 'kids went to Cap on the bridge with their troubles and their broken toys.'"},{"number":3,"category":"character","header":"Raised American flag every day after Pearl Harbor","body":"After Pearl Harbor he raised the American flag over the Indian Rocks Beach bridge every day — 'buying new ones from his own pocket money as they wore out.' The daily flag-raising continued through his later retirement years."},{"number":4,"category":"legacy","header":"Doubleday published 'A Year on a Yawl'","body":"American Boy magazine editor W C Sprague persuaded him to write his sailing experience as an eighteen-month serial. Doubleday Page & Co published the result as 'A Year on a Yawl,' which also ran as a serial in seven newspapers."}],"slug":"kenneth-ransom-1876"},"X00928":{"id":"X00928","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1879,"month":1,"day":1},"death":{"year":1941,"month":1,"day":1},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2701","children_ids":["HD2702","HD2703","HD2705"],"date_year":1903,"date_month":4,"date_day":2}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Alice Grace Hamilton Ransom","first_name":"Alice","last_name":"Ransom","maiden_name":"Hamilton","middle_name":"Grace","married_names":["Ransom"],"nickname":"Allie"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"alice-hamilton-1879"},"HD2683":{"id":"HD2683","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00912","mother_id":"HD2682"},"tags":["military","civil_war"],"sources":[{"short":"EH 1909; FamilySearch"}],"birth":{"year":1828,"month":4,"day":28,"city":"Townshend","county":"Windham County","state":"Vermont","country":"United States"},"death":{"year":1908,"month":2},"marriages":[{"spouse_id":"X00913","children_ids":["HD2690","HD2688","HD2697","HD2698","HD2699","HD2700","HD2701","HD2826"],"marriage_number":1,"date_year":1853,"date_month":3,"date_day":5,"location_city":"Kalamazoo","location_state":"Michigan"}],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Board of Education 1873"},"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Wyllys Cadwell Ransom","first_name":"Wyllys","last_name":"Ransom","middle_name":"Cadwell","married_names":[],"photo_url":"https://www.wikitree.com/photo.php/4/49/Ransom-1023.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"danger","header":"Survived nine bullets through hat and clothing","body":"Two weeks after he repelled a Confederate band attempting to free prisoners at Independence MO, five mounted armed rebels attacked him on Kansas City streets. In the hand-to-hand fight 'nine balls' went 'through his hat and clothing that did not strike his person'; he shot one attacker before falling seriously wounded himself."},{"number":2,"category":"military","header":"Pursued Quantrill after the Lawrence massacre","body":"He was present in the aftermath of Quantrill's August 1863 raid on Lawrence Kansas — where 150 unarmed men and boys were murdered — and participated in the pursuit of the Confederate guerrillas across the Kansas-Missouri border."},{"number":3,"category":"military","header":"Daily skirmishes with Quantrill in 1862 Missouri","body":"Commanding the 6th Kansas Cavalry as senior Major, he held Confederate guerrillas in western Missouri at bay through 1862 — daily skirmishes with William Quantrill, George Todd, Dick Yeager, and Parker. The summer was 'almost daily fights' per his 1903 family memoir."},{"number":4,"category":"family","header":"Secretary to his Michigan-governor father, 1849","body":"His father Epaphroditus Ransom served as Governor of Michigan; the son served as his personal secretary 1849. The family had emigrated from Vermont to Michigan in October 1834 when Wyllys was six."}],"slug":"wyllys-ransom-1828"},"X00913":{"id":"X00913","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"EH 1909; FamilySearch"}],"birth":{"year":1835},"death":{"year":1907},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2683","children_ids":["HD2690","HD2688","HD2697","HD2698","HD2699","HD2700","HD2701","HD2826"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Emma Mottram","first_name":"Mary","middle_name":"Emma","maiden_name":"Mottram","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-mottram-1835"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}