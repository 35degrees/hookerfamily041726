r Dwight","first_name":"Elizabeth","middle_name":"Buckminster","maiden_name":"Dwight","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780755964/Dwight-186_krvivu.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":{"name_element":"Elizabeth Buckminster","inspired_by_id":"X03113","description":"Named for her grandmother Elizabeth Buckminster Dwight (1730–1798)."},"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"category":"education","header":"She ran a famous school at Lenox","body":"In Lenox she kept a celebrated girls' boarding school, long known simply as Mrs. Sedgwick's, that drew pupils from leading American families. Her sister-in-law, the novelist Catharine Maria Sedgwick, lived with the family and gave the household its literary fame.","number":1}],"slug":"elizabeth-dwight-1801"},"X00725":{"id":"X00725","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"death":{"year":1821,"month":3,"day":8,"city":"Northampton","state":"Massachusetts"},"birth":{"year":1767,"month":9,"day":17,"city":"Springfield","state":"Massachusetts"},"marriages":[{"spouse_id":"X00786","children_ids":["HD2406","HD2407","HD2419"],"marriage_number":1,"date_year":1789,"date_month":4,"date_day":25,"location_city":"Sandwich","location_state":"Massachusetts"},{"spouse_id":"H00945","children_ids":["HD2281","HD2282","HD2283","HD2284","HD2285","HD2286","HD2287","HD2288","HD2289","HD2290","HD2291","HD2292","HD2293","HD2294","HD2295"],"marriage_number":2,"date_year":1798,"date_month":3,"date_day":3,"location_city":"Stockbridge","location_state":"Massachusetts"}],"gender":"female","number_of_marriages":2,"parents":{"father_id":"X03111","father_name":"Col. Josiah Dwight","mother_id":"X03113","mother_name":"Elizabeth Buckminster Dwight"},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Josiah Dwight","first_name":"Josiah","maiden_name":"Dwight","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780757295/28332260_1f6800b6-8968-4cfd-877f-c57f60ecea69_cvek4h.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[{"landmark_id":"LM120","landmark_blurb":"His father built this house, later moved to Historic Deerfield."}],"artworks":[],"quotes":[],"military_service":[],"education":[{"school_name":"Harvard College","dates":"1786","type":"undergraduate","notes":"A.B. 1786."}],"career":[{"role":"Merchant","location":"Stockbridge, Massachusetts","notes":"For a time in business with his brother-in-law William Edwards."},{"role":"Court clerk; State Treasurer","organization":"Hampshire County Court; Commonwealth of Massachusetts"}],"narrative_blocks":[{"category":"career","header":"Harvard man, merchant, and state treasurer","body":"Josiah Dwight graduated from Harvard in 1786 and set up as a merchant at Stockbridge, for a time partnered with his brother-in-law William Edwards. He later served as clerk of the Hampshire County court and as treasurer of the Commonwealth of Massachusetts.","number":1},{"category":"family","header":"Rhoda Edwards was his second wife","body":"Dwight first married Caroline Williams in 1789, but she died in 1796. Two years later he married Rhoda Edwards, the celebrated 'Madam Dwight,' with whom he raised fifteen children.","number":2}],"slug":"josiah-dwight-1767"},"H00945":{"id":"H00945","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00381","mother_id":"X00709"},"tags":[],"sources":[{"short":"EH 1909"}],"birth":{"year":1778,"month":5,"day":7,"city":"Stockbridge","state":"Massachusetts"},"death":{"year":1863,"month":11,"day":13,"city":"Northampton","county":"Hampshire County","state":"Massachusetts","country":"United States","age":85},"marriages":[{"spouse_id":"X00725","children_ids":["HD2281","HD2282","HD2283","HD2284","HD2285","HD2286","HD2287","HD2288","HD2289","HD2290","HD2291","HD2292","HD2293","HD2294","HD2295"],"marriage_number":1,"date_year":1798,"date_month":3,"date_day":3,"location_city":"Stockbridge","location_state":"Massachusetts"}],"alternate_photo_url":"https://americanaristocracy.com/storage/18324/Screenshot-2024-02-12-at-20.23.36.png","gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Rhoda Edwards","first_name":"Rhoda","maiden_name":"Edwards","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780756028/Screenshot-2024-02-12-at-20.23.36_qyat8x.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"character","header":"Madam Dwight a wonder and joy in Northampton","body":"Contemporary admirers described Rhoda as 'a wonder and a joy to all who knew her, for intellectual power and brightness, to the end of her very long life.' She was held in veneration by the admiring people of Northampton Massachusetts and by 'a multitude without that historic town.' The recognition extended well beyond local family circles into the wider regional culture of mid-nineteenth-century Massachusetts intellectual life."},{"number":2,"category":"family","header":"Mother of fifteen children with Josiah Dwight","body":"Rhoda married Josiah Dwight of Northampton on March 3, 1798 and they had fifteen documented children together. The very large family size placed the Dwight-Edwards household among the more substantial child-bearing marriages of late-eighteenth and early-nineteenth-century western Massachusetts. Josiah died about 1822, leaving Rhoda widowed with many children to raise alone over the next four decades."},{"number":3,"category":"family","header":"Widowed about 1822 with many children","body":"After Josiah's death about 1822, Rhoda raised her surviving children through her long widowhood — she lived another forty-one years until her 1863 death. The decades-long widowhood and intellectual reputation combined to make her one of Northampton's prominent older women of the mid-nineteenth century."},{"number":4,"category":"family","header":"Born Stockbridge MA 1778, died Northampton 1863","body":"Rhoda Edwards was born May 7, 1778 in Stockbridge, Berkshire County Massachusetts and died November 13, 1863 in Northampton, Hampshire County Massachusetts at age eighty-five. She is buried at Bridge Street Cemetery, Northampton. The Stockbridge-to-Northampton life arc tracked her marriage migration about thirty miles east into the Connecticut River valley."}],"slug":"rhoda-edwards-1778"}},"burialCemetery":null,"institutionsById":{"INST022":{"id":"INST022","primary_name":"American Board of Commissioners for Foreign Missions","name":"American Board of Commissioners for Foreign Missions","alt_names":["ABCFM","American Board"],"type":"missionary_society","founding_year":1810,"location":{"city":"Boston","state":"Massachusetts"},"primary_persons":["X00724"],"hooker_connected_people":["X00724","X02121","X02122","T01213","H00527","I01195"],"person_ids":[],"related_institutions":[],"related_landmarks":[],"tags":["native_american_contact","missionary"],"sources":[{"short":"Wikipedia","note":"Elias Cornelius (clergyman); ABCFM"}],"notes":"First American foreign-mission organization. Tree connections: Rev. Elias Cornelius (agent 1816, secretary 1831-32); Ainsworth and Harriet Ellsworth Blunt, missionaries to the Cherokee at Brainerd, Tennessee; Eliza Talcott, missionary to Japan; Rev. William Banfield Capron, Madura mission; Judge John Hooker, member."}},"crossConnections":[]}