ts":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-cannon-1780-2"},"H00481":{"id":"H00481","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1744,"month":4,"day":7,"city":"Norwalk","state":"Connecticut"},"parents":{"mother_id":"H00253","father_research_notes":"Capt. Joseph St. John of Norwalk","father_id":"X00215"},"tags":["yale_graduate","revolutionary_war","slaveholder","moral_complexity"],"sources":[{"label":"St. John Genealogy — entry 144","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"},{"label":"DAR Patriot Ancestor A099267","url":"https://services.dar.org/Public/DAR_Research/search_adb/?action=full&p_id=A099267"}],"death":{"year":1800,"month":2,"day":1,"city":"Norwalk","state":"Connecticut"},"marriages":[{"children_ids":["H01241","H01242","H01246","H01243","H01244","H01245"],"spouse_id":"X00217","marriage_number":1,"date_year":1777,"date_month":6,"date_day":19}],"enslaved_persons":[{"name":"Dover","description":"Enslaved man, jointly owned with brother Stephen. On June 3, 1777, William sent Dover to fight in the Continental Army in his stead, receiving half-ownership of Dover as credit from Stephen. \"Received of my brother Stephen St. John, the one half of his Negro boy named Dover, now inlisted into the Continental Service, for the one half of which boy I am obliged to pay sixty dollars on demand, to exempt me from all actual service. William St. John.\" William was a Loyalist; his wife's 1800 census shows 1 enslaved person still in household."}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"education":[{"notes":"A.B. 1766, A.M. 1769. Same class as Jared Ingersoll and Jonathan Ingersoll.","school_name":"Yale College","graduation_year":1766,"institution_id":"INST022"}],"bio":{"display_name":"William St. John","first_name":"William","last_name":"St. John","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1762-1766","institution_blurb":"Yale A.B. 1766, A.M. 1769 — same class as Hons. Jared and Jonathan Ingersoll of Connecticut."}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["HD0368"],"burial":{"cemetery_id":"CEM002","plot_notes":"East Norwalk Historical Cemetery. FA confirmation."},"narrative_blocks":[{"number":1,"category":"education","header":"Yale class of 1766","body":"William Saint John graduated Yale with A.B. 1766 and A.M. 1769, in the same class as Hon. Jared and Jonathan Ingersoll — two of Connecticut's most prominent legal and political figures — and served as private tutor in the wealthy Phillipse family of Phillipse, New York. He was described by contemporaries as 'a very fine looking, superior man, a person of fine address and manners, presiding handsomely at his own table.'"},{"number":2,"category":"legacy","header":"Two verdicts: DAR Patriot Ancestor and colonial Loyalist","body":"One chronicler records that Saint John 'was a Loyalist and was sent to New York with the Army,' yet he is simultaneously honored as a DAR Patriot Ancestor (A099267) for Civil Service during the Revolution — a tension common among colonial Norwalk families divided by the conflict. In June 1777 he received from his brother Stephen 'the one half of his Negro boy named Dover, now inlisted into the Continental Service,' paying sixty dollars to exempt himself from actual military service."},{"number":3,"category":"death","header":"Suffered heavy losses when Tryon burned Norwalk, 1779","body":"William Saint John suffered significant property losses in General Tryon's burning of Norwalk in July 1779, the same raid that destroyed or damaged much of the town. He died February 1, 1800, in his fifty-sixth year — survived by his wife Mary Esther Belden, who would outlive him by fifty years, dying at ninety-seven in 1850."}],"slug":"william-st-john-1744"},"X00217":{"id":"X00217","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["slaveholder","moral_complexity"],"sources":[],"birth":{"year":1753},"death":{"year":1850},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00481","date_year":1777,"date_month":6,"date_day":19,"children_ids":["H01241","H01242","H01246","H01243","H01244","H01245"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Esther Belden","first_name":"Mary","middle_name":"Esther","maiden_name":"Belden","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-belden-1753"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[{"type":"cousin_marriage","related_id":"HD4340","link_text":"Susannah Lockwood","display_label":"Married his second cousin — both descend from Susannah Selleck St. John","slug":"susannah-st-john-1803"}]}