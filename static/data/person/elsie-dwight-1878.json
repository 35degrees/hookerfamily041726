st encountered the royal children, setting in motion his courtship of the future Queen Liliʻuokalani."}],"cross_connections":[{"type":"civic_connection","related_id":"I00899","display_label":"Dominis born at Yates's home; Dwight knew him in Honolulu","link_text":"Reverend Andrew Yates"},{"type":"family_orbit","related_id":"X02833","display_label":"Both lived in Honolulu's missionary elite for decades","link_text":"John Owen Dominis"}],"bio":{"display_name":"Samuel Gelston Dwight","first_name":"Samuel","last_name":"Dwight","middle_name":"Gelston","married_names":[],"photo_url":"https://www.wikitree.com/photo.php/9/97/Dwight-779.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"samuel-dwight-1815"},"X00772":{"id":"X00772","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1839},"death":{"year":1879},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2376","location_country":"United States","children_ids":["HD2377","HD2378","HD2379"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Anna Haaheo Mahoe","first_name":"Anna","middle_name":"Haaheo","maiden_name":"Mahoe","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"anna-mahoe-1839"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}