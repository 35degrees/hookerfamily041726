"id":"HD4028","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Lea","last_name":"Davison","married_names":[],"gender":"female","display_name":"Lea Davison","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778545156/lea-davison-portrait-3-544x720_ove5hb.jpg"},"birth":{"year":1983,"city":"Sunderland","state":"Vermont","country":"United States"},"baptism":{},"death":{},"residence":{"city":"Jericho","state":"Vermont","country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":13,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["social_reform"],"notable_blurb":"Olympic mountain biker, 2012 + 2016 Games","primary_url":"https://en.wikipedia.org/wiki/Lea_Davison","primary_url_label":"Wikipedia: Lea Davison"},"parents":{"father_id":"I00555","mother_id":"HD4026"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00557","date_year":2018,"date_month":9,"date_day":22,"children_ids":["HD4032"]}],"education":[{"institution":"Mount Mansfield Union High School","degree":"High school","end_year":2001,"location_city":"Jericho","location_state":"Vermont","notes":"Class of 2001."},{"institution":"Middlebury College","institution_id":"INST054","degree":"Bachelor of Arts","field":"Environmental Studies","start_year":2001,"end_year":2005,"location_city":"Middlebury","location_state":"Vermont","notes":"Focus in conservation biology. Competed on Middlebury alpine ski team during undergraduate. Tore ACL end of first year (repaired 2002)."}],"career":[{"employer":"Team Allied/SRAM","role":"Professional mountain biker","start_year":2001,"location_state":"Vermont","notes":"Began racing 2001 at NORBA Nationals Mount Snow VT (7th place). Cross-coun