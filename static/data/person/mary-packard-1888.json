iversity of Alabama College of Community Health Services","start_year":1973,"end_year":1976,"notes":"Co-founder of the college."},{"role":"Director of Medical Education","organization":"Birmingham Baptist Medical Centers","start_year":1976,"end_year":1992,"notes":"Retired 1992."}],"military_service":[{"war":"World War II","war_id":"WAR008","rank":"Unknown","notes":"Veteran per obituary. Specific WWII service not detailed."},{"war":"Korean War","war_id":"WAR014","rank":"Flight Surgeon","rank_end":"Flight Surgeon","rank_year_end":1954,"unit":"U.S. Navy","notes":"Naval flight surgeon. Completed military service 1954."}],"institutions":[{"institution_id":"INST022","relationship":"alumnus","institution_blurb":"Yale University graduate; went on to Harvard Medical School and a distinguished career in cardiology and public health."},{"institution_id":"INST002","relationship":"alumnus","institution_blurb":"Harvard Medical School graduate; interned Columbia-Presbyterian; resident Peter Bent Brigham Hospital."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["wwii","korean_war","navy","physician","yale_graduate","living_or_recent"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Yale, Harvard Medical, Korean flight surgeon","body":"John Mallory Packard graduated from Yale University and Harvard Medical School, interned at Columbia-Presbyterian, and completed military service as a naval flight surgeon in the Korean War before beginning private practice in cardiology and internal medicine in Pensacola in 1954. He went on to co-found the College of Community Health Services at the University of Alabama, served as president of the Alabama Heart Association and Birmingham Academy of Medicine, and was active in genealogical societies — a member of the New England Historic Genealogical Society and the Sons of the American Revolution."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"john-packard-1920"},"I00749":{"id":"I00749","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Ann","last_name":"Packard","maiden_name":"Schoonover","married_names":["Packard"],"gender":"female","display_name":"Ann Schoonover Packard"},"birth":{"year":1923,"month":11,"day":21,"city":"Fort Worth","county":"Tarrant County","state":"Texas","country":"United States"},"baptism":{},"death":{"year":2011,"month":4,"day":24,"city":"Birmingham","county":"Jefferson County","state":"Alabama","country":"United States"},"residence":{},"burial":{"plot_notes":"FindAGrave #69267362. Cremated."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4421","location_country":"United States","children_ids":["HD4426"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["living_or_recent"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"ann-schoonover-1923"},"HD4426":{"id":"HD4426","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Charles","middle_name":"Edward","last_name":"Packard","married_names":[],"gender":"male","display_name":"Charles Edward Packard"},"birth":{"year":1957,"month":11,"day":7,"city":"Pensacola","county":"Escambia County","state":"Florida","country":"United States"},"baptism":{},"death":{"year":2011,"month":2,"day":7,"city":"Alabaster","county":"Shelby County","state":"Alabama","country":"United States"},"residence":{},"burial":{"plot_notes":"FindAGrave #244736513. Specific buri