:false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1800},"death":{"year":1877},"tags":["middlebury_graduate"],"sources":[],"marriages":[{"spouse_id":"HD1673","children_ids":["HD1685","HD1686","HD1687","HD1688","HD1689"],"marriage_number":1,"date_year":1841}],"gender":"male","narrative_blocks":[{"category":"politics","header":"A congressman with a price on his head","body":"Gates served two terms in Congress as an antislavery Whig from New York, drafting the party's protest against the annexation of Texas. His stand so angered the South that a planter offered five hundred dollars for his capture.","number":1},{"category":"social_reform","header":"His house hid fugitives in cellar and attic","body":"Gates ran a station on the Underground Railroad from his Warsaw, New York, home, concealing freedom-seekers in its cellar and attic. The house still stands and is listed on the National Register of Historic Places.","number":2},{"category":"politics","header":"He twice ran for lieutenant governor and lost","body":"After Congress, Gates twice sought the lieutenant governorship of New York on antislavery tickets, as a Free Soiler in 1848 and a Free Democrat in 1852. Both campaigns failed, but they kept him at the center of the cause.","number":3}],"number_of_marriages":1,"parents":{},"notable":{"is_notable":true,"notable_category":["social_reform","politics"],"notable_blurb":"Antislavery congressman with a bounty on him","primary_url":"https://en.wikipedia.org/wiki/Seth_M._Gates","primary_url_label":"Wikipedia"},"institutions":[{"institution_id":"INST054","institution_blurb":"Middlebury College alumnus."}],"cross_connections":[],"bio":{"display_name":"Seth Merrill Gates","first_name":"Seth","last_name":"Gates","middle_name":"Merrill","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780775954/SethMGates_itroe1.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"doc