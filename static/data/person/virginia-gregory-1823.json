ay":5,"age":50,"country":"United States"},"residence":{},"burial":{"plot_notes":"Christ Church Cemetery, Sherburne Chenango Co NY"},"baptism":{},"cross_connections":[],"narrative_blocks":[],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Alice Waters","first_name":"Alice","last_name":"Waters","maiden_name":"Haven","married_names":["Trevor","Waters"],"gender":"female"},"slug":"alice-waters-1895"},"X02896":{"id":"X02896","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_progenitor":false,"is_easter_egg":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker_bool":false},"parents":{},"tags":["navy","war_of_1812","mexican_american_war","civil_war","admiral","notable"],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"X02897","end_type":"death","end_year":1866,"children_ids":["I01301"]}],"number_of_marriages":1,"notable":{"is_notable":true,"notable_blurb":"US Navy Rear Admiral — War of 1812, Mexican War, Civil War","notable_category":["military"],"primary_url":"https://en.wikipedia.org/wiki/Francis_Gregory","primary_url_label":"Wikipedia"},"birth":{"year":1789,"month":10,"day":9,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"death":{"year":1866,"month":10,"day":4,"city":"Brooklyn","county":"Kings County","state":"New York","country":"United States","age":76},"residence":{},"burial":{"plot_notes":"Grove Street Cemetery, New Haven CT"},"baptism":{},"cross_connections":[{"type":"in_law","related_id":"HD5120","display_label":"married his daughter Virginia"}],"narrative_blocks":[{"number":1,"category":"military","header":"Rear Admiral USN through three wars 1809-1865","body":"Francis Hoyt Gregory served the United States Navy for fifty-six years — from his 1809 appointment by President Jefferson through to his Civil War retirement. He served in the War of 1812 (Lake Ontario under Isaac Chauncey at Toronto, Kingston, and Fort George); commanded the USS Raritan blockade squadron off the coast of Mexico 1846-1847 in the Mexican-American War; and was promoted Rear Admiral July 16, 1862 during the Civil War as superintendent of private shipyards constructing iron-clad vessels. Two US Navy destroyers were later named USS Gregory in his honor (DD-82 and DD-802)."},{"number":2,"category":"military","header":"Wheelbarrow-stone escape story while in British custody","body":"Captured by the British in August 1814 during the War of 1812, Gregory refused parole and was sent to England where he remained until June 1815 — months after the war had ended. Under house arrest at a country estate, he was bound by a gentleman's agreement defining boundaries with a large stone marker. When he wished to attend a formal dinner party beyond the boundary, he arrived to accusations of breaking the terms — only to lead his accusers outside where they found his wheelbarrow containing the large marker stone parked at the corner of the dinner house."},{"number":3,"category":"family","header":"Father of Virginia Gregory, Governor Ingersoll's wife","body":"Francis's daughter Virginia Gregory (1823-1898) married Charles Roberts Ingersoll — future Governor of Connecticut 1873-1877 — bringing the Rear Admiral's bloodline into the Hooker-Ingersoll line. Through this marriage Francis became grandfather to five Ingersoll grandchildren including Virginia Ingersoll Gause (Wilmington DE; matriarch of the Gause-Canby line) and Elizabeth Shaw Ingersoll Haven (named for Francis's wife and her grandmother)."}],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[{"war":"War of 1812","war_id":"WAR-OF-1812","side":"American","rank_start":"Midshipman","rank_end":"Lieutenant","unit":"US Navy (USS Revenge under Oliver Hazard Perry, USS Vesuvius/Gun Boat 162, Lake Ontario under Isaac Chauncey)","service_years":"1809-1815","notes":"Appointed midshipman Jan 16, 1809 by Jefferson. Served USS Revenge (Oliver Hazard Perry). Capt anti-pirate actions 1810-1811 off Pensacola/Mobile/Brassa-Barataria captured La Franchise, Santa Maria, La Divina, La Sophie, Le Vengeance, La Pandrita, Diomede, Alexandria. Lake Ontario under Isaac Chauncey — attacks on Toronto, Kingston, Fort George. Promoted lieutenant Jan 28, 1814. Captured by British Aug 1814, refused parole, sent to England held until June 1815 (months after war ended). FAMOUS STORY: under house arrest with stone marker boundary; arrived at dinner party past boundary, then revealed he had wheeled the entire marker stone in a wheelbarrow."},{"war":"Mexican-American War","war_id":"WAR-MEXAM","side":"American","rank_start":"Captain","rank_end":"Captain","unit":"USS Raritan (blockade squadron off coast of Mexico)","service_years":"1846-1847","notes":"Commanded blockade squadron off Mexican coast 1846-1847 aboard USS Raritan."},{"war":"American Civil War","war_id":"WAR-CIVIL","side":"Union","rank_start":"Captain","rank_end":"Rear Admiral","unit":"Union Navy (Superintendent of Private Shipyards, iron-clad construction)","service_years":"1861-1865","notes":"Returned to naval service to superintend construction and fitting-out of naval vessels in private shipyards, including iron-clad vessels. Promoted to Rear Admiral July 16, 1862."}],"education":[],"career":[],"bio":{"display_name":"Rear Admiral Francis Hoyt Gregory","first_name":"Francis","last_name":"Gregory","middle_name":"Hoyt","married_names":[],"title":"Rear Admiral","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779827648/Francis_Gregory_abv61k.jpg"},"slug":"francis-gregory-1789"}