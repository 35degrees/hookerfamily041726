arrative_blocks":[{"number":1,"category":"family","header":"Lost father at seven, carried his name forward","body":"Freeman Wilbur Lybarger was seven years old when his father Freeman Delbert died at thirty-nine in 1913. As the elder son he carried his father's first name forward into the next generation and into his own World War II service. His mother Bertha would remarry Silas Young twelve years later in 1925, giving him Young half-siblings when he was already nineteen."},{"number":2,"category":"family","header":"Five children scattered across America in turn","body":"Freeman Wilbur and Minerva McKinnon had at least five known children born 1925 to 1933: daughters Ruth and Ruby, sons James Donald (Korean War Navy veteran), Robert (Navy veteran), and Leroy 'Lee.' James eventually moved to Texas where he died in Killeen in 2015. The other siblings remained in Crawford County Pennsylvania."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"freeman-lybarger-1906"},"HD4283":{"id":"HD4283","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Ruth","middle_name":"B.","last_name":"Watson","maiden_name":"Lybarger","married_names":[],"gender":"female","display_name":"Ruth B. Lybarger Watson"},"birth":{"year":1925,"month":6,"day":9,"city":"Saint Louis","county":"City of St. Louis","state":"Missouri","country":"United States"},"baptism":{},"death":{"year":2013,"month":2,"day":18,"city":"Erie","county":"Erie County","state":"Pennsylvania","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM355","plot_notes":"Troy Center Cemetery, Troy Center Crawford County PA."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":12,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_cat