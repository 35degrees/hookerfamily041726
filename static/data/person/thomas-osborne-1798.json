county":"New Haven County","state":"Connecticut","country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["scientist","biochemist"],"notable_blurb":"Co-discovered Vitamin A, 1913; founded amino acid science","primary_url":"https://en.wikipedia.org/wiki/Thomas_Burr_Osborne_(chemist)","primary_url_label":"Wikipedia: Thomas Burr Osborne (chemist)"},"parents":{"father_id":"X02817","father_name":"Arthur Dimon Osborne","mother_id":"HD1572","mother_name":"Frances Louisa Blake Osborne"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00596","date_year":1886,"date_month":6,"date_day":23,"location_city":"New Haven","location_county":"New Haven County","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1929,"children_ids":["HD4113","HD4114"]}],"education":[{"institution":"Yale College","institution_id":"INST022","degree":"A.B.","end_year":1881},{"institution":"Yale University","institution_id":"INST022","degree":"Ph.D.","field":"Chemistry","end_year":1885}],"career":[{"role":"Chemist","organization":"Connecticut Agricultural Experiment Station","start_year":1888,"end_year":1929,"notes":"Spent entire career here. Researches on vegetable proteins beginning 1888. Published 'The Vegetable Proteins' (1909). With Lafayette Mendel co-discovered Vitamin A in 1913, established essential amino acids (lysine and tryptophan) in healthy diet."}],"military_service":[],"institutions":[{"institution_id":"INST022","role":"alumnus + faculty connection","notes":"Yale A.B. 1881, PhD 1885"},{"institution_id":"INST144"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[{"related_id":"HD4101","display_label":"Yale science PhDs through different Blake siblings","relationship_type":"first cousin once removed","category":"shared_education","notes":"HD4112 (Yale PhD chemistry 1885) and HD4101 (Yale PhD math/physics 1925) — both descend from Eli Whitney Blake (X00503) and Eliza Maria O'Brien Blake (HD1556) through different children. The Blake-Whitney inventive tradition expressed through two generations of Yale scientists.","type":"family_connection","link_text":"George Blake Thacher"}],"narrative_blocks":[{"number":1,"category":"science","header":"Co-discovered Vitamin A; founded amino acid science","body":"Thomas Burr Osborne and Lafayette Mendel — colleagues at the Connecticut Agricultural Experiment Station — independently co-discovered Vitamin A in 1913, the same year that Elmer McCollum and Marguerite Davis published the same finding three weeks earlier. Both papers appeared in the same issue of the Journal of Biological Chemistry; both teams established that vitamin deficiency caused xerophthalmia, opening modern nutritional biochemistry."},{"number":2,"category":"science","header":"Isolated essential amino acids in rat nutrition studies","body":"Working at the Connecticut Agricultural Experiment Station with 200 carefully fed rats, Osborne and Mendel showed which amino acids — lysine and tryptophan among them — are essential in a healthy diet. Casein became the first identified 'complete protein,' establishing nutrition science beyond caloric energy and toward structural amino acid requirements."},{"number":3,"category":"honors","header":"National Academy 1910, AAA&S 1914, APS 1921","body":"Osborne was elected to the United States National Academy of Sciences in 1910, the American Academy of Arts and Sciences in 1914, and the American Philosophical Society in 1921 — the three foundational American scientific societies. He published over a hundred papers, most jointly with his collaborator Lafayette Mendel."}],"quotes":[],"sources":[{"label":"Wikipedia: Thomas Burr Osborne (chemist)","url":"https://en.wikipedia.org/wiki/Thomas_Burr_Osborne_(chemist)"}],"research_sources":[],"documents":[],"slug":"thomas-osborne-1859"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[{"type":"family_orbit","related_id":"HD1572","display_label":"married his son, the lawyer Arthur Dimon Osborne","slug":"frances-blake-1835"}]}