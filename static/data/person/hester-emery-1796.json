r 40+ years — the same trade as his father. He rose to Grand Master of the Prince Hall Masonic Grand Lodge of Connecticut, the historically African American Masonic order founded in the tradition of Prince Hall. He married twice: first Catherine Ann Jackson (d. Oct 5, 1882, married Oct 28, 1855 Norwich CT); then nurse Clarissa Ann Beman (married May 22, 1886 Norwich CT, who survived him by 20 years). No children from either marriage. He died Jan 6, 1913 in Norwich age 87, buried Yantic Cemetery, Norwich CT.","body":"Walter Harris Burr came to Norwich CT c.1852 and worked as a barber for over 40 years. He became the Most Worshipful Grand Master of the Prince Hall Masonic Grand Lodge of Connecticut — one of the most prominent African American fraternal offices in the state.","number":1}],"number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Walter Harris Burr","first_name":"Walter","last_name":"Burr","middle_name":"Harris","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"walter-burr-1825"},"X00632":{"id":"X00632","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1822},"death":{"year":1882},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1938","children_ids":[],"marriage_number":1,"date_year":1855}],"gender":"female","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Catherine Ann Jackson","first_name":"Catherine","middle_name":"Ann","maiden_name":"Jackson","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"d