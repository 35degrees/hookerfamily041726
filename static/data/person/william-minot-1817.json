":1,"category":"arts","header":"She painted the terror of Niagara Falls","body":"In 1818 Louisa Davis Minot produced a striking pair of canvases of Niagara Falls, the only works known from her hand. A daughter of the Massachusetts solicitor-general Daniel Davis, she rendered the dizzying force of the gorge with surprising originality."}],"sources":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Louisa","last_name":"Minot","married_names":["Louisa Davis Minot"],"display_name":"Louisa Davis Minot","middle_name":"Davis","gender":"female","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780716750/164121248_21f81133-af2f-41da-9ec0-5124eb551e7a_z4evfr.jpg","bio_blurb":"Painter of early Niagara Falls canvases"},"military_service":[],"slug":"louisa-minot-1787"},"X03107":{"id":"X03107","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"gender":"male","birth":{"year":1758,"month":12,"day":22,"city":"Boston","county":"Suffolk County","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1802,"month":1,"day":2,"city":"Boston","county":"Suffolk County","state":"Massachusetts","country":"United States"},"burial":{},"residence":{"city":"Boston","state":"Massachusetts","country":"United States"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":true},"notable":{"is_notable":true,"notable_category":["law","history"],"notable_blurb":"Judge and founder of the Massachusetts Historical Society","primary_url":"https://americanaristocracy.com/people/george-richards-minot","primary_url_label":"American Aristocracy"},"parents":{"father_