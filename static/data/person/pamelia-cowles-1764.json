":[{"number":1,"category":"marriage","header":"Married a Hooker descendant for double-line children","body":"He married Laura Hooker Thompson in 1810 — both bride and groom were 6th-generation descendants of Rev. Thomas Hooker through entirely separate lines. Their children descend doubly: through the Newton-Hooker line and through the Hooker-Cowles line."},{"number":2,"category":"legacy","header":"Connecticut farmer who carved out an Ohio town","body":"He removed from Goshen, Connecticut to Richfield Township in Summit County, Ohio sometime before the 1820s. By that decade he had purchased most of the land around Richfield's east center, building the homestead later owned by Homer Carter."},{"number":3,"category":"family","header":"Brought his widowed mother west to Ohio","body":"His mother Rebecca Minott Newton lived with him in Richfield in her widowhood before moving on to live with his brother Eben in Canfield, Ohio. Both sons had migrated to the Western Reserve."}],"slug":"john-newton-1787"},"HD2915":{"id":"HD2915","is_placeholder":false,"gender":"male","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1811,"month":6,"day":12,"city":"Goshen","state":"Connecticut"},"death":{"year":1874},"parents":{"father_id":"HD2925","mother_id":"HD0532"},"marriages":[],"tags":["double_hooker_ancestry"],"sources":[{"short":"Cowles Genealogy #682"},{"bib_id":"BIB003"}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Marcus Newton","first_name":"Marcus","last_name":"Newton","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"marcus-newton-18