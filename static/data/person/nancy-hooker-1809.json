ast_name":"Hooker","married_names":[],"bio_blurb":"Woolen pioneer and 1818 Constitution delegate","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781205983/Screenshot_2026-06-11_at_12.26.06_PM_imjx9x.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"business","header":"First Bristol woolen manufactory, burned 1903","body":"Bryan Hooker established one of the first woolen manufactories in Connecticut at Bristol — his fulling mill long known locally as 'the old yellow shop, near the bridge on the corner of East and South Streets.' The building stood for over a century before it was destroyed by fire in 1903 — seventy-seven years after Hooker's death. The mill represented the small-scale industrial transition between colonial-era home-spinning and the later New England textile factory system."},{"number":2,"category":"politics","header":"Delegate to 1818 Connecticut Constitution convention","body":"On July 4, 1818, Bryan Hooker was appointed delegate to the Hartford convention that framed the new Connecticut Constitution — the document that finally separated church and state in Connecticut and replaced the colonial-era Fundamental Orders. He had served Bristol as Town Clerk in 1806 and from 1811 through 1820, and as Bristol's representative in the Connecticut General Assembly across four sessions between 1812 and 1817. He voted on the conservative side and chaired several important committees during the convention."},{"number":3,"category":"business","header":"The old yellow shop by the bridge","body":"Bryan built one of the first woolen manufactories in Connecticut; his fulling mill at the corner of East and South Streets was known for generations as the old yellow shop. It outlived him by seventy-seven years, until fire took it in 1903."},{"number":4,"category":"family","header":"“Wouldn’t you like to see your mother?”","body":"His new stepdaughter, nine-year-old Rhoda Ann Fuller, boycotted the wedding and fled to her grandparents. On Esquire Hooker’s advice no one pursued her for a full year — then he drove his carriage over “on business,” asked the question, and she came home for good, staying until her own marriage to the mapmaker Samuel Augustus Mitchell."}],"career":[{"role":"Woolen manufacturer","location":"Bristol"},{"role":"Town Clerk","organization":"Bristol","start_year":1806,"end_year":1820},{"role":"Representative","organization":"Connecticut General Assembly"}],"slug":"bryan-hooker-1764"},"X01272":{"id":"X01272","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00515","date_year":1804,"location_city":"Bristol","location_state":"Connecticut","children_ids":["HD0606","HD0607","HD0608"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Nancy Lee Fuller","first_name":"Nancy","middle_name":"Lee","maiden_name":"Fuller","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"nancy-fuller"},"H00262":{"id":"H00262","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1736,"month":12,"day":13,"city":"Woodbury","state":"Connecticut"},"parents":{"father_id":"H0009