h":{"year":1865,"month":7,"day":5,"city":"Bedford","state":"Virginia"},"death":{"year":1934,"month":11,"day":23,"city":"Lynchburg","state":"Virginia"},"parents":{"mother_id":"HD0795","father_research_notes":"John William Murrell","father_id":"X00165"},"marriages":[{"children_ids":["HD0800","HD0801"],"spouse_id":"X00166","marriage_number":1}],"tags":["politician"],"sources":[],"prominent_name_reason":"George Edward Murrell (1865-1934) — Member of the Virginia House of Delegates, Bedford County, 1899-1904. Democrat. Chaired the Committee on Retrenchment and the Economy. Son of Mary Ann Hart Murrell (HD0795, great-great-great-great-granddaughter of Thomas Hooker) and John William Murrell of Lynchburg, Virginia. Born July 5, 1865 — weeks before the end of the Confederacy. Source: https://history.house.virginia.gov/members","gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Politician"},"cross_connections":[],"bio":{"display_name":"George Edward Murrell","first_name":"George","last_name":"Murrell","middle_name":"Edward","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Born weeks after Appomattox in adjacent Virginia county","body":"George Edward Murrell was born July 5, 1865 in Bedford County Virginia — about three months after Lee's April 9, 1865 surrender at Appomattox in the adjacent Appomattox County. The birth straddled the divide between Virginia's Confederate wartime existence and its Reconstruction-era reorganization. He spent his entire life in the Bedford-Lynchburg area of central Virginia."},{"number":2,"category":"politics","header":"Virginia House of Delegates 1899-1904 Bedford County","body":"George served three two-year terms in the Virginia House of Delegates representing Bedford County from 1899 through 1904 as a Democrat. His committee assignments included Agriculture and Mining, Banks Currency and Commerce, Counties Cities and Towns, Enrolled Bills, Finance, and Retrenchment and the Economy. He chaired the Retrenchment and the Economy committee during his final term — a fiscal-restraint role characteristic of turn-of-the-century Southern Democratic legislators."},{"number":3,"category":"family","header":"Named daughter Mary Hart preserving Hooker family line","body":"George and his wife Mildred Garland had two documented children: Mary Hart Murrell Douville (born 1890) and Mildred Murrell McLeod (born 1903). The elder daughter Mary's middle name Hart deliberately preserved the Hart-Hooker maternal ancestry that connected this Virginia-line branch to the Connecticut Hooker family — the cross-regional naming pattern keeping the family memory alive in the Reconstruction-era Bedford County household."},{"number":4,"category":"family","header":"Bedford Virginia 1865 to Lynchburg Virginia 1934","body":"George Edward Murrell was born July 5, 1865 in Bedford, Virginia and died November 23, 1934 in Lynchburg, Virginia at age sixty-nine. The Bedford-to-Lynchburg life arc remained within the same central Virginia twenty-mile region. His farming-and-politics career combined the two principal occupational paths of his post-war Virginia generation."}],"slug":"george-murrell-1865"}},"burialCemetery":{"id":"CEM571","name":"St. John's Episcopal Church Cemetery","city":"Arden","state":"New York","visitable":true,"notes":"St. John's Episcopal Church Cemetery, Arden, Orange County, New York.","hooker_connections":["H01564","X00164"]},"institutionsById":{},"crossConnections":[]}