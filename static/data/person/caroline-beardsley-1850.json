_year":1810,"location":{"city":"Boston","state":"Massachusetts"},"primary_persons":["X00724"],"hooker_connected_people":["X00724","X02121","X02122","T01213","H00527","I01195"],"person_ids":[],"related_institutions":[],"related_landmarks":[],"tags":["native_american_contact","missionary"],"sources":[{"short":"Wikipedia","note":"Elias Cornelius (clergyman); ABCFM"}],"notes":"First American foreign-mission organization. Tree connections: Rev. Elias Cornelius (agent 1816, secretary 1831-32); Ainsworth and Harriet Ellsworth Blunt, missionaries to the Cherokee at Brainerd, Tennessee; Eliza Talcott, missionary to Japan; Rev. William Banfield Capron, Madura mission; Judge John Hooker, member."},"INST0043":{"id":"INST0043","primary_name":"Auburn Button Works (Auburn Plastics)","name":"Auburn Button Works (Auburn Plastics)","short_name":"Auburn Button Works","alt_names":[],"type":"manufacturing","founding_year":1876,"location":{"city":"Auburn","state":"New York"},"primary_persons":[],"hooker_connected_people":["HD2488","HD2498"],"person_ids":["X00821"],"related_institutions":[],"related_landmarks":[],"tags":[],"sources":[],"notes":"Founded 1876 by John Hermon Woodruff (Yale 1863, X00821) as \"Woodruff's Button Factory\" in Auburn NY. Originally in the post office on Exchange Street; moved to 1900 Washington St in 1900; larger plant on Canoga Street 1911; second plant on 24 McMaster St WWII. Products: pearl and shellac buttons, typewriter keys, butt plates for rifles, 78-rpm records, molded plastic goods. Douglas Woodruff (HD2498, Yale 1905) succeeded as president until his death 1957. Renamed Auburn Plastics 1957 when button manufacturing ceased. Connected to Hooker tree through Caroline Porter Beardsley Woodruff (HD2488), 8th-generation descendant of Thomas Hooker through Susannah Edwards (H00382)."}},"crossConnections":[]}