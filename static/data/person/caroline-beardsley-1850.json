{"name":"Nelson Beardsley (X00830) — uncle of her husband Alonzo; law partner of William H. Seward; 50-year bank president; Yale 1827","person_id":"X00830","relationship":"Nelson Beardsley (1807-1894) was the uncle of Alonzo Glover Beardsley Sr. (X00802), husband of Hooker descendant Anna Phillips Porter Beardsley. His law partnership with William H. Seward (Lincoln's Secretary of State), 50-year bank presidency, and $7M fortune made him one of Auburn's most prominent citizens.","connection_type":"orbit_non_descendant"},{"name":"Roswell Beardsley (X00835) — uncle of her husband; US postmaster 72 consecutive years under 20 presidents","person_id":"X00835","relationship":"Brother of Alonzo Glover Beardsley Sr. (X00802). Postmaster at North Lansing NY 1828-1902 — appointed under John Quincy Adams, still serving under Theodore Roosevelt. Believed the longest continuous single government appointment in US history.","connection_type":"orbit_non_descendant"},{"name":"William Clinton Beardsley (X00837) — uncle of her husband; Democratic presidential elector 1852, banker, railroad director","person_id":"X00837","connection_type":"orbit_non_descendant","relationship":"Brother of Alonzo Glover Beardsley Sr. (X00802)."}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Anna Phillips Porter","first_name":"Anna","middle_name":"Phillips","maiden_name":"Porter","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"anna-porter-1828"},"HD2436":{"id":"HD2436","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"fathe