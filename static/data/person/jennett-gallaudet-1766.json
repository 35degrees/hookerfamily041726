lphia","state":"Pennsylvania"},"death":{"year":1851,"month":9,"day":10,"city":"Hartford","state":"Connecticut"},"parents":{"father_id":"X00124","mother_id":"HD0405"},"marriages":[{"spouse_id":"X00125","children_ids":[],"marriage_number":1,"date_year":1821,"date_month":8,"date_day":29}],"prominent_name_reason":"Rev. Thomas Hopkins Gallaudet (1787-1851) — Yale 1805 (highest honors, age 17); co-founded with Laurent Clerc and Mason Cogswell the first permanent school for deaf students in North America: the American School for the Deaf, Hartford, April 15, 1817. First principal of the school. Thomas Hooker's 6th-generation descendant through Alice Hooker → Alice Howard → Alice Howard Hopkins → Jennett Hopkins Gallaudet.","tags":["educator","minister","author","yale_graduate"],"sources":[{"short":"Wikipedia","notes":"Thomas Hopkins Gallaudet article"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["education"],"notable_blurb":"Founded American School for the Deaf","primary_url":"https://en.wikipedia.org/wiki/Thomas_Hopkins_Gallaudet","primary_url_label":"Wikipedia"},"cross_connections":[{"type":"civic_peer","related_id":"X00804","display_label":"recruited Gallaudet as Worcester's asylum chaplain in 1838","document_id":"DOC005","link_text":"Samuel Bayard Woodward"},{"type":"parallel_descent","related_id":"HD2442","display_label":"shared her Thomas Hooker descent, unknown to either family","document_id":"DOC005","link_text":"Maria Porter"},{"type":"artifact","related_id":"H00546","display_label":"co-wrote their schoolbooks and edited the Connecticut Observer","link_text":"Rev. Horace Hooker"},{"type":"parallel_careers","related_id":"HD5937","display_label":"led the Michigan School for the Deaf for decades"},{"type":"parallel_careers","related_id":"HD5940","display_label":"led the Washington State School for the Deaf"}],"education":[{"notes":"Graduated with highest honors, age 17.","school_name":"Yale College","graduation_year":1805,"institution_id":"INST022"}],"bio":{"title":"Reverend","display_name":"Rev. Thomas Hopkins Gallaudet","notes":"Named for Capt. Thomas Hopkins, his maternal grandfather","first_name":"Thomas","last_name":"Gallaudet","middle_name":"Hopkins","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781635976/04-15-thomas-gallaudet-engraving-resized_vb6a9f.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1805"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"legacy","header":"Founded America's first school for the deaf","body":"He founded the American School for the Deaf in Hartford on April 15, 1817 — the first permanent school for the deaf in the Western Hemisphere. He had traveled to Paris to learn French Sign Language, returning with deaf teacher Laurent Clerc to build the school together."},{"number":2,"category":"family","header":"Married his own deaf student Sophia Fowler","body":"Among his first students was Sophia Fowler, born deaf; he married her in 1821 after her graduation. Their son Edward Miner Gallaudet founded what became Gallaudet University in Washington, carrying the family's mission to the national stage."},{"number":3,"category":"career","header":"Co-authored religious textbooks with Horace Hooker","body":"In the 1830s and 1840s he collaborated with fellow Hooker descendant Rev. Horace Hooker on Scripture Biography for the Young, The Practical Spelling Book, and The School and Family Dictionary. The spelling book was reprinted under both names for years after his death in 1851."},{"number":4,"category":"education","header":"He crossed the ocean to learn the method","body":"In 1815 Mason Cogswell's circle sent Gallaudet to Europe to learn how the deaf were taught. At the Paris institute of the Abbé Sicard he persuaded Laurent Clerc, a brilliant deaf instructor, to sail back with him. Clerc became the first deaf teacher of the deaf in America."},{"number":5,"category":"legacy","header":"His son's college still carries the name","body":"His youngest son, Edward Miner Gallaudet, carried the family's work to Washington. There he founded the college that became Gallaudet University, the only university in the world built for deaf students. The name his father made now stands over its gates."}],"career":[{"role":"Principal & Founder","organization":"American School for the Deaf, Hartford","start_year":1817,"end_year":1830}],"slug":"thomas-gallaudet-1787"},"X00125":{"id":"X00125","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1798,"month":3,"day":20,"city":"Guilford","state":"Connecticut"},"death":{"year":1877,"month":5,"day":13,"city":"Washington","state":"D.C."},"burial":{"cemetery_id":"CEM025","plot_notes":"Cedar Hill Cemetery, Hartford, Connecticut"},"marriages":[{"spouse_id":"HD0411","children_ids":[],"marriage_number":1}],"prominent_name_reason":"Sophia Fowler Gallaudet — \"Mother of the American Deaf.\" Born deaf; student at the American School for the Deaf from 1817, married its principal Thomas Hopkins Gallaudet in 1821. First matron of the Columbia Institution (later Gallaudet University) 1857-1866. Lobbied Congress to establish the National Deaf-Mute College.","sources":[{"short":"Wikipedia","notes":"Sophia Fowler Gallaudet article"}],"gender":"female","tags":[],"number_of_marriages":1,"parents":{},"notable":{"is_notable":true,"notable_category":["education"],"notable_blurb":"Deaf educator, co-founded American School","primary_url":"https://en.wikipedia.org/wiki/Sophia_Fowler_Gallaudet","primary_url_label":"Wikipedia"},"cross_connections":[],"bio":{"display_name":"Sophia Fowler Gallaudet","first_name":"Sophia",