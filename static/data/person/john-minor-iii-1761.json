ions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"lucy-minor-1849"},"HD1606":{"id":"HD1606","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1858},"death":{"year":1932},"parents":{"father_id":"X00513","mother_id":"HD1598"},"marriages":[{"spouse_id":"X00519","children_ids":["HD1648"],"marriage_number":1,"date_year":1882,"date_month":12,"date_day":28,"location_city":"Manhattan","location_state":"New York"}],"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Helen Willis Minor Poyntz","first_name":"Helen","last_name":"Poyntz","married_names":["Poyntz"],"middle_name":"Willis","maiden_name":"Minor"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"helen-poyntz-1858"},"HD1607":{"id":"HD1607","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1865,"month":5,"day":10,"city":"Brooklyn","state":"New York"},"death":{"year":1928,"month":12,"day":26,"city":"Biltmore Forest","state":"North Carolina"},"parents":{"father_id":"X00513","mother_id":"HD1598"},"marriages":[{"spouse_id":"X00990","children_ids":["HD2757","HD2760","HD2830","HD2761"],"marriage_number":1,"date_year":1890}],"tags":[],"sources":[],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["medicine"],"notable_blurb":"Pioneered TB treatment in Asheville; trained in Vienna","primary_url":"https://images.findagrave.com/photos/2020/190/192055092_caf7fbfc-fbaf-464e-bd67-94dd71d47990.jpeg","primary_url_label":"FindAGrave"},"burial":{"cemetery_id":"CEM043"},"narrative_blocks":[{"header":"Pioneered tuberculosis treatment in Asheville","detail":"Moving to Asheville to convalesce, Minor began specializing in tuberculosis treatment in 1897 — the specialty that made him famous. Asheville had become a leading center for TB treatment due to its climate, and Minor's European training and precision made him one of its most respected physicians. He died at Biltmore Forest, Buncombe County NC in 1928. His son Dr. John Minor (HD2760) also became a physician and WW1 veteran, buried at Arlington. (FindAGrave; FamilySearch)","body":"Charles Lancelot Minor earned his M.D. from the University of Virginia in 1888, interned at St. Luke's Hospital New York, then spent two years studying in Vienna under Weichselbaum, Kolisko, and Friedrich Kraus, with additional study in Berlin, Munich, Paris, London, and obstetrics at the Rotunda Hospital in Dublin. Returning in 1892, he practiced surgery in Washington until developing tuberculosis in 1895.","number":1,"category":"character"},{"number":2,"category":"career","header":"Vienna trained him; Asheville claimed him","body":"Brooklyn-born and Vienna-trained, the eighth-generation Hooker descendant built his tuberculosis practice on Asheville’s mountain air and died at Biltmore Forest — but was carried home to Brooklyn’s Green-Wood. The Confederate “Col. Lancelot Minor” of the war articles is a different family entirely."}],"cross_connections":[],"bio":{"display_name":"Doctor Charles Lancelot Minor","title":"Doctor","first_name":"Charles","last_name":"Minor","middle_name":"Lancelot","married_names":[],"photo_url":"https://images.findagrave.com/photos/2020/190/192055092_caf7fbfc-fbaf-464e-bd67-94dd71d47990.jpeg","bio_blurb":"Asheville tuberculosis pioneer"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Physician","location":"Asheville, North Carolina"}],"education":[{"school_name":"Medical training, Vienna","type":"professional"}],"slug":"charles-minor-1865"},"X01924":{"id":"X01924","has_descendants_documented":false,"is_placeholder":false,"gender":"female","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1802,"month":12,"day":2,"city":"Fredericksburg","state":"Virginia","country":"United States"},"death":{"year":1896,"month":9,"day":15,"city":"Alexandria","state":"Virginia","country":"United States"},"parents":{"father_id":"X01923","mother_research_notes":"Lucy Landon Carter Minor"},"marriages":[],"number_of_marriages":1,"tags":["abolitionist"],"sources":[{"short":"Wikipedia — Mary Berkeley Minor Blackford","url":"https://en.wikipedia.org/wiki/Mary_Berkeley_Minor_Blackford"}],"notable":{"is_notable":true,"notable_category":["social_reform","religion"],"notable_blurb":"Founded Female Auxiliary of the American Colonization Society","primary_url":"https://en.wikipedia.org/wiki/Mary_Berkeley_Minor_Blackford","primary_url_label":"Wikipedia"},"narrative_blocks":[{"header":"Founded Fredericksburg's anti-slavery auxiliary at 26","detail":"Blackford kept a journal, Notes Illustrative of the Wrongs of Slavery, recording her evolving beliefs on the subject. She opposed abolition itself as 'impracticable' while remaining personally opposed to slavery — a position that defined the colonizationist movement. Her brother was a missionary in Liberia 1837-1843. She lived to 93, and in 1892 her six surviving children gathered for the first time since the war to celebrate her 90th birthday together in Alexandria. Her grandson Launcelot Minor Blackford wrote her biography, Mine Eyes Have Seen The Glory (Harvard University Press, 1954). She was the sister of Dr. James Monroe Minor (X00513), who married Ellen Josephine Pierrepont (HD1598), a 6th-generation Hooker descendant. (Wikipedia)","body":"Mary Berkeley Minor Blackford founded the Fredericksburg and Falmouth Female Auxiliary of the American Colonization Society in 1829, taught enslaved people to read the Bible in defiance of Virginia law, and maintained decades of correspondence with anti-slavery activists. Yet when the Civil War came, five of her eight children served in the Confederate Army. 'To see my sons arrayed against one part of their country,' she wrote in 1861, 'is a sorrow that makes me feel the grave is the only place for me.'","number":1},{"number":2,"category":"family","header":"Five sons fought for the Confederacy","body":"The woman who founded Fredericksburg’s anti-slavery auxiliary at twenty-six lived to watch five of her sons fight for the Confederacy. She survived the war by thirty years, dying at ninety-three."}],"cross_connections":[],"bio":{"display_name":"Mary Berkeley Minor Blackford","first_name":"Mary","middle_name":"Berkeley","last_name":"Blackford","maiden_name":"Minor","married_names":["Blackford"],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/1/15/Mary_Berkeley_Minor_Blackford.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-minor-1802"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[{"type":"in_law","related_id":"HD1598","display_label":"married his son Doctor in 1847","slug":"ellen-minor-1828"}]}