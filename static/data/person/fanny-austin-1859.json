_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"She died April 1866","body":"Fanny Pixley married James Sperry in Great Barrington in January 1812 and they lived at Henrietta, New York, raising eight children across three decades; she died April 29, 1866 in Rochester at approximately seventy-eight, and James outlived her by almost exactly eleven months — dying March 29, 1867 also in Rochester. The Pixley genealogy corrects the EH date: Fanny died in 1866, not 1867 — she went first, after fifty-four years of marriage, and James followed in the same city the following spring."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"fanny-sperry-1788"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}