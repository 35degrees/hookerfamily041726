,{"role":"Warden and Clerk","organization":"St. John's Protestant Episcopal Parish, North Haven","notes":"Served in this role for over thirty years."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["cousin_marriage"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Three wives, three children buried by 1841","body":"Ezra outlived his first two wives — Esther in 1836 and Mary in 1853 — and buried three of his five children before they reached age seven. Only Ezra Leander, born 1844 to his third wife, reached adulthood, and he never married."}],"quotes":[],"sources":[{"label":"FindAGrave memorial 127199478","url":"https://www.findagrave.com/memorial/127199478/ezra-stiles"}],"research_sources":[],"documents":[],"slug":"ezra-stiles-1804"},"HD4087":{"id":"HD4087","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Charles","middle_name":"William","last_name":"Stiles","married_names":[],"gender":"male","display_name":"Charles William Stiles"},"birth":{"year":1833,"month":2,"day":3,"city":"North Haven","county":"New Haven County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1840,"month":8,"day":7,"country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":2,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H01186","father_name":"Ezra Stiles","mother_id":"HD1446","mother_name":"Esther Pierpont Stiles"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_young"],"research_tags":[],"cross_