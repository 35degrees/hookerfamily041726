","date_year":1840,"date_month":10,"date_day":15,"location_country":"United States","end_type":"death","end_year":1866,"children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["illinois_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Died childless; her sister Diantha married her widower","body":"Lucy Strong Phelps died on February 22, 1866 at age forty-five — without children — and just eight months later her sister Diantha married her widower Franklin Hope, repeating the very pattern that had brought their own parents together: their mother Mary Deming Hooker had married Burnham Phelps after Burnham's first wife Louisa Hooker died in 1812. The Hooker-Phelps family repeated this pattern across two generations."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909), entries 483–2370","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"lucy-hope-1820"},"I00775":{"id":"I00775","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Franklin","middle_name":"A","last_name":"Hope","married_names":[],"gender":"male","display_name":"Franklin A. Hope"},"birth":{},"baptism":{},"death":{"year":1884,"month":9,"day":18,"city":"Marlboro","county":"Bureau County","state":"Illinois","country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"numb