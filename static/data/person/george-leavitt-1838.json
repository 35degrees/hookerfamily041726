:[],"slug":"george-leavitt-1838"},"X01346":{"id":"X01346","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0881","date_year":1866,"date_month":10,"date_day":2,"location_city":"Lancaster","location_state":"Massachusetts","children_ids":["HD0886","HD0887","HD0888","HD0889","HD0890"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Henrietta Swan Kendrick","first_name":"Henrietta","middle_name":"Swan","maiden_name":"Kendrick","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"henrietta-kendrick"},"HD0886":{"id":"HD0886","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD0881","mother_research_notes":"Henrietta Swan Kendrick Leavitt","mother_id":"X01346"},"tags":[],"sources":[],"birth":{"year":1868},"death":{"year":1921},"prominent_name_reason":"HENRIETTA SWAN LEAVITT (1868-1921) — astronomer at Harvard College Observatory. Discovered the period-luminosity relationship for Cepheid variable stars (1908, confirmed 1912). Her discovery became the fundamental \"cosmic yardstick\" enabling Edwin Hubble to determine that galaxies exist far beyond the Milky Way and that the universe is expanding. \"If Henrietta Leavitt had provided the key to determine the size of the cosmos, then it was Edwin Powell Hubble who inserted it in the lock.\" Nobel Prize nomination attempted 1924 (posthumously ineligible). Asteroid 5383 Leavitt and lunar crater Leavitt named in her honor. Generation 8 from Thomas Hooker. Wikipedia: https://en.wikipedia.org/wiki/Henrietta_Swan_Leavitt","cross_connections":[{"type":"family_connection","related_id":"HD0881","display_label":"Astronomer who discovered the period-luminosity relationship for Cepheid variables, enabling.","link_text":"George Roswell Leavitt"},{"type":"family_connection","related_id":"HD0880","display_label":"Astronomer who discovered the period-luminosity relationship for Cepheid variables, enabling.","link_text":"Erasmus Darwin Leavitt Jr."},{"type":"family_connection","related_id":"H00302","display_label":"Astronomer who discovered the period-luminosity relationship for Cepheid variables, enabling.","link_text":"Sarah Hooker"},{"type":"family_connection","related_id":"H00685","display_label":"Astronomer who discovered the period-luminosity relationship for Cepheid variables, enabling.","link_text":"Roger Leavitt"},{"type":"family_orbit","related_id":"HD0901","display_label":"Great-nephew killed at Khe Sanh in 1968 age 21","link_text":"PFC Gridley Barstow Strong"},{"type":"family_orbit","related_id":"HD0894","display_label":"Sister's son became Ambassador; her grandson died at Khe Sanh","link_text":"Robert Campbell Strong"},{"type":"parallel_careers","related_id":"X02263","display_label":"a 1868-born astronomer whose telescopes mapped the cosmos"},{"type":"parallel_careers","related_id":"HD3148","link_text":"Eunice Newton Foote","display_label":"a woman scientist eclipsed by a man, rediscovered a century later"}],"gender":"female","marriages":[],"notable":{"is_notable":true,"notable_category":["science"],"notable_blurb":"Discovered the period-luminosity law for Cepheids","primary_url":"https://en.wikipedia.org/wiki/Henrietta_Swan_Leavitt","primary_url_label":"Wikipedia"},"bio":{"display_name":"Henrietta Swan Leavitt","first_name":"Henrietta","middle_name":"Swan","maiden_name":"Leavitt","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777495652/Henrietta_Swan_Leavitt_wgx0aa.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"science","header":"Discovered the cosmic measuring rod for galaxies","body":"Working as a 'Harvard Computer' studying photographic plates of the Magellanic Clouds, she found that Cepheid variable stars pulse at a rate directly tied to their brightness. This single relationship gave Edwin Hubble the tool to prove that other galaxies existed beyond the Milky Way and to measure cosmic expansion."},{"number":2,"category":"character","header":"Worked deaf and underpaid for thirty years","body":"An illness in young adulthood left her permanently deaf. As one of Edward Pickering's 'computers' she was paid thirty cents an hour, less than men doing comparable work, and credit for her discoveries was often subsumed under her supervisor's name."},{"number":3,"category":"career","header":"Catalogued thousands of variable stars before her breakthrough","body":"Her period-luminosity discovery emerged from years of meticulous work cataloguing thousands of variable stars on photographic plates. By the time she published the Cepheid relationship in 1912, she had already identified more than half of all known variable stars in the southern sky."},{"number":4,"category":"legacy","header":"Nobel nomination came three years too late","body":"Swedish mathematician Gösta Mittag-Leffler began the process of nominating her for the Physics Prize in 1924 before learning she had died of cancer in 1921 at age fifty-three. The Nobel Prize cannot be awarded posthumously."},{"number":5,"category":"legacy","header":"Modern artists reckon with her erased contribution","body":"In 2014 Aura Satz superimposed her portrait on a photograph of the lunar crater named for her, calling 'women's names associated with imperceptible craters' an apt metaphor for women's brief visibility in history. Anna Von Mertens's 2018-2019 Radcliffe exhibition 'Measure' depicted in quilt form the night skies over Lancaster Massachusetts at her birth and Cambridge at her death."}],"videos":[{"video_id":"VID007"}],"slug":"henrietta-leavitt-1868"},"HD0887":{"id":"HD0887","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD0881","mother_research_notes":"Henrietta Swan Kendrick Leavitt","mother_id":"X01346"},"tags":[],"sources":[],"birth":{"year":1873,"month":8,"day":1,"city":"Cambridge","county":"Middlesex County","state":"Massachusetts","country":"United States"},"death":{"year":1955,"month":5,"day":22,"city":"Akron","county":"Summit County","state":"Ohio","country":"United States"},"marriages":[{"spouse_id":"X00154","children_ids":["HD0891","HD0892","HD0893","HD0894","HD0895"],"marriage_number":1}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Martha Almira Leavitt Strong","first_name":"Martha","last_name":"Strong","maiden_name":"Leavitt","middle_name":"Almira Leavitt","married_names":["Strong"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"martha-strong-1873"},"X00154":{"id":"X00154","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendan