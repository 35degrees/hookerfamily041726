0892":{"id":"HD0892","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00154","mother_id":"HD0887"},"tags":[],"sources":[],"birth":{"year":1907},"death":{"year":1938},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"William Leavitt Strong","first_name":"William","last_name":"Strong","middle_name":"Leavitt","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"william-strong-1907"},"HD0893":{"id":"HD0893","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00154","mother_id":"HD0887"},"tags":[],"sources":[],"birth":{"year":1911},"death":{"year":2001},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"Named for a family tradition","detail":"Captain John Kendrick pioneered American trade in the Pacific Northwest, Hawaii, and China, and was the first American to attempt to open trade with Japan. He was killed in 1794 in Hawaii during an exchange of cannon salutes, when a cannon was fired loaded by accident. His name carried enough prestige in the Kendrick family that it passed as a middle name into the Strong line: John Kendrick Strong's sister Louise carried it too (Louise Kendrick Brown, HD2780). Whether the Kendrick family descended directly from the captain or simply shared the surname and admired him is not documented. (Wikipedia — John Kendrick; family records)","body":"John Kendrick Strong was named for a family tradition rooted in his grandmother Henrietta Swan Kendrick Leavitt's surname. Captain John Kendrick (1740–1794) — the famous sea captain, Boston Tea Party participant, and leader of the first American expedition to the Pacific Northwest — inspired the Kendrick family's naming tradition across generations.","number":1}],"cross_connections":[],"bio":{"display_name":"John Kendrick Strong","first_name":"John","last_name":"Strong","middle_name":"Kendrick","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-strong-1911"},"HD0894":{"id":"HD0894","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00154","mother_id":"HD0887"},"tags":["diplomat"],"sources":[{"label":"Wikipedia — Robert C. Strong","url":"https://en.wikipedia.org/wiki/Robert_C._Strong"}],"birth":{"year":1915,"month":9,"day":29,"city":"Chicago","county":"Cook County","state":"Illinois"},"death":{"year":1999,"month":12,"day":28,"city":"Tucson","county":"Pima County","state":"Arizona"},"burial":{"cemetery_id":"CEM100"},"marriages":[{"spouse_id":"X00157","children_ids":["HD0901","HD3140","HD3141"],"marriage_number":1,"date_year":1939,"date_month":9,"date_day":1,"location_city":"Westminster","location_country":"United Kingdom"}],"cross_connections":[{"type":"family_orbit","related_id":"HD0886","display_label":"His mother Martha was Henrietta Swan Leavitt's sister — the astronomer whose Cepheid work Hubble used to prove the universe was expanding.","link_text":"Henrietta Swan Leavitt"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["diplomacy","politics"],"notable_blurb":"U.S. Ambassador to Iraq 1963-67","primary_url":"https://en.wikipedia.org/wiki/Robert_C._Strong","primary_url_label":"Wikipedia"},"institutions":[{"institution_id":"INST065","institution_blurb":"Beloit College B.A. 1938. Member Sigma Pi fraternity. Addressed Beloit alumni April 1967, just after leaving Baghdad, as one of the last Americans out of Iraq."},{"institution_id":"INST064","institution_blurb":"University of Wisconsin-Madison — graduate study."}],"narrative_blocks":[{"header":"He passed a three-day entrance exam in 1939","body":"Robert Campbell Strong passed the three-day competitive examination for the U.S. Foreign Service in 1939. His first posting was as vice consul in Prague, Czechoslovakia — the same year Germany occupied the country. He then moved to Durban, South Africa, and later Sofia, Bulgaria, before returning to Washington.","number":1},{"header":"He was America's man in Taipei in December","body":"In December 1949, just weeks after the Republic of China government retreated to Taiwan following Communist forces' victory on the mainland, Strong was named Chargé d'Affaires ad interim of the U.S. Embassy Office in Taipei. He monitored Nationalist activities, handled sensitive communications about possible U.S. military assistance, and relayed Washington's formal protests when ROC aircraft launched air raids on Shanghai. He was the face of American diplomacy to a government that had just lost a billion people.","number":2},{"header":"Kennedy sent him to Baghdad in 1963","body":"President Kennedy appointed Strong U.S. Ambassador to Iraq on May 13, 1963, just months after a Ba'athist coup had overthrown Prime Minister Qasim. Strong had written the State Department memorandum recommending recognition of the new regime. He navigated a second coup in November 1963, Kurdish insurgencies, and growing Iraqi alignment with the Soviet bloc