g class of what grew into Yale Divinity School. The twelve students formalized the program by inviting Professor Kingsley to teach Hebrew and Professor Goodrich elocution and sermon composition, transforming twice-weekly evenings at Fitch's house into Yale's first theological department."}],"burial":{"cemetery_id":"CEM056"},"number_of_marriages":2,"slug":"horace-hooker-1793"},"I00298":{"id":"I00298","prefix":"I","classification":{"descent_from_thomas_hooker":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"include_in_path_calculation":false},"bio":{"display_name":"Harriet Watkinson Hooker","first_name":"Harriet","maiden_name":"Watkinson","last_name":"Hooker","married_names":["Hooker"],"gender":"female"},"birth":{"year":1815,"country":"United States"},"death":{"year":1884,"month":3,"day":6,"county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_name":"Edward Watkinson"},"marriages":[{"marriage_number":1,"spouse_id":"H00546","date_year":1843,"date_month":11,"date_day":22,"children_ids":["H01466","H01467"]}],"tags":[],"narrative_blocks":[],"cross_connections":[],"burial":{"cemetery_id":"CEM056"},"number_of_marriages":1,"slug":"harriet-watkinson-1815"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}