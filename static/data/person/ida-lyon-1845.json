rate","rank_start":"Cadet","rank_end":"Captain","service_years":"1861-1865","role":"Served in the Confederate Army under his father Lt. Gen. Leonidas Polk; advanced from cadet to captain.","battles":[]},{"war":"World War I","war_id":"WAR007","side":"United States","rank":"1st Lieutenant","service_years":"1917-1918","unit":"U.S. Army Reserve Medical Corps","role":"Volunteered in 1917 at age seventy-two; held commission until death June 23, 1918.","notes":"Remarkable Confederate-to-Union late-life service arc."}],"narrative_blocks":[{"number":1,"category":"achievement","header":"Wrote authoritative biography of his Confederate-general father","body":"William Mecklenburg Polk wrote the two-volume Leonidas Polk: Bishop and General (1893), the standard biography of his father and a primary source for subsequent Polk scholarship. The work combined personal recollection with his father's papers and contemporary military records. It remained the definitive treatment of Bishop Polk well into the twentieth century."},{"number":2,"category":"family","header":"Son Frank served as first US Under Secretary","body":"His son Frank Lyon Polk served as Counselor to the U.S. Department of State through the First World War and became the first Under Secretary of State when that position was created in 1919. Frank had earlier served as Acting Secretary of State during portions of the Wilson administration. The Polk lineage — Bishop, then physician-biographer, then diplomat — spans three generations and three callings."},{"number":3,"category":"career","header":"Cornell Medical College Dean and Gynecology Professor","body":"After Confederate Army service, William Mecklenburg Polk graduated from Columbia's College of Physicians and Surgeons. He became Dean and Professor of Gynecology at Cornell University Medical College in 1898. Earlier appointments included Professor of Obstetrics and Gynecology at NYU (1879-1898) and Professor of Therapeutics and Clinical Medicine at Bellevue Hospital Medical College (1875-1879)."},{"number":4,"category":"achievement","header":"Returned to US service in WWI at seventy-two","body":"Polk served as President of the New York Academy of Medicine from 1910 to 1914, and as President of the Aztec Club of 1847 in 1912-1913. After volunteering in 1917 at age seventy-two, he held a 1st Lieutenant commission in the U.S. Army Reserve Medical Corps until his death June 23, 1918 — a Confederate Captain who returned to U.S. service late in life."}],"burial":{"place":"Woodlawn Cemetery","city":"Bronx","state":"New York"},"slug":"william-polk-1844"},"HD5056":{"id":"HD5056","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"generation_from_thomas":9,"is_easter_egg":false},"parents":{"father_id":"HD2601","mother_id":"X01884"},"tags":["died_young"],"sources":[],"marriages":[],"gender":"male","number_of_marriages":0,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1869},"death":{"year":1877,"age":8},"cross_connections":[],"bio":{"display_name":"Leon Polk","first_name":"Leon","last_name":"Polk","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Leon died young","body":"Leon died in 1877, aged about eight."}],"slug":"leon-polk-1869"},"HD5047":{"id":"HD5047","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"generation_from_thomas":9,"is_easter_egg":false},"parents":{"father_id":"HD2601","mother_id":"X01884"},"tags":["yale_graduate","columbia_law","diplomat","lawyer"],"sources":[{"short":"Wikipedia: Frank Polk","url":"https://en.wikipedia.org/wiki/Frank_Polk"},{"short":"FindAGrave Frank Lyon Polk","url":"https://www.findagrave.com/memorial/127058396"}],"marriages":[{"spouse_id":"X02878","spouse_name":"Elizabeth Sturgis Potter","marriage_number":1,"date_year":1908,"date_month":1,"date_day":27,"place_city":"Philadelphia","place_state":"Pennsylvania","children_ids":["HD5048","HD5049","HD5050","HD5051","HD5052"],"end_type":"death","end_year":1943}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["diplomat","law","public_service"],"notable_blurb":"First U.S. Under Secretary of State, 1919","primary_url":"https://en.wikipedia.org/wiki/Frank_Polk","primary_url_label":"Wikipedia"},"birth":{"year":1871,"month":9,"day":13,"city":"New York","state":"New York","country":"USA"},"death":{"year":1943,"month":2,"day":7,"city":"New York","state":"New York","country":"USA","age":71},"cross_connections":[],"bio":{"display_name":"Frank Lyon Polk","first_name":"Frank","last_name":"Polk","middle_name":"Lyon","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779680354/960px-Frank_Lyon_Polk__LC-DIG-npcc-01132__trimmed_vkkbr4.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST153","relationship":"donor","years":"1928","institution_blurb":"Awarded D.C.L. honorary degree from the University of the South in 1928 — grandson of co-founder Bishop Polk."}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"Spanish-American War","war_id":"WAR012","side":"United States","rank":"Captain","dates_active":"April 1898 - November 30, 1899","service_record":"Served with Troop A, New York Volunteer Cavalry, April 1898. Appointed Captain and assistant on Quartermaster Staff of General Ernst's Brigade, June 19, 1898. Stationed at Chickamauga, GA, Charleston, SC, and in Puerto Rico. Honorably discharged November 30, 1899.","unit":"Troop A, New York Volunteer Cavalry; later Quartermaster Staff, General Ernst's Brigade"}],"burial":{"place":"Woodlawn Cemetery","city":"Bronx","state":"New York"},"narrative_blocks":[{"number":1,"category":"career","header":"First US Under Secretary of State, 1919-1920","body":"When the office of U.S. Under Secretary of State was created in 1919, Frank Lyon Polk became its first occupant — serving July 1, 1919 to June 15, 1920. He briefly served as Acting Secretary of State from February 14 to March 12, 1920, between Robert Lansing and Bainbridge Colby. He had previously served as the 4th Counselor of the State Department from September 16, 1915 through June 30, 1919."},{"number":2,"category":"achievement","header":"Headed American delegation at Paris Peace Conference","body":"After President Wilson and Secretary Lansing departed Paris in 1919, Polk headed the American Commission to Negotiate Peace and represented the United States at the remaining Paris Peace Conference sessions. He was made a Grand Officer of the French Legion of Honor and elected to the North Carolina Society of the Cincinnati in 1919. His portrait was painted by Sir Oswald Birley in 1923."},{"number":3,"category":"career","header":"Name partner of Davis Polk & Wardwell law firm","body":"Frank Lyon Polk's surname is the 'Polk' in Davis Polk & Wardwell — one of the elite New York law firms still bearing his name today. He had managed John W. Davis's 1924 Democratic presidential campaign; Davis was a fellow Davis Polk name partner. From 1932 until his death in 1943 he served as President of the New York Public Library."},{"number":4,"category":"character","header":"Survived attempted mayoral assassination, 1914","body":"On April 17, 1914, while serving as Corporation Counsel for New York City, Polk was wounded by gunfire when a former city employee attempted to assassinate Mayor John Purroy Mitchel. The mayor survived; Polk recovered from his gunshot wound. The episode preceded by sixteen months his appointment as Counselor to the State Department."}],"slug":"frank-polk-1871-2"},"X02878":{"id":"X02878","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD5047","spouse_name":"Frank Lyon Polk","marriage_number":1,"date_year":1908,"date_month":1,"date_day":27,"place_city":"Philadelphia","place_state":"Pennsylvania","children_ids":["HD5048","HD5049","HD5050","HD5051","HD5052"],"end_type":"death","end_year":1943}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1886,"month":7,"day":31,"city":"Philadelphia","state":"Pennsylvania","country":"USA"},"death":{"year":1960,"month":10,"day":25,"city":"Manhattan","county":"New York County","state":"New York","age":74},"cross_connections":[],"bio":{"display_name":"Elizabeth Sturgis Potter Polk","first_name":"Elizabeth","last_name":"Polk","maiden_name":"Potter","middle_name":"Sturgis","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"place":"Woodlawn Cemetery","city":"Bronx","state":"New York"},"slug":"elizabeth-potter-1886"},"HD5048":{"id":"HD5048","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"generation_from_thomas":10,"is_easter_egg":false},"parents":{"father_id":"HD5047","mother_id":"X02878"},"tags":[],"sources":[],"marriages":[],"gender":"male","number_of_marriages":0,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1908,