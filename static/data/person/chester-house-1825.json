-house-1797"},"X02754":{"id":"X02754","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Sophia","middle_name":"Risley","last_name":"House","maiden_name":"Risley","married_names":["House"],"gender":"female","display_name":"Sophia Risley House"},"birth":{"year":1798,"month":6,"day":25,"county":"Gloucester","state":"New Jersey","country":"United States"},"baptism":{},"death":{"year":1873,"month":6,"day":16,"city":"Turin","county":"Lewis","state":"New York","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM248","plot_notes":"Find a Grave memorial 82482462"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3619","date_year":1819,"location_country":"United States","end_type":"death","end_year":1873,"children_ids":["HD3636","HD3637","HD3638","HD3639"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"New Jersey-born wife joined Cyprian's Turin migration","body":"Sophia was born in Gloucester County New Jersey and married Cyprian House in 1819 — soon after his arrival in Turin Lewis County NY. They were married fifty-four years and raised four children in Turin together. Sophia died there in June 1873, ten years before Cyprian."}],"quotes":[],"sources":[{"short":"Find a Grave — Turin Cemetery","url":"https://www.findagrave.com/cemetery/66512/turin-cemetery"},{"short":"FamilySearch — House family records","url":"https://ancestors.familysearc