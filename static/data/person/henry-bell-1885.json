lver ran printing business for many years."},{"role":"Co-founder","organization":"Waupun Oil Company, Waupun Wisconsin","start_year":1866,"notes":"With others formed oil company 1866; sold oil by the barrel from West Virginia well."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["wisconsin_migration"],"research_tags":["has_discrepancy"],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Lawyer who published Fond du Lac's first newspaper","body":"Eli Hooker settled in Fond du Lac, Wisconsin in 1846, co-founded the city's first newspaper the Fond du Lac Journal, and became a Waupun attorney who rode horseback across Dodge County to court in Juneau — sometimes staying overnight at an inn between Minnesota Junction and Juneau. He attended the 1860 Republican convention in Chicago that nominated Lincoln, gave temperance talks, and died December 10, 1889 — his wife Catherine following exactly one month later."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"eli-hooker-1820"},"I00886":{"id":"I00886","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Catherine","middle_name":"Richardson","last_name":"Hooker","maiden_name":"Sharp","married_names":["Hooker"],"gender":"female","display_name":"Catherine Richardson Hooker"},"birth":{"year":1832,"month":1,"day":6,"city":"Gambier","county":"Knox County","state":"Ohio","country":"United States"},"baptism":{},"death":{"year":1890,"month":1,"day":10,"city":"Waupun","county":"Dodge County","state":"Wisconsin","country":"United States"},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":fals