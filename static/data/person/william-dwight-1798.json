ing_inspiration":[],"institutions":[{"institution_id":"INST133","relationship":"alumnus","institution_blurb":"Attended Boston Latin School."},{"institution_id":"INST002","relationship":"alumnus","years":"1886"},{"institution_id":"INST034"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"education":[{"institution_id":"INST133","school_name":"Boston Latin School","dates":"attended pre-college","type":"secondary","notes":"Per research notes: 'Attended Boston Latin School — co-founded 1636 by John Cotton, contemporary of Thomas Hooker.'"},{"institution_id":"INST002","dates":"1886","notes":" — Harvard class of 1886. Founding trustee of Wentworth Institute of Technology. Harvard holds the annual Frederick William Atherton Lecture (since 1966) on ethical and social criticism. Great-great-great-grandson of Jonathan Edwards."}],"slug":"frederick-atherton-1865"},"HD2067":{"id":"HD2067","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00665","mother_id":"HD2064"},"tags":[],"sources":[],"birth":{"year":1868},"death":{"year":1917},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Edward Dwight Atherton","first_name":"Edward","last_name":"Atherton","middle_name":"Dwight","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"edward-atherton-1868"},"HD2068":{"id":"HD2068","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00665","mother_id":"HD2064"},"tags":["academic"],"sources":[],"birth":{"year":1871,"month":9,"day":25},"death":{"year":1944,"month":3,"day":8},"gender":"male","notable":{"is_notable":true,"notable_category":[]},"narrative_blocks":[{"header":"Composer trained by the leading European masters","detail":"Set music to the poems of Charlotte Perkins Gilman. Where his brother Frederick legacy is a Harvard lecture series, Percy is a $15,000 Harvard scholarship fund for musical talent — the two brothers embodying the Dwight family twin traditions of public life and the arts. (Wikipedia)","body":"Studied composition under three of the most eminent Gilded Age European teachers, composing songs, chamber music, and comic operas from his lifelong Boston home.","number":1},{"number":2,"category":"arts","header":"He set Charlotte Perkins Gilman to music","body":"Atherton composed songs, chamber works, and comic operas, and set the poems of feminist writer Charlotte Perkins Gilman — their correspondence survives at Harvard. He never married, living his whole life at 144 Commonwealth Avenue."},{"number":3,"category":"arts","header":"He left Harvard a scholarship for musicians","body":"His will endowed a $15,000 Harvard fund for musically gifted students and gave $1,000 to the Library of Congress music division. He had trained under the great European masters — Rheinberger in Munich, Sgambati in Rome, Widor in Paris."}],"marriages":[],"cross_connections":[],"bio":{"display_name":"Percy Lee Atherton","first_name":"Percy","last_name":"Atherton","middle_name":"Lee","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus","years":"1893"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"education":[{"school_name":"Harvard College","dates":"1893","type":"undergraduate","notes":"honors in music"}],"career":[{"role":"Composer","notes":"songs, chamber music, comic operas"}],"slug":"percy-atherton-1871"},"HD2069":{"id":"HD2069","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2051","mother_id":"X00662"},"tags":[],"sources":[],"birth":{"year":1841,"month":3,"day":13,"city":"New York","state":"New York"},"death":{"year":1921,"month":5,"day":19,"city":"Brooklyn","state":"New York"},"orbit_connections":[{"name":"Rossiter Worthington Raymond","relationship":"Husband of Sarah Mellen Dwight (HD2073)","notes":"Rossiter Worthington Raymond (Apr 27, 1840 Cincinnati OH - Dec 31, 1918 Brooklyn NY). Mining engineer, legal scholar, author, Civil War officer, chess player, poet. Described at his memorial as one of the most remarkable cases of versatility that our country has ever seen. Aide-de-camp to General Fremont during the Civil War; commended for gallant conduct. US Commissioner of Mining Statistics. Secretary of AIME 1884-1911 (AIME named its Rossiter W. Raymond Memorial Award after him in 1945). Raymond Peak (10,014 ft), Alpine County CA, named for him in 1865. His parents participated in the Underground Railroad in Syracuse NY. Member of the American Philosophical Society. Famous quote: Life is eternal; and love is immortal; and death is only a horizon; and a horizon is nothing save the limit of our sight. Published Western novel Brave Hearts (1873). Buried Green-Wood Cemetery, Brooklyn. (Wikipedia; FindAGrave)","primary_url":"https://en.wikipedia.org/wiki/Rossiter_W._Raymond","connection_type":"orbit_spouse"}],"gender":"female","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sarah Mellen Dwight","first_name":"Sarah","middle_name":"Mellen","maiden_name":"Dwight","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-dwight-1841"},"H00920":{"id":"H00920","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1764},"death":{"year":1846},"parents":{"father_id":"X00635","mother_id":"H00379"},"marriages":[{"spouse_id":"X00659","children_ids":["HD2050","HD2051","HD2052"],"marriage_number":1,"date_year":1792,"date_month":9,"date_day":9}],"tags":["author","journalist","abolitionist","congressman"],"sources":[{"short":"Edward Hooker 1909","entry":"920"}],"cross_connections":[{"type":"mentor_student","notes":"Admitted to bar 1787. The mentor-student relationship between these two Jonathan Edwards grandchildren is documented in Dwight's biography. (Wikipedia; DAB)","related_id":"H00920","display_label":"Theodore Dwight Sr. studied law under his cousin Pierpont Edwards.","link_text":"Theodore Dwight"},{"type":"mentor_student","notes":"Admitted to bar 1787. The mentor-student relationship between these two Jonathan Edwards grandchildren is documented in Dwight's biography. (Wikipedia; DAB)","related_id":"H00386","display_label":"Theodore Dwight Sr. studied law under his cousin Pierpont Edwards.","link_text":"Pierpont Edwards"},{"type":"civic_peer","notes":"Both were grandsons of Jonathan Edwards. Both had their careers ultimately shaped by political catastrophe — Burr's duel with Hamilton (1804) and Dwight's association with the Hartford Convention (1814). Their brief partnership is documented in Appletons' Cyclopaedia and DAB.","related_id":"H00920","display_label":"Theodore Dwight Sr. had a brief law partnership with his.","link_text":"Theodore Dwight"},{"type":"civic_peer","notes":"Both were grandsons of Jonathan Edwards. Both had their careers ultimately shaped by political catastrophe — Burr's duel with Hamilton (1804) and Dwight's association with the Hartford Convention (1814). Their brief partnership is documented in Appletons' Cyclopaedia and DAB.","related_id":"H00913","display_label":"Theodore Dwight Sr. had a brief law partnership with his.","link_text":"Aaron Burr Jr."}],"orbit_connections":[{"name":"Richard March Hoe (X00797) — grandson of rotary press inventor; married granddaughter of Theodore Dwight's line","person_id":"X00797","relationship":"Richard March Hoe Harper Sr. married Mabel Simpkins Bacon (HD2426), granddaughter of Dr. Gorham Bacon (HD2413), great-great-granddaughter of Amelia Dwight (HD2286), great-great-great-granddaughter of Rhoda Edwards Dwight, and a descendant of Theodore Dwight Sr. (H00920). His grandfather Richard March Hoe invented the rotary printing press (1843) and the web perfecting press (1871) that printed 18,000 newspapers/hour — the same generation as Theodore Dwight Sr.'s 1825 steam-press newspaper.","connection_type":"orbit_non_descendant"}],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"U.S. Congressman","primary_url":"https://en.wikipedia.org/wiki/Theodore_Dwight_(journalist)"},"narrative_blocks":[{"header":"Hartford Convention secretary","detail":"Dwight was at the center of Connecticut Federalism for two decades — as editor of the Connecticut Mirror (its primary organ), as a member of the Connecticut State Council 1809-15, and briefly as a US Congressman (Dec 1806-Mar 1807). His 1833 History of the Hartford Convention became the primary Federalist account of that controversy. The Convention's association with disloyalty during the war's victorious conclusion largely destroyed the Federalist Party, making Dwight and his cousin Aaron Burr Jr. (H00913) emblematic of two very different careers cut short by political miscalculation. (Wikipedia)","body":"Dwight served as secretary of the Hartford Convention in 1814-15, the gathering of New England Federalists whose opposition to the War of 1812 effectively ended the Federalist Party as a national force.","number":1},{"header":"New York Daily Advertiser","detail":"He built the Advertiser into a major New York paper over nearly two decades before the Great Fire of December 1835 destroyed its offices and presses. His father's Hartford Courant and Connecticut Mirror connections gave him a journalism apprenticeship; the Advertiser represented his mature achievement. His son William Richard Dwight later co-edited the paper with him. (Wikipedia; Dwight 1874)","body":"Dwight's New York Daily Advertiser (founded 1817) was the first American periodical printed by steam-powered cylinder press (1825), capable of 2,000 copies per hour.","number":2},{"header":"Abolitionist — argued for immediate emancipation and reparations","detail":"Using natural law philosophy, Dwight contended that Black Americans had every right to use force to defend their natural rights — a more radical position than most white abolitionists of his generation. This oration preceded his better-known journalism career and connects him, and through him his son Theodore Dwight Jr. (HD2050), to the organized abolitionist movement that would culminate in the Civil War. His son Theodore Jr. continued this tradition, working directly with the enslaved scholar Omar ibn Said. (Theodore Dwight, \"An Oration... Before the Connecticut Society,\" published pamphlet)","body":"In an oration before the Connecticut Society for the Promotion of Freedom, Dwight argued that enslaved people had never consented to a social contract and were therefore in a state of war with white Americans, entitled not only to freedom but to reparations.","number":3},{"header":"Jefferson and Sally Hemings","detail":"Published decades before the abolitionist press widely addressed the Hemings relationship, Dwight's 1839 work represents one of the earliest treatments of what would remain a contested historical question for more than 150 years. His anti-Jeffersonian Federalist politics gave him both motive and audience. His cousin Aaron Burr Jr. (H00913) — Jefferson's bitter political enemy — would have relished the publication had he lived to see it. (Wikipedia; The Character of Thomas Jefferson, Hartford, 1839)","body":"In The Character of Thomas Jefferson (1839), Dwight argued that Jefferson's character was duplicitous and explicitly referenced his relationship with Sally Hemings.","number":4}],"number_of_marriages":1,"bio":{"display_name":"Theodore Dwight","first_name":"Theodore","last_name":"Dwight","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/9e/Theodore_Dwight.jpg/440px-Theodore_Dwight.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"theodore-dwight-1764"},"X00659":{"id":"X00659","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1765,"month":11,"day":17,"city":"Middletown","state":"Connecticut"},"death":{"year":1846,"month":4,"day":2,"city":"New York City","state":"New York"},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00920","date_year":1792,"date_month":9,"date_day":9,"children_ids":["HD2050","HD2051","HD2052"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Abigail Alsop","first_name":"Abigail","maiden_name":"Alsop","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"abigail-alsop-1765"},"X00635":{"id":"X00635","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"birth":{"year":1726},"death":{"year":1777},"tags":["loyalist","natchez_colony"],"sources":[],"marriages":[{"spouse_id":"H00379","children_ids":["H00914","H00915","H00916","H00917","H00918","H00919","H00920","H00921","H00922","H00923","H00924","H00925","H00926"],"marriage_number":1,"date_year":1750,"date_month":11}],"gender":"male","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Maj. Timothy Dwight III","title":"Major","first_name":"Timothy","last_name":"Dwight","suffix":"III","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"plot_notes":"Unknown grave near Natchez, Adams County, Mississippi — died in the wilderness 1777, body location never recorded"},"education":[{"school_name":"Yale College","institution_id":"INST022","degree_or_field":"B.A.","class_year":1744,"notes":"Yale 1744."}],"career":[{"role":"Merchant","location":"Northampton, MA","end_year":1776,"notes":"Merchant in Northampton MA. Substantial family business."},{"role":"Judge of common pleas court","organization":"Massachusetts colony courts","location":"Hampshire County, MA","start_year":1758,"end_year":1774,"notes":"Judge 1758-1774. Took oath of fealty to British crown on assuming office — held this oath binding through the Revolution and refused to revoke it."},{"role":"Selectman","organization":"Town of Northampton","location":"Northampton, MA","start_year":1760,"end_year":1764},{"role":"Town Recorder","organization":"Town of Northampton","location":"Northampton, MA","start_year":1760,"end_year":1775},{"role":"Representative","organization":"Massachusetts Legislature","location":"Boston, MA"}],"narrative_blocks":[{"number":1,"category":"politics","header":"Loyalist judge who would not break his oath","body":"He had sworn fealty to the British crown in 1758 on becoming judge of the court of common pleas, and held that oath binding when the Revolution came. His Northampton family suffered increasing community ostracism as the war approached; one biographer called him 'a Loyalist on Christian principle, and yet thoroughly patriotic in his feelings.'"},{"number":2,"category":"family","header":"Took two sons to a Mississippi colony, 1776","body":"Disillusioned with revolutionary Northampton, in May 1776 he sailed from Middletown CT with two of his sons — Sereno and Jonathan — toward a British land grant at Natchez Mississippi. They were accompanied by the Phelps and Lyman families and the Rev Mr Smith's household; within a year he and Mrs Lyman would both be dead at Natchez of fever."},{"number":3,"category":"death","header":"Died in the wilderness, body never recovered","body":"He died at Natchez Mississippi in June 1777 at age fifty in the wilderness, without trial or recorded grave. News of his death traveled slowly back to Northampton; his son Timothy Dwight IV left the Continental Army in 1778 to return home as the oldest surviving male and take charge of the family's affairs."},{"number":4,"category":"family","header":"Carried tiny wife on his palm, arm's length","body":"His wife Mary Edwards Dwight was as small as he was large — he sometimes carried her around the room on his open palm held out at arm's length. She bore him thirteen children, eight of them sons, all noted for fine physical forms — the smallest son Cecil was five-foot-eight-and-a-half and weighed two hundred pounds."}],"slug":"timothy-dwight-iii-1726"},"H00379":{"id":"H00379","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1734,"month":4,"day":4,"city":"Northampton","state":"Massachusetts"},"death":{"year":1807,"month":2,"day":28,"city":"Northampton","state":"Massachusetts"},"parents":{"father_id":"X00128","mother_id":"HD0418"},"tags":["slaveholder"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 379"}],"marriages":[{"spouse_id":"X00635","children_ids":["H00914","H00915","H00916","H00917","H00918","H00919","H00920","H00921","H00922","H00923","H00924","H00925","H00926"],"marriage_number":1,"date_year":1750,"date_month":11}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"civic_connection","related_id":"H00264","display_label":"Refused his Northampton congregation, took communion twelve miles away instead.","link_text":"Rev. John Hooker"}],"bio":{"display_name":"Mary Edwards Dwight","first_name":"Mary","last_name":"Dwight","married_names":["Dwight"],"maiden_name":"Edwards","photo_url":"https://images.findagrave.com/photos/2017/95/22275967_1491537990.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married at sixteen as Edwards left for Stockbridge","body":"Her November 1750 wedding to Major Timothy Dwight came two months before Jonathan Edwards moved his family to the Stockbridge mission. The marriage was permitted because the family was about to be separated."},{"number":2,"category":"family","header":"Mother of Yale's eighth president Timothy Dwight","body":"Her son Timothy Dwight IV led Yale College from 1795 to 1817. He shaped a generation of New England intellectual life from his grandfather Edwards's old territory."},{"number":3,"category":"religion","header":"Refused her pew when Hooker succeeded her father","body":"When the distant Thomas Hooker descendant Rev. John Hooker became Northampton's pastor after Edwards's dismissal, she placed her own chair in the vestibule below the belfry. On communion Sabbaths she rode twelve miles on a pillion behind her son to take communion at another church."},{"number":4,"category":"family","header":"Heard a year later her husband had died","body":"Major Timothy Dwight III died at Natchez, Mississippi in 1777 during a southern trip. The news did not reach her at Northampton until a full year after his death."},{"number":5,"category":"character","header":"Husband could carry her on his open palm","body":"She was unusually small in stature and was described in old age as 'opinionated and self-willed.' Patriot rabble burned her fields and stole her livestock during the Revolution because of her husband's Tory sympathies."}],"slug":"mary-dwight-1734"}},"burialCemetery":null,"institutionsById":{"INST002":{"id":"INST002","primary_name":"Harvard College","name":"Harvard College","short_name":"Harvard","alt_names":[],"type":"university","founding_year":1636,"location":{"city":"Cambridge","state":"Massachusetts"},"primary_persons":[],"hooker_connected_people":["H00061","I00137","HD1175","X02364","H00028","HD2332","H00007","HD2978","HD0374","HD1641","I00004","HD0888","U00014","HD3350","H00071","I00112","I00002","I00111","HD0372","HD3129","I00005","I00003","H00008","X02366","HD2981","HD3150","HD1149","HD2443","HD0313","HD0309","H00219","T00036","HD3127","U00023","H00036","HD3177","HD0310","T00448","HD0102","HD3286","HD4421","HD0610","H00044","H01554","HD3790","T00063","HD04851","I00060","HD0308","HD2337","H00024","H00038","I00007","H00016","T00073","T0