e":"Connecticut","country":"United States"},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00505","mother_id":"H00449"},"number_of_marriages":0,"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Descended from New Haven Colony's first governor","body":"Mabel Eaton descended from Theophilus Eaton (about 1590-1658) — co-founder of New Haven Colony in 1638 and its first governor for two decades. The Eaton lineage placed her among the small group of Connecticut Hooker descendants who carried New Haven Colony founding-family ancestry alongside their Hartford-Hooker line. The combined Eaton-Hooker descent represented the merger of the two principal seventeenth-century Connecticut colonial-founder lineages."},{"number":2,"category":"family","header":"Named for aunt Mabel Stiles Frost","body":"Mabel was given the same first name as her maternal aunt Mabel Stiles Frost — the 'father of music at North Haven' Titus Frost's wife — preserving the family name across the Stiles-Eaton lines of the late-eighteenth-century North Haven community. Her grandmother Mabel Clark Stiles had been the original Mabel; the name passed through three generations of the family."},{"number":3,"category":"family","header":"Baptized 1783 at St. John's Church North Haven","body":"Mabel was baptized in 1783 at St. John's Episcopal Church North Haven Connecticut. No birth date was recorded for her or for her siblings — the North Haven family's documen