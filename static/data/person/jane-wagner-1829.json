824,"month":9,"day":19,"city":"Junius","state":"New York","country":"United States"},"death":{"year":1865,"month":5,"day":25,"city":"Fort Plain","state":"New York","country":"United States"},"tags":["named_for_hooker"],"has_descendants_documented":true,"naming_inspiration":[{"name_element":"Hooker","inspired_by_id":"H00001","description":"Middle name 'Hooker' honors his mother Ann Hooker Congdon's birth family, descendants of Rev. Thomas Hooker."}],"parents":{"father_id":"I01025","mother_id":"H01268b"},"marriages":[{"marriage_number":1,"spouse_id":"I01031","date_year":1852,"date_month":2,"date_day":9,"location_country":"United States","children_ids":["HD4765","HD4766","HD4767"]}],"number_of_marriages":1,"narrative_blocks":[{"number":1,"category":"death","header":"Named Hooker; died at Fort Plain at forty","body":"James Hooker Congdon — his middle name preserving his mother Ann Hooker's birth family — married Jane Augusta Wagner on February 9, 1852, lived at Troy and Fort Plain, New York, and died there on May 25, 1865 at forty years old, his wife surviving him by forty-two years until her own death in 1907 at Johnstown, New York. He was the eldest child of Ann Hooker Congdon, who herself died at thirty at Freedom, New York in 1834 — and his surname Congdon rather than Hooker was the reason his 'Hooker' name migrated to the middle position, a naming pattern repeated throughout the Hooker family tree when daughters married out."}],"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"generation_from_john_talcott":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"former_ids":[],"is_placeholder":false,"baptism":{},"residence":{"country":"United States"},"burial":{},"education":[],"career":[],"military_service":[],"institutions