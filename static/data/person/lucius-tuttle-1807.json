{"person":{"id":"HD4125","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Lucius","last_name":"Tuttle","married_names":[],"gender":"male","display_name":"Lucius Tuttle"},"birth":{"year":1807,"month":12,"day":7,"city":"Hamden","county":"New Haven County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1885,"month":1,"day":8,"city":"Hamden","county":"New Haven County","state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM312","plot_notes":"Mount Carmel Burying Ground, Hamden — same cemetery as father Eli, grandmother Kezia, and sister Lucy."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD3142","father_name":"Eli Tuttle","mother_id":"I00603","mother_name":"Thankful Asenath Perkins Tuttle"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"place","header":"Lived all seventy-seven years in Hamden CT","body":"Lucius Tuttle was born in Hamden in 1807 and died there in 1885 age 77 — unlike his Ohio-bound brother Leonard or far-traveling nephew Jonathan, he never left the New Haven County town where his grandmother Kezia and father Eli were also buried. All three rest at Mount Carmel Burying Ground."}],"quotes":[],"sources":[{"label":"FindAGrave #11269591","url":"https://www.findagrave.com/memorial/11269591/lucius-tuttle"}],"research_sources":[],"documents":[],"slug":"lucius-tuttle-1807"},"neighborhood":{"focus":{"id":"HD4125","slug":"lucius-tuttle-1807","n":"Luc