,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01111","date_year":1812,"date_month":12,"date_day":1,"location_country":"United States","end_type":"death","end_year":1834,"children_ids":["HD3551","HD3552","HD3553","HD3554","HD3555"],"location_city":"Berlin","location_county":"Hartford","location_state":"Connecticut"}],"education":[],"career":[{"title":"Tinsmith / itinerant tinware seller","type":"trades","notes":"Tinsmith by trade — taught by Enoch Kelsey. He and wife Candace went from town to town selling their wares. Both died young (he 42, she 43); deaths attributed to mercury used in the tin manufacturing process."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Mercury tinsmithing killed husband and wife","body":"Solomon was a tinsmith by trade, taught by Enoch Kelsey of Berlin. He and Candace traveled town to town selling their tinware. Both died young — Solomon at forty-two in 1834 and Candace at forty-three the following year — deaths the family attributed to the mercury used in the tin-making process."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909"},{"short":"FamilySearch — Hooker Gilbert family tree","url":"https://ancestors.familysearch.org/en/tree/person/KP4S-SW7"},{"short":"WikiTree (online genealogy)","url":"https://www.wikitree.com/"}],"research_sources":[],"documents":[],"slug":"solomon-churchill-jr-1791"},"H01111":{"id":"H01111","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Candace","last_name":"Churchill","maiden_name":"Gilbert","married_names":["Churchill"],"gender":"female","display_name":"Candace Gilbert Churchill"},"birth":{"year":1791,"month":7,"day":12,"city":"Middletown","county":"Middlesex","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1835,"month":6,"day":9,"country":"United States","city":"Kensington","county":"Hartford","state":"Connecticut","cause":"Likely mercury poisoning from husband's tinsmithing trade"},"residence":{},"burial":{"cemetery_id":"CEM237"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H00420","mother_id":"X02713"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02721","date_year":1812,"date_month":12,"date_day":1,"location_country":"United States","end_type":"death_of_spouse","end_year":1834,"children_ids":["HD3551","HD3552","HD3553","HD3554","HD3555"],"location_city":"Berlin","location_county":"Hartford","location_state":"Connecticut"}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Candace","inspired_by_id":"X02713","description":"Named for her mother Candace Sage Gilbert, who died in 1805."}],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died at forty-three from her husband's trade","body":"Candace died at age forty-three in 1835 — one year after her husband Solomon Churchill Jr., a tinsmith. Family record attributes both deaths to the mercury used in tin manufacturing. Together they had traveled town to town selling their wares, with their five children left orphaned in 1835."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909"},{"short":"FamilySearch — Hooker Gilbert family tree","url":"https://ancestors.familysearch.org/en/tree/person/KP4S-SW7"},{"short":"Find a Grave — Christian Lane Cemetery","url":"https://www.findagrave.com/cemetery/103278/christian-lane-cemetery"},{"short":"WikiTree (online genealogy)","url":"https://www.wikitree.com/"}],"research_sources":[],"documents":[],"slug":"candace-churchill-1791"},"H00420":{"id":"H00420","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"I00150","mother_id":"H00224"},"tags":["named_for_hooker","revolutionary_war"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 420"},{"short":"Berlin-Peck Memorial Library — Rev War","source_id":"berlin_peck_rev_war"},{"short":"Find a Grave — Christian Lane Cemetery","url":"https://www.findagrave.com/cemetery/103278/christian-lane-cemetery"}],"birth":{"year":1751,"month":6,"day":5,"city":"Berlin","state":"Connecticut","county":"Hartford","country":"United States"},"marriages":[{"marriage_number":1,"spouse_id":"X02713","date_year":1776,"date_month":11,"date_day":1,"location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1805,"children_ids":["H01109","H01110","H01111","H01112","H01113","H01114"]},{"spouse_id":"H00432","children_ids":[],"marriage_number":2,"date_year":1807,"date_month":6,"date_day":30,"end_type":"death_of_spouse","end_year":1840}],"cross_connections":[{"type":"cousin_marriage","related_id":"H00228","display_label":"Maternal uncle whose daughter Sarah he married in 1807.","link_text":"Samuel Hooker Jr."}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1840,"month":12,"day":6,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"bio":{"display_name":"Hooker Gilbert","first_name":"Hooker","last_name":"Gilbert","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[{"name_element":"Hooker","inspired_by_id":"H00224","description":"Given the surname 'Hooker' as his first name in honor of his mother Elizabeth Hooker Gilbert's family. First-name use of the maternal surname is unusual and emphatic — he later married into the Hooker line as well, his second wife Sarah Hooker (H00432) being his maternal first cousin."}],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","rank":"Private","rank_year_start":1776,"rank_year_end":1779,"unit":"Multiple — Capt. Gad Stanley's Co (1776), Capt. Lankton's Co under Col. Noadiah Hooker's Regt (1777), Capt. Matthew Cole's Co (1779)","notes":"Three documented enlistments: (1) June 1776 — four months in Capt. Gad Stanley's Company at the Battle of Harlem Heights; (2) summer 1777 — three months in Capt. Lankton's Company under Col. Noadiah Hooker's Regiment; (3) July 1779 — ten days in Capt. Matthew Cole's Company at the Battle of New Haven (Tryon's Raid). Placed on the federal pension list in 1838. DAR Ancestor #A045110. Source: Berlin-Peck Memorial Library."}],"narrative_blocks":[{"number":1,"category":"military","header":"Three Revolutionary War enlistments and 1838 pension","body":"Hooker Gilbert enlisted three times during the Revolution: four months in June 1776 in Capt. Gad Stanley's Company at the Battle of Harlem Heights; three months in summer 1777 in Capt. Lankton's Company under Col. Noadiah Hooker's Regiment; and ten days in July 1779 in Capt. Matthew Cole's Company at the Battle of New Haven during Tryon's Raid. He was placed on the federal pension list in 1838 and is recorded as DAR Ancestor #A045110."},{"number":2,"category":"family","header":"Married his first cousin Sarah Hooker in 1807","body":"Hooker Gilbert's first wife Candace Sage died May 15, 1805. Two years later on June 30, 1807 he married Sarah Hooker — his maternal first cousin and the daughter of his uncle Samuel Hooker Jr. The marriage united two grandchildren of Samuel Hooker via his daughter Elizabeth Hooker Gilbert and his son Samuel Hooker Jr."},{"number":3,"category":"family","header":"Both spouses died within two days December 1840","body":"Sarah Hooker died December 4, 1840 at Kensington Connecticut at age 77. Hooker Gilbert followed her two days later on December 6, 1840 at age 86 — together they had been married for thirty-three years."},{"number":4,"category":"family","header":"Two grandchildren of Samuel Hooker reunited 1807","body":"Hooker Gilbert and Sarah Hooker were the marriage point where two branches of the Hooker line came back together. His mother Elizabeth and her father Samuel Jr. had been siblings — both children of Samuel Hooker of Kensington. The cousin marriage produced no documented children of its own but closed a fifty-year gap between the two branches."}],"burial":{"cemetery_id":"CEM237"},"slug":"hooker-gilbert-1751"},"X02713":{"id":"X02713","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Candace","last_name":"Gilbert","maiden_name":"Sage","married_names":["Gilbert"],"gender":"female","display_name":"Candace Sage Gilbert"},"birth":{},"baptism":{},"death":{"year":1805,"month":5,"day":15,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00420","date_year":1776,"date_month":11,"date_day":1,"location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1805,"children_ids":["H01109","H01110","H01111","H01112","H01113","H01114"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry varies"}],"research_sources":[],"documents":[],"slug":"candace-sage"}},"burialCemetery":{"id":"CEM235","primary_name":"Chippiannock Cemetery","location":{"city":"Rock Island","county":"Rock Island","state":"Illinois","country":"United States"},"find_a_grave_url":"https://www.findagrave.com/cemetery/105126/chippiannock-cemetery","hooker_connections":["HD3555","X02726"],"notes":"Resting place of Cyrus Churchill (HD3555, 1826-1886) and his wife Louisa Harriett Wilson (X02726, 1837-1923) — the Connecticut-born wagon manufacturer who migrated to Rock Island in mid-19th century, and his Pennsylvania-born wife who arrived in Rock Island as a four-year-old."},"institutionsById":{},"crossConnections":[]}