0","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"title":"Colonel","first_name":"Milton","middle_name":"Anthony","last_name":"Candler","married_names":[],"gender":"male","display_name":"Col. Milton Anthony Candler","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778254343/Milton_A._Candler_-_Brady-Handy_tu9chz.jpg","photo_notes":"Brady-Handy collection portrait, c.1875-79 during his Congressional service."},"birth":{"year":1837,"month":1,"day":11,"city":"Campbellton","county":"Campbell County (now Fulton County, since 1932)","state":"Georgia","country":"United States"},"baptism":{},"death":{"year":1909,"month":8,"day":8,"city":"Decatur","county":"DeKalb County","state":"Georgia","country":"United States"},"residence":{"city":"Decatur","county":"DeKalb County","state":"Georgia","country":"United States"},"burial":{"cemetery_id":"CEM271","plot_notes":"Decatur Cemetery, Decatur GA — buried with wife Eliza"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":true},"notable":{"is_notable":true,"notable_category":["congressman","lawyer","confederate"],"notable_blurb":"Two-term Georgia Congressman; Coca-Cola Asa's older brother","primary_url":"https://en.wikipedia.org/wiki/Milton_A._Candler","primary_url_label":"Wikipedia"},"parents":{"father_name":"Samuel Charles Candler (1809-1873) of Columbia County, Georgia — served in both houses of the Georgia legislature; slaveholder (17 slaves owned + 19 leased per 1860 census)","mother_name":"Martha Bernetta Beall (1819-1897) of Bartow County, Georgia","father_research_notes":"Samuel Charles Candler's father Col. William Candler (1730-1784) led Georgia troops in the American Revolutionary War and later served as state legislator."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02781","date_year":1857,"location_county":"DeKalb County","location_state":"Georgia","location_country":"United States","end_type":"death","end_year":1909,"children_ids":["I00429"]}],"education":[{"institution":"Private education (Campbellton/Villa Rica, Georgia)","notes":"Firstborn son received private education per Candler family means."},{"institution":"University of Georgia, Athens","degree":"A.B.","year_completed":1854,"notes":"Graduated 1854 at age 17."}],"career":[{"title":"Lawyer","organization":"Georgia bar","dates":"1856-1909","type":"law","notes":"Admitted to bar 1856. Began practice in Cassville, Bartow County (where his mother's family lived). Moved to Decatur, DeKalb County 1857 — practiced there most of his remaining life."},{"title":"State Representative","organization":"Georgia State House of Representatives","dates":"1861-1863","type":"politics","notes":"Represented DeKalb County during the Civil War's opening years."},{"title":"Delegate","organization":"Georgia State Constitutional Convention","dates":"1865","type":"politics","notes":"Postwar Reconstruction-era constitutional convention."},{"title":"State Senator","organization":"Georgia State Senate","dates":"1868-1872","type":"politics"},{"title":"Delegate","organization":"Democratic National Convention","dates":"1872, 1876","type":"politics"},{"title":"U.S. Representative (Democrat)","organization":"U.S. House of Representatives","dates":"1875-1879","type":"politics","notes":"44th + 45th Congresses, representing Georgia. Withdrew from re-nomination 1878 after his district adopted a free-silver plank — reflecting the Bourbon Democrat-Greenback fracture in the late-1870s South."}],"military_service":[{"war":"Civil War","branch":"Confederate States Army","rank":"Captain","unit":"10th Regiment Georgia Cavalry, State Guards (Murphey Guards)","dates":"August 1863-1864","notes":"Mounted infantry battalion organized August 1863 to serve six months as local defense west of the Chattahoochee River. The unit was named in honor of his recently deceased father-in-law, Charles Murphey, former US Representative."}],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["congressman","lawyer","confederate","civil_war","slaveholder"],"research_tags":[],"cross_connections":[{"type":"in_law","related_id":"HD3780","display_label":"married his daughter Florence in 1888"}],"narrative_blocks":[{"number":1,"category":"politics","header":"Two-term Georgia Congressman in the Reconstruction era","body":"Milton served two terms in the U.S. House (1875-1879) as a Democrat from DeKalb County. He had earlier sat in the Georgia House (1861-63) and Senate (1868-72) and was a delegate to the 1865 state constitutional convention. He withdrew from re-nomination in 1878 after his district adopted a free-silver plank — a casualty of the Bourbon-Greenback fracture splitting the late-1870s South."},{"number":2,"category":"military","header":"Captained the Murphey Guards Confederate cavalry","body":"In August 1863 Milton accepted a captain's commission in the 10th Regiment Georgia Cavalry, State Guards — known as the Murphey Guards. The unit had been raised by the Candler family in honor of his recently deceased father-in-law Charles Murphey, former U.S. Representative who died January 1861. They served six months as mounted infantry west of the Chattahoochee."},{"number":3,"category":"family","header":"Older brother of Coca-Cola founder Asa Candler","body":"Milton was the eldest of thirteen Candler siblings. His younger brothers included Asa Griggs Candler (1851-1929), who built the Coca-Cola Company, and Rev. Warren Akin Candler (1857-1941), president of Emory University. The Candler family rose from antebellum Carroll County slaveholding to define Atlanta's twentieth-century commercial and educational landscape."}],"quotes":[],"sources":[{"short":"Wikipedia: Milton A. Candler","url":"https://en.wikipedia.org/wiki/Milton_A._Candler","accessed":"2026-05"},{"short":"Find a Grave: Milton Anthony Candler","url":"https://www.findagrave.com/memorial/","accessed":"2026-05"},{"short":"Biographical Directory of the United States Congress","accessed":"2026-05"},{"short":"Brady-Handy Photograph Collection (Library of Congress)","accessed":"2026-05"}],"research_sources":[],"documents":[],"slug":"milton-candler-1837"},"X02781":{"id":"X02781","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Elizabeth","middle_name":"Caroline","last_name":"Candler","maiden_name":"Murphey","married_names":["Candler"],"nickname":"Eliza","gender":"female","display_name":"Elizabeth Caroline 'Eliza' Murphey Candler"},"birth":{"year":1839,"month":10,"day":22,"city":"Decatur","county":"DeKalb County","state":"Georgia","country":"United States"},"baptism":{},"death":{"year":1917,"month":1,"day":4,"city":"Decatur","county":"DeKalb County","state":"Georgia","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM271","plot_notes":"Decatur Cemetery, Decatur GA — buried with husband Milton"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":true},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Charles Murphey of Decatur GA — U.S. Representative from Georgia 1851-1853 (32nd Congress, Democrat); died January 1861, months before the Civil War began","father_research_notes":"Charles Murphey was a US Representative from Georgia, 32nd Congress (1851-1853), Democrat. His January 1861 death prompted the Candler family to raise the 'Murphey Guards' Confederate cavalry company in his memory; his son-in-law Milton Candler captained the unit. Possible additional easter_egg candidate (notable grandparent-in-law of Hooker tree spouse)."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02780","date_year":1857,"location_county":"DeKalb County","location_state":"Georgia","location_country":"United States","end_type":"death","end_year":1909,"children_ids":["I00429"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Daughter of Congressman Charles Murphey of Decatur","body":"Eliza was the daughter of Charles Murphey, U.S. Representative from Georgia who died January 1861 — months before the Civil War began. To honor his memory, the Candler family raised the 'Murphey Guards' Confederate cavalry company; her husband Milton served as its captain. She bore Milton twelve children and survived him by nearly eight years, dying at seventy-seven."}],"quotes":[],"sources":[{"short":"Find a Grave Memorial 84544237","url":"https://www.findagrave.com/memorial/84544237","accessed":"2026-05"},{"short":"Wikipedia: Milton A. Candler (re: marriage and family)","url":"https://en.wikipedia.org/wiki/Milton_A._Candler","accessed":"2026-05"}],"research_sources":[],"documents":[],"slug":"elizabeth-murphey-1839"}},"burialCemetery":{"id":"CEM272","name":"Westview Cemetery","city":"Atlanta","county":"Fulton County","state":"Georgia","country":"United States","founded":1884,"wikipedia_url":"https://en.wikipedia.org/wiki/Westview_Cemetery","primary_url":"https://www.findagrave.com/cemetery/37684/westview-cemetery","hooker_connections":["HD3782","HD3784","I00429","I00431"],"notes":"Largest civilian cemetery in the southeastern United States, founded 1884. Burial place of Florence Candler Cowles (I00429, 1867-1940, daughter of Congressman Milton Candler), her daughter Florence Cowles Hardisty (HD3782, d.1920 age 27), son-in-law John T. Hardisty Sr (I00431, d.1938), and grandson John Thomas Hardisty Jr (HD3784, d.1927 age 9). Also contains Henry Grady, Joel Chandler Harris, Asa Griggs Candler (Coca-Cola founder + brother-in-law of Milton Candler)."},"institutionsById":{},"crossConnections":[]}