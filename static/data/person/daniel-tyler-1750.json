mpany and helped found Anniston, named for his daughter-in-law Annie.","number":2},{"category":"education","header":"West Point artillerist who studied in France","body":"Graduating from West Point in 1819, Tyler became an authority on artillery, studying at the French school at Metz and translating French gunnery manuals into English. His honesty inspecting private arms contractors may have stalled his promotion beyond first lieutenant.","number":3}],"number_of_marriages":1,"education":[{"institution_id":"INST035","dates":"1819","type":"graduation"}],"career":[{"role":"Iron manufacturer"},{"role":"President","organization":"Norwich and Worcester Railroad"},{"role":"President","organization":"Macon and Western Railroad"},{"role":"President","organization":"Mobile and Montgomery Railroad"}],"slug":"daniel-tyler-1799"},"I01649":{"id":"I01649","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":false,"is_easter_egg":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"spouse_id":"HD2280","children_ids":["HD6075","HD6076","HD6077","HD6078","HD6079"],"marriage_number":1,"marriage_year":1832}],"tags":[],"narrative_blocks":[],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Emily","last_name":"Lee","display_name":"Emily Lee Tyler","gender":"female","married_names":["Tyler"],"maiden_name":"Lee"},"military_service":[],"career":[],"birth":{"country":"United States","year":1815},"death":{"country":"United States","year":1864,"city":"New York","state":"New York"},"burial":{"cemetery_id":"CEM766"},"education":[],"slug":"emily-lee-1815"},"HD6075":{"id":"