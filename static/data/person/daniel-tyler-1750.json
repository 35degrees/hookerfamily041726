om_thomas_hooker":true,"descent_from_john_talcott":false,"generation_from_thomas":8},"parents":{"father_id":"HD2279","mother_id":"X01692"},"tags":["civil_war","army","general","author"],"gender":"male","birth":{"year":1831,"month":12,"day":22,"city":"Hunter","state":"New York","country":"United States"},"death":{"year":1874,"month":12,"day":1,"city":"Boston","state":"Massachusetts","country":"United States"},"burial":{"cemetery_id":"CEM025"},"notable":{"is_notable":true,"notable_category":["military"],"notable_blurb":"Union artillery general who commanded the Reserve at Gettysburg","primary_url":"https://en.wikipedia.org/wiki/Robert_O._Tyler","primary_url_label":"Wikipedia"},"bio":{"display_name":"Brig. Gen. Robert Ogden Tyler","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781034861/TylerR_hi2ft6.jpg"},"marriages":[],"education":[{"institution_id":"INST035","dates":"1853","type":"graduation","notes":"22nd of 52"}],"institutions":[{"institution_id":"INST035","relationship":"alumnus"}],"military_service":[{"war":"American Civil War","war_id":"WAR006","rank":"Brevet Major General","unit":"Artillery Reserve, Army of the Potomac","years":"1861-1866","notes":"Commanded the Artillery Reserve at Gettysburg; severely wounded at Cold Harbor; deputy quartermaster general after the war."}],"career":[{"role":"Deputy Quartermaster General","organization":"United States Army","start_year":1866,"end_year":1874}],"landmarks":[{"landmark_id":"LM139","landmark_blurb":"Commanded the Army of the Potomac's Artillery Reserve, honored by this Gettysburg monument."}],"cross_connections":[{"type":"parallel_careers","related_id":"HD2280","display_label":"was his uncle and also a Union brigadier general"}],"narrative_blocks":[{"category":"military","header":"His guns helped break Pickett's Charge","body":"At Gettysburg he commanded the Army of the Potomac's Artillery Reserve, whose massed guns helped repel the Confederate assault on the third day. Two horses were shot from under him during the fighting.","number":1},{"category":"family","header":"Nephew of the general who founded Anniston","body":"His uncle Daniel Tyler also wore a Union general's star and later founded the Alabama city of Anniston. Both men descended from the theologian Jonathan Edwards through their Connecticut family.","number":2},{"category":"military","header":"Shot at Cold Harbor, he never rode again","body":"A bullet shattered his ankle at Cold Harbor in 1864, ending his field command. He was brevetted major general for gallantry and served out the war at a desk.","number":3},{"category":"literature","header":"He finished his memoir, then died at forty-two","body":"His war injuries wore at his health, and he died young. He had just completed an autobiography, published in 1878 and still in print.","number":4},{"category":"military","header":"He soldiered the frontier before the war","body":"Before the Civil War he campaigned in the Yakima War in the Pacific Northwest and the Utah War, crossing the young frontier as an artillery officer. Gettysburg lay years ahead.","number":5}],"slug":"brig-gen-robert-ogden-tyler-hd6129"},"HD6130":{"id":"HD6130","has_descendants_documented":true,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":true,"is_easter_egg":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"generation_from_thomas":8},"gender":"female","parents":{"father_id":"HD2279","mother_id":"X01692"},"birth":{"year":1820,"month":6,"day":29,"city":"Brooklyn","state":"Connecticut","country":"United States"},"death":{"year":1887,"month":6,"day":24,"city":"Hartford","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM138"},"bio":{"display_name":"Sarah Sofia Tyler Cowen"},"number_of_marriages":1,"marriages":[{"spouse_id":"I01678","marriage_number":1,"date_year":1840,"children_ids":["HD6131","HD6132"],"end_type":"death_of_spouse","end_year":1844