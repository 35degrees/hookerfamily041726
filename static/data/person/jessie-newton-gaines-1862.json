:1,"category":"politics","header":"A mission-born baby became San Antonio’s mayor","body":"Samuel Galitzin Newton was born at Harmony Mission among the Osage in 1823 and rose to become a lawyer, a Confederate officer in the Civil War, and mayor of San Antonio. His remarkable name came from a Russian prince admired by the mission family."},{"number":2,"category":"legacy","header":"His lost house surfaced in a school dig","body":"In 2025, archaeology during construction at San Antonio’s Fox Tech High School campus uncovered the remnants of the Newton House, his former home, in the south parking lot. The dig also exposed the 1700s San Pedro Acequia irrigation system nearby."}],"videos":[{"video_id":"VID002"}],"slug":"samuel-galitzin-newton-1823"},"I01798":{"id":"I01798","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":null},"bio":{"display_name":"Mary Elizabeth Tompkins Newton","first_name":"Mary Elizabeth","last_name":"Newton","married_names":[],"maiden_name":"Tompkins"},"birth":{"year":1830,"date_precision":"exact","month":12,"day":12},"death":{"year":1878,"date_precision":"exact","month":1,"day":8,"city":"San Antonio","state":"Texas","country":"United States"},"parents":{"father_id":null,"mother_id":null},"marriages":[{"spouse_id":"HD6474","marriage_number":1,"date_year":1854,"children_ids":["HD6483","HD6484","HD6485","HD6486","HD6487","HD6488","HD6489"]}],"tags":[],"burial":{"cemetery_id":"CEM892"},"slug":"mary-elizabeth-tompkins-1830"},"HD6470":{"id":"HD6470","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":8},"bio":{"display_name":"Rev. Samuel Newton","first_name":"Samuel","last_name":"Newton","married_names":[],"title":"Rev.","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781541724/samnewton_zhjlhs.png","bio_blurb":"Osage and Cherokee missionary; San Antonio pioneer"},"birth":{"year":1792,"date_pre