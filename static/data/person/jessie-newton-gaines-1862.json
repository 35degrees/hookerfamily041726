city’s First Presbyterian Church."},{"number":4,"category":"character","header":"Six generations of Samuels before him","body":"Rev. Samuel Newton was the sixth Samuel Newton in unbroken succession — Samuel son of Samuel son of Samuel, back six generations to the immigrant minister Roger Newton. He carried that Connecticut lineage from a Woodbridge parsonage to the Texas frontier."}],"cross_connections":[{"type":"civic_connection","related_id":"X02122","link_text":"Ainsworth Blunt","display_label":"served the same Cherokee mission field in Indian Territory"}],"slug":"samuel-newton-1792"},"I01796":{"id":"I01796","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":null},"bio":{"display_name":"Mary Hunt McCarty Newton","first_name":"Mary Hunt","last_name":"Newton","married_names":[],"maiden_name":"McCarty"},"birth":{"year":1802,"date_precision":"exact","month":7,"day":19,"city":"Pompton","state":"New Jersey","country":"United States"},"death":{"year":1835,"date_precision":"exact","month":11,"day":21,"city":"Park Hill","state":"Oklahoma","country":"United States"},"parents":{"father_id":null,"mother_id":null},"marriages":[{"spouse_id":"HD6470","marriage_number":2,"date_year":1822,"children_ids":["HD6474","HD6475","HD6476","HD6477","HD6478","HD6479","HD6480"]}],"tags":[],"slug":"mary-hunt-mccarty-1802"}},"burialCemetery":{"id":"CEM039","name":"Oakwood Cemetery","city":"Troy","county":"Rensselaer County","state":"New York","country":"United States","lat":42.7639,"lng":-73.6669,"visitable":true,"notes":"Burial place of John Paine Cushman (X01916), Maria Jones Tallmadge Cushman (HD1033), Harriet Delafield Cushman Balch (HD2816), and Rev. John Paine Cushman Jr. (HD2817).","sources":[],"hooker_connections":["HD1033","HD2816","HD2817","X01916","X01917","HD5473","X03019","HD5474"]},"institutionsById":{},"crossConnections":[]}