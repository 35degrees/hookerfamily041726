rces":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Alice Hathaway","last_name":"Lee","display_name":"Alice Hathaway Lee Roosevelt","gender":"female","married_names":["Roosevelt"],"maiden_name":"Lee","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780959321/rooseveltalicehbio_rxttez.jpg"},"military_service":[],"career":[],"birth":{"country":"United States","year":1861,"city":"Chestnut Hill","state":"Massachusetts"},"death":{"country":"United States","year":1884,"city":"New York","state":"New York"},"burial":{"cemetery_id":"CEM582"},"education":[],"slug":"alice-hathaway-lee-1861"},"X00744":{"id":"X00744","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"tags":["author","nobel_prize","president"],"sources":[],"birth":{"year":1858},"death":{"year":1919},"gender":"male","parents":{"father_id":"X03151","mother_id":"X03152"},"notable":{"is_notable":true,"notable_category":["politics","military"],"notable_blurb":"26th US President; Rough Rider; Nobel Peace laureate","primary_url":"https://en.wikipedia.org/wiki/Theodore_Roosevelt","primary_url_label":"Wikipedia"},"marriages":[{"spouse_id":"X03147","children_ids":["X03145"],"marriage_number":1,"marriage_year":1880},{"spouse_id":"HD6083","children_ids":["HD6086","HD6087","HD6088","HD6089","HD6090"],"marriage_number":2,"marriage_year":1886}],"cross_connections":[{"type":"parallel_careers","related_id":"HD2335","display_label":"his Harvard ornithology partner on an 1877 bird list","link_text":"Henry Davis Minot"},{"type":"civic_connection","related_id":"HD1170","display_label":"Trust-busted Morgan's Northern Securities Company in 1904","link_text":"John Pierpont Morgan"},{"type":"professional","related_id":"I01429","link_text":"Thomas Hastings","display_label":"designed the townhouse his family used near the White House"},{"type":"professional","related_id":"HD5701","link_text":"Lucius Hart Beers","display_label":"drew up the guardianship papers for his children"},{"type":"historical_connection","related_id":"X00721","display_label":"the Columbia president and Nobel laureate he befriended"}],"bio":{"display_name":"Theodore Roosevelt","first_name":"Theodore","last_name":"Roosevelt","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780965933/535146190_1328320185969705_5247696981767004675_n_rjvlwf.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"},{"institution_id":"INST063","relationship":"alumnus"}],"artworks":[],"quotes":[],"military_service":[{"war":"Spanish-American War","branch":"United States Army","rank":"Colonel","unit":"1st U.S. Volunteer Cavalry (Rough Riders)","notes":"Led the assault on the San Juan Heights, 1898; Medal of Honor awarded in 2001."}],"narrative_blocks":[{"category":"marriage","header":"He married the childhood friend next door","body":"Roosevelt married Edith Kermit Carow in London in 1886, his second wife and a granddaughter of the Union general Daniel Tyler. Through her he entered the Tyler family, with its Edwards and Hooker roots in colonial Connecticut.","number":1},{"number":2,"category":"character","header":"Harvard ornithology friendship became his first publication","body":"He met Henry Davis Minot, a Boston-based naturalist, as a Harvard freshman in 1877. They spent vacations listing birds in the Adirondacks and co-authored 'The Summer Birds of the Adirondacks' that fall — his first published work."},{"number":3,"category":"politics","header":"Trust-busted J.P. Morgan's Northern Securities Company","body":"His administration brought the antitrust suit that dissolved Morgan's Northern Securities holding company in 1904, ending the merger of the Northern Pacific and Great Northern railroads. Morgan reportedly told him 'Send your man to my man and they can fix it up' — the President refused, and the Supreme Court sided with the government."},{"category":"character","header":"He befriended Columbia's president Nicholas Butler","body":"Roosevelt's circle included Nicholas Murray Butler, the long-serving Columbia president and 1931 Nobel peace laureate, whom he nicknamed Nicholas Miraculous. The two Republican allies stayed close from Roosevelt's rise through the White House years.","number":4},{"category":"family","header":"The Roosevelts borrowed a famous architect's townhouse","body":"When the White House was torn up for renovation in 1902, the family decamped to a townhouse belonging to the firm of Carrère and Hastings. Its partner Thomas Hastings would go on to design the New York Public Library and Arlington's Tomb of the Unknowns.","number":5}],"number_of_marriages":2,"education":[{"institution_id":"INST002","dates":"1880","type":"graduation","notes":"A.B."},{"institution_id":"INST063","notes":"law; left for politics"}],"career":[{"role":"Member","organization":"New York State Assembly","start_year":1882,"end_year":1884},{"role":"Commissioner","organization":"U.S. Civil Service Commission","start_year":1889,"end_year":1895},{"role":"President","organization":"New York City Police Board","start_year":1895,"end_year":1897},{"role":"Assistant Secretary of the Navy","organization":"United States Navy","start_year":1897,"end_year":1898},{"role":"Governor","organization":"New York","start_year":1899,"end_year":1900},{"role":"President","organization":"United States","start_year":1901,"end_year":1909}],"slug":"theodore-roosevelt-1858"},"X03145":{"id":"X03145","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":false,"is_easter_egg":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false},"notable":{"is_notable":true,"notable_category":["literature"],"notable_blurb":"Theodore Roosevelt's daughter; Washington wit","primary_url":"https://en.wikipedia.org/wiki/Alice_Roosevelt_Longworth","primary_url_label":"Wikipedia"},"parents":{"father_id":"X00744","mother_id":"X03147"},"number_of_marriages":1,"marriages":[{"spouse_id":"X03146","children_ids":[],"marriage_number":1,"marriage_year":1906}],"tags":["author","extraordinary_longevity"],"narrative_blocks":[{"category":"legacy","header":"Washington's sharpest tongue for seventy years","body":"Longworth reigned over Washington society for decades from her Massachusetts Avenue salon, feared for her wit and her feuds with both Roosevelt cousins. A pillow on her sofa read, 'If you can't say something good, sit here by me.'","number":1},{"category":"character","header":"If you can't say anything nice, sit here","body":"She kept a sofa cushion embroidered with that line and lived by it, skewering presidents for six decades. She dismissed Thomas Dewey as the little man on the wedding cake and would not call her cousin anything but Franklin.","number":2},{"category":"character","header":"Pet snake, cigarettes, the White House roof","body":"The president's irreverent eldest daughter smoked on the White House roof when forbidden to below and carried a pet snake to receptions. Her father said he could run the country or control Alice, but not both.","number":3},{"category":"character","header":"Princess Alice toured Asia for her father","body":"At twenty-one she joined the 1905 Taft mission to Japan, China, and the Philippines as the president's envoy-celebrity, mobbed everywhere as Princess Alice. Her favorite blue-gray set off a national craze called Alice blue, even a hit song.","number":4},{"category":"marriage","header":"The 1906 White House wedding of the year","body":"In February 1906 she married Ohio congressman Nicholas Longworth in the East Room before all of official Washington, the most watched wedding of its day. The match cooled after he backed Taft over her father, and she outlived him by nearly fifty years.","number":5}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"family_orbit","related_id":"HD6083","display_label":"was her stepmother in the White House"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Alice Lee","last_name":"Roosevelt","display_name":"Alice Lee Roosevelt Longworth","gender":"female","married_names":["Longworth"],"maiden_name":"Roosevelt","bio_blurb":"Theodore Roosevelt's daughter; Washington wit","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780959697/1656_125735608076_f64rpf.jpg"},"military_service":[],"career":[{"role":"Author"},{"role":"Columnist","organization":"\"Capital Comment\""}],"birth":{"country":"United States","year":1884,"city":"New York","state":"New York"},"death":{"country":"United States","year":1980,"city":"Washington","state":"District of Columbia"},"burial":{"cemetery_id":"CEM770"},"education":[],"slug":"alice-lee-roosevelt-1884"}},"burialCemetery":{"id":"CEM769","name":"Mount Auburn Cemetery","city":"Cambridge","state":"Massachusetts","country":"United States","county":"Middlesex","gps":{"latitude":42.37318,"longitude":-71.14531},"hooker_connections":["X03148","X03149"]},"institutionsById":{},"crossConnections":[]}