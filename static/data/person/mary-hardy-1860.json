tery_id":"CEM004"},"narrative_blocks":[{"header":"Sat at the door all day","body":"As a young girl, Mary Ann Cowles was left in charge of her family's Farmington home while her parents were out. A slave catcher from the South came looking for a fugitive hidden inside. She sat at the front door all day and refused to let anyone enter — the slave catcher had to leave empty-handed.","number":1}],"cross_connections":[],"bio":{"display_name":"Mary Ann Cowles Hardy","first_name":"Mary Ann","last_name":"Hardy","maiden_name":"Cowles","married_names":["Hardy"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-ann-hardy-1826"},"H00697":{"id":"H00697","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1782,"month":10,"day":18},"parents":{"father_id":"X00270","mother_id":"H00309"},"tags":["yale_connection","yale_graduate","underground_railroad","politician","abolitionist"],"sources":[{"short":"Edward Hooker 1909","entry":"697"},{"short":"Cowles Family Genealogy"},{"bib_id":"BIB003"}],"death":{"year":1841,"month":2,"day":6,"city":"Farmington","state":"Connecticut"},"gender":"male","number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"X01969","children_ids":["HD2869","HD2870","HD2871","HD2872","HD2873","HD2874","HD2875","HD2876","HD2877","HD2878"],"end_type":"death_of_spouse","end_year":1837,"date_year":1803,"date_month":10,"date_day":23},{"marriage_number":2,"spouse_id":"X01970","children_ids":[],"date_year":1838,"date_month":11,"date_day":8}],"notable":{"is_notable":false,"notable_category":[]},"burial":{"cemetery_id":"CEM004"},"narrative_blocks":[{"header":"Enrolled Yale at 15","body":"In 1797, scarcely fifteen years old, Horace Cowles was admitted to the freshman class at Yale College. A growing disability forced him to leave in his senior year before examinations; invited by the faculty to attend with his class, he declined and was never enrolled as a graduate. He became a merchant with his brother, then justice of the peace, selectman, town clerk, state legislator, choir instructor, and member of the Missionary, Temperance, Anti-Masonic, and Anti-Slavery Societies.","number":1},{"header":"One of three Mende girls from the Amistad","body":"After the Amistad captives were freed, the Mende from that ship spent eight months in Farmington while arrangements were made for their return to Sierra Leone. Horace Cowles took in one of the three young Mende girls — believed to be Teme, also called Tamie — who attended school with the other Mende each morning and learned domestic skills with the Cowles children. Horace fell ill toward the end of the Mende's stay and died in 1841; his son Samuel Smith inherited the house and continued the Underground Railroad work.","number":2}],"open_questions":[{"question":"Is Rev. Noah Porter Sr. (1781-1866), who preached Horace Cowles's funeral sermon, a relation to the Hooker tree?","status":"open","notes":"Noah Porter Sr. was minister of the First Church of Christ in Farmington 1806-1866 (60 years). He preached Horace Cowles's funeral sermon, published as a 26-page pamphlet. His son Noah Porter Jr. (1811-1892) became president of Yale. The Porter family is prominent in Farmington history — worth checking whether there is a Hooker or Cowles family connection. (Cowles Genealogy #642)"}],"cross_connections":[{"type":"civic_peer","related_id":"X01977","display_label":"Rev. Noah Porter preached his funeral sermon — 26-page pamphlet, Farmington 1841","link_text":"Rev. Noah Porter Jr."},{"type":"amistad_connection","related_id":"X02013","display_label":"Willcox held the Mende captives in federal custody during their trial; Cowles housed one of the Mende girls in his Farmington home after the Supreme Court freed them in 1841.","link_text":"Norris Willcox"},{"type":"civic_connection","related_id":"H00698","display_label":"Both Cowles cousins sheltered Mende girls in 1841","link_text":"Major Timothy Cowles","description":"When the freed Amistad Mende were brought to Farmington in 1841, Horace Cowles and his cousin Major Timothy Cowles each took in one of the three surviving Mende girls. Horace sheltered Teme; Timothy is believed to have sheltered Kagne."},{"type":"civic_connection","related_id":"X01985","display_label":"Fellow Farmington abolitionist and Underground Railroad partner.","link_text":"Austin Franklin Williams"},{"type":"civic_connection","related_id":"H01837","display_label":"Hooker-descendant Farmington abolitionists, Amistad-era neighbors.","link_text":"Jennette Cowles Williams"},{"type":"civic_connection","related_id":"H01626","display_label":"Fellow Hooker-descendant Connecticut abolitionist of the same generation.","link_text":"John Hooker"}],"landmarks":[{"landmark_id":"LM031","landmark_blurb":"Underground Railroad station; Amistad Mende girl stayed here."},{"landmark_id":"LM032","landmark_blurb":"Underground Railroad station; Amistad Mende girl stayed here."}],"education":[{"school_name":"Yale College","institution_id":"INST022","type":"university","notable":false,"institution_blurb":"Admitted 1797 age 15; left in senior year due to disability; never formally graduated despite faculty invitation."}],"bio":{"display_name":"Horace Cowles","first_name":"Horace","last_name":"Cowles","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"artworks":[],"quotes":[],"military_service":[],"slug":"horace-cowles-1782"},"X01969":{"id":"X01969","is_placeholder":false,"gender":"female","has_descendants_documented":false,"classification":{"inc