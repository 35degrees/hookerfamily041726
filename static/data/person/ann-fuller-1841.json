nstitutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"henry-fuller-1840"},"X02653":{"id":"X02653","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Anson","last_name":"Fowler","married_names":[],"gender":"male","display_name":"Anson Fowler"},"birth":{"year":1809,"month":2,"day":15,"city":"Fairfield","county":"Herkimer","state":"New York","country":"United States"},"baptism":{},"death":{"year":1855,"month":3,"day":15,"city":"Wheatland Township","county":"Hillsdale","state":"Michigan","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM207","plot_notes":"Churches Corners Cemetery, Wheatland Township Hillsdale County MI."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Abel Fowler","mother_name":"Mary Eddy Fowler","father_research_notes":"Abel Fowler of Churchville NY. Per EH 1909 entry 2242 and the published Fowler genealogy 'Descendants of Abel Fowler.'","mother_research_notes":"Mary Eddy Fowler. Per EH 1909 entry 2242."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H02242","date_year":1831,"date_month":2,"date_day":12,"location_city":"Ogden","location_county":"Monroe","location_state":"New York","location_country":"United States","end_type":"death","end_year":1855,"children_ids":["H03720","H03721","H03722","H03723","H03724"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["new_york_migration","michigan_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"character","header":"Origin of the name Anson remains uncertain","body":"Anson was born in Fairfield Herkimer County NY in 1809 to Abel and Mary Eddy Fowler — but the Fowler line shows no documented earlier Anson. Genealogists have suggested the name may trace to Mary's possible Eddy or Ross matrilineal kin: a William Anson Eddy and an Anson Ross were both born around 1809, and three Ross sisters had married three Eddy brothers in that family network. Whether the name came from those collateral relatives or from a popular contemporary figure named Anson is unresolved."},{"number":2,"category":"family","header":"Frontier child became Michigan land-patent pioneer","body":"Anson was about seven when his parents moved the family west from Herkimer County NY to Genesee County NY around 1816. After marrying Harriet Louisa Gridley in Ogden NY in 1831, the couple bought land in Wheatland Township Hillsdale County Michigan from a federal land office in 1835 — second-wave New England migration into the Old Northwest. Three of their five surviving children were born in Wheatland on that patent."}],"quotes":[],"sources":[{"label":"Melissa Craven Fowler — Fowler family genealogist","url":"https://www.melissacravenfowler.com/"}],"research_sources":[],"documents":[],"slug":"anson-fowler-1809"},"H02242":{"id":"H02242","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Harriet","middle_name":"Louisa","last_name":"Fowler","maiden_name":"Gridley","married_names":["Fowler"],"gender":"female","display_name":"Harriet Louisa Gridley Fowler"},"birth":{"year":1810,"month":5,"day":12,"city":"Pompey","state":"New York","country":"United States"},"baptism":{},"death":{"year":1898,"month":11,"day":7,"city":"Wheatland Township","county":"Hillsdale","state":"Michigan","country":"United States"},"residence":{"city":"Wheatland Township","county":"Hillsdale","state":"Michigan","country":"United States"},"burial":{"cemetery_id":"CEM207","plot_notes":"Churches Corners Cemetery, Wheatland Township Hillsdale County MI. Per Abel Fowler genealogy."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H01093","mother_id":"X02649"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02653","date_year":1831,"date_month":2,"date_day":12,"location_city":"Ogden","location_county":"Monroe","location_state":"New York","location_country":"United States","end_type":"death_of_spouse","end_year":1855,"children_ids":["H03720","H03721","H03722","H03723","H03724"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["michigan_migration","new_york_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Pioneer Hooker line into Michigan","body":"Harriet Louisa Gridley and Anson Fowler married at Ogden NY in 1831 and later migrated to Wheatland Township in Hillsdale County Michigan — among the first Hooker-descended families to settle west of New York. Four of their five children were born in Michigan; Anson is buried at Churches Corners Cemetery there."},{"number":2,"category":"character","header":"Charter member of frontier Free-Will Baptist Church","body":"Harriet was an early member of the First Free-Will Baptist Church of Wheatland Michigan, organized February 19, 1838 in Eli Eastman's home shortly after the Fowlers arrived. The church gathered at Church's Corners just a few miles from her farm; local accounts noted that before the congregation organized, 'there was more rifle-shooting done on Sunday than any other day.'"},{"number":3,"category":"family","header":"Widowed at forty-five, managed her own land deals","body":"When Anson died in 1855 Harriet was forty-five, with five surviving children. Hillsdale County records show her buying and selling acreage within a few miles of the original 1835 patent for the next two decades — alone or jointly with relatives. She remained financially comfortable through the 1870 and 1880 censuses, outlived Anson by forty-three years, and died in Wheatland Township in 1898."}],"quotes":[],"sources":[{"label":"Descendants of Abel Fowler (Wix-hosted PDF)","url":"https://docs.wixstatic.com/ugd/c44016_98436f8b114248ff82fee17977f0097b.pdf"},{"label":"Melissa Craven Fowler — Fowler family genealogist","url":"https://www.melissacravenfowler.com/"}],"research_sources":[],"documents":[],"slug":"harriet-fowler-1810"},"H01093":{"id":"H01093","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Thomas","middle_name":"Hooker","last_name":"Gridley","married_names":[],"gender":"male","display_name":"Thomas Hooker Gridley"},"birth":{"year":1775,"month":1,"day":31,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1857,"month":8,"day":4,"city":"North Chili","county":"Monroe","state":"New York","country":"United States"},"residence":{"city":"North Chili","county":"Monroe","state":"New York","country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"X02647","mother_id":"H00409"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02649","date_year":1800,"date_month":2,"date_day":23,"location_country":"United States","end_type":"death_of_spouse","end_year":1826,"children_ids":["H02239","H02240","H02241","H02242","H02243","H02244"]}],"education":[],"career":[{"role":"Farmer","location":"Kensington CT, Durham NY, Pompey NY, North Chili NY","notes":"Farmed across multiple Connecticut and New York locations through his lifetime."}],"military_service":[{"war":"War of 1812","war_id":"WAR009","rank":"Soldier","notes":"Soldier of the War of 1812, stationed at Oswego NY — Lake Ontario port and frontline against British attack 1814."}],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Hooker","inspired_by_id":"H00001","description":"Middle name honors his great-great-great-grandfather Rev. Thomas Hooker, founder of Hartford CT."}],"artworks":[],"tags":["named_for_hooker","war_of_1812","new_york_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Named for his ancestor Reverend Thomas Hooker","body":"Thomas Hooker Gridley was given the full name of his great-great-great-grandfather Rev. Thomas Hooker, founder of Hartford. The naming honored a preacher five generations removed who had died in 1647 — a 1775 echo of the Puritan founding."},{"number":2,"category":"military","header":"War of 1812 soldier at Oswego frontier","body":"Thomas Hooker Gridley served as a soldier at Oswego NY during the War of 1812. The Lake Ontario port was captured by the British in May 1814 and the fort burned. His specific role and fate during the engagement are not documented in EH 1909."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"thomas-gridley-1775"},"X02649":{"id":"X02649","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Lucilla","last_name":"Gridley","maiden_name":"Kirtland","married_names":["Gridley"],"gender":"femal