ate_month":4,"date_day":9,"location_country":"United States","children_ids":["HD4607","HD4608","HD4609"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Mary Austin","description":"Named 'Mary Austin' after her father Rev. Andrew Yates's first wife Mary Austin (d.1806) — honoring his first family in the second."}],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[{"type":"in_law","related_id":"X02831","display_label":"was her father-in-law"}],"narrative_blocks":[{"number":1,"category":"family","header":"Both Reade sisters married into the Hooker family","body":"Mary Austin Yates married John Reade Stuyvesant in 1840 — whose father Nicholas William Stuyvesant had married Catherine Livingston Reade, the sister of Helen Sarah Reade who had married Mary's uncle James Hooker of Poughkeepsie (H00797). The Reade sisters thus each connected to the Hooker world: one by marrying James Hooker directly, the other through her son who married back into the Hooker line a generation later."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave memorial records","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"mary-yates-1811"},"X02831":{"id":"X02831","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Nicholas","middle_name":"William","last_name":"Stuyvesant","married_names":[],"gender":"male","display_name":"Nicholas William Stuyvesant","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778905719/Nicholas_William_Stuyvesant__1769_1833__1905_290_vqb4m7.jpg"},"birth":{"year":1769,"city":"New York","state":"New York","country":"United States"},"baptism":{},"death":{"year":1833,"month":3,"day":11,"city":"New York","state":"New York","country":"United States"},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":true},"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Built Greenwich Village's oldest surviving house","primary_url":"https://en.wikipedia.org/wiki/Nicholas_William_Stuyvesant","primary_url_label":"Wikipedia"},"parents":{"father_id":"X02830"},"number_of_marriages":1,"marriages":[{"children_ids":["I00904","X03076"],"marriage_number":1}],"education":[],"career":[{"role":"Landowner","organization":"New York City","notes":"Inherited \"the Bowery House\" from uncle. Educated in Scotland."},{"role":"Real Estate Developer","organization":"44 Stuyvesant Street, Greenwich Village","start_year":1795,"notes":"Built Federal-style house in 1795, now the oldest house in Greenwich Village."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["merchant"],"research_tags":[],"cross_connections":[{"type":"kinship_by_marriage","display_label":"their wives, Catherine and Helen Reade, were sisters","related_id":"H00797","link_text":"Judge James Hooker"},{"type":"in_law","related_id":"H02005","display_label":"married his son John in 1840"}],"narrative_blocks":[{"number":1,"category":"family","header":"He built the Village’s oldest house","body":"The merchant built what survives today as Greenwich Village’s oldest house. His wife’s sister married James Hooker of Poughkeepsie, and his son John Reade Stuyvesant married Mary Austin Yates, a sixth-generation Hooker descendant — the family’s double tie to this tree."},{"number":2,"category":"family","header":"His nephew became Secretary of State","body":"His sister Elizabeth married Adjutant General Nicholas Fish, and their son Hamilton Fish rose to New York’s governorship, the U.S. Senate, and the State Department under Grant."}],"quotes":[],"sources":[{"label":"Wikipedia","url":"https://en.wikipedia.org/wiki/Nicholas_William_Stuyvesant"}],"research_sources":[],"documents":[],"slug":"nicholas-stuyvesant-1769"},"I00899":{"id":"I00899","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"title":"Reverend","first_name":"Andrew","last_name":"Yates","married_names":[],"gender":"male","display_name":"Andrew Yates","bio_blurb":"Union College founding professor and clergyman"},"birth":{"year":1773,"month":1,"day":17,"state":"New York","country":"United States"},"baptism":{},"death":{"year":1844,"month":10,"day":14,"city":"Schenectady","county":"Schenectady County","state":"New York","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM430","plot_notes":"Vale Cemetery Schenectady NY per FA"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":2,"spouse_id":"H00794","date_year":1810,"date_month":6,"date_day":11,"location_country":"United States","children_ids":["H02005","H02006","H02007","H02008","H02009","H02010","H02011","H02012","H02013"]}],"education":[{"institution_id":"INST022","school_name":"Yale College","dates":"1794","type":"bachelor","notes":"Per Yale bio reference: \"the Rev. Dr. Andrew Yates (Yale 1794).\""}],"career":[{"role":"Pastor","organization":"East Hartford, Connecticut"},{"role":"Professor","organization":"Union College, Schenectady, New York","notes":"One of the first professors at Union College per Schenectady biographical records. \"Well versed in ancient and modern languages including Holland Dutch.\""},{"role":"Principal","organization":"Polytechnic Institute, Chittenango, New York"}],"military_service":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["academic","educator"],"research_tags":[],"cross_connections":[{"type":"civic_connection","related_id":"HD2376","display_label":"Both connected to John Owen Dominis's Hawaiian royal orbit","link_text":"Samuel Gelston Dwight"},{"type":"family_orbit","related_id":"X02833","display_label":"Born in his Schenectady home on March 10, 1832","link_text":"John Owen Dominis"}],"narrative_blocks":[{"number":1,"category":"family","header":"The Dominis family lived in his Schenectady home","body":"The Schenectady Gazette (August 27, 1932) records that John Owen Dominis was 'born March 10, 1832 at 26 Front Street in the home of Reverend Dr. Andrew Yates' — the Dominis family boarded with Yates while the sea-captain father traded abroad, and the Dominis daughters who died at boarding school were buried in Christopher Yates's family plot at Vale Cemetery, where Yates and Hannah Allin Hooker are also interred. That boarder's son went on to marry Queen Liliʻuokalani, the last sovereign monarch of the Kingdom of Hawaiʻi, making a Schenectady parsonage the birthplace of the kingdom's final male consort."},{"number":2,"category":"military","header":"Grandson served Farragut's staff at Mobile Bay","body":"Andrew Yates's grandson, Captain Arthur Reed Yates (Naval Academy 1857) — son of his eldest son Reverend John Austin Yates — served on Admiral David Farragut's personal staff at the Battle of Mobile Bay on August 5, 1864, receiving Farragut's written commendation for gallantry and dying in November 1892 on the very eve of promotion to Commodore. At that same battle, Captain James Hooker Strong — whose mother Dolly Goodwin Hooker was the own sister of Yates's wife Hannah Allin Hooker — commanded USS Monongahela and rammed the Confederate ironclad CSS Tennessee, making two men bound through this Schenectady household heroes of the same decisive naval engagement."},{"number":3,"category":"education","header":"One of Union College's founding professors in Schenectady","body":"Reverend Andrew Yates was among the first professors at Union College in Schenectady — an institution chartered in 1795 whose founders included his cousin Joseph C. Yates, later Governor of New York (1823-1825). His command of ancient and modern languages, including Holland Dutch, made him one of the most learned academics in upstate New York of his generation, and he later served as principal of the Polytechnic Institute in Chittenango, New York."},{"number":4,"category":"marriage","header":"His first wife was kin to Texas's founder","body":"Andrew Yates's first wife Mary Austin (b.1776; d.1806) was described in a Schenectady biographical record as 'of English stock and a relative of the founder of Austin, Texas' — a reference to Stephen F. Austin (1793-1836), the American empresario whose colonization of Mexican Texas made 'Austin' a legendary name in the story of westward expansion. The precise kinship is not documented, but the community clearly recognized the connection, and Yates honored his first wife's memory by naming their daughter Mary Austin — a name that eventually passed to his granddaughter Mary Austin Yates Stuyvesant, buried at Saint Mark's-in-the-Bowery in New York City."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave memorial records","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"andrew-yates-1773"},"H00794":{"id":"H00794","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":true,"is_easter_egg":false,"generation_from_john_talcott":5},"birth":{"year":1785},"parents":{"father_id":"H00348","mother_id":"X00319"},"tags":[],"sources":[{"short":"Edward Hooker 1909","entry":"794"},{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00899","date_year":1810,"date_month":6,"date_day":11,"location_country":"United States","children_ids":["H02005","H02006","H02007","H02008","H02009","H02010","H02011","H02012","H02013"]}],"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1859,"month":10,"day":20,"city":"Schenectady","county":"Schenectady County","state":"New York","country":"United States"},"cross_connections":[{"type":"family_orbit","related_id":"X02833","display_label":"His sisters' graves share her husband's burial plot at Vale","link_text":"John Owen Dominis"}],"bio":{"display_name":"Hannah Allin Hooker","first_name":"Hannah","middle_name":"Allin","maiden_name":"Hooker","married_names":[],"gender":"female","bio_blurb":"Hooker descendant; wife of Rev. Andrew Yates"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM430","plot_notes":"Vale Cemetery Schenectady NY per FA"},"narrative_blocks":[{"number":1,"category":"family","header":"Husband's ward became consort of Hawaii's last queen","body":"The Dominis family — Captain John Dominis, wife Mary Jones, and their young son John Owen — boarded at 26 Front Street, the Yates home in Schenectady; John Owen was born there on March 10, 1832, and the Dominis daughters who died young were buried in the Yates family plot at Vale Cemetery alongside Hannah and her husband. That same boy went on to marry Queen Liliʻuokalani, the last sovereign monarch of the Kingdom of Hawaiʻi, becoming the kingdom's last and only male consort."}],"slug":"hannah-hooker-1785"}},"burialCemetery":{"id":"CEM432","name":"Poughkeepsie Rural Cemetery","location":{"city":"Poughkeepsie","county":"Dutchess County","state":"New York","country":"United States"},"url":"https://www.findagrave.com/cemetery/65711/poughkeepsie-rural-cemetery","hooker_connections":["HD4607","I00905","HD4609","HD4612","HD4613","HD4617"]},"institutionsById":{},"crossConnections":[]}