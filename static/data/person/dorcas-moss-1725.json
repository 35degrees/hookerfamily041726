_blurb":"Yale 1736; Pastor of First Congregational Church, Ridgefield…","primary_url":"https://en.wikipedia.org/wiki/Jonathan_Ingersoll","primary_url_label":"Wikipedia"},"narrative_blocks":[{"number":1,"category":"legacy","header":"Yale 1736; Pastor of First Congregational Church, Ridgefield…","body":"Yale 1736; Pastor of First Congregational Church, Ridgefield, CT for 40 years","migrated_from":"historical_significance"},{"number":2,"category":"legacy","header":"Chaplain with Connecticut troops at Fort Ticonderoga 1758","body":"Chaplain with Connecticut troops at Fort Ticonderoga 1758 under Col. David Wooster","migrated_from":"historical_significance"},{"number":3,"category":"legacy","header":"Preached before the Connecticut General Assembly on Election…","body":"Preached before the Connecticut General Assembly on Election Day 1761","migrated_from":"historical_significance"},{"number":4,"category":"legacy","header":"In 1777, freed his enslaved man Cyphax (age","body":"In 1777, freed his enslaved man Cyphax (age 20) with selectmen approval — one of few documented manumissions in Ridgefield","migrated_from":"historical_significance"}],"education":[{"degree":"graduate","school_name":"Yale College","graduation_year":1736,"institution_id":"INST022"}],"military_service":[{"war":"French and Indian War","active_in_war":true,"rank":"Chaplain","unit":"4th Regiment (Col. David Wooster), then 3rd Regiment","dates":"1758-1759","battles":["Battle of Carillon / Fort Ticonderoga 1758","Amherst's campaign 1759 — Fort Carillon to Oswego to St. Lawrence"],"notes":"Chaplain in Abercromby's ill-fated attack on Fort Carillon 1758. Wrote to a colleague that God showed \"distinguishing mercy to the Connecticut Troops\" who suffered few deaths in that dreadful slaughter. Following year served under Amherst from Fort Carillon to Oswego and down the St. Lawrence.","war_id":"WAR003"}],"bio":{"title":"Reverend","display_name":"Rev. Jonathan Ingersoll","first_name":"Jonathan","last_name":"Ingersoll","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1736"}],"landmarks":[],"artworks":[],"quotes":[],"slug":"jonathan-ingersoll-1713"},"HD0121":{"id":"HD0121","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1747,"month":4,"day":16,"city":"Ridgefield","state":"Connecticut","country":"United States"},"death":{"year":1823,"month":1,"day":12,"state":"Connecticut","country":"United States","age":75},"parents":{"father_id":"HD0115","mother_id":"I00079"},"political_offices":[{"title":"Member, Connecticut Council of Assistants","dates":"1792-1797"},{"title":"Judge, Connecticut Supreme Court of Errors","dates":"1792-1798"},{"title":"Superior Court Judge, Connecticut","dates":"1798-1801, 1811-1816"},{"title":"Lieutenant Governor, Connecticut","dates":"1816-1823","notes":"9th Lieutenant Governor; elected annually until death"}],"tags":["judge","lawyer","politician","yale_connection"],"sources":[],"gender":"male","notable":{"is_notable":true,"notable_category":["politics","law"],"notable_blurb":"Connecticut Lieutenant Governor 1816-1823, Superior Court Judge","primary_url":"https://en.wikipedia.org/wiki/Jonathan_Ingersoll","primary_url_label":"Wikipedia"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01299","date_year":1786,"date_month":4,"date_day":1,"location_city":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1823,"children_ids":["HD5107","HD5108","HD5109","HD5110","HD5111","HD5112","HD5113","HD5114","HD5115","HD5116"]}],"cross_connections":[{"type":"place_overlap","related_id":"H01407","display_label":"Both buried Grove Street Cemetery, New Haven — Hooker descendants","link_text":"Dr. Worthington Hooker"}],"education":[{"degree":"graduate","school_name":"Yale College","graduation_year":1766,"institution_id":"INST022"}],"bio":{"display_name":"Jonathan Ingersoll Jr.","first_name":"Jonathan","last_name":"Ingersoll","suffix":"Jr.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1766"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"politics","header":"Lieutenant Governor of Connecticut, 1816-1823","body":"Jonathan Ingersoll Jr. served as Lieutenant Governor of Connecticut from 1816 until his death in 1823 — the role making him a principal political figure of the early-Republic era in the state. The Lt Governor's office in Connecticut was a significant constitutional post during the years following the 1818 Constitution. His son Ralph I. Ingersoll later described him as 'a gentleman of great moral worth, and among the foremost in his profession.'"},{"number":2,"category":"law","header":"State Attorney, Superior Court Judge, then Lt Governor","body":"Jonathan rose through three principal Connecticut public-service offices in succession — first State Attorney, then a Judge of the Superior Court, then Lieutenant Governor. The progression took him from prosecutorial to judicial to political leadership across the late-eighteenth and early-nineteenth centuries. His judicial reputation rested on the same qualities of moral worth and professional standing that distinguished his political tenure."},{"number":3,"category":"family","header":"Father of US Minister to Russia Ralph Ingersoll","body":"Jonathan's son Ralph I. Ingersoll (born February 8, 1789) followed him into the law and the public service — eight years in the United States Congress (1825-1833), State Attorney for twelve years, Connecticut Minister Plenipotentiary to the Russian court 1846-1848 under President Polk. The Ingersoll legal dynasty was one of the longest-running Connecticut family practices of the nineteenth century. A grandson Charles Roberts Ingersoll became Governor of Connecticut 1873-1877."}],"burial":{"plot_notes":"Grove Street Cemetery, New Haven CT"},"slug":"jonathan-ingersoll-jr-1747"},"I01299":{"id":"I01299","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker_bool":false},"parents":{},"tags":[],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"HD0121","date_year":1786,"date_month":4,"date_day":1,"location_city":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1823,"children_ids":["HD5107","HD5108","HD5109","HD5110","HD5111","HD5112","HD5113","HD5114","HD5115","HD5116"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1772,"country":"United States"},"death":{"year":1850,"age":78,"country":"United States"},"residence":{},"burial":{},"baptism":{},"cross_connections":[],"narrative_blocks":[],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Grace Ingersoll","first_name":"Grace","last_name":"Ingersoll","maiden_name":"Isaacs","married_names":["Ingersoll"],"gender":"female"},"slug":"grace-isaacs-1772"},"HD5107":{"id":"HD5107","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_