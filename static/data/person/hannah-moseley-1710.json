ry or March 1789 Mary and Zachariah moved their family from Hebron Connecticut to Berlin Vermont — traveling up the Connecticut River with two teams of oxen, then up the White River, switching from wheels to runners at Brookfield, then over a blazed trail. They arrived to find their log cabin's roof had collapsed under three to four feet of snow."},{"number":2,"category":"family","header":"Lost firstborn daughter Mary in 1798","body":"Mary's eldest child — also named Mary, born in Hebron — died in 1798. Four months later another daughter was born and named Mary in her sister's memory. The second Mary later married Julius Yemans Dewey and was the mother of Admiral George Dewey, hero of Manila Bay 1898."}],"slug":"mary-perrin-1758"},"T01388":{"id":"T01388","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":5,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1759,"month":5,"day":16,"city":"Glastonbury","state":"Connecticut","country":"United States","county":"Hartford"},"death":{"year":1848,"month":6,"day":6,"city":"East Hartford","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"T01001","mother_id":"U00042"},"marriages":[{"marriage_number":1,"spouse_id":"X01833","date_year":1780,"date_month":9,"date_day":28,"location_city":"East Hartford","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1844,"children_ids":["TD0187","TD0188","TD0189","TD0190","TD0191","TD0192","TD0193"]}],"sources":[{"short":"Talcott 1876","page":"Entry 1388"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Hannah Talcott Hills","first_name":"Hannah","last_name":"Hills","maiden_name":"Talcott",