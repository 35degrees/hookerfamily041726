Seth (H01789) → John Butler (H03203) → Florence → Helen → Lea Hooker → compiler.","path_to_compiler":"T01389 Samuel × HD0064 Abigail Pantry Hooker → H01789 Seth → H03203 John B. → Florence → Helen → Lea → compiler"},"sources":[{"short":"Talcott 1876","page":"Entry 1389"}],"primary_residence":{"city":"West Hartford","state":"Connecticut","notes":"Resided in Eastbury (Glastonbury) until 1788, then West Hartford for the rest of his life."},"cross_connections":[],"gender":"male","tags":["hooker_talcott_convergence"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"burial":{"cemetery_id":"CEM113","plot_notes":"Old Center Cemetery, West Hartford CT. FindAGrave confirms. Buried with wife H00687 Abigail Pantry Hooker."},"residence":{"city":"West Hartford","state":"Connecticut","country":"United States"},"baptism":{},"is_placeholder":false,"narrative_blocks":[{"number":1,"category":"marriage","header":"Married the Hooker-Talcott convergence in 1795","body":"On January 25, 1795 he married Abigail Pantry Hooker in West Hartford. He was a fifth-generation Talcott; she was a fifth-generation descendant of Rev. Thomas Hooker."},{"number":2,"category":"family","header":"Moved from Glastonbury to West Hartford in 1788","body":"He left the Talcott homeland in Eastbury for West Hartford seven years before his marriage. He stayed there for the rest of his life."}],"artworks":[],"documents":[],"quotes":[],"statues":[],"research_tags":[],"naming_inspiration":[],"landmarks":[],"institutions":[],"bio":{"display_name":"Samuel Talcott","first_name":"Samuel","last_name":"Talcott","married_names":[]},"research_sources":[],"military_service":[],"slug":"samuel-talcott-1765"},"T01390":{"id":"T01390","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":5,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"bi