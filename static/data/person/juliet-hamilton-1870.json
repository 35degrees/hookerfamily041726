urces":[],"birth":{"year":1896,"month":6,"day":12,"city":"Ramapo","county":"Rockland County","state":"New York","country":"United States"},"death":{"year":1985,"month":1,"day":25,"city":"Mystic","state":"Connecticut","country":"United States","age":88,"cause":"cardiac arrest"},"marriages":[{"marriage_number":1,"spouse_id":"X00385","date_year":1916,"date_month":6,"date_day":10,"children_ids":["HD1234","HD1235","HD1236","HD1237"]}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["military_officer","historic_preservation","public_service"],"notable_blurb":"WAC deputy director WWII; National Trust founding trustee","primary_url":"https://en.wikipedia.org/wiki/Helen_Morgan_Hamilton","primary_url_label":"Helen Morgan Hamilton — Wikipedia"},"cross_connections":[],"bio":{"display_name":"Helen Morgan Hamilton Burgess","first_name":"Helen","last_name":"Burgess","maiden_name":"Hamilton","middle_name":"Morgan","married_names":["Burgess"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"World War II","war_id":"WAR008","side":"United States","rank":"Lieutenant Colonel","rank_start":"Officer","rank_end":"Lieutenant Colonel","rank_year_start":1942,"rank_year_end":1947,"unit":"Women's Army Corps — Deputy Director 1945-1947","notes":"Entered United States Army during WWII after first husband's 1942 death. Active in formation of Women's Auxiliary Army Corps (later WAC). Served as Deputy Director WAC 1945-1947. Achieved rank of Lieutenant Colonel. Awarded Legion of Merit and Army Commendation Medal."}],"narrative_blocks":[{"number":1,"category":"military","header":"Deputy Director Women's Army Corps, World War II","body":"After her first husband's 1942 death, Helen entered the United States Army and served as Deputy Director of the Women's Army Corps from 1945 to 1947 — one of the highest positions held by any woman in the U.S. Army during the immediate postwar period. She achieved the rank of Lieutenant Colonel and was awarded the Legion of Merit and the Army Commendation Medal for her service. Her three sons had already entered military service when she joined them."},{"number":2,"category":"career","header":"Founding trustee, National Trust for Historic Preservation","body":"Helen was a founding trustee of the National Trust for Historic Preservation in 1953 — the Congressionally-chartered nonprofit established that year to preserve America's historic places — and served in that role for twenty-five years until 1978. She also served as president of the Foundation for the Preservation of Historic Georgetown, where she lived for many years, and as Fellow of the Pierpont Morgan Library in New York."},{"number":3,"category":"career","header":"Director of public liaison, Marshall Plan administration","body":"In 1949 Helen became Director of Public Liaison for the Economic Cooperation Administration — the U.S. government agency that administered the Marshall Plan to rebuild postwar Europe. The role placed her at the center of one of the most consequential American foreign-policy programs of the twentieth century. In 1957 she was appointed consultant to U.S. Secretary of War Robert P. Patterson on the proposed universal military training program."},{"number":4,"category":"family","header":"J.P. Morgan granddaughter, Alexander Hamilton great-great-granddaughter","body":"Helen's maternal grandfather was financier J.P. Morgan; her maternal grandmother was Fanny Tracy Morgan. She was also a great-great-granddaughter of Alexander Hamilton, the first U.S. Secretary of the Treasury. The Hamilton-Morgan-Hooker confluence in her ancestry placed her in three of the most prominent American family lines of the eighteenth, nineteenth, and twentieth centuries."},{"number":5,"category":"family","header":"Born Ramapo NY 1896, died Mystic CT 1985","body":"Helen Morgan Hamilton was born June 12, 1896 in Ramapo, Rockland County New York — the eldest of five children of William Pierson Hamilton and Juliet Pierpont Morgan. She died of cardiac arrest on January 25, 1985 in Mystic Connecticut at age eighty-eight. Her four children with Col. Arthur Hale Woods included Distinguished Flying Cross naval aviator John Pierpont Woods (1918-2012) and OSS officer Alexander Hamilton Woods (1922-2008)."}],"slug":"helen-burgess-1896"},"X00385":{"id":"X00385","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1870},"death":{"year":1942},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1229","children_ids":["HD1234","HD1235","HD1236","HD1237"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Arthur Hale Woods","first_name":"Arthur","last_name":"Woods","middle_name":"Hale","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"arthur-woods-1870"},"HD1234":{"id":"HD1234","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":11,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00385","mother_id":"HD1229"},"tags":["flying_cross","harvard_graduate","navy","politician","pro_athlete","wwii"],"sources":[],"birth":{"year":1918,"month":2,"day":6,"city":"New York City","state":"New York","country":"United States"},"death":{"year":2012,"month":5,"day":23,"city":"Harpswell","county":"Cumberland County","state":"Maine","country":"United States","age":94},"marriages":[{"children_ids":["HD1244","HD1245","HD1246","HD1247"],"spouse_id":"X01879","marriage_number":1,"date_year":1947}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"John Pierpont Woods","first_name":"John","last_name":"Woods","middle_name":"Pierpont","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"World War II","war_id":"WAR008","side":"United States","rank":"Naval Aviator","unit":"United States Naval Air Force","notes":"Awarded Distinguished Flying Cross for heroism and extraordinary achievement in aerial flight during World War II."}],"narrative_blocks":[{"number":1,"category":"character","header":"Bought blue school bus, drove to Costa Rica","body":"In retirement John Pierpont Woods bought a blue school bus, loaded his possessions and his dog into it, and drove to Costa Rica — where he lived for seven years before returning north to settle in Harpswell Maine. The deliberate post-career adventure stood in sharp contrast to the conventional retirement of his American Airlines pilot and Connecticut General Assembly representative careers. He spoke fluent Spanish, French, German, and Chinese."},{"number":2,"category":"military","header":"Distinguished Flying Cross, Naval Air Force WWII","body":"John served in the United States Naval Air Force during World War II and was awarded the Distinguished Flying Cross for 'heroism and extraordinary achievement in aerial flight.' He then became an American Airlines pilot for a long civilian aviation career, followed by Director of Operations and Air Traffic Control at the National Business Aircraft Association until his 1980 retirement. The military-to-civilian-aviation arc was characteristic of his mid-century Naval Air Force generation."},{"number":3,"category":"character","header":"Set world swim records into his nineties","body":"John ran marathons and was a master swimmer who set world records in his age category into his nineties. The lifelong-athleticism extended his physical practice five decades beyond most men's competitive careers. He died at age ninety-four in Harpswell Maine, still active in the master-swimming community into his final years."},{"number":4,"category":"family","header":"NYC 1918 to Harpswell Maine 2012 age ninety-four","body":"John Pierpont Woods was born February 6, 1918 in New York City and died May 23, 2012 in Harpswell, Cumberland County Maine at age ninety-four. He was a Brooks School 5th-graduating-class alumnus and Harvard University graduate. His mother was Helen Morgan Hamilton Burgess, the WAC Lt. Colonel Deputy Director during World War II."}],"slug":"john-woods-1918"},"HD1235":{"id":"HD1235","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":11,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00385","mother_id":"HD1229"},"tags":[],"sources":[],"birth":{"year":1919},"death":{"year":2003},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Leonard Hamilton Woods","first_name":"Leonard","last_name":"Woods","middle_name":"Hamilton","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"leonard-woods-1919"},"HD1236":{"id":"HD1236","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":11,"descent_from_thomas_hooker":true,"descent_from_john