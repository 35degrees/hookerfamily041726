sdale","state":"Michigan","country":"United States"},"burial":{"cemetery_id":"CEM207","plot_notes":"Churches Corners Cemetery, Wheatland Township Hillsdale County MI. Per Abel Fowler genealogy."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H01093","mother_id":"X02649"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02653","date_year":1831,"date_month":2,"date_day":12,"location_city":"Ogden","location_county":"Monroe","location_state":"New York","location_country":"United States","end_type":"death_of_spouse","end_year":1855,"children_ids":["H03720","H03721","H03722","H03723","H03724"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["michigan_migration","new_york_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Pioneer Hooker line into Michigan","body":"Harriet Louisa Gridley and Anson Fowler married at Ogden NY in 1831 and later migrated to Wheatland Township in Hillsdale County Michigan — among the first Hooker-descended families to settle west of New York. Four of their five children were born in Michigan; Anson is buried at Churches Corners Cemetery there."},{"number":2,"category":"character","header":"Charter member of frontier Free-Will Baptist Church","body":"Harriet was an early member of the First Free-Will Baptist Church of Wheatland Michigan, organized February 19, 1838 in Eli Eastman's home shortly after the Fowlers arrived. The church gathered at Church's Corners just a few miles from her farm; local accounts noted that before the congregation organized, 'there was more rifle-shooting done on Sunday than any other day.'"},{"number":3,"category":"family","header":"Widowed at forty-five, managed her own land deals","body":"When Anson died in 1855 Harriet was forty-five, with five surviving children. Hillsdale County records show her buying and selling acreage within a few miles of the original 1835 patent for the next two decades — alone or jointly with relatives. She remained financially comfortable through the 1870 and 1880 censuses, outlived Anson by forty-three years, and died in Wheatland Township in 1898."}],"quotes":[],"sources":[{"label":"Descendants of Abel Fowler (Wix-hosted PDF)","url":"https://docs.wixstatic.com/ugd/c44016_98436f8b114248ff82fee17977f0097b.pdf"},{"label":"Melissa Craven Fowler — Fowler family genealogist","url":"https://www.melissacravenfowler.com/"}],"research_sources":[],"documents":[],"slug":"harriet-fowler-1810"},"H02243":{"id":"H02243","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"John","middle_name":"Kirtland","last_name":"Gridley","married_names":[],"gender":"male","display_name":"John Kirtland Gridley"},"birth":{"year":1813,"month":4,"day":20,"city":"Pompey","state":"New York","country":"United States"},"baptism":{},"death":{},"residence":{"city":"Lockport","county":"Niagara","state":"New York","country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H01093","mother_id":"X02649"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02654","date_year":1840,"date_month":8,"date_day":3,"location_country":"Unite