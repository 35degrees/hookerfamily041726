andmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-poyntz-1891"},"HD1607":{"id":"HD1607","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1865,"month":5,"day":10,"city":"Brooklyn","state":"New York"},"death":{"year":1928,"month":12,"day":26,"city":"Biltmore Forest","state":"North Carolina"},"parents":{"father_id":"X00513","mother_id":"HD1598"},"marriages":[{"spouse_id":"X00990","children_ids":["HD2757","HD2760","HD2830","HD2761"],"marriage_number":1,"date_year":1890}],"tags":[],"sources":[],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["medicine"],"notable_blurb":"Pioneered TB treatment in Asheville; trained in Vienna","primary_url":"https://images.findagrave.com/photos/2020/190/192055092_caf7fbfc-fbaf-464e-bd67-94dd71d47990.jpeg","primary_url_label":"FindAGrave"},"burial":{"cemetery_id":"CEM043"},"narrative_blocks":[{"header":"Pioneered tuberculosis treatment in Asheville","detail":"Moving to Asheville to convalesce, Minor began specializing in tuberculosis treatment in 1897 — the specialty that made him famous. Asheville had become a leading center for TB treatment due to its climate, and Minor's European training and precision made him one of its most respected physicians. He died at Biltmore Forest, Buncombe County NC in 1928. His son Dr. John Minor (HD2760) also became a physician and WW1 veteran, buried at Arlington. (FindAGrave; FamilySearch)","body":"Charles Lancelot Minor earned his M.D. from the University of Virginia in 1888, interned at St. Luke's Hospital New York, then spent two years studying in Vienna under Weichselbaum, Kolisko, and Friedrich Kraus, with additional study in Berlin, Munich, Paris, London, and obstetrics at the Rotunda Hospital in Dublin. Returning in 1892, he practiced surgery in Washington until developing tuberculosis in 1895.","number":1,"category":"character"},{"number":2,"category":"career","header":"Vienna trained him; Asheville claimed him","body":"Brooklyn-born and Vienna-trained, the eighth-generation Hooker descendant built his tuberculosis practice on Asheville’s mountain air and died at Biltmore Forest — but was carried home to Brooklyn’s Green-Wood. The Confederate “Col. Lancelot Minor” of the war articles is a different family entirely."}],"cross_connections":[],"bio":{"display_name":"Doctor Charles Lancelot Minor","title":"Doctor","first_name":"Charles","last_name":"Minor","middle_name":"Lancelot","married_names":[],"photo_url":"https://images.findagrave.com/photos/2020/190/192055092_caf7fbfc-fbaf-464e-bd67-94dd71d47990.jpeg","bio_blurb":"Asheville tuberculosis pioneer"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Physician","location":"Asheville, North Carolina"}],"education":[{"school_name":"Medical training, Vienna","type":"professional"}],"slug":"charles-minor-1865"},"X00990":{"id":"X00990","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1861,"month":8,"day":27,"county":"Prince Edward County","state":"Virginia","country":"United States"},"death":{"year":1942,"month":2,"day":10,"city":"Charlottesville","state":"Virginia","country":"United States"},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1607","children_ids":["HD2757","HD2760","HD2830","HD2761"]}],"parents":{"father_research_notes":"Charles Venable"},"notable":{"is_notable":false,"notable_category"