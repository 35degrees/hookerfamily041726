acy","header":"Direct ancestor of the compiler Samuel Talcott Hooker","body":"Direct ancestor of the compiler Samuel Talcott Hooker through the maternal Talcott line","migrated_from":"historical_significance"}],"education":[{"school_name":"Harvard College","graduation_year":1658,"institution_id":"INST002"}],"military_service":[{"war":"King Philip's War","active_in_war":true,"rank":"Lieutenant","dates":"1675-1676","notes":"Rose through Trained Band ranks during this period","war_id":"WAR002"}],"bio":{"display_name":"Captain Samuel Talcott","title":"Captain","first_name":"Samuel","last_name":"Talcott","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"slug":"samuel-talcott-1635"},"U00025":{"id":"U00025","visible_default":false,"in_talcott_book":true,"classification":{"is_spouse_of_talcott_descendant":true,"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1644,"month":6,"day":9,"city":"Springfield","state":"Massachusetts"},"death":{"year":1678,"month":2,"day":2,"city":"Wethersfield","state":"Connecticut"},"parents":{"father_id":"Y00002","mother_id":"Y00003"},"marriages":[{"spouse_id":"T00036","children_ids":["T00430","T00431","T00432","T00433","T00434","T00135","T00436","T00437"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1678,"date_year":1661,"date_month":11,"date_day":7}],"sources":[{"short":"Talcott 1876","page":"Entry 36"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Hannah Holyoke Talcott","first_name":"Hannah","last_name":"Talcott","married_names":["Talcott"],"maiden_name":"Holyoke"},"residence":{},"baptis