cuments":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Mother of all ten Leete children","body":"Anna Payne, daughter of Rev. John Payne of Southoe, married William Leete in England in 1636 and crossed to Guilford with him. She bore all ten of his children and died in 1668, before he rose to the Connecticut governorship."}],"slug":"anna-payne-1621"},"X00067":{"id":"X00067","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"birth":{"year":1612,"city":"Keyston","county":"Huntingdonshire","country":"England"},"death":{"year":1683,"month":4,"day":16,"city":"Hartford","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM003","plot_notes":"Interred at the Ancient Burying Ground — same ground as Thomas Hooker."},"marriages":[{"children_ids":["X00065","X00108"],"spouse_id":"X01837","marriage_number":1}],"cross_connections":[{"type":"civic_peer","related_id":"I00003","display_label":"sheltered the regicides at Milford, as Leete did","link_text":"Rev. Roger Newton Sr."},{"type":"family_connection","related_id":"H00031","display_label":"His granddaughter married the first Guilford Probate Judge.","link_text":"Judge James Hooker"},{"type":"civic_peer","display_label":"governed both Massachusetts and Connecticut","related_id":"X02128","link_text":"Gov. John Haynes"}],"tags":["colonial_assistant","governor"],"sources":[],"gender":"male","number_of_marriages":1,"parents":{},"notable":{"is_notable":true,"notable_category":["government"],"notable_blurb":"Governor of New Haven and Connecticut colonies","primary_url":"https://en.wikipedia.org/wiki/William_Leete","primary_url_label":"Wikipedia"},"narrative_blocks":[{"number":1,"category":"politics","header":"The only man to govern both New Haven","body":"He served Guilford as town clerk from 1639, rose to Governor of New Haven Colony (1661-1664), and then Governor of the Colony of Connecticut (1676-1683) — the only person ever to hold both offices. He is buried at the Ancient Burying Ground in Hartford — the same ground as Thomas Hooker."},{"number":2,"category":"character","header":"He used the Sabbath and slow horses","body":"When royal agents arrived demanding the regicides Goffe and Whalley, he read the King's warrant aloud in public — alerting everyone to the agents' purpose — then furnished horses so slowly that the Sabbath intervened before they could depart. By Monday the men were hidden. Roger Newton did the same in Milford; Roger Hooker did the same in Hartford — three men in the same civic network, the same year."},{"number":3,"category":"legacy","header":"Granddaughters married into the Hooker family — two branches","body":"His son William Leete Jr. fathered Mary Leete, who married Hon. James Hooker of Guilford. His son Andrew Leete fathered Mercy Leete, who married Samuel Hooker of Kensington. Two of his granddaughters independently married into the Hooker family in the same generation."},{"number":4,"category":"civic","header":"One of Guilford's founding settlers","body":"Leete left England in 1639 to escape the persecution of Puritans he had witnessed as a court clerk. He was among the twenty-five who signed the plantation covenant at sea and helped found Guilford, becoming one of the seven pillars of its church."},{"number":5,"category":"civic","header":"He kept Guilford's records for over twenty years","body":"Leete served as town clerk of Guilford from 1639 until 1662, alongside terms as magistrate and deputy. The long climb through colony offices carried him eventually to the governorship."}],"bio":{"title":"Governor","display_name":"Gov. William Leete","first_name":"William","last_name":"Leete","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[