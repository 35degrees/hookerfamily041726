:"family","header":"Father of the ecologist Henry Chandler's father","body":"Linus's eighth child Henry Martyn Cowles, born to him and Eunetia in 1831, would become a Kensington farmer and deacon. His grandson — born 1869 in the same house — was Henry Chandler Cowles, the founding figure of American plant ecology."}],"burial":{"cemetery_id":"CEM022","plot_notes":"Ledge Cemetery, Berlin, Connecticut, per FindAGrave."},"slug":"linus-cowles-1787"},"HD0512":{"id":"HD0512","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1812,"city":"Kensington","state":"Connecticut"},"parents":{"father_id":"HD0510","mother_research_notes":"Ruth Cowles","mother_id":"X01218"},"tags":[],"sources":[],"gender":"male","marriages":[{"spouse_id":"X01586","children_ids":[],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"death":{},"cross_connections":[],"bio":{"display_name":"George Cowles","first_name":"George","last_name":"Cowles","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"george-cowles-1812"},"X01586":{"id":"X01586","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0512","children_ids":[]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Betsey Ann Norton","first_