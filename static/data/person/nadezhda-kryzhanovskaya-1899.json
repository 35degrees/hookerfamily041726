","last_name":"Blake","married_names":[],"gender":"male","display_name":"Robert Pierpont Blake","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778626245/robertblake-resized_uzv44q.png"},"birth":{"year":1886,"month":11,"day":1,"city":"San Francisco","county":"San Francisco County","state":"California","country":"United States"},"baptism":{},"death":{"year":1950,"month":5,"day":9,"city":"Cambridge","county":"Middlesex County","state":"Massachusetts","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM311"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["academic","scholar"],"notable_blurb":"American Byzantinist; scholar of Armenian and Georgian cultures","primary_url":"https://www.findagrave.com/memorial/126755114/robert_pierpont-blake","primary_url_label":"FindAGrave: Robert Pierpont Blake"},"parents":{"father_id":"HD1567","father_name":"Charles Thompson Blake","mother_id":"X01504","mother_name":"Harriet Waters Stiles Blake"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00594","date_year":1920,"date_month":1,"date_day":7,"location_city":"Tiflis","location_state":"Georgia","location_country":"Democratic Republic of Georgia","end_type":"death","end_year":1950,"children_ids":[]}],"education":[{"institution":"Harvard University","degree":"John Harvard Traveling Fellow","field":"Byzantine Studies","start_year":1911,"end_year":1918,"notes":"Fellowship years primarily spent in Russia studying Russian, Arabic, Syriac, Armenian, and Georgian languages."}],"career":[{"role":"Professor","organization":"Tbilisi State University, Georgia","start_year":1918,"end_year":1920,"notes":"Helped found Tbilisi State University in 1918