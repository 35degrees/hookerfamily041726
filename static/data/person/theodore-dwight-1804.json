ptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"plot_notes":"Unknown grave near Natchez, Adams County, Mississippi — died in the wilderness 1777, body location never recorded"},"education":[{"school_name":"Yale College","institution_id":"INST022","degree_or_field":"B.A.","class_year":1744,"notes":"Yale 1744."}],"career":[{"role":"Merchant","location":"Northampton, MA","end_year":1776,"notes":"Merchant in Northampton MA. Substantial family business."},{"role":"Judge of common pleas court","organization":"Massachusetts colony courts","location":"Hampshire County, MA","start_year":1758,"end_year":1774,"notes":"Judge 1758-1774. Took oath of fealty to British crown on assuming office — held this oath binding through the Revolution and refused to revoke it."},{"role":"Selectman","organization":"Town of Northampton","location":"Northampton, MA","start_year":1760,"end_year":1764},{"role":"Town Recorder","organization":"Town of Northampton","location":"Northampton, MA","start_year":1760,"end_year":1775},{"role":"Representative","organization":"Massachusetts Legislature","location":"Boston, MA"}],"narrative_blocks":[{"number":1,"category":"politics","header":"Loyalist judge who would not break his oath","body":"He had sworn fealty to the British crown in 1758 on becoming judge of the court of common pleas, and held that oath binding when the Revolution came. His Northampton family suffered increasing community ostracism as the war approached; one biographer called him 'a Loyalist on Christian principle, and yet thoroughly patriotic in his feelings.'"},{"number":2,"category":"family","header":"Took two sons to a Mississippi colony, 1776","body":"Disillusioned with revolutionary Northampton, in May 1776 he sailed from Middletown CT with two of his sons — Sereno and Jonathan — toward a British land grant at Natchez Mississippi. They were accompanied by the Phelps and Lyman families and the Rev Mr Smith's household; within a year he and Mrs Lyman would both be dead at Natchez of fever."},{"number":3,"category":"death","header":"Died in the wilderness, body never recovered","body":"He died at Natchez Mississippi in June 1777 at age fifty in the wilderness, without trial or recorded grave. News of his death traveled slowly back to Northampton; his son Timothy Dwight IV left the Continental Army in 1778 to return home as the oldest surviving male and take charge of the family's affairs."},{"number":4,"category":"family","header":"Carried tiny wife on his palm, arm's length","body":"His wife Mary Edwards Dwight was as small as he was large — he sometimes carried her around the room on his open palm held out at arm's length. She bore him thirteen children, eight of them sons, all noted for fine physical forms — the smallest son Cecil was five-foot-eight-and-a-half and weighed two hundred pounds."}],"slug":"timothy-dwight-iii-1726"},"H00379":{"id":"H00379","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1734,"month":4,"day":4,"city":"Northampton","state":"Massachusetts"},"death":{"year":1807,"month":2,"day":28,"city":"Northampton","state":"Massachusetts"},"parents":{"father_id":"X00128","mother_id":"HD0418"},"tags":["slaveholder"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 379"}],"marriages":[{"spouse_id":"X00635","children_ids":["H00914","H00915","H00916","H00917","H00918","H00919","H00920","H00921","H00922","H00923","H00924","H00925","H00926"],"marriage_number":1,"date_year":1750,"date_month":11}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"civic_connection","related_id":"H00264","display_label":"Refused his Northampton congregation, took communion twelve miles away instead.","link_text":"Rev. John Hooker"}],"bio":{"display_name":"Mary Edwards Dwight","first_name":"Mary","last_name":"Dwight","married_names":["Dwight"],"maiden_name":"Edwards","photo_url":"https://images.findagrave.com/photos/2017/95/22275967_1491537990.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married at sixteen as Edwards left for Stockbridge","body":"Her November 1750 wedding to Major Timothy Dwight came two months before Jonathan Edwards moved his family to the Stockbridge mission. The marriage was permitted because the family was about to be separated."},{"number":2,"category":"family","header":"Mother of Yale's eighth president Timothy Dwight","body":"Her son Timothy Dwight IV led Yale College from 1795 to 1817. He shaped a generation of New England intellectual life from his grandfather Edwards's old territory."},{"number":3,"category":"religion","header":"Refused her pew when Hooker succeeded her father","body":"When the distant Thomas Hooker descendant Rev. John Hooker became Northampton's pastor after Edwards's dismissal, she placed her own chair in the vestibule below the belfry. On communion Sabbaths she rode twelve miles on a pillion behind her son to take communion at another church."},{"number":4,"category":"family","header":"Heard a year later her husband had died","body":"Major Timothy Dwight III died at Natchez, Mississippi in 1777 during a southern trip. The news did not reach her at Northampton until a full year after his death."},{"number":5,"category":"character","header":"Husband could carry her on his open palm","body":"She was unusually small in stature and was described in old age as 'opinionated and self-willed.' Patriot rabble burned her fields and stole her livestock during the Revolution because of her husband's Tory sympathies."}],"slug":"mary-dwight-1734"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}