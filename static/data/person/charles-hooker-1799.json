"children_ids":["H05315"]}],"career":[],"education":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Orphaned at thirteen, then again at seventeen","body":"Charles Hooker Baldwin lost his father Albert in 1879 at thirteen years old, then his mother Jennette Phelps Hooker in 1883 at seventeen — both parents gone before he reached twenty. He married Bertha Wilson Smith of Newark on April 30, 1889, and they had one daughter."}],"naming_inspiration":[{"name_element":"Hooker","inspired_by_id":"H01433","description":"Middle name Hooker honors his mother Jennette Phelps Hooker's maiden surname, tracing descent from Rev. Thomas Hooker of Hartford."}],"quotes":[],"documents":[],"burial":{},"residence":{"city":"Newark","county":"Essex","state":"New Jersey","country":"United States"},"sources":[],"research_sources":[],"slug":"charles-baldwin-1865"},"H00533":{"id":"H00533","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"compiler_ancestor":true,"lineage_note":"H00533 William (gen 5) → H00265 Seth (gen 4) → H00098 John No.2 (gen 3) → H00030 John (gen 2) → H00007 Samuel (gen 1) → H00001 Thomas","descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1756,"month":9,"day":15,"city":"Kensington","state":"Connecticut"},"death":{"year":1826,"month":2,"day":4,"city":"Kensington","state":"Connecticut"},"parents":{"father_id":"H00265","mother_id":"I00042"},"compiler_ancestor":true,"compiler_connection":{"notes":"William Hooker is the compiler's direct paternal ancestor through the Hooker surname line. His father Seth (H00265) died when William was 2 years old. William is the link between the confirmed paternal line and the compiler's grandfather Michael Gay Hooker. Research needed to trace descendants.","path_to_compiler":"H00533 William → [descendants to trace] → Michael Gay Hooker → Samuel Talcott Hooker (compiler)"},"open_questions":[{"question":"Full descent from William Hooker (H00533) to Michael Gay Hooker","status":"research_needed","notes":"William born 1756 Kensington CT; died 1826. His starred children H01427-H01433 are the next research step. The compiler's grandfather Michael Gay Hooker's connection runs through one of these children.","action":"Research EH entries 1427-1433; check CT vital records and census records for William's children"}],"tags":["compiler_ancestor","musician","revolutionary_war"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 533"}],"marriages":[{"spouse_id":"I00046","children_ids":["H01426","H01427","H01428","H01429","H01430","H01431","H01432","H01433","H01434"],"marriage_number":1,"date_year":1779}],"primary_residence":{"city":"Kensington (Berlin)","state":"Connecticut","notes":"Born and died Kensington CT. Also had family connection to Hinsdale NH through wife."},"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[],"notable_blurb":null,"primary_url":null,"primary_url_label":null},"cross_connections":[{"type":"cousin_marriage","related_id":"H00429","display_label":"Her daughter Amelia married my son Dr. William in 1814.","link_text":"Ann Hooker Stanley"},{"type":"cousin_marriage","related_id":"H00553","display_label":"His daughter Amelia married my son Dr. William in 1814.","link_text":"Seth Stanley"},{"type":"family_orbit","related_id":"X00049","display_label":"was the father of his wife Hannah Jones"}],"military_service":[{"war":"American Revolutionary War","war_id":"WAR001","side":"American","rank_start":"Private","rank_end":"Sergeant","rank_year_start":1777,"rank_year_end":1780,"unit":"Capt. Caleb Bull's Company in Webb's Regiment, Continental Army","service_years":"1777-1780","notes":"Enlisted Apr 21, 1777 as Private for 3 years in Capt. Caleb Bull's Company, Webb's Regiment. Promoted Sergeant May 16, 1780 for an additional 8 months. Member of the Hartford 'band of music' (eight musicians) raised 1777 and attached to the Connecticut line. Pensioned Nov 4, 1818. DAR Ancestor #A057709."}],"bio":{"display_name":"William Hooker","first_name":"William","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"military","header":"Hartford band of music attached to Connecticut line","body":"William Hooker was a member of the eight-man 'band of music' raised in Hartford in 1777 and attached to the Connecticut line of the Continental Army — one of the rare documented Revolutionary War regimental musical ensembles. The band provided drums, fifes, and field music during the war's middle years. The arrangement was unusual: most Revolutionary regiments had ad hoc field musicians rather than a formally organized eight-piece band."},{"number":2,"category":"military","header":"Three years Private, eight months Sergeant 1777-1780","body":"William enlisted April 21, 1777 as a Private in Captain Caleb Bull's Company of Webb's Regiment for a three-year term. On May 16, 1780 he was promoted to Sergeant for an additional eight months of service. He was pensioned November 4, 1818 (DAR Ancestor #A057709) — the federal pension secured nearly four decades after his service ended."},{"number":3,"category":"family","header":"Nine children with Sarah Wilcox of Berlin","body":"William married Sarah Wilcox of Berlin Connecticut and they had nine documented children together. The family remained in Kensington, the original Berlin Connecticut parish where William had been born in 1756 and where he would die in 1826. The nine-child household was characteristic of the post-Revolutionary Connecticut farming generation."},{"number":4,"category":"family","header":"Kensington Berlin CT 1756 to 1826 age sixty-nine","body":"William Hooker was born September 15, 1756 in Kensington (now Berlin) Connecticut and died February 4, 1826 in Kensington at age sixty-nine. He is buried at West Lane Cemetery in Berlin Connecticut. His Revolutionary War service spanned the war's middle period from the bleakest 1777 Valley Forge winter through the war's final 1780-1781 phase."}],"slug":"william-hooker-1756"},"I00046":{"id":"I00046","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1758,"month":12,"day":5,"city":"Hartford","state":"Connecticut"},"death":{"year":1854,"month":4,"day":12},"parents":{"father_id":"X00049","mother_id":"X00050"},"marriages":[{"spouse_id":"H00533","children_ids":["H01426","H01427","H01428","H01429","H01430","H01431","H01432","H01433","H01434"],"marriage_number":1,"date_year":1779}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 533"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Hannah Jones Hooker","first_name":"Hannah","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Jones"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"hannah-jones-1758"},"H00265":{"id":"H00265","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"compiler_ancestor":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1731,"month":12,"day":8,"city":"Kensington","state":"Connecticut"},"death":{"year":1758,"month":12,"day":10,"city":