 rivals","body":"Across his career Bromley assembled a collection of over seven thousand photographic negatives. He bought five hundred from B.F. Upton in 1878 when Upton relocated to Florida, sixteen hundred from W.H. Illingworth's St. Paul gallery, and the inventories of thirty other photographers. The collection — primarily glass plates — survives at Hennepin County Library."}],"quotes":[],"sources":[{"label":"Edward A. Bromley Photographs collection — Hennepin County Library Special Collections (M/A 0323)","url":"https://archives.hclib.org/repositories/sc/resources/edward_a_bromley_photographs"}],"research_sources":[],"documents":[],"slug":"edward-bromley-1849"},"X02468":{"id":"X02468","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Georgena","last_name":"Bromley","married_names":["Bromley"],"gender":"female","display_name":"Georgena Bromley"},"birth":{"year":1848,"country":"United States"},"baptism":{},"death":{"year":1930,"country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3475","location_country":"United States","end_type":"death_of_spouse","end_year":1925,"children_ids":["HD3478"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":["needs_research"],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"georgena-bromley-1848"},"HD3478":{"id":"HD3478","former_ids":[],"is_placeholder":false,"has_descendants_documented":fal