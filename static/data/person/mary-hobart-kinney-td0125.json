,"artworks":[],"quotes":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","unit":"8th Company, 12th Regiment Connecticut Militia","notes":"Documented Revolutionary War service."}],"burial":{"cemetery_id":"CEM176","plot_notes":"Berlin Corner Cemetery, Berlin Corners VT."},"narrative_blocks":[{"number":1,"category":"character","header":"Settled Berlin Vermont with collapsed-roof cabin","body":"Zachariah served in the Revolutionary War with the 8th company of the 12th Connecticut militia, then in February-March 1789 led his family from Hebron Connecticut to Berlin Vermont — up the Connecticut River with two teams of oxen, switching from wheels to runners in Brookfield. They found the log cabin he had built the previous summer crushed under three or four feet of snow."},{"number":2,"category":"legacy","header":"Founded a 1300-acre farm still in family","body":"Zachariah's 1300 acres in the East Road School District of Berlin VT — at what became the southeast corner of East Road and Scott Hill Road — passed down through generations of Perrins. His son Porter, the first boy born in Berlin, built the house at Scott Hill and Airport Road in 1815 (still standing). A descendant Henry Perrin still lived in 'Perrin territory' along Scott Hill Road into the modern era."}],"slug":"zachariah-perrin-1748"},"T01387":{"id":"T01387","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":6,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1758,"month":6,"day":17,"city":"Glastonbury","state":"Connecticut"},"death":{"year":1828,"month":9,"day":11,"city":"Berlin Corners","county":"Washington","state":"Vermont"},"parents":{"father_id":"T01001","mother_id":"U00042"},"marriages":[{"children_ids":["T01391","TD0120","T01393","T01394","T01395","T01396","TD0170","TD0138","T01399"],"spouse_id":"