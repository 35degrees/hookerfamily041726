s_talcott_spouse":true,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{},"marriages":[{"marriage_number":1,"spouse_id":"TD0120","date_year":1804,"date_month":8,"date_day":30,"location_city":"Berlin","location_state":"Vermont","location_country":"United States","end_type":"death_of_self","end_year":1862,"children_ids":["TD0121","TD0122","TD0123","TD0124","TD0125","TD0126","TD0127","TD0128","TD0129","TD0130","TD0131","TD0132"]}],"number_of_marriages":1,"tags":["minister","clergy","extraordinary_longevity"],"research_tags":[],"sources":[{"label":"Vermont Genealogy — Biography of Rev. James Hobart","url":"https://vermontgenealogy.com/washington/biography-of-rev-james-hobart.htm"},{"label":"FindAGrave — Rev James Hobart","url":"https://www.findagrave.com/memorial/641556/james-hobart"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"religion","header":"Berlin Vermont's first settled minister thirty-one years","body":"Ordained November 7, 1798 as Berlin Congregational's first settled minister, James drafted the church's confession of faith, covenant, and articles of discipline himself. His 31-year pastorate ran to May 1829, when a mutual council dismissed him. He then spent twelve years preaching in New Hampshire and twenty more itinerating around Worcester, Berlin, and West Berlin Vermont."},{"number":2,"category":"character","header":"Walked six miles and preached at ninety-five","body":"Per his obituary, 'in the very last year of his life, his 96th, he was able to preach a pretty well connected discourse, and could walk 6 or 8 miles in a day.' Below ordinary height with erect carriage, great memory, and a strong distinct voice, James was described as 'self-denying, laborious and persevering, having quite a missionary spirit.'"},{"number":3,"category":"family","header":"Three daughters married Congregational ministers","body":"Three of James and Betsey's daughters married Congregational ministers across New England: Pamelia married Rev. Rufus Child (Gilmanton NH then Berlin), Julia married Rev. Pliny Fisk Barnard (Richmond ME then Williamstown VT then Westminster VT), and Hannah married Rev. George Craven (Methodist, Danville VT). The Berlin pulpit's reach extended through the next generation."},{"number":4,"category":"religion","header":"Walked six miles a day preaching at ninety-six","body":"In the ninety-sixth year of his life Rev. Hobart preached well-connected discourses and was able to walk six or eight miles in a day. Below average height, he stood erect and was blessed with a retentive memory, strong voice, and good delivery."}],"cross_connections":[],"naming_inspiration":[],"education":[{"institution_id":"INST058","school_name":"Dartmouth College","dates":"1794","type":"undergraduate","notes":"A.B. 1794."},{"school_name":"Studies with Rev. Asa Burton","dates":"1794-1795","type":"theological","notes":"Apprentice studies with Asa Burton of Thetford VT before preaching license 1795."}],"career":[{"role":"Minister (candidate)","organization":"Chelsea VT","start_year":1795,"end_year":1796},{"role":"Minister (candidate)","organization":"Plymouth NH and Nottingham NH","start_year":1796,"end_year":1798,"notes":"Settlement call from Nottingham."},{"role":"First settled minister","organization":"Berlin Congregational Church (Berlin VT)","start_year":1798,"end_year":1829,"notes":"Ordained November 7, 1798. Drew up church confession of faith, covenant, and articles of discipline. 31-year pastorate dismissed by mutual council May 1829."},{"role":"Itinerant preacher","organization":"New Hampshire and Vermont congregations","start_year":1829,"end_year":1862,"notes":"Plymouth, Wentworth, Enfield, Alexandria, Bridgewater NH and near Portsmouth (12 years); then Worcester, Berlin, West Berlin VT (last 20 years)."}],"military_service":[],"institutions":[{"institution_id":"INST058","relationship":"alumnus"}],"landmarks":[],"artworks":[],"documents":[],"quotes