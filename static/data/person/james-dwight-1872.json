er":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"James Dwight III","first_name":"James","last_name":"Dwight","suffix":"III","married_names":[],"gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779194739/jamesdwightiii_nysgiy.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM009","plot_notes":"Grove Street Cemetery, New Haven CT — with father Pope of Yale and daughter Aurelia"},"narrative_blocks":[{"number":1,"category":"family","header":"Twin brother John died at nineteen, 1803","body":"Born 1 September 1784 at Greenfield Hill CT, he was the twin of John Dwight who died at age 19 in 1803 — leaving him the only surviving male of that birth-day pair among Pope Dwight's children. The twin's death came when James was just nineteen and starting his hardware apprenticeship."},{"number":2,"category":"career","header":"Hardware merchant from New Haven to Petersburg","body":"He went into hardware business with his older brother Timothy Dwight Jr at New Haven, then carried the trade to Petersburg VA. He returned to New York and established the hardware firm James & George A. Dwight before moving south again later in life to Georgia."},{"number":3,"category":"marriage","header":"Lost his first wife at twenty-five, 1813","body":"On 13 March 1811 at New Haven he married Aurelia Darling, daughter of Joseph and Amelia Mills Darling. She bore him one daughter Elizabeth Smith Dwight in 1812 and died in 1813 at age 25 — leaving him a widower with an infant. He remarried 8 August 1815 at Norwich CT to Susan Breed."},{"number":4,"category":"retirement","header":"Retired to New Haven, 1854","body":"After decades of hardware trade between Connecticut, Virginia, New York, and Georgia, he returned to New Haven in 1854 at age 70 and retired there. He died 24 March 1863 at 78 — outliving by 60 years his twin brother John who had died at 19. Father of Tim V the 12th Yale president by Susan Breed."}],"career":[{"role":"Hardware merchant","organization":"James & George A. Dwight","location":"New Haven CT → Petersburg VA → New York → Georgia","start_year":1803,"end_year":1854,"notes":"Hardware partnership with brother Timothy Dwight Jr starting at New Haven; carried trade to Petersburg VA; established James & George A. Dwight hardware firm in NYC; later returned south to Georgia. Retired to New Haven 1854."}],"slug":"james-dwight-iii-1784"},"I01104":{"id":"I01104","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Susan","last_name":"Dwight","maiden_name":"Breed","married_names":["Dwight"],"gender":"female","display_name":"Susan Breed Dwight","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779194911/susanbreed_rexogh.png"},"birth":{"year":1785,"month":12,"day":17,"city":"Stonington","county":"New London","state":"Connecticut","country":"United States of America"},"baptism":{},"death":{"year":1851,"month":8,"day":29,"city":"New London","county":"New London","state":"Connecticut","country":"United States of America"},"residence":{"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States"},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Breed family of New Haven CT"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1969","date_year":1815,"date_month":8,"date_day":8,"location_city":"Norwich","location_county":"New London","location_state":"Connecticut","lo