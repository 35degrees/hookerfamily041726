1846,"notes":"Yale 1846."},{"school_name":"Brainard Academy","degree_or_field":"Teacher","class_year":1847,"notes":"Taught a year or two at Brainard Academy in Haddam CT after Yale."},{"school_name":"Yale College","institution_id":"INST022","degree_or_field":"Tutor","class_year":1849,"notes":"Yale Tutor 1849-1853."},{"school_name":"Andover Theological Seminary","degree_or_field":"Theology study","class_year":1854,"notes":"Began theology study at Andover Seminary 1854."},{"school_name":"Yale Divinity School","institution_id":"INST121","degree_or_field":"Theology study","class_year":1856,"notes":"Removed to Yale Divinity School 1856."},{"school_name":"Columbia Law School","degree_or_field":"LL.B.","class_year":1861,"notes":"LL.B. Columbia 1861 under cousin Professor Theodore W. Dwight (founder of Columbia Law)."}],"career":[{"role":"Lawyer (bar admitted)","location":"New York City","start_year":1861,"notes":"Admitted to NY bar 1861."},{"role":"Assistant teacher of Municipal Law","organization":"Columbia Law School","location":"New York City","start_year":1863,"end_year":1866,"notes":"Taught Municipal Law at Columbia 1863-1866 under cousin Prof. Theodore W. Dwight."}],"military_service":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"},{"institution_id":"INST121","relationship":"alumnus"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["yale_graduate","lawyer"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"education","header":"Yale tutor, Andover theology, Columbia Law","body":"After Yale 1846 he tutored at Yale 1849-1853, studied theology at Andover Seminary then Yale Divinity, before taking his LL.B. at Columbia Law in 1861 under his cousin Professor Theodore W. Dwight — founder of Columbia Law School. He practiced law in New York City and assisted Theodore at Columbia teaching Municipal Law from 1863 to 1866."},{"number":2,"category":"family","header":"Only child born and died same day, London","body":"He married Cora Charlesina Tallmadge of New York in Philadelphia on 6 June 1866 at age forty. Their only child James McLaren Dwight was born — and died — on 4 May 1872 in London during the couple's extended European travels of 1869-1876."},{"number":3,"category":"death","header":"Tripped in dressing room, died five days later","body":"On the evening of 23 June 1897 he tripped and fell in his dressing room, breaking a thigh. The shock to his seventy-one-year-old system was such that he failed rapidly and died five days later on 1 July, just shy of his seventy-second birthday."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"james-dwight-1825"},"I01105":{"id":"I01105","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Cora","middle_name":"Charlesina","last_name":"Dwight","maiden_name":"Tallmadge","married_names":["Dwight"],"gender":"female","display_name":"Cora Charlesina Tallmadge Dwight"},"birth":{"year":1833,"month":10,"day":17,"city":"New York","county":"New York","state":"New York","country":"United States"},"baptism":{},"death":{"year":1914,"month":10,"day":7,"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM009","plot_notes":"Grove Street Cemetery, New Haven CT"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Maj. Charles B. (or Benjamin) Tallmadge, US Army","mother_name":"Margaret (Kennedy) Tallmadge"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD04876","date_year":1866,"date_month":6,"date_day":6,"location_city":"Philadelphia","location_county":"Philadelphia","location_state":"Pennsylvani