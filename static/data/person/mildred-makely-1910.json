ue,"is_talcott_spouse":false,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{},"marriages":[{"marriage_number":1,"spouse_id":"HD3402","location_country":"United States","end_type":"death_of_spouse","end_year":1943,"children_ids":["HD3406"]}],"number_of_marriages":1,"tags":[],"research_tags":[],"sources":[{"label":"FindAGrave — Rose Marguerita Boothe Ward","url":"https://www.findagrave.com/memorial/150404225/rose_marguerita-ward"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"naming_inspiration":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"rose-boothe-1891"},"X01665":{"id":"X01665","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["minister","author","academic"],"sources":[{"label":"FindAGrave — Rev George Kemp Ward","url":"https://www.findagrave.com/memorial/26753459/george_kemp-ward"},{"label":"Princeton Magazine, Vol. 6 (1891), pp. 428-9 — biographical sketch","url":"https://books.google.com/books?id=vmE9AQAAMAAJ&pg=PA428"}],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1545","date_year":1873,"date_month":5,"date_day":18,"location_state":"New York","location_country":"United States","end_type":"death","end_year":1937,"children_ids":["HD3407","HD3401","HD3400","HD3402","HD3403"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1848,"month":1,"day":9,"city":"Rochester","county":"Monroe","state":"New York","country":"United States"},"death":{"year":1937,"month":7,"day":18,"city":"Bronxville","county":"Westchester","state":"New York","country":"United States"},"cross_connections":[],"bio":{"display_name":"Rev. George Kemp Ward","first_name":"George","middle_name":"Kemp","last_name":"Ward","title":"Reverend","married_names":[],"extra_names":"M.A.","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777607291/gerogekempward_vnathx.jpg","photo_notes":"Portrait. Cloudinary."},"residence":{"city":"Dansville","county":"Livingston","state":"New York","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST023","relationship":"alumnus","years":"1865-1869","institution_blurb":"Class of 1869, A.M. 1872. Class Secretary and Historian; American Whig Society; Iota Chapter of Delta Psi."},{"institution_id":"INST145","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM170","plot_notes":"LittleVille Cemetery, Avon NY. FindAGrave 26753459."},"education":[{"school_name":"Rochester Collegiate Institute","type":"preparatory","notes":"Preliminary training; later attended the University of Rochester in his Freshman year before transferring to Princeton."},{"school_name":"University of Rochester","dates":"ca.1864-1865","type":"undergraduate","notes":"Mid-Freshman year transfer to Princeton."},{"institution_id":"INST023","dates":"1865-1869","type":"undergraduate","notes":"Princeton class of 1869; member of the American Whig Society; Iota Chapter of Delta Psi (joined at Rochester); elected Secretary and Historian of his class."},{"institution_id":"INST023","dates":"1872","type":"graduate","notes":"Master of Arts (A.M.) Princeton University."},{"institution_id":"INST145","school_name":"Princeton Theological Seminary","dates":"1869-1873","type":"seminary","notes":"Prepared for the ministry of the Presbyterian Church."}],"career":[{"role":"Pastor","organization":"Dansville Presbyterian Church","location":"Dansville, New York","start_year":1873,"end_year":1898,"notes":"First and only pastoral charge — twenty-five years. Twice Moderator of the Presbytery of Rochester; editor of the Presbyterian Church Herald; member of the Livingston County Historical Society."},{"role":"Secretary","organization":"Association of Descendants of Andrew Ward","notes":"Compiler of the Andrew Ward Family Genealogy."},{"role":"Author","organization":"self-published / Princeton class historian","notes":"Published two volumes of class history: 'After Nine Years' (1878) and 'The Vigintennial Volume of 1869' (1889) — a finely illustrated twenty-year record of the Princeton class. Also published several religious pamphlets including 'The Strength of Young Manhood' and 'The Memorial of Elizabeth Dippy'."}],"narrative_blocks":[{"number":1,"category":"education","header":"Switched colleges mid-freshman year for Princeton","body":"George began his college career at the University of Rochester but, midway through his Freshman year, transferred to Princeton — bringing his Iota Chapter of Delta Psi membership with him. He graduated as Old Nassau's Class Secretary and Historian in 1869, then earned his A.M. in 1872 and finished at Princeton Theological Seminary the next year."},{"number":2,"category":"religion","header":"Twenty-five-year pastorate at Dansville Presbyterian","body":"After ordination George took the pastorate at Dansville Presbyterian Church in upstate New York and stayed for a quarter century — from 1873 until 1898. Twice elected Moderator of the Presbytery of Rochester, he edited the Presbyterian Church Herald and sat on the Livingston County Historical Society alongside his pastoral work."},{"number":3,"category":"literature","header":"Compiled the Andrew Ward Family Genealogy","body":"As Secretary of the Association of Descendants of Andrew Ward, George compiled the family genealogy that traces the Ward line back to East Haddam Connecticut. He also published two Princeton class histories — 'After Nine Years' (1878) and 'The Vigintennial Volume of 1869' (1889) — the latter a finely illustrated twenty-year reunion record."},{"number":4,"category":"family","header":"Father was former Mayor of Rochester New York","body":"George was the son of Hon. Levi A. Ward, a former Mayor of Rochester, and the grandson of Dr. Levi Ward, a pioneer of Western New York who had emigrated from East Haddam Connecticut early in the 19th century. He was also a cousin of Prof. Henry A."},{"number":5,"category":"family","header":"Cousin of the Rochester natural-science magnate","body":"George was a first cousin of Prof. Henry Augustus Ward, the naturalist who founded Ward's Natural Science Establishment in Rochester. The firm supplied geological, zoological, and anthropological specimens to universities and museums across the United States — and the cousins shared the Rochester Ward extended family's scholarly orientation, George turning to ministry and genealogy where Henry turned to natural history."},{"number":6,"category":"family","header":"Grandfather pioneered Western New York from Connecticut","body":"George's grandfather Dr. Levi Ward emigrated from East Haddam Connecticut early in the 19th century and was among the pioneer settlers of Western New York, establishing the Ward family in Rochester. The migration west from a Connecticut town that itself had been a 17th-century Puritan settlement carried the family's New England Calvinist culture into the Genesee Valley."}],"slug":"george-ward-1848"},"HD1545":{"id":"HD1545","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1852,"month":9,"day":8,"city":"Rochester","county":"Monroe","state":"New York","country":"United States"},"death":{"year":1939,"month":3,"day":15,"city":"Bronxville","county":"Westchester","state":"New York","country":"United States"},"parents":{"father_id":"HD1092","mother_id":"X00499"},"marriages":[{"spouse_id":"X01665","children_ids":["HD3407","HD3401","HD3400","HD3402","HD3403"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1937,"date_year":1873,"date_month":5,"date_day":18,"location_state":"New York","location_country":"United States"}],"tags":[],"sources":[{"label":"FindAGrave — Caroline Editha Pierpont Ward","url":"https://www.findagrave.com/memorial/26753448/caroline_editha-ward"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"naming_pattern","related_id":"HD3412","display_label":"Granddaughter Carolyn Pierpont Ward carries her name forward two ways","link_text":"Carolyn Pierpont Ward"}],"bio":{"display_name":"Caroline Editha Pierpont","first_name":"Caroline","middle_name":"Editha","maiden_name":"Pierpont","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM170","plot_notes":"LittleVille Cemetery, Avon NY. FindAGrave 26753448."},"narrative_blocks":[{"number":1,"category":"marriage","header":"Daughter's marriage produced a Hooker cousin convergence","body":"Caroline married Rev. George Kemp Ward in 1873 and bore four children — Levi, Ruth, Charles, and Kenneth — all Hooker descendants through her Pierpont line. When her daughter Ruth married Horace Willard Hooker in 1906, the union produced the project's third documented Hooker-Hooker cousin marriage, with both spouses tracing descent to Rev. Thomas Hooker through different branches."}],"slug":"caroline-pierpont-1852"}},"burialCemetery":{"id":"CEM171","name":"Lakeview Cemetery","city":"Groveland","county":"Livingston","state":"New York","country":"United States","primary_url":"https://www.findagrave.com/cemetery/65053/lakeview-cemetery","hooker_connections":["HD3402","HD3406","I00341"],"notes":"Groveland NY cemetery. Burial site of Charles Sloan Ward (HD3402), his second wife Rose Marguerita Boothe (I00341), and their daughter Mildred May Ward (HD3406). Distinct from CEM154 Lakeview Cemetery in Brockport NY."},"institutionsById":{},"crossConnections":[]}