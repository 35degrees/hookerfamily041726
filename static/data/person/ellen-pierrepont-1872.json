s_notable":true,"notable_category":[],"notable_blurb":"Diplomat","primary_url":"https://en.wikipedia.org/wiki/Jay_Pierrepont_Moffat"},"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Jay Pierrepont Moffat","first_name":"Jay","last_name":"Moffat","middle_name":"Pierrepont","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/a/a2/Jay_Pierrepont_Moffat.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"US Ambassador to Canada through early WWII","body":"Nominated by President Roosevelt, he served as U.S. Ambassador to Canada from 1940 until his death in 1943 — through the first year of U.S. participation in World War II. He had previously been Chief of the Western European Division of the State Department 1937-1940."},{"number":2,"category":"lineage","header":"Lineal descendant of Chief Justice John Jay","body":"He was a lineal descendant of Chief Justice John Jay — Treaty of Paris negotiator and first Chief Justice of the United States. The Jay ancestry was unusual for a career diplomat: the great Federalist diplomat-jurist's lineal heir served as ambassador 150 years later."},{"number":3,"category":"family","header":"Father-in-law was Pearl Harbor ambassador","body":"His wife Lilla Cabot Grew's father Joseph C. Grew was U.S. Ambassador to Japan at the time of the Pearl Harbor attack — and 'tried hard to avert the Pacific stage of WWII' per the NYT obituary. Two senior ambassador positions thus passed through one 1927 marriage."},{"number":4,"category":"death","header":"Died Ottawa surgery complications at forty-seven","body":"He died at Ottawa on 25 January 1943 from surgery complications for phlebitis — two and a half weeks after his 47th birthday. His service was held at Christ Church Cathedral Ottawa, attended by Canadian Prime Minister Mackenzie King."}],"slug":"jay-moffat-1896"},"X00524":{"id":"X00524","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1907},"death":{"year":1994},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1639","children_ids":["HD1647"],"marriage_number":1,"date_year":1927,"location_city":"Hancock","location_state":"New Hampshire"}],"gender":"female","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Lilla Cabot Grew","first_name":"Lilla","middle_name":"Cabot","maiden_name":"Grew","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"lilla-grew-1907"},"HD1647":{"id":"HD1647","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":11,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1929},"death":{"year":2010},"parents":{"father_id":"HD1639","mother_id":"X00524"},"marriages":[],"tags":[],"sources":[],"gender":"female","notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Edith Alice Pierrepont Spenser","first_name":"Edith","last_name":"Spenser","married_names":["Moffat","Spenser"],"maiden_name":"Pierrepont","middle_name":"Alice"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"edith-spenser-1929"},"HD1640":{"id":"HD16