":"Various Vermont firms","end_year":1860,"notes":"Prepared for college but chose mercantile life until 1860."},{"role":"Assistant Secretary","organization":"Vermont Mutual Fire Insurance Co.","start_year":1860,"end_year":1864,"notes":"Four-year tenure before Civil War service."},{"role":"Assistant Secretary, then Vice-President","organization":"National Life Insurance Company","start_year":1865,"end_year":1897,"notes":"Returned from Civil War and joined NLI under his father's presidency. Elected vice-president June 1877; held position to January 1897."}],"military_service":[{"war":"American Civil War","rank":"Captain","rank_start":"Lieutenant","rank_end":"Captain","rank_year_start":1864,"rank_year_end":1865,"unit":"8th Regiment, Vermont Volunteer Infantry (Quartermaster)","notes":"Joined 8th VT Volunteers as Quartermaster in Louisiana January 1864; accompanied regiment to Virginia July 1864; participated in battles of Opequon and Cedar Creek. Promoted Captain and Assistant Quartermaster, U.S. volunteers staff department February 11, 1865; resigned three months later. Quartermaster papers preserved at Vermont Historical Society."}],"institutions":[{"institution_id":"INST112","relationship":"executive","years":"1865-1897","institution_blurb":"Civil War quartermaster who returned to serve as assistant secretary then vice-president of his father Julius's National Life Insurance Company until 1897."}],"landmarks":[{"landmark_id":"LM062","landmark_blurb":"Built the 1889 Queen Anne brick house at 120 State Street Montpelier (designed by mayor George Guernsey) on the site of his family home."}],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"edward-dewey-1829"},"X02375":{"id":"X02375","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"display_name":"Susan Griggs Lilley Dewey","first_name":"Susan","middle_name":"Griggs","last_name":"Dewey","maiden_name":"Lilley","married_names":["Dewey"]},"birth":{"year":1834,"month":10,"day":4,"