ources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"place":"Mount Auburn Cemetery","city":"Cambridge","state":"Massachusetts"},"slug":"isabelle-labouisse-1939"},"HD2606":{"id":"HD2606","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00869","mother_id":"HD2603"},"tags":["diplomat","nobel_prize"],"sources":[{"short":"Online vital records; The Record LXXI; EH 1909"}],"birth":{"year":1904,"month":2},"death":{"year":1987,"month":3},"marriages":[{"spouse_id":"X00871","children_ids":[],"marriage_number":1,"date_year":1935,"date_month":6,"date_day":29},{"spouse_id":"X00870","children_ids":[],"marriage_number":2,"date_year":1954,"date_month":11,"date_day":19,"location_city":"New York","location_state":"New York"}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"UNICEF director; accepted 1965 Nobel Peace Prize","primary_url":"https://en.wikipedia.org/wiki/Henry_Richardson_Labouisse_Jr.","primary_url_label":"Wikipedia"},"cross_connections":[{"type":"civic_peer","related_id":"TD0244","display_label":"Junior ECA Paris staffer on Marshall Plan, later Fitzgerald biographer","link_text":"Andrew Winchester Turnbull"},{"type":"family_orbit","related_id":"X02866","display_label":"his father-in-law, who shared a Nobel for radioactivity"},{"type":"family_orbit","related_id":"X02867","display_label":"his mother-in-law, twice a Nobel laureate"}],"bio":{"display_name":"Henry Richardson Labouisse","first_name":"Henry","last_name":"Labouisse","middle_name":"Richardson","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/en/7/7e/Henry_Richardson_Labouisse%2C_Jr..jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"achievement","header":"Accepted UNICEF's 1965 Nobel Peace Prize","body":"Henry Labouisse became Executive Director of UNICEF in 1965 — the year UNICEF was awarded the Nobel Peace Prize. He accepted the prize on the organization's behalf. UNICEF would conduct major relief operations under his fourteen-year leadership, including during the Nigerian civil war in 1968 and in Cambodia in 1979."},{"number":2,"category":"marriage","header":"Married Eve Curie; son-in-law of Marie Curie","body":"His second marriage on November 19, 1954 to Ève Curie made him son-in-law of Pierre and Marie Curie. The Curie family won five Nobel Prizes — Pierre and Marie (Physics 1903), Marie again (Chemistry 1911), Irène and Frédéric Joliot-Curie (Chemistry 1935), and Henry himself accepting the Peace Prize for UNICEF in 1965. Ève survived him by twenty years, dying in 2007 at age 102."},{"number":3,"category":"family","header":"Great-great-grandson of Confederate bishop Leonidas Polk","body":"His mother Frances Devereux Huger Labouisse descended from Leonidas Polk (X00867) — the Episcopal bishop killed as a Confederate general at Pine Mountain in 1864. Polk's daughter Elizabeth Devereux Polk married William Elliott Huger; their daughter Frances was Henry's mother. The Curie marriage thus joined Henry's two genealogical headlines — Hooker-Edwards Puritan lineage on the New England side, Polk Confederate aristocracy on the Louisiana side."}],"slug":"henry-labouisse-1904"},"X00871":{"id":"X00871","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1909},"death":{"year":1945},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2606","date_year":1935,"date_month":6,"date_day":29,"children_ids":[]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Scriven Clark","first_name":"Elizabeth","middle_name":"Scriven","maiden_name":"Clark","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elizabeth-clark-1909"},"X00870":{"id":"X00870","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["author","charity","journalist"],"sources":[],"birth":{"year":1904,"month":12,"day":6,"city":"Paris","country":"France"},"death":{"year":2007,"month":10,"day":22,"city":"Manhattan","state":"New York"},"gender":"female","notable":{"is_notable":true,"notable_category":["author","arts","social_reform"],"notable_blurb":"Journalist, author, UNICEF First Lady","primary_url":"https://en.wikipedia.org/wiki/Eve_Curie","primary_url_label":"Wikipedia"},"number_of_marriages":1,"narrative_blocks":[{"number":1,"category":"legacy","header":"The only Curie without a Nobel Prize","body":"Ève Curie was the younger daughter of Marie and Pierre Curie, and the only member of her family who did not become a scientist. She joked that she was the only Curie without a Nobel Prize — until 1965, when her husband Henry Labouisse accepted the Nobel Peace Prize on behalf of UNICEF, completing the family legacy of five Nobel laureates."},{"number":2,"category":"career","header":"Her biography of Marie Curie won the National","body":"Published in 1937, Ève's biography Madame Curie became an international bestseller and won the National Book Award. She followed it with Journey Among Warriors (1943), dispatches from the front lines of World War II that earned a Pulitzer nomination."},{"number":3,"category":"social_reform","header":"Decades at UNICEF","body":"From the 1960s onward Ève devoted herself to UNICEF, traveling to over 100 countries with her husband, the organization's executive director. The United Nations Secretary General Kofi Annan visited her in her New York apartment on her 100th birthday in 2004. She died in Manhattan in 2007 at age 102."}],"burial":{"cemetery_id":"CEM021"},"marriages":[{"marriage_number":1,"spouse_id":"HD2606","date_year":1954,"date_month":11,"date_day":19,"location_city":"New York","location_state":"New York","children_ids":[]}],"parents":{"father_id":"X02866","mother_id":"X02867"},"cross_connections":[],"career":[{"title":"Journalist","location_country":"France"},{"title":"Pianist","location_country":"France"},{"title":"Author","location_country":"France"},{"title":"UNICEF Special Advisor","organization":"UNICEF","start_year":1962}],"bio":{"display_name":"Ève Denise Curie Labouisse","first_name":"Ève","last_name":"Labouisse","maiden_name":"Curie","middle_name":"Denise","married_names":["Labouisse"],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779659630/E%CC%80ve_Curie_1937_ha28qj.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"eve-curie-1904"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}