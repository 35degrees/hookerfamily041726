":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"susan-dusenbury-1812"},"X00121":{"id":"X00121","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1739,"month":10,"day":15,"city":"Westchester County","state":"New York"},"death":{"year":1822,"month":12,"day":20,"city":"White Plains","state":"New York"},"parents":{"father_name":"Samuel Purdy Jr. (1710-1796)","mother_name":"Winifred Griffin"},"marriages":[{"spouse_id":"H00331","children_ids":["H00770","H00771","H00772","H00773","H00774","H00775","H00776","H00777","H00778","H00779"],"marriage_number":1,"spouse_name":"Abigail Smith (Hooker descendant)","date_year":1764,"end_type":"death","end_year":1822}],"prominent_name_reason":"Capt. Jacob G. Purdy — owner of the Jacob Purdy House, White Plains, NY (NRHP 1979). Gen. Washington used the house as Revolutionary War headquarters during the Battle of White Plains (October 1776) and again for two months in 1778. Now headquarters of the White Plains Historical Society.","sources":[{"short":"Wikipedia","notes":"Jacob Purdy House article"}],"political_offices":[{"title":"Captain","jurisdiction":"Westchester County Militia, New York","dates":"1775-1783","notes":"Joined 1775; served until end of Revolution."}],"cross_connections":[{"type":"national_landmark","related_id":"H00331","display_label":"Washington's headquarters during Battle of White Plains, 1776","link_text":"Abigail Smith Purdy","notes":"Capt. Jacob Purdy's house on Battle Avenue, White Plains, served as General Washington's headquarters during the Battle of White Plains (Oct 28, 1776) and again for two months in 1778. The house is now known as the Jacob Purdy House, maintained by the White Plains Historical Society. His wife Abigail Smith Purdy was a great-great-great-grandchild of Rev. Thomas Hooker — making this a Hooker-descendant-owned Washington headquarters."}],"gender":"male","tags":["revolutionary_war"],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["military"],"notable_blurb":"Washington's headquarters during Battle of White Plains","primary_url":"https://en.wikipedia.org/wiki/Jacob_Purdy_House","primary_url_label":"Wikipedia"},"military_service":[{"branch":"Continental Army / Westchester Militia","rank":"Captain","war":"Revolutionary War","start_year":1775,"notes":"Joined Westchester Militia 1775; commissioned Captain by the Battle of White Plains (Oct 28, 1776). DAR Patriot Ancestor #A125030. His brother Gabriel Purdy was a Loyalist, fighting for the British in DeLancey's Corps."}],"bio":{"title":"Captain","display_name":"Captain Jacob G Purdy","first_name":"Jacob","last_name":"Purdy","middle_name":"G","married_names":[],"gender":"male"},"residence":{"city":"White Plains","county":"Westchester","state":"New York","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"burial":{"plot_notes":"Burial location not yet recorded."},"narrative_blocks":[{"number":1,"category":"military","header":"Washington headquartered in his house, twice during war","body":"His house on Battle Avenue, White Plains, served as General Washington's headquarters during the Battle of White Plains (Oct 28, 1776) and again for two months in 1778. The house — known today as the Jacob Purdy House and maintained by the White Plains Historical Society — stands on what was the path of the Continental Army's retreat after the battle. He was an active Westchester militia captain, not a passive landlord."},{"number":2,"category":"family","header":"Loyalist brother fled to Nova Scotia after war","body":"His brother Gabriel Purdy fought for the British in DeLancey's Corps and was expelled to Nova Scotia after the Revolution. The two brothers were on opposite sides of the war across the White Plains battlefield. They never reconciled — and the Purdy family was permanently divided by the Revolution."},{"number":3,"category":"family","header":"Loyalist branch grew larger than the Patriot branch","body":"Gabriel Purdy died in Nova Scotia leaving seventeen children, one hundred seventy grandchildren, and fifty-two great-great-grandchildren — a Loyalist descent now numerically larger than the Patriot Purdys in North America. Jacob himself was a DAR Patriot Ancestor (#A125030). The genealogical irony: the family that chose the losing side multiplied faster than the family that chose the winning one."}],"slug":"jacob-purdy-1739"},"H00331":{"id":"H00331","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1746,"month":3,"day":21,"city":"White Plains","state":"New York"},"death":{"year":1839,"month":11,"day":12,"city":"White Plains","state":"New York"},"parents":{"father_id":"I00140","mother_id":"H00109"},"marriages":[{"spouse_id":"X00121","children_ids":["H00770","H00771","H00772","H00773","H00774","H00775","H00776","H00777","H00778","H00779"],"marriage_number":1,"date_year":1764}],"tags":["extraordinary_longevity"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 331"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Abigail Smith Purdy","first_name":"Abigail","last_name":"Purdy","married_names":["Purdy"],"maiden_name":"Smith"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"She lived to ninety-three","body":"Abigail Smith married Capt. Jacob Purdy and lived to ninety-three, dying in 1839 — among the longest lives of her generation."}],"slug":"abigail-purdy-1746"},"I00140":{"id":"I00140","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1702,"month":5,"day":5,"city":"Newport Pagnell","county":"Buckinghamshire","country":"England"},"death":{"year":1771,"month":2,"day":26,"city":"White Plains","state":"New York"},"burial":{"cemetery_id":"CEM579","plot_notes":"First Presbyterian Church Cemetery, White Plains NY; later church construction extended over his grave. SOURCE: FindAGrave."},"parents":{"mother_research_notes":"Susannah Odell","father_research_notes":"Thomas Smith of Rye, NY"},"church_roles":[{"role":"Pastor","location":"Rye, New York","dates":"ordained Dec 13, 1742"},{"role":"Pastor","location":"White Plains, New York","dates":"later years"},{"role":"Occasional preacher","location":"Sing Sing, New York","dates":"1763-1768"}],"marriages":[{"spouse_id":"H00109","children_ids":["H00320","H00321","H00322","H00323","H00324","H00325","H00326","H00327","H00328","H00329","H00330","H00331"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 109"},{"short":"Smith-Hooker Genealogy by Della Bishop, 1936"},{"short":"Yale Biographical Sketches 1701-1745 (1885)","page":"359"}],"gender":"male","tags":["yale_graduate","physician","minister"],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["physician","minister"],"notable_blurb":"Physician-minister at White Plains for thirty years","primary_url":"https://www.findagrave.com/memorial/62188479/john-smith","primary_url_label":"FindAGrave"},"cross_connections":[{"type":"historical_connection","related_id":"X00128","display_label":"Young friend in New York who drew him toward the ministry","link_text":"Jonathan Edwards"}],"education":[{"school_name":"Yale College","graduation_year":1727,"institution_id":"INST022"}],"bio":{"title":"Rev. Dr.","display_name":"Rev. Dr. John Smith","first_name":"John","last_name":"Smith","married_names":[],"gender":"male"},"residence":{"city":"White Plains","county":"Westchester","state":"New York","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1727"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Physician","organization":"Rye and White Plains, NY","end_year":1771,"notes":"Practiced medicine alongside ministry for nearly 30 years. 'Said to have been a very successful physician... remarkably successful in cases of insanity.'"},{"role":"Presbyterian Minister","organization":"White Plains Presbyterian Church","end_year":1771,"notes":"Served the White Plains church which was destroyed in the Battle of White Plains October 1776, seven years after his death."}],"narrative_blocks":[{"number":1,"category":"relationships","header":"Walked the Hudson with Jonathan Edwards as friend","body":"He was a personal friend of Jonathan Edwards, the most important American theologian of the eighteenth century. On one occasion, walking together along the banks of the Hudson, Smith confided to Edwards: 'To be separated from my endeared friends and companions are the most bitter trials of my life.' The friendship spanned Smith's quarter-century at White Plains and Edwards's career through Northampton, Stockbridge, and Princeton."},{"number":2,"category":"career","header":"Physician and Presbyterian minister for thirty years","body":"He practiced medicine and ministry simultaneously at Rye and White Plains for nearly thirty years — a rare dual vocation in colonial America. Contemporaries described him as 'remarkably successful in cases of insanity.' His Yale class of 1727 trained him for ministry; the medicine he taught himself."},{"number":3,"category":"historical","header":"His church destroyed at Battle of White Plains","body":"Seven years after his death in 1771, the Battle of White Plains was fought in front of his Presbyterian church on Oct 28, 1776 — and the building was destroyed. A second church on the same ground was later destroyed by fire. The third — built of gray stone — was eventually extended over his grave, and the original upright slab was moved further back."},{"number":4,"category":"clergy","header":"A church was later built over his grave","body":"Rev. Dr. John Smith served nearly thirty years as Presbyterian minister at Rye and White Plains. After his death the White Plains meetinghouse was rebuilt over his burial spot, and his gravestone was moved back to accommodate it."}],"slug":"john-smith-1702"},"H00109":{"id":"H00109","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1704,"month":5,"day":10,"city":"Guilford","state":"Connecticut"},"parents":{"father_id":"H00031","mother_id":"I00061"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 109"},{"short":"Smith-Hooker Genealogy by Della Bishop, 1936, Ithaca NY"}],"death":{"year":1775,"month":9,"day":5,"city":"White Plains","state":"New York"},"marriages":[{"spouse_id":"I00140","children_ids":["H00320","H00321","H00322","H00323","H00324","H00325","H00326","H00327","H00328","H00329","H00330","H00331"],"marriage_number":1,"date_year":1724,"date_month":5,"date_day":6,"location_city":"Guilford","location_state":"Connecticut"}],"cross_connections":[{"type":"family_connection","related_id":"H00757","display_label":"Mehitable Hooker Smith is the great-grandmother of Maj. Benjamin Tallmadge.","link_text":"Maj. Benjamin Tallmadge Jr."}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Mehitable Hooker Smith","notes":"Also called \"Mabel\" per EH","first_name":"Mehitable","last_name":"Smith","married_names":["Smith"],"maiden_name":"Hooker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Twelve children with Rev. John Smith of Rye","body":"She married Rev. John Smith of Rye, New York, and had twelve children between 1727 and 1750. The family lived in Westchester County during the years just before the Revolution turned that border country into a no-man's land."},{"number":2,"category":"family","header":"Great-grandmother of Washington's spymaster","body":"Her great-grandson Major Benjamin Tallmadge ran the Culper Ring for George Washington — the network that exposed Benedict Arnold's 1780 treason. Tallmadge was a classmate of Nathan Hale and a fellow Hooker descendant."},{"number":3,"category":"family","header":"Daughter Abigail at Washington's White Plains headquarters","body":"Her daughter Abigail Smith married Jacob Purdy, whose Purchase, NY house served as Washington's headquarters during the Battle of White Plains in 1776 and again in 1778. The Purdy descendants would carry the line through several Patriot–Loyalist conflicts."},{"number":4,"category":"family","header":"She and her sister married two Smith brothers","body":"Mehitable Hooker married Rev. Dr. John Smith of Rye. Her elder sister Hannah had married his brother Thomas, so two Hooker sisters wed two Smith brothers."}],"burial":{"cemetery_id":"CEM579","plot_notes":"First Presbyterian Church Cemetery, White Plains NY. SOURCE: FindAGrave."},"slug":"mehitable-smith-1704"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}