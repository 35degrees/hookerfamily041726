es":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2370","date_year":1867,"date_month":3,"children_ids":["HD2410"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Henriette Lucie Fornachon de Preux","first_name":"Henriette","middle_name":"Lucie","maiden_name":"Fornachon de Preux","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"henriette-fornachon-de-preux-1848"},"HD2370":{"id":"HD2370","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00768","mother_id":"HD2293"},"tags":["civil_war","navy","physician"],"sources":[{"short":"U.S. Naval History and Heritage Command","url":"https://www.history.navy.mil/","note":"Photo NH 49078 carte de visite"},{"short":"Andy Hall (Civil War medical researcher)","note":"FindAGrave contribution"}],"birth":{"year":1837,"month":3,"day":13,"note":"BIRTHPLACE DISCREPANCY: Edwards 1903 (Northampton MA) vs FindAGrave/Andy Hall (Saco ME). Multiple Civil War service records cite Saco ME as birthplace — likely the correct one. Northampton MA may have been family residence at one point. Sam to advise."},"marriages":[{"spouse_id":"X00787","children_ids":["HD2410"],"marriage_number":1,"date_year":1867,"date_month":3}],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["medicine","military"],"notable_blurb":"USN Civil War surgeon; tended Confederate wounded"},"death":{},"cross_connections":[],"bio":{"display_name":"Acting Asst. Surgeon George Hopkins, USN","first_name":"George","last_name":"Hopkins","title":"Acting Asst. Surgeon","married_names":[],"gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779717881/georgehopkins_nflfzg.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Civil War","war_id":"WAR006","side":"United States Navy","rank":"Acting Assistant Surgeon","service_years":"1862-1865","commissioned_date":"October 1, 1862","appointed_date":"November 1862","discharged_date":"October 12, 1865 (honorably discharged)","units":["Mississippi Squadron","USS Red Rover (hospital ship)","USS Tacony"],"engagements":["Off Fort Fisher, January 1865 — only medical officer aboard USS Tacony; filed casualty report; went ashore Jan 17, 1865 to tend Confederate wounded"],"role":"Naval surgeon on Mississippi Squadron hospital ship USS Red Rover (one of the Civil War's most famous floating hospitals). Later aboard USS Tacony as sole medical officer during 1865 Fort Fisher operations.","photograph":"U.S. Naval History and Heritage Command Photograph NH 49078 (carte de visite)"}],"narrative_blocks":[{"number":1,"category":"medicine","header":"USN Civil War surgeon, hospital ship Red Rover","body":"George Hopkins enlisted October 1, 1862 and was appointed Acting Assistant Surgeon in the U.S. Navy in November 1862. He served with the Mississippi Squadron — including aboard the USS Red Rover, the Navy's first hospital ship and one of the most famous Civil War floating hospitals. He was honorably discharged October 12, 1865 at war's end."},{"number":2,"category":"character","header":"Tended Confederate wounded ashore at Fort Fisher","body":"In January 1865, Hopkins was the only medical officer aboard USS Tacony during operations off Fort Fisher, North Carolina. He filed a casualty report from the engagement. On January 17, 1865 he went ashore at Fort Fisher to tend Confederate wounded — a cross-line medical act notable for its humanity in the war's final months."},{"number":3,"category":"identity","header":"Sole known portrait — Navy Historical Heritage Command","body":"The only known image of George Hopkins is a Civil War-era carte de visite portrait now in the U.S. Naval History and Heritage Command collection, catalog NH 49078. He married Henrietta Lucie Fornachon of New York in March 1867 and had seven children. Edwards 1903 records Northampton MA birthplace; Navy service records cite Saco ME — discrepancy unresolved."}],"slug":"george-hopkins-1837"},"HD2410":{"id":"HD2410","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2370","mother_id":"X00787"},"tags":[],"sources":[],"birth":{"year":1877,"month":7,"city":"New York","state":"New York"},"death":{"year":1964,"month":12,"city":"Portland","state":"Oregon"},"gender":"unknown","marriages":[{"spouse_id":"X01557","children_ids":[],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Ranald Maurice Hopkins","first_name":"Ranald","last_name":"Hopkins","middle_name":"Maurice","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ranald-hopkins-1877"},"X01557":{"id":"X01557","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2410","children_ids":[]}],"parents":{},"notable":{"is_notabl