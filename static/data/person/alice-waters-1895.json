y":"Fairfield County","state":"Connecticut","country":"United States","age":63},"residence":{},"burial":{"plot_notes":"Fairlawn Cemetery, Ridgefield CT (Jones-Haven plot)"},"baptism":{},"cross_connections":[],"narrative_blocks":[],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Elizabeth Shaw Haven","first_name":"Elizabeth","last_name":"Haven","maiden_name":"Ingersoll","middle_name":"Shaw","married_names":["Haven"],"gender":"female"},"slug":"elizabeth-haven-1860"},"HD5120":{"id":"HD5120","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":1,"descent_from_thomas_hooker_bool":true},"parents":{"father_id":"HD5108","mother_id":"I01300"},"tags":["governor","politician"],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"I01301","end_type":"death_of_spouse","end_year":1898,"children_ids":["HD5124","HD5125","HD5126","HD5127","HD5128"]}],"number_of_marriages":1,"notable":{"is_notable":true,"notable_blurb":"Governor of Connecticut, 1873-1877","notable_category":["politics"],"primary_url":"https://en.wikipedia.org/wiki/Charles_Roberts_Ingersoll","primary_url_label":"Wikipedia"},"birth":{"year":1821,"month":9,"day":16,"city":"North Haven","state":"Connecticut","country":"United States"},"death":{"year":1903,"month":1,"day":25,"city":"North Haven","state":"Connecticut","country":"United States","age":81},"residence":{},"burial":{"plot_notes":"Grove Street Cemetery, New Haven CT"},"baptism":{},"cross_connections":[{"type":"civic_peer","related_id":"HD2659","display_label":"New Haven attorney; Bristol law firm founder, almost lifelong friend","link_text":"Louis H. Bristol","notes":"Lifelong friendship documented in Bristol's CT Reports memorial. Bristol senior counsel for Yale University, founder of Bristol Stoddard & Bristol 1888."},{"type":"in_law","related_id":"X02896","display_label":"was his father-in-law; US Navy Rear Admiral"}],"narrative_blocks":[{"number":1,"category":"politics","header":"Governor of Connecticut, 1873-1877","body":"Charles Roberts Ingersoll served as Governor of Connecticut from 1873 through 1877 — four years that placed him at the head of the state during Reconstruction-era industrial expansion. He continued the family's prominent role in Connecticut public life that his father Ralph (US Minister to Russia, four-term Congressman) and grandfather Jonathan Ingersoll Jr. (Lieutenant Governor 1816-1823) had established before him. Three consecutive generations of Ingersolls held principal Connecticut state offices."},{"number":2,"category":"character","header":"Almost lifelong friendship with Louis H. Bristol","body":"Charles maintained an unusually close, almost lifelong friendship with New Haven attorney Louis H. Bristol — the senior counsel for Yale University and founder of the Bristol Stoddard Bristol law firm. The friendship was described as 'one of special closeness' that ran from their early careers at the New Haven bar through to Bristol's 1910 death. Both men were New Haven figures of the same generation, both descendants of prominent Connecticut legal families."},{"number":3,"category":"family","header":"Married Admiral Francis Gregory's daughter Virginia","body":"Charles married Virginia Gregory (1823-1898), daughter of Admiral Francis Gregory of the United States Navy. The couple had five children together — only three of whom survived to adulthood, two infant deaths and a childhood death marking the family. Virginia died November 30, 1898 in New Haven at age seventy-five, five years before Charles followed in 1903."},{"number":4,"category":"family","header":"North Haven 1821 to 1903, age eighty-one","body":"Charles Roberts Ingersoll was born September 16, 1821 in North Haven Connecticut and died January 25, 1903 in North Haven at age eighty-one. He is buried at Grove Street Cemetery in New Haven alongside three generations of the Ingersoll family. The Grove Street cluster includes his father Ralph, grandfather Jonathan Jr., his wife Virginia Gregory, and his children."}],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST001","role":"student","notes":"Hopkins Grammar School preparatory training"},{"institution_id":"INST022","role":"student","notes":"Yale College class of 1840; honorary LLD 1874"}],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Charles Roberts Ingersoll","first_name":"Charles","last_name":"Ingersoll","middle_name":"Roberts","married_names":[],"gender":"male"},"slug":"charles-ingersoll-1821"},"I01301":{"id":"I01301","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker_bool":false},"parents":{"father_id":"X02896","mother_id":"X02897"},"tags":[],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"HD5120","end_type":"death_of_spouse","end_year":1898,"children_ids":["HD5124","HD5125","HD5126","HD5127","HD5128"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1823,"month":8,"day":28,"country":"United States"},"death":{"year":1898,"month":11,"day":30,"age":75,"country":"United States"},"residence":{},"burial":{"pl