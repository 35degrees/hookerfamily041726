y_label":"Their children's marriages closed two Hooker-cousin loops","type":"family_connection"},{"type":"cousin_marriage","related_id":"HD3260","display_label":"Her daughter Caroline Shader married his son Thomas Harvey Hooker","notes":"Cousin marriage documentation. H02424 (Thomas Edwin Hooker) and HD3260 (Laura Electa Hooker Shader) are uncle and niece — Laura's father Myron Hooker (H01272) was Thomas Edwin's half-brother. Their respective children H03872 Thomas Harvey Hooker (Thomas Edwin's son) and X02269 Caroline E. Shader (Laura's daughter) were third cousins who married Feb 12, 1863. Children of that marriage (H05030 Lucy and H05031 Alvah) inherit double-Hooker ancestry with descent_paths_to_thomas=2."}],"burial":{"cemetery_id":"CEM514","plot_notes":"Sandy Creek Cemetery Murray Orleans County New York per FA"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"thomas-hooker-1813"},"X02241":{"id":"X02241","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":false},"bio":{"first_name":"Lucy","last_name":"Hooker","maiden_name":"Hyde","married_names":["Hooker"],"gender":"female","display_name":"Lucy Hyde Hooker"},"birth":{"year":1819,"county":"Wayne County","state":"New York","country":"United States"},"death":{"year":1861,"month":8,"day":1,"city":"Murray","county":"Orleans County","state":"New York","country":"United States"},"parents":{},"burial":{"plot_notes":"Sandy Creek Cemetery, Murray, Orleans County NY (per Findagrave). Same as husband Thomas Edwin."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H02424","date_year":1839,"date_month":9,"date_day":19,"location_city":"Augusta","location_county