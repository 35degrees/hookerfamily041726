,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1756,"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States"},"cross_connections":[],"bio":{"display_name":"Susan Woodward Russell","first_name":"Susan","last_name":"Russell","maiden_name":"Woodward","married_names":["Russell"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{},"former_ids":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married brother-in-law after sister Sarah's 1807 death","body":"Susan Woodward of New Haven was the elder sister of Sarah Woodward, second wife of Col. Samuel Andrew Russell. When Sarah died suddenly in New York August 1807, Samuel — needing care for his five young children — married Susan around 1809. She died at Buffalo in September 1819 aged 62-63."}],"slug":"susan-woodward-1756"},"HD1323":{"id":"HD1323","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00844","mother_id":"X00413"},"tags":["new_york_migration"],"sources":[],"birth":{"year":1785,"month":7,"day":12,"city":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1860,"month":11,"day":23,"city":"Homer","county":"Cortland County","state":"New York","country":"United States","age":75},"marriages":[{"spouse_id":"X00419","children_ids":["HD1332","HD1333","HD1334","HD1335","HD1336","HD1337","HD1338","HD1339","HD1340","HD1341","HD1342"],"marriage_number":1}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Lucy Munson Russell Hill","first_name":"Lucy","last_name":"Hill","maiden_name":"Russell","middle_name":"Munson","married_names":["Hill"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST023"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Eleven children with US Consul to Brazil","body":"Lucy Munson Russell married Henry Hill on January 20, 1807 in Homer, Cortland County New York. Henry was appointed United States Consul to Brazil by President Thomas Jefferson in 1808 — serving at Salvador (Bahia) from 1808 through about 1815-1818, then transferring to Rio de Janeiro. The couple had eleven documented children, many of them born in Brazil during the consulship."},{"number":2,"category":"family","header":"Several daughters born in Brazil 1808-1824","body":"Among Lucy's eleven children, Maria Louisa (1808), Charlotte Henrietta (1824), and others were born in Brazil during Henry's consul years. The Brazilian-birth circumstance was extraordinarily rare for early-nineteenth-century Connecticut-line American women — Lucy's adult life spanned both the Connecticut and Cortland County NY home bases and the Salvador-Rio diplomatic-residence years across two continents."},{"number":3,"category":"family","header":"Outlived husband by nineteen years, buried Buffalo","body":"Henry Hill died July 24, 1841 at age sixty-three; Lucy outlived him by nineteen years, dying November 23, 1860 in Homer New York at age seventy-five. She is buried at Forest Lawn Cemetery in Buffalo New York — the major Buffalo garden cemetery — distinguishing her death-and-burial location from her Connecticut birth and Homer residence."},{"number":4,"category":"family","header":"New Haven CT 1785 to Homer NY 1860","body":"Lucy Munson Russell was born July 12, 1785 in New Haven Connecticut. She died in Homer, Cortland County New York at age seventy-five. Her father Captain William Russell of Middletown CT and her mother set her up to marry into the Hill family whose career took her on the unusual Brazilian-diplomatic-post excursion."}],"slug":"lucy-hill-1785"},"HD1324":{"id":"HD1324","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00844","mother_id":"X00414"},"tags":[],"sources":[],"birth":{"year":1791},"death":{"year":1828},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"William Andrew Russell","first_name":"William","last_name":"Russell","middle_name":"Andrew","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"william-russell-1791"},"HD1325":{"id":"HD1325","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00844","mother_id":"X00414"},"tags":[],"sources":[],"birth":{"year":1794},"death":{"year":1889},"gender":"female","marriages":[{"spouse_id":"X01643","children_ids":[],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Harriet Wadsworth Russell Williams","first_name":"Harriet","last_name":"Williams","maiden_name":"Russell","middle_name":"Wadsworth","married_names":["Williams"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"harriet-williams-1794"},"HD1326":{"id":"HD1326","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00844","mother_id":"X00414"},"tags":["killed_in_action","second_seminole_war"],"sources":[],"birth":{"year":1797},"death":{"year":1839},"marriages":[{"spouse_id":"X00420","children_ids":["HD1343"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["military"],"notable_blurb":"Killed in the Second Seminole War, 1839"},"cross_connections":[{"type":"family_connection","related_id":"H02539","display_label":"Cousin Edward P. Hooker advocated Seminole education later","link_text":"Rev. Edward Payson Hooker","description":"Capt. Samuel Law Russell was killed fighting in the Second Seminole War in 1839. Roughly fifty years later, his distant cousin Rev. Edward Payson Hooker became founding president of Rollins College in Florida and was a vocal advocate for Seminole education and educational equity — a remarkable arc within one Hooker descent line."}],"military_service":[{"war":"Second Seminole War","war_id":"WAR011","rank":"Captain","unit":"2nd U.S. Infantry Regiment (HHC, 3rd Battalion, 2nd Infantry, 1836-1839)","killed_in_action":true,"service_years":"1819-1839","commission_progression":[{"rank":"Second Lieutenant","date":"1819-08-13","unit":"2nd U.S. Infantry Regiment"},{"rank":"Assistant Commissary Subsistence","date":"1824-07"},{"rank":"First Lieutenant","date":"1827-12"},{"rank":"Captain","date":"1836-06"}],"battles":[{"battle_id":"BTL042","battle_name":"Engagement on the Miami River","year":1839,"month":2,"day":28,"location_city":"Key Biscayne","location_state":"Florida"}],"cause_of_death":"Three musket balls — two in chest, one in brain","notes":"Killed leading his company into battle on the Miami River near Key Biscayne, Feb 28, 1839. Fort Dallas was renamed Fort Russell in his memory."}],"narrative_blocks":[{"number":1,"category":"death","header":"Killed by three balls, two in the chest","body":"On February 28, 1839, leading his infantry company against the Seminoles on the Miami River near Key Biscayne, Captain Russell was struck by three Seminole musket balls — two in the breast and the third in the brain. He died almost instantly at age 40, twenty years to the month after first putting on the uniform of the 2nd U.S. Infantry."},{"number":2,"category":"legacy","header":"The Army renamed the fort after him","body":"Fort Dallas — the U.S. Army's first post on Key Biscayne — was rechristened Fort Russell in his memory, and bore his name for most of its operating life. His regimental officers raised an Italian marble box-tomb over his remains at Governor's Island, inscribed: 'a Christian soldier; a dignified and exemplary gentleman; a tender husband and father.'"}],"bio":{"display_name":"Captain Samuel Law Russell","first_name":"Samuel","last_name":"Russell","title":"Captain","middle_name":"Law","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST035"}],"landmarks":[],"artworks":[],"quotes":[],"slug":"samuel-russell-1797"},"HD1327":{"id":"HD1327","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00844","mother_id":"X00414"},"tags":[],"sources":[],"birth":{"year":1801},"death":{"year":1865},"marriages":[{"spouse_id":"X00416","children_ids":["HD1344","HD1328"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"notable":{"is_notable"