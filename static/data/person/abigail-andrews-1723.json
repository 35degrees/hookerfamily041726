iction":"New York State Assembly","dates":"1806, 1807, 1816"},{"title":"Judge","jurisdiction":"Niagara County NY","dates":"1817-1834"},{"title":"Delegate","jurisdiction":"New York Constitutional Convention","dates":"1821"},{"title":"Presidential Elector","jurisdiction":"New York","dates":"1824"},{"title":"Postmaster","jurisdiction":"Buffalo NY","dates":"1831-1834"}],"marriages":[{"spouse_id":"X00413","children_ids":["HD1323"],"marriage_number":1,"date_year":1783,"marriage_year":1783},{"spouse_id":"X00414","children_ids":["HD1324","HD1325","HD1326","HD1327","HD6128"],"marriage_number":2,"date_year":1790,"marriage_year":1790},{"spouse_id":"X00415","children_ids":[],"marriage_number":3,"date_year":1809,"end_type":"death_of_spouse","end_year":1819,"location_state":"New York","location_country":"United States","marriage_year":1809}],"gender":"male","number_of_marriages":3,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Col. Samuel Andrews Russell","first_name":"Samuel","last_name":"Russell","title":"Colonel","middle_name":"Andrews","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"plot_notes":"Forest Lawn Cemetery, Buffalo NY"},"narrative_blocks":[{"number":1,"category":"career","header":"Postmaster of Buffalo, appointed April 1831","body":"Appointed Postmaster of Buffalo NY in April 1831 by President Andrew Jackson; held the office until his death on 2 July 1834. The Yale biographical sketch summarized: 'loved, esteemed, and respected by all who knew him.'"},{"number":2,"category":"politics","header":"NY Constitutional Convention 1821, Elector 1824","body":"Served as a delegate to the New York State Constitutional Convention of 1821 — which revised the state constitution to broaden suffrage and reorganize the judiciary. Selected as a Presidential Elector for New York in the 1824 election."},{"number":3,"category":"career","header":"Niagara County Judge from April 1817","body":"First appointed Judge in Niagara County NY in April 1817 — shortly after his removal from New York City to Buffalo. Held judicial office in western New York's frontier period when Niagara County still encompassed much of the territory later subdivided into Erie and other counties."},{"number":4,"category":"marriage","header":"Married two of the three Woodward sisters","body":"After his first wife Lucy Munson died at 29 in 1785 leaving a daughter, he married Sarah Woodward of New Haven in November 1790. She died suddenly in New York August 1807; around 1809 he then married her sister Susan Woodward, who died September 1819 in her 63rd year."},{"number":5,"category":"military","header":"Revolutionary War private under Capt. Peter Vail","body":"Served as a private in the Connecticut militia under Captain Peter Vail and Colonel Canfield during the Revolutionary War. SAR Patriot #P-283245 + DAR #A098524. His Yale studies followed wartime service and graduation around 1779 — he remained at Yale as graduate student and Butler until May 1783."}],"slug":"samuel-russell-1759"},"X00413":{"id":"X00413","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1756},"death":{"year":1785},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00844","children_ids":["HD1323"],"marriage_year":1783}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Lucy Munson","first_name":"Lucy","maiden_name":"Munson","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"d