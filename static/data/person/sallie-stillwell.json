aths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_research_notes":"John Howe Cecil (Sr.); Richmond VA family.","mother_research_notes":"Pattie Cary Cecil; Richmond VA."},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2158","children_ids":["HD3381","HD3382","HD3383"],"date_year":1953,"date_month":4,"date_day":18,"location_city":"Charlottesville","location_state":"Virginia","location_country":"United States","end_year":2022,"end_type":"death_of_spouse"}],"education":[{"school_name":"Saint Christopher's School","type":"secondary","notes":"Richmond VA preparatory school."},{"school_name":"Episcopal High School","type":"secondary","notes":"Alexandria VA boarding school."},{"institution_id":"INST023","school_name":"Princeton University","dates":"1946+","type":"undergraduate","notes":"Education interrupted by 3-year WWII Army service ending in the Philippines; returned to graduate."}],"career":[{"role":"Jazz pianist","organization":"Les Deux Magots","location":"Paris, France","notes":"After graduating from Princeton, spent a year in Paris playing jazz piano at the famous Saint-Germain-des-Prés cafe."},{"role":"Sales","organization":"IBM","location":"New York City"},{"role":"Stock broker","organization":"Independent practice","location":"Washington, D.C.","notes":"Where he met future wife Suzan Knight (then at Time Magazine)."},{"role":"Broker","organization":"Thurston and Company","location":"Richmond, Virginia","start_year":1956,"end_year":1965,"notes":"Joined upon return to Richmond 1956."},{"role":"Co-founder","organization":"Cecil-Waller Company","location":"Richmond, Virginia","start_year":1965,"end_year":1977,"notes":"Formed with Raymond T. Waller; offered investment planning services."},{"role":"Founder","organization":"Cecil Financial Planning Corporation (later Cecil, Walke & Company)","location":"Richmond, Virginia","start_year":1977,"end_year":1998,"notes":"Earned certification as a financial planner 1977. Sold the firm at age 75."},{"role":"Investment manager","organization":"Trend Line Capital Management","location":"Richmond, Virginia","start_year":1998,"notes":"Continued managing investment accounts of old friends for many years after age 75."}],"military_service":[{"war":"World War II","war_id":"WAR008","unit":"United States Army","notes":"Three-year enlistment in the US Army during WWII; service ended in the Philippines. Interrupted his Princeton education."}],"institutions":[{"institution_id":"INST023","relationship":"alumnus"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["extraordinary_longevity","wwii","banker"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"character","header":"Played jazz piano at Paris Les Deux Magots","body":"After graduating from Princeton he spent a year in Paris playing jazz piano at Les Deux Magots, the Left-Bank cafe of Sartre, de Beauvoir, and Hemingway. He remained a gifted pianist for the rest of his life and brought the music of that year home to Richmond."},{"number":2,"category":"military","header":"Three-year Army enlistment ended in Philippines","body":"His Princeton education was interrupted by a three-year US Army enlistment during World War II, service ending in the Philippines. He returned to Princeton afterward and graduated, then took the year in Paris before settling into a New York business career."},{"number":3,"category":"career","header":"Sold his financial firm at seventy-five","body":"After founding Cecil-Waller Company in 1965 and earning his Certified Financial Planner credential in 1977, he ran Cecil Financial Planning Corporation (later Cecil, Walke & Company) until selling it at age seventy-five in 1998. He then joined Trend Line Capital Management and managed accounts of old friends for many years more."},{"number":4,"category":"death","header":"Died peacefully at one hundred","body":"He died peacefully in his sleep on May 24, 2024, two months shy of what would have been his 101st birthday. He was predeceased by his wife of nearly 69 years Suzan Knight Cecil and his sister Jane Abert Cecil; survived by sister Patricia Cecil Hass of Princeton, three children, four grandchildren, and a great-grandchild."}],"quotes":[],"sources":[{"label":"2024 obituary — John Howe Cecil Jr."}],"research_sources":[],"documents":[],"slug":"john-cecil-jr-1923"},"HD2158":{"id":"HD2158","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00689","mother_id":"HD2111"},"tags":["extraordinary_longevity","journalist"],"sources":[],"birth":{"year":1929,"month":9,"day":29,"city":"Springfield","county":"Hampden","state":"Massachusetts","country":"United States"},"death":{"year":2022,"month":3,"day":3,"city":"Richmond","county":"Richmond","state":"Virginia","country":"United States","cause":"dementia"},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00327","children_ids":["HD3381","HD3382","HD3383"],"date_year":1953,"date_month":4,"date_day":18,"location_city":"Charlottesville","location_state":"Virginia","location_country":"United States","end_year":2022,"end_type":"death"}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Suzan Whitney Knight Cecil","first_name":"Suzan","last_name":"Cecil","middle_name":"Whitney","maiden_name":"Knight","married_names":["Cecil"],"nickname":"Sue","gender":"female","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777501991/suzancecil_hkpkw1.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"plot_notes":"Hollywood Cemetery, Richmond VA"},"education":[{"school_name":"St. Anne's School","type":"secondary","notes":"Charlottesville VA preparatory school."},{"school_name":"Bennington College","type":"undergraduate","notes":"Bennington VT progressive women's college."}],"career":[{"role":"Staff","organization":"Time Magazine","location":"Washington, D.C.","notes":"Early career."},{"role":"Staff","organization":"Richmond Times-Dispatch","location":"Richmond, Virginia","notes":"After moving to Richmond ca.1956."},{"role":"Elder; chair 150th Anniversary Committee","organization":"Second Presbyterian Church","location":"Richmond, Virginia"},{"role":"Board Member","organization":"Sheltering Arms Hospital","location":"Richmond, Virginia"},{"role":"Board Member","organization":"Garden Club of Virginia","location":"Virginia"},{"role":"Founding Member","organization":"Maymont Foundation","location":"Richmond, Virginia"},{"role":"Governor's appointee","organization":"Falls of the James Scenic River Advisory Committee","location":"Virginia"}],"narrative_blocks":[{"number":1,"category":"career","header":"Time Magazine then Richmond Times-Dispatch journalist","body":"Sue Cecil began her career at Time Magazine in Washington D.C. — where she met her future husband John Howe Cecil Jr. After their 1953 marriage and ca. 1956 move to Richmond Virginia, she joined the Richmond Times-Dispatch. The combined Time + Times-Dispatch arc gave her decades of journalism credentials before her postwar civic-leadership career took precedence."},{"number":2,"category":"character","header":"Founding member Maymont Foundation, Garden Club Virginia","body":"Sue Cecil was a founding member of the Maymont Foundation (overseeing the major Richmond historic estate and gardens) and served on the board of the Garden Club of Virginia. She also sat on the Sheltering Arms Hospital board and was a Governor's appointee to the Falls of the James Scenic River Advisory Committee — a complete Richmond civic-leadership portfolio. At Second Presbyterian Church she was an Elder and chaired the 150th Anniversary Committee."},{"number":3,"category":"family","header":"Sixty-nine year marriage; three children built","body":"Sue married John Howe Cecil Jr. (1923-2024) on April 18, 1953 in Charlottesville Virginia. The marriage lasted nearly sixty-nine years until her death March 3, 2022 in Richmond at age ninety-two — after what her obituary called 'a fierce battle with dementia.' Their three children Graham Howe Cecil, Sallie Cecil Stillwell, and Maria Whitney Cecil Hirsche are all built in tree."}],"slug":"suzan-cecil-1929"},"X00689":{"id":"X00689","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["wwi"],"sources":[],"birth":{"year":1890,"month":10,"day":20},"death":{"year":1948,"month":7,"day":30},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2111","date_year":1918,"date_month":3,"date_day":31,"location_city":"Paris","location_country":"France","children_ids":["HD2155","HD2156","HD2157","HD2158","HD2159"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Earl Wall Knight","first_name":"Earl","last_name":"Knight","middle_name":"Wall","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"World War I","war_id":"WAR007","rank_year_start":1917,"unit":"United States military (specific branch not yet researched)","notes":"Registered for US military service in 1917; married Frances Pierpont Whitney in Paris March 31, 1918 during the war. Per FamilySearch / Ancestry."}],"slug":"earl-knight-1890"},"HD2111":{"id":"HD2111","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2085","mother_id":"X00677"},"tags":[],"sources":[],"birth":{"year":1891,"month":8,"day":19,"city":"New Haven","state":"Connecticut"},"death":{"year":1976,"month":11,"day":27},"marriages":[{"spouse_id":"X00689","children_ids":["HD2155","HD2156","HD2157","HD2158","HD2159"],"marriage_number":1,"date_year":1918,"date_month":3,"date_day":31,"location_city":"Paris","location_country":"France"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Frances Pierpont Whitney Knight","first_name":"Frances","last_name":"Knight","middle_name":"Pierpont","maiden_name":"Whitney","married_names":["Knight"],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777501326/franceswhitney_wltgyz.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"plot_notes":"University of Virginia Cemetery and Columbarium, Charlottesville VA"},"narrative_blocks":[{"number":1,"category":"marriage","header":"Married a soldier in Paris in March 1918","body":"She married North Carolinian Earl Wall Knight in Paris on March 31, 1918, eight months before the WWI Armistice and while Allied lines still held against Germany's Spring Offensive forty miles from the city. Her husband had registered for US military service the previous year; the wedding took place during his active war service."}],"slug":"frances-knight-1891"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}