HD3097":{"id":"HD3097","is_placeholder":false,"gender":"male","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":11,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1916,"month":12,"day":6},"death":{"year":1962,"month":9,"day":27,"city":"Biddeford Pool","county":"York County","state":"Maine"},"parents":{"father_id":"HD3093","mother_id":"X02075"},"marriages":[{"marriage_number":1,"spouse_id":"X02078","end_type":"divorce","children_ids":[],"date_year":1941,"date_month":1,"date_day":1},{"marriage_number":2,"spouse_id":"X02079","children_ids":["HD3098"],"date_year":1946,"date_month":1,"date_day":1}],"number_of_marriages":2,"tags":["wwii","military","journalist","businessman"],"sources":[{"short":"FindAGrave"}],"notable":{"is_notable":false,"notable_category":[]},"burial":{"cemetery_id":"CEM083"},"institutions":[{"institution_id":"INST056","institution_blurb":"Graduate of The Taft School, Watertown CT — the school his great-uncle Horace Dutton Taft founded."}],"narrative_blocks":[{"header":"He went from Army private to General Stilwell's","body":"David Gibson Taft was drafted in 1941 as a private, sent to officer candidate school, and commissioned. He was sent to Burma as an infantry officer and was wounded in action. He then served on the staff of General Joseph 'Vinegar Joe' Stilwell as a liaison officer with Chinese troops, then on Lord Mountbatten's staff in Ceylon, then with General Sir Oliver Leese — commander of all ground forces in the China-Burma-India theater.","number":1,"category":"character"},{"number":2,"category":"military","header":"From Army private to Stilwell’s staff","body":"Drafted as a private in 1941, he was commissioned, sent to Burma as an infantry officer, and wounded — then served as liaison on “Vinegar Joe” Stilwell’s staff, later under Mountbatten in Ceylon. He came home to run Cincinnati’s WKRC radio and television."}],"cross_connections":[{"type":"civic_peer","related_id":"HD3080","display_label":"was his second cousin; both Taft great-grandsons in WWII","link_text":"Rear Adm. David Sinton Ingalls"}],"bio":{"display_name":"David Gibson Taft","first_name":"David","last_name":"Taft","married_names":[],"bio_blurb":"WWII officer, then Cincinnati broadcaster"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"education":[{"school_name":"The Taft School","type":"secondary"},{"school_name":"Union College","type":"undergraduate"}],"career":[{"role":"Captain","organization":"U.S. Army, China-Burma-India","notes":"wounded in Burma"},{"role":"VP & General Manager","organization":"Taft Broadcasting (WKRC)"}],"slug":"david-taft-1916"},"HD0337":{"id":"HD0337","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1810,"month":11,"day":5,"city":"Townshend","state":"Vermont"},"death":{"year":1891,"month":5,"day":21,"city":"San Diego","state":"California"},"parents":{"father_id":"HD0336","mother_id":"X01153"},"marriages":[{"marriage_number":1,"spouse_id":"X01154","end_type":"death_of_spouse","end_year":1852,"children_ids":["HD3067","HD3068","HD3069","HD3070","HD3071"],"date_year":1841,"date_month":1,"date_day":1},{"marriage_number":2,"spouse_id":"X01155","children_ids":["HD3072","HD0338","HD3073","HD3074","HD3075"],"date_year":1853,"date_month":12,"date_day":26,"location_city":"Millbury","location_state":"Massachusetts"}],"tags":["lawyer","judge","politician","diplomat","skull_and_bones","yale_graduate","ohio_migration","abolitionist"],"sources":[{"label":"Wikipedia — Alphonso Taft","url":"https://en.wikipedia.org/wiki/Alphonso_Taft"}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":true,"notable_category":["politics","law"],"notable_blurb":"U.S. Attorney General 1876","primary_url":"https://en.wikipedia.org/wiki/Alphonso_Taft","primary_url_label":"Wikipedia"},"burial":{"cemetery_id":"CEM083"},"narrative_blocks":[{"header":"He co-founded Skull and Bones","body":"Alphonso Taft co-founded Skull and Bones at Yale in 1832 with William Huntington Russell — who was also a Hooker descendant, though neither man knew it. His son William Howard Taft joined the same society, as did Henry Waters Taft and Horace Dutton Taft. Alphonso served as Attorney General, Secretary of War, and U.S. Minister to both Austria-Hungary and Russia — but his greatest legacy was the political dynasty: William became the only person to hold both the presidency and the Chief Justiceship.","number":1},{"header":"He dissented in the Bible-in-schools case","body":"In 1872, Alphonso Taft dissented from his own court's ruling requiring Bible reading in Cincinnati's public schools. He argued that the government must be neutral toward all religions, referencing Jewish taxpayers' right to secular education. The opinion was widely admired but killed his 1875 bid for the Republican nomination for Governor of Ohio.","number":2},{"number":3,"category":"family","header":"His father Peter Rawson honored Hooker ancestry","body":"His father was Peter Rawson Taft — the middle name \"Rawson\" an explicit tribute to Peter's mother Rhoda Rawson Taft, who descended from Rev. Grindal Rawson and Susanna Wilson Rawson, herself a daughter of Rev. Thomas Hooker's daughter Sarah Hooker Wilson. The name traveled three generations to Alphonso's father before reaching him."}],"cross_connections":[{"type":"civic_peer","related_id":"HD1395","display_label":"Co-founded Skull and Bones at Yale in 1832 — both were Thomas Hooker descendants, though neither knew it.","link_text":"William Huntington Russell"},{"type":"ci