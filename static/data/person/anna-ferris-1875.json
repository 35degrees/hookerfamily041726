sources":[],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2392","children_ids":["HD2393","HD2394"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Ferris (husband)","first_name":"Ferris","last_name":"(husband)","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ferris-husband"},"HD2050":{"id":"HD2050","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00920","mother_id":"X00659"},"tags":["abolitionist","academic","author"],"sources":[{"short":"Yale Biographical Sketches"}],"birth":{"year":1796,"month":3,"day":3},"death":{"year":1866,"month":10,"day":16},"marriages":[{"spouse_id":"X00777","children_ids":["HD2388","HD2389","HD2390","HD2391","HD2392"],"marriage_number":1,"date_year":1827,"date_month":4,"date_day":24}],"gender":"male","notable":{"is_notable":true,"primary_url":"https://en.wikipedia.org/wiki/Theodore_Dwight_(author)","primary_url_label":"Wikipedia","notable_category":["author","social_reform"],"notable_blurb":"Abolitionist reformer"},"narrative_blocks":[{"header":"American Ethnological Society founder","detail":"The Society's founding mission aligned with abolitionist goals: if Africa could be shown to be a continent of sophisticated literate culture, the racist premises of pro-slavery ideology would collapse. Dwight worked directly with the enslaved West African scholar Omar ibn Said — one of a handful of African intellectuals whose writing survived American slavery — to gather and translate his Arabic-language autobiography. (INST033; Wikipedia; flashbak.com via FindAGrave)","body":"Theodore Dwight Jr. co-founded the American Ethnological Society (1842) and used it as a platform to demonstrate that African peoples had deep literary and religious traditions long before European colonization.","number":1},{"header":"Omar ibn Said","detail":"Omar ibn Said had been brought from Futa Toro (in present-day Senegal) to South Carolina in 1807. A practicing Muslim and scholar, he wrote Arabic on the walls of his prison cell in Fayetteville NC, catching the attention of abolitionists. Dwight, as founder of the American Ethnological Society and member of the New York Colonization Society, wanted the autobiography to reach a white American audience to undermine slavery's premise. The 15-page handwritten document remains a landmark of early American literature. (Wikipedia; \"The Life of Omar ibn Said,\" flashbak.com 2019)","body":"Dwight persuaded the enslaved West African scholar Omar ibn Said (1770-1864) to write his autobiography in Arabic — the only known extant slave narrative written in Arabic in the United States.","number":2},{"header":"*The Northern Traveller* (1825)","detail":"He also compiled and published the travelogues of his uncle Timothy Dwight IV (H00914) in 1821. His work as a travel writer, like his abolitionism and his interest in foreign languages and international politics, reflected a restless engagement with the world beyond New England that contrasted sharply with his father's Federalist parochialism. He is described by the American National Biography as \"undeniably one of America's foremost spokespersons for creating a national identity founded on cultural and geographical literacies.\" Died jumping off a departing train near Brooklyn, Oct 16, 1866. (Wikipedia; ANB)","body":"Dwight's Northern Traveller (1825) was the second tourist guidebook ever published in the United States, going through six editions through 1841.","number":3}],"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Theodore Dwight","first_name":"Theodore","last_name":"Dwight","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1814"},{"institution_id":"INST033"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"education":[{"institution_id":"INST022","dates":"1814","notes":" — Yale B.A. 1814. Nephew of Timothy Dwight IV (H00914, Yale president). Compiled his uncle's travelogues, published 1821. Founder of the American Ethnological Society."}],"slug":"theodore-dwight-1796"},"X00777":{"id":"X00777","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1808},"death":{"year":1870},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2050","date_year":1827,"date_month":4,"date_day":24,"children_ids":["HD2388","HD2389","HD2390","HD2391","HD2392"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Eleanor Bayard Boyd","first_name":"Eleanor","middle_name":"Bayard","maiden_name":"Boyd","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"eleanor-boyd-1808"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}