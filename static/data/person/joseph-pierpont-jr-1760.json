.","number":1}],"cross_connections":[],"bio":{"display_name":"Belinda Pierpont Bigelow","first_name":"Belinda","last_name":"Bigelow","maiden_name":"Pierpont","married_names":["Bigelow"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"belinda-bigelow-1804"},"X00466":{"id":"X00466","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1802},"death":{"year":1895},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1437","children_ids":["HD1438"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Levi Lewis Bigelow","first_name":"Levi","last_name":"Bigelow","middle_name":"Lewis","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"levi-bigelow-1802"},"HD1438":{"id":"HD1438","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00466","mother_id":"HD1437"},"tags":["governor"],"sources":[{"short":"Online vital records / Pierpont genealogy"}],"birth":{"year":1834,"month":5,"day":16,"city":"North Haven","state":"Connecticut","country":"United States"},"death":{"year":1891,"month":10,"day":12,"city":"New Haven","state":"Connecticut","country":"United States"},"political_offices":[{"title":"Governor","jurisdiction":"Connecticut","dates":"1881-1883"},{"title":"Mayor","jurisdiction":"New Haven CT","dates":"1879-1881"},{"title":"Member","jurisdiction":"Connecticut House of Representatives","dates":"1875"}],"cross_connections":[{"type":"family_connection","related_id":"HD1492","display_label":"Second cousins once removed via Lt. Joseph Pierpont","link_text":"Edwards Pierrepont"}],"institution_affiliations":[{"institution_id":"INST040","role":"founder","year":1881,"notes":"Signed legislation accepting the Storrs gift, establishing Storrs Agricultural School on Sep 28, 1881."}],"gender":"male","marriages":[{"spouse_id":"H00359","children_ids":[],"marriage_number":1}],"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Founded the University of Connecticut as 33rd governor","primary_url":"https://www.nga.org/governor/hobart-baldwin-bigelow/","primary_url_label":"National Governors Association"},"narrative_blocks":[{"header":"Founded the University of Connecticut, 1881","detail":"Bigelow was Mayor of New Haven (1879-1881) before his election as 33rd Governor of Connecticut (1881-1883, Republican). His governorship created the school that became UConn; required fire escapes for workplaces with 12+ employees; and reformed Connecticut's election procedures. He died in 1891, eight years after leaving office. UConn did not take its current name until 1939, nearly half a century after his death. (Wikipedia; EH 1909; UConn official history)","body":"As 33rd Governor of Connecticut 1881-1883 (Republican) he signed the legislation founding the Storrs Agricultural School — now the University of Connecticut. The single-term governorship was the capstone of his Republican career after New Haven mayoralty and state house service.","number":1},{"number":2,"category":"politics","header":"First Connecticut fire-escape law for larger firms","body":"As Republican Governor 1881-1883 he signed legislation requiring fire escapes for companies with twelve or more employees — the first such occupational safety law in Connecticut. He also signed electoral procedure reforms during his single term."},{"number":3,"category":"politics","header":"New Haven Mayor before becoming Governor","body":"He served as Mayor of New Haven 1879-1881 immediately before his governorship; previously Councilman 1863-1876; CT House 1875; Delegate Republican National Convention 1880. The municipal-to-state political path was typical of post-Civil War Connecticut Republican leadership."},{"number":4,"category":"lineage","header":"Doubly descended from Rev. James Pierpont","body":"Through his mother Belinda Pierpont he descended from Rev. James Pierpont — Yale co-founder — through both Joseph Pierpont Jr's patrilineal Pierpont line AND through Pierpont's daughter Mary who married Samuel Russell. Published biographies acknowledge only one of these Pierpont-Yale paths."}],"number_of_marriages":1,"burial":{"cemetery_id":"CEM018"},"bio":{"display_name":"Gov. Hobart Baldwin Bigelow","first_name":"Hobart","last_name":"Bigelow","title":"Governor","middle_name":"Baldwin","married_names":[],"photo_url":"https://www.nga.org/wp-content/uploads/2018/01/Hobart_Baldwin_Bigelow_Connecticut_Governor-2.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST040"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"hobart-bigelow-1834"},"H00366":{"id":"H00366","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD0416","mother_id":"I00145"},"tags":["yale_graduate","revolutionary_war","politician","episcopal","extraordinary_longevity"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 366"}],"birth":{"year":1730,"month":9,"day":13,"city":"North Haven"