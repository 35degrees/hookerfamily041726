y lightning while seated on one bench in a sabbath-day-house. Three horses and a colt were killed instantly; all six humans survived."},{"number":4,"category":"military","header":"Captain in the Connecticut Militia, served the Revolution","body":"He was commissioned first lieutenant of the Ninth Company, Second Regiment Connecticut Militia in 1760, and captain in 1764. His gravestone confirms he served in the Revolution."}],"education":[{"school_name":"Yale College","dates":"1751","type":"college"}],"career":[{"role":"Farmer and general trader","location":"North Haven"},{"role":"Representative","organization":"Connecticut General Assembly"},{"role":"Parish Clerk","organization":"St. John’s Church","notes":"59 years"}],"slug":"joseph-pierpont-1730"},"X00456":{"id":"X00456","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1736},"death":{"year":1783},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00366","date_year":1756,"date_month":10,"date_day":21,"children_ids":["H00872","H00873","H00874","H00875","H00876","H00877"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Lydia Bassett","first_name":"Lydia","maiden_name":"Bassett","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"lydia-bassett-1736"},"HD0416":{"id":"HD0416","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":fal