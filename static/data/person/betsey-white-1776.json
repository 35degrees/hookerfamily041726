,"bio":{"display_name":"Almira Cadwell Ransom","first_name":"Almira","last_name":"Ransom","maiden_name":"Cadwell","married_names":["Ransom"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"almira-ransom-1805"},"X00912":{"id":"X00912","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["governor"],"sources":[{"short":"EH 1909; FamilySearch"}],"birth":{"year":1798},"death":{"year":1859,"month":11,"day":11,"city":"Fort Scott","state":"Kansas"},"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"7th Governor of Michigan; Michigan Supreme Court justice","primary_url":"https://en.wikipedia.org/wiki/Epaphroditus_Ransom","primary_url_label":"Wikipedia"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2682","children_ids":["HD2683","HD2684","HD2824","HD2825"],"date_year":1827,"date_month":2,"date_day":21,"location_city":"Montpelier","location_state":"Vermont"}],"parents":{},"narrative_blocks":[{"header":"Shielded Potawatomi from removal, 1840","detail":"During his governorship the first telegraph line from New York to Detroit was completed (March 1, 1849). Two significant immigrations occurred: Dutch settlers under Rev. Van Raalte founded Holland, Michigan and established Hope College; and James Jesse Strang led a faction of Mormon followers to Beaver Island, where Strang founded a short-lived kingdom before his assassination. Ransom's strong anti-slavery position cost him renomination by the state Democratic Party in 1850. He was elected again to the state legislature in 1853 and 1854. (Wikipedia)","body":"Epaphroditus Ransom served as Michigan Supreme Court justice from 1837, including as chief justice 1843-1848. In 1840 he issued a ruling preventing the removal of the Catholic Potawatomi from their lands in southwestern Michigan. Elected governor in 1848, he was the first inaugurated in Lansing after the capital moved from Detroit.","number":1},{"header":"Died in Kansas, private fortune ruined","detail":"The Panic of 1855 destroyed his private business ventures. In 1857 President Buchanan appointed him receiver of public monies for the Osage Land Office in Fort Scott, Kansas. He died there in 1859 at 61, buried at Mountain Home Cemetery in Kalamazoo. His wife Almira Cadwell (HD2682) was a 7th-generation descendant of Rev. Thomas Hooker through the Cadwell family. His father Major Ezekiel Ransom was present at the execution of Major John André during the Revolutionary War — the spy whose capture unraveled Benedict Arnold's treason. (Wikipedia; research notes)","body":"Ransom was the first president of the Michigan Agricultural Society, directly instrumental in establishing both the Michigan State Fair and Michigan State University. He served as regent of the University of Michigan 1850-1852 and co-founded the village of Augusta, Michigan.","number":2}],"cross_connections":[{"type":"civic_connection","display_label":"oversaw the André execution Ransom's father witnessed","related_id":"H00757","link_text":"Maj. Benjamin Tallmadge Jr."}],"bio":{"display_name":"Epaphroditus Ransom","first_name":"Epaphroditus","last_name":"Ransom","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/f/ff/Epaphroditus_Ransom_1.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"epaphroditus-ransom-1798"},"HD2683":{"id":"HD2683","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00912","mother_id":"HD2682"},"tags":["military","civil_war"],"sources":[{"short":"EH 1909; FamilySearch"}],"birth":{"year":1828,"month":4,"day":28,"city":"Townshend","county":"Windham County","state":"Vermont","country":"United States"},"death":{"year":1908,"month":2},"marriages":[{"spouse_id":"X00913","children_ids":["HD2690","HD2688","HD2697","HD2698","HD2699","HD2700","HD2701","HD2826"],"marriage_number":1,"date_year":1853,"date_month":3,"date_day":5,"location_city":"Kalamazoo","location_state":"Michigan"}],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Board of Education 1873"},"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Wyllys Cadwell Ransom","first_name":"Wyllys","last_name":"Ransom","middle_name":"Cadwell","married_names":[],"photo_url":"https://www.wikitree.com/photo.php/4/49/Ransom-1023.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"danger","header":"Survived nine bullets through hat and clothing","body":"Two weeks after he repelled a Confederate band attempting to free prisoners at Independence MO, five mounted armed rebels attacked him on Kansas City streets. In the hand-to-hand fight 'nine balls' went 'through his hat and clothing that did not strike his person'; he shot one attacker before falling seriously wounded himself."},{"number":2,"category":"military","header":"Pursued Quantrill after the Lawrence massacre","body":"He was present in the aftermath of Quantrill's August 1863 raid on Lawrence Kansas — where 150 unarmed men and boys were murdered — and participated in the pursuit of the Confederate guerrillas across the Kansas-Missouri border."},{"number":3,"category":"military","header":"Daily skirmishes with Quantrill in 1862 Missouri","body":"Commanding the 6th Kansas Cavalry as senior Major, he held Confederate guerrillas in western Missouri at bay through 1862 — daily skirmishes with William Quantrill, George Todd, Dick Yeager, and Parker. The summer was 'almost daily fights' per his 1903 family memoir."},{"number":4,"category":"family","header":"Secretary to his Michigan-governor father, 1849","body":"His father Epaphroditus Ransom served as Governor of Michigan; the son served as his personal secretary 1849. The family had emigrated from Vermont to Michigan in October 1834 when Wyllys was six."}],"slug":"wyllys-ransom-1828"},"HD2684":{"id":"HD2684","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00912","mother_id":"HD2682"},"tags":[],"sources":[{"short":"FamilySearch; genealogy records"}],"birth":{"year":1832,"month":10},"death":{"year":1909,"month":5},"marriages":[{"spouse_id":"X00914","children_ids":["HD2685"],"marriage_number":1,"date_year":1854,"date_month":4,"date_day":6,"location_city":"Kalamazoo","location_state":"Michigan"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Antoinette Eugenia Ransom","first_name":"Antoinette","middle_name":"Eugenia","maiden_name":"Ransom","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"antoinette-ransom-1832"},"HD2824":{"id":"HD2824","has_descendants_documented":false,"is_placeholder":false,"gender":"female","classification":{"include_in_path_calculation":false,"generation_from_thomas":9,"descent_f