{"person":{"id":"H00151","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1737,"month":5,"day":15},"death":{"year":1816,"month":12,"day":10,"city":"Greenfield","state":"Massachusetts"},"parents":{"father_id":"HD0007","mother_id":"I00026"},"tags":["durham_newton","greenfield_newton","minister","yale_graduate","slaveholder","author","diarist","moral_complexity"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 151"},{"short":"Caroline Gaylord Newton 1914"},{"label":"Willard's History of Greenfield","url":"https://archive.org/details/willardshistoryo02will/page/121/mode/1up?q=Newton"}],"marriages":[{"children_ids":["HD3316","HD3317","HD3318","HD3319","HD3320","HD3321","HD3322","HD3323"],"spouse_id":"X01018","marriage_number":1,"date_year":1762,"date_month":8,"date_day":26}],"ministry_positions":[{"role":"Pastor","church":"First Congregational Church","location":"Greenfield, Massachusetts","dates":"1761-1816","duration_years":55,"notes":"Ordained November 13, 1761. \"Resided at Greenfield, where he was pastor of church for 53 years\" per EH (actual span closer to 55 years, 1761-1816)."}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"family_connection","related_id":"H00018","display_label":"She left him a £30 Yale bequest he fulfilled in 1758","link_text":"Alice Newton Buckingham"}],"education":[{"degree":"graduate","school_name":"Yale College","graduation_year":1758,"institution_id":"INST022"}],"bio":{"display_name":"Rev. Roger Newton","title":"Reverend","first_name":"Roger","last_name":"Newton","married_names":[],"bio_blurb":"First minister of Greenfield, Massachusetts"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1758"},{"institution_id":"INST058"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"religion","header":"Yale 1758 — Greenfield Massachusetts pastor 56 years","body":"He graduated Yale in 1758 and was ordained at the First Church in Greenfield, Massachusetts on November 18, 1761. He served Greenfield for fifty-six years until his death in December 1816."},{"number":2,"category":"family","header":"Aunt's £30 bequest set the ministry in motion","body":"His aunt Alice Newton Buckingham left him £30 for college if he proved 'likely for public service' — he was barely three years old when she made the bequest. He graduated Yale eighteen years later and fulfilled her hope."},{"number":3,"category":"character","header":"Town stayed a single parish all 56 years","body":"He accepted Greenfield's call on the condition that all persons of 'competent knowledge and sober lives' be permitted communion, avoiding doctrinal narrowness. The entire town remained united in a single parish throughout his ministry — an unusual achievement in the fractious colonial church landscape."},{"number":4,"category":"social_reform","header":"Baptized an enslaved girl called Tinner in 1767","body":"In his record of baptisms for September 20, 1767, he noted 'Tinner, my negro girl' — an enslaved person in his household. This stands in tension with his liberal communion policy and the harmony of his ministry."},{"number":5,"category":"death","header":"Diary: 'I would not live always'","body":"On May 23, 1812 he wrote in his diary: 'I shall not and I would not live always.' He died four years later in December 1816, in his eightieth year, having outlived his wife by eleven years."}],"slug":"roger-newton-1737"},"neighborhood":{"focus":{"id":"H00151","slug":"roger-newton-1737","n":"Rev. Roger Newton","by":1737,"dy":1816,"sx":"m","hd":true,"td":false,"ee"