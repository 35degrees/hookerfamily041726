"type":"civic_connection","related_id":"H00288","display_label":"Both on the Farmington Library founding committee; Hooker a borrower.","link_text":"Col. Noadiah Hooker"}],"gender":"male","parents":{"father_name":"Jonathan Bull","mother_name":"Abigail Bull","father_research_notes":"Jonathan Bull of Farmington CT (EH entry 300)"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00300","date_year":1768,"date_month":11,"date_day":9,"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1820,"children_ids":["H00682","H00683"]}],"notable":{"is_notable":true,"notable_category":["art"],"notable_blurb":"Goldsmith, engraver, Farmington civic leader","primary_url":"https://fhs-ct.org/?p=228","primary_url_label":"Farmington Historical Society"},"narrative_blocks":[{"category":"marriage","header":"Two siblings married two siblings — one ceremony","body":"On November 9, 1768 in Farmington, Cyprian Strong married Sarah Bull, and his sister Elizabeth Strong married Sarah's brother Martin Bull — both weddings on the same day. Two Strong siblings and two Bull siblings, bound together in a single ceremony.","number":1},{"number":2,"category":"career","header":"He engraved Farmington's Monthly Library bookplates","body":"A goldsmith, silversmith (silver spoons and buttons), and gunpowder manufacturer, Martin Bull also served as church deacon, conductor of church music, Probate Clerk of Farmington for 39 years, and Town Treasurer for 8. As an engraver he designed the Farmington Monthly Library bookplate around 1801 — described as 'one of the more memorable American bookplates of the early Federal period.'"},{"number":3,"category":"military","header":"Among 70 Farmington men pledged at Ticonderoga, 1776","body":"Before the Revolution formally began, he was among 70 Farmington signers of an agreement to march to Boston to assist besieged countrymen if needed. He later manufactured saltpetre for the Continental Army."}],"bio":{"display_name":"Deacon Martin Bull","first_name":"Martin","last_name":"Bull","title":"Deacon","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"martin-bull-1744"},"H00300":{"id":"H00300","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1746,"month":11,"day":3,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1820,"month":4,"day":19,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"I00055","mother_id":"H00103"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 300"},{"short":"Julius Gay, Historical Pamphlets (Farmington 1890-1911)","url":"https://archive.org/details/historicalpamphl00gayj/page/n47/mode/2up"}],"burial":{"cemetery_id":"CEM004","plot_notes":"Buried with husband Martin Bull."},"marriages":[{"marriage_number":1,"spouse_id":"X00152","date_year":1768,"date_month":11,"date_day":9,"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1820,"children_ids":["H00682","H00683"]}],"cross_connections":[],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"category":"marriage","header":"Two siblings married two siblings — one ceremony","body":"On November 9, 1768 in Farmington, Cyprian Strong married Sarah Bull, and his sister Elizabeth Strong married Sarah's brother Martin Bull — both weddings on the same day. Two Strong siblings and two Bull siblings, bound together in a single ceremony.","number":1}],"bio":{"display_name":"Elizabeth Strong Bull","first_name":"Elizabeth","last_name":"Bull","maiden_name":"Strong","married_names":["Bull"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elizabeth-bull-1746"},"I00055":{"id":"I00055","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1702,"month":10,"day":8,"city":"Farmington","state":"Connecticut"},"death":{"year":1751,"month":3,"day":30,"city":"Farmington","state":"Connecticut"},"parents":{"mother_research_notes":"Margaret Hart — daughter of Capt. Thomas Hart (X00031), son of Stephen Hart (X00034)","father_research_notes":"Asahel Strong Sr. (b. Nov 14, 1668 Northampton MA) — married Margaret Hart, daughter of Capt. Thomas Hart (X00031)"},"marriages":[{"spouse_id":"H00103","children_ids":["H00293","H00294","H00295","H00296","H00297","H00298","H00299","H00300"],"marriage_number":1,"date_year":1729,"date_month":1,"date_day":8}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 103"}],"gender":"male","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[],"notable_blurb":null,"primary_url":null,"primary_url_label":null},"cross_connections":[{"type":"parallel_descent","related_id":"I00900","display_label":"Both Strong men who married Hooker descendants, 84 years apart","link_text":"Judge Elisha Beebe Strong"}],"bio":{"title":"Captain","display_name":"Captain Asahel Strong Jr.","first_name":"Asahel","last_name":"Strong","suffix":"Jr.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"His Hooker marriage echoed down two more generations","body":"When Captain Asahel Strong Jr. married Sarah Hooker in 1729 at Farmington, Connecticut — a great-great-granddaughter of Rev. Thomas Hooker — he began a pattern that would echo through generations: their great-great-grandson Asahel Hooker Strong was born in 1776 with 'Hooker' preserved as his middle name, and 84 years after the first marriage, Judge Elisha Beebe Strong married another Thomas Hooker descendant, Dolly Goodwin Hooker, at Canandaigua, New York in 1813. By 1866, that second union had produced Beebe Hooker Strong of Milwaukee, the fourth person in the Strong family to carry the Hooker name — connecting the original Farmington parsonage to the Wisconsin frontier across 137 years."}],"slug":"asahel-strong-jr-1702"},"H00103":{"id":"H00103","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1708,"month":4,"day":16,"city":"Farmington","state":"Connecticut"},"death":{"year":1777,"month":9,"day":18,"city":"Farmington","state":"Connecticut"},"parents":{"father_id":"H00030","mother_id":"I00031"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 103"},{"short":"Native Northeast Portal","url":"https://www.nativenortheastportal.com/bio/bibliography/hooker-ruth-1708-1777"}],"marriages":[{"spouse_id":"I00055","children_ids":["H00293","H00294","H00295","H00296","H00297","H00298","H00299","H00300"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1751,"date_year":1729,"date_month":1,"date_day":8},{"children_ids":[],"spouse_id":"I00134","marriage_number":2,"date_year":1772,"date_month":11,"date_day":19}],"cross_connections":[{"type":"parallel_descent","related_id":"H00795","display_label":"Hooker women who married Strongs in 1729 and 1813","link_text":"Dolly Goodwin Hooker"}],"gender":"female","narrative_blocks":[{"number":1,"category":"family","header":"Eight children with Capt. Asahel Strong Jr.","body":"She married Capt. Asahel Strong Jr. on January 8, 1729 and bore him eight children — including Rev. Cyprian Strong of Chatham. Asahel was a grandson of Stephen Hart through his mother Margaret Hart, closing another loop in the Hart-Hooker network."},{"number":2,"category":"death","header":"Lost three children in September 1736","body":"In a single ten-day span — September 6 to 15, 1736 — three of her young children died: Lois and Ruth on the same day, then Elnathan nine days later. The cluster strongly suggests an epidemic moving through Farmington."},{"number":3,"category":"marriage","header":"Second husband Solomon Whitman lived to 93","body":"After Capt. Asahel Strong's death she married Solomon Whitman, who was Town Clerk at 92 and made a pair of shoes on his 90th birthday. He died at 93 from over-fatigue settling a fence dispute between two brothers."}],"number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Ruth Hooker Whitman","first_name":"Ruth","last_name":"Whitman","maiden_name":"Hooker","married_names":["Strong","Whitman"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ruth-whitman-1708"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}