arks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"She lived to ninety-three","body":"Abigail Smith married Capt. Jacob Purdy and lived to ninety-three, dying in 1839 — among the longest lives of her generation."}],"slug":"abigail-purdy-1746"},"X00121":{"id":"X00121","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1739,"month":10,"day":15,"city":"Westchester County","state":"New York"},"death":{"year":1822,"month":12,"day":20,"city":"White Plains","state":"New York"},"parents":{"father_name":"Samuel Purdy Jr. (1710-1796)","mother_name":"Winifred Griffin"},"marriages":[{"spouse_id":"H00331","children_ids":["H00770","H00771","H00772","H00773","H00774","H00775","H00776","H00777","H00778","H00779"],"marriage_number":1,"spouse_name":"Abigail Smith (Hooker descendant)","date_year":1764,"end_type":"death","end_year":1822}],"prominent_name_reason":"Capt. Jacob G. Purdy — owner of the Jacob Purdy House, White Plains, NY (NRHP 1979). Gen. Washington used the house as Revolutionary War headquarters during the Battle of White Plains (October 1776) and again for two months in 1778. Now headquarters of the White Plains Historical Society.","sources":[{"short":"Wikipedia","notes":"Jacob Purdy House article"}],"political_offices":[{"title":"Captain","jurisdiction":"Westchester County Militia, New York","dates":"1775-1783","notes":"Joined 1775; served until end of Revolution."}],"cross_connections":[{"type":"national_landmark","related_id":"H00331","display_label":"Washington's headquarters during Battle of White Plains, 1776","link_text":"Abigail Smith Purdy","notes":"Capt. Jacob Purdy's house on Battle Avenue, White Plains, served as General Washington's headquarters during the Battle of White Plains (Oct 28, 1776) and again for two months in 1778. The house is now known as the Jacob Purdy House, maintained by the White Plains Historical Society. His wife Abigail Smith Purdy was a great-great-great-grandchild of Rev. Thomas Hooker — making this a Hooker-descendant-owned Washington headquarters."}],"gender":"male","tags":["revolutionary_war"],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["military"],"notable_blurb":"Washington's headquarters during Battle of White Plains","primary_url":"https://en.wikipedia.org/wiki/Jacob_Purdy_House","primary_url_label":"Wikipedia"},"military_service":[{"branch":"Continental Army / Westchester Militia","rank":"Captain","war":"Revolutionary War","start_year":1775,"notes":"Joined Westchester Militia 1775; commissioned Captain by the Battle of White Plains (Oct 28, 1776). DAR Patriot Ancestor #A125030. His brother Gabriel Purdy was a Loyalist, fighting for the British in DeLancey's Corps."}],"bio":{"title":"Captain","display_name":"Captain Jacob G Purdy","first_name":"Jacob","last_name":"Purdy","middle_name":"G","married_names":[],"gender":"male"},"residence":{"city":"White Plains","county":"Westchester","state":"New York","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"burial":{"plot_notes":"Burial location not yet recorded."},"narrative_blocks":[{"number":1,"category":"military","header":"Washington headquartered in his house, twice during war","body":"His house on Battle Avenue, White Plains, served as General Washington's headquarters during the Battle of White Plains (Oct 28, 1776) and again for two months in 1778. The house — known today as the Jacob Purdy House and maintained by the White Plains Historical Society — stands on what was the path of the Continental Army's retreat after the battle. He was an active Westchester militia captain, not a passive landlord."},{"number":2,"category":"family","header":"Loyalist brother fled to Nova Scotia after war","body":"His brother Gabriel Purdy fought for the British in DeLancey's Corps and was expelled to Nova Scotia after the Revolution. The two brothers were on opposite sides of the war across the White Plains battlefield. They never reconciled — and the Purdy family was permanently divided by the Revolution."},{"number":3,"category":"family","header":"Loyalist branch grew larger than the Patriot branch","body":"Gabriel Purdy died in Nova Scotia leaving seventeen children, one hundred seventy grandchildren, and fifty-two great-great-grandchildren — a Loyalist descent now numerically larger than the Patriot Purdys in North America. Jacob himself was a DAR Patriot Ancestor (#A125030). The genealogical irony: the family that chose the losing side multiplied faster than the family that chose the winning one."}],"slug":"jacob-purdy-1739"},"H00770":{"id":"H00770","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1765},"parents":{"father_id":"X00121","mother_id":"H00331"},"tags":[],"sources":[{"short":"Edward Hooker 1909","entry":"770"}],"gender":"unknown","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"death":{},"cross_connections":[],"bio":{"display_name":"Levinah Purdy","first_name":"Levinah","last_name":"Purdy","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"levinah-purdy-1765"},"H00771":{"id":"H00771","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott