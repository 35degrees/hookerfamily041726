egory":"family","header":"Died at Peru New York after Connecticut marriage","body":"She married Miles Leete at Guilford Connecticut about 1791, but died at Peru in upstate New York on 20 February 1827 at age fifty-seven. The migration from coastal Connecticut to the Adirondack-frontier town of Peru tracked a common New England migration route via the Champlain Valley."},{"number":3,"category":"legacy","header":"Youngest daughter Elizabeth lived to ninety-four","body":"Her last child Elizabeth Leete was born in 1811 and lived to ninety-four in 1905 — a span of nearly a century from the early Republic to the dawn of the twentieth century. The mother died less than two decades after Elizabeth's birth, in 1827."}],"slug":"elizabeth-leete-1769"},"X00130":{"id":"X00130","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1757},"death":{"year":1836,"month":7,"day":24,"city":"Peru","state":"New York"},"parents":{"grandfather_notes":"William Leete — Governor of Connecticut Colony 1676-1683","mother_id":"H00416","father_research_notes":"Roland Leete","father_id":"X00207"},"marriages":[{"spouse_id":"HD0437","children_ids":["HD0438","HD0439"],"marriage_number":1}],"sources":[],"gender":"male","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Miles Leete","first_name":"Miles","last_name":"Leete","married_names":[],"bio_blurb":"Governor Leete’s descendant who married a Hooker line"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"His family and the Hookers shared a governor","body":"He descended from Governor William Leete of Connecticut, whose daughter Me