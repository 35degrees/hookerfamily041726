mont Law School Dean","primary_url":"https://en.wikipedia.org/wiki/Thomas_M._Debevoise","primary_url_label":"Wikipedia"},"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Thomas M. Debevoise 2d","first_name":"Thomas","last_name":"Debevoise","middle_name":"McElrath","married_names":[],"suffix":"2d","gender":"male"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"undergraduate_alumnus","years":"1946-1950","institution_blurb":"Yale College B.A. 1950."}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"education":[{"institution_id":"INST022","school_name":"Yale University","dates":"1946-1950","type":"undergraduate","degree":"B.A."},{"school_name":"Columbia Law School","dates":"1951-1954","type":"graduate","degree":"J.D."}],"career":[{"role":"Assistant United States Attorney","organization":"Southern District of New York","location":"Manhattan, New York","start_year":1954,"end_year":1956,"notes":"Assisted James B. Donovan in the defense of Soviet spy Rudolf Abel — the case Donovan later used as leverage in the 1962 prisoner swap returning U-2 pilot Francis Gary Powers."},{"role":"Private practice attorney","organization":"Independent practice","location":"Woodstock, Vermont","start_year":1957,"end_year":1958},{"role":"Deputy Attorney General","organization":"State of Vermont","location":"Montpelier, Vermont","start_year":1959,"end_year":1960,"notes":"Appointed January 1959; served until promoted to Attorney General February 1960."},{"role":"Attorney General","organization":"State of Vermont","location":"Montpelier, Vermont","start_year":1960,"end_year":1962,"notes":"Appointed Feb 2, 1960 by Gov. Robert Stafford to fill vacancy of Frederick M. Reed; won full term Nov 1960 as Republican; resigned Jan 1, 1962. Succeeded by Charles J. Adams."},{"role":"Assistant General Counsel","organization":"Federal Power Commission","location":"Washington, D.C.","start_year":1962,"end_year":1964},{"role":"Founding Partner","organization":"Debevoise & Liberman","location":"New York City and Washington, D.C.","start_year":1965,"notes":"Distinct from his father's Debevoise & Plimpton."},{"role":"Trustee Board President / Dean / Dean Emeritus","organization":"Vermont Law School","location":"South Royalton, Vermont","start_year":1973,"end_year":1995,"notes":"Trustee board president 1973-1974; Dean 1974-1982 (founding-era leadership of the school established in 1972); Dean Emeritus 1982-1995; trustee emeritus 1983-1995. Honorary Doctor of Laws 1984. Debevoise Hall on the VLS campus (renovated 2005) was named for him and his wife Ann."},{"role":"President","organization":"Woodstock Foundation","location":"Woodstock, Vermont","start_year":1982,"end_year":1995,"notes":"Foundation established by Laurance Rockefeller and Mary French Rockefeller to promote conservation and sustainable land use."}],"narrative_blocks":[{"number":1,"category":"law","header":"Helped defend Soviet spy Rudolf Abel","body":"As a young Assistant U.S. Attorney for the Southern District of New York 1954-1956, he assisted James B. Donovan in the court-appointed defense of accused Soviet spy Col. Rudolf Abel. Donovan later used the case as leverage in the 1962 prisoner swap that returned downed U-2 pilot Francis Gary Powers in exchange for Abel's release."},{"number":2,"category":"politics","header":"Appointed Vermont Attorney General at thirty","body":"After moving to Woodstock in 1956 and serving as Deputy Attorney General from 1959, he was appointed Vermont Attorney General in February 1960 by Governor Robert Stafford to fill a vacancy. He won a full term as a Republican that November and served until resigning in January 1962."},{"number":3,"category":"education","header":"Founding-era Dean of Vermont Law School","body":"He served as Dean of the Vermont Law School from 1974 to 1982, leading the institution through its formative first decade after its 1972 founding. Vermont Law School awarded him an honorary Doctor of Laws in 1984; Debevoise Hall on the South Royalton campus, renovated in 2005, was named for him and his wife Ann."},{"number":4,"category":"social_reform","header":"Led the Rockefellers' Woodstock Foundation thirteen years","body":"From 1982 until his death in 1995 he served as president of the Woodstock Foundation, established by Laurance Rockefeller and Mary French Rockefeller to promote conservation and sustainable land use. He had moved to Woodstock in 1956 and made it his home for the rest of his life."},{"number":5,"category":"death","header":"Lung cancer at sixty-five at Dartmouth-Hitchcock","body":"He died February 1, 1995 at the Dartmouth-Hitchcock Medical Center in Lebanon, New Hampshire of complications from surgery for lung cancer. He was survived by his wife Ann, his sister Elizabeth Debevoise Healy of Manhattan, four children, and eight grandchildren."}],"slug":"thomas-debevoise-1929"},"HD3373":{"id":"HD3373","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Thomas","last_name":"Debevoise","suffix":"III","married_names":[],"gender":"male","display_name":"Thomas Debevoise 3rd"},"birth":{},"baptism":{},"death":{},"residence":{"city":"South Woodstock","county":"Windsor","state":"Vermont","country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":12,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD2153","mother_id":"X00688"},"gender":"male","marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["living_or_recent"],"research_tags":[],"cross_co