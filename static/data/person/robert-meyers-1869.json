:false,"is_progenitor":false,"is_easter_egg":false},"parents":{"father_id":"X00389","mother_id":"H00828"},"tags":["physician","yale_graduate"],"sources":[{"short":"Hyde Genealogy by Reuben H. Walworth, p.300-301","url":"https://www.google.com/books/edition/Hyde_Genealogy/rIKhN5aMelcC"},{"short":"Find a Grave — Evergreen Cemetery New Haven CT","url":"https://www.findagrave.com/cemetery/103328/evergreen-cemetery"},{"short":"WikiTree (online genealogy)","url":"https://www.wikitree.com/"}],"birth":{"year":1818,"month":3,"day":14,"city":"Bethlehem","county":"Litchfield","state":"Connecticut","country":"United States"},"death":{"year":1874,"month":7,"day":31,"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States"},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00375","date_year":1841,"date_month":12,"date_day":21,"location_country":"United States","end_type":"death","end_year":1874,"children_ids":["HD3657","HD3658","HD3659","HD3660"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Doctor Timothy Langdon","first_name":"Timothy","last_name":"Langdon","title":"Doctor","married_names":[],"gender":"male"},"residence":{"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[{"name_element":"Timothy","description":"Named for his paternal grandfather Rev. Timothy Langdon (1758-1801) of Danbury CT, who died seventeen years before his namesake's birth."},{"name_element":"Timothy","inspired_by_name":"Rev. Timothy Langdon (paternal grandfather, not in tree)","description":"First name 'Timothy' honors paternal grandfather Rev. Timothy Langdon."}],"institutions":[{"institution_id":"INST022","institution_blurb":"Yale Medical School Class of 1841. Third-generation Hooker descendant in the Yale ecosystem (after his maternal grandfather James Pierpont III H00353 and great-grandfather Rev. James Pierpont — Yale founder)."},{"institution_id":"INST122"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"education":[{"institution":"Yale Medical School","degree":"M.D.","year_completed":1841,"field":"Medicine","notes":"Graduated Yale Medical School 1841."}],"career":[{"title":"Physician","dates":"1841-1874","type":"medicine","notes":"Practiced medicine. Engaged in practice at Naugatuck Connecticut from 1841 until 1867, when he removed to New Haven. Died in New Haven July 31, 1874."}],"burial":{"cemetery_id":"CEM265","plot_notes":"Find a Grave memorial 147387591"},"narrative_blocks":[{"number":1,"category":"family","header":"Orphaned at twelve, raised by aunt-turned-stepmother","body":"Timothy Langdon lost his mother Elizabeth Pierpont Langdon at age seven in 1825 and his father Rev. John Langdon at age twelve in 1830. He was raised by his stepmother Abby Pierpont Church — who was simultaneously his maternal aunt, having married his father Rev. John Langdon as his second wife in December 1824, while Timothy's mother Elizabeth was still alive. The wife-then-sister marriage pattern was uncommon but documented in Litchfield-area Congregational families."},{"number":2,"category":"death","header":"Daughter Julia died twenty-one days after his death","body":"Timothy Langdon died July 31, 1874 in New Haven at age fifty-six. His twenty-four-year-old daughter Julia Pierpont Langdon died August 21, 1874 — twenty-one days after her father's death. Two of Timothy's other three children had also died young (Willie at five in 1848; William Harley at five in 1856), leaving only daughter Caroline Elizabeth Meyers to survive both her father and her sister."},{"number":3,"category":"career","header":"Yale Medical 1841, twenty-six years Naugatuck practice","body":"Timothy Langdon graduated Yale Medical School in 1841 and married Mary Ann Morse on December 21 the same year — a Yale-Medical-graduation-to-marriage compression characteristic of nineteenth-century mid-Connecticut physician families. He practiced medicine at Naugatuck Connecticut from 1841 until 1867 — twenty-six years — before removing to New Haven in 1867. He is buried at Evergreen Cemetery, New Haven Connecticut."},{"number":4,"category":"family","header":"Born Bethlehem CT 1818, named for grandfather","body":"Timothy Langdon was born March 14, 1818 in Bethlehem, Litchfield County Connecticut, the eldest child of Elizabeth Pierpont Langdon and Rev. John Langdon. He was named for his paternal grandfather Rev. Timothy Langdon. His full name carried both his grandfather's first name and the Pierpont-Hooker line through his mother — the dual-honor naming pattern was standard in early-Republic Litchfield Hill families."}],"slug":"timothy-langdon-1818"},"I00375":{"id":"I00375","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Mary","middle_name":"Ann","last_name":"Langdon","maiden_name":"Morse","married_names":["Langdon"],"gender":"female","display_name":"Mary Ann Morse Langdon"},"birth":{"year":1818,"country":"United States"},"baptism":{},"death":{"year":1891,"country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Harley Morse","mother_name":"Susan Hall Morse","father_research_notes":"Harley Morse (not built per Jalapeño).","mother_research_notes":"Susan Hall Morse (not built per Jalapeño)."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1248","date_year":1841,"date_month":12,"date_day":21,"location_country":"United States","end_type":"death_of_spouse","end_year":1874,"chil