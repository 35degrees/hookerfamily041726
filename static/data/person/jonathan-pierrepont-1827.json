"location_city":"New Haven","location_state":"Connecticut","location_country":"United States","marriage_year":1814}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Rev. Hezekiah Beers Pierpont","first_name":"Hezekiah","last_name":"Pierpont","title":"Reverend","middle_name":"Beers","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Pastor","organization":"Hopewell Presbyterian Church","location":"Hopewell, Ontario County, New York","notes":"Pastorate after move to Rochester area in 1821; 'several years' per Pierpont family book."},{"role":"Pastor","organization":"Avon Presbyterian Church","location":"Avon, Livingston County, New York","notes":"Later pastorate in Avon — site of the family burial ground (LittleVille Cemetery)."}],"narrative_blocks":[{"number":1,"category":"religion","header":"Reverted name spelling to ancestral Pierrepont","body":"Hezekiah Beers consciously restored the older spelling 'Pierrepont' to the family name, undoing the simplified 'Pierpont' his immediate American forebears had adopted. The change held in his Rochester branch — his son Jonathan Edwards Pierrepont and granddaughter Caroline Editha Pierrepont (later Ward) carry the Reverend's preferred spelling forward."},{"number":2,"category":"family","header":"Would have inherited the lost English titles","body":"Per family tradition, when Hezekiah's older brother Evelyn died at sea off Norway in 1812 unmarried, Hezekiah became the head of the American branch — and would have inherited the disputed English Pierrepont titles and estates had the family's claim to them ever been recognized. The Pierrepont book treats this with appropriate skepticism."}],"slug":"hezekiah-pierpont-1792"},"X00328":{"id":"X00328","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"Pierpont genealogy / online vital records"}],"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00813","date_year":1814,"date_month":5,"date_day":29,"location_city":"New Haven","location_state":"Connecticut","location_country":"United States","children_ids":["HD1088","HD1089","HD1090","HD1091","HD1092","HD1093","HD1094"],"marriage_year":1814}],"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1789,"country":"United States"},"death":{"year":1860,"month":12,"day":11,"city":"Avon","state":"New York","country":"United States"},"cross_connections":[],"bio":{"display_name":"Mary Malloy","has_discrepancy":true,"discrepancy_note":"EH 1909 spells \"Mulloy\"; corrected to \"Malloy\" — standard Irish surname, almost certainly an EH transcription error.","first_name":"Mary","maiden_name":"Malloy","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-malloy-1789"},"H00351":{"id":"H00351","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1755,"month":3,"day":16,"city":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1808,"month":2,"day":7,"city":"New Haven","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00116","mother_id":"I00143"},"tags":["not_yet_fully_entered","revolutionary_war","yale_graduate"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 351"}],"burial":{"plot_notes":"Fair Haven Union Cemetery, New Haven CT. GPS: 41.31140, -72.89440.","cemetery_id":"CEM101"},"marriages":[{"spouse_id":"X00324","children_ids":["H00809","H00810","H00811","H00812","H00813","H00814","H00815","H00816","H00817","H00818","H00819","X00355"],"marriage_number":1,"date_year":1780,"date_month":3,"location_country":"United States"}],"cross_connections":[{"type":"military","related_id":"H00288","display_label":"Friend-compatriots in the Revolutionary War.","link_text":"Col. Noadiah Hooker"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"legacy","header":"Parliament refused to make him Duke because he","body":"His descent from the Dukes of Kingston was formally established — but Parliament refused to recognize the claim because he was American. After the Revolution he became financially reduced and spent his final years working for wages at Yale, the institution his own family had helped found."},{"number":2,"category":"marriage","header":"Three brothers snowbound — three sisters married","body":"Three Pierpont brothers journeying through Litchfield County stopped overnight at the Collins home in South Farms when a great storm stranded them for weeks. All three married daughters of the family: Robert married Lois Collins, his brother Evelyn married her sister Rhoda, and their brother James married a third sister."},{"number":3,"category":"career","header":"Yale alumnus turned Yale College employee","body":"Evelyn was a Revolutionary War officer and a Yale College graduate who settled as a farmer at Litchfield Connecticut after the war. Reduced in circumstances late in life, he returned to Yale — not as alumnus but as employee — and continued in such service until his death."}],"bio":{"display_name":"Lt. Evelyn Pierpont","first_name":"Evelyn","last_name":"Pierpont","title":"Lieutenant","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"evelyn-pierpont-1755"},"X00324":{"id":"X00324","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1764,"month":10,"day":5,"city":"Litchfield","county":"Litchfield","state":"Connecticut","country":"United States"},"death":{"year":1845,"month":6,"day":20,"city":"Livonia","county":"Livingston","state":"New York","country":"United States"},"gender":"female","parents":{"father_id":"X02136","mother_id":"X02137"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00351","children_ids":["H00809","H00810","H00811","H00812","H00813","H00814","H00815","H00816","H00817","H00818","H00819","X00355"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Rhoda Collins Pierpont","first_name":"Rhoda","last_name":"Pierpont","maiden_name":"Collins","married_names":["Pierpont"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"rhoda-collins-1764"}},"burialCemetery":{"id":"CEM170","name":"LittleVille Cemetery","city":"Avon","county":"Livingston","state":"New York","country":"United States","gps":{"lat":42.89516,"lng":-77.76157},"primary_url":"https://www.findagrave.com/cemetery/2195620/littleville-cemetery","hooker_connections":["HD1092","HD1545","X01665"],"notes":"Avon NY cemetery containing the Pierrepont-Ward family burials of the Rochester branch (Jonathan Edwards Pierrepont HD1092, his daughter Caroline Edit