ember of the club — one of the country's oldest, founded 1888."},{"number":3,"category":"death","header":"Heart attack at Shelter Island at fifty-one","body":"Kenneth died suddenly of a heart attack on Shelter Island NY on 2 April 1939, age 51, just over three years into his marriage to Florence McAndrews. He left no children. Buried Ferncliff Cemetery and Mausoleum in Hartsdale NY, away from his Rochester family."}],"cross_connections":[{"type":"parallel_careers","related_id":"HD6587","link_text":"Benjamin Munroe Burr","display_label":"a fellow Guaranty Trust executive and wartime veteran"}],"naming_inspiration":[{"name_element":"Kemp","inspired_by_id":"X01665","description":"Middle name carries his father George Kemp Ward's middle name forward to the next generation."}],"education":[],"career":[{"role":"Junior staff","organization":"Guaranty Trust Company of New York","location":"New York City","notes":"Early-career employment before WWI service."},{"role":"Partner","organization":"Hemphill, Noyes & Co.","location":"15 Broad Street, New York City","start_year":1919,"end_year":1939,"notes":"Joined the investment banking firm at 15 Broad Street upon return from France in 1919; remained partner until his 1939 death."}],"military_service":[{"war":"World War I","war_id":"WAR007","unit":"American Expeditionary Forces (France)","notes":"Served overseas in France during the First World War, after early career employment at Guaranty Trust Company of New York. Returned 1919 and joined Hemphill, Noyes & Co."}],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"kenneth-ward-1887"},"HD1546":{"id":"HD1546","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1861},"death":{"year":1909},"parents":{"father_id":"H