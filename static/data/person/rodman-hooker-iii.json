ther_id":"I00288"},"marriages":[{"marriage_number":1,"spouse_id":"I00331","date_year":1963,"end_type":"death","end_year":2016,"children_ids":["HD3390","HD3391","HD3392"]}],"number_of_marriages":1,"tags":["banker","marine_corps"],"sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"career","header":"Banker across five California institutions","body":"He worked as a banker at United California Bank in Los Angeles, Middendorff Colgate & Co., Seattle First National Bank, Crocker National Bank, First Interstate Bank, and Wells Fargo. After banking he became chairman of Washington Square Associates and Cambridge Park Properties."},{"number":2,"category":"military","header":"Marine Corps service from 1958 to 1961","body":"He served in the United States Marine Corps from 1958 to 1961, between Cate School and his graduation from USC. He kept the 'Pops' nickname from his family throughout his banking career."},{"number":3,"category":"education","header":"USC Man of Troy and Business School president","body":"He was elected President of the USC Business School and received the university's Man of Troy Award. He had prepped at Cate School and Menlo School of Business before USC."},{"number":4,"category":"family","header":"Pebble Beach summers with grandfather 'The Boss'","body":"Rod's youth carried him between San Francisco, Hillsborough, and Indian Wells — but the family centerpiece was Pebble Beach, where his maternal grandfather Samuel F.B. Morse 'The Boss' had built the resort community itself. Summer visits with The Boss, brother Michael, and their mother Nancy Morse Hooker were the formative geography of two Hooker generations across the California coast."}],"cross_connections":[{"type":"naming_pattern","related_id":"X02298","display_label":"Middle name 'Lent' continues his father's tribute to George.","link_text":"George Heydenfeldt Lent"}],"education":[{"institution_id":"INST097","type":"secondary","notes":"Attended in the 1950s under the Cate School name (the school had been The Santa Barbara School in earlier decades)."},{"school_name":"Menlo School of Business","type":"preparatory"},{"institution_id":"INST107","type":"undergraduate","notes":"Later President of USC Business School alumni board; Man of Troy Award recipient."}],"bio":{"first_name":"Rodman","middle_name":"Lent","last_name":"Hooker","married_names":[],"suffix":"Jr.","nickname":"Pops","display_name":"Rodman L. Hooker Jr."},"residence":[],"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"institutions":[{"institution_id":"INST094","relationship":"member","institution_blurb":"Member of San Francisco's oldest private gentlemen's club."},{"institution_id":"INST098","relationship":"member","institution_blurb":"Member of the historic San Francisco Peninsula country club."},{"institution_id":"INST097","relationship":"alumnus"},{"institution_id":"INST107","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"rodman-hooker-jr-1940"},"I00331":{"id":"I00331","is_placeholder":false,"has_descendants_documented":true,"bio":{"display_name":"Juliet Burkett Hooker","first_name":"Juliet","middle_name":"Burkett","last_name":"Hooker","maiden_name":"Burkett","married_names":["Hooker"]},"birth":{"year":1940,"country":"United States"},"death":{"year":2016,"country":"United States","note":"Per LegacyConnect record cited in obituary lookup; year 2016."},"baptism":{},"residence":{},"burial":{},"gender":"female","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{},"marriages":[{"marriage_number":1,"spouse_id":"HD3315","date_year":1963,"location_country":"United States","end_type":"death_of_spouse","end_year":2016,"children_ids":["HD3390","HD3391","HD3392"]}],"number_of_marriages":1,"tags":[],"research_tags":[],"sources":[],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"naming_inspiration":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"juliet-burkett-1940"},"HD3246":{"id":"HD3246","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":true,"generation_from_thomas":10},"bio":{"first_name":"Rodman","middle_name":"Lent","last_name":"Hooker","married_names":[],"gender":"male","display_name":"Rodman Lent Hooker"},"birth":{"year":1909,"state":"California","country":"United States","historical_notes":"Per Tony Hooker pedigree + Sam family knowledge: b.1909 — likely Hillsborough or San Francisco given father Robert Gay's residence pattern"},"death":{"year":1994,"state":"California","country":"United States"},"parents":{"father_id":"H04266","mother_id":"X02253"},"number_of_marriages":3,"marriages":[{"marriage_number":1,"spouse_id":"I00288","date_year":1934,"date_month":7,"location_country":"United States","end_type":"separation","end_year":1940,"children_ids":["HD3315","HD3384"],"notes":"First wife (per WikiTree + 1940 census + family records). Two sons: Michael G. Hooker (Sam Talcott Hooker's father, b.~1936, NOT BUILT per living rule) and Rodman L. Hooker Jr. (HD3315, 1940-2016). Separated post-1940 census; Nancy went on to Walker then Borland. Rodman Lent later remarried."},{"marriage_number":2,"spouse_id":"I00289","date_year":1956,"location_country":"United States","end_type":"death_of_spouse","end_year":1969,"children_ids":[],"notes":"Native of Pasadena; previously married Thomas Bunn of Pebble Beach (3 Bunn children). Died June 1, 1969 at home 761 Chiltern Rd Hillsborough age 54; coroner-investigated unattended death."},{"marriage_number":3,"spouse_id":"I00290","end_type":"death","end_year":1994,"children_ids":[],"notes":"Third wife. Born Harrisburg PA 1925. Three Sollner children from prior marriage. No children with Rodman. Survived him by 14 years; d. Tampa FL Oct 5, 2008 age 83."}],"tags":["california_migration"],"sources":[{"short":"Direct family information from Sam Talcott Hooker (curator)","page":"Sam Hooker confirmed: \"Rodman Lent who was my grandfather\""},{"short":"Sam's father's obituary","page":"'Grandson of Elizabeth Shreve and Robert Gay Hooker of Hillsborough'"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"First name echoes his Shreve grandmother's surname","body":"His mother Elizabeth Lawton Shreve had carried Rodman as a maternal-line name through her own mother Rebecca Rodman Nichols. His uncle George Rodman Shreve, a partner in the Shreve & Co. SF jewelry firm, also carried it forward."},{"number":2,"category":"marriage","header":"Three marriages: Morse, Austin, Sollner","body":"He married Nancy Morse in July 1934 and had two sons Michael and Rodman Jr. before their post-1940 separation. He later married Jane Elise Austin (d. 1969 in Hillsborough) and Louise Henrichsen Sollner (d. 2008 in Tampa)."}],"cross_connections":[{"type":"naming_pattern","related_id":"X02298","display_label":"Middle name 'Lent' honors his father's business partner.","link_text":"George Heydenfeldt Lent"},{"type":"in_law","related_id":"X02345","display_label":"was his father-in-law"}],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"rodman-hooker-1909"},"I00288":{"id":"I00288","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"female","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"birth":{"year":1915,"month":5,"day":13,"city":"San Francisco","county":"San Francisco County","state":"California","country":"United States"},"death":{"year":2005,"month":5,"day":26,"city":"Pebble Beach","county":"Monterey County","state":"California","country":"United States","note":"Last residence Pebble Beach. Buried Lake Forest Cemetery IL Section C, Block 15, Lot 13."},"burial":{},"parents":{"father_id":"X02345","mother_id":"X02346"},"marriages":[{"marriage_number":1,"spouse_id":"HD3246","date_year":1934,"date_month":7,"location_country":"United States","end_type":"separation","end_year":1940,"children_ids":["HD3315","HD3384"],"notes":"Two sons: Michael G. Hooker (Sam Talcott Hooker's father, b.~1936, NOT BUILT per living-person rule) and Rodman L. Hooker Jr. (HD3315, 1940-2016). Per WikiTree: married July 1934. The 1940 census shows them as a couple in Hillsborough San Mateo County with sons Michael (4) and Rodman Jr. (0). Separated some time after the 1940 census; Nancy was with Walker by 1950."},{"marriage_number":2,"spouse_id":"X02349","end_type":"death_of_spouse","end_year":1966,"children_ids":[],"notes":"One daughter Anne Walker (NOT BUILT). Walker had a daughter Martha from prior marriage to Alida Douglas Robinson. Walker d. Apr 8, 1966 Pebble Beach."},{"marriage_number":3,"spouse_id":"X02350","date_year":1967,"date_month":3,"date_day":7,"location_city":"San Francisco","location_state":"California","location_country":"United States","end_type":"death","end_year":2005,"children_ids":[],"notes":"No children with Borland; he had four children from prior marriage. They lived at Pebble Beach from 1972 until her 2005 death."}],"number_of_marriages":3,"tags":[],"sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Daughter of Pebble Beach's founder Samuel Morse","body":"She was born May 13, 1915 in San Francisco to Samuel Finley Brown Morse and Anne Camden Thompson, four years before her father founded Del Monte Properties at Pebble Beach. By the 1920 census her parents had separated and her mother had married Col. George Richardson."},{"number":2,"category":"marriage","header":"Three husbands: Hooker, Walker, Borland","body":"After her 1940-era separation from Rodman Lent Hooker she married New York socialite banker Kenneth Stewart Walker, who died at Pebble Beach in 1966. She then married William Fuller Borland on March 7, 1967 and lived at Pebble Beach until her 2005 death there."},{"number":3,"category":"family","header":"Raised in Lake Forest by stepfather George Richardson","body":"After her parents' 1916 separation she was raised by her mother and stepfather Col. George Adams Richardson in Lake Forest, Illinois from 1920. The family moved to Rancho Santa Fe in the early 1940s where Richardson ran the Rancho Santa Fe Inn."},{"number":4,"category":"family","header":"Three marriages produced a blended California family","body":"Nancy married first Rodman Lent Hooker — sons Michael and Rod Jr. — then Kenneth Stewart Walker, with daughter Anne Walker; and finally William Fuller Borland in 1967, who became stepfather to all three of her Hooker and Walker children. The blended family centered on Pebble Beach, where Nancy's father Samuel F.B. Morse 'The Boss' had built the resort community, and where Borland would chair the AT&T Pro-Am tournament in his retirement years."}],"cross_connections":[],"education":[],"bio":{"first_name":"Nancy","middle_name":"Anne","last_name":"Borland","maiden_name":"Morse","married_names":["Nancy Morse Hooker","Nancy Morse Walker","Nancy Morse Borland"],"display_name":"Nancy Morse Hooker Walker Borland"},"residence":[],"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"nancy-morse-1915"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}