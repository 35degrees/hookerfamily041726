urialCemetery":null,"institutionsById":{"INST139":{"id":"INST139","primary_name":"Litchfield Female Academy","name":"Litchfield Female Academy","alt_names":["Miss Pierce's School"],"type":"academy","founding_year":1792,"location":{"city":"Litchfield","county":"Litchfield County","state":"Connecticut","country":"United States"},"wikipedia_url":"https://en.wikipedia.org/wiki/Litchfield_Female_Academy","primary_persons":[],"hooker_connected_people":["H00828","HD1165"],"person_ids":[],"related_institutions":[],"related_landmarks":[],"tags":[],"sources":[],"notes":"Founded 1792 by Sarah Pierce in Litchfield Connecticut — among the earliest formal secondary schools for women in the United States. The academy operated until 1833, training over 3,000 young women from across the early Republic. Sybil Dudley Austin's daughter Sybil Webb attended in 1818 (X02783 NB#2 references); daughter not yet built as separate entry. Future builds of Sybil Webb Austin and other LFA-attending Hooker descendants should also be wired to this INST."}},"crossConnections":[]}