cian's work and its institutional support, sustained through decades of Montana winters, golf trips to California and Hawaii, and summers at their Whitefish condo. Joanne outlived him by twenty-eight years, dying in Eden Prairie, Minnesota in December 2023 at age ninety-three — one of the most recently deceased members of the Hooker family tree, carrying a genealogical line from Hartford 1636 to Minnesota 2023."}],"quotes":[],"sources":[{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"arthur-northrop-1911"},"I00973":{"id":"I00973","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Joanne","middle_name":"Mary","last_name":"Northrop","maiden_name":"McGinnis","married_names":["Northrop"],"gender":"female","display_name":"Joanne Mary McGinnis Northrop","photo_notes":"Joanne Mary McGinnis Northrop (1930-2023)"},"birth":{"year":1930,"month":11,"day":16,"city":"Fargo","county":"Cass County","state":"North Dakota","country":"United States"},"baptism":{},"death":{"year":2023,"month":12,"day":2,"city":"Eden Prairie","county":"Hennepin County","state":"Minnesota","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM485","plot_notes":"Highland Cemetery Great Falls Montana per FA — buried with husband"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4719","date_year":1955,"location_country":"United States","children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["extraordinary_longevity"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"character","header":"Treasurer of the medical auxiliary; died at ninety-three","body":"Joanne Mary McGinnis Northrop spent decades as treasurer of the Women's Medical Auxiliary for both Cascade County and the Montana State Medical Association, building an institutional life alongside her husband's medical practice in Great Falls while also traveling with him to California and Hawaii for golf and maintaining a condo in Whitefish, Montana for skiing and lake summers. She died in Eden Prairie, Minnesota on December 2, 2023 at age ninety-three — one of the most recently deceased members of the Hooker-line family tree, and among the most long-lived, her Montana and Minnesota years carrying a genealogical thread forward from a nineteenth-century New York City family into the twenty-first century."}],"quotes":[],"sources":[{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"joanne-mcginnis-1930"},"HD4634":{"id":"HD4634","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Eliza","middle_name":"M","last_name":"Northrop","maiden_name":"Mumford","married_names":["Northrop"],"gender":"female","display_name":"Eliza M. Mumford Northrop"},"birth":{"year":1843,"month":8,"day":23,"city":"New York","county":"New York County","state":"New York","country":"United States"},"baptism":{},"death":{"year":1930,"month":12,"day":1,"city":"Detroit","county":"Wayne County","state":"Michigan","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM484","plot_notes":"Woodmere Cemetery Detroit per FA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"generation_from_john_talcott":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_pro