pired_by_id":"X01251","description":"Middle name Mills carries the maternal grandfather's surname — John Easton Mills, the Mayor of Montreal who died of typhus 1847. Naming honors the Mills civic legacy across the Redpath generation."}],"artworks":[],"tags":["canada_migration","british_columbia_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Bonnie Brae summer farm, two marriages, four children","body":"Harold Mills Redpath married Alice Graham Watson in July 1897 and moved with her to 355 Olivier Avenue Westmount; in 1901 he purchased the Merriman farm in Georgetown Quebec and renamed it Bonnie Brae, where the family summered regularly through 1910. He and Alice had four children — Elizabeth Grace, John, Peter Harold, and Hugh — before separating; he later married Marie Adele Prendiville. He died at Saanich near Victoria British Columbia on December 26, 1948 at age seventy-five."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"harold-redpath-1873"},"HD4199":{"id":"HD4199","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Elizabeth","middle_name":"Grace","last_name":"Thompson","maiden_name":"Redpath","married_names":["Thompson"],"nickname":"Betty","gender":"female","display_name":"Elizabeth Grace 'Betty' Redpath Thompson"},"birth":{"year":1898,"month":4,"city":"Westmount (Montreal)","state":"Quebec","country":"Canada"},"baptism":{},"death":{"year":1976,"month":5,"day":23,"state":"Quebec","country":"Canada"},"residence":{},"burial":{"cemetery_id":"CEM328","plot_notes":"Cimetière Mont-Royal Montreal."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_ca