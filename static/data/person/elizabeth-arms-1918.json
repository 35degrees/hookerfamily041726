ppy'","body":"Arms married Betsy Parcells in July 1939 and the marriage lasted until his death at ninety-seven, seventy-three years later — a span longer than most genealogical generations. His family knew him as 'Poppy,' a Pied Piper who shared his passion for sailing, fishing, and lobster pots with children and grandchildren alike."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"charles-arms-1915"},"HD4336":{"id":"HD4336","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"David","middle_name":"Salter","last_name":"Arms","married_names":[],"gender":"male","display_name":"David Salter Arms"},"birth":{"year":1943},"baptism":{},"death":{"year":1999},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":12,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00698","mother_id":"HD4334"},"marriages":[{"children_ids":["HD4337"],"marriage_number":1}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["living_or_recent"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"number_of_marriages":1,"slug":"david-arms-1943"},"HD4337":{"id":"HD4337","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Jonathan","middle_name":"Davenport","last_name":"Arms","married_names":[],"gender":"male","display_name":"Jonathan Davenport Arms"},"birth":{"year":1969,"month":5,"day":19,"city":"Cleveland","county":"Cuyahoga County","state":"Ohio","country":"United States"},"baptism":{},"death":{"year":2008,"month":10,"day":26,"city":"Providence","count