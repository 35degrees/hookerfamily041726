ath_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1673,"month":1,"day":18,"city":"Boston","state":"Massachusetts"},"death":{"year":1763,"month":5,"day":10,"city":"Weymouth","state":"Massachusetts"},"parents":{"father_id":"I00058","mother_id":"H00020"},"marriages":[{"spouse_id":"I00062","children_ids":["HD0068","HD0069","HD0070","HD0071","HD0072","HD0073","HD0074","HD0075","HD0076"],"marriage_number":1,"date_year":1703,"location_city":"Weymouth","location_state":"Massachusetts"},{"marriage_number":2,"spouse_id":"X02995","spouse_name":"Deacon Samuel White","date_year":1725,"children_ids":[]}],"cross_connections":[{"type":"parallel_descent","related_id":"I00059","display_label":"Sarah Batt married Micajah Torrey Jr. — whose father Micajah.","link_text":"Rev. Capt. Josiah Torrey"},{"type":"parallel_descent","related_id":"I00062","display_label":"Sarah Batt married Micajah Torrey Jr. — whose father Micajah.","link_text":"Micajah Torrey Jr."},{"type":"parallel_descent","related_id":"X00072","display_label":"Sarah Batt married Micajah Torrey Jr. — whose father Micajah.","link_text":"Micajah Torrey"}],"tags":[],"open_questions":["Torrey line not fully researched beyond Weymouth — further descendants possible. See open_research_threads."],"sources":[],"gender":"female","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Sarah Batt White","first_name":"Sarah","last_name":"Torrey","married_names":["Torrey","White"],"maiden_name":"Batt","bio_blurb":"Twice-widowed Weymouth mother of nine"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Married her step-uncle's son","body":"Sarah Batt's stepfather Josiah Torrey was the brother of her husband Micajah Torrey Jr.'s father Micajah Torrey Sr. — Sarah therefore married her step-uncle's son. Her own children were both step-cousins to and children-in-law of the broader Torrey family network. The step-family marriage pattern was common in colonial New England where remarriages frequently rearranged the kinship of small village populations."},{"number":2,"category":"family","header":"Nine documented children with Micajah Torrey Jr.","body":"Sarah and Micajah Torrey Jr. had nine documented children. The marriage produced the largest single Batt-Torrey family cluster of the late-seventeenth and early-eighteenth-century Boston-and-Weymouth Massachusetts area, with the family settling primarily at Weymouth where Sarah lived out her long widowhood-and-old-age decades."},{"number":3,"category":"family","header":"Lived to ninety; gravestone reads eighty-fifth year","body":"Sarah lived to approximately age ninety — born January 18, 1673 in Boston and died May 10, 1763 in Weymouth, a span of ninety years and three months. The Weymouth gravestone reads 'in ye 85th year of her age' — a discrepancy suggesting either an inaccurate stone inscription or a contemporary error in computing her age. The colonial gravestone tradition of counting the running year rather than completed years often produced such variations."},{"number":4,"category":"family","header":"Boston 1673 to Weymouth Massachusetts 1763","body":"Sarah Batt was born January 18, 1673 in Boston Massachusetts, daughter of Paul Batt and Sarah Wilson Torrey. She died May 10, 1763 in Weymouth Massachusetts. Her ninety-year life spanned from the early years of King Philip's War through to the eve of the American Revolution."},{"number":5,"category":"family","header":"Widowed twice, she married a deacon","body":"Three years after Micajah Torrey died, Sarah married Deacon Samuel White of Braintree, becoming the second wife of a man who outlived her first husband by decades."}],"burial":{"cemetery_id":"CEM659"},"slug":"sarah-torrey-1673"},"HD0068":{"id":"HD0068","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1704,"month":3,"day":21,"city":"Weymouth","state":"Massachusetts"},"parents":{"father_id":"I00062","mother_id":"HD0067"},"tags":[],"sources":[],"death":{"year":1782,"city":"Taunton","state":"Massachusetts"},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Samuel Torrey","first_name":"Samuel","last_name":"Torrey","married_names":[],"bio_blurb":"Eldest of the Torrey-Batt children"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"samuel-torrey-1704"},"HD0069":{"id":"HD0069","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1706,"month":3,"day":5,"city":"Weymouth","state":"Massachusetts"},"parents":{"father_id":"I00062","mother_id":"HD0067"},"tags":[],"sources":[],"death":{"year":1763,"month":6,"day":23,"city":"Weymouth","state":"Massachusetts"},"gender":"male","number_of_marriages":1,"marriages":[{"children_ids":["HD5452"],"marriage_number":1}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Paul Torrey","first_name":"Paul","last_name":"Torrey","married_names":[],"bio_blurb":"Weymouth Torrey who consolidated the family land"},"residence":{},"baptism":{},"research_tags":[],"research