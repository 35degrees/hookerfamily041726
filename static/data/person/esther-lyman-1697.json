$1,650."},{"number":2,"category":"family","header":"Named replacement children after two he lost","body":"Their first daughter Sarah died at ten days old in March 1796, and the next daughter, born fourteen months later, was given the same name. The pattern repeated with James Tudor — when the first one died at three months in 1811, they gave the name to their final son, born two years later in 1813."}],"sources":[{"label":"Tankerhoosen Valley History","url":"https://www.tankerhoosen.info/history/talcott_vernon.htm"}],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"title":"Deacon","first_name":"Samuel","last_name":"Talcott","married_names":[],"display_name":"Deacon Samuel Talcott"},"military_service":[],"slug":"samuel-talcott-1757"},"T01031":{"id":"T01031","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"gender":"male","birth":{"year":1758,"month":12,"day":14,"city":"Bolton","county":"Tolland","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1835,"month":12,"day":17,"city":"Vernon","county":"Tolland","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM116","plot_notes":"Elmwood Cemetery Vernon CT. FindAGrave confirms."},"residence":{"city":"Vernon","county":"Tolland","state":"Connecticut","country":"United States"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":5,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["politics"],"notable_blurb":"Connecticut legislator; 1818 Constitutional Convention delegate"},"parents":{"father_id":"T00909","mother_id":"I00207","mother_research_no