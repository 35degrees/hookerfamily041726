table":{"is_notable":true,"notable_category":["religion","education"],"notable_blurb":"Fellow of Yale College 1710-1728; Pastor First Church"},"narrative_blocks":[{"number":1,"category":"religion","header":"Helped ordain John Hart with four other ministers","body":"On 25 November 1706 the East Guilford church was gathered and Rev John Hart ordained over it. The five-minister service included Buckingham of Saybrook, Pierpont of New Haven, Noadiah Russell of Middletown, and Samuel Russell of Branford alongside Ruggles — colonial Connecticut's tight clerical network on display."},{"number":2,"category":"death","header":"First wife Sarah died after fifteen years marriage","body":"His first wife Sarah Fiske died in 1706 at age thirty-two after fifteen years of marriage and five children. He remarried Mary Hubbard at Boston Massachusetts on 1 June 1708 — taking a second wife in his thirty-eighth year."},{"number":3,"category":"career","header":"Thirty-three years pastoring Guilford's First Church","body":"He was ordained pastor of First Church Guilford in 1695 at twenty-four — the position he held for thirty-three consecutive years until his death in 1728. The 1710 appointment as Fellow of Yale College gave him an additional eighteen-year tenure on Yale's governing board."}],"cross_connections":[{"type":"historical_connection","display_label":"East Guilford ordination, November 25, 1706","related_id":"X00126","link_text":"Rev. James Pierpont"},{"type":"historical_connection","display_label":"East Guilford ordination, November 25, 1706","related_id":"X01001","link_text":"Rev. Thomas Buckingham"},{"type":"historical_connection","display_label":"East Guilford ordination, November 25, 1706","related_id":"I00137","link_text":"Rev. John Hart"},{"type":"in_law","related_id":"H00317","display_label":"married his son Doctor in 1736"}],"institution_affiliations":[],"education":[{"institution_id":"INST022","school_name":"Yale College","type":"university","notable":true,"institution_blurb":"Fellow of Yale College 1710-1728; present at East Guilford ordination 1706.","years":"1710-1728"}],"bio":{"display_name":"Rev. Thomas Ruggles","first_name":"Thomas","last_name":"Ruggles","title":"Reverend","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Pastor","organization":"First Church of Guilford","start_year":1695,"end_year":1728},{"role":"Fellow","organization":"Yale College","start_year":1710,"end_year":1728}],"slug":"thomas-ruggles-1671"},"X02854":{"id":"X02854","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"bio":{"display_name":"Sarah Fisk Ruggles","first_name":"Sarah","last_name":"Ruggles","maiden_name":"Fiske","married_names":["Sarah Fiske Ruggles"]},"gender":"female","birth":{"year":1674,"city":"Braintree","state":"Massachusetts"},"death":{"year":1706,"month":7,"day":27,"city":"Guilford","state":"Connecticut"},"parents":{},"marriages":[{"marriage_number":1,"spouse_id":"X01929","children_ids":["X03242","X03243","X01756","X03218","X03244"]}],"sources":[],"cross_connections":[],"tags":[],"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":1,"research_tags":[],"research_sources":[],"documents":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"burial":{"cemetery_id":"CEM047","notes":"Cenotaph"},"slug":"sarah-fiske-1674"},"I00137":{"id":"I00137","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1682,"month":4,"day":12,"city":"Farmington","state":"Connecticut","country":"United States"},"death":{"year":1731,"month":3,"day":4,"city":"East Guilford","state":"Connecticut"},"burial":{"cemetery_id":"CEM038"},"parents":{"mother_research_notes":"Ruth Hawkins (daughter of Anthony Hawkins of Farmington)","father_id":"X00045","mother_id":"X01721"},"church_roles":[{"role":"Second Tutor, Yale College","dates":"1703-1705","notes":"Bespoken as tutor on the day of his graduation. Preceded by Daniel Hooker (first tutor, 1702), who was a son of Rev. Samuel Hooker of Farmington (H00007) and brother-in-law of Rev. James Pierpont, Yale's founding patron."},{"role":"Pastor","location":"East Guilford (now Madison), Connecticut","dates":"ordained Nov 25, 1707 – died Mar 4, 1731","notes":"Granted 25 acres by town of Guilford as settlement. \"One of the first Eminence of preachers in his Day\" (Rev. Thomas Ruggles Jr.). \"A gentleman of eminent piety\" (Rev. John Devotion). About 80 members added to church during his pastorate. In 1722, signed Rector Cutler's petition expressing doubt of Presbyterian ordination — later resolved his doubts and remained in place. President Stiles: \"Mr. Hart is said to have been a man of the greatest ingenuity and learning of all the seven.\""}],"marriages":[{"children_ids":["X01905","X01906"],"spouse_id":"X01178","marriage_number":1,"end_type":"death_of_spouse","end_year":1715,"date_year":1712,"date_month":3,"date_day":20},{"children_ids":[],"spouse_id":"X00134","marriage_number":2,"end_type":"death_of_spouse","end_year":1719,"date_year":1717,"date_month":8,"date_day":12},{"spouse_id":"H00105","children_ids":["H00311","H00312","H00313","H00314","H00315","H00316"],"marriage_number":3,"date_year":1720,"date_month":12,"date_day":6}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 105"},{"short":"Yale Biographical Sketches 1701-1745 (1885)","url":"https://www.cga.ct.gov/hco/books/Biographical_Sketches_of_Grads_of_Yale_1701-1745_1885.pdf"}],"gender":"male","tags":["minister","yale_graduate","educator"],"number_of_marriages":3,"notable":{"is_notable":true,"notable_category":["academia","religion"],"notable_blurb":"Yale's first B.A. graduate, 1703","primary_url":"https://yale60.org/wp-content/uploads/2025/05/OurLegacyOfJohnHart.pdf","primary_url_label":"yale60.org"},"narrative_blocks":[{"number":1,"category":"education","header":"Yale's first B.A. graduate — alone in 1703","body":"He was the first student in Yale College to be advanced to a Bachelor's Degree. He graduated alone at Saybrook on September 15, 1703 — his diploma signed by Rector Abraham Pierson, Moses Noyes, Thomas Buckingham, and Noadiah Russell."},{"number":2,"category":"career","header":"Second Yale tutor — succeeded Daniel Hooker","body":"He was appointed Yale's second tutor on the very day of his graduation, succeeding his Farmington townsman Daniel Hooker. He served from 1703 to 1705, with charge of the two lower classes."},{"number":3,"category":"religion","header":"Ordained East Guilford's first minister, 1707","body":"In April 1707 he accepted the call to East Guilford (now Madison), and on November 25, 1707 he was ordained over the new thirteen-member church. Five ministers including James Pierpont and Thomas Buckingham officiated."},{"number":4,"category":"religion","header":"Signed the 1722 Yale Episcopal declaration","body":"In September 1722 he joined Rector Cutler and five others in signing the famous declaration before Yale trustees questioning the validity of Presbyterian ordination. After conference at Yale Library on October 16, his doubts were resolved and he remained Congregational."},{"number":5,"category":"character","header":"Greatest ingenuity and learning of all seven","body":"President Ezra Stiles called him a man of 'the greatest ingenuity and learning' among the seven who signed the 1722 declaration. His estate at death included £35 in books — a substantial scholarly library."}],"cross_connections":[{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X00126","link_text":"Rev. James Pierpont"},{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X01001","link_text":"Rev. Thomas Buckingham"},{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X01929","link_text":"Rev. Thomas Ruggles"},{"type":"civic_peer","related_id":"H00036","display_label":"Succeeded him as Yale's second tutor in 1703","link_text":"Doctor Daniel Hooker"}],"education":[{"dates":"1700-1702","notes":"Two years at Harvard; transferred 1702","school_name":"Harvard College","institution_id":"INST002"},{"degree":"B.A.","notes":"FIRST student at Yale to receive a Bachelor's degree — graduated alone at Saybrook, September 15, 1703. His original diploma is preserved in Yale Library. The 1702 class received M.A. degrees only (honorary, for Harvard graduates); Hart's 1703 B.A. was Yale's first bachelor's degree.","school_name":"Yale College (Collegiate School of Connecticut)","graduation_year":1703,"institution_id":"INST022"}],"bio":{"title":"Reverend","display_name":"Rev. John Hart","first_name":"John","last_name":"Hart","married_names":[],"bio_blurb":"Yale's first graduate; second tutor of the college"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"},{"institution_id":"INST022","relationship":"alumnus","years":"1703"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-hart-1682"},"X01178":{"id":"X01178","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00137","date_year":1712,