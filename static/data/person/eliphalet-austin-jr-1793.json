 died in 1837 and left her a young widow with the household to keep. She managed the farm and raised the children alone for thirty-five years until her own death in 1872."}],"burial":{"cemetery_id":"CEM035","plot_notes":"Austinburg Center Cemetery, Austinburg, Ashtabula County, Ohio."},"slug":"sally-austin-1796"},"HD3713":{"id":"HD3713","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Sarah","middle_name":"Hayes","last_name":"Austin","married_names":[],"gender":"female","display_name":"Sarah Hayes Austin"},"birth":{"year":1820,"month":10,"day":5,"country":"United States"},"baptism":{},"death":{"year":1856,"month":6,"day":24,"country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"X01418","mother_id":"H01142"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"short":"Cowles Families in America #688 — Sally Berrien Cowles Austin"}],"research_sources":[],"documents":[],"slug":"sarah-austin-1820"},"HD3714":{"id":"HD3714","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Charlotte","middle_name":"Cowles","last_name":"Seeley","maiden_name":"Austin","married_names":["Seeley"],"gender":"female","display_name":"Charlotte Cowles Austin Seeley"},"birth":{"year":1822,"month":8,"day":26,"city":"Austinburg","county":"Ashtabula","state":"Ohio","country":"United States"},"baptism":{},"death":{},"residence":{"city":"