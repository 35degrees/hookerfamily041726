{"person":{"id":"HD1867","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1844},"death":{"year":1915},"parents":{"father_id":"HD1695","mother_id":"X00601"},"marriages":[{"spouse_id":"X00603","children_ids":["HD1868"],"marriage_number":1,"date_year":1864}],"tags":["military","civil_war","legal","freemason"],"sources":[],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Disbarred for refusing the KKK oath (1870-1875)"},"narrative_blocks":[{"header":"Disbarred for refusing the KKK oath (1870-1875)","detail":"After establishing his law practice in Greeneville TN, Judge Ingersoll was disbarred for refusing to take the oath sworn by Ku Klux Klan members — required of lawyers in Reconstruction-era Tennessee. He lost his initial appeal and was barred from practice from 1870 to 1875. He subsequently recovered his career, was appointed to the Tennessee Supreme Court in 1879, and became Dean of the University of Tennessee Law Department 1891-1914. He was a friend and neighbor of former President Andrew Johnson in Greeneville TN.","body":"Refused to take the \"Ku Klux Oath\" required of Tennessee lawyers; temporarily disbarred 1870-1875 as a result.","number":1},{"header":"Tennessee Supreme Court justice and Yale Class","detail":"Henry Hulbert Ingersoll attended Oberlin College and Yale University (class of 1863). He served as a private in the 7th Ohio Volunteer Infantry during the Civil War before moving south and entering law. After the KKK disbarment and reinstatement, his career accelerated: Tennessee Supreme Court 1879; LL.D. 1889; Dean of UT Law 1891-1914; Secretary of the Democratic National Convention in St. Louis 1888; President of the Tennessee Bar Association; Vice President of the American Bar Association 1907-1912; Grand Master of Tennessee Freemasons. Author of The Handbook of the Law of Public Corporations — still referenced today.","body":"Yale 1863; Civil War private; appointed Tennessee Supreme Court 1879; Dean of UT Law 1891-1914; VP of the American Bar Association 1907-1912.","number":2}],"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Judge Henry Hulbert Ingersoll","title":"Judge","first_name":"Henry","last_name":"Ingersoll","middle_name":"Hulbert","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"henry-ingersoll-1844"},"neighborhood":{"focus":{"id":"HD1867","slug":"henry-ingersoll-1844","n":"Judge Henry Hulbert Ingersoll","by":1844,"dy":1915,"sx":"m","hd":true,"td":false,"ee":false,"g":8},"spouses":[{"order":1,"spouse":{"id":"X00603","slug":"emily-rogers-1847","n":"Emily Gertrude Rogers","by":1847,"dy":1915,"sx":"f","hd":false,"td":false,"ee":false,"g":null},"year":1864,"children":[{"id":"HD1868","slug":"mabel-ingersoll-1869","n":"Mabel Rogers Ingersoll","by":1869,"dy":1933,"sx":"f","hd":true,"td":false,"ee":false,"g":9}]}],"parents":{"father":{"id":"HD1695","slug":"william-ingersoll-1801","n":"William Ingersoll","by":1801,"dy":1873,"sx":"m","hd":true,"td":false,"ee":false,"g":7},"mother":{"id":"X00601","slug":"samantha-bassett-1805","n":"Samantha Bassett","by":1805,"dy":1882,"sx":"f","hd":false,"td":false,"ee":false,"g":null}},"grandparents":{"paternal":{"father":{"id":"X00543","slug":"david-ingersoll-1759","n":"David Ingersoll","by":1759,"dy":1839,"sx":"m","hd":false,"td":false,"ee":false,"g":null},"mother":{"id":"H00907","slug":"sarah-parsons-1760","n":"Sarah Parsons","by":1760,"dy":1837,"sx":"m","hd":true,"td":false,"ee":false,"g":6}},"maternal":{}},"grandchildren":[{"id":"HD1875","slug":"henry-ingersoll-1893","n":"Henry I Ingersoll","by":18