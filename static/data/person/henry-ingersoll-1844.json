ations where conventional kinetic models broke down — addressing the work of Michaelis and Menten on enzyme velocity constants.","number":1}],"cross_connections":[],"bio":{"display_name":"Chandler Dymick Ingersoll","first_name":"Chandler","last_name":"Ingersoll","middle_name":"Dymick","married_names":[],"photo_url":"https://images.findagrave.com/photos/2020/281/216441007_27c3015b-34ce-402e-9b8b-5174c5ea9732.jpeg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"chandler-ingersoll-1897"},"HD1878":{"id":"HD1878","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1898},"death":{"year":1978},"parents":{"father_id":"X00604","mother_id":"HD1868"},"marriages":[{"spouse_id":"X01539","children_ids":[],"marriage_number":1}],"tags":[],"sources":[],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"John Campbell Ingersoll","first_name":"John","last_name":"Ingersoll","middle_name":"Campbell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-ingersoll-1898-2"},"HD1695":{"id":"HD1695","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1801,"month":12,"day":22,"city":"Lee","state":"Massachusetts"},"death":{"year":1873,"month":5,"