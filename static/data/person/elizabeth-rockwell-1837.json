4272"]}],"tags":["california_migration","new_york_migration","merchant","extraordinary_story","rancher"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 2705"},{"short":"Wikipedia: Henry Hooker","url":"https://en.wikipedia.org/wiki/Henry_Hooker"},{"short":"Wikipedia: Sierra Bonita Ranch","url":"https://en.wikipedia.org/wiki/Sierra_Bonita_Ranch"},{"short":"Willcox Cowboy Hall of Fame (1990 Posthumous Award)"},{"short":"National Cowboy & Western Heritage Museum (1959 Hall of Great Westerners)"},{"short":"Lynn R. Bailey, Henry Clay Hooker and the Sierra Bonita (book)","document_id":"DOC015"}],"careers":[{"role":"Store keeper","employer":"(self)","location":"Hangtown (Placerville) CA","start_year":1858,"end_year":1865,"notes":"Hardware store; destroyed by fire Aug 10, 1865"},{"role":"Livestock trader","employer":"(self)","location":"CA → NV → AZ Territory","start_year":1865,"end_year":1867,"notes":"Famous turkey drive 1865; pivoted to beef contracts 1867"},{"role":"Beef contractor / Rancher","employer":"U.S. Army (Apache War contracts) and Sierra Bonita Ranch","start_year":1867,"end_year":1907,"notes":"Founded Sierra Bonita Ranch 1872 in Sulphur Springs Valley AZ. Largest ranch in Arizona at peak (250,000 acres, 30,000 head). Honorary title Colonel."}],"notable":{"is_notable":true,"notable_blurb":"Founded Sierra Bonita — Arizona's first cattle ranch","notable_category":["rancher","frontier","old_west","arizona_pioneer"],"primary_url":"https://en.wikipedia.org/wiki/Henry_Hooker","primary_url_label":"Wikipedia: Henry Hooker"},"awards":[{"year":1959,"award":"Hall of Great Westerners","organization":"National Cowboy & Western Heritage Museum","notes":"Posthumous induction"},{"year":1964,"award":"National Historic Landmark designation (Sierra Bonita Ranch)","organization":"National Park Service","notes":"Posthumous; ranch he founded"},{"year":1990,"award":"Cowboy Hall of Fame Posthumous Award","organization":"Willcox Cowboy Hall of Fame","notes":"Posthumous"}],"narrative_blocks":[{"number":1,"category":"family","header":"Three Hinsdale brothers, three California fortunes","body":"Older brother Charles Gay built the San Francisco hardware fortune; younger brother John Daggett funded the 100-inch Hooker Telescope at Mount Wilson — the instrument Hubble used to prove the expanding universe. Henry Clay went south to Arizona Territory and founded its largest cattle empire."},{"number":2,"category":"family","header":"Sierra Bonita runs in the sixth generation today","body":"After his 1907 death the ranch passed through son Edwin, grandson Harry, and on to sixth-generation operator Jesse Hooker Davis. The original Herefords from his 1880s importations still graze the 45,000-acre headquarters — Arizona's oldest ranch under continuous single-family ownership."},{"number":3,"category":"family","header":"Hinsdale farmboy to Arizona cattle king","body":"Born in 1828 on the family farm settled by his great-grandfather Rev. Bunker Gay, he left Hinsdale at twenty in 1848 and reached Arizona by 1867. He built a 250,000-acre empire two thousand miles from the Connecticut River Valley homestead where his life began."},{"number":4,"category":"business","header":"Lost everything in a fire, then drove turkeys","body":"After the 1865 Placerville fire destroyed his hardware store and home, he spent his last thousand dollars on five hundred live turkeys and drove them with two dogs over the Sierra Nevada to the Comstock Lode mining camps. He sold them for $1,750 — the capital that funded his Arizona move."},{"number":5,"category":"business","header":"A cattle stampede chose Sierra Bonita's site","body":"While moving ten thousand Texas Longhorns across Arizona in 1872, his herd stampeded and was found grazing in a verdant cienega beneath the Pinaleño Mountains. He homesteaded the spot, named it Sierra Bonita for the range, and built a U-shaped adobe fortress with twenty-inch walls and gun ports."},{"number":6,"category":"frontier","header":"Sheltered Wyatt Earp after the Vendetta Ride","body":"On March 27, 1882, the Earp posse fled to Sierra Bonita pursued by warrants for the killings of the Vendetta Ride. He fed them, gave fresh horses, refused to tell Sheriff Behan which way they had gone, and remained Earp's friend for the rest of his life."}],"cross_connections":[{"type":"place_overlap","related_id":"HD04831","display_label":"Nephew Frederick joined him at Angelus-Rosedale, 1933","link_text":"Frederick Hooker Jones"},{"type":"career_overlap","related_id":"HD04844","display_label":"Nephew Cassius followed his Arizona ranching example","link_text":"Cassius Mason Hooker"}],"burial":{"plot_notes":"Rosedale Cemetery, Los Angeles CA (no CEM entry yet — pending creation)"},"residence":{"city":"Bonita","county":"Graham","state":"Arizona","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[{"document_id":"DOC015","role":"subject","notes":"Standard biography by Lynn R. Bailey."}],"naming_inspiration":[],"institutions":[],"landmarks":[{"landmark_id":"LM054","landmark_blurb":"Founded the ranch in 1872; built and lived in its U-shaped adobe headquarters until his 1907 death."},{"landmark_id":"LM106","landmark_blurb":"Born and raised on the Hinsdale homestead until he left for New York at age 20 in 1848."}],"artworks":[{"artwork_id":"ART046","role":"subject"}],"quotes":[],"military_service":[],"career":[{"role":"Clerk","location":"New York City","start_year":1848,"end_year":1849,"notes":"Brief stint in NYC immediately after leaving Hinsdale at age 20."},{"role":"Indian Department Contractor","organization":"U.S. Government","location":"Kansas City, Missouri","start_year":1849,"end_year":1852,"notes":"Attached to the Indian Department, supplying goods on the Missouri frontier."},{"role":"Miner and Merchant","location":"Placerville, California (El Dorado County)","start_year":1853,"end_year":1866,"notes":"Mined the El Dorado County diggings before opening a hardware merchant operation at Placerville (Hangtown). His store and home burned in 1865."},{"role":"Beef Contractor","organization":"U.S. Army","location":"Arizona Territory","start_year":1867,"end_year":1872,"notes":"Supplied beef to military posts and Indian agencies during the Apache Wars in partnership with Capt. Hugh Hinds."},{"role":"Owner and Operator","organization":"Sierra Bonita Ranch","location":"Sulphur Springs Valley, Arizona Territory","start_year":1872,"end_year":1907,"notes":"Founded Arizona's first permanent American cattle ranch. Built U-shaped adobe fortress; expanded to 250,000 acres / 30,000 head. After 1891 drought reorganized as Sierra Bonita Land & Stock Co., capitalized $500,000."}],"videos":[{"video_id":"VID008"}],"slug":"henry-hooker-1828"},"H04270":{"id":"H04270","former_ids":[],"is_placeholder":false,"gender":"female","has_descendants_documented":false,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"is_easter_egg":false,"include_in_path_calculation":true,"descent_from_thomas_hooker":true},"bio":{"first_name":"Ida","middle_name":"M.","last_name":"Hooker","married_names":[],"gender":"female","display_name":"Ida M. Hooker"},"birth":{"year":1858,"month":5,"day":3,"state":"California","country":"United States"},"death":{"year":1937},"parents":{"father_id":"H02705","mother_id":"X02248"},"marriages":[],"tags":["california_migration","arizona_migration"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 4270"},{"short":"Wikipedia: Henry Hooker"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ida-hooker-1858"},"H04271":{"id":"H04271","former_ids":[],"is_placeholder":false,"gender":"male","has_descendants_documented":t