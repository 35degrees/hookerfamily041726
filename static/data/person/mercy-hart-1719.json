ty":"Farmington","state":"Connecticut","country":"United States"},"cross_connections":[],"bio":{"display_name":"Mercy Hart Hooker","first_name":"Mercy","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Hart"},"residence":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mercy-hart-1719"},"H00104":{"id":"H00104","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1710,"month":9,"day":17,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1774,"month":5,"day":25,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00030","mother_id":"I00031"},"tags":["compiler_ancestor"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 104"}],"cross_connections":[],"burial":{"cemetery_id":"CEM004"},"marriages":[{"marriage_number":1,"spouse_id":"I00135","date_year":1740,"date_month":1,"date_day":29,"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1745,"children_ids":["H00301","H00302","H00303"]},{"marriage_number":2,"spouse_id":"I00136","date_year":1747,"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1774,"children_ids":["H00304","H00305","H00306","H00307","H00308","H00309","H00310"]}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"character","header":"He kept the Hooker Elm's famous hospitality alive","body":"He inherited the Farmington estate and the famous Hooker Elm from his father John. EH described him as 'a thorough gentleman of the old school' who continued the famed hospitality of the elm gatherings."},{"number":2,"category":"family","header":"Favorite son and keeper of family history","body":"He accompanied his father John on official journeys around the Colony and brought his first wife to live in the family house. EH wrote that he received from his father full information about the family's English origins — and that his father was the best informed of all Thomas Hooker's grandsons on the subject."},{"number":3,"category":"family","header":"Three sisters married Hart brothers — knot tied","body":"His sisters Abigail, Mary, and Sarah each married a son of Capt. John Hart between 1719 and 1725. Through those three marriages, Roger found himself simultaneously brother-in-law to Nathaniel, Samuel, and Matthew Hart — the Hart and Hooker families fully intertwined."},{"number":4,"category":"family","header":"His granddaughter Abigail married Samuel Talcott","body":"His son Thomas Hooker fathered Abigail Hooker, who married Samuel Talcott of Hartford. The marriage merged the Hooker surname into the Talcott line — a transition that defines several gen 6+ branches."}],"bio":{"display_name":"Roger Hooker","first_name":"Roger","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"roger-hooker-1710"},"H00301":{"id":"H00301","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1740,"month":12,"day":16,"city":"Farmington","state":"Connecticut"},"death":{"year":1741,"month":4,"