r_of_marriages":1,"notable":{"is_notable":false,"notable_category":[],"primary_url":"https://en.wikipedia.org/wiki/Jonathan_Leavitt_(minister)","primary_url_label":"Wikipedia"},"bio":{"display_name":"Sarah Hooker Leavitt","notes":"Sarah No. 2 — replacement naming after first Sarah (H00301) who died April 1741","first_name":"Sarah","maiden_name":"Hooker","married_names":["Leavitt"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married Rev. Jonathan Leavitt of Heath","body":"She married Rev. Jonathan Leavitt and moved to Heath, Massachusetts. Leavitt was twice dismissed from churches — once for dragging a runaway enslaved woman home by rope, and once for Loyalist sympathies."},{"number":2,"category":"family","header":"Twelve children — eleven sons and one daughter","body":"She had twelve children with Jonathan Leavitt — eleven sons and one daughter named Clarissa. EH lists only three; other sources confirm the full count of twelve."},{"number":3,"category":"death","header":"Daughter gave her wrong medicine, killing her","body":"She died suddenly in 1791 after her daughter Clarissa gave her the wrong medicine. Clarissa herself died unmarried seven years later — never recovering from the accident."},{"number":4,"category":"legacy","header":"Underground Railroad station owners descended from her","body":"Two of her grandsons — Roger Hooker Leavitt and Hart Leavitt — operated Underground Railroad stations in Charlemont, Massachusetts, sheltering the fugitive Basil Dorsey for five years. Roger's home is on the National Park Service Underground Railroad Network to Freedom."},{"number":5,"category":"death","header":"A wrong medicine, given by her daughter","body":"She died suddenly at Heath on October 11, 1791, after taking the wrong medicine — handed to her, the Yale record says, by her daughter Clarissa. The funeral text was “He hath done all things well”; the Connecticut Courant carried the notice."}],"slug":"sarah-leavitt-1742"},"X00153":{"id":"X00153","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["slaveholder","loyalist"],"sources":[{"short":"Emerson Davis, Biographical Sketches of Congregational Pastors","notes":"Vol.1 p.276; Vol.5 p.238"},{"short":"Edward Hooker 1909","page":"Entry 302"}],"birth":{"year":1731,"month":1,"day":11,"city":"Suffield","state":"Connecticut"},"death":{"year":1802,"month":9,"day":9,"city":"Heath","state":"Massachusetts"},"burial":{"cemetery_id":"CEM867"},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00302","date_year":1761,"date_month":12,"date_day":10,"end_type":"death_of_spouse","end_year":1791,"children_ids":["H00684","H00685","HD0857","HD0858","HD0859","HD0860","HD0861","HD0862","HD0863","HD0864","HD0865","HD0866"]}],"parents":{},"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Rev., Hooker descendant","primary_url":"https://en.wikipedia.org/wiki/Jonathan_Leavitt_(minister)","primary_url_label":"Wikipedia"},"cross_connections":[],"bio":{"display_name":"Rev. Jonathan Leavitt","first_name":"Jonathan","last_name":"Leavitt","title":"Reverend","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781293358/98874117_c8db83d3-fc8e-4ceb-a975-8781d57cc0cd-resized_p2ilji.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1758"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Yale 1758 minister at Walpole and Charlemont","body":"He graduated Yale in 1758 and was ordained at Walpole, New Hampshire on May 27, 1761. After 1767 he served the Charlemont, Massachusetts pulpit until 1785."},{"number":2,"category":"family","header":"Uncle of Chief Justice Oliver Ellsworth","body":"His sister Jemima Leavitt married Capt. David Ellsworth, making him the uncle of Oliver Ellsworth — Founding Father, signer of the Constitution, and third Chief Justice of the United States Supreme Court. The Ellsworth and Leavitt households were closely tied through Suffield, Connecticut."},{"number":3,"category":"crime","header":"Dragged a runaway enslaved woman home by rope","body":"In 1764 he was dismissed from his Walpole ministry after allegedly dragging a runaway enslaved woman home behind his horse by a rope tied to his saddle. He was installed at Charlemont, Massachusetts three years later."},{"number":4,"category":"politics","header":"Dismissed from Charlemont for his Loyalist sentiments","body":"He was dismissed from his Charlemont, Massachusetts ministry in 1785 for Loyalist sympathies during the Revolution. He preached on alone in a schoolhouse and sued his former parishioners for back wages, winning roughly £700."},{"number":5,"category":"family","header":"Wife died from medicine her daughter gave her","body":"His wife Sarah Hooker Leavitt died in October 1791 at age 49 'as a consequence of taking wrong medicine' given to her by their daughter Clarissa. The obituary called the loss sudden and unexpected."},{"number":6,"category":"legacy","header":"Two grandsons defended him in a 1904 book","body":"Two of his grandsons John Hooker Leavitt and William Hooker Leavitt published a 1904 volume titled 'A Sketch of the Life and Character of Rev. Jonathan Leavitt.' They tried to portray their controversial ancestor as a misunderstood and complicated man."}],"education":[{"institution_id":"INST022","dates":"1758","type":"undergraduate","notes":"B.A. — Yale 1758. Tier-2 spouse of Sarah Hooker (H00302). Two brothers also Yale graduates. Nephew-by-marriage to Chief Justice Oliver Ellsworth."}],"slug":"jonathan-leavitt-1731"},"H00684":{"id":"H00684","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1764,"month":2,"day":27,"city":"Walpole","state":"New Hampshire"},"death":{"year":1830,"month":5,"day":1,"city":"Greenfield","state":"Massachusetts"},"parents":{"father_id":"X00153","mother_id":"H00302"},"marriages":[{"children_ids":["HD0856"],"spouse_id":"X00156","marriage_number":1,"date_year":1796}],"tags":["not_yet_fully_entered"],"sources":[],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Jonathan Leavitt","first_name":"Jonathan","last_name":"Leavitt","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"jonathan-leavitt-1764"},"H00685":{"id":"H00685","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1771,"month":1,"day":12,"city":"Charlemont","state":"Massachusetts"},"death":{"year":1840,"month":6,"day":4,"city":"Burdett","state":"New York"},"parents":{"father_id":"X00153","mother_id":"H00302"},"tags":["not_yet_fully_entered","named_for_hooker","abolitionist"],"marriages":[{"children_ids":["HD0867","HD0868","HD0869"],"spouse_id":"X00252","marriage_number":1}],"sources":[],"cross_connections":[{"type":"parallel_descent","related_id"