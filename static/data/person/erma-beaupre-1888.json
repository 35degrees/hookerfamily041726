ong","married_names":[],"gender":"male","display_name":"Captain William Robert Strong","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778988848/williamstrong_pgjfat.png","photo_notes":"Captain William Robert Strong (1884-1919)"},"birth":{"year":1884,"month":7,"day":14,"city":"Evanston","county":"Cook County","state":"Illinois","country":"United States"},"baptism":{},"death":{"year":1919,"month":10,"day":19,"city":"Ovando","county":"Powell County","state":"Montana","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM473","plot_notes":"Forestvale Cemetery Helena per FA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"generation_from_john_talcott":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD4698","mother_id":"I00960"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00962","date_year":1914,"date_month":6,"date_day":15,"location_city":"Silver Bow","location_state":"Montana","location_country":"United States","end_type":"death","end_year":1919,"children_ids":["HD4705"]}],"education":[],"career":[],"military_service":[{"war":"World War I","war_id":"WAR007","rank":"Captain","unit":"Unknown regiment; Battle of Chateau-Thierry","years":"c.1917-1918","notes":"Secretary Helena Rifle Club before war. Carried Colt automatic pistol at Chateau-Thierry. Killed in hunting accident Oct 19, 1919 near Ovando MT, witnessed by gunwriter Elmer Keith."}],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["wwi","freemason","army","unusual_death"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Killed hunting; daughter born two months later","body":"Captain William Robert Strong served at the Battle of Chateau-Thierry in World War I carrying the Colt automatic pistol he had bought as Secretary of the Helena Rifle Club, and was shot and killed in a hunting accident north of Ovando, Montana on October 19, 1919 — gunwriter Elmer Keith, standing six feet away, recalled the fatal slug missed him by inches. His daughter Billie Louise was born on December 16, 1919, two months after his death, and died in 1925 at age five."},{"number":2,"category":"military","header":"At Chateau-Thierry he did not miss a shot","body":"Captain William Robert Strong fought at the Battle of Chateau-Thierry in 1918 carrying the .30-06 Colt automatic pistol he had purchased for $14.25 through the DCM and NRA as Secretary of the Helena Rifle Club before the war — and told gunwriter Elmer Keith that he 'used several clips in one engagement and did not think he missed a shot,' a soldier's account that Keith found credible enough to preserve in his book Sixguns. Keith was standing six feet away from Strong on the morning the hunting accident took his life in 1919 — 'the 150 grain .30-06 slug that took his life missed me by inches' — making him the last witness to a man who had carried the same gun through a World War."}],"quotes":[],"sources":[{"label":"FindAGrave","url":"https://www.findagrave.com"},{"label":"Elmer Keith, Sixguns — eyewitness account of the hunting accident"}],"research_sources":[],"documents":[],"slug":"william-strong-1884"},"HD4705":{"id":"HD4705","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Billie","middle_name":"Louise","last_name":"Strong","married_names":[],"gender":"female","display_name":"Billie Louise Strong"},"birth":{"year":1919,"month":12,"day":16,"city":"Helena","county":"Lewis and Clark County","state":"Montana","country":"United States"},"baptism":{},"death":{"year":1925,"month":5,"day":31,"city":"Helena","county":"Lewis and Clark County","state":"Montana","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM473","plot_notes":"Forestvale Cemetery Helena — alongside father Captain William Robert Strong"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"generation_from_john_talcott":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD4701","mother_id":"I00962"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_in_childhood"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Her father was killed before she was born","body":"Billie Louise Strong was born on December 16, 1919, fifty-eight days after her father Captain William Robert Strong was shot and killed in a hunting accident near Ovando, Montana — her mother Erma had been pregnant when the bullet that narrowly missed Elmer Keith struck her husband. She died in Helena on May 31, 1925 at age five, and was buried at Forestvale Cemetery alongside the father she never knew."}],"quotes":[],"sources":[{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"billie-strong-1919"}},"burialCemetery":{"id":"CEM474","name":"Mount Calvary Cemetery","location":{"city":"Portland","county":"Multnomah County","state":"Oregon","country":"United States"},"url":"https://www.findagrave.com/cemetery/39166/mount-calvary-cemetery","hooker_connections":["I00962"]},"institutionsById":{},"crossConnections":[]}