stitutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["extraordinary_longevity"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"character","header":"Quaker-heritage Delaware woman who outlived her husband","body":"Born in Edgemoor, Delaware to a Quaker-heritage Comly family, Gertrude married Atlanta-born Ray Cowles Werner in 1925. She survived her husband by twenty-eight years, dying in Medford, New Jersey on May 1, 1990 at the age of one hundred and one — extraordinary_longevity. She was buried beside Ray at Oakland Cemetery in Atlanta."}],"quotes":[],"sources":[{"short":"FamilySearch LZTB-VV5","url":"https://ancestors.familysearch.org/en/tree/person/LZTB-VV5","accessed":"2026-05"},{"short":"Find a Grave Memorial 97125149","url":"https://www.findagrave.com/memorial/97125149","accessed":"2026-05"}],"research_sources":[],"documents":[],"slug":"gertrude-comly-1889"}},"burialCemetery":{"id":"CEM270","name":"Oakland Cemetery","city":"Atlanta","county":"Fulton County","state":"Georgia","country":"United States","gps":"33.7494, -84.3739","founded":1850,"wikipedia_url":"https://en.wikipedia.org/wiki/Oakland_Cemetery_(Atlanta)","primary_url":"https://www.oaklandcemetery.com/","hooker_connections":["HD3774","HD3775","HD3776","HD3777","HD3778","I00425","I00426","I00427"],"notes":"Historic Atlanta cemetery founded 1850. Burial place of the Werner-Cowles family branch: Florence Woodruff Cowles Werner (HD3774), her husband Edward A. Werner Sr (I00425), and all four of their children — Edward Jr (HD3775), Lynn Woodruff (HD3776), Florence Brine (HD3777), Ray Cowles (HD3778) — plus Ray's wife Gertrude Comly Werner (I00427). Contains notable Atlanta citizens including 6 governors, Margaret Mitchell, Bobby Jones."},"institutionsById":{},"crossConnections":[]}