scent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD0984","mother_id":"I00385","father_name":"Ebenezer Mix Cowles","mother_name":"Frances M. Atwood Cowles"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00425","date_year":1872,"date_month":12,"date_day":19,"location_city":"Huntsville","location_county":"Madison County","location_state":"Alabama","location_country":"United States","end_type":"death","end_year":1911,"children_ids":["HD3775","HD3776","HD3777","HD3778"]}],"education":[{"institution":"Huntsville Female Seminary, Huntsville, Alabama","notes":"Per EH: 'educated at the Huntsville Female Seminary, Huntsville, Ala., a Presbyterian institution, which at that time was foremost in educating young ladies.'"}],"career":[],"military_service":[],"institutions":[{"institution_id":"INST118","role":"student","dates":"1850s-1860s","notes":"Per EH 1909, attended Huntsville Female Seminary."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["georgia_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Born in Georgia's capital, educated in Alabama","body":"Florence was born March 6, 1843 in Milledgeville — Georgia's state capital — and educated at the Huntsville Female Seminary, a Presbyterian institution then foremost in educating young Southern women. She married Georgia Railroad agent Edward Werner in Huntsville in December 1872 and settled permanently in Atlanta."},{"number":2,"category":"family","header":"Her estate sparked a Georgia Supreme Court battle","body":"Florence died November 29, 1911, never having distributed her late husband Edward's estate to their four children. Her son Lynn assumed management without court authority; by 1943 the estate dispute reached the Georgia Supreme Court, where Edward Jr. sued Lynn, Florence, and Ray over property mismanagement and a disputed sale of 528 West Peachtree Street Atlanta."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909, entry #1698 (Florence Woodruff Cowles)","url":"https://archive.org/details/descendantsofrev00hook","accessed":"2026-05"},{"short":"FamilySearch KD7Q-YNP","url":"https://ancestors.familysearch.org/en/tree/person/KD7Q-YNP","accessed":"2026-05"},{"short":"Find a Grave Memorial 97125562","url":"https://www.findagrave.com/memorial/97125562","accessed":"2026-05"},{"short":"Werner v. Werner, 195 Ga. 868 (Ga. Sup. Ct. May 6, 1943, Reid CJ)","accessed":"2026-05"}],"research_sources":[],"documents":[],"slug":"florence-werner-1843"},"HD3775":{"id":"HD3775","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Edward","middle_name":"Alphonso","last_name":"Werner","suffix":"Jr.","married_names":[],"gender":"male","display_name":"Edward Alphonso Werner Jr."},"birth":{"year":1874,"month":9,"day":5,"city":"Huntsville","county":"Madison County","state":"Alabama","country":"United States"},"baptism":{},"death":{"year":1955,"month":5,"day":24,"city":"Atlanta","county":"Fulton County","state":"Georgia","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM270","plot_notes":"Oakland Cemetery, Atlanta"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00425","mother_id":"HD3774","father_name":"Edward Alphonso Werner Sr","mother_name":"Florence Woodruff Cowles Werner"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00426","location_country":"United States","end_type":"divorce_or_death","children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["alabama_migration","georgia_migration","lawyer"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Plaintiff in 1943 Georgia Supreme Court estate suit","body":"Edward Werner Jr. was named plaintiff in the Georgia Supreme Court 1943 estate case Werner versus Werner — number 14530 — in which he sued his brothers Lynn and Ray and sister Florence Brine over their parents' estate. Edward alleged that brother Lynn had mismanaged the estate and appropriated profits from the sale of 528 West Peachtree Street Atlanta. The reported case became part of the published record of mid-twentieth-century Georgia probate law."},{"number":2,"category":"family","header":"Two marriages and three documented children","body":"Edward had two marriages with three documented children. His wife Elizabeth Weakley bore daughters Elisabeth Werner born 1908 and Harriette Werner born 1915; his wife Ethel Margaret Cook of Atlanta bore daughter Elizabeth C. Werner born 1907. The chronological ordering of the two marriages remains unsettled across descendant records."},{"number":3,"category":"family","header":"Huntsville Alabama 1874 to Atlanta Georgia 1955","body":"Edward Werner Jr. was born September 5, 1874 in Huntsville, Madison County Alabama and died May 24, 1955 in Atlanta, Fulton County Georgia at age eighty. He is buried at Oakland Cemetery Atlanta — one of the most prominent nineteenth-century Southern garden cemeteries, holding the graves of Margaret Mitchell, Bobby Jones, and many of Atlanta's founding families."},{"number":4,"category":"family","header":"Hooker descent through mother Florence Cowles Werner","body":"Edward inherited Hooker descent through his mother Florence Woodruff Cowles Werner — the Connecticut Cowles family being one of the major mid-nineteenth-century New England-to-Deep South migration lines that brought Connecticut Yankees south of the Mason-Dixon. His father Edward Alphonso Werner Sr. was a non-Hooker line spouse."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909, entry #3695","url":"https://archive.org/details/descendantsofrev00hook","accessed":"2026-05"},{"short":"FamilySearch MBGM-Q4Q","url":"https://ancestors.familysearch.org/en/tree/person/MBGM-Q4Q","accessed":"2026-05"},{"short":"Find a Grave Memorial 52098668","url":"https://www.findagrave.com/memorial/52098668","accessed":"2026-05"},{"short":"Werner v. Werner, 195 Ga. 868 (1943) — named plaintiff","accessed":"2026-05"}],"research_sources":[],"documents":[],"slug":"edward-werner-jr-1874"},"I00426":{"id":"I00426","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Ethel","middle_name":"Margaret","last_name":"Werner","maiden_name":"Cook","married_names":["Werner"],"gender":"female","display_name":"Ethel Margaret Cook Werner"},"birth":{"year":1876,"month":11,"day":20,"city":"Atlanta","county":"Fulton County","state":"Georgia","country":"United States"},"baptism":{},"death":{"year":1947,"month":7,"day":16,"city":"Atlanta","county":"Fulton County","state":"Georgia","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM270","plot_notes":"Section 3 Block 92 Lot 6 G, Oakland Cemetery Atlanta (per Find a Grave GPS 33.7493917,-84.3739389)"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3775","location_country":"United States","end_type":"death","end_year":1947,"children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],