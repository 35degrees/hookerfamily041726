l_death"],"sources":[],"birth":{"year":1857,"month":10},"death":{"year":1894,"month":1},"marriages":[{"spouse_id":"X00919","children_ids":["HD2691","HD2692","HD2694"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"William Epaphroditus Ransom","first_name":"William","last_name":"Ransom","middle_name":"Epaphroditus","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"death","header":"Railroad detective killed after train-robber scuffle","body":"William Epaphroditus Ransom was a Union Pacific Railroad detective. While investigating train robberies near Wahoo Nebraska in January 1894, he confronted a thief breaking into a box car; in the resulting scuffle the burglar was shot dead and Ransom was 'thrown or slipped upon the end of a tie' and injured his head. He seemed not badly hurt at first."},{"number":2,"category":"death","header":"Brain fever onset; out of mind until death","body":"Alarming symptoms of brain fever soon developed after his head injury. Ransom was admitted to Saint Joseph's Hospital in Omaha and was 'continually out of his mind' until his death on January 29, 1894 at age thirty-six. The head-injury-to-brain-fever sequence reflected the era's limited understanding of post-traumatic intracranial complications."},{"number":3,"category":"death","header":"Brother Arthur also died in same year","body":"William's brother Arthur Ransom also died in April 1894 — both Ransom sons dead within three months. The compressed double family loss across two siblings in one year captured the kind of unrelated tragedy that occasionally swept through American families of the Gilded Age. William was survived by his wife Josephine E. Pierce and three children."},{"number":4,"category":"career","header":"Ten years with Union Pacific Railroad","body":"Ransom was connected with the Union Pacific Railroad for ten years before his death — first as chief clerk to the superintendent, then in the law and claims departments. He was 'well liked' and described as 'one of the best known young railroad men in town.' Born October 27, 1857 in Lecompton Douglas County Kansas, he is buried at Mountain Home Cemetery in Kalamazoo Michigan."}],"slug":"william-ransom-1857"},"HD2691":{"id":"HD2691","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":11,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2690","mother_id":"X00919"},"tags":[],"sources":[],"birth":{"year":1883,"month":12},"death":{"year":1922,"month":9},"marriages":[{"spouse_id":"X00920","children_ids":["HD2695"],"marriage_number":1}],"gender":"unknown","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Majoria B Ransom","first_name":"Majoria","last_name":"Ransom","middle_name":"B","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"majoria-ransom-1883"},"X00920":{"id":"X00920","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1880},"death":{"year":1931},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2691","children_ids":["HD2695"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_