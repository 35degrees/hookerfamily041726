ine Walter died in 1797 after producing one child, and a presumed unnamed third wife produced a son baptized in 1800; the family network shows the high cost of post-Revolutionary childbearing in colonial Connecticut."}],"slug":"elizabeth-eaton-1755"},"H00238":{"id":"H00238","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1729,"month":9,"day":5,"city":"Windsor","state":"Connecticut"},"parents":{"father_id":"I00126","mother_id":"H00092"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 238"}],"marriages":[{"spouse_id":"I00158","children_ids":["H00447","H00448","H00449","H00450","H00451","H00452","H00453a","H00453","H00454"],"marriage_number":1,"date_year":1750,"date_month":5,"date_day":31,"location_city":"New Haven","location_state":"Connecticut"}],"death":{"year":1783,"month":3,"day":13,"city":"North Haven","state":"Connecticut"},"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Isaac Stiles Jr.","first_name":"Isaac","last_name":"Stiles","suffix":"Jr.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"isaac-stiles-jr-1729"},"I00158":{"id":"I00158","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1730,"month":11,"day":5,"city":"New Haven","state":"Connecticut"},"death":{"year":1802,"month":2,"day":14,"city":"North Haven",