:"Member, U.S. House of Representatives","jurisdiction":"Mississippi","dates":"March 4, 1895 – March 3, 1897","notes":"Democrat. 54th Congress. Elected Nov 6, 1894."}],"tags":["mississippi_migration","confederate","civil_war","veteran"],"sources":[],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["politics"],"primary_url":"https://history.house.gov/People/Detail/21799","notable_blurb":"Mississippi U.S. Representative and Confederate veteran"},"cross_connections":[],"military_service":[{"war":"American Civil War","rank":"Private","unit":"Cowan's Battery, 1st Mississippi Light Artillery (CSA)","rank_year_start":1863,"notes":"Enlisted 26 April 1863; served in the Army of Mississippi and Army of Tennessee; captured at Blakely, Alabama, 9 April 1865."}],"bio":{"display_name":"James Grafton Spencer","first_name":"James","last_name":"Spencer","middle_name":"Grafton","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780860062/7134498_5d1f5129-d300-4dcb-b8b1-5c967682f99a_d6s5br.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"category":"politics","header":"He followed a Hooker into Congress unrelated","body":"Elected to the Fifty-fourth Congress in 1894, Spencer took the Mississippi seat just vacated by Charles E. Hooker, a Confederate colonel who, despite the shared surname, has no documented kinship to the Thomas Hooker line from which Spencer descended. A genuine Hooker descendant thus replaced a man merely named Hooker.","number":1},{"category":"military","header":"Captured in the war's final week","body":"Spencer enlisted as a private in Cowan's Battery of the First Mississippi Light Artillery in 1863 and served through the Army of Mississippi and the Army of Tennessee. He was captured at Blakely, Alabama, on April 9, 1865, in one of the last engagements of the Civil War.","number":2},{"category":"career","header":"From cotton fields to the Capitol","body":"After the war Spencer returned to Port Gibson and worked in agriculture, real estate, and insurance before entering politics. He served in the Mississippi House from 1892 to 1894 and then a single term in the United States Congress.","number":3},{"category":"family","header":"Son of a Yale-trained frontier patriarch","body":"James was the sixth of ten children of Horatio Nelson Spencer, a Connecticut-born Yale graduate who became a Port Gibson banker, railroad president, and planter. The Spencers carried their Hooker descent from New England into the Mississippi cotton country.","number":4}],"education":[{"school_name":"Oakland College","type":"college","dates":"1861","location":"Mississippi"}],"career":[{"role":"U.S. Representative (Mississippi)","organization":"United States Congress","start_year":1895,"end_year":1897,"notes":"Fifty-fourth Congress."},{"role":"Member","organization":"Mississippi House of Representatives","start_year":1892,"end_year":1894},{"role":"Agriculture, real estate, and insurance","location":"Port Gibson, Mississippi"}],"slug":"james-spencer-1844"},"X01115":{"id":"X01115","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0273","date_year":1866,"date_month":4,"date_day":25,"location_city":"Claiborne","location_state":"Mississippi","children_ids":["HD5962","HD5963","HD5964","HD5965","HD5966"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1846,"month":10,"day":27,"county":"Claiborne","state":"Mississippi","country":"United States"},"death":{"year":1913,"month":8,"day":19,"city":"Natchez","county":"Adams