er_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"descent_paths_to_thomas":1,"is_progenitor":false},"birth":{"year":1641,"month":10,"day":18,"city":"Newtowne (Cambridge)","county":"Middlesex","state":"Massachusetts","country":"United States"},"death":{"year":1668,"month":4,"day":7,"city":"Rowley","county":"Essex County","state":"Massachusetts","country":"United States"},"burial":{"plot_notes":"Plot 4 Row, East (Marble) South front"},"parents":{"father_id":"I00002","mother_id":"H00002"},"marriages":[{"spouse_id":"I00007","children_ids":["H00038","X00014"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1668,"date_year":1666,"date_month":4,"date_day":30}],"tags":["minister","harvard_graduate","epidemic_death"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 8","notes":"Graduation year 1655 corrected to 1658 per gravestone and ordination records"},{"short":"Rowley Burial Ground gravestone inscription"},{"short":"Essex County Probate file #25186"},{"short":"Probate Records of Essex County","volume":"2","page":"127"},{"short":"Sibley's Harvard Graduates","volume":"III","pages":"342-3"},{"label":"Sibley's Harvard Graduates, Vol. III, pp. 342-3"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Thomas Hooker raised him for Harvard","body":"After his mother Joanna's death in 1646, he was brought up in his grandfather Rev. Thomas Hooker's Hartford household. Thomas fitted him for Harvard — making Samuel one of the very few people who knew the founder of Hartford personally."},{"number":2,"category":"career","header":"Harvard at 17 — Rowley's minister at 24","body":"He received his B.A. and A.M. from Harvard in 1658 at roughly age seventeen, then was ordained pastor of First Church Rowley on November 15, 1665 — the third minister of that congregation. He served for less than three years before his death."},{"number":3,"category":"death","header":"Both died within two months — probable epidemic","body":"His wife Dorothy died February 12, 1668, and he followed fifty-five days later on April 7. Their infant son Samuel was eight months old — two young ministers dying weeks apart in the same town strongly suggests an epidemic."},{"number":4,"category":"death","header":"Wrote his will — died three days later","body":"He wrote his will on April 4, 1668; he died on April 7. He left his infant son Samuel — eight months old — to the care of Rev. Henry and Margery Flint of Braintree, with 100 acres at Rowley to come to the boy at age 21."},{"number":5,"category":"family","header":"Matthew Day's will called him 'little Samuel'","body":"Matthew Day — the Cambridge printer and Harvard figure — left him a silver spoon engraved with his own name in his will of May 10, 1649, addressing him as 'my old acquaintance little Samuel Shepard.' He was seven years old."}],"is_placeholder":false,"baptism":{},"residence":{"city":"Rowley","county":"Essex","state":"Massachusetts","country":"United States"},"institutions":[{"institution_id":"INST002","institution_blurb":"Harvard B.A. and A.M. 1658."}],"landmarks":[],"naming_inspiration":[],"research_tags":[],"cross_connections":[],"quotes":[{"text":"A very Precious, Holy, Meditating, Able and Choice Young Man. His Attainments in Communion with God, and in Daily Meditation and Close Walking, may shame those that are Elder than he. He was but Twenty six years of Age in October last. He was an Excellent Preacher, most dearly Beloved at Rowly, and of all that knew him; but just settled among them. The People would have Plucked out their Eyes for him, to have saved his Life.","attribution":"Rev. Jonathan Mitchell, Harvard 1647, on Samuel Shepard","category":"legacy"}],"research_sources":[],"education":[{"institution_id":"INST002","degrees":[{"degree":"B.A.","year":1658},{"degree":"A.M.","year":1658}]}],"bio":{"title":"Reverend","display_name":"Rev. Samuel Shepard","first_name":"Samuel","last_name":"Shepard","married_names":[]},"documents":[],"artworks":[],"military_service":[],"slug":"samuel-shepard-1641"},"H00038":{"id":"H00038","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"descent_paths_to_thomas":1,"is_progenitor":false},"birth":{"year":1667,"month":8,"day":19,"city":"Rowley","state":"Massachusetts","country":"United States"},"death":{"year":1723,"city":"Woodbridge","county":"Middlesex","state":"New Jersey","country":"United States"},"parents":{"father_id":"H00008","mother_id":"I00007"},"marriages":[{"children_ids":[],"spouse_id":"I00178","marriage_number":1,"date_year":1698,"date_month":7,"date_day":14,"location_city":"Boston","location_county":"Suffolk","location_state":"Massachusetts","location_country":"United States"}],"tags":["minister","harvard_graduate","orphaned_in_infancy","new_jersey_minister","justice_of_peace"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 38"},{"short":"Vital Records of Rowley, Massachusetts","page":"p. 194"},{"short":"Sibley's Harvard Graduates","volume":"III","pages":"342-3"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Mother, father, grandfather — all dead by April","body":"His mother Dorothy died February 12, 1668. His father wrote his will April 4 and died April 7. His grandfather Rev. Henry Flint of Braintree — appointed guardian in the will — died April 27, twenty days after."},{"number":2,"category":"career","header":"His wife refused to let him be ordained","body":"He served as minister at Woodbridge, New Jersey from 1695 without ordination — his wife Alice Mason opposed permanent settlement there. In 1701 he told the church committee: \"There is no hope of my wife's compliance with my settling here, and therefore I would advise you to look out for another.\" He eventually became a Justice of the Peace in Woodbridge instead."},{"number":3,"category":"career","header":"Harvard 1685 — became a New Jersey JP","body":"He graduated Harvard in 1685, the son and grandson of Harvard men. After leaving the Woodbridge ministry he remained in New Jersey, eventually serving as Justice of the Peace for Middlesex County. In a 1706 deed he described himself as one of \"Her Majesty's Justices of the Peace in the Town of Woodbridge.\" He died circa 1722-3."}],"is_placeholder":false,"baptism":{"year":1667,"month":8,"day":25,"city":"Rowley","state":"Massachusetts","country":"United States"},"residence":{"city":"Woodbridge","county":"Middlesex","state":"New Jersey","country":"United States"},"institutions":[{"institution_id":"INST002","institution_blurb":"Harvard B.A. 1685."}],"landmarks":[],"naming_inspiration":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"education":[{"institution_id":"INST002","degrees":[{"degree":"B.A.","year":1685}],"notes":"Paternal grandfather was Rev. Thomas Shepard of Cambridge"}],"bio":{"display_name":"Samuel Shepard","first_name":"Samuel","last_name":"Shepard","married_names":[]},"documents":[],"artworks":[],"military_service":[],"slug":"samuel-shepard-1667"},"I00178":{"id":"I00178","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00038","date_year":1698,"date_month":7,"date_day":14,"location_city":"Boston","location_state":"Massachusetts","location_country":"United States","children_ids":[]}],"parents":{},"notable