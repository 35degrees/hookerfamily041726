HD4641","HD4642","HD4643","HD4644","HD4645"]}],"education":[],"career":[{"role":"Newspaper Makeup Editor","organization":"St. Paul Pioneer Press Dispatch, Saint Paul, Minnesota","end_year":1936,"notes":"Makeup editor — responsible for typography, page layout, and press production. Nine years at the Pioneer Press Dispatch; fifty years in newspapers total."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["newspaper"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Fifty years in newspapers, ending in Saint Paul","body":"Robert Drake Strong spent fifty years in the newspaper trade, working as makeup editor of the St. Paul Pioneer Press Dispatch — a craft requiring command of typography, page layout, and production under deadline pressure, invisible to readers but essential to every edition. His career carried him from the Milwaukee frontier family of his father Robert Hunter Strong to the newspaper rooms of the Twin Cities, where the printed word had been his vocation since before Minnesota had achieved the scale of a major American press market."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"History of Descendants of Elder John Strong, Vol. 1 (1871)","url":"https://dn720908.ca.archive.org/0/items/historyofdescend0001dwig/historyofdescend0001dwig.pdf"},{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"robert-strong-1863"},"I00925":{"id":"I00925","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Mary","middle_name":"Dibb","last_name":"Strong","maiden_name":"Dibb","married_names":["Strong"],"gender":"female","display_name":"Mary Dibb Strong"},"birth":{"year":1863,"month":10,"day":12,"state":"Minnesota","country":"United States"},"baptism":{},"death":{