ndmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"William John","last_name":"Clarke","display_name":"Col. William John Clarke","gender":"male","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780855314/26009835_3eadac99-00f9-447a-b4e7-bdd56eb411c4_bizkxn.jpg","bio_blurb":"Confederate colonel and New Bern judge"},"military_service":[{"war":"Mexican-American War","active_in_war":true,"rank":"Captain (Brevet Major)","role":"12th U.S. Infantry","battles":[]},{"war":"American Civil War","active_in_war":true,"rank":"Colonel","role":"Commanded the 24th North Carolina Infantry, C.S.A.","battles":["Drewry's Bluff 1864"],"notes":"Wounded at Drewry's Bluff, 15 May 1864; captured near Dinwiddie Court House and imprisoned at Fort Delaware until July 1865."}],"career":[{"role":"Dean, School of Medicine","organization":"Washington University","location":"St. Louis, Missouri","start_year":1917,"end_year":1923},{"role":"Dean, Medical School","organization":"University of California","location":"Berkeley, California","start_year":1936}],"birth":{"year":1819,"month":8,"day":2,"city":"Raleigh","county":"Wake","state":"North Carolina","country":"United States"},"death":{"year":1886,"month":1,"day":23,"city":"New Bern","county":"Craven","state":"North Carolina","country":"United States"},"burial":{"cemetery_name":"Cedar Grove Cemetery","city":"New Bern","county":"Craven","state":"North Carolina","country":"United States"},"slug":"william-john-clarke-1819"},"HD5936":{"id":"HD5936","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"female","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"include_in_path_calculation":true,"is_easter_egg":false,"generation_from_thomas":8},"notable":{"is_notable":true,"notable_category":["author","poetry"],"notable_blurb":"North Carolina poet and editor","primary_url":"https://en.wikipedia.org/wiki/Mary_Bayard_Devereux_Clarke"},"parents":{"father_id":"HD2592","mother_id":"X00872"},"number_of_marriages":1,"marriages":[{"spouse_id":"I01588","children_ids":["HD5937","HD5938","HD5939","HD5940"],"marriage_number":1}],"tags":["author"],"narrative_blocks":[{"number":1,"category":"literature","header":"She set out to prove Carolina's literary worth","body":"Writing as Tenella, Mary Bayard Clarke compiled Wood Notes, the first anthology of North Carolina poetry, then filled magazines North and South with her own verse and prose. The Raleigh News and Observer later mourned her as one of the state's most gifted daughters."},{"number":2,"category":"career","header":"She wrote to keep her family afloat","body":"After her husband returned from Confederate prison broken in health and income, Clarke turned her pen into the household's support, editing journals and selling hymns at five dollars apiece. She translated Victor Hugo's poems so ably that the work drew notice in France."},{"number":3,"category":"family","header":"Her gifts passed to daughter and granddaughter","body":"Clarke's daughter Mary married the photographer Rufus Morgan, and her granddaughter Bayard Wootten became one of the South's pioneering photographers. The family's creative streak ran from Mary Bayard's verse to the camera lens within two generations."},{"category":"literature","header":"She hid behind a string of pen names","body":"Clarke published as Tenella and Betsey Bittersweet, names that let a Southern woman write freely for a press that frowned on it. Her satirical political pieces during Reconstruction drew particular notice.","number":4},{"category":"family","header":"One family's women wrote for both sides","body":"Mary Bayard Clarke's verse and her sister Catherine's war diary spoke for the Confederacy, while their first cousin Lillie Devereux Blake became a leading Northern suffragist. The Devereux women left a literary record spanning the divide of the Civil War.","number":5}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"family_connection","related_id":"HD2595","display_label":"her first cousin and a Northern woman suffragist"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Mary Bayard","last_name":"Clarke","display_name":"Mary Bayard Devereux Clarke","gender":"female","married_names":[],"maiden_name":"Devereux","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780855193/Clarke_Mary_Bayard_bs8mdz.jpg","also_known_as":["Tenella","Betsey Bittersweet"]},"military_service":[],"career":[{"role":"Author and translator"},{"role":"Editor","organization":"Southern Field and Fireside","start_year":1865}],"birth":{"year":1827,"month":5,"day":13,"city":"Raleigh","county":"Wake","state":"North Carolina","country":"United States"},"death":{"year":1886,"month":3,"day":30,"city":"New Bern","county":"Craven","state":"North Carolina","country":"United States"},"burial":{"cemetery_name":"Cedar Grove Cemetery","city":"New Bern","county":"Craven","state":"North Carolina","country":"United States"},"education":[{"school_name":"Educated by governesses (Princeton and Yale curriculum)","type":"tutored"}],"slug":"mary-bayard-clarke-1827"},"HD2592":{"id":"HD2592","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00866","mother_id":"HD2591"},"tags":["lawyer","slaveholder"],"sources":[{"short":"Online vital records; The Record LXXI; EH 1909"}],"birth":{"year":1793,"month":11,"day":17,"city":"New Bern","county":"Craven","state":"North Carolina","country":"United States"},"death":{"year":1869,"month":3,"day":7,"city":"Halifax","county":"Halifax","state":"North Carolina","country":"United States"},"marriages":[{"spouse_id":"X00872","children_ids":["HD2607","HD5936"],"marriage_number":1},{"spouse_id":"X01883","children_ids":[],"marriage_number":2,"date_year":1837}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Thomas Pollock Devereux","first_name":"Thomas","last_name":"Devereux","middle_name":"Pollock","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780856771/thomdev_wgx3vv.png","bio_blurb":"North Carolina lawyer, Supreme Court reporter, planter"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_name":"City Cemetery","city":"Raleigh","county":"Wake","state":"North Carolina","country":"United States"},"career":[{"role":"U.S. Attorney for the District of North Carolina"},{"role":"Reporter of the North Carolina Supreme Court","start_year":1826,"end_year":1839,"notes":"Published four volumes of law and two of equity reports (\"Devereux's Reports\")."},{"role":"Trustee","organization":"University of North Carolina","start_year":1820,"end_year":1827}],"education":[{"school_name":"Yale College","type":"college","dates":"graduated 1813"},{"school_name":"Litchfield Law School","type":"law","dates":"1813-1815"}],"narrative_blocks":[{"category":"law","header":"His law reports still bear his name","body":"As reporter of the North Carolina Supreme Court from 1826, Devereux published four volumes of law and two of equity that lawyers cited for generations as Devereux's Reports. He took up law in earnest only after business reverses spent his inherited fortune.","number":1},{"category":"character","header":"He held fifteen hundred people in bondage","body":"Inheriting his uncle's plantations, Devereux became one of North Carolina's largest enslavers, the people he held valued near three-quarters of a million dollars at emancipation. A staunch Unionist before secession, he backed the Confederacy once war came.","number":2}],"slug":"thomas-devereux-1793"},"X00872":{"id":"X00872","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1796},"death":{"year":1836},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2592","children_ids":["HD2607","HD5936"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Catherine Anne Johnson","first_name":"Catherine","middle_name":"Anne","maiden_name":"Johnson","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"catherine-johnson-1796"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}