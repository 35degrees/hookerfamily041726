se,"has_descendants_documented":false,"bio":{"title":"Colonel","first_name":"John","last_name":"Winder","married_names":[],"gender":"male","display_name":"Colonel John Winder"},"birth":{"year":1804,"month":11,"day":24,"city":"Uniontown","county":"Fayette County","state":"Pennsylvania","country":"United States"},"baptism":{},"death":{"year":1897,"month":9,"day":26,"city":"Detroit","county":"Wayne County","state":"Michigan","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM437","plot_notes":"Elmwood Cemetery Detroit per FA"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H02016","date_year":1836,"location_country":"United States","children_ids":["HD4618","HD4619","HD4620"]}],"education":[],"career":[{"role":"Clerk of Supreme Court of Territory of Michigan","organization":"Michigan Territory","start_year":1826},{"role":"City Clerk","organization":"Detroit, Michigan","start_year":1832,"end_year":1836},{"role":"Clerk of Circuit Court","organization":"Michigan","start_year":1848,"end_year":1870},{"role":"Colonel","organization":"Michigan State Militia","notes":"On staffs of many Michigan governors; member of the Brady Guards of Detroit."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["extraordinary_longevity"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"character","header":"Michigan militia colonel who lived to ninety-two","body":"John Winder served as City Clerk of Detroit from 1832 to 1836, Clerk of the Circuit Court from 1848 to 1870, and as a colonel on the staffs of numerous Michigan governors — a civic career spanning over four decades in the early American Midwest. He died in Detroit on September 26, 1897 at the extraordinary age of ninety-two, surviving his wife Martha Cornelia Strong by nearly three years."}],"quotes":[],"sources":[{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"john-winder-1804"},"H02016":{"id":"H02016","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Martha","middle_name":"Cornelia","last_name":"Strong","married_names":[],"gender":"female","display_name":"Martha Cornelia Strong"},"birth":{"year":1818,"month":4,"day":13,"city":"Rochester","county":"Monroe County","state":"New York","country":"United States"},"baptism":{},"death":{"year":1901,"month":1,"day":20,"city":"Detroit","county":"Wayne County","state":"Michigan","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM437","plot_notes":"Elmwood Cemetery Detroit per FA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"generation_from_john_talcott":6,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00900","mother_id":"H00795"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00912","date_year":1836,"location_country":"United States","children_ids":["HD4618","HD4619","HD4620"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Bertha, her twin, died young at twenty-eight","body":"Martha Cornelia Strong was born as a twin with her sister Bertha Rosabella on April 13, 1818 in Rochester, New York. Bertha died in 1846 at age twenty-eight; Martha survived as a starred entry in the Hooker genealogy."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"History of Descendants of Elder John Strong, Vol. 1 (1871)","url":"https://dn720908.ca.archive.org/0/items/historyofdescend0001dwig/historyofdescend0001dwig.pdf"}],"research_sources":[],"documents":[],"slug":"martha-strong-1818"},"I00900":{"id":"I00900","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"title":"Judge","first_name":"Elisha","middle_name":"Beebe","last_name":"Strong","married_names":[],"gender":"male","display_name":"Elisha Beebe Strong"},"birth":{"year":1788,"month":11,"day":29,"city":"Hartford","county":"Hartford County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1867,"month":10,"day":12,"city":"Detroit","county":"Wayne County","state":"Michigan","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM436","plot_notes":"Mount Hope Cemetery Rochester NY per FA"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["politics","law"],"notable_blurb":"First Judge of Monroe County, NY; Yale 1809","primary_url":"https://en.wikipedia.org/wiki/Elisha_Beebe_Strong","primary_url_label":"Wikipedia"},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00795","date_year":1813,"date_month":6,"date_day":24,"location_country":"United States","end_type":"death_of_spouse","end_year":1850,"children_ids":["H02014","H02015","H02016","H02017","H02018","H02019","H02020","H02021"]}],"education":[{"institution_id":"INST022","school_name":"Yale College","dates":"1809","type":"bachelor","notes":"Prepared for college by Nathan Johnson. Yale class of 1809."},{"institution_id":"INST024","school_name":"Litchfield Law School","dates":"1810","type":"law","notes":"Attended Litchfield Law School 1810; thereafter read law in Canandaigua NY."}],"career":[{"role":"Lawyer","organization":"Canandaigua, New York","start_year":1812,"end_year":1816,"notes":"Partner with William H. Adams. Admitted to bar 1812."},{"role":"Land Developer","organization":"Rochester, New York","start_year":1816,"notes":"Purchased 1,000 acres near Rochester with Elisha Beach; developed Carthage area; erected storehouses, incline railway, bridge over lower falls."},{"role":"Member of NY State Assembly","organization":"Ontario County, New York","start_year":1819,"end_year":1820,"notes":"Elected from Ontario County."},{"role":"First Judge of Monroe County","organization":"Monroe County, New York","start_year":1821,"end_year":1823,"notes":"Appointed March 5, 1821 by Governor DeWitt Clinton. Monroe County organized February 23, 1821."},{"role":"Lawyer","organization":"Detroit, Michigan","start_year":1861,"end_year":1867,"notes":"Moved to Detroit 1861; died there Oct 14, 1867."}],"military_service":[],"institutions":[{"institution_id":"INST024","relationship":"alumnus","institution_blurb":"Attended 1810; appointed first judge of Monroe County NY by 1821."},{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["yale_graduate","lawyer","judge","politician"],"research_tags":[],"cross_connections":[{"type":"parallel_descent","related_id":"I00055","display_label":"Both Strong men who married Hooker descendants, 84 years apart","link_text":"Capt. Asahel Strong Jr."}],"narrative_blocks":[{"number":1,"category":"politics","header":"First Judge of Monroe County, appointed 1821","body":"Elisha Beebe Strong was appointed the first judge of Monroe County, New York on March 5, 1821 by Governor DeWitt Clinton — just days after the county itself was organized by the state legislature from Ontario County territory. A Yale graduate (1809) and Litchfield Law School alumnus, he had also served in the New York State Assembly in 1819-1820 and as a presidential elector in 1824, becoming one of the most prominent legal figures in upstate New York."},{"number":2,"category":"marriage","header":"His Hooker marriage repeated a Strong family tradition","body":"When Elisha Beebe Strong married Dolly Goodwin Hooker in 1813 at Canandaigua, New York, he was not the first Strong to wed a Thomas Hooker descendant: 84 years earlier, his ancestral kin Captain Asahel Strong Jr. had married Sarah Hooker of Farmington, Connecticut in 1729, producing a line that named a grandson 'Asahel Hooker Strong' to preserve the memory. The two unions — Farmington 1729, Canandaigua 1813 — trace the same Strong-Hooker affinity across the Great Migration and the early Republic, from a Farmington lawyer's household to a frontier judge's courtroom on the Erie Canal."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave","url":"https://www.findagrave.com"},{"label":"Wikipedia — Elisha Beebe Strong","url":"https://en.wikipedia.org/wiki/Elisha_Beebe_Strong"},{"label":"Litchfield Law School Biographical Ledger","url":"https://ledger.litchfieldhistoricalsociety.org/ledger/students/2494"}],"research_sources":[],"documents":[],"slug":"elisha-strong-1788"},"H00795":{"id":"H00795","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":true,"is_easter_egg":false,"generation_from_john_talcott":5},"birth":{"year":1787},"parents":{"father_id":"H00348","mother_id":"X00319"},"tags":[],"sources":[{"short":"Edward Hooker 1909","entry":"795"},{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"death":{"year":1850,"month":2,"day":15,"city":"Rochester","county":"Monroe County","state":"New York","country":"United States"},"gender":"female","marriages":[{"spouse_id":"I00900","children_ids":["H02014","H02015","H02016","H02017","H02018","H02019","H02020","H02021"],"marriage_number":1,"date_year":1813,"date_month":6,"date_day":24}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"parallel_descent","related_id":"H00103","display_label":"Hooker women who married Strongs in 1729 and 1813","link_text":"Sarah Hooker Strong"}],"bio":{"display_name":"Dolly Goodwin Hooker","first_name":"Dolly","middle_name":"Goodwin","maiden_name":"Hooker","married_names":[],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"politics","header":"Her husband was Monroe County's first judge","body":"Dolly Goodwin Hooker married Elisha Beebe Strong, who in 1821 became the first judge of Monroe County, New York. She died in Rochester in 1850; he remarried and moved to Detroit, dying there in 1867."},{"number":2,"category":"marriage","header":"Her Hooker-Strong marriage echoed one from 1729","body":"When Dolly Goodwin Hooker married Elisha Beebe Strong in 1813, she entered a family that had already wed into the Hooker line 84 years before: Captain Asahel Strong Jr. had married her distant cousin Sarah Hooker at Farmington in 1729, and a grandson of that marriage — Asahel Hooker Strong — was already carrying her maiden name as his own middle name by 1776. Dolly's marriage completed the second arc; her great-grandson Beebe Hooker Strong, born in Milwaukee in 1866, would carry the name to a third generation on the Wisconsin frontier."}],"burial":{"cemetery_id":"CEM436","plot_notes":"Mount Hope Cemetery Rochester NY per FA"},"slug":"dolly-hooker-1787"}},"burialCemetery":{"id":"CEM441","name":"Clinton Grove Cemetery","location":{"city":"Clinton Township","county":"Macomb County","state":"Michigan","country":"United States"},"url":"https://www.findagrave.com/cemetery/286/clinton-grove-cemetery","hooker_connections":["HD4620"]},"institutionsById":{},"crossConnections":[]}