ust ended","body":"Durrell Crosby Davis died on November 12, 1918 — one day after the Armistice that ended the First World War — from an accidental gunshot wound in Prineville, Oregon, where he was serving as principal of Stayton High School. The cruel timing placed his death in the first hours of the peace that so many had sacrificed for; he was twenty-four years old, recently married to Ellen Violet Hinz, and the father of an infant daughter."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"durrell-davis-1893"},"HD4632":{"id":"HD4632","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Wells","middle_name":"Hawley","last_name":"Strong","married_names":[],"gender":"male","display_name":"Wells Hawley Strong"},"birth":{"year":1860,"month":2,"day":29,"state":"Wisconsin","country":"United States"},"baptism":{},"death":{"year":1860,"month":12,"day":3,"country":"United States"},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"generation_from_john_talcott":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H02018","mother_id":"I00916"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_in_infancy"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"History of Descendants of Elder John Strong, Vol. 1 (1871)","url":"https://dn720908.ca.archive.org/0/items/historyofd