g was the son of the second Strong-Hooker marriage — Judge Elisha Beebe Strong and Dolly Goodwin Hooker — and the father of the man who would carry that name to a third generation: Beebe Hooker Strong, born Milwaukee 1866. He came to Wisconsin around 1830 at age ten, making the journey from the Rochester land grants his father had built to the Great Lakes frontier, and with him the Strong-Hooker legacy crossed into a new American West."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"History of Descendants of Elder John Strong, Vol. 1 (1871)","url":"https://dn720908.ca.archive.org/0/items/historyofdescend0001dwig/historyofdescend0001dwig.pdf"}],"research_sources":[],"documents":[],"slug":"robert-strong-1820"},"HD4626":{"id":"HD4626","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"title":"Doctor","first_name":"Warner","middle_name":"Bryant","last_name":"Strong","married_names":[],"gender":"male","display_name":"Doctor Warner Bryant Strong"},"birth":{"year":1861,"month":9,"day":30,"city":"Wauwatosa","county":"Milwaukee County","state":"Wisconsin","country":"United States"},"baptism":{},"death":{"year":1927,"month":5,"day":3,"city":"Chicago","county":"Cook County","state":"Illinois","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM440","plot_notes":"Forest Home Cemetery Milwaukee per FA and Waukesha Freeman obit May 1927"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"generation_from_john_talcott":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H02018","mother_id":"I00916"},"number_of_marriages":1,"marr