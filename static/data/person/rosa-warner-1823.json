h_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Died at twenty-nine; he became Wisconsin's radical voice","body":"Marian Caldwell Strong Amlie died on May 4, 1930 at age twenty-nine — just one year before her husband Thomas Ryum Amlie was first elected to Congress, and two years before he became one of the most radical legislative voices of the New Deal era, described by the Wall Street Journal as sponsoring legislation to put 'the federal government in control of all industry by practical socialization.' She was buried at Forest Home Cemetery in Milwaukee, the same ground that holds her father Beebe Hooker Strong — both a Wisconsin civic leader and his daughter, both returned to the cemetery Milwaukee's pioneers had established."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"History of Descendants of Elder John Strong, Vol. 1 (1871)","url":"https://dn720908.ca.archive.org/0/items/historyofdescend0001dwig/historyofdescend0001dwig.pdf"},{"label":"FindAGrave","url":"https://www.findagrave.com"},{"label":"Wikipedia — Thomas Ryum Amlie","url":"https://en.wikipedia.org/wiki/Thomas_Ryum_Amlie"}],"research_sources":[],"documents":[],"slug":"marian-amlie-1900"},"HD4649":{"id":"HD4649","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"William","middle_name":"W","last_name":"Strong","married_names":[],"gender":"male","display_name":"William W Strong"},"birth":{"year":1902,"month":9,"day":9,"state":"Wisconsin","country":"United States"},"baptism":{},"death":{"year":1970,"month":12,"day":4,"city":"Scottsdale","county":"Maricopa County","state":"Arizona","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM451","plot_notes":"Green Acres Memorial Park Scottsdale per FA"},"classification":{"is_thomas_descendant":true,"is_talcott_desce