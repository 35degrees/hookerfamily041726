le":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD4627","mother_id":"I00925"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00926","location_country":"United States","children_ids":["HD4646","HD4647"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"frederic-strong-1900"},"HD4628":{"id":"HD4628","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Beebe","middle_name":"Hooker","last_name":"Strong","married_names":[],"gender":"male","display_name":"Beebe Hooker Strong","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778958093/beebestrong_yqiosu.jpg","photo_notes":"Beebe Hooker Strong (1866-1933), prominent Baraboo Wisconsin businessman and local historian"},"birth":{"year":1866,"month":6,"day":19,"city":"Wauwatosa","county":"Milwaukee County","state":"Wisconsin","country":"United States"},"baptism":{},"death":{"year":1933,"country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM440","plot_notes":"Forest Home Cemetery Milwaukee per FA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"generation_from_john_talcott":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H02018","mother_id":"I00916"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00929","location_country":"United States","children_ids":["HD4648","HD4649"]}],"education":[],"career":[{"role":"Treasurer","organization":"Baraboo Gas & Electric Light Company, Baraboo, Wisconsin","notes":"W.H. Hopkins was president; B.H. Strong treasurer per period records."},{"role":"Local historian and civic leader","organization":"Baraboo, Wisconsin","end_year":1933,"notes":"Compiled and preserved historical accounts of the Baraboo region; documented account of how the Baraboo River received its name. Also managed local real estate."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Hooker","inspired_by_id":"H00001","description":"Middle name 'Hooker' honors the maternal Hooker ancestry — his mother was Rosa Searls Warner Strong, wife of Robert Hunter Strong, whose mother Dolly Goodwin Hooker carried the Hooker surname directly."},{"name_element":"Beebe","inspired_by_id":"I00900","description":"First name 'Beebe' honors the Beebe family — his great-grandfather Judge Elisha BEEBE Strong (I00900) took the Beebe surname from his mother Mary Beebe Strong of Windsor, CT."}],"artworks":[],"tags":["named_for_hooker","newspaper"],"research_tags":[],"cross_connections":[{"type":"parallel_descent","related_id":"H00673","display_label":"Both bore the Hooker name through the Strong family, 90 years apart","link_text":"Asahel Hooker Strong"}],"narrative_blocks":[{"number":1,"category":"family","header":"The name 'Hooker' traveled from Farmington to Milwaukee","body":"Beebe Hooker Strong was born in Milwaukee in June 1866, bearing a middle name that traces a 137-year arc: his great-great-grandmother Sarah Hooker of Farmington, Connecticut had married into the Strong family in 1729, her great-great-grandson Asahel Hooker Strong preserved the name in Connecticut in 1776, and his grandmother Dolly Goodwin Hooker married a Strong again in 1813. The 'Hooker' in his name was a deliberate act of genealogical memory — a Wisconsin family's way of honoring the Hartford Puritan founder in whose blood they knew themselves to share."},{"number":2,"category":"legacy","header":"Preserved how the Baraboo River got its name","body":"Beebe Hooker Strong became a prominent civic figure in Baraboo, Wisconsin — Treasurer of the Baraboo Gas & Electric Light Company — where he compiled and preserved the documented account explaining how the Baraboo River received its unusual name, a piece of regional oral history that would otherwise have passed unrecorded. The same instinct that drove him to document local origins animated his family's naming practice: they called him 'Hooker' so that no descendant would forget where they came from, and he spent his career ensuring Baraboo didn't forget where it came from either."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"History of Descendants of Elder John Strong, Vol. 1 (1871)","url":"https://dn720908.ca.archive.org/0/items/historyofdescend0001dwig/historyofdescend0001dwig.pdf"},{"label":"FindAGrave","url":"https://www.findagrave.com"},{"label":"Wisconsin Historical Society — Newspaper Records BA5205","url":"https://www.wisconsinhistory.org/Records/Newspaper/BA5205"}],"research_sources":[],"documents":[],"slug":"beebe-strong-1866"},"I00929":{"id":"I00929","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Mary","middle_name":"Louise","last_name":"Strong","maiden_name":"Caldwell","married_names":["Strong"],"gender":"female","display_name":"Mary Louise Caldwell Strong"},"birth":{},"baptism":{},"death":{},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg"