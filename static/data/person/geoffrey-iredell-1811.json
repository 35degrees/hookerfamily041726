},"birth":{"year":1818,"city":"Philadelphia","state":"Pennsylvania"},"death":{"year":1888,"month":7,"day":22,"city":"Washington","state":"District of Columbia"},"parents":{"father_id":"X00620","mother_id":"HD1914"},"marriages":[{"spouse_id":"X00624","children_ids":["HD1935","HD1936_laura","HD1937_francis"],"marriage_number":1,"date_year":1838}],"tags":[],"sources":[{"short":"Wikipedia","note":"Aaron Burr; WikiTree"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Susan Webb Iredell","first_name":"Elizabeth","last_name":"Iredell","married_names":["Iredell"],"middle_name":"Susan","maiden_name":"Webb"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elizabeth-iredell-1818"},"HD1935":{"id":"HD1935","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1849},"death":{"year":1908},"parents":{"father_id":"X00624","mother_id":"HD1928"},"marriages":[{"spouse_id":"X00627","children_ids":["HD1960"],"marriage_number":1,"date_year":1869}],"tags":["nursing_pioneer","abolitionist_heritage","civil_rights","howard_university"],"sources":[],"gender":"female","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"First Black nursing superintendent at Howard's Freedman's Hospital","primary_url":"https://en.wikipedia.org/wiki/Sara_Iredell_Fleetwood"},"narrative_blocks":[{"number":1,"category":"career","header":"First Black nursing superintendent at Freedman's Hospital","body":"In 1901 she outscored all national applicants on the civil service examination to become the first Black nursing supervisor at Howard's Freedman's Hospital. The institution had been built into a center of Black medicine by Dr. Daniel Hale Williams, who taught her in Freedman's first nursing class."},{"number":2,"category":"family","header":"Wife of a Medal of Honor recipient","body":"She married Sgt. Major Christian Abraham Fleetwood in 1869 — recipient of the Medal of Honor for the Battle of Chaffin's Farm in 1864. Together they hosted weekly literary salons at 319 U Street in LeDroit Park, at the center of Washington's Black professional community."},{"number":3,"category":"family","header":"Great-granddaughter of Aaron Burr","body":"Her great-grandfather Aaron Burr Jr. was the third Vice President; her grandmother Louisa Charlotte Burr was his unacknowledged daughter with Mary Emmons, confirmed by DNA in 2018. She grew up in Philadelphia among Webb cousins, including her uncle Frank J. Webb — author of The Garies and Their Friends."},{"number":4,"category":"social_reform","header":"Co-founded the Colored Women's League of Washington","body":"In 1892 she was one of nine co-founders of the Colored Women's League of Washington. Her LeDroit Park home at 319 U Street is now a marker on the African American Heritage Trail."},{"number":5,"category":"education","header":"Oberlin pupil-teacher in the late 1850s","body":"She attended Oberlin College from 1856 to 1858 as a pupil-teacher — one of the few institutions then open to Black students. She went on to teach in Philadelphia, the Institute for Colored Youth, and schools in Frederick MD and Washington DC before entering nursing in 1893."}],"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Sara Louise Iredell Fleetwood","first_name":"Sara","last_name":"Fleetwood","married_names":["Fleetwood"],"middle_name":"Louise","maiden_name":"Iredell","photo_url":"https://www.wikitree.com/photo.php/0/09/Iredell-53.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST025"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sara-fleetwood-1849"},"X00627":{"id":"X00627","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1840},"death":{"year":1914},"tags":["medal_of_honor","civil_war"],"sources":[],"marriages":[{"spouse_id":"HD1935","children_ids":["HD1960"],"marriage_number":1,"date_year":1869}],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Medal of Honor, Battle of Chaffin’s Farm"},"number_of_marriages":1,"parents":{},"cross_connections":[],"bio":{"display_name":"Christian Abraham Fleetwood","first_name":"Christian","last_name":"Fleetwood","middle_name":"Abraham","married_names":[],"photo_url":"https://www.wikitree.com/photo.php/d/da/Fleetwood-831.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST025"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Civil War","branch":"Union Army","rank":"Sergeant Major","notes":"Medal of Honor, Chaffin’s Farm"}],"narrative_blocks":[{"number":1,"category":"military","header":"A Medal of Honor outside Richmond","body":"Fleetwood’s bravery at the Battle of Chaffin’s Farm in September 1864 earned the Medal of Honor, among the African American soldiers decorated for that single day’s fighting. He went on to clerk for the Freedmen’s Bureau and to organize Washington’s first Black National Guard unit."},{"number":2,"category":"arts","header":"Literary salons at 319 U Street","body":"He and Sara hosted weekly literary salons at their home in LeDroit Park, one of Black Washington’s intellectual centers. His papers went to the Library of Congress in 1947."}],"slug":"christian-fleetwood-184