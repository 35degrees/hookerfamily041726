ty":"Cedar Falls","state":"Iowa"},"marriages":[{"marriage_number":1,"spouse_id":"HD6335","date_year":1925,"children_ids":[]}],"burial":{"cemetery_id":"CEM873"},"narrative_blocks":[{"number":1,"category":"family","header":"The caretaker became the wife","body":"She came to the Leavitt home in 1905 to care for the young children, their mother an invalid; twenty years later — two years after Katherine’s death — she married Roger. They had no children."}],"slug":"mary-larsen-leavitt-x03318"},"HD0870":{"id":"HD0870","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD0868","mother_research_notes":"Keziah Osgood Hunt","mother_id":"X01344"},"tags":["named_for_hooker","banker"],"sources":[],"birth":{"year":1831,"month":10,"day":11,"county":"Franklin","state":"Massachusetts"},"death":{"year":1906,"month":9,"day":25,"city":"Waterloo","state":"Iowa"},"prominent_name_reason":"John Hooker Leavitt (1831-1906) — Iowa banker, state senator, philanthropist. Pioneer of Waterloo, Iowa 1854; founded Leavitt & Johnson National Bank. Iowa State Senate 1871. Early benefactor of Talladega College, Alabama's oldest HBCU. Wikipedia: https://en.wikipedia.org/wiki/John_Hooker_Leavitt Named \"Hooker\" for Hooker ancestry.","gender":"male","marriages":[{"marriage_number":1,"spouse_id":"X03315","date_year":1858,"date_month":1,"date_day":1,"children_ids":["HD6334","HD6335","HD6336","HD6337","HD6338","HD6339"]}],"notable":{"is_notable":true,"primary_url":"https://en.wikipedia.org/wiki/John_Hooker_Leavitt","primary_url_label":"Wikipedia","notable_blurb":"Waterloo pioneer banker and Iowa senator","notable_category":["business","politics"]},"cross_connections":[],"bio":{"display_name":"John Hooker Leavitt","first_name":"John","last_name":"Leavitt","middle_name":"Hooker","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781294268/67713297_a424791d-a9e8-4a4d-9781-c27295949098-resized_kywsqz.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM870"},"career":[{"role":"Founder and president","organization":"Leavitt & Johnson National Bank, Waterloo","start_year":1856,"end_year":1901},{"role":"Senator","organization":"Iowa Senate","start_year":1871}],"narrative_blocks":[{"number":1,"category":"business","header":"He surveyed for the Brooklyn Bridge builder","body":"Trained as a civil engineer, young Leavitt was contracted by John Roebling to survey a large tract — then struck west in 1854 and traded the transit for a Waterloo banking house that bore his name for half a century."},{"number":2,"category":"social_reform","header":"An early benefactor of Talladega College","body":"The son of Underground Railroad conductors became an early benefactor of Alabama’s oldest historically Black college, and joined the Pocumtuck Valley Memorial Association where his father had been vice president. In the Iowa Senate he fought James Harlan’s return to Washington."}],"number_of_marriages":1,"slug":"john-leavitt-1831"},"X03315":{"id":"X03315","bio":{"display_name":"Caroline C. Ware Leavitt","gender":"female","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781294736/caroline_qru01h.png"},"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"has_descendants_documented":true,"number_of_marriages":1,"tags":[],"sources":[],"birth":{"year":1836,"month":10,"day":11,"city":"Granville","state":"Illinois"},"death":{"year":1917,"month":2,"day":19,"city":"Waterloo","state":"Iowa"},"marriages":[{"marriage_number":1,"spouse_id":"HD0870","date_year":1858,"children_ids":["HD6334","HD6335","HD6336","HD6337","HD6338","HD6339"]}],"burial":{"cemetery_id":"CEM870"},"narrative_blocks":[{"number":1,"category":"character","header":"She drove a stagecoach at a dead run","body":"Born to the Illinois frontier, she could ride the wildest colt in the pasture and once drove a four-horse stage at a dead run to catch a train; two Iowa runaway accidents — one that injured her badly — never slowed her."},{"number":2,"category":"social_reform","header":"A man presided; she ran the school","body":"Superintendent of Waterloo’s Congregational Sunday school in the late 1860s — when a woman could not properly speak aloud in church — she did all the planning while a male assistant presided, and the school doubled. She taught there more than fifty years."}],"slug":"caroline-c-ware-leavitt-x03315"},"HD0868":{"id":"HD0868","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00685","mother_id":"X00252"},"tags":["underground_railroad","abolitionist"],"sources":[],"birth":{"year":1805,"month":7,"day":21,"city":"Heath","state":"Massachusetts"},"death":{"year":1885,"month":7,"day":17,"city":"Waterloo","state":"Iowa"},"marriages":[{"children_ids":["HD0870"],"spouse_id":"X01344","marriage_number":1},{"marriage_number":2,"spouse_id":"X03311","date_year":1839,"children_ids":[]},{"marriage_number":3,"spouse_id":"X03312","date_year":1877,"children_ids":[]},{"marriage_number":4,"spouse_id":"X03313","date_year":1882,"children_ids":[]}],"prominent_name_reason":"Col. Roger Hooker Leavitt — Underground Railroad operator. His home in Charlemont MA is on the National Park Service's National Underground Railroad Network to Freedom. Sheltered fugitive slave Basil Dorsey (escaped Frederick County MD 1836) for over five years. Colonel in the Massachusetts militia. Member of Massachusetts legislature. Advocate for the Hoosac Tunnel. Died in Waterloo, Iowa visiting son John Hooker Leavitt, 1885. Wikipedia: https://en.wikipedia.org/wiki/Roger_Hooker_Leavitt Family correspondence at Library of Congress Manuscript Division.","gender":"male","number_of_marriages":4,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Underground Railroad conductor; Massachusetts senator","primary_url":"https://en.wikipedia.org/wiki/Roger_Hooker_Leavitt","primary_url_label":"Wikipedia"},"cross_connections":[],"bio":{"display_name":"Roger Hooker Leavitt","notes":"Named \"Hooker\" honoring maternal Hooker ancestry through grandmother Sarah Hooker (H00302).","first_name":"Roger","last_name":"Leavitt","middle_name":"Hooker","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781293573/28545170_1497140793_i5iubz.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM868"},"education":[{"school_name":"Hopkins Academy, Hadley","type":"secondary"},{"school_name":"Dartmouth College","type":"undergraduate","notes":"briefly"}],"career":[{"role":"Senator","organization":"Massachusetts Senate"},{"role":"President","organization":"Franklin County Anti-Slavery Society","start_year":1836},{"role":"Incorporator","organization":"Troy & Greenfield Railroad","start_year":1848}],"narrative_blocks":[{"number":1,"category":"social_reform","header":"Basil Dorsey lived five years in hiding","body":"The fugitive Basil Dorsey, escaped from Maryland in 1836, sheltered more than five years among the Leavitt households at Charlemont — hidden in plain sight while the 1840 census recorded no persons of color there. Brother Joshua wrote from New York: “do all that Christian benevolence requires in his care.”"},{"number":2,"category":"social_reform","header":"The Utica mob converted his parents","body":"Violence by pro-slavery factions at the October 1835 Utica convention — which he attended with brothers Joshua and Hart — fully converted the elder Leavitts to the cause. Within a year he was president of the Franklin County Anti-Slavery Society."},{"number":3,"category":"family","header":"Four wives, the last at seventy-six","body":"Widowed of Keziah Osgood Hunt in 1838, he married her sister Eliza the next year; Olive Warriner in Chicago at seventy-one; and at seventy-six, the schoolteacher Lucy Trowbridge — her first marriage, at fifty-one. He was also among the earliest promoters of the Hoosac Tunnel."}],"slug":"roger-leavitt-1805"},"X01344":{"id":"X01344","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0868","children_ids":["HD0870"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1807,"month":4,"day":17,"city":"Heath","state":"Massachusetts"},"death":{"year":1838,"month":11,"day":11,"city":"Charlemont","state":"Massachusetts"},"cross_connections":[],"bio":{"display_name":"Keziah Osgood Hunt","first_name":"Keziah","middle_name":"Osgood","maiden_name":"Hunt","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781293928/28545375_c9ffafc3-25a6-4fb6-9319-238c71c66f03_ocftks.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM868"},"narrative_blocks":[{"number":1,"category":"family","header":"Dead at thirty-one, three sons left","body":"She died in November 1838 — the same year Basil Dorsey’s wife died under the family’s protection — leaving John Hooker, William Hunt, and Henry Jenkins, the eldest just seven."}],"slug":"keziah-hunt-1807"}},"burialCemetery":{"id":"CEM870","name":"Elmwood Cemetery","city":"Waterloo","county":"Black Hawk","state":"Iowa","country":"United States","visitable":true,"hooker_connections":["HD0870","X03315","HD6335","X03316","X03317","HD6340","X03319","HD6344","X03323"]},"institutionsById":{},"crossConnections":[]}