"start_year":1840}],"narrative_blocks":[{"number":1,"category":"social_reform","header":"The Liberty Party’s man for Lieutenant Governor","body":"President of the Franklin County Anti-Slavery Society, he accepted the new Massachusetts Liberty Party’s 1840 nomination for Lieutenant Governor — the abolitionist ticket his son Joshua’s party-building made possible. His household sheltered Basil Dorsey alongside his sons’."}],"slug":"roger-leavitt-1771"},"X00252":{"id":"X00252","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["abolitionist"],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00685","children_ids":["HD0867","HD0868","HD0869"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1773},"death":{"year":1851,"month":3,"day":19,"city":"Charlemont","state":"Massachusetts"},"cross_connections":[],"bio":{"display_name":"Chloe Maxwell Leavitt","first_name":"Keziah","middle_name":"Osgood","maiden_name":"Maxwell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM868"},"narrative_blocks":[{"number":1,"category":"social_reform","header":"She petitioned to free the capital","body":"Chloe circulated a petition demanding the abolition of slavery in the District of Columbia while her husband ran for Lieutenant Governor on the Liberty ticket and her sons ran the Underground Railroad."}],"slug":"keziah-maxwell-1773"}},"burialCemetery":{"id":"CEM870","name":"Elmwood Cemetery","city":"Waterloo","county":"Black Hawk","state":"Iowa","country":"United States","visitable":true,"hooker_connections":["HD0870","X03315","HD