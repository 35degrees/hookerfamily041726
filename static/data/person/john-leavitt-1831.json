 Leavitt","gender":"male"},"classification":{"include_in_path_calculation":false,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"has_descendants_documented":false,"number_of_marriages":0,"tags":[],"sources":[],"birth":{"year":1869},"death":{"year":1937},"marriages":[],"parents":{"father_id":"HD0870","mother_id":"X03315"},"slug":"joseph-lyman-leavitt-hd6338"},"HD6339":{"id":"HD6339","bio":{"display_name":"Grace L. Leavitt Cascaden","gender":"female"},"classification":{"include_in_path_calculation":false,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"has_descendants_documented":false,"number_of_marriages":1,"tags":[],"sources":[],"birth":{"year":1873},"death":{"year":1965},"marriages":[{"marriage_number":1,"spouse_id":null,"children_ids":[]}],"parents":{"father_id":"HD0870","mother_id":"X03315"},"slug":"grace-l-leavitt-cascaden-hd6339"},"HD0868":{"id":"HD0868","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00685","mother_id":"X00252"},"tags":["underground_railroad","abolitionist"],"sources":[],"birth":{"year":1805,"month":7,"day":21,"city":"Heath","state":"Massachusetts"},"death":{"year":1885,"month":7,"day":17,"city":"Waterloo","state":"Iowa"},"marriages":[{"children_ids":["HD0870"],"spouse_id":"X01344","marriage_number":1},{"marriage_number":2,"spouse_id":"X03311","date_year":1839,"children_ids":[]},{"marriage_number":3,"spouse_id":"X03312","date_year":1877,"children_ids":[]},{"marriage_number":4,"spouse_id":"X03313","date_year":1882,"children_ids":[]}],"prominent_name_reason":"Col. Roger Hooker Leavitt — Underground Railroad operator. His home in Charlemont MA is on the National Park Service's National Underground Railroad Network to Freedom. Sheltered fugitive slave Basil Dorsey (escaped Frederick County MD 1836) for over five years. Colonel in the Massachusetts militia. Member of Massachusetts legislature. Advocate for the Hoosac Tunnel. Died in Waterloo, Iowa visiting son John Hooker Leavitt, 1885. Wikipedia: https://en.wikipedia.org/wiki/Roger_Hooker_Leavitt Family correspondence at Library of Congress Manuscript Division.","gender":"male","number_of_marriages":4,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Underground Railroad conductor; Massachusetts senator","primary_url":"https://en.wikipedia.org/wiki/Roger_Hooker_Leavitt","primary_url_label":"Wikipedia"},"cross_connections":[],"bio":{"display_name":"Roger Hooker Leavitt","notes":"Named \"Hooker\" honoring maternal Hooker ancestry through grandmother Sarah Hooker (H00302).","first_name":"Roger","last_name":"Leavitt","middle_name":"Hooker","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781293573/28545170_1497140793_i5iubz.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM868"},"education":[{"school_name":"Hopkins Academy, Hadley","type":"secondary"},{"school_name":"Dartmouth College","type":"undergraduate","notes":"briefly"}],"career":[{"role":"Senator","organization":"Massachusetts Senate"},{"role":"President","organization":"Franklin County Anti-Slavery Society","start_year":1836},{"role":"Incorporator","organization":"Troy & Greenfield Railroad","start_year":1848}],"narrative_blocks":[{"number":1,"category":"social_reform","header":"Basil Dorsey lived five years in hiding","body":"The fugitive Basil Dorsey, escaped from Maryland in 1836, sheltered more than five years among the Leavitt households at Charlemont — hidden in plain sight while the 1840 census recorded no persons of color there. Brother Joshua wrote from New York: “do all that Christian benevolence requires in his care.”"},{"number":2,"category":"social_reform","header":"The Utica mob converted his parents","body":"Violence by pro-slavery factions at the October 1835 Utica convention — which he attended with brothers Joshua and Hart — fully converted the elder Leavitts to the cause. Within a year he was president of the Franklin County Anti-Slavery Society."},{"number":3,"category":"family","header":"Four wives, the last at seventy-six","body":"Widowed of Keziah Osgood Hunt in 1838, he married her sister Eliza the next year; Olive Warriner in Chicago at seventy-one; and at seventy-six, the schoolteacher Lucy Trowbridge — her first marriage, at fifty-one. He was also among the earliest promoters of the Hoosac Tunnel."}],"slug":"roger-leavitt-1805"},"X01344":{"id":"X01344","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0868","children_ids":["HD0870"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1807,"month":4,"day":17,"city":"Heath","state":"Massachusetts"},"death":{"year":1838,"month":11,"day":11,"city":"Charlemont","state":"Massachusetts"},"cross_connections":[],"bio":{"display_name":"Keziah Osgood Hunt","first_name":"Keziah","middle_name":"Osgood","maiden_name":"Hunt","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781293928/28545375_c9ffafc3-25a6-4fb6-9319-238c71c66f03_ocftks.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"nami