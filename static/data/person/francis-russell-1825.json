notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Col. Samuel Andrews Russell","first_name":"Samuel","last_name":"Russell","title":"Colonel","middle_name":"Andrews","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"plot_notes":"Forest Lawn Cemetery, Buffalo NY"},"narrative_blocks":[{"number":1,"category":"career","header":"Postmaster of Buffalo, appointed April 1831","body":"Appointed Postmaster of Buffalo NY in April 1831 by President Andrew Jackson; held the office until his death on 2 July 1834. The Yale biographical sketch summarized: 'loved, esteemed, and respected by all who knew him.'"},{"number":2,"category":"politics","header":"NY Constitutional Convention 1821, Elector 1824","body":"Served as a delegate to the New York State Constitutional Convention of 1821 — which revised the state constitution to broaden suffrage and reorganize the judiciary. Selected as a Presidential Elector for New York in the 1824 election."},{"number":3,"category":"career","header":"Niagara County Judge from April 1817","body":"First appointed Judge in Niagara County NY in April 1817 — shortly after his removal from New York City to Buffalo. Held judicial office in western New York's frontier period when Niagara County still encompassed much of the territory later subdivided into Erie and other counties."},{"number":4,"category":"marriage","header":"Married two of the three Woodward sisters","body":"After his first wife Lucy Munson died at 29 in 1785 leaving a daughter, he married Sarah Woodward of New Haven in November 1790. She died suddenly in New York August 1807; around 1809 he then married her sister Susan Woodward, who died September 1819 in her 63rd year."},{"number":5,"category":"military","header":"Revolutionary War private under Capt. Peter Vail","body":"Served as a private in the Connecticut militia under Captain Peter Vail and Colonel Canfield during the Revolutionary War. SAR Patriot #P-283245 + DAR #A098524. His Yale studies followed wartime service and graduation around 1779 — he remained at Yale as graduate student and Butler until May 1783."}],"slug":"samuel-russell-1759"},"X00414":{"id":"X00414","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"death":{"year":1807,"month":8,"day":8,"city":"New York","state":"New York","country":"United States"},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00844","date_year":1790,"children_ids":["HD1324","HD1325","HD1326","HD1327","HD6128"],"marriage_year":1790}],"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1763,"country":"United States"},"cross_connections":[],"bio":{"display_name":"Sarah Woodward","first_name":"Sarah","maiden_name":"Woodward","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-woodward-1763"}},"burialCemetery":null,"institutionsById":{"INST035":{"id":"INST035","primary_name":"United States Military Academy (West Point)","name":"United States Military Academy (West Point)","alt_names":[],"type":"educational_military","primary_persons":[],"hooker_connected_people":["HD0154","HD1151","HD1154","HD1159","HD1326","T00387","HD1343","HD2163","HD2594","TD0059","HD3016","T01807","T01842","T01802","X02670","HD4700","I00961","HD4703","T01818","HD2280","HD6129","HD6163"],"person_ids":["X00313","X00351","X01917","X00867"],"related_institutions":[],"related_landmarks":[],"tags":["military","educational"],"sources":[],"notes":"Founded 1802 at West Point NY. HOOKER TREE CONNECTION: Rev. George Washington Woodbridge (HD2163), son of General Jonathan Woodbridge (H00928), graduated West Point; served as 2nd Lieutenant US Army 1826-1829 before entering the Episcopal ministry. He became rector of Monumental Church Richmond VA 1843-1878 and escorted Flora Cooke Stuart to her dying husband Jeb Stuart in May 1864."}},"crossConnections":[]}