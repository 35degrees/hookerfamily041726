cendant":false,"is_easter_egg":false},"parents":{"father_id":"H00844","mother_id":"X00414"},"tags":["killed_in_action","second_seminole_war"],"sources":[],"birth":{"year":1797},"death":{"year":1839},"marriages":[{"spouse_id":"X00420","children_ids":["HD1343"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["military"],"notable_blurb":"Killed in the Second Seminole War, 1839"},"cross_connections":[{"type":"family_connection","related_id":"H02539","display_label":"Cousin Edward P. Hooker advocated Seminole education later","link_text":"Rev. Edward Payson Hooker","description":"Capt. Samuel Law Russell was killed fighting in the Second Seminole War in 1839. Roughly fifty years later, his distant cousin Rev. Edward Payson Hooker became founding president of Rollins College in Florida and was a vocal advocate for Seminole education and educational equity — a remarkable arc within one Hooker descent line."}],"military_service":[{"war":"Second Seminole War","war_id":"WAR011","rank":"Captain","unit":"2nd U.S. Infantry Regiment (HHC, 3rd Battalion, 2nd Infantry, 1836-1839)","killed_in_action":true,"service_years":"1819-1839","commission_progression":[{"rank":"Second Lieutenant","date":"1819-08-13","unit":"2nd U.S. Infantry Regiment"},{"rank":"Assistant Commissary Subsistence","date":"1824-07"},{"rank":"First Lieutenant","date":"1827-12"},{"rank":"Captain","date":"1836-06"}],"battles":[{"battle_id":"BTL042","battle_name":"Engagement on the Miami River","year":1839,"month":2,"day":28,"location_city":"Key Biscayne","location_state":"Florida"}],"cause_of_death":"Three musket balls — two in chest, one in brain","notes":"Killed leading his company into battle on the Miami River near Key Biscayne, Feb 28, 1839. Fort Dallas was renamed Fort Russell in his memory."}],"narrative_blocks":[{"number":1,"category":"death","header":"Killed by three balls, two in the chest","body":"On February 28, 1839, leading his infantry company against the Seminoles on the Miami River near Key Biscayne, Captain Russell was struck by three Seminole musket balls — two in the breast and the third in the brain. He died almost instantly at age 40, twenty years to the month after first putting on the uniform of the 2nd U.S. Infantry."},{"number":2,"category":"legacy","header":"The Army renamed the fort after him","body":"Fort Dallas — the U.S. Army's first post on Key Biscayne — was rechristened Fort Russell in his memory, and bore his name for most of its operating life. His regimental officers raised an Italian marble box-tomb over his remains at Governor's Island, inscribed: 'a Christian soldier; a dignified and exemplary gentleman; a tender husband and father.'"}],"bio":{"display_name":"Captain Samuel Law Russell","first_name":"Samuel","last_name":"Russell","title":"Captain","middle_name":"Law","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST035"}],"landmarks":[],"artworks":[],"quotes":[],"slug":"samuel-russell-1797"},"X00420":{"id":"X00420","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1803},"death":{"year":1874},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1326","children_ids":["HD1343"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Sheldon Platt","first_name":"Elizabeth","middle_name":"Sheldon","maiden_name":"Platt","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"eliza