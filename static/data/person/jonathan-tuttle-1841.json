1,"marriages":[{"marriage_number":1,"spouse_id":"I00604","date_year":1836,"date_month":1,"date_day":4,"location_city":"Portage","location_county":"Portage County","location_state":"Ohio","location_country":"United States","children_ids":["HD4130","HD4131"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["ohio_migration"],"research_tags":[],"cross_connections":[{"type":"parallel_descent","related_id":"HD4141","link_text":"Henry Stiles","display_label":"Second cousins via Esther Hooker, both migrated to Ohio"}],"narrative_blocks":[{"number":1,"category":"migration","header":"Migrated to Ohio, married in Portage County","body":"Leonard Tuttle was born in Hamden CT in 1810 but joined the westward migration to Ohio's Western Reserve by his mid-twenties, marrying Hannah Brown in Portage County on January 4, 1836. He lived out his life in Medina County, dying in 1875 and was buried at Woodlawn Cemetery in Lodi — far from the Hamden Mount Carmel ground where his brothers Lucius and Asahel and sister Lucy rest."}],"quotes":[],"sources":[{"label":"FindAGrave #23023184","url":"https://www.findagrave.com/memorial/23023184/leonard-tuttle"}],"research_sources":[],"documents":[],"slug":"leonard-tuttle-1810"},"I00604":{"id":"I00604","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Hannah","last_name":"Tuttle","maiden_name":"Brown","married_names":[],"gender":"female","display_name":"Hannah Brown Tuttle"},"birth":{"year":1815,"month":6,"day":8,"city":"North Hampton","county":"Rockingham County","state":"New Hampshire","country":"United States"},"baptism":{},"death":{"year":1880,"city":"Lodi","county":"Medina County","state":"Ohio","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM317","plot_notes":"Woodlawn Cemetery, Lodi OH — with husband Leonard and daughter Helen Mary."},"classification":{"is_thomas_descendant":false,"is_talcott_desce