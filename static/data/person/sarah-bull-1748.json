,"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Named Hooker to preserve his grandmother's birth name","body":"Asahel Hooker Strong was born on November 8, 1776, in Chatham, Connecticut — the son of Reverend Cyprian Strong D.D. and the grandson of Captain Asahel Strong Jr. and Sarah Hooker Strong of Farmington; his middle name 'Hooker' explicitly preserved the maiden name of a Thomas Hooker descendant, making him the first Strong to carry that name as a living act of genealogical memory. Ninety years later, his distant cousin Beebe Hooker Strong was born in Milwaukee, Wisconsin — the second Strong to be named 'Hooker,' and a testament to how deliberately this frontier family remembered its Connecticut origins."}],"slug":"asahel-strong-1776"},"H00674":{"id":"H00674","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1779,"month":2,"day":17,"city":"Chatham","state":"Connecticut"},"parents":{"father_id":"H00299","mother_id":"X00134"},"tags":["not_yet_fully_entered","replacement_naming"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 674"}],"marriages":[{"spouse_id":"X01340","marriage_number":1,"children_ids":[],"location_city":"Killingworth","location_state":"Connecticut"}],"gender":"unknown","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"death":{},"cross_connections":[],"bio":{"display_name":"Florella Strong No. 2","first_name":"Florella","last_name":"Strong","suffix":"No. 2","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"