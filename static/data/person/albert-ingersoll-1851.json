s":[{"marriage_number":1,"spouse_id":"I01299","date_year":1786,"date_month":4,"date_day":1,"location_city":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1823,"children_ids":["HD5107","HD5108","HD5109","HD5110","HD5111","HD5112","HD5113","HD5114","HD5115","HD5116"]}],"cross_connections":[{"type":"place_overlap","related_id":"H01407","display_label":"Both buried Grove Street Cemetery, New Haven — Hooker descendants","link_text":"Dr. Worthington Hooker"}],"education":[{"degree":"graduate","school_name":"Yale College","graduation_year":1766,"institution_id":"INST022"}],"bio":{"display_name":"Jonathan Ingersoll Jr.","first_name":"Jonathan","last_name":"Ingersoll","suffix":"Jr.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1766"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"politics","header":"Lieutenant Governor of Connecticut, 1816-1823","body":"Jonathan Ingersoll Jr. served as Lieutenant Governor of Connecticut from 1816 until his death in 1823 — the role making him a principal political figure of the early-Republic era in the state. The Lt Governor's office in Connecticut was a significant constitutional post during the years following the 1818 Constitution. His son Ralph I. Ingersoll later described him as 'a gentleman of great moral worth, and among the foremost in his profession.'"},{"number":2,"category":"law","header":"State Attorney, Superior Court Judge, then Lt Governor","body":"Jonathan rose through three principal Connecticut public-service offices in succession — first State Attorney, then a Judge of the Superior Court, then Lieutenant Governor. The progression took him from prosecutorial to judicial to political leadership across the late-eighteenth and early-nineteenth centuries. His judicial reputation rested on the same qualities of moral worth and professional standing that distinguished his political tenure."},{"number":3,"category":"family","header":"Father of US Minister to Russia Ralph Ingersoll","body":"Jonathan's son Ralph I. Ingersoll (born February 8, 1789) followed him into the law and the public service — eight years in the United States Congress (1825-1833), State Attorney for twelve years, Connecticut Minister Plenipotentiary to the Russian court 1846-1848 under President Polk. The Ingersoll legal dynasty was one of the longest-running Connecticut family practices of the nineteenth century. A grandson Charles Roberts Ingersoll became Governor of Connecticut 1873-1877."}],"burial":{"plot_notes":"Grove Street Cemetery, New Haven CT"},"slug":"jonathan-ingersoll-jr-1747"},"I01299":{"id":"I01299","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker_bool":false},"parents":{},"tags":[],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"HD0121","date_year":1786,"date_month":4,"date_day":1,"location_city":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1823,"children_ids":["HD5107","HD5108","HD5109","HD5110","HD5111","HD5112","HD5113","HD5114","HD5115","HD5116"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1772,"country":"United States"},"death":{"year":1850,"age":78,"country":"United States"},"residence":{},"burial":{},"baptism":{},"cross_connections":[],"narrative_blocks":[],"quotes":[],"documents":[],"naming_inspiration":[]