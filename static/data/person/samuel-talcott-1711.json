0035","mother_id":"U00012"},"tags":[],"sources":[{"short":"Talcott 1876","page":"Entry 45"}],"marriages":[{"spouse_id":"U00022","children_ids":["T00065","T00066","T00067","X00436"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1705,"date_year":1693},{"spouse_id":"U00017","children_ids":["T00068","I00054","T00070","T00071","T00072","T00073","X00446"],"marriage_number":2,"end_type":"death_of_spouse","end_year":1738}],"political_offices":[{"title":"Governor","jurisdiction":"Colony of Connecticut","dates":"1724-1741","duration_years":17,"notes":"First Governor of Connecticut born within its limits. Longest-serving after Gov. Winthrop. Died in office Oct 11, 1741."}],"cross_connections":[{"type":"historical_connection","related_id":"H00115","display_label":"Son-in-law signed his estate — 'Nathaniel Hooker and Eunice Hooker'","link_text":"Captain Nathaniel Hooker"},{"type":"family_connection","related_id":"H00360","display_label":"His granddaughter Esther married Rev. Noadiah Russell in 1758","link_text":"Noadiah Russell"},{"type":"civic_peer","related_id":"U00020","display_label":"was the Deputy Governor whose death opened his path","link_text":"Nathan Gold"}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":true,"notable_category":["politics"],"notable_blurb":"First Connecticut governor born within its limits","primary_url":"https://en.wikipedia.org/wiki/Joseph_Talcott","primary_url_label":"Wikipedia"},"narrative_blocks":[{"header":"First Connecticut governor born within the colony","body":"Born in Hartford on November 16, 1669, Joseph Talcott was the first Governor of Connecticut born within the colony rather than in England. He served from 1724 until his death on October 11, 1741 — 17 years in office, longer than any predecessor except Governor Winthrop and any successor until the modern era. His funeral expenses of £69 12s. 6d. were paid from the Colonial Treasury.","number":1,"category":"politics"},{"header":"He presided in the upper house the afternoon","body":"When his wife Eunice died suddenly about noon on Thursday, May 25, 1738, the Deputy Governor was absent at Norwich. Governor Talcott did not let his private grief interfere with his official duty — he returned and presided in the upper house that same afternoon. The General Assembly appointed a committee to draw an address of condolence to the Governor.","number":2,"category":"politics"},{"header":"His estate was signed by 'Nathaniel Hooker","body":"At the Court of Probate, Hartford, on December 25, 1742, the distribution of Governor Talcott's estate was signed by all children as co-heirs. Among the signatures: 'Nathaniel Hooker and Eunice Hooker' — his daughter Eunice Talcott and her husband Nathaniel Hooker 2d. The Talcott-Hooker convergence was entered into the public record.","number":3,"category":"family"},{"header":"Three of his children each found a separate","body":"His daughter Eunice married Nathaniel Hooker 2d — direct Hooker surname. His son Matthew married Mary Russell, a Hooker descendant through the Pierpont branch. His daughter Abigail married Rev. Daniel Wadsworth; their son Jeremiah later married Mary's own sister Mehitable Russell, also a Hooker descendant.","number":4,"category":"family"},{"header":"Petitioned for his father's estate by primogeniture","body":"Joseph Talcott was the fourth son of Lt.-Col. John Talcott Jr. but the eldest to survive his father. In 1691, at age 21, he petitioned the General Court for his father's estate by right of primogeniture — an assertive legal claim for colonial Connecticut. He was first mentioned in public life in 1711 as a committee member to lay out the town of Coventry.","number":5,"category":"law"}],"bio":{"display_name":"Gov. Joseph Talcott","title":"Governor","first_name":"Joseph","last_name":"Talcott","married_names":[],"bio_blurb":"Colonial governor of Connecticut"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM003"},"slug":"joseph-talcott-1669"},"U00017":{"id":"U00017","visible_default":true,"in_talcott_book":true,"classification":{"is_spouse_of_talcott_descendant":true,"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1678,"month":8,"day":18,"city":"Southampton","county":"Suffolk","state":"New York","country":"United States"},"death":{"year":1738,"month":5,"day":25,"city":"Hartford","county":"Hartford","state":"Connecticut","country":"United States"},"marriages":[{"children_ids":[],"spouse_id":"X01733","marriage_number":1},{"spouse_id":"T00045","children_ids":["T00068","I00054","T00070","T00071","T00072","T00073","X00446"],"marriage_number":2}],"sources":[{"short":"Talcott 1876","page":"Entry 45"},{"short":"Edward Hooker 1909","page":"Entry 115"}],"gender":"female","tags":[],"number_of_marriages":2,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Eunice Howell Talcott","notes":"Widow of [first husband Wakeman] before marrying Gov. Joseph Talcott (T00045)","first_name":"Eunice","last_name":"Talcott","married_names":["Wakeman","Talcott"],"maiden_name":"Howell"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM003"},"slug":"eunice-howell-1678"},"T00035":{"id":"T00035","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":1,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1632,"city":"Braintree","county":"Essex","country":"England"},"death":{"year":1688,"month":7,"day":23,"city":"Hartford","state":"Connecticut"},"parents":{"father_id":"T00011","mother_id":"U00011"},"marriages":[{"spouse_id":"U00012","children_ids":["T00039","T00040","T00041","T00042","T00043","T00044","T00045","T00046"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1674,"date_year":1650,"date_month":10,"date_day":29},{"spouse_id":"U00013","children_ids":["T00047","T00049","T00051"],"marriage_number":2,"date_year":1676,"date_month":11,"date_day":9}],"sources":[{"short":"Talcott 1876","page":"Entry 35"},{"short":"Talcott 1876","url":"https://archive.org/details/talcottpedigreei00talc"}],"political_offices":[{"title":"Ensign","jurisdiction":"Connecticut Militia","dates":"1650"},{"title":"Captain","jurisdiction":"Connecticut Militia","dates":"1660"},{"title":"Deputy / Assistant Magistrate","jurisdiction":"Colony of Connecticut","dates":"from May 18, 1654","notes":"Elected before Connecticut joined New Haven Colony"},{"title":"Treasurer","jurisdiction":"Colony of Connecticut","dates":"1660-1676","notes":"Succeeded his father May 17, 1660; held office until 1676"},{"title":"Major, then Lieut.-Colonel","jurisdiction":"Connecticut Army","dates":"1676","notes":"Resigned Treasurer and took command of Connecticut army at outbreak of King Philip's War"}],"cross_connections":[],"gender":"male","tags":["king_philips_war"],"number_of_marriages":2,"notable":{"is_notable":true,"notable_category":["military"],"notable_blurb":"Colonial military commander, King Philip's War","primary_url":"https://en.wikipedia.org/wiki/John_Talcott_(military_officer)","primary_url_label":"Wikipedia"},"narrative_blocks":[{"category":"politics","header":"He was named guardian of the charter","body":"When Connecticut's royal charter arrived from Charles the Second in 1662, the freemen chose Talcott, with Samuel Wyllys and Lieutenant John Allyn, as the committee sworn to keep it in their custody. A quarter-century later he would help spirit that same charter away from Andros.","number":1},{"category":"politics","header":"He took the charter as the candles died","body":"By Roger Wolcott's 1764 account, when the candles were snuffed in the Hartford meeting-house in 1687, Talcott and Nathaniel Stanley lifted the two colonial charters from the table before Andros could seize them. Wolcott's telling names no oak; the tree entered the tradition later, and the duplicate passed to his son-in-law Joseph Wadsworth.","number":2},{"category":"military","header":"Connecticut's victorious commander in King Philip's War","body":"Talcott led Connecticut's forces through King Philip's War in 1675 and 1676, winning a string of engagements that earned him promotion to lieutenant-colonel. His campaigns ranged from the river towns down into the Narragansett country.","number":3},{"category":"politics","header":"He kept the colony's purse for sixteen years","body":"Talcott served as treasurer of Connecticut Colony from 1660 to 1676, taking the office directly from his father before him. The family's account books became a running ledger of early Hartford.","number":4},{"category":"death","header":"He died intestate, his estate worth thousands","body":"Talcott died in 1688 without a will, leaving an estate appraised at more than two thousand pounds, a substantial colonial fortune. It passed by primogeniture to his eldest surviving son, the future governor Joseph Talcott.","number":5}],"military_service":[{"war":"King Philip's War","active_in_war":true,"rank":"Lieutenant Colonel","dates":"1676","unit":"Connecticut Standing Army","role":"Commander of Connecticut forces","battles":["Multiple engagements with Wampanoag and allied tribes"],"notes":"Led Connecticut standing army with 200 Mohegan and Pequot Indian allies. 'In the various battles with the Indians in which he was engaged, he was always victorious, and obtained great renown as an Indian fighter.' Promoted from Major to Lieut.-Colonel during the war.","war_id":"WAR002"}],"bio":{"display_name":"Lieut.-Col. John Talcott Jr.","title":"Lieut.-Col.","first_name":"John","last_name":"Talcott","suffix":"Jr.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"slug":"john-talcott-jr-1632"},"U00012":{"id":"U00012","visible_default":false,"in_talcott_book":true,"classification":{"is_spouse_of_talcott_descendant":true,"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{},"death":{"year":1674,"month":6,"day":21},"parents":{"notes":"Her father John Wakeman was Colony Treasurer — the same office her husband John Talcott Jr. would later hold","father_research_notes":"John Wakeman, Treasurer of the Colony of Connecticut"},"marriages":[{"spouse_id":"T00035","children_ids":["T00039","T00040","T00041","T00042","T00043","T00044","T00045","T00046"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1674,"date_year":1650,"date_month":10,"date_day":29}],"sources":[{"short":"Talcott 1876","page":"Entry 35"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Helena Wakeman Talcott","first_name":"Helena","last_name":"Talcott","married_names":["Talcott"],"maiden_name":"Wakeman"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"helena-wakeman"}},"burialCemetery":{"id":"CEM003","name":"Ancient Burying Ground","city":"Hartford","state":"Connecticut","gps":{"latitude":41.7627,"longitude":-72.6743},"founded":1640,"visitable":true,"notes":"Adjacent to Center Church. Earliest surviving identifiable gravestone dates to 1648. Resting place of many Hartford founders including Rev. Thomas Hooker (exact location unknown).","hooker_connections":["H00001","H00033","H00102","H00110","H00115","H00362","I00053","T00011","T00383","T00384","T00385","T00386","T00387","T00388","X00067","X00110","X00123","X00418","X01014","X02128","X02129","X00049","H00028","I00056","X02130","X00066","H00032","H00340","X00083","X00050","X01998","TD0058","T00071","X01763","U00017","U00022","T00045","X03384"]},"institutionsById":{"INST022":{"id":"INST022","primary_name":"American Board of Commissioners for Foreign Missions","name":"American Board of Commissioners for Foreign Missions","alt_names":["ABCFM","American Board"],"type":"missionary_society","founding_year":1810,"location":{"city":"Boston","state":"Massachusetts"},"primary_persons":["X00724"],"hooker_connected_people":["X00724","X02121","X02122","T01213","H00527","I01195"],"person_ids":[],"related_institutions":[],"related_landmarks":[],"tags":["native_american_contact","missionary"],"sources":[{"short":"Wikipedia","note":"Elias Cornelius (clergyman); ABCFM"}],"notes":"First American foreign-mission organization. Tree connections: Rev. Elias Cornelius (agent 1816, secretary 1831-32); Ainsworth and Harriet Ellsworth Blunt, missionaries to the Cherokee at Brainerd, Tennessee; Eliza Talcott, missionary to Japan; Rev. William Banfield Capron, Madura mission; Judge John Hooker, member."}},"crossConnections":[]}