ism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["I00109"],"narrative_blocks":[{"number":1,"category":"family","header":"Second Mary — first Mary the twin died young","body":"Mary Reynolds Rawson was born November 20, 1716 in Bristol Rhode Island — the second daughter named Mary, after the first Mary (twin to her sister Anne) had died young earlier in November 1716. The replacement naming worked: this second Mary lived to nearly eighty-seven, dying in 1803 after surviving two marriages and bearing children in both. Her first marriage to Dr. Samuel Morse left her widowed with three young children when he died in 1743."},{"number":2,"category":"family","header":"Married her first cousin Edward Rawson in 1748","body":"After widowhood in 1743, Mary remarried Deacon Edward Rawson — her first cousin through their mothers Susannah Rawson Reynolds and Wilson Rawson who were siblings, both fifth-generation Hooker descendants via the Sarah Hooker line. Their marriage was a documented Pierpont-Reynolds first-cousin union. The 'Aunt Reynolds' relationship was sometimes recorded ambiguously as grandmother rather than mother, but Mary was the daughter, not the granddaughter, of Susannah Rawson Reynolds."}],"slug":"mary-rawson-1716"},"I01088":{"id":"I01088","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"title":"Doctor","first_name":"Samuel","last_name":"Morse","married_names":[],"gender":"male","display_name":"Dr. Samuel Morse"},"birth":{"year":1717,"month":11,"day":5,"city":"Newbury","county":"Essex","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1743,"month":6,"day":12,"city":"Mendon","county":"Worcester","state":"Massachusetts","country":"United States"},"residence":{"city":"Mendon","county":"Worcester","state":"Massachusetts","country":"United States"},"burial":{"plot_notes":"Old