eet shop","location":"Hinsdale, NH","start_year":1838,"notes":"Manufacturer of doors, sash, blinds, and dressed lumber for many years on Canal Street."},{"role":"Selectman (three terms)","organization":"Town of Hinsdale","location":"Hinsdale, NH","notes":"Served three years as selectman; re-elected to a fourth term but resigned."},{"role":"State Representative","organization":"New Hampshire General Court","location":"Concord, NH","start_year":1876,"end_year":1877,"notes":"Representative for Hinsdale 1876–77; also delegate to the 1876 New Hampshire Constitutional Convention."},{"role":"Captain","organization":"Ashuelot Guards (militia)","location":"Hinsdale, NH","notes":"Local military company."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["politician"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Orphaned at two, brought to Hinsdale at twelve","body":"His father Cyrus Jones died when he was about two years old and his mother Sally Bowker moved the family to Athol, Massachusetts. At twelve he was sent to Hinsdale to live with his uncle Windsor Bowker; he never left."},{"number":2,"category":"family","header":"Married Julia Worthington Hooker, December 1842","body":"He married Julia W., daughter of Henry Hooker of the Hinsdale homestead, on 7 December 1842. They raised three children, two of whom became mechanics in Keene."},{"number":3,"category":"business","header":"Built a Canal Street doors-and-sash factory","body":"After three years running a Kilbourn brook sawmill in the mid-1830s, he bought a shop on Canal Street in Hinsdale village and manufactured doors, sash, blinds, and dressed lumber for many years. The shop was a fixture of the manufacturing village."},{"number":4,"category":"politics","header":"Constitutional convention delegate, 1876","body":"He served three terms as selectman, represented Hinsdale in the state legislature in 1876–77, and sat as a delegate to the 1876 New Hampshire constitutional convention. Earlier he had been captain of the Ashuelot Guards, a Hinsdale militia company."},{"number":5,"category":"family","header":"Born in Gerry, Massachusetts — renamed Phillipston, 1814","body":"His birthplace was named for Elbridge Gerry, fifth vice-president of the United States, but the town was renamed Phillipston in 1814 after Gerry's political fall from grace. He was thus born in Gerry but always identified as a Phillipston native."}],"quotes":[],"sources":[],"research_sources":[{"bib_id":"BIB011","page":"Hinsdale chapter — Henry M. Jones biographical sketch"}],"documents":[],"slug":"henry-jones-1811"},"neighborhood":{"focus":{"id":"X02834","slug":"henry-jones-1811","n":"Henry M. Jones","by":1811,"dy":1886,"sx":"u","hd":false,"td":false,"ee":true,"g":null},"spouses":[{"order":1,"spouse":{"id":"H02701","slug":"julia-hooker-1818","n":"Julia Worthington Hooker","by":1818,"dy":null,"sx":"f","hd":true,"td":false,"ee":false,"g":8},"year":1842,"children":[{"id":"HD04829","slug":"henry-jones-1845","n":"Henry Abbott Jones","by":1845,"dy":null,"sx":"u","hd":true,"td":false,"ee":false,"g":9},{"id":"HD04830","slug":"charles-jones-1848","n":"Charles Armest Jones","by":1848,"dy":1928,"sx":"u","hd":true,"td":false,"ee":false,"g":9},{"id":"HD04831","slug":"frederick-jones-1866","n":"Frederick Hooker Jones","by":1866,"dy":1933,"sx":"u","hd":true,"td":false,"ee":false,"g":9}]}],"parents":{},"grandparents":{"paternal":{},"maternal":{}},"grandchildren":[],"siblings_count":0},"context":{"X02834":{"id":"X02834","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Henry","middle_name":"M","last_name":"Jones","married_names":[],"gender":"male","display_name":"Henry M. Jones"},"birth":{"year":1811,"month":7,"day":24,"city":"Gerry","county":"Worcester","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1886,"month":7,"day":7,"city":"Hinsdale","county"