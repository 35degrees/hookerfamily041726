ber":1,"spouse_id":"H00435","date_year":1786,"date_month":3,"date_day":12,"location_city":"Kensington","location_state":"Connecticut","end_type":"death_of_spouse","end_year":1834,"children_ids":["HD0510","HD0511"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Elizabeth (Betsy)","first_name":"Elizabeth","maiden_name":"(Betsy)","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elizabeth-betsy"},"H00435":{"id":"H00435","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1755,"month":11,"day":13,"city":"Kensington","state":"Connecticut"},"death":{"year":1846,"month":9,"day":20,"city":"Kensington (Berlin)","state":"Connecticut"},"burial":{"cemetery_id":"CEM022","plot_notes":"Ledge Cemetery, Berlin, Connecticut"},"parents":{"father_id":"I00155","mother_id":"H00230"},"marriages":[{"children_ids":["HD0510","HD0511"],"spouse_id":"X01217","marriage_number":1,"date_year":1786,"date_month":3,"date_day":12,"location_city":"Kensington","location_state":"Connecticut","end_type":"death_of_spouse","end_year":1834}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 435"},{"short":"Cowles Family Genealogy","page":"Entry 470"}],"gender":"male","tags":["revolutionary_war"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","active_in_war":true,"rank":"Private","unit":"Capt. Selah Hart's Co., Col. Erastus Wolcott's regiment (1776 Boston siege); Capt. Sloper's cavalry, Col. Bull's regiment (1776-1779 NY campaigns); Capt. Ichabod Norton's Co. (1778 Albany); Capt. Seth Deming's cavalry (1779 New Haven Alarm)","notes":"Five field tours documented in pension affidavit: (1) Jan 1776 — 3 months at Roxbury MA on Dorchester Hill, Capt. Selah Hart / Col. Wolcott (siege of Boston, occupation after British evacuation Mar 17); (2) Jul 1776 — 3 weeks to Newark NJ, Capt. Sloper / Col. Bull; (3) Oct 1776 — 3 months Peekskill and White Plains NY, same regiment (campaign during which Fort Washington fell); (4) Jan 1778 — 2 weeks Albany NY under Capt. Ichabod Norton, retrieving Gen. Burgoyne's surrendered artillery to Farmington; (5) 1779 — 1 week New Haven Alarm, Capt. Seth Deming, cavalry. PLUS express rider duty for Brig.-Gen. Selah Hart, Nov 7 and Nov 19, 1779, through Simsbury, New Hartford, Norfolk, Torrington, Canaan; paid 45 pounds 13 shillings Dec 20, 1779 (Conn. Archives Rev. War Vol. 16 p. 259). Total field service 7 months 2 weeks. Pensioned 1833. Brother Samuel Cowles (H00434) was witness to his pension application; conversely Jabez witnessed Samuel's 1832 pension application."}],"bio":{"display_name":"Jabez Cowles","first_name":"Jabez","last_name":"Cowles","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[{"bib_id":"BIB003"}],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[{"text":"Always lived in that part of Berlin, formerly Farmington, where he now lives, and was born in Farmington, Nov. 1755.","attribution":"Jabez Cowles, sworn pension affidavit (paraphrased in U.S. Pension Office record), circa 1832-1833","category":"character"}],"narrative_blocks":[{"number":1,"category":"military","header":"On Dorchester Hill the day Boston was lost","body":"Jabez served three months at Roxbury and on Dorchester Hill in the spring of 1776 under Capt. Selah Hart of Farmington and Col. Erastus Wolcott, occupying the lines that forced the British to evacuate Boston on March 17. He was twenty years old, on his first wartime tour."},{"number":2,"category":"military","header":"Pension granted 1833 — his brother's was not","body":"Jabez's federal pension was approved in 1833, recognizing seven months and two weeks of Revolutionary service. His older brother Samuel had filed a year earlier and been rejected for falling short of the six-month minimum, even though both rode the same campaigns under Col. Bull."},{"number":3,"category":"military","header":"Brought home the cannon Burgoyne surrendered at Saratoga","body":"In January 1778 Jabez marched with Capt. Ichabod Norton to Albany to bring back artillery captured from Gen. Burgoyne after the surrender at Saratoga. The guns were carted south to Farmington across two weeks of winter hauling."},{"number":4,"category":"military","header":"Five wartime tours plus express rides for Hart","body":"Beyond his five field tours — Boston, Newark, White Plains, Albany, the New Haven Alarm — Jabez rode express for Brig.-Gen. Selah Hart in November 1779, carrying messages through Simsbury, New Hartford, Norfolk, Torrington, and Canaan. He was paid 45 pounds 13 shillings a month later."},{"number":5,"category":"marriage","header":"Married a captain's widow with two stepchildren","body":"Jabez married Betsey Pratt Scoville in March 1786, the widow of Capt. Daniel Scovil who had died at Colchester five years earlier. She brought two children from her first marriage — Dan and Mary — into the new Kensington household."}],"slug":"jabez-cowles-1755"},"HD0510":{"id":"HD0510","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1787,"month":12,"day":10,"city":"Kensington","state":"Connecticut"},"death":{"year":1868,"month":1,"day":12,"city":"Kensington","state":"Connecticut"},"parents":{"father_id":"H00435","mother_research_notes":"Elizabeth Cowles","mother_id":"X01217"},"marriages":[{"children_ids":["HD0512","HD0513","HD0514","HD0515","HD0516","HD0517"],"spouse_id":"X01218","marriage_number":1,"end_type":"death_of_spouse","end_year":1825,"date_year":1812,"date_month":7,"date_day":9},{"children_ids":["HD0518","HD3786","HD0519","HD0520"],"spouse_id":"X01219","marriage_number":2,"date_year":1828,"date_month":11,"date_day":23}],"tags":[],"sources":[{"short":"Cowles Family Genealogy","page":"Entry 1198"}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Linus Cowles","first_name":"Linus","last_name":"Cowles","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[{"bib_id":"BIB003"}],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married his brother Luman's widow in 1828","body":"After Linus's first wife Ruth died in 1825, he remarried in November 1828 to Eunetia Pardee — the widow of his younger brother Luman, who had died at thirty-three in 1823. The levirate-style match kept the household and the children together within the Cowles family."},{"number":2,"category":"religion","header":"Farmer, Whig, and Congregational church member","body":"Linus lived his entire life in Kensington, working the family farm and counting himself a Whig in politics and a member of the Kensington Congregational Church. His ten children were raised in the same parish his grandfather Asahel had joined a century before."},{"number":3,"category":"family","header":"Father of the ecologist Henry Chandler's father","body":"Linus's eighth child Henry Martyn Cowles, born to him and Eunetia in 1831, would become a Kensington farmer and deacon. His grandson — born 1869 in the same house — was Henry Chandler Cowles, the founding figure of American plant ecology."}],"burial":{"cemetery_id":"CEM022","plot_notes":"Ledge Cemetery, Berlin, Connecticut, per FindAGrave."},"slug":"linus-cowles-1787"},"X01218":{"id":"X01218","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0510","date_year":1812,"date_month":7,"date_day":9,"end_type":"death_of_spouse","end_year":1825,"children_ids":["HD0512","HD0513","HD0514","HD0515","HD0516","HD0517"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Ruth Cowles","first_name":"Ruth","maiden_name":"Cowles","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ruth-cowles"},"X01219":{"id":"X01219","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"Cowles Family Genealogy","page":"Entry 1199 (spouse of Luman) + 1198 (m2 spouse of Linus)"}],"gender":"female","number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"HD0511","date_year":1812,"date_month":1,"date_day":1,"location_city":"East Haven","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1823,"children_ids":["HD0521","HD0522"]},{"marriage_number":2,"spouse_id":"HD0510","date_year":1828,"date_month":11,"date_day":23,"location_city":"Kensington","location_county":"Hart