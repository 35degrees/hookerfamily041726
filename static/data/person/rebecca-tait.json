ie-1904"},"X02872":{"id":"X02872","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{},"tags":["lawyer"],"sources":[],"marriages":[{"spouse_id":"HD5035","spouse_name":"William Huger Hardie","marriage_number":1,"date_year":1932,"children_ids":["HD5036","HD5037","HD5038"],"end_type":"death","end_year":1959}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["law"],"notable_blurb":"Oxford-trained English barrister; New York lawyer"},"birth":{"year":1907,"month":4,"day":7,"city":"Philadelphia","state":"Pennsylvania","county":"Philadelphia County","country":"USA"},"death":{"year":1978,"month":11,"day":29,"city":"Washington","state":"District of Columbia","country":"USA","age":71},"cross_connections":[],"bio":{"display_name":"Jessie Edson Hendrick Hardie","first_name":"Jessie","last_name":"Hardie","maiden_name":"Hendrick","middle_name":"Edson","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"place":"Westminster Cemetery","city":"Bala Cynwyd","state":"Pennsylvania"},"narrative_blocks":[{"number":1,"category":"career","header":"Oxford-trained English barrister practicing as NY lawyer","body":"Jessie Edson Hendrick trained as an English barrister at Oxford, then practiced as a New York lawyer — a notable transatlantic legal career for a woman of her generation. She married William Huger Hardie in 1932; their son Bill Hardie Jr. wrote in his own obituary that 'in deference to my parents, I received an engineering degree from Yale and a law degree from the University of Virginia.' She outlived her husband by nineteen years."}],"slug":"jessie-hendrick-1907"}},"burialCemetery