craft School (instructor) → Air Corps","allegiance":"United States","service_years":"1941-end of WWII","notes":"Enlisted in New York's Seventh Regiment, National Guard. Regiment entered federal service in 1941. After Pearl Harbor, commissioned at the Anti-Aircraft School and kept on as an instructor. Served as battery commander and intelligence officer, then transferred to classified work and finally to the Air Corps.","war_id":"WAR008"}],"bio":{"first_name":"Hugh","middle_name":"Gaylord","last_name":"Barclay","married_names":[],"suffix":"Jr.","display_name":"Hugh Gaylord Barclay Jr."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"slug":"hugh-barclay-jr-1880"},"TD0078":{"id":"TD0078","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"gender":"female","classification":{"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":9,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":false},"birth":{"year":1894,"month":8,"day":23,"city":"Washington","state":"District of Columbia","country":"United States"},"death":{"year":1980,"month":1,"day":10,"city":"Alexandria","county":"City of Alexandria","state":"Virginia","country":"United States"},"burial":{"cemetery_id":"CEM141","plot_notes":"Oak Hill Cemetery, Washington DC."},"parents":{"father_id":"T01873","mother_id":"I00266"},"marriages":[{"marriage_number":1,"spouse_id":"I00267","children_ids":["TD0100","TD0080","TD0081"],"end_type":"death_of_spouse","end_year":1952}],"number_of_marriages":1,"tags":[],"sources":[{"short":"Findagrave"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"bio":{"first_name":"Dorothy","middle_name":"Laurence","last_name":"Talcott","maiden_name":"Talcott","married_names":["Barclay"],"display_name":"Dorothy Laurence Talcott Barclay"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"dorothy-talcott-1894"},"X02147":{"id":"X02147","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"gender":"male","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":true},"birth":{"year":1850,"county":"Dallas County","state":"Alabama","country":"United States"},"death":{"year":1941,"month":1,"day":13,"city":"Mobile","county":"Mobile County","state":"Alabama","country":"United States"},"burial":{"cemetery_id":"CEM143","plot_notes":"Pine Crest Cemetery, Mobile AL."},"parents":{"father_research_notes":"Family genealogical sources call him \"Hugh Gaylord Barclay Jr.\" — implying a Hugh Gaylord Barclay Sr. (his father, b. likely ~1820) preceded him."},"marriages":[{"marriage_number":1,"spouse_id":"X02148","date_year":1880,"date_month":3,"date_day":16,"location_city":"Louisville","location_state":"Kentucky","children_ids":["I00267"],"end_type":"death_of_subject","end_year":1941}],"number_of_marriages":1,"tags":["railroad","baptist_seminary","alabama"],"sources":[{"short":"Barclay family genealogy (sourced via Hugh Gaylord Barclay III obituary 2008)"}],"notable":{"is_notable":false,"notable_category":[]},"education":[{"institution":"Stonewall Institute","location":"Dallas County, Alabama"},{"institution":"Southern Baptist Theological Seminary","location":"Louisville, Kentucky","start_year":1878,"end_year":1880,"degree":"Schools of Old Testament English, New Testament English, and Homiletics","notes":"Per John R. Sampey, 'Southern Baptist Theological Seminary - the First Thirty Years.' Did not continue in the seminary after 1880; took a railroad clerk position to support his growing family."}],"career":[{"role":"Clerk and Salesman","organization":"Various — Louisville KY","start_year":1870,"end_year":1878,"notes":"Moved with his mother to Louisville KY around 1870; worked clerk and salesman positions for several years before entering seminary."},{"role":"Clerk","organization":"Louisville & Nashville Railroad (L&N)","start_year":1880,"end_year":1884,"notes":"Took L&N position to support his growing family rather than continuing in ministry."},{"role":"Traveling Agent","organization":"Louisville & Nashville Railroad","start_year":1884,"end_year":1888},{"role":"General Agent","organization":"Louisville & Nashville Railroad — Mobile AL","start_year":1888,"end_year":1932,"notes":"Moved to Mobile in 1888. Held this position until retirement at age 82 (1932)."}],"narrative_blocks":[{"number":1,"category":"work","header":"Southern Baptist seminary student turned L&N railroad agent","body":"Educated at Stonewall Institute in Dallas County, Alabama, Hugh Barclay studied at the Southern Baptist Theological Seminary 1878-1880, graduating in the schools of Old Testament English, New Testament English, and Homiletics. Rather than continue in ministry he took a clerk position with the Louisville & Nashville Railroad, eventually becoming general agent in Mobile — a position he held until retiring at age 82."},{"number":2,"category":"career","header":"Worked L&N Railroad over fifty years until eighty-two","body":"After abandoning ministry he joined the Louisville and Nashville Railroad in 1880 as a clerk; promoted to traveling agent 1884; general agent at Mobile AL 1888; retired only at age eighty-two. The L&N career — over fifty years — dwarfed his two years at the Southern Baptist Theological Seminary."},{"number":3,"category":"marriage","header":"Caroline ten years younger; called him 'Mr Bar'","body":"He married Caroline Adams Brannon at Louisville KY on 16 March 1880, when she was nineteen and he was twenty-nine. She called him 'Mr Bar' — a private nickname that survived in family records. He was tall, wore a beard, and outlived her by four years to age ninety."},{"number":4,"category":"family","header":"Three Hugh Gaylords across three Barclay generations","body":"Family records called him 'Hugh Gaylord Barclay Jr' — implying an undocumented Hugh Sr born around 1820 who never surfaced in the genealogical record. His son born 1880 was called 'Hugh III' and his grandson born 1916 'Hugh IV', leaving the project to use Sr/Jr/III for the documented three rather than the missing four."}],"cross_connections":[],"bio":{"first_name":"Hugh","middle_name":"Gaylord","last_name":"Barclay","married_names":[],"suffix":"Sr.","nickname":"\"Mr. Bar\"","display_name":"Hugh Gaylord Barclay Sr."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"hugh-barclay-sr-1850"},"X02148":{"id":"X02148","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"gender":"female","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":true},"birth":{"year":1860,"month":6,"city":"Louisville","state":"Kentucky","country":"United States"},"death":{"year":1945,"month":9,"day":2,"country":"United States"},"burial":{"cemetery_id":"CEM143","plot_notes":"Pine Crest Cemetery, Mobile AL."},"parents":{"father_research_notes":"James W. Brannon — merchant who came from Winchester, Virginia.","mother_research_notes":"Catherine T. Adams — native who came from Indiana."},"marri