t_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{},"tags":["lawyer"],"sources":[],"marriages":[{"spouse_id":"HD5035","spouse_name":"William Huger Hardie","marriage_number":1,"date_year":1932,"children_ids":["HD5036","HD5037","HD5038"],"end_type":"death","end_year":1959}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["law"],"notable_blurb":"Oxford-trained English barrister; New York lawyer"},"birth":{"year":1907,"month":4,"day":7,"city":"Philadelphia","state":"Pennsylvania","county":"Philadelphia County","country":"USA"},"death":{"year":1978,"month":11,"day":29,"city":"Washington","state":"District of Columbia","country":"USA","age":71},"cross_connections":[],"bio":{"display_name":"Jessie Edson Hendrick Hardie","first_name":"Jessie","last_name":"Hardie","maiden_name":"Hendrick","middle_name":"Edson","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"place":"Westminster Cemetery","city":"Bala Cynwyd","state":"Pennsylvania"},"narrative_blocks":[{"number":1,"category":"career","header":"Oxford-trained English barrister practicing as NY lawyer","body":"Jessie Edson Hendrick trained as an English barrister at Oxford, then practiced as a New York lawyer — a notable transatlantic legal career for a woman of her generation. She married William Huger Hardie in 1932; their son Bill Hardie Jr. wrote in his own obituary that 'in deference to my parents, I received an engineering degree from Yale and a law degree from the University of Virginia.' She outlived her husband by nineteen years."}],"slug":"jessie-hendrick-1907"},"HD5036":{"id":"HD5036","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"generation_from_thomas":11,"is_easter_egg":false},"parents":{"father_id":"HD5035","mother_id":"X02872"},"tags":["died_in_infancy"],"sources":[],"marriages":[],"gender":"male","number_of_marriages":0,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1936},"death":{"year":1936},"cross_connections":[],"bio":{"display_name":"Joseph Hardie III","first_name":"Joseph","last_name":"Hardie","married_names":[],"suffix":"III"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"joseph-hardie-iii-1936"},"HD5037":{"id":"HD5037","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"generation_from_thomas":11,"is_easter_egg":false},"parents":{"father_id":"HD5035","mother_id":"X02872"},"tags":["yale_graduate","lawyer"],"sources":[],"marriages":[{"spouse_id":"X02873","spouse_name":"Alix Winter","marriage_number":1,"children_ids":["HD5040","HD5041","HD5042","HD5039"],"end_type":"death","end_year":2019}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["law"],"notable_blurb":"Davis Polk attorney; voted best in his field"},"birth":{"year":1938,"month":3,"day":1,"city":"New York","state":"New York","county":"New York County","country":"USA"},"death":{"year":2019,"month":5,"day":20,"city":"Mobile","state":"Alabama","county":"Mobile County","country":"USA","age":81},"cross_connections":[],"bio":{"display_name":"William Huger Hardie Jr.","first_name":"William","last_name":"Hardie","middle_name":"Huger","married_names":[],"suffix":"Jr.","nickname":"Bill"},"residence":{"city":"Mobile","state":"Alabama","country":"USA"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"place":"Thornhill Cemetery","state":"Alabama","county":"Talladega County"},"narrative_blocks":[{"number":1,"category":"career","header":"Davis Polk attorney; moved to Mobile 1966","body":"Bill Hardie practiced three years at Davis Polk in New York before moving to Mobile, Alabama in 1966, where he joined Johnstone Adams and stayed for the rest of his career. He was voted best lawyer in his field many times and published widely on legal research. At St. Paul's Episcopal Church Mobile he served as vestry clerk for twenty years and completed the four-year Education for Ministry course."},{"number":2,"category":"character","header":"Polymath with two-dozen mastered interests","body":"Bill's obituary listed his areas of personal expertise: religion, geography, physics, philosophy, history, sailing, scuba diving, underwater photography, amateur flying, classical and jazz music, theater, baseball, crossword puzzles, computer programming, sewing, toilet repair, genealogy, travel, and wine. He was 'a shameless braggart about his children.' His Yale engineering degree and UVA law degree were taken 'in deference' to his engineer father and lawyer mother."},{"number":3,"category":"family","header":"Outlived his son Frank Winter Hardie","body":"Bill's son Frank Winter Hardie (HD5039) died of neuroendocrine cancer at 28 in December 2007 — twelve years before Bill himself. He was survived by his other three children (Tuck, Ted, Rebecca) and four grandsons (Gabriel, Charles, Frank Tait, Jasper). Bill's wife Alix Winter survived him."}],"slug":"william-hardie-jr-1938"},"X02873":{"id":"X02873","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":fa