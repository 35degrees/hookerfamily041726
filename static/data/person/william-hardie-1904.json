e,"generation_from_thomas":12,"is_easter_egg":false},"parents":{"father_id":"HD5037","mother_id":"X02873"},"tags":[],"sources":[],"marriages":[{"spouse_id":"X02877","spouse_name":"Elaine de la Houssaye","marriage_number":1,"children_ids":[],"end_type":"death","end_year":2007}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["arts"],"notable_blurb":"LSU MFA screenplay; Civil War Book Review editor"},"birth":{"year":1979,"month":11,"day":28,"city":"Mobile","state":"Alabama","county":"Mobile County","country":"USA"},"death":{"year":2007,"month":12,"day":26,"city":"Mobile","state":"Alabama","county":"Mobile County","country":"USA","age":28,"cause":"neuroendocrine cancer"},"cross_connections":[],"bio":{"display_name":"Frank Winter Hardie","first_name":"Frank","last_name":"Hardie","middle_name":"Winter","married_names":[]},"residence":{"city":"Houston","state":"Texas","country":"USA","note":"at time of death"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"place":"Thornhill Cemetery","state":"Alabama","county":"Talladega County"},"narrative_blocks":[{"number":1,"category":"career","header":"LSU MFA in Creative Writing; best screenplay award","body":"Frank Hardie earned his MFA in Creative Writing at LSU, where he won the program's best screenplay award for his thesis and tied for best thesis in his class. He had earlier earned his BS from Rhodes College in Memphis, where he was president of his SAE fraternity chapter and played baseball. Before his cancer diagnosis he served as editor of the Civil War Book Review at LSU."},{"number":2,"category":"death","header":"Died of neuroendocrine cancer at age twenty-eight","body":"Frank Winter Hardie died of neuroendocrine cancer on December 26, 2007 — the day after Christmas — at age 28 in Mobile, Alabama. He had been a resident of Houston, Texas at the time. He was buried at Thornhill Cemetery in Talladega County, Alabama; his father Bill would join him there twelve years later."}],"slug":"frank-hardie-1979"},"HD5038":{"id":"HD5038","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"generation_from_thomas":11,"is_easter_egg":false},"parents":{"father_id":"HD5035","mother_id":"X02872"},"tags":["died_in_infancy"],"sources":[],"marriages":[],"gender":"male","number_of_marriages":0,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1943},"death":{"year":1943},"cross_connections":[],"bio":{"display_name":"Edson Hendrick Hardie","first_name":"Edson","last_name":"Hardie","middle_name":"Hendrick","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"edson-hardie-1943"},"X01706":{"id":"X01706","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"male","number_of_marriages":1,"marriages":[{"spouse_id":"HD2610","spouse_name":"Lucia Polk Huger","marriage_number":1,"date_year":1894,"children_ids":["HD5035"],"end_type":"death","end_year":1915}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1866,"month":12,"day":29,"city":"New Orleans","state":"Louisiana","country":"USA"},"death":{"year":1915,"month":6,"day":24,"city":"Dallas","state":"Texas","county":"Dallas County","country":"USA","age":48},"cross_connections":[],"bio":{"display_name":"Joseph Hardie","first_name":"Joseph","last_name":"Hardie","married_names":[]},"residence":{},"baptism":{