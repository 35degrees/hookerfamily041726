down Waterbury roots","body":"A Revolutionary War soldier, Ezra Pierpont was the first of his family to settle the East Farms district of Waterbury, arriving in 1801 after years of buying and expanding farmland in nearby Prospect. His descendants held the land for a century and founded a family association in 1923 whose reunions ran for ninety years."},{"number":2,"category":"family","header":"Third in his generation to marry a Blakeslee","body":"Ezra married Mary Blakeslee in 1783. He was the third Pierpont of his generation to wed into the Blakeslee family, after his kinswomen Elizabeth and Mehitable Pierpont had each married a Blakeslee man."}],"slug":"ezra-pierpont-1757"},"X00459":{"id":"X00459","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00872","children_ids":[]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Deborah Unknown","first_name":"Deborah","maiden_name":"Unknown","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"deborah-unknown-x00459"},"X00458":{"id":"X00458","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1762},"death":{"year":1827},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00872","date_year":1783,"date_month":3,"date_day":