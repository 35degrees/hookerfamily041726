er":true},"bio":{"first_name":"William","middle_name":"Henry","last_name":"Hooker","married_names":[],"gender":"male","display_name":"William Henry Hooker","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777229610/williamhenryhooker1864_gn3m0w.png","photo_notes":"Findagrave-sourced photo via Cloudinary"},"birth":{"year":1864,"month":8,"day":18,"city":"Murray","county":"Orleans County","state":"New York","country":"United States"},"death":{"year":1933,"month":5,"day":15,"city":"Brockport","county":"Monroe County","state":"New York","country":"United States"},"parents":{"father_id":"H02424","mother_id":"X02242"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3270","date_year":1890,"location_country":"United States","end_type":"death_of_spouse","end_year":1915,"children_ids":["HD3236","HD3237","HD3238"]}],"tags":["cousin_marriage","new_york_migration"],"sources":[{"short":"Findagrave"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Married fellow Hooker descendant, third-cousin distance","body":"William Henry 'Willie' Hooker married Lydia Mason Robinson — herself a Hooker descendant via her grandmother Laura E. Hooker Shader, daughter of Captain Thomas Hooker's son Myron Hooker. William Henry and Lydia were third cousins once removed; their marriage united two Hooker-line branches in a single household, with their son Charles Theodore Hooker holding documented double Hooker ancestry through both parents."},{"number":2,"category":"family","header":"Two brothers each married a Shader-line Hooker cousin","body":"The cousin marriage was paralleled in the family: William Henry's brother Thomas Harvey Hooker had also married a Shader-line Hooker cousin (Caroline E. Shader, Lydia's aunt). Two brothers Thomas Edwin Hooker's sons each thus married a Shader-line Hooker woman, making their offspring doubly Hooker-descended on both maternal and paternal sides. The pattern thickened the Hooker-line concentration in the Murray, Orleans County New York branch."},{"number":3,"category":"family","header":"Born Murray NY 1864, three children with Lydia","body":"William Henry Hooker was born August 18, 1864 in Murray, Orleans County New York — the eldest child of Thomas Edwin Hooker by his second wife Susan M. Brown. He died May 15, 1933 in Brockport, Monroe County New York at age sixty-eight, buried at Beach Ridge Cemetery Brockport. He had three children with Lydia: C. Theodore Hooker (1891-1971), Ethel Susan Hooker Zastrow (1896-1928 died young at 31), and Marjory Violetta Hooker Delahanty (1902-1993)."}],"cross_connections":[],"burial":{"plot_notes":"Beach Ridge Cemetery, Brockport, Monroe County NY (per Findagrave). Same as wife Lydia Mason Robinson Hooker."},"nickname":"Willie","residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"william-hooker-1864"},"HD3270":{"id":"HD3270","former_ids":["X02243"],"is_placeholder":false,"has_descendants_documented":true,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":true,"generation_from_thomas":10,"descent_from_thomas_hooker":true},"bio":{"first_name":"Lydia","middle_name":"Mason","last_name":"Hooker","maiden_name":"Robinson","married_names":["Hooker"],"gender":"female","display_name":"Lydia Mason Robinson Hooker"},"birth":{"year":1865,"month":7,"day":9,"state":"New York","country":"United States","city":"Murray","county":"Orleans County"},"death":{"year":1915,"month":2,"day":8,"city":"Holley","county":"Orleans County","state":"New York","country":"United States"},"parents":{"father_id":"X02287","mother_id":"HD3269"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H03880","date_year":1889,"date_month":1,"date_day":19,"location_state":"New York","location_country":"United States","end_type":"death","end_year":1915,"children_ids":["HD3236","HD3237","HD3238"]}],"tags":["cousin_marriage"],"sources":[{"short":"EH 3880 (as William Henry Hooker spouse)"},{"short":"WikiTree + Findagrave"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Cousin marriage united two Hooker-line branches","body":"Lydia Mason Robinson married William Henry Hooker on January 19, 1889 — the marriage joining two Hooker-line branches in a single household. Lydia descended from Captain Thomas Hooker through her grandmother Laura Electa Hooker Shader (Myron Hooker's daughter); William Henry descended through the parallel Thomas Edwin Hooker branch. They were third cousins once removed, and their three children inherited double Hooker ancestry."},{"number":2,"category":"family","header":"Three children, daughter Ethel died age thirty-one","body":"Lydia and William Henry had three children: Charles Theodore Hooker (1891-1971), Ethel Susan Hooker Zastrow (1896-1928 died young at thirty-one), and Marjory Violetta Hooker Delahanty (1902-1993). The Hooker-Zastrow line traces forward through Ethel; the Hebner-Cook-Stafford family that descended from these children is doubly Hooker-descended on both maternal and paternal sides."},{"number":3,"category":"family","header":"Born Murray NY 1865, died Holley 1915","body":"Lydia Mason Robinson was born July 9 or 10, 1865 in Murray, Orleans County New York. She died February 8, 1915 in Holley, Orleans County New York at age forty-nine — predeceasing her husband William Henry by eighteen years. The Orleans County NY core of the Hooker-Shader-Robinson cousin network spanned three generations of intermarriages within the same upstate New York county."}],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"lydia-hooker-1865"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}