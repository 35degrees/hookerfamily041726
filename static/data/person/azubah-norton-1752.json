nder":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02228","date_year":1838,"location_country":"United States","end_type":"death_of_spouse","end_year":1890,"children_ids":["HD3190","HD3191","HD3192"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Truman Bartlett","first_name":"Truman","last_name":"Bartlett","married_names":[],"photo_url":"https://images.findagrave.com/photos/2017/138/60834891_1495246133.jpg","photo_notes":"Findagrave portrait."},"burial":{"plot_notes":"Mount Pleasant Cemetery, Tibbets, Walworth County WI (per Findagrave). Photo URL: https://images.findagrave.com/photos/2017/138/60834891_1495246133.jpg"},"career":[{"role":"Lumberman","start_year":1836,"end_year":1844,"notes":"Worked in lumbering at Essex County NY from age 21 (1836-1838); back to Vermont 1838-1844; relocated to Wisconsin Oct 1844."},{"role":"Sawmill operator","start_year":1844,"end_year":1856,"notes":"Operated a sawmill in Spring Prairie, Walworth County, Wisconsin for 12 years."},{"role":"Farmer","organization":"Truman Bartlett farm (later Lauderdale Farms)","start_year":1856,"notes":"In 1856 bought a 100-acre farm north of Elkhorn (Section 6, town of LaFayette, Walworth County WI). By 1882 had increased to 180 acres (100 acres farmland $50/acre + 80 acres in Troy at $12/acre). Property later became Lauderdale Farms (Sylvandale 1908; bought by S.J. Lauderdale 1908)."}],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"truman-bartlett-1815"},"HD0950":{"id":"HD0950","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD0436","mother_id":"X00206"},"tags":["wisconsin_migration"],"sources":[],"birth":{"year":1817},"death":{"year":1914},"gender":"female","marriages":[{"marriage_number":1,"spouse_id":"X01615","date_year":1838,"date_month":4,"date_day":28,"location_city":"Rutland","location_county":"Rutland County","location_state":"Vermont","location_country":"United States","end_type":"death_of_spouse","end_year":1868,"children_ids":["HD3200","HD3201","HD3195","HD3202","HD3203","HD3204","HD3206","HD3205","HD3207"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Miranda Emily Bartlett Adams","first_name":"Miranda","last_name":"Adams","middle_name":"Emily","maiden_name":"Bartlett","married_names":["Adams"]},"burial":{"cemetery_id":"CEM049","plot_notes":"Brick Church Cemetery, Greenbush WI (per Findagrave). Same cemetery as her parents Hooker Bartlett + Hannah Baldwin."},"narrative_blocks":[{"number":1,"category":"family","header":"Mother of nine — five sons survived her","body":"Miranda Emily Bartlett Adams bore nine children with husband Abram Adams between 1839 and 1860 — three years pre-Wisconsin (born VT) and six post-Wisconsin (born WI). She lost her son Mortimer to typhoid in the Civil War (1862, age 19) and her daughter Helen young (1871, age 24). At her death in 1914 at age 96, the Sheboygan Press obituary named five surviving sons (Samuel, Noble, Emert, Eugene, Delisle) and three daughters."}],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"miranda-adams-1817"},"HD0951":{"id":"HD0951","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD0436","mother_id":"X00206"},"tags":["civil_war","killed_in_action"],"sources":[],"birth":{"year":1822},"death":{"year":1864,"month":7,"day":22,"city":"New Orleans","county":"Orleans Parish","state":"Louisiana","country":"United States","cause":"killed in action at Port Hudson, Louisiana"},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"military_service":[{"war":"American Civil War","rank":"Private","unit":"Company B, 35th Wisconsin Infantry","notes":"Killed Jul 22, 1864 at Port Hudson, Louisiana.","war_id":"WAR006"}],"bio":{"display_name":"Levi H. Bartlett","first_name":"Levi","last_name":"Bartlett","middle_name":"H.","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777226502/LeviBartlett_s7dafp.png","photo_notes":"Civil War tintype, c. 1860-1869. Per Sam's attribution decision: this is HD0951 PVT Levi H. Bartlett (Co. B, 35th Wisconsin Infantry); the Wisconsin Historical Society catalog (which lists it as 'Co. G, 37th Massachusetts Volunteer Infantry') is presumed to have a unit transcription error since the image is held in a Wisconsin source for a Wisconsin soldier."},"burial":{"plot_notes":"Chalmette National Cemetery, Chalmette, St. Bernard Parish LA (per Findagrave)."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"military","header":"Killed in action Port Hudson, Louisiana, July 1864","body":"Levi H. Bartlett was killed on July 22, 1864 at the vicinity of Port Hudson Louisiana during the Civil War, at about age forty-two. He was serving as a private in Company B, Thirty-fifth Wisconsin Infantry — having enlisted from Wisconsin despite his Vermont origin. The Port Hudson siege was a critical Union operation to control the lower Mississippi River; the fortified Confederate position had finally fallen the year before, but skirmishes and casualties continued throughout 1864."},{"number":2,"category":"military","header":"Vermont birth, Wisconsin enlistment, Louisiana death","body":"Levi H. Bartlett was born around 1822 in Vermont. By the time of his Civil War enlistment he was living in Wisconsin and joined the Thirty-fifth Wisconsin Infantry — the cross-country movement from his New England birthplace to his midwestern enlistment was characteristic of mid-nineteenth-century American settler migration. His death in Louisiana completed a Vermont-Wisconsin-Louisiana arc spanning his lifetime."},{"number":3,"category":"family","header":"Left widow Elizabeth; buried Chalmette National","body":"Levi was survived by his widow Elizabeth Bartlett. He is buried at Chalmette National Cemetery in Saint Bernard Parish Louisiana — the federally-administered military cemetery for Union soldiers killed in the lower Mississippi River campaigns of the Civil War. The cemetery clusters thousands of Union dead from operations at Port Hudson, New Orleans, and surrounding theaters of the western Confederacy collapse."}],"slug":"levi-bartlett-1822"},"HD0952":{"id":"HD0952","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD0436","mother_id":"X00206"},"tags":[],"sources":[],"birth":{"year":1827,"month":10,"day":17,"state":"Vermont","country":"United States"},"death":{"year":1916,"month":7,"day":9,"city":"Little Falls","county":"Morrison County","state":"Minnesota","country":"United States"},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X01909","children_ids":["HD2784","HD2785","HD2786","HD2787","HD2788"],"date_year":1851,"date_month":2,"date_day":4,"location_city":"Fond du Lac","location_state":"Wisconsin