ds":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Ursula","middle_name":"Wyatt","last_name":"Trudeau","maiden_name":"Johnston","married_names":["Trudeau"],"gender":"female","display_name":"Ursula Wyatt Johnston Trudeau","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778700987/ursulalyman_nxbxsd.png","photo_notes":"Portrait of Ursula Wyatt Johnston Trudeau (1932-2019)."},"birth":{"year":1932,"month":1,"day":17,"city":"Montréal","state":"Quebec","country":"Canada"},"baptism":{},"death":{"year":2019,"month":12,"day":5,"city":"Saranac Lake","county":"Franklin County","state":"New York","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM329","plot_notes":"Saint Johns In The Wilderness Episcopal Cemetery, Brighton NY — same as husband Dr. Francis Berger Trudeau Jr."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00632","mother_id":"HD4192"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00633","date_year":1961,"end_type":"death_of_spouse","end_year":1995,"children_ids":["X02823"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["canada_migration","new_york_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Montreal twin married Trudeau Institute president","body":"Ursula Wyatt Johnston was born January 17, 1932 in Montreal, twin sister of Walter Tudor Wyatt Johnston. She married Dr. Francis Berger Trudeau Jr. in 1961 — he was the founding president of the Trudeau Institute in Saranac Lake New York and grandson of Dr. Edward Livingston Trudeau, the tuberculosis treatment pioneer. She lived in Saranac Lake until her death in 2019 at age eighty-seven and was buried alongside her husband at Saint Johns In The Wilderness Episcopal Cemetery in Brighton New York."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"ursula-trudeau-1932"},"I00633":{"id":"I00633","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"title":"Doctor","first_name":"Francis","middle_name":"Berger","last_name":"Trudeau","suffix":"Jr.","married_names":[],"gender":"male","display_name":"Doctor Francis Berger Trudeau Jr.","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778701067/francistrudeua_jq2kna.jpg","photo_notes":"Portrait of Dr. Francis Berger Trudeau Jr. (1919-1995), Trudeau Institute founding president."},"birth":{"year":1919,"month":7,"day":21,"city":"Saranac Lake","county":"Franklin County","state":"New York","country":"United States"},"baptism":{},"death":{"year":1995,"month":4,"day":25,"city":"Saranac Lake","county":"Franklin County","state":"New York","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM329","plot_notes":"Saint Johns In The Wilderness Episcopal Cemetery, Brighton NY."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["medicine","science"],"notable_blurb":"Trudeau Institute founding president, 1980 Olympics ski team","primary_url":"https://www.findagrave.com/memorial/123921752/francis_berger-trudeau","primary_url_label":"FindAGrave memorial #123921752"},"parents":{"father_name":"Dr. Francis Berger Trudeau Sr.","father_research_notes":"Dr. Francis Berger Trudeau Sr. (Saranac Lake physician). His own father was Dr. Edward Livingston Trudeau (1848-1915), founder of Trudeau Sanatorium and pioneer of US tuberculosis treatment. Three-generation Trudeau physician dynasty."},"number_of_marriages":1,"marriages":[{"marriage_number":2,"spouse_id":"HD4195","date_year":1961,"end_type":"death","end_year":1995,"children_ids":["X02823"]}],"education":[{"institution_id":"INST022","dates":"1938-1942","type":"undergraduate","notes":"Yale University, BA 1942. Also did ski jumping for Yale in the 1930s."},{"school_name":"Columbia University College of Physicians and Surgeons","dates":"-1950","type":"medical","notes":"Columbia MD 1950."},{"school_name":"Bellevue Hospital and New York University","type":"residency","notes":"Intern and resident at Bellevue Hospital and NYU."},{"school_name":"Royal Victoria Hospital, Montreal","type":"fellowship","notes":"Further training at the Royal Victoria Hospital Montreal — connection to the Lyman/Johnston Montreal family his wife Ursula came from."}],"career":[{"role":"Founding President","organization":"Trudeau Institute","location":"Saranac Lake, NY","start_year":1954,"notes":"Trudeau Institute research center — successor institution to his grandfather Dr. Edward Livingston Trudeau's pioneering tuberculosis sanatorium. Served as president from 1954 until shortly before his death; chairman emeritus thereafter."},{"role":"Internal medicine physician","organization":"Saranac Lake, NY","location":"Saranac Lake, NY","start_year":1954,"end_year":1985,"notes":"Practiced internal medicine in Saranac Lake from 1954 until retirement in 1985."},{"role":"Chief of Medicine","organization":"General Hospital, Saranac Lake","location":"Saranac Lake, NY","start_year":1960,"end_year":1977,"notes":"Chief of medicine for 17 years."},{"role":"Senior Medical Officer, Nordic events","organization":"1980 Winter Olympic Games (Lake Placid)","location":"Lake Placid, NY","start_year":1980,"end_year":1980,"notes":"Senior medical officer for Nordic events at 1980 Winter Olympics. Also team physician for the US Nordic Ski Team."},{"role":"Commissioner","organization":"Adirondack Park Agency","location":"New York","notes":"Appointed to the newly-formed Adirondack Park Agency by Gov. Hugh Carey in the mid-1970s — second Essex County commissioner; stepped down following dispute over the legality of his appointment under APA single-county-commissioner rule."}],"military_service":[{"war":"World War II","war_id":"WAR008","unit":"United States Navy","notes":"WWII Navy veteran."}],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1938-1942","institution_blurb":"Yale BA 1942; ski jumped for Yale in the 1930s."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["yale_graduate","physician","wwii","navy","collegiate_athlete","new_york_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Third Trudeau physician, founded Trudeau Institute","body":"Dr. Francis Berger Trudeau Jr. was the third generation of Trudeau physicians at Saranac Lake — his grandfather Dr. Edward Livingston Trudeau founded the Trudeau Sanatorium and pioneered tuberculosis treatment in the United States. After Yale 1942, Navy service in World War II, and Columbia medical school 1950, he returned to Saranac Lake and practiced internal medicine for thirty-one years. He served as founding president of the Trudeau Institute research center from 1954 until shortly before his death and was named chairman emeritus in his final months."},{"number":2,"category":"career","header":"Yale ski jumper, 1980 Olympics Nordic team physician","body":"Francis Trudeau ski-jumped for Yale in the 1930s and remained a competitive Nordic skier through life — in 1982, after hip replacement surgery, he won first place in a fifteen-kilometer Empire State Games masters race. He served as senior medical officer for Nordic events at the 1980 Winter Olympic Games at Lake Placid, as physician for the United States Nordic Ski Team, and as physician for the Saranac Lake Central School District. He died April 25, 1995 at age seventy-five."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"francis-trudeau-jr-1919"},"X02823":{"id":"X02823","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Garry","middle_name":"Beekman","last_name":"Trudeau","married_names":[],"extra_names":"Garretson Beekman Trudeau (formal birth name)","gender":"male","display_name":"Garry Trudeau"},"birth":{"year":1948,"month":7,"day":21,"city":"New York","county":"New York County","state":"New York","country":"United States"},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["arts","journalism"],"notable_blurb":"Pulitzer-winning Doonesbury cartoonist, Yale graduate","primary_url":"https://en.wikipedia.org/wiki/Garry_Trudeau","primary_url_label":"Wikipedia — Garry Trudeau"},"parents":{"father_id":"I00633","mother_name":"Jean Moore Amory","mother_research_notes":"First wife of I00633 Dr. Francis Berger Trudeau Jr. Jean Moore Amory was Garry's biological mother (Ursula Wyatt Johnston was Garry's stepmother starting from his father's 1961 second marriage). Not built per Jalapeño Rule.","mother_id":"HD4195"},"marriages":[],"education":[{"institution_id":"INST022","dates":"-1970","type":"undergraduate","notes":"Yale University BA 1970."},{"institution_id":"INST022","dates":"-1973","type":"graduate","notes":"Yale MFA 1973."}],"career":[{"role":"Cartoonist / Author","organization":"Doonesbury (syndicated by Universal Press Syndicate)","location":"United States","start_year":1970,"notes":"Created Doonesbury — debuted at Yale Daily News 1968 as 'Bull Tales,' syndicated nationally October 26, 1970. Won the 1975 Pulitzer Prize for Editorial Cartooning — first time the prize was awarded to a comic strip. Continued running Doonesbury for over five decades."}],"military_service":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1966-1973","institution_blurb":"Yale BA 1970 and MFA 1973; Doonesbury launched in the Yale Daily News in 1968."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["yale_graduate","new_york_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Pulitzer 1975, first comic strip win","body":"Garry Trudeau created Doonesbury at Yale in 1968 as 'Bull Tales' for the Yale Daily News; it was syndicated nationally October 26, 1970 by Universal Press Syndicate. In 1975 he won the Pulitzer Prize for Editorial Cartooning — the first time the prize was ever awarded to a comic strip. He continued writing Doonesbury for over five decades, with his work consistently engaging American political and cultural life from Watergate forward."},{"number":2,"category":"family","header":"Stepson of Hooker descendant, bronze bust 1994","body":"Garry Trudeau is the biological son of Dr. Francis Berger Trudeau Jr. from his first marriage to Jean Moore Amory. When his father remarried Ursula Wyatt Johnston in 1961, Garry was thirteen; his stepmother Ursula was the Hooker descendant through the Lyman-Mills-Mills-Stiles-Hooker line. In August 1994 Garry presented his father with a bronze bust at the Trudeau Institute library in Saranac Lake — documented direct interaction with the institution that united his Trudeau family with the Hooker-descent Lyman family of Montreal."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"garry-trudeau-1948"},"HD4182":{"id":"HD4182","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Walter","middle_name":"Ernest","last_name":"Lyman","m