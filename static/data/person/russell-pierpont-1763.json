piration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1751"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"religion","header":"Yale 1751 — fifty-nine years parish clerk","body":"He graduated Yale in 1751 and served as parish clerk for fifty-nine years — first at the Congregational church, then at St. John's Episcopal in North Haven. The Congregational church refused to accept his resignation, so for four years he served as clerk of both simultaneously."},{"number":2,"category":"politics","header":"First Episcopalian appointed Justice of the Peace","body":"He was the first Episcopalian appointed Justice of the Peace by the Connecticut Legislature. He served nine times in the Connecticut General Assembly, beginning in 1787 when North Haven was first incorporated as a town."},{"number":3,"category":"religion","header":"Lightning struck six on a sabbath-day-house bench","body":"On July 29, 1771, Capt. Pierpont, his wife Lydia, and four others were struck by lightning while seated on one bench in a sabbath-day-house. Three horses and a colt were killed instantly; all six humans survived."},{"number":4,"category":"military","header":"Captain in the Connecticut Militia, served the Revolution","body":"He was commissioned first lieutenant of the Ninth Company, Second Regiment Connecticut Militia in 1760, and captain in 1764. His gravestone confirms he served in the Revolution."}],"education":[{"school_name":"Yale College","dates":"1751","type":"college"}],"career":[{"role":"Farmer and general trader","location":"North Haven"},{"role":"Representative","organization":"Connecticut General Assembly"},{"role":"Parish Clerk","organization":"St. John’s Church","notes":"59 years"}],"slug":"joseph-pierpont-1730"},"X00456":{"id":"X00456","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":