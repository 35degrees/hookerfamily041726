ay":31,"location_city":"Meadville","location_county":"Crawford County","location_state":"Pennsylvania","location_country":"United States","end_type":"death","end_year":1844,"children_ids":["HD4243"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["pennsylvania_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"sarah-buchanan-1807"},"HD4243":{"id":"HD4243","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Elizabeth","middle_name":"Ruth","last_name":"Byllesby","maiden_name":"Ellis","married_names":["Byllesby"],"gender":"female","display_name":"Elizabeth Ruth Ellis Byllesby"},"birth":{"year":1843,"month":3,"day":12,"city":"Meadville","county":"Crawford County","state":"Pennsylvania","country":"United States"},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD4235","mother_id":"I00654"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01293","date_year":1864,"date_month":6,"date_day":1,"children_ids":["HD4254","HD4255","HD4256","HD4257","HD4258","HD4259"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Ruth","inspired_by_id":"H00465","description":"Middle name Ruth honors paternal grandmother Ruth Stiles Ellis (1778-1863, then still living at the time of Elizabeth's birth ~1843)."}],"artworks":[],"tags":["episcopal","pennsylvania_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Mother died when she was an infant","body":"Elizabeth Ruth Ellis was the only child of Dr. Edward Ellis's second marriage to Sarah Buchanan. Her mother died on March 14, 1844 — when Elizabeth was about a year old — and she was raised by her father through his subsequent widowhood. The single-parent childhood marked her early years in Meadville Pennsylvania."},{"number":2,"category":"family","header":"Married rector of her father's church","body":"In 1864 Elizabeth married Rev. Morison Byllesby — then and for some time afterward Rector of Christ Church Meadville Pennsylvania. Her father Dr. Edward Ellis served the same parish as Warden and Vestryman. The intra-parish marriage kept the family centered in the same Episcopal community across two generations."},{"number":3,"category":"death","header":"Lost infant son Edward to cholera","body":"Elizabeth and Rev. Byllesby's third child Edward Ellis Byllesby was born July 3, 1868 and died of cholera around August 1, 1868 — about one month old. The infant death named for Elizabeth's father captured both the family's affection for the Ellis name and the period's ongoing vulnerability to epidemic disease before modern sanitation."},{"number":4,"category":"family","header":"Six children; only surviving child of father","body":"Elizabeth had six documented children with Rev. Byllesby: Ruth Ellis (1865), Lewis Smith, Edward Ellis (1868-1868 cholera), Ellis Buchanan (1872), Langton (1873), and Sarah Elizabeth (1875). At her father Dr. Edward Ellis's 1885 death his obituary noted 'He leaves but one child, Mrs. Byllesby' — confirming Elizabeth was his only surviving child despite his multiple marriages."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"elizabeth-byllesby-1843"},"I01293":{"id":"I01293","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":fal