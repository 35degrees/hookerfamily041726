uotes":[],"military_service":[],"slug":"david-hebner-1863"},"H05030":{"id":"H05030","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":true,"generation_from_thomas":10},"bio":{"first_name":"Lucy","middle_name":"M.","last_name":"Hebner","maiden_name":"Hooker","married_names":["Hebner"],"gender":"female","display_name":"Lucy M. Hooker Hebner","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777239390/davidandlucyhebner_t4spcj.png","photo_notes":"Photo shows David and Lucy together; same Cloudinary URL applied to both their entries"},"birth":{"year":1864,"month":3,"day":16,"state":"New York","country":"United States","historical_notes":"Per EH 5030 + WikiTree: b. March 16, 1864 NY (WikiTree says \"about 16 Mar 1864\" matching EH)."},"death":{"year":1924,"month":12,"day":24,"city":"Medina","county":"Orleans County","state":"New York","country":"United States","note":"Died Christmas Eve 1924 in Medina NY. Outlived first child Jay (KIA 1918) by six years. Sometimes recorded as \"Louise\" Hooker — informal alternate name (per Findagrave for daughter Etta E Hebner Cook)."},"parents":{"father_id":"H03872","mother_id":"X02269"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02270","date_year":1883,"date_month":1,"date_day":1,"location_state":"New York","location_country":"United States","children_ids":["HD3254","HD3255"],"notes":"Per EH 3872: m. Jan 1, 1883 — New Year's Day wedding. WikiTree records David L. Hebner as her husband."}],"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 5030 (under Thomas Harvey Hooker children)"},{"short":"WikiTree: Lucy (Hooker) Hebner","url":"https://www.wikitree.com/"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"burial":{"cemetery_id":"CEM150","plot_notes":"Boxwood Cemetery, Medina Orleans County NY — same plot as husband David Conrad Hebner"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"lucy-hebner-1864"},"H03872":{"id":"H03872","former_ids":["HD3223"],"is_placeholder":false,"gender":"male","has_descendants_documented":true,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"is_easter_egg":false,"include_in_path_calculation":true,"descent_from_thomas_hooker":true},"bio":{"first_name":"Thomas","middle_name":"Harvey","last_name":"Hooker","married_names":[],"gender":"male","display_name":"Thomas Harvey Hooker"},"birth":{"year":1840,"month":7,"day":15,"city":"Murray","county":"Orleans County","state":"New York","country":"United States"},"death":{"year":1919,"city":"Stafford","county":"Genesee County","state":"New York","country":"United States"},"parents":{"father_id":"H02424","mother_id":"X02241"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02269","date_year":1863,"date_month":2,"date_day":12,"location_state":"New York","location_country":"United States","end_type":"death","end_year":1919,"children_ids":["H05030","H05031"]}],"tags":["cousin_marriage"],"sources":[{"short":"Findagrave"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Married third cousin from Myron Hooker line","body":"Thomas Harvey Hooker married Caroline E. 'Carrie' Shader on February 12, 1863. Both spouses were third cousins descending from Captain Thomas Hooker — Thomas Harvey through his father Thomas Edwin Hooker, and Caroline through her mother Laura Electa Hooker Shader whose father Myron Hooker was Thomas Edwin's half-brother. The cousin-marriage united two Hooker descent paths that had separated several generations earlier."},{"number":2,"category":"family","header":"His cousin marriage merged two separated Hooker lines","body":"Thomas Harvey Hooker's marriage to his third cousin Caroline Shader re-merged two Hooker family lines that had separated three generations earlier through the half-brother split between his father Thomas Edwin and her grandfather Myron. The cousin marriage was a deliberate or coincidental rejoin of two parallel Hooker descent streams in western New York. He and his wife maintained the Hooker surname throughout their marriage."},{"number":3,"category":"family","header":"Eldest son of Thomas Edwin Hooker","body":"Thomas Harvey Hooker was born July 15, 1840 in Murray, Orleans County New York — eldest son of Thomas Edwin Hooker and Lucy Hyde Hooker. The Hooker family had migrated to the western New York lake-plain region during the early nineteenth century along with many other Connecticut Yankees seeking new agricultural land."},{"number":4,"category":"family","header":"Born Orleans County NY, died Stafford NY 1919","body":"Thomas Harvey Hooker died March 21, 1919 in Stafford, Genesee County New York at age seventy-eight. His two children — Lucy and Alvah — both lived into the mid-twentieth century, with Alvah surviving until 1953 and Lucy until 1924."}],"cross_connections":[],"burial":{"cemetery_id":"CEM152","plot_notes":"Stafford Rural Cemetery, Stafford Genesee County NY — same plot area as wife Caroline + daughter Alva + son-in-law Jean Mason + infant grandson H. Mason"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"thomas-hooker-1840"},"X02269":{"id":"X02269","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":true},"bio":{"first_name":"Caroline","middle_name":"E.","last_name":"Hooker","maiden_name":"Shader","married_names":["Hooker"],"nickname":"Carrie","gender":"female","display_name":"Caroline E. \"Carrie\" Shader Hooker"},"birth":{"year":1842,"month":3,"day":16,"city":"Wethersfield","county":"Wyoming County","state":"New York","country":"United States","historical_notes":"Per EH 3872: b. March 16, 1842 Wethersfield. WikiTree records \"Wethersfield Springs, Wyoming County NY\" — same location."},"death":{"year":1923,"month":1,"day":19,"state":"New York","country":"United States","city":"Stafford","county":"Genesee County"},"parents":{"father_id":"X02280","mother_id":"HD3260","mother_research_notes":"Laura E. Hooker Shader (HD3260, b.1818 VT, Myron Hooker's daughter — making Caroline a Hooker descendant on her mother's side)"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H03872","date_year":1863,"date_month":2,"date_day":12,"location_state":"New York","location_country":"United States","end_type":"death_of_spouse","end_year":1919,"children_ids":["H05030","H05031"]}],"tags":["cousin_marriage"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 3872 (as Thomas Harvey Hooker spouse)"},{"short":"WikiTree: Caroline E. Shader","url":"https://www.wikitree.com/"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"burial":{"cemetery_id":"CEM152","plot_notes":"Stafford Rural Cemetery, Stafford Genesee County NY — alongside husband Thomas Harvey and daughter Alva"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"caroline-shader-1842"}},"burialCemetery":{"id":"CEM150","name":"Boxwood Cemetery","city":"Medina","county":"Orleans County","state":"New York","zip":"14103","gps":{"latitude":43.2181,"longitude":-78.39193},"visitable":true,"notes":"Long-standing Medina NY cemetery serving Orleans County. The Hebner-Cook family plot complex includes David Conrad Hebner (1863-1930), his wife Lucy M. Hooker Hebner (1864-1924), their daughter Etta E. Hebner Cook (1896-1957), her husband Irving Burns Cook (1895-1968), and their two sons Clarence Irving 'Cookie' Cook (1918-1977) and Donald David 'Cookie' Cook (1922-2004), plus Donald's wife Shirley Marie Perry Cook (1936-1967). In 2016, a CENOTAPH for PVT Jay David Hebner (1895-1918, KIA WWI in France, actually buried at Saint-Mihiel American Cemetery) was added to the Hebner-Cook plot complex through the efforts of Jay's great-niece Debbie Morse (Dabrina D. Cook Morse) — Donald's daughter — restoring his memory to Medina after nearly 100 years of absence from the village.","hooker_connections":["H05030","HD3254","HD3255","HD3256","HD3257","X02270","X02271","X02273"]},"institutionsById":{},"crossConnections":[]}