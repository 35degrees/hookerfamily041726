":false,"is_easter_egg":false},"birth":{"year":1726,"month":10,"day":23},"death":{"year":1802,"month":9,"day":28,"city":"Greenfield","state":"Massachusetts"},"parents":{"father_id":"HD0007","mother_id":"I00026"},"tags":["durham_newton","greenfield_newton","revolutionary_war"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 148"},{"short":"Caroline Gaylord Newton 1914"}],"marriages":[{"spouse_id":"I00082","children_ids":["HD0154","HD0155","HD0156","HD0157","HD0158","HD0159","HD0160","HD0161","HD0162"],"marriage_number":1},{"children_ids":[],"spouse_id":"X01017","marriage_number":2}],"political_offices":[{"title":"Assessor","jurisdiction":"Greenfield, Massachusetts"},{"title":"Selectman","jurisdiction":"Greenfield, Massachusetts"},{"title":"Overseer of the Poor","jurisdiction":"Greenfield, Massachusetts"},{"title":"Member of the Legislature","jurisdiction":"Massachusetts","notes":"After close of Revolutionary War"}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"John Newton","first_name":"John","last_name":"Newton","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"military","header":"Lexington Alarm minute man at age forty-eight","body":"He responded to the Lexington Alarm of April 1775 as a minute man in Capt. Jonas Lock's company, Col. Williams's Massachusetts regiment. He had been commissioned earlier to apprehend Tories in Durham, Connecticut."},{"number":2,"category":"family","header":"Born twin — Greenfield reunion with brother Roger","body":"He was twin to Abner Newton Jr., born together October 23, 1726 in the Durham Main Street house. After the Revolution he removed to Greenfield, Massachusetts, where his brother Rev. Roger Newton was minister for 53 years."},{"number":3,"category":"family","header":"Hemlock swamps that became valuable land","body":"He, his son Isaac, and his brother Roger purchased many acres of wild land in Greenfield at 7 shillings 6 pence per acre. The hemlock swamp later became valuable; he held many civic offices in the town after the war."},{"number":4,"category":"death","header":"His second wife died two weeks before him","body":"His second wife Hulda died September 14, 1802 in Greenfield, age 60. He died two weeks later on September 28, age nearly 76."}],"slug":"john-newton-1726"},"HD0154":{"id":"HD0154","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1748,"month":2,"day":28},"death":{"year":1824,"month":9,"day":23},"parents":{"father_id":"H00148","mother_id":"I00082"},"tags":["greenfield_newton","revolutionary_war"],"sources":[{"short":"Caroline Gaylord Newton 1914"}],"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"parallel_descent","related_id":"HD2926","display_label":"Another Isaac Newton, born same era, both Hooker descendants","link_text":"Isaac Newton"}],"military_service":[{"war":"American Revolutionary War","war_id":"WAR001","side":"United States","rank":"Captain","rank_start":"soldier","rank_end":"Captain","rank_year_end":1781,"unit":"Continental Army; took command of 113 men at West Point July 1, 1781","notes":"Present at Fort Edward when General Burgoyne surrendered (1777 turning point) and at West Point when Benedict Arnold's treachery was discovered and Arnold fled to British lines. Was on board the British warship Vulture (which had carried Major André) and there saw General Washington. Received Captain's commission July 1, 1781 and the same day took command of 113 men at West Point."}],"bio":{"title":"Captain","display_name":"Captain Isaac Newton","first_name":"Isaac","last_name":"Newton","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST035"}],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"military","header":"At West Point when Benedict Arnold fled","body":"Captain Isaac Newton was present at West Point when Benedict Arnold's treachery was discovered and Arnold fled to the British. He was on board the Vulture — the British warship that had carried Major André — and there saw General Washington. The 1780 episode placed him at one of the Revolutionary War's most dramatic single moments of decision."},{"number":2,"category":"military","header":"Also at Fort Edward for Burgoyne's surrender","body":"Isaac Newton was at Fort Edward in 1777 when General John Burgoyne surrendered — the turning-point battle that brought France into the war as a U.S. ally. Combined with his West Point presence three years later, Newton was an eyewitness participant at two of the three most consequential single events of the Revolutionary War's northern theater."},{"number":3,"category":"military","header":"Captain's commission and 113 men, July 1781","body":"On July 1, 1781 Captain Isaac Newton received his Captain's commission and the same day took command of 113 men at West Point. The simultaneous-day commission-and-command was unusual — most officers received their commissions days or weeks before their assigned units. The arrangement reflected the wartime pace of unit-rotation at West Point during the final years of the war."},{"number":4,"category":"family","header":"Born Milford 1748, died Greenfield MA 1824","body":"Isaac Newton was born July 12, 1748 in Milford Connecticut and died June 3, 1824 in Greenfield Massachusetts at age seventy-five. He was the son of John Newton — the family's progenitor of the Greenfield Massachusetts Newton branch — and grandson of the Newton-Hooker line through Mary Hooker Newton."}],"slug":"isaac-newton-1748"},"HD0155":{"id":"HD0155","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1750,"month":7,"day":29},"parents":{"father_id":"H00148","mother_id":"I00082"},"tags":["greenfield_newton"],"sources":[{"short":"Caroline Gaylord Newton 1914"}],"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"death":{},"cross_connections":[{"type":"parallel_descent","related_id":"HD2925","display_label":"Another John Newton, same Hooker tree, parallel branch","link_text":"John Newton"}],"bio":{"display_name":"John Newton","first_name":"John","last_name":"Newton","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-newton-1750"},"HD0156":{"id":"HD0156","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1752},"parents":{"father_id":"H00148","mother_id":"I00082"},"tags":["greenfield_newton"],"sources":[{"short":"Caroline Gaylord Newton 1914"}],"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"death":{},"cross_connections":[],"bio":{"display_name":"Samuel Newton","first_name":"Samuel","last_name":"Newton","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes"