ion":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2375","mother_id":"X00771"},"tags":["hawaii_mission_era"],"sources":[],"birth":{"year":1815,"month":1,"city":"Northampton","state":"Massachusetts","country":"United States"},"death":{"year":1880,"month":8,"city":"Honolulu","state":"Hawaii","country":"United States"},"marriages":[{"spouse_id":"X00772","children_ids":["HD2377","HD2378","HD2379"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"institutions":[{"institution_id":"INST041","institution_blurb":"ABCFM missionary to Hawaii; children named for ABCFM colleagues Juliette Cooke and Samuel Castle."}],"narrative_blocks":[{"number":1,"category":"career","header":"ABCFM missionary to Hawaii","body":"He sailed to Hawaii in 1848 as an ABCFM missionary and served there until his death in Honolulu in 1880. He named his children for ABCFM colleagues: Juliette Cooke Dwight (for Juliette Montague Cooke, ABCFM missionary) and Samuel Castle Dwight (for Samuel Northrup Castle, ABCFM lay agent). His branch of the Hooker tree ends in Hawaii."},{"number":2,"category":"family","header":"Lived alongside John Dominis in Honolulu's missionary circle","body":"Samuel Gelston Dwight died in Honolulu in August 1880 as a prominent figure in the same small missionary-connected elite as John Owen Dominis — the man born in 1832 at Reverend Andrew Yates's Schenectady home, whose wife Hannah Allin Hooker was a seventh-generation descendant of Thomas Hooker. Dwight named his daughter Juliette Cooke Dwight for Juliette Montague Cooke, co-founder of the Royal School in Honolulu — the very school next to which young Dominis first encountered the royal children, setting in motion his courtship of the future Queen Liliʻuokalani."}],"cross_connections":[{"type":"civic_connection","related_id":"I00899","display_label":"Dominis born at Yates's home; Dwight knew him in Honolulu","link_text":"Reverend Andrew Yates"},{"type":"family_orbit","related_id":"X02833","display_label":"Both lived in Honolulu's missionary elite for decades","link_text":"John Owen Dominis"}],"bio":{"display_name":"Samuel Gelston Dwight","first_name":"Samuel","last_name":"Dwight","middle_name":"Gelston","married_names":[],"photo_url":"https://www.wikitree.com/photo.php/9/97/Dwight-779.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"samuel-dwight-1815"},"HD2377":{"id":"HD2377","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2376","mother_id":"X00772"},"tags":[],"sources":[],"birth":{"year":1857,"city":"Hawaii","state":"Hawaii"},"death":{"year":1917,"city":"Honolulu","state":"Hawaii"},"gender":"female","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Juliette Cooke Dwight","first_name":"Juliette","middle_name":"Cooke","maiden_name":"Dwight","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Named for the woman who ran the school","body":"Juliette Cooke Dwight was named for Juliette Montague Cooke, who co-founded the Royal School (Chiefs' Children's School) in Honolulu in 1839 — the school next to which the young John Owen Dominis first befriended the royal children, including the girl who would become Queen Liliʻuokalani. Dominis himself had been born in 1832 at the Schenectady home of Reverend Andrew Yates, whose wife Hannah Allin Hooker was a Hooker descendant — threading this family's namesake back through the Yates household to the Hooker family of Windsor, Connecticut."}],"slug":"juliette-dwight-1857"},"HD2378":{"id":"HD2378","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2376","mother_id":"X00772"},"tags":[],"sources":[],"birth":{"year":1856,"month":6,"city":"Kalae","state":"Hawaii"},"death":{"year":1930,"month":2,"city":"Honolulu","state":"Hawaii"},"marriages":[{"spouse_id":"X00775","children_ids":["HD2387"],"marriage_number":1,"date_year":1877}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Samuel Castle Dwight","first_name":"Samuel","last_name":"Dwight","middle_name":"Castle","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"samuel-dwight-1856"},"X00775":{"id":"X00775","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1863},"death":{"year":1926},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2378","date_year":1877,"children_ids":["HD2387"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Harriette Kanekapoli Beck","f