:10},"bio":{"first_name":"Fred","middle_name":"Hooker","last_name":"Gordon","married_names":[],"suffix":"Sr.","gender":"male","display_name":"Frederick Hooker Gordon Sr.","bio_blurb":"Brockport banker who chose farming"},"birth":{"year":1881,"month":4,"day":9,"city":"Brockport","county":"Monroe County","state":"New York","country":"United States"},"death":{"year":1951,"month":9,"day":29,"city":"Rochester","county":"Monroe County","state":"New York","country":"United States"},"parents":{"father_id":"X02281","mother_id":"H03892"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02284","date_year":1906,"date_month":2,"date_day":3,"location_state":"New York","location_country":"United States","children_ids":["HD3275","HD3277"],"notes":"Per EH 5051 + family records: m. Feb 3, 1906 Florence DeMoss Robinson (b.1885 Monroe NY). At least two sons known: Lucius Robinson 'Bob' Gordon (1912-2008, RIT trustee + benefactor with Gordon Field House and Activities Center named for him + RIT honorary doctorate — possible NOTABLE candidate) and a second son not yet identified."}],"tags":["named_for_hooker"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 5051"},{"short":"Andrews family history (1908)","page":"p.77 — Whitehall Farms in Clarkson NY"},{"short":"RIT 'Remembering Lucius Bob Gordon, RIT Trustee and Benefactor 1912-2008'","page":"(re. son Lucius)"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"career","header":"He quit the family bank to farm","body":"At twenty-nine he walked away from the Gordon family bank for his own ground — Whitehall Farms, north of Brockport. His son Bob spent seventy years giving to a Rochester college that put the family name on its field house."}],"cross_connections":[],"burial":{"plot_notes":"Mount Hope Cemetery, Rochester NY — Section MM Lot 266"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions