:{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":false},"bio":{"first_name":"Virginia","last_name":"Gordon","maiden_name":"DeVilbiss","married_names":["Gordon"],"gender":"female","display_name":"Virginia DeVilbiss Gordon"},"birth":{"year":1914,"month":3,"day":23},"death":{"year":1997,"month":1,"day":24,"city":"Rochester","county":"Monroe County","state":"New York","country":"United States"},"burial":{"plot_notes":"Mount Hope Cemetery, Rochester NY"},"parents":{"father_id":"X02291","mother_id":"X02292"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3275","location_country":"United States","end_type":"death_of_spouse","end_year":2003,"children_ids":["HD3276"]}],"tags":[],"sources":[{"short":"Findagrave Mt. Hope"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"virginia-devilbiss-1914"},"HD3276":{"id":"HD3276","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":true,"generation_from_thomas":12},"bio":{"first_name":"Fred","middle_name":"Hooker","last_name":"Gordon","married_names":[],"suffix":"III","gender":"male","display_name":"Fred Hooker Gordon III"},"birth":{"year":1936,"state":"New York","country":"United States"},"death":{"year":1955,"month":2,"city":"Boston","county":"Suffolk County","state":"Massachusetts","country":"United States","cause":"Meningioma (brain tumor)"},"burial":{"plot_notes":"Mount Hope Cemetery, Rochester NY"},"parents":{"father_id":"HD3275","mother_id":"X02290"},"number_of_marriages":0,"marriages":[],"tags":["named_for_hooker"],"sources":[{"short":"Findagrave Mt. Hope Cemetery Rochester"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"fred-gordon-iii-1936"},"HD3277":{"id":"HD3277","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":true,"generation_from_thomas":11},"bio":{"first_name":"Lucius","middle_name":"Robinson","last_name":"Gordon","married_names":[],"nickname":"Bob","gender":"male","display_name":"Lucius Robinson \"Bob\" Gordon","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777245912/luciusbobgordon_hhvcc3.jpg","photo_notes":"Cloudinary; supplied by Sam"},"birth":{"year":1912,"month":7,"day":25,"city":"Brockport","county":"Monroe County","state":"New York","country":"United States"},"death":{"year":2008,"month":4,"day":28,"note":"RIT flag lowered to half-staff May 3, 2008 day of his memorial service."},"burial":{"plot_notes":"Mount Hope Cemetery, Rochester NY — Section MM Lot 266 (same plot as parents Fred Sr + Florence)"},"parents":{"father_id":"HD3266","mother_id":"X02284"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02293","location_state":"New York","location_country":"United States","end_type":"death_of_spouse","end_year":2006,"children_ids":[]}],"education":[{"institution":"Phillips Academy","location":"Andover MA","end_year":1931},{"institution":"Yale University, Sheffield Scientific School","location":"New Haven CT","start_year":1931,"end_year":1935,"degree":"Bachelor of Industrial Engineering"}],"careers":[{"role":"Co-leader / Chairman of the Board","employer":"Mixing Equipment Company (MIXCO)","location":"Rochester NY area + Canada/Australia/England","start_year":1937,"notes":"Joined brother Fred Hooker Gordon Jr (HD-prefix above) in 1937. Grew the company from 15 employees to factories in Canada, Australia and England. Awarded the Army-Navy 'E' during WWII for developing technology used to make war products. The company is now a division of SPX Corporation."},{"role":"Trustee","employer":"Rochester Institute of Technology","location":"Rochester NY","start_year":1975,"end_year":2008,"notes":"Honorary vice chairman. RIT Honorary Doctorate of Humane Letters 1999. Nathaniel Rochester Award. The Gordon Field House and Activities Center named for Lucius + wife Marie 'Tony' (dedicated September 10, 2004). Lucius gave $5 million in gifts and commitments toward the $25M field house. Other named at RIT: Marie and Lucius R. Gordon administrative wing in Student Life Center; Bob Gordon Shell (crew team rowing shell); Lucius Gordon Drive at the RIT Business and Technology Park."},{"role":"Board Member","employer":"Genesee Hospital, Hillside Children's Center, Allendale Columbia School, Rochester Savings Bank, Industrial Management Council","location":"Rochester NY"}],"tags":["academic","extraordinary_longevity","wwii","yale_graduate"],"sources":[{"short":"RIT Magazine, 'Remembering Lucius Bob Gordon, RIT Trustee and Benefactor: 1912-2008'","url":"https://www.rit.edu/news/remembering-lucius-bob-gordon-rit-trustee-and-benefactor-1912-2008"},{"short":"Lucius Robinson Gordon obituary (April 2008)"},{"short":"RIT Magazine Fall 2002 — Gordon Field House announcement","url":"http://www.rit.edu/magazine/fall2002/fieldhouse/"},{"short":"Findagrave (Mt. Hope Cemetery)"}],"notable":{"is_notable":true,"notable_blurb":"RIT trustee 70-year benefactor; Field House namesake","notable_category":["benefactor","industrialist","academic"],"primary_url":"https://www.rit.edu/news/remembering-lucius-bob-gordon-rit-trustee-and-benefactor-1912-2008","primary_url_label":"RIT obituary"},"narrative_blocks":[{"number":1,"category":"youth_adventure","header":"1935 Yukon Gold Rush retraced; 1936 Africa Kodachrome","body":"Lucius 'Bob' Gordon graduated Phillips Academy Andover (1931) and Yale's Sheffield Scientific School (Industrial Engineering, 1935). After college, he joined his uncle Ward Wickwire on a 1935 trip to the Yukon retracing the 1898 Gold Rush. Then he traveled with his cousin George Cooley Gordon III ( best man at his 1941 wedding) 6,000 miles across Africa from Cairo to Capetown."},{"number":2,"category":"career","header":"MIXCO grew from 15 employees to global factories","body":"In 1937, Lucius joined his brother Fred Hooker Gordon Jr. (HD-prefix above) at the Mixing Equipment Company (MIXCO). Together they grew it from 15 employees to factories in Canada, Australia, and England. During WWII the company was awarded the Army-Navy 'E' for developing technology used to make war products — including, with the help of Mechanics Institute (RIT's predecessor), improved aviation fuel for the British and American Air Forces."},{"number":3,"category":"philanthropy","header":"Gordon Field House at RIT dedicated 2004","body":"Lucius's relationship with RIT spanned seven decades, dating to 1937 when he and his brother Fred reached out to RIT's predecessor Mechanics Institute for machinists, lab technicians, chemists, and co-op students. He joined the RIT Board of Trustees in 1975, served as honorary vice chairman, and received the RIT Honorary Doctorate of Humane Letters in 1999 plus the Nathaniel Rochester Award. By 2002 he sensed RIT lacked one piece of student life — a field house."}],"cross_connections":[{"related_person_id":"HD3263","relationship":"first_cousin_kodachrome_africa_expedition","evidence":"With cousin George C. Gordon III, traveled 6,000 miles Cairo-to-Capetown ~1936. Eastman Kodak commissioned the cousins to test its new Kodachrome film. Lucius served as best man at George III's 1941 wedding (per NYT Aug 7, 1941).","display_label":"Cousins traveled Cairo-to-Capetown testing Kodachrome film","type":"family_connection"}],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"lucius-gordon-1912"},"X02293":{"id":"X02293","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":false},"bio":{"first_name":"Marie","middle_name":"Antoinette","last_name":"Gordon","maiden_name":"Townson","married_names":["Gordon"],"nickname":"Tony","gender":"female","display_name":"Marie Antoinette \"Tony\" Townson Gordon"},"birth":{"year":1918,"month":1,"day":20,"city":"Rochester","county":"Monroe County","state":"New York","country":"United States"},"death":{"year":2006,"month":2,"day":12,"county":"Monroe County","state":"New York","country":"United States"},"burial":{"plot_notes":"Mount Hope Cemetery, Rochester NY (Section MM Lot 266 with husband Lucius)"},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3277","location_state":"New York","location_country":"United States","end_type":"death","end_year":2006,"children_ids":[]}],"tags":[],"sources":[{"short":"Findagrave + Lucius obituary"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"marie-townson-1918"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}