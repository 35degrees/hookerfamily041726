etts"},"death":{"year":1890,"month":11,"city":"Pennsylvania","state":"Pennsylvania"},"orbit_connections":[{"name":"Theodore Roosevelt (X00744) — Harvard classmate and ornithology companion","person_id":"X00744","relationship":"Harvard classmates, class of 1880; both interested in ornithology","notes":"Roosevelt and Minot shared a passion for ornithology at Harvard. Minot published \"The Land Birds and Game Birds of New England\" at 17. Roosevelt later wrote extensively on natural history. ","connection_type":"orbit_non_descendant"}],"gender":"male","notable":{"is_notable":true,"notable_category":["science","business"],"notable_blurb":"Ornithologist; railroad executive; train-crash victim at thirty-one","primary_url":"https://en.wikipedia.org/wiki/Henry_Minot","primary_url_label":"Wikipedia"},"marriages":[],"cross_connections":[{"type":"parallel_careers","related_id":"X00744","display_label":"Harvard classmate; co-published Adirondacks bird list 1877","link_text":"Theodore Roosevelt"}],"bio":{"display_name":"Henry Davis Minot","first_name":"Henry","last_name":"Minot","middle_name":"Davis","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777495507/henryminot_bel0d8.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Published authoritative bird guide as a Harvard freshman","body":"His 'Land Birds and Game Birds of New England' (1877) appeared when he was a seventeen-year-old college freshman. The volume remained an authoritative reference for New England ornithology for the next two decades."},{"number":2,"category":"character","header":"Theodore Roosevelt's closest Harvard ornithology friend","body":"He and TR met as freshman classmates at Harvard in 1877, both already serious ornithologists. They spent vacations listing birds in the Adirondacks and co-authored 'The Summer Birds of the Adirondacks' that fall — Roosevelt's first published work."},{"number":3,"category":"career","header":"Left Harvard for the railroads at twenty","body":"He withdrew from Harvard as a sophomore and entered railroad management — first with the Boston & Albany, then rising through several lines to assistant treasurer of the Lehigh Valley Railroad. The choice marked him as the rare Harvard man who chose practical industry over the law."},{"number":4,"category":"death","header":"Killed at thirty-one in the industry he served","body":"On November 14, 1890 the Day Express on the Pennsylvania Railroad's main line collided head-on with a freight train near New Florence Pennsylvania, killing him and twenty-one others. Theodore Roosevelt, by then US Civil Service Commissioner, was devastated; the friendship had defined his college years."}],"slug":"henry-minot-1859"},"HD2345":{"id":"HD2345","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00741","mother_id":"HD2329"},"tags":[],"sources":[],"birth":{"year":1849,"month":5,"city":"West Roxbury","state":"Massachusetts"},"death":{"year":1900,"month":11,"city":"Boston","state":"Massachusetts"},"marriages":[{"spouse_id":"X00750","children_ids":["HD2346"],"marriage_number":1,"date_year":1882,"date_month":6,"date_day":24}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"William Minot","first_name":"William","last_name":"Minot","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":