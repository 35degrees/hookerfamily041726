:1868,"month":11,"day":5,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1934,"month":7,"day":15,"city":"Springdale","county":"Fairfield","state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM256","plot_notes":"Find a Grave memorial 15028207"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00363","mother_id":"H02325"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00366","location_country":"United States","end_type":"death_of_spouse","end_year":1932,"children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Wadsworth","inspired_by_id":"X00267","description":"Middle name 'Wadsworth' carries forward the Wadsworth surname through his great-aunt Ann Goodwin Mix Wadsworth (HD0524) — Catherine Hooker Williams's aunt — who married Dr. Harry Wadsworth (X00267, 1780-1813). Note that the middle name 'Wadsworth' AND the first name 'Harry' both echo Dr. Harry Wadsworth's name."}],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"short":"Find a Grave — Spring Grove Cemetery Darien CT","url":"https://www.findagrave.com/cemetery/103740/spring-grove-cemetery"},{"short":"WikiTree (online genealogy)","url":"https://www.wikitree.com/"}],"research_sources":[],"documents":[],"slug":"harry-deming-1868"},"X02770":{"id":"X02770","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"title":"Reverend","first_name":"Joshua","last_name":"Williams","married_names":[],"gender":"male","display_name":"Rev. Joshua Williams"},"birth":{"year":1761,"month":2,"day":3,"country":"United States"},"baptism":{},"death":{"year":1836,"month":2,"day":8,"country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Capt. Elias Williams","father_research_notes":"Capt. Elias Williams (not built)."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02771","date_year":1781,"date_month":10,"date_day":24,"location_country":"United States","end_type":"death","end_year":1836,"children_ids":["X00266"]}],"education":[{"institution":"Yale College","degree":"Bachelor's degree","year_completed":1780,"field":"Theology preparation","notes":"Graduated Yale 1780. Licensed October 1782 by the Hartford South Association to preach as a candidate."}],"career":[{"title":"Pastor of the Congregational Church","organization":"Congregational Church Southampton (Long Island NY)","dates":"May 25 1785 - April 1 1789","type":"clergy","notes":"Ordained and instituted at Southampton LI on May 25, 1785. Salary £70/year plus 40 cords of wood delivered yearly. Resigned April 1, 1789. Local history records he received 486 members into the church during his Southampton tenure."},{"title":"Pastor of the Harwinton Congregational Church","organization":"Harwinton Congregational Church (Litchfield County CT)","dates":"March 3 1790 - June 1822","type":"clergy","notes":"Installed March 3, 1790. The present (1808) church was erected at a cost of $8,000. Recorded in his memorandum that 'for seven years his salary of $350 was sufficient; but that then the expense of living was nearly doubled.' Worn down by labors of a revival in November 1820, attacked by disease that confined him 77 days. Petitioned for release; in May 1822 the people gave him $1,000 and he was dismissed in June 1822."},{"title":"Member of monthly missions prayer meeting","organization":"Harwinton Church","dates":"established 1815","type":"clergy","notes":"Per Harwinton Church record February 7, 1815: 'conversed on the subject of a monthly prayer meeting for missions.' Williams remarked to a grandson that he and the neighboring ministers were 'about the first in the world to set up and establish the monthly concert of prayer for missions.'"}],"military_service":[],"institutions":[{"institution_id":"INST022","institution_blurb":"Yale College Class of 1780. Followed by son Joshua Lewis Williams (X00266, Yale 1805)."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["clergy","yale_graduate"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Two pulpits, hundreds of conversions, seventy-seven days down","body":"Joshua served the Southampton Long Island church for four years (1785-1789), receiving 486 members into communion before resigning. He was installed at Harwinton Connecticut in 1790 and stayed thirty-two years. In November 1820, exhausted by a revival, he was confined to the house seventy-seven days; the people of Harwinton gave him a thousand-dollar gift in 1822 and he was released."},{"number":2,"category":"family","header":"He outlived son and grandson by years","body":"Removing to Bethlehem to live with his youngest son in 1822, the son died in 1831 having graduated Yale and practiced medicine. Joshua then went to the Upper Houses to be with his eldest son Joshua Lewis — who died December 29, 1832, the day before his own son also died at Yale. Father and grandson were buried in one grave January 1, 1833."}],"quotes":[],"sources":[{"short":"Williams Family Genealogy","url":"http://dunhamwilcox.net/bios/williams.htm","notes":"The Williams Family — Rev. Joshua Williams + descendants."},{"short":"WikiTree (online genealogy)","url":"https://www.wikitree.com/"}],"research_sources":[],"documents":[],"slug":"joshua-williams-1761"},"X02771":{"id":"X02771","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Mary","last_name":"Williams","maiden_name":"Webb","married_names":["Williams"],"gender":"female","display_name":"Mary Webb Williams"},"birth":{"year":1760,"month":9,"day":2,"country":"United States"},"baptism":{},"death":{"year":1838,"month":5,"day":16,"country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"David Webb","mother_name":"Mary Williams Webb","father_research_notes":"David Webb (not built).","mother_research_notes":"Mary Williams Webb (not built) — note the wife's maiden surname was 'Williams,' same as her future husband's surname; not necessarily a relation but worth flagging."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02770","date_year":1781,"date_month":10,"date_day":24,"location_country":"United States","end_type":"death_of_spouse","end_year":1836,"children_ids":["X00266"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"short":"Williams Family Genealogy","url":"http://dunhamwilcox.net/bios/williams.htm","notes":"The Williams Family — Rev. Joshua Williams + descendants."}],"research_sources":[],"documents":[],"slug":"mary-webb-1760"}},"burialCemetery":null,"institutionsById":{"INST022":{"id":"INST022","primary_name":"American Board of Commissioners for Foreign Missions","name":"American Board of Commissioners for Foreign Missions","alt_names":["ABCFM","American Board"],"type":"missionary_society","founding_year":1810,"location":{"city":"Boston","state":"Massachusetts"},"primary_persons":["X00724"],"hooker_connected_people":["X00724","X02121","X02122","T01213","H00527","I01195"],"person_ids":[],"related_institutions":[],"related_landmarks":[],"tags":["native_american_contact","missionary"],"sources":[{"short":"Wikipedia","note":"Elias Cornelius (clergyman); ABCFM"}],"notes":"First American foreign-mission organization. Tree connections: Rev. Elias Cornelius (agent 1816, secretary 1831-32); Ainsworth and Harriet Ellsworth Blunt, missionaries to the Cherokee at Brainerd, Tennessee; Eliza Talcott, missionary to Japan; Rev. William Banfield Capron, Madura mission; Judge John Hooker, member."}},"crossConnections":[]}