er":1,"spouse_id":"H02325","date_year":1846,"date_month":9,"date_day":1,"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1894,"children_ids":["H02326","H02327","H02328","H02329","H02330","H02331","H02332"]}],"education":[],"career":[{"title":"Manufacturer of farming implements","dates":"~1855-1858","type":"manufacturing","notes":"Lived in Northampton MA where he was engaged in the manufacture of farming implements."},{"title":"Member of Massachusetts Legislature","organization":"Massachusetts General Court","dates":"1857","type":"politics","notes":"Served as a member of the Massachusetts legislature in 1857 while living in Northampton MA."},{"title":"Owner of Farmington Iron Foundry and Machine Shop","organization":"Farmington Iron Foundry","dates":"1858-1869","type":"manufacturing","notes":"Returned to Farmington 1858 and continued the implements business at the Farmington Iron Foundry and Machine Shop — situated on the NY NH and Canal Railroad. Made an assortment of mill gearing, pulleys, fan bellows, plow castings, and railing."},{"title":"Owner-operator of Glen Eyre PA","dates":"1869-?","type":"manufacturing","notes":"Moved to Glen Eyre, Pike County Pennsylvania in 1869 — engaged in the manufacture of furniture and in mercantile business, 'practically owning the whole town' per family history."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"From Northampton legislator to Pennsylvania town owner","body":"John Deming made farm implements in Northampton Massachusetts and served in the 1857 Massachusetts legislature. Returning to Farmington in 1858 he ran the Farmington Iron Foundry on the rail line, then in 1869 moved to Glen Eyre Pennsylvania, where furniture-making and mercantile business gave him ownership of 'practically the whole town.' He died in Brooklyn at sixty-eight."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909"},{"short":"Williams Family Genealogy","url":"http://dunhamwilcox.net/bios/williams.htm","notes":"The Williams Family — Rev. Joshua Williams + descendants."},{"short":"WikiTree (online genealogy)","url":"https://www.wikitree.com/"},{"short":"Wilford Woodruff Papers — John Deming entry","url":"https://www.2023.wilfordwoodruffpapers.org/subjects/john-deming"},{"short":"Find a Grave — Riverside Cemetery Farmington CT","url":"https://www.findagrave.com/cemetery/103605/riverside-cemetery"}],"research_sources":[],"documents":[],"slug":"john-deming-1825"},"H02326":{"id":"H02326","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Anna","last_name":"Deming","married_names":[],"gender":"female","display_name":"Anna Deming"},"birth":{"year":1848,"country":"United States"},"baptism":{},"death":{"year":1848,"country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00363","mother_id":"H02325"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_in_infancy"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"short":"WikiTree (online genealogy)","url":"https://www.wikitree.com/"}],"research_sources":[],"documents":[],"slug":"anna-deming-1848"},"H02327":{"id":"H02327","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Annie","middle_name":