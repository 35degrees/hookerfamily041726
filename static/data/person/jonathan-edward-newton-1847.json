xact","month":12,"day":29,"city":"Durham","state":"Connecticut","country":"United States"},"death":{"year":1852,"date_precision":"exact","month":9,"day":9,"city":"Durham","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00149","mother_id":"I00083"},"marriages":[{"spouse_id":"I01775","marriage_number":1,"date_year":1788,"date_month":3,"date_day":4,"children_ids":["HD6440","HD6441","HD6442","HD6443","HD6444","HD6445","HD6446"]}],"tags":["revolutionary_war"],"burial":{"cemetery_id":"CEM569"},"narrative_blocks":[{"number":1,"category":"military","header":"He marched to New Haven at fourteen","body":"Abner Newton enlisted before he was fifteen and marched with his company to New Haven in July 1779 when the British invaded under General Tryon. The heavy flintlock musket he carried was kept until his death in 1852, when his grandsons destroyed it."},{"number":2,"category":"military","header":"“Their guns shone like silver”","body":"In extreme old age Abner relived his war years, pointing to a hill near his home and saying he had watched the British come over it, their guns shining like silver — and that he was glad to see them go. He had stood guard the night Arnold burned New London."},{"number":3,"category":"character","header":"He refused a pension on principle","body":"Though his comrades applied for pensions, Abner would not, saying he did not wish his townsmen to remark when he died, “Another old pensioner gone.” He was ordained deacon some twenty-five years after his boyhood service."}],"slug":"abner-newton-1764"},"I01775":{"id":"I01775","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":null},"bio":{"display_name":"Abigail Fairchild Newton","first_name":"Abigail","last_name":"Newton","married_names":[],"maiden_name":"Fairchild"},"birth":{"year":1766,"date_precision":"exact","month":10,"day":7,"city":"Middletown","state":"Connecticut","country":"United States"},"death":{"year":1825,"date_precision":"exact","month":11,"day":16,"city":"Durham","state":"Connecticut","country":"United States"},"parents":{"father_id":null,"mother_id":null},"marriages":[{"spouse_id":"HD6420","marriage_number":1,"date_year":1788,"children_ids":["HD6440","HD6441","HD6442","HD6443","HD6444","HD6445","HD6446"]}],"tags":[],"burial":{"cemetery_id":"CEM569"},"narrative_blocks":[{"number":1,"category":"family","header":"Her father died saving smallpox prisoners","body":"Abigail Fairchild’s father Elisha drove his team to Milford in January 1777 to carry home Continental soldiers released sick and dying from British prison ships. He caught smallpox from those he rescued and died within three weeks, leaving his widow with five young children."},{"number":2,"category":"family","header":"Her wedding dress was fine linen chintz","body":"Abigail Fairchild married Abner Newton in 1788 in a wedding dress of fine linen chintz, having survived a hard childhood after her father’s death left her mother a widow at thirty-one with five small children. The couple lived thirteen years in Hartland before returning to Durham."}],"slug":"abigail-fairchild-1766"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}