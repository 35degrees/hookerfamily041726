ge 40, still in office."},{"number":5,"category":"family","header":"His daughter married into the Talcott-Edwards line","body":"His daughter Sarah Hooker married Hon. Daniel Edwards in 1728 — whose mother was Mary Talcott, daughter of Lt.-Col. John Talcott. Their children thus descend from both Rev. Thomas Hooker and the founding Talcott line."}],"bio":{"display_name":"Nathaniel Willett Hooker","first_name":"Nathaniel","last_name":"Hooker","middle_name":"Willett","married_names":[],"bio_blurb":"Hartford colonial assemblyman; grandson of Thomas Hooker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"nathaniel-hooker-1671"},"I00051":{"id":"I00051","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1677,"month":10,"day":8,"city":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1753,"month":8,"day":23,"city":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"X00057","mother_id":"X00058"},"marriages":[{"marriage_number":1,"spouse_id":"H00033","date_year":1698,"date_month":12,"date_day":28,"location_city":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1711,"children_ids":["H00110","H00111","H00112","H00113","H00114","H00115"]},{"marriage_number":2,"spouse_id":"X01058","date_year":1713,"date_month":12,"date_day":8,"location_city":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1743,"children_ids":[]}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 33"}],"gender":"female","tags":[],"number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"family_connection","related_id":"I00031","display_label":"Both Standley women married Hooker brothers — different families.","link_text":"Abigail Standley Hooker"}],"bio":{"display_name":"Mary Standley Hooker Austin","first_name":"Mary","last_name":"Austin","married_names":["Hooker","Austin"],"maiden_name":"Standley"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Half a Hartford house lot came with marriage","body":"When Mary Stanley married the Hartford merchant Nathaniel Hooker in 1698, her father gave the couple half his house lot, which ran from the Center Church burying-yard down to the Little River. Nathaniel served in the legislature until his death in 1711, after which she married another noted Hartford merchant, John Austin."}],"slug":"mary-standley-1677"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}