{},"residence":{"country":"United States"},"institutions":[],"landmarks":[],"naming_inspiration":[],"research_tags":[],"narrative_blocks":[{"number":1,"category":"military","header":"Militia ensign in King Philip's War","body":"When King Philip's War broke out in 1675, Samuel was appointed ensign in the Milford militia at roughly age 29. He served through the war and its recurring aftermath of Indian skirmishes, rising to captain of the Milford militia by 1698."},{"number":2,"category":"career","header":"Represented Milford fifteen times in the General Court","body":"He represented Milford in fifteen sessions of the Connecticut General Court between 1691 and 1703 — a span of sustained civic service that ran alongside his captaincy of the militia. His father Roger Newton Sr. had helped found the town's church."},{"number":3,"category":"family","header":"Thomas Hooker left him £10 in his will","body":"He was nine months old when his grandfather Rev. Thomas Hooker died in 1647. Thomas's will left a £10 legacy to him — a substantial inheritance for a Hooker grandchild born during the Hartford founding."},{"number":4,"category":"family","header":"His wife and cousin's wife were Fenn half-sisters","body":"His wife Martha Fenn's half-sister Susanna married William Hooker — Samuel's first cousin. The Fenn family thus connected to the Hooker tree twice in the same generation through different lines."},{"number":5,"category":"family","header":"A second marriage to a soldier's widow","body":"After Martha Fenn died, Samuel married Sarah Welch Fowler, widow of John Fowler, who had been killed taking an Indian fort in 1693. Their son Abner bore a name found nowhere else in the Newton or Hooker line."}],"quotes":[],"research_sources":[],"artworks":[],"career":[{"role":"Representative","organization":"Connecticut General Court","start_year":1691,"end_year":1703,"notes":"Represented Milford in 15 sessions of the General Court, 1691-1703."}],"military_service":[{"war":"King Philip's War","war_id":"WAR002","rank_start":"Ensign","rank_end":"Captain","rank_year_start":1675,"rank_year_end":1698,"unit":"Milford Militia","notes":"Appointed ensign 1675 at outbreak of King Philip's War. Served in recurring skirmishes with Indians. Rose to captain of Milford militia 1698. Source: Newton Genealogy (Leonard 1915)."}],"bio":{"display_name":"Samuel Newton","first_name":"Samuel","last_name":"Newton","married_names":[]},"documents":[],"slug":"samuel-newton-1646"},"I00008":{"id":"I00008","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"descent_paths_to_thomas":0,"is_progenitor":false},"birth":{"year":1650,"month":1,"day":1,"country":"United States"},"death":{"year":1697,"month":1,"day":1,"state":"Connecticut","country":"United States"},"parents":{"father_id":"X00010","mother_id":"X00011","mother_research_notes":"Sarah Baldwin, bapt. April 22, 1621, Aston Clinton, Buckinghamshire, England","father_research_notes":"Benjamin Fenn, b. ca. 1612 Stewkley, Buckinghamshire, England. Emigrated ca. 1630. Assistant Governor of Connecticut 1665-1672. Stewkley is in the same county as Amersham, where Thomas Hooker married Susanna Garbrand on April 3, 1621."},"marriages":[{"marriage_number":1,"spouse_id":"H00011","date_year":1669,"date_month":3,"date_day":14,"location_city":"Milford","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","children_ids":["H00039","H00040","H00041","H00043","H00044"]}],"cross_connections":[{"type":"family_connection","related_id":"H00029","display_label":"Her sister married the merchant across from his father's store.","link_text":"William Hooker"}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 11"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"baptism":{"year":1650,"month":7,"day":7,"city":"Milford","state":"Connecticut","country":"United States"},"narrative_blocks":[{"number":1,"category":"family","header":"Her father was Connecticut Assistant Governor","body":"Her father Benjamin Fenn emigrated from Stewkley, Buckinghamshire, England — the same county where Rev. Thomas Hooker had married Susanna Garbrand in 1621. Fenn served as Assistant Governor of Connecticut from 1665 to 1672. Martha's half-sister Susanna Fenn married William Hooker — bringing the Fenn family into the Hooker tree twice."}],"burial":{},"is_placeholder":false,"former_ids":[],"residence":{"country":"United States"},"institutions":[],"landmarks":[],"naming_inspiration":[],"research_tags":[],"quotes":[],"research_sources":[],"artworks":[],"bio":{"display_name":"Martha Fenn Newton","first_name":"Martha","last_name":"Newton","married_names":["Newton"],"maiden_name":"Fenn"},"documents":[],"military_service":[],"slug":"martha-fenn-1650"},"I00003":{"id":"I00003","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"descent_paths_to_thomas":0,"is_progenitor":false},"birth":{"year":1620,"month":1,"day":1,"country":"England","date_precision":"approximate"},"death":{"year":1683,"month":6,"day":7,"city":"Milford","state":"Connecticut","country":"United States","date_precision":"exact"},"parents":{"father_research_notes":"Said to be of the family of Sir Isaac Newton; possibly son of a Samuel Newton. Parentage unproven — see research_notes."},"marriages":[{"spouse_id":"H00003","children_ids":["H00011","H00012","H00013","H00014","H00015","H00016","H00017","H00018"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1676,"date_year":1644,"location_country":"United States"}],"tags":["minister","farmington_founder","seven_pillars","yale_connection","missionary","great_migration","indigenous_rights","yale_founder"],"sources":[{"short":"Edward Hooker 1909","page":"Entry g-45"},{"short":"Flagg 1926","page":"pp. 255-256"},{"short":"Caroline Gaylord Newton 1914","full":"Caroline Gaylord Newton, Rev. Roger Newton, Deceased 1683, and One Line of his Descendants (Durham, Conn., 1914), pp. 3-10"},{"short":"Leonard 1915","full":"Ermina Newton Leonard, Newton Genealogy (Salem, Mass: Higginson Book Company, 1915), p. 700"},{"short":"Hulburt 1967","full":"Mabel S. Hulburt, Farmington Church and Town (Stonington, Conn: The Pequot Press, 1967), p. 8"},{"short":"Cutter 1913","full":"William Richard Cutter, New England Families, Genealogical and Memorial (New York: Lewis Historical Publishing, 1913), vol. 3, p. 1730"},{"short":"N.E. Reg.","volume":"11","page":"323"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["religion","education"],"notable_blurb":"Founding Farmington pastor; trained Yale's first rector","primary_url":"https://www.nativenortheastportal.com/bio/bibliography/newton-roger-1683","primary_url_label":"Native Northeast Portal biography"},"narrative_blocks":[{"number":1,"category":"religion","header":"Hooker trained him; he founded Farmington's church","body":"Roger Newton studied theology at Hartford under Thomas Hooker and, around 1645, married Hooker's eldest daughter, Mary. Ordained the first pastor of Farmington in 1652, he later served twenty-three years as the second pastor of Milford."},{"number":2,"category":"legacy","header":"He trained Yale's first rector at his table","body":"As Hooker had trained him, Newton took young men into his Milford home for theological study. One was Abraham Pierson Jr., who became the first rector of Yale College."},{"number":3,"category":"religion","header":"He sheltered the fugitive regicides near Milford","body":"From 1661 the regicide judges Edward Whalley and William Goffe — hunted for signing the death warrant of Charles I — hid in a cellar near Newton in Milford. Their presence was kept secret through the two years they remained."},{"number":4,"category":"social_reform","header":"He brought Tunxis members into the church","body":"Newton did missionary work among the Tunxis and witnessed the 1650 agreement between Connecticut and the tribe. A few Tunxis became members of his Farmington church, with the standing that membership carried."},{"number":5,"category":"character","header":"He left Farmington in a year of calamity","body":"Newton departed Farmington in 1657 after a season of disaster — a man named Scott was murdered, and the house of John Hart burned with most of the family inside. He waited months in Boston for passage to England before settling instead at Milford."}],"cross_connections":[{"type":"civic_connection","related_id":"X00094","display_label":"was received into Milford Church by Newton, 1661","link_text":"Miles Merwin"},{"type":"civic_peer","related_id":"X00067","display_label":"also sheltered the regicides, at Guilford","link_text":"Gov. William Leete"},{"type":"civic_connection","related_id":"X02127","display_label":"trained by Newton; became Yale's first rector","link_text":"Rev. Abraham Pierson Jr."},{"type":"civic_peer","related_id":"H00007","display_label":"succeeded Newton as Farmington's pastor","link_text":"Rev. Samuel Hooker"}],"quotes":[],"is_placeholder":false,"baptism":{},"residence":{"city":"Milford","county":"New Haven","state":"Connecticut","country":"United States"},"landmarks":[],"naming_inspiration":[],"research_tags":[],"research_sources":[],"education":[{"dates":"Easter 1636","type":"matriculation","school_name":"King's College, Cambridge"},{"institution_id":"INST002","notes":"Studied at Harvard but name not on graduate list. Some early Harvard records in which his name would naturally appear were accidentally burned; uncertain he received a diploma. Cotton Mather nevertheless speaks of him as one of the young students who came from England to finish their education in America."}],"bio":{"title":"Reverend","display_name":"Rev. Roger Newton Sr.","first_name":"Roger","last_name":"Newton","married_names":[],"suffix":"Sr.","bio_blurb":"First pastor of Farmington; second of Milford","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781475281/rogernewtonsr_mspjci.png"},"documents":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"}],"artworks":[],"military_service":[],"career":[{"role":"Pastor (founding)","organization":"First Church of Farmington","location":"Farmington, Connecticut","start_year":1652,"end_year":1657,"notes":"Ordained the church's first pastor, October 13, 1652."},{"role":"Pastor","organization":"First Church of Milford","location":"Milford, Connecticut","start_year":1660,"end_year":1683,"notes":"Second pastor; installed August 22, 1660."}],"burial":{"cemetery_id":"CEM005","plot_notes":"Buried in Founders' Cemetery (Rev. Peter Prudden's Garden) on the Wepawaug; 1889 memorial at Founders Memorial Bridge, Milford."},"slug":"roger-newton-sr-1620"},"H00003":{"id":"H00003","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":2,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"descent_paths_to_thomas":1,"is_progenitor":false},"birth":{"year":1623,"month":1,"day":1,"country":"England"},"death":{"year":1676,"month":2,"day":4,"city":"Milford","county":"New Haven County","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM005","plot_notes":"Buried in Peter Prudden's Garden — no tombstone remains"},"parents":{"father_id":"H00001","mother_id":"I00001"},"marriages":[{"spouse_id":"I00003","children_ids":["H00011","H00012","H00013","H00014","H00015","H00016","H00017","H00018"],"marriage_number":1,"end_type":"death","end_year":1676,"date_year":1644,"location_country":"United States"}],"tags":["great_migration"],"sources":[{"short":"Edward Hooker 1909","page":"Entry g-46"},{"short":"Flagg 1926","page":"pp. 256-257"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"is_placeholder":false,"baptism":{},"residence":{"city":"Milford","county":"New Haven","state":"Connecticut","country":"United States"},"institutions":[],"landmarks":[],"naming_inspiration":[],"research_tags":[],"cross_connections":[{"type":"cousin_marriage","related_id":"H00024","display_label":"Her daughter Sarah Newton married her first cousin John Wilson.","link_text":"John Wilson"}],"quotes":[],"research_sources":[],"narrative_blocks":[{"number":1,"category":"family","header":"Cared for her mother on the Hartford migration","body":"According to the Newton family genealogy, Mary was the daughter responsible for caring for her mother Susanna on the arduous journey from Cambridge to Hartford in 1636 — a journey in which Mrs. Hooker 'was carried on a horse litter' in poor health. Mary was roughly 13 years old."},{"number":2,"category":"family","header":"Stayed in Hartford while Newton built Farmington","body":"When Roger Newton went to establish the church at Farmington in the late 1640s, Mary remained in Hartford — their son Samuel's baptism on October 20, 1646 appears on the Hartford register, placing her there while her husband laid the groundwork for the congregation he would formally organize."},{"number":3,"category":"family","header":"Eight children born across three Connecticut towns","body":"The family's migrations are recorded in their children's birthplaces: Samuel and Roger Jr. born in Hartford; Susannah and John in Farmington; Ezekiel back in Hartford; then Sarah, Mary, and Alice in Milford — where the family finally settled and where Mary died on February 4, 1676."},{"number":4,"category":"family","header":"Probably born in Esher near Hooker's curacy","body":"Newton family genealogy says she was born around 1623, probably at Esher, Surrey — where Thomas Hooker had served as curate from c. 1618 to 1625. Esher was also where Hooker met her mother Susanna Garbrand."}],"bio":{"display_name":"Mary Hooker Newton","first_name":"Mary","last_name":"Newton","married_names":["Newton"],"maiden_name":"Hooker"},"documents":[],"artworks":[],"military_service":[],"slug":"mary-newton-1623"},"X00010":{"id":"X00010","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"birth":{"year":1612,"city":"Stewkley","county":"Buckinghamshire","country":"England"},"migration":{"arrival_date":{"year":1630,"circa":true}},"political_offices":[{"title":"Deputy","jurisdiction":"General Assembly of New Haven Colony","dates":"1653-1654"},{"title":"Magistrate","jurisdiction":"Milford, Connecticut","dates":"1654-1663","duration_years":9},{"title":"Assistant","jurisdiction":"Colony of Connecticut","dates":"1665-1672"},{"title":"Commissioner","jurisdiction":"United Colonies of New England (New Haven Colony)","dates":"1661, 1663","notes":"Served with Gov. Leete"}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 10"},{"short":"Families of Early Milford","page":"p. 250"},{"short":"Empty Branches on the Family Tree","url":"https://emptybranchesonthefamilytree.com/2016/11/researching-benjamin-fenn-part-2/","notes":"Blog post with careful analysis; corrects 1630 Mary and John arrival date to likely 1637"},{"short":"Benjamin Fenn Chapter (DAR)","notes":"Chapter named in honor of Benjamin Fenn"}],"marriages":[{"children_ids":["I00008","X00066"],"spouse_id":"X00011","marriage_number":1,"end_type":"death_of_spouse","end_year":1663,"date_year":1638},{"spouse_id":"X00062","children_ids":["I00057","X00106"],"marriage_number":2,"date_year":1664,"date_month":3,"date_day":12}],"death":{"year":1672,"month":9,"day":14,"city":"Milford","state":"Connecticut"},"emigration":{"arrived":"c. 1637","first_residence":"Dorchester, Massachusetts","notes":"Likely arrived 1637 with a group from Buckinghamshire — NOT on the 1630 Mary and John as sometimes stated online. First appears in colonial records 1637; seven-year gap makes 1630 arrival implausible. Removed from Dorchester to Milford where he received lot #3 (2 acres 11 rods 3 poles).","has_discrepancy":true,"discrepancy_note":"Online sources give 1630 / Mary and John. Genealogical blog (Empty Branches) argues compellingly for 1637 Buckinghamshire group. 1637 preferred."},"cross_connections":[{"type":"parallel_descent","related_id":"X00104","display_label":"James Fenn's marriage to Joanna Prudden connected the Fenn-Hooker families.","link_text":"Rev. Peter Prudden"},{"type":"parallel_descent","related_id":"X00103","display_label":"James Fenn's marriage to Joanna Prudden connected the Fenn-Hooker families.","link_text":"Rev. Samuel Prudden"},{"type":"family_connection","related_id":"H00029","display_label":"His daughter Susanna married the Hooker merchant.","link_text":"William Hooker"}],"gender":"male","tags":[],"number_of_marriages":2,"parents":{},"notable":{"is_notable":true,"notable_category":["government"],"notable_blurb":"Milford founder; Connecticut Assistant Governor 1665-1672","primary_url":"https://emptybranchesonthefamilytree.com/2016/11/researching-benjamin-fenn-part-2/","primary_url_label":"Empty Branches on the Family Tree"},"narrative_blocks":[{"number":1,"category":"career","header":"Milford magistrate and a colonial Assistant","body":"Benjamin Fenn was a deacon, magistrate, and militia officer at Milford. He represented the town in the New Haven Colony and served as an Assistant of the colony from 1665 to 1672."},{"number":2,"category":"migration","header":"He took lot number three at Milford","body":"Born at Stewkley in Buckinghamshire, Fenn came over in the Great Migration and settled at Milford. He held land on both sides of the Atlantic for the rest of his life."},{"number":3,"category":"family","header":"Two daughters married into the Hooker line","body":"His daughter Martha married Samuel Newton, a grandson of Thomas Hooker; his daughter Susanna married William Hooker of Farmington. Both ties pull the Fenn family into the Hooker tree."},{"number":4,"category":"character","header":"His will left each grandchild a single ewe","body":"Fenn's 1672 will divided farms in Milford, New Haven, and Buckinghamshire among his sons. To every one of his grandchildren he left a single ewe sheep."}],"bio":{"display_name":"Benjamin Fenn","first_name":"Benjamin","last_name":"Fenn","married_names":[],"bio_blurb":"Milford magistrate and colonial Assistant"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM005","plot_notes":"Buried in the Milford Cemetery."},"career":[{"role":"Assistant","organization":"New Haven & Connecticut Colony","start_year":1665,"end_year":1672,"notes":"Milford deputy 1653; magistrate 1654-1663; Commissioner of the United Colonies 1661 and 1663."}],"slug":"benjamin-fenn-1612"},"X00011":{"id":"X00011","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1621,"month":4,"day":22,"city":"Aston Clinton","county":"Buckinghamshire","country":"England"},"marriages":[{"spouse_id":"X00010","children_ids":["I00008","X00066"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909"}],"gender":"female","parents":{},"tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1663,"month":4,"day":29,"city":"Milford","county":"New Haven County","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM005","plot_notes":"Buried in Peter Prudden's garden, Milford Cemetery."},"narrative_blocks":[{"number":1,"category":"migration","header":"Her father died during the Atlantic crossing","body":"Sarah Baldwin sailed for New England in 1638 aboard the Martin. Her father, Sylvester Baldwin, made his will on the ocean and died during the crossing, when she was about seventeen."},{"number":2,"category":"family","header":"Six children, then buried in Prudden's garden","body":"Sarah married Benjamin Fenn at Milford and bore six children. She died in 1663 and was buried in Peter Prudden's garden at Milford."}],"cross_connections":[],"bio":{"display_name":"Sarah Baldwin Fenn","first_name":"Sarah","last_name":"Fenn","married_names":["Fenn"],"maiden_name":"Baldwin"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-baldwin-1621"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[{"type":"in_law","related_id":"X00074","display_label":"was her father-in-law; Constable of New London 1680","slug":"john-plumbe"}]}