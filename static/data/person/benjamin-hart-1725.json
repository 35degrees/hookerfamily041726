[],"former_ids":["HD1012"],"burial":{"cemetery_id":"CEM038","plot_notes":"West Cemetery, Madison CT (FindAGrave Memorial #61366889)."},"narrative_blocks":[{"number":1,"category":"family","header":"Buried wife at thirty-seven; lost infant son too","body":"His wife Charlotte Jemima Welles Hart died at thirty-seven on March 31, 1858 in Madison. Their only known child Roger Baldwin Hart, born 1851, died in 1852 not yet age one. Baldwin himself died March 20, 1865 aged fifty, seven years a widower with no surviving descendants."},{"number":2,"category":"family","header":"Died seven years a widower at fifty","body":"His wife Charlotte died at thirty-seven on March 31, 1858 in Madison. Their infant son Roger had died six years before in 1852, not yet age one. Baldwin himself died March 20, 1865 aged fifty, leaving no descendants."}],"slug":"baldwin-hart-1815"},"H01878":{"id":"H01878","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00725","mother_id":"X00279"},"tags":["civil_war"],"sources":[],"birth":{"year":1835,"month":3,"day":19,"city":"Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1919,"month":1,"day":10,"city":"Madison","county":"New Haven","state":"Connecticut","country":"United States"},"marriages":[{"marriage_number":1,"spouse_id":"I01287","date_year":1859,"date_month":7,"date_day":14,"end_type":"death","end_year":1919,"children_ids":["HD5032","HD5033"]}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Capt. William Winthrop Hart","first_name":"William","last_name":"Hart","title":"Capt.","middle_name":"Winthrop","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779636423/williamwinthrophart_as7gjv.jpg","photo_notes":"Photo provided by Sam Hooker (project compiler). Per FindAGrave Memorial #61366868."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"branch":"U.S. Army — Connecticut Volunteers","rank":"Captain (Capt. per FindAGrave)","war":"Civil War","start_year":1862,"notes":"Company G, 14th Regiment Connecticut Volunteer Infantry. The 14th CT mustered August 1862 and saw heavy action: Antietam (their first battle, three weeks after mustering, in the cornfield), Fredericksburg, Chancellorsville, Gettysburg, and through the Petersburg Campaign — one of the most-engaged Connecticut regiments of the war. Specific service dates and discharge not yet researched."}],"former_ids":["HD1013"],"burial":{"cemetery_id":"CEM038","plot_notes":"West Cemetery, Madison CT (FindAGrave Memorial #61366868)."},"narrative_blocks":[{"number":1,"category":"military","header":"Civil War, Company G, 14th Connecticut Volunteers","body":"Served in Company G, 14th Regiment Connecticut Volunteer Infantry during the Civil War, holding rank of Captain. The 14th CT mustered August 1862 and saw heavy action at Antietam (their first battle, three weeks after mustering, in the cornfield), Fredericksburg, Chancellorsville, Gettysburg, and through the Petersburg Campaign — one of the most-engaged Connecticut regiments of the war."},{"number":2,"category":"family","header":"Died same year as wife Roxanna, 1919","body":"He died at Madison January 10, 1919 aged eighty-three. His wife Roxanna Rebecca Scranton Hart followed five months later on June 13, 1919 aged eighty-four. Together fifty-nine years and buried side by side at West Cemetery, Madison CT."}],"slug":"william-hart-1835"},"I00137":{"id":"I00137","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1682,"month":4,"day":12,"city":"Farmington","state":"Connecticut","country":"United States"},"death":{"year":1731,"month":3,"day":4,"city":"East Guilford","state":"Connecticut"},"burial":{"cemetery_id":"CEM038"},"parents":{"mother_research_notes":"Ruth Hawkins (daughter of Anthony Hawkins of Farmington)","father_id":"X00045","mother_id":"X01721"},"church_roles":[{"role":"Second Tutor, Yale College","dates":"1703-1705","notes":"Bespoken as tutor on the day of his graduation. Preceded by Daniel Hooker (first tutor, 1702), who was a son of Rev. Samuel Hooker of Farmington (H00007) and brother-in-law of Rev. James Pierpont, Yale's founding patron."},{"role":"Pastor","location":"East Guilford (now Madison), Connecticut","dates":"ordained Nov 25, 1707 – died Mar 4, 1731","notes":"Granted 25 acres by town of Guilford as settlement. \"One of the first Eminence of preachers in his Day\" (Rev. Thomas Ruggles Jr.). \"A gentleman of eminent piety\" (Rev. John Devotion). About 80 members added to church during his pastorate. In 1722, signed Rector Cutler's petition expressing doubt of Presbyterian ordination — later resolved his doubts and remained in place. President Stiles: \"Mr. Hart is said to have been a man of the greatest ingenuity and learning of all the seven.\""}],"marriages":[{"children_ids":["X01905","X01906"],"spouse_id":"X01178","marriage_number":1,"end_type":"death_of_spouse","end_year":1715,"date_year":1712,"date_month":3,"date_day":20},{"children_ids":[],"spouse_id":"X00134","marriage_number":2,"end_type":"death_of_spouse","end_year":1719,"date_year":1717,"date_month":8,"date_day":12},{"spouse_id":"H00105","children_ids":["H00311","H00312","H00313","H00314","H00315","H00316"],"marriage_number":3,"date_year":1720,"date_month":12,"date_day":6}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 105"},{"short":"Yale Biographical Sketches 1701-1745 (1885)","url":"https://www.cga.ct.gov/hco/books/Biographical_Sketches_of_Grads_of_Yale_1701-1745_1885.pdf"}],"gender":"male","tags":["minister","yale_graduate","educator"],"number_of_marriages":3,"notable":{"is_notable":true,"notable_category":["academia","religion"],"notable_blurb":"Yale's first B.A. graduate, 1703","primary_url":"https://yale60.org/wp-content/uploads/2025/05/OurLegacyOfJohnHart.pdf","primary_url_label":"yale60.org"},"narrative_blocks":[{"number":1,"category":"education","header":"Yale's first B.A. graduate — alone in 1703","body":"He was the first student in Yale College to be advanced to a Bachelor's Degree. He graduated alone at Saybrook on September 15, 1703 — his diploma signed by Rector Abraham Pierson, Moses Noyes, Thomas Buckingham, and Noadiah Russell."},{"number":2,"category":"career","header":"Second Yale tutor — succeeded Daniel Hooker","body":"He was appointed Yale's second tutor on the very day of his graduation, succeeding his Farmington townsman Daniel Hooker. He served from 1703 to 1705, with charge of the two lower classes."},{"number":3,"category":"religion","header":"Ordained East Guilford's first minister, 1707","body":"In April 1707 he accepted the call to East Guilford (now Madison), and on November 25, 1707 he was ordained over the new thirteen-member church. Five ministers including James Pierpont and Thomas Buckingham officiated."},{"number":4,"category":"religion","header":"Signed the 1722 Yale Episcopal declaration","body":"In September 1722 he joined Rector Cutler and five others in signing the famous declaration before Yale trustees questioning the validity of Presbyterian ordination. After conference at Yale Library on October 16, his doubts were resolved and he remained Congregational."},{"number":5,"category":"character","header":"Greatest ingenuity and learning of all seven","body":"President Ezra Stiles called him a man of 'the greatest ingenuity and learning' among the seven who signed the 1722 declaration. His estate at death included £35 in books — a substantial scholarly library."}],"cross_connections":[{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X00126","link_text":"Rev. James Pierpont"},{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X01001","link_text":"Rev. Thomas Buckingham"},{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X01929","link_text":"Rev. Thomas Ruggles"},{"type":"civic_peer","related_id":"H00036","display_label":"Succeeded him as Yale's second tutor in 1703","link_text":"Doctor Daniel Hooker"}],"education":[{"dates":"1700-1702","notes":"Two years at Harvard; transferred 1702","school_name":"Harvard College","institution_id":"INST002"},{"degree":"B.A.","notes":"FIRST student at Yale to receive a Bachelor's degree — graduated alone at Saybrook, September 15, 1703. His original diploma is preserved in Yale Library. The 1702 class received M.A. degrees only (honorary, for Harvard graduates); Hart's 1703 B.A. was Yale's first bachelor's degree.","school_name":"Yale College (Collegiate School of Connecticut)","graduation_year":1703,"institution_id":"INST022"}],"bio":{"title":"Reverend","display_name":"Rev. John Hart","first_name":"John","last_name":"Hart","married_names":[],"bio_blurb":"Yale's first graduate; second tutor of the college"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"},{"institution_id":"INST022","relationship":"alumnus","years":"1703"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-hart-1682"},"H00105":{"id":"H00105","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1693,"month":11,"day":5,"city":"Guilford","state":"Connecticut"},"parents":{"father_id":"H00031","mother_id":"I00061"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 105"}],"death":{"year":1756,"month":9,"day":6,"city":"Guilford","state":"Connecticut"},"marriages":[{"spouse_id":"I00137","children_ids":["H00311","H00312","H00313","H00314","H00315","H00316"],"marriage_number":1,"date_year":1720,"date_month":12,"date_day":6,"location_city":"Guilford","location_state":"Connecticut"}],"cross_connections":[{"type":"family_connection","related_id":"H00036","display_label":"Her husband succeeded Daniel as Yale's second tutor","link_text":"Doctor Daniel Hooker"},{"type":"in_law","related_id":"X00045","display_label":"was her father-in-law"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Mary Hooker Hart","first_name":"Mary","last_name":"Hart","married_names":["Hart"],"maiden_name":"Hooker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married Yale's first B.A. graduate","body":"On December 6, 1720 she married Rev. John Hart of East Guilford as his third wife. Hart had been Yale's first B.A. graduate (1703) and second tutor — succeeding her uncle Daniel Hooker, who had been Yale's first tutor."},{"number":2,"category":"family","header":"Three of her six children survived to marry","body":"With John Hart she had six children — four sons and two daughters. Two sons died young and infant Mary lived only three months. Sons Thomas (1723-1813) and Benjamin (1725-1804) carried the line, while daughter Sarah married three times — twice to Yale graduates."}],"slug":"mary-hart-1693"},"X00045":{"id":"X00045","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"birth":{"year":1643,"month":10,"day":24,"city":"Windsor","county":"Hartford County","state":"Connecticut","country":"United States"},"death":{"year":1726,"month":8,"day":27},"parents":{"father_id":"X00034","mother_id":"X01888"},"marriages":[{"children_ids":["X00043","I00137"],"spouse_id":"X01721","marriage_number":1}],"sources":[{"short":"Andrews, New Britain","page":"pp. 364-5"}],"gender":"male","tags":["king_philips_war","king_williams_war","connecticut_assembly"],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["military","politics"],"notable_blurb":"Farmington militia captain, General Court speaker","primary_url":"https://www.nativenortheastportal.com/bio/bibliography/hart-thomas-1643-1726","primary_url_label":"Native Northeast Portal biography"},"cross_connections":[{"type":"in_law","related_id":"H00105","display_label":"married his son John in 1720"},{"type":"civic_peer","related_id":"H00030","display_label":"shared with him the leadership of early Farmington","link_text":"John Hooker"}],"military_service":[{"branch":"Farmington trainband","rank":"Captain","notes":"Ensign 1678, Lieutenant 1692, Captain 1695"}],"bio":{"title":"Captain","display_name":"Captain Thomas Hart","first_name":"Thomas","last_name":"Hart","married_names":[],"bio_blurb":"Farmington militia captain; General Court Speaker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"career":[{"role":"Speaker","organization":"Connecticut General Court"},{"role":"Justice, 17 years","organization":"Hartford County"},{"role":"Council member","organization":"Connecticut","start_year":1697}],"narrative_blocks":[{"number":1,"category":"politics","header":"One of Farmington’s two prominent men","body":"Contemporaries paired him with John Hooker as “the two prominent men of Farmington” — ensign to captain of the trainband, Speaker of the General Court, and seventeen years a Hartford County justice. His son Deacon Thomas married into the Hooker family."}],"slug":"thomas-hart-1643"},"X01721":{"id":"X01721","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"EH 1909"}],"gender":"female","parents":{"father_research_notes":"Anthony Hawkins of Farmington","mother_id":"X00044","father_id":"X00043"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X00045","children_ids":["X00043","I00137"]}],"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1649,"month":10,"day":24,"city":"Windsor","county":"Hartford County","state":"Connecticut","country":"United States"},"death":{"year":1724,"month":10,"day":9,"city":"Farmington","county":"Hartford County","state":"Connecticut","country":"United States"},"cross_connections":[],"bio":{"display_name":"Ruth Hawkins","first_name":"Ruth","last_name":"Hawkins","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ruth-hawkins-1649"},"H00031":{"id":"H00031","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":3,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1666,"month":10,"day":27,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1740,"month":3,"d