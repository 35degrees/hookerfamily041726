95","H00296","H00297","H00298","H00299","H00300"],"marriage_number":1,"date_year":1729,"date_month":1,"date_day":8}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 103"}],"gender":"male","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[],"notable_blurb":null,"primary_url":null,"primary_url_label":null},"cross_connections":[{"type":"parallel_descent","related_id":"I00900","display_label":"Both Strong men who married Hooker descendants, 84 years apart","link_text":"Judge Elisha Beebe Strong"}],"bio":{"title":"Captain","display_name":"Captain Asahel Strong Jr.","first_name":"Asahel","last_name":"Strong","suffix":"Jr.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"His Hooker marriage echoed down two more generations","body":"When Captain Asahel Strong Jr. married Sarah Hooker in 1729 at Farmington, Connecticut — a great-great-granddaughter of Rev. Thomas Hooker — he began a pattern that would echo through generations: their great-great-grandson Asahel Hooker Strong was born in 1776 with 'Hooker' preserved as his middle name, and 84 years after the first marriage, Judge Elisha Beebe Strong married another Thomas Hooker descendant, Dolly Goodwin Hooker, at Canandaigua, New York in 1813. By 1866, that second union had produced Beebe Hooker Strong of Milwaukee, the fourth person in the Strong family to carry the Hooker name — connecting the original Farmington parsonage to the Wisconsin frontier across 137 years."}],"slug":"asahel-strong-jr-1702"},"H00103":{"id":"H00103","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"i