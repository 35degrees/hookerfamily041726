le","tags":["yale_tutor","yale_graduate"],"number_of_marriages":2,"notable":{"is_notable":true,"notable_category":["education"],"notable_blurb":"Son of Yale's founding trustee; Yale tutor 1722-24","primary_url":"https://archives.yale.edu/agents/people/22447","primary_url_label":"Yale Archives"},"narrative_blocks":[{"number":1,"category":"career","header":"Yale tutor 1722-24 — then apothecary","body":"He graduated from Yale in 1718 and served as a tutor there 1722-24. He then established himself as an apothecary in Boston, continuing the business until his second marriage in 1754, when he moved to New Haven and carried on the same trade there until his death in 1776."},{"number":2,"category":"family","header":"His three eldest sons all married sisters","body":"The eldest three sons — Evelyn, Robert, and James — all married sisters, daughters of Charles Collins of Litchfield. The Collins sisters were daughters of Charles Collins of Litchfield."},{"number":3,"category":"character","header":"Whitefield preached under his elm tree — twice","body":"Rev. George Whitefield was twice the guest of James Pierpont — in October 1740 and again in 1745. On the latter occasion \"he preached to an immense audience from a platform under the Elm tree, in front of Mr. Pierpont's house.\" (Pierpont occupied his father's residence at Elm and Temple Streets, New"},{"number":4,"category":"character","header":"Spent his last years chasing an English inheritance","body":"The last years of his life were clouded by vain efforts to obtain recognition as the rightful heir to the titles and estates of the Pierrepont family in England. (His son Evelyn carried this further — His son Evelyn pursued this claim further."},{"number":5,"category":"family","header":"Sister married Edwards — the Aaron Burr legacy","body":"His sister Sarah Pierpont Edwards married Jonathan Edwards, the Great Awakening theologian. Their daughter Esther married Rev. Aaron Burr Sr., and their son Aaron Burr became the 3rd Vice President of the United States and killed Alexander Hamilton in a duel in 1804. The Pierpont siblings split into two of the most consequential American lineages."}],"education":[{"notes":"Tutor at Yale 1722-1724","school_name":"Yale College","graduation_year":1718,"institution_id":"INST022"}],"bio":{"display_name":"James Pierpont","first_name":"James","last_name":"Pierpont","married_names":[],"bio_blurb":"Yale tutor, then apothecary in Boston and New Haven"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1718"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Tutor","organization":"Yale College","start_year":1722,"end_year":1724},{"role":"Apothecary","location":"Boston","start_year":1727,"end_year":1754},{"role":"Apothecary","location":"New Haven","start_year":1754,"end_year":1776,"notes":"Occupied his father’s residence at Elm and Temple Streets."}],"slug":"james-pierpont-1699"},"I00143":{"id":"I00143","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1728,"month":1,"day":1,"city":"New Haven","state":"Connecticut"},"death":{"year":1803,"city":"New Haven","state":"Connecticut"},"parents":{"mother_research_notes":"Unknown Callone Sherman","father_research_notes":"Jabez Sherman of New Haven"},"marriages":[{"spouse_id":"H00116","children_ids":["H00351","H00352","H00353","H00354","H00355"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 116"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Anna Sherman Pierpont","notes":"Also given as Ann Sherman Davenport — widow of 