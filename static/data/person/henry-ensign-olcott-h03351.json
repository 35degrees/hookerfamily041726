residence":{"city":"Manchester","county":"Hartford","state":"Connecticut","country":"United States"},"burial":{},"gender":"male","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"is_easter_egg":false,"descent_paths_to_thomas":1},"parents":{"father_id":"H00705","mother_id":"I00349"},"marriages":[{"marriage_number":1,"spouse_id":"I00348","date_year":1856,"date_month":10,"date_day":20,"location_country":"United States","end_type":"death_of_self","end_year":1910,"children_ids":["H03346","H03347","H03348","H03349","H03350","H03351"]}],"number_of_marriages":1,"tags":["california_migration","environmentalist","author"],"research_tags":[],"sources":[{"label":"Wikipedia — James B. Olcott","url":"https://en.wikipedia.org/wiki/James_B._Olcott"},{"label":"Connecticut State Library — James Bradford Olcott Papers","url":"https://cslarchives.ctstatelibrary.org/repositories/2/resources/3"},{"label":"Olcott Genealogy Book (Ingmire 1874)","url":"https://ia801606.us.archive.org/4/items/descendantsoftho00ingood/descendantsoftho00ingood.pdf"}],"research_sources":[],"notable":{"is_notable":true,"notable_category":["agriculture","science","public_service"],"notable_blurb":"Turfgrass pioneer; introduced zoysiagrass to America","primary_url":"https://en.wikipedia.org/wiki/James_B._Olcott","primary_url_label":"Wikipedia"},"narrative_blocks":[{"number":1,"category":"character","header":"Sailed for the Gold Rush at age eighteen","body":"In 1849 James B. sailed from Connecticut to San Francisco aboard the Henry Lee as part of the California Gold Rush, age eighteen. He worked for an import company specializing in exotic Pacific plants, ran a tavern in Sacramento, then sailed around the world collecting grass specimens — visiting Hawaii, Korea, Britain, France, and Germany."},{"number":2,"category":"science","header":"Introduced zoysiagrass to the United States","body":"From 1889 under the auspices of the Connecticut Agricultural Experiment Station, James B. began an obsessive turfgrass research project at his Manchester farm 'The Ranch.' One acre held more than 1,500 distinct grass specimens in five-square-foot plots, which he mowed and maintained using tools of his own invention. He traveled to Europe, Australia, and New Zealand collecting samples, and was the first to introduce zoysiagrass to America."},{"number":3,"category":"legacy","header":"Advised Olmsted on Central Park and Bushnell lawns","body":"Frederick Law Olmsted consulted James B. Olcott on the lawns of his most famous landscape designs — New York's Central Park and Hartford's Bushnell Park. Olcott's reputation as 'the Grass Man' brought him into the inner circle of the most influential landscape architect of the era."},{"number":4,"category":"public_service","header":"Founding trustee of the Storrs Agricultural School","body":"In 1880 James B. served on a three-person Connecticut General Assembly committee — with William Henry Brewer of Yale and George A. Bowen — that reviewed Charles and Augustus Storrs's offer to donate land and money for a state agricultural school. He was appointed to the school's first board of trustees in 1881 and stepped down in 1888 after advocating Yale retain its land-grant status."},{"number":5,"category":"career","header":"Worked for Cheney Brothers and the Connecticut Grange","body":"Between his farm and his turfgrass work, James B. oversaw outdoor work — landscaping and road construction — for the Cheney Brothers silk-manufacturer company town in South Manchester. He co-founded the Manchester chapter of the Connecticut State Grange in 1885; some peers thought him 'something of a crank.'"}],"cross_connections":[{"type":"civic_peer","related_id":"X02035","display_label":"Advised Olmsted on Central Park and Bushnell Park lawns","link_text":"Frederick Law Olmsted"}],"naming_inspiration":[{"name_element":"Bradford","inspired_by_id":"I00349","description":"Middle name carries his maternal grandmother Alice Bradford's surname forward — the line tracing back to William Bradford, second governor of Plymouth Colony."}],"education":[{"school_name":"Center Academy","dates":"ca.1853","type":"secondary","notes":"Harwinton CT. Attended after returning from California."}],"career":[{"role":"Apprentice printer","organization":"The Republican (Hartford newspaper)","location":"Hartford, Connecticut","start_year":1846,"notes":"Worked in printing offices age 16."},{"role":"Tavern and boardinghouse proprietor","organization":"Self (Sacramento)","location":"Sacramento, California","start_year":1849,"notes":"Started during California Gold Rush."},{"role":"Farmer / turfgrass culturist","organization":"The Ranch (Manchester family farm)","location":"South Manchester, Connecticut","end_year":1890,"notes":"Inherited and managed family farm. Retired 1890; turned over to son Walter."},{"role":"Agriculture columnist","organization":"Hartford Courant","location":"Hartford, Connecticut","start_year":1869,"end_year":1889,"notes":"Wrote agriculture column for two decades."},{"role":"Outdoor work superintendent","organization":"Cheney Brothers (silk manufacturer, Manchester)","location":"South Manchester, Connecticut","notes":"Oversaw landscaping and road construction in the Cheney Brothers company town."},{"role":"Founding trustee","organization":"Storrs Agricultural School (later University of Connecticut)","location":"Mansfield, Connecticut","start_year":1881,"end_year":1888,"notes":"Served on the original three-person committee (with William Henry Brewer of Yale and George A. Bowen) that recommended the legislature accept Charles and Augustus Storrs's 1880 land-and-money donation. Subsequently appointed to the school's first board of trustees in 1881; resigned 1888 after advocating Yale retain land-grant status."}],"military_service":[],"institutio