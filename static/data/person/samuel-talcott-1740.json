ear":1789,"month":12,"day":31,"city":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1836,"month":3,"day":19,"city":"New York","state":"New York","country":"United States"},"parents":{"father_id":"T00394","mother_id":"U00066"},"marriages":[],"classification":{"is_talcott_descendant":true,"descent_from_john_talcott":true,"is_thomas_descendant":false,"descent_from_thomas_hooker":false,"generation_from_john_talcott":5,"include_in_path_calculation":true,"is_easter_egg":false,"is_talcott_spouse":false,"is_thomas_spouse":false},"tags":["lawyer"],"education":[{"institution_id":"INST043","dates":"1809","type":"university","notes":"Williams College, A.B. 1809"}],"career":[{"role":"Attorney","organization":"Lowville and Utica, New York","start_year":1812},{"role":"Attorney General of New York","organization":"State of New York","start_year":1821,"end_year":1829}],"notable":{"is_notable":true,"notable_category":["law","politics"],"notable_blurb":"Attorney General of New York","primary_url":"https://en.wikipedia.org/wiki/Samuel_A._Talcott","primary_url_label":"Wikipedia"},"narrative_blocks":[{"number":1,"category":"law","header":"He beat Daniel Webster at the Supreme Court","body":"Arguing a landmark trusts-and-perpetuities case before the U.S. Supreme Court, Talcott prevailed against Daniel Webster himself. The dispute, over the Sailors' Snug Harbor estate, was a stage few country-trained lawyers ever reached. The victory sealed his standing among the era's great advocates."},{"number":2,"category":"politics","header":"Eight years as New York's attorney general","body":"Appointed attorney general of New York in 1821, Talcott held the office for eight years. He was a leading member of the Albany Regency, the machine that ran the state for the Van Buren faction. Few lawyers argued more often before its highest courts."},{"number":3,"category":"career","header":"From a country office to the front rank","body":"Talcott studied law in the office of Gold and Sill and was admitted to the bar in 1812. He built his practice outward from Lowville to Utica before reaching New York City. Within a decade he stood among the most respected advocates in the state."},{"number":4,"category":"character","header":"Forced out for “irregular habits”","body":"In 1829 Talcott resigned the attorney generalship under the phrase “irregular habits.” It was the period's polite euphemism for a drinking problem. The brilliance of his public career ran alongside that private struggle."},{"number":5,"category":"legacy","header":"The bar said his learning was never surpassed","body":"At his death the New York Bar gathered to mourn him in the Supreme Court chamber. Its resolution praised talent and scholarship “rarely equaled and never surpassed” at the bar of the state. He was forty-six."}],"burial":{"cemetery_id":"CEM056"},"slug":"samuel-austin-talcott-1789"},"T02292":{"id":"T02292","bio":{"first_name":"Child","last_name":"Talcott","display_name":"Child Talcott"},"gender":"unknown","birth":{"year":1777,"date_precision":"approximate"},"death":{"year":1778},"parents":{"father_id":"T00394","mother_id":"U00066"},"marriages":[],"classification":{"is_talcott_descendant":true,"descent_from_john_talcott":true,"is_thomas_descendant":false,"descent_from_thomas_hooker":false,"generation_from_john_talcott":5,"include_in_path_calculation":true,"is_easter_egg":false,"is_talcott_spouse":false,"is_thomas_spouse":false},"tags":["died_young","died_in_infancy"],"slug":"child-talcott-1777"},"T02293":{"id":"T02293","bio":{"first_name":"Infant","last_name":"Talcott","display_name":"Infant Talcott"},"gender":"unknown","birth":{"year":1788,"date_precision":"approximate"},"death":{"year":1789},"parents":{"father_id":"T00394","mother_id":"U00066"},"marriages":[],"classification":{"is_talcott_descendant":true,"descent_from_john_talcott":true,"is_thomas_descendant":false,"descent_from_thomas_hooker":false,"generation_from_john_talcott":5,"include_in_path_calculation":true,"is_easter_egg":false,"is_talcott_spouse":false,"is_thomas_spouse":false},"tags":["died_young","died_in_infancy"],"slug":"infant-talcott-1788"},"T00071":{"id":"T00071","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":3,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1711,"city":"Hartford","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1797,"month":3,"day":3,"city":"Hartford","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"T00045","mother_id":"U00017"},"marriages":[{"children_ids":["T00394","T02277","T02278","T02279","T02280","T02281","T02282","T02283"],"spouse_id":"X01763","marriage_number":1,"date_year":1739,"date_month":5,"date_day":3}],"sources":[{"short":"Talcott 1876","page":"Entry 71"}],"gender":"male","tags":["yale_graduate"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Samuel Talcott","first_name":"Samuel","last_name":"Talcott","married_names":[],"bio_blurb":"Hartford sheriff and colonel"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM003"},"education":[{"institution_id":"INST022","dates":"1733","type":"university","notes":"Yale College 1733"}],"career":[{"role":"High Sheriff","organization":"Hartford County, Connecticut"},{"role":"Colonel","organization":"Connecticut militia"}],"narrative_blocks":[{"number":1,"category":"character","header":"He bought the stones meant for a church","body":"When Hartford's Episcopalians began their first church in 1762, the foundation stones ended up in Samuel Talcott's house instead. He had not led the mob that wrecked the work, but he bought the stones from a man with no right to sell them. The churchmen never forgave him for it."},{"number":2,"category":"character","header":"“The gates of hell shall not prevail”","body":"In 1786 the Episcopalians tried again, and at the laying of the cornerstone one of their leaders rose to speak. “I lay the corner-stone of the first Episcopal Church in Hartford,” he declared, “and Sam Talcott and the gates of hell shall not prevail against it.” His name had become a byword for the opposition."},{"number":3,"category":"family","header":"His will named only three of his children","body":"Samuel and Mabel raised a houseful of children, several of whom died young. When he made his will, he named only the three who outlived him: his son Samuel, his daughter Mary Watson, and his daughter Jerusha. The document quietly records how much a colonial family could lose."}],"slug":"samuel-talcott-1711"},"X01763":{"id":"X01763","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"EH 1909"}],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"T00071","date_year":1739,"date_month":5,"date_day":3,"children_ids":["T00394","T02277","T02278","T02279","T02280","T02281","T02282","T02283"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1713,"month":2,"day":13,"city":"Hartford","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1775,"month":2,"day":5,"city":"Hartford","county":"Hartford","state":"Connecticut","country":"United States"},"cross_connections":[],"bio":{"display_name":"Mabel Wyllys Talcott","first_name":"Maybel","last_name":"Talcott","married_names":["Talcott"],"maiden_name":"Wyllys"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM003"},"slug":"maybel-wyllys-1713"},"T00045":{"id":"T00045","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":2,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1669,"month":11,"day":16,"city":"Hartford","state":"Connecticut"},"death":{"year":1741,"month":10,"day":11,"city":"Hartford","state":"Connecticut"},"parents":{"father_id":"T00035","mother_id":"U00012"},"tags":[],"sources":[{"short":"Talcott 1876","page":"Entry 45"}],"marriages":[{"spouse_id":"U00022","children_ids":["T00065","T00066","T00067","X00436"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1705,"date_year":1693},{"spouse_id":"U00017","children_ids":["T00068","I00054","T00070","T00071","T00072","T00073","X00446"],"marriage_number":2,"end_type":"death_of_spouse","end_year":1738}],"political_offices":[{"title":"Governor","jurisdiction":"Colony of Connecticut","dates":"1724-1741","duration_years":17,"notes":"First Governor of Connecticut born within its limits. Longest-serving after Gov. Winthrop. Died in office Oct 11, 1741."}],"cross_connections":[{"type":"historical_connection","related_id":"H00115","display_label":"Son-in-law signed his estate — 'Nathaniel Hooker and Eunice Hooker'","link_text":"Captain Nathaniel Hooker"},{"type":"family_connection","related_id":"H00360","display_label":"His granddaughter Esther married Rev. Noadiah Russell in 1758","link_text":"Noadiah Russell"},{"type":"civic_peer","related_id":"U00020","display_label":"was the Deputy Governor whose death opened his path","link_text":"Nathan Gold"}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":true,"notable_category":["politics"],"notable_blurb":"First Connecticut governor born within its limits","primary_url":"https://en.wikipedia.org/wiki/Joseph_Talcott","primary_url_label":"Wikipedia"},"narrative_blocks":[{"header":"First Connecticut governor born within the colony","body":"Born in Hartford on November 16, 1669, Joseph Talcott was the first Governor of Connecticut born within the colony rather than in England. He served from 1724 until his death on October 11, 1741 — 17 years in office, longer than any predecessor except Governor Winthrop and any successor until the modern era. His funeral expenses of £69 12s. 6d. were paid from the Colonial Treasury.","number":1,"category":"politics"},{"header":"He presided in the upper house the afternoon","body":"When his wife Eunice died suddenly about noon on Thursday, May 25, 1738, the Deputy Governor was absent at Norwich. Governor Talcott did not let his private grief interfere with his official duty — he returned and presided in the upper house that same afternoon. The General Assembly appointed a committee to draw an address of condolence to the Governor.","number":2,"category":"politics"},{"header":"His estate was signed by 'Nathaniel Hooker","body":"At the Court of Probate, Hartford, on December 25, 1742, the distribution of Governor Talcott's estate was signed by all children as co-heirs. Among the signatures: 'Nathaniel Hooker and Eunice Hooker' — his daughter Eunice Talcott and her husband Nathaniel Hooker 2d. The Talcott-Hooker convergence was entered into the public record.","number":3,"category":"family"},{"header":"Three of his children each found a separate","body":"His daughter Eunice married Nathaniel Hooker 2d — direct Hooker surname. His son Matthew married Mary Russell, a Hooker descendant through the Pierpont branch. His daughter Abigail married Rev. Daniel Wadsworth; their son Jeremiah later married Mary's own sister Mehitable Russell, also a Hooker descendant.","number":4,"category":"family"},{"header":"Petitioned for his father's estate by primogeniture","body":"Joseph Talcott was the fourth son of Lt.-Col. John Talcott Jr. but the eldest to survive his father. In 1691, at age 21, he petitioned the General Court for his father's estate by right of primogeniture — an assertive legal claim for colonial Connecticut. He was first mentioned in public life in 1711 as a committee member to lay out the town of Coventry.","number":5,"category":"law"}],"bio":{"display_name":"Gov. Joseph Talcott","title":"Governor","first_name":"Joseph","last_name":"Talcott","married_names":[],"bio_blurb":"Colonial governor of Connecticut"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM003"},"slug":"joseph-talcott-1669"},"U00017":{"id":"U00017","visible_default":true,"in_talcott_book":true,"classification":{"is_spouse_of_talcott_descendant":true,"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1678,"month":8,"day":18,"city":"Southampton","county":"Suffolk","state":"New York","country":"United States"},"death":{"year":1738,"month":5,"day":25,"city":"Hartford","county":"Hartford","state":"Connecticut","country":"United States"},"marriages":[{"children_ids":[],"spouse_id":"X01733","marriage_number":1},{"spouse_id":"T00045","children_ids":["T00068","I00054","T00070","T00071","T00072","T00073","X00446"],"marriage_number":2}],"sources":[{"short":"Talcott 1876","page":"Entry 45"},{"short":"Edward Hooker 1909","page":"Entry 115"}],"gender":"female","tags":[],"number_of_marriages":2,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Eunice Howell Talcott","notes":"Widow of [first husband Wakeman] before marrying Gov. Joseph Talcott (T00045)