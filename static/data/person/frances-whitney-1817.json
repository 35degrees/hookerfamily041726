HD2083"],"marriage_number":1,"date_year":1817,"date_month":1,"date_day":6}],"birth":{"year":1765,"month":12,"day":8,"city":"Westborough","state":"Massachusetts"},"death":{"year":1825,"month":1,"day":8,"city":"New Haven","state":"Connecticut"},"gender":"male","notable":{"is_notable":true,"notable_category":["business","science"],"notable_blurb":"Invented the cotton gin; pioneered interchangeable parts","primary_url":"https://en.wikipedia.org/wiki/Eli_Whitney","primary_url_label":"Wikipedia"},"artworks":[{"artwork_id":"ART008","role":"subject"},{"artwork_id":"ART050","role":"subject"}],"number_of_marriages":1,"parents":{},"cross_connections":[],"bio":{"display_name":"Eli Whitney","first_name":"Eli","last_name":"Whitney","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777495010/eliwhitney_nkupkd.webp"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST108","relationship":"founder_legacy","institution_blurb":"Adjacent museum preserving the Whitney Armory site established 1798."},{"institution_id":"INST022","relationship":"alumnus","years":"1792"}],"landmarks":[{"landmark_id":"LM060","role":"connection"}],"quotes":[],"military_service":[],"education":[{"institution_id":"INST022","dates":"1789-1792","type":"undergraduate","notes":"B.A. 1792, Phi Beta Kappa. Worked as a schoolteacher to pay tuition; entered Yale at 24, graduated at 27."}],"narrative_blocks":[{"number":1,"category":"career","header":"Invented the cotton gin during a plantation visit","body":"Visiting Catherine Littlefield Greene's Mulberry Grove plantation in 1793 as a tutor, he heard the difficulty of separating short-staple cotton from its seeds. He built a working prototype in ten days and a finished machine in six months."},{"number":2,"category":"legacy","header":"Cotton gin made the South wealthy, not him","body":"His 1794 patent was widely pirated by Southern planters, and he spent years in court collecting only a fraction of his awarded damages. The cotton gin made cotton economically viable again and revitalized Southern slavery — a consequence that haunted Whitney, who was a Northern abolitionist by sympathy."},{"number":3,"category":"career","header":"Pioneered American mass production with a musket contract","body":"After his patent disaster he took a 1798 federal contract for ten thousand muskets and built a factory at Whitneyville, Connecticut using interchangeable parts. In 1801 he demonstrated to John Adams and Thomas Jefferson by picking parts at random from boxes and assembling working muskets on the spot."},{"number":4,"category":"education","header":"Worked his way to Yale at twenty-four","body":"He earned his tuition teaching school in Westborough and graduated Yale Phi Beta Kappa in 1792, four years older than his classmates. He had originally planned to study law but took a tutoring job in Georgia after graduation — the trip that would lead him to Catherine Greene's plantation."},{"number":5,"category":"marriage","header":"Married Jonathan Edwards's granddaughter at fifty-one","body":"In 1817 he married Henrietta Frances Edwards, granddaughter of the theologian Jonathan Edwards, who was twenty-eight years his junior. They had four children before his death from prostate cancer in January 1825."}],"slug":"eli-whitney-1765"},"HD2046":{"id":"HD2046","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00386","mother_id":"X00654"},"marriages":[{"spouse_id":"X00655","children_ids":["HD2080","HD2081","HD2082","HD2083"],"marriage_number":1,"date_year":1817,"date_month":1,"date_day":6}],"tags":[],"sources":[],"birth":{"year":1786,"month":6,"day":28,"city":"New Jersey","state":"New Jersey"},"death":{"year":1870,"month":4,"day":16},"orbit_connections":[{"name":"Samuel F.B. Morse","relationship":"Painter of Eli Whitney's portrait (1822) — five years after Whitney's marriage to Henrietta Frances Edwards (HD2046), seven years before Morse's telegraph patent","notes":"Samuel Finley Breese Morse (1791-1872) painted the definitive portrait of Eli Whitney in 1822, three years before Whitney's death. Oil on canvas, 35 7/8 × 27 3/4 in. Yale Art Gallery accession 1827.1 — accession number 1827.1 suggests this is among the very first formally catalogued works in the Yale Art Gallery collection. Yale Art Gallery: https://artgallery.yale.edu/collections/objects/31 \n\nGIFT: Donated to Yale by George Hoadley (B.A. 1801) — the 4th Mayor of New Haven, husband of Mary Ann Woolsey Hoadley (HD2075, a Hooker descendant), and the man whose Eagle Bank presidency had nearly bankrupted Yale in 1825. The gift came in 1827 — two years after Whitney's death, two years after the bank collapse. Whether it was redemptive gesture or simply the natural action of New Haven's social elite, the Hooker family network is woven through every thread: Whitney married a Hooker descendant (HD2046); Hoadley married a Hooker descendant (HD2075); Hoadley donated the portrait to Yale, whose presidency was held by Henrietta's first cousin Timothy Dwight IV (H00914). \n\nMorse also taught at NYU; Theodore William Dwight (HD1989), Columbia Law School founder, studied under Morse — connecting the Hooker tree to Morse through two separate branches. (Yale Art Gallery; Wikipedia; NYC Digital Collections)","primary_url":"https://artgallery.yale.edu/collections/objects/31","connection_type":"orbit_non_descendant"}],"gender":"female","narrative_blocks":[{"header":"Married Eli Whitney","detail":"The marriage united two of New England's most prominent family networks: the Edwards-Hooker theological dynasty and the Whitney manufacturing empire. Whitney was already famous — his cotton gin had been patented in 1794, his musket contracts had made him wealthy, and he had pioneered interchangeable parts manufacturing. He was also in failing health; he died eight years after the wedding. Henrietta survived him by 45 years, dying ~1870 — long enough to witness the Emancipation Proclamation and the end of the war the cotton gin had helped make economically intractable. His portrait had been painted by Samuel F.B. Morse in 1822 — five years after the wedding, seven years before Morse's telegraph. (Wikipedia; FindAGrave)","body":"Henrietta Frances Edwards married Eli Whitney on January 6, 1817, when she was 30 and he was 51. Whitney's biographer noted the marriage \"further tied him to Connecticut's ruling elite\" — she was a granddaughter of Jonathan Edwards, daughter of Connecticut's Democratic Party chief, and first cousin of Yale's Federalist president Timothy Dwight IV.","number":1,"category":"character"},{"number":2,"category":"family","header":"She outlived the cotton gin’s inventor by decades","body":"As Eli Whitney’s widow she lived forty-five more years — long enough to see the Emancipation Proclamation and the end of the Civil War, the full reckoning of what her husband’s machine had set loose on the country."}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Henrietta Frances Edwards Whitney","first_name":"Henrietta","last_name":"Whitney","married_names":["Whitney"],"middle_name":"Frances","maiden_name":"Edwards","bio_blurb":"Wife of cotton-gin inventor Eli Whitney"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"henrietta-whitney-1786"},"H00386":{"id":"H00386","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1750,"month":4,"day":8,"city":"Northampton","state":"Massachusetts"},"death":{"year":1826,"month":4,"day":5,"city":"Bridgeport","state":"Connecticut"},"parents":{"father_id":"X00128","mother_id":"HD0418"},"tags":["lawyer","continental_congress","freemason","judge","politician"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 386"}],"burial":{"cemetery":"Grove Street Cemetery","city":"New Haven","state":"Connecticut","cemetery_id":"CEM009"},"marriages":[{"spouse_id":"X00654","children_ids":["HD2652","HD2095","HD2653","HD2654","HD2044","HD2045","HD2096","HD2097","HD2098","HD2099","HD2046"],"marriage_number":1}],"gender":"male","notable":{"is_notable":true,"notable_category":["law","politics"],"notable_blurb":"First US District Judge CT; Grand Master CT","primary_url":"https://en.wikipedia.org/wiki/Pierpont_Edwards","primary_url_label":"Wikipedia"},"narrative_blocks":[{"number":1,"category":"law","header":"Jefferson named him Connecticut's first federal judge","body":"Thomas Jefferson appointed him the first U.S. District Judge for the District of Connecticut in 1806; he served until his death twenty years later. He had earlier represented Connecticut in the Continental Congress (1787-1788) and helped ratify the U.S. Constitution at the state convention."},{"number":2,"category":"family","header":"His daughter married Eli Whitney","body":"His daughter Henrietta Frances Edwards married inventor Eli Whitney in 1817. Their daughter Henrietta Whitney Edwards later married Prof. Worthington Hooker in 1855 — reuniting the Hooker and Edwards lines through Thomas Hooker."},{"number":3,"category":"family","header":"His nephew Aaron Burr was six years younger","body":"His older sister Esther Edwards married Rev. Aaron Burr Sr.; their son Aaron Burr Jr. became Vice President and was only six years younger than Pierpont. The two were uncle and nephew but more like brothers in age."},{"number":4,"category":"character","header":"First Grand Master of Masons in Connecticut","body":"He was a Freemason in Hiram Lodge No. 1 in New Haven and became the first Grand Master of the Grand Lodge of Connecticut. The Grand Lodge still honors distinguished members with a medal in his name."},{"number":5,"category":"career","header":"Bought Richfield Township in Ohio's Western Reserve","body":"He invested £60,000 in the Connecticut Land Company in 1795 — five percent of the company — and was one of seven investors who purchased Richfield Township in Ohio. He sent his son John Stark Edwards as his first agent in the Western Reserve."}],"number_of_marriages":1,"cross_connections":[{"type":"civic_connection","related_id":"HD2925","display_label":"Newton settled the Ohio township he had bought.","link_text":"John Newton"},{"type":"historical_connection","related_id":"H00443","display_label":"Both Hooker descendants shaped the Western Reserve — land and education","link_text":"Rev. Giles Hooker Cowles"},{"type":"civic_peer","related_id":"T00387","display_label":"He won this seat — then declined it, forcing Wadsworth back","link_text":"Col. Jeremiah Wadsworth"},{"type":"civic_peer","related_id":"X00614","display_label":"Fellow early Connecticut lawyer-judge; husband of Edwards's niece Sally Burr.","link_text":"Judge Tapping Reeve"}],"institutions":[{"institution_id":"INST022","relationship":"portrait_subject","institution_blurb":"Yale University Art Gallery holds his 1795 portrait by William Jennys (ART031, accession 1968.30.4)."},{"institution_id":"INST0045"}],"bio":{"display_name":"Pierpont Edwards","first_name":"Pierpont","last_name":"Edwards","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/9/9d/William_Jennys_-_Portrait_of_Judge_Pierpont_Edwards_%281750-1826%29_-_1968.30.4_-_Yale_University_Art_Gallery.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"a