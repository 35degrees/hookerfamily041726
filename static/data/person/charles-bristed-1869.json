kson1937_dafbxs.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST167","relationship":"executive"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"category":"career","header":"Time-Life executive and Cold War propagandist","body":"A senior executive at Henry Luce's Time Inc., Jackson directed Allied psychological warfare in North Africa and at Eisenhower's SHAEF during the war. He later ran the Free Europe Committee and Radio Free Europe and served as Eisenhower's Special Assistant for international affairs.","number":1},{"category":"character","header":"His magazines doubled as Cold War tools","body":"As publisher of Fortune and Life, Jackson moved fluidly between journalism and intelligence work and was later described as Luce's personal liaison to the CIA. Papers opened after his death showed he had aided covert information campaigns since the late 1940s.","number":2},{"category":"legacy","header":"He bought the Zapruder film for Life","body":"Days after President Kennedy's assassination, Jackson secured Time-Life's purchase of Abraham Zapruder's home movie of the killing. Life published individual frames but, controversially, never released the footage as a moving film during his lifetime.","number":3},{"category":"family","header":"He married into the Astor-Sedgwick Berkshire world","body":"Jackson's wife, Katherine Bristed, descended from the Astor and Sedgwick families, and the couple summered at the Bristed estate near Stockbridge. He is buried within the famous Sedgwick family circle in Stockbridge Cemetery.","number":4},{"category":"character","header":"He blurred journalism and government propaganda","body":"Moving fluidly between Time Inc. and Washington, Jackson embodied the Cold War alliance of media and state, drafting psychological-warfare strategy while running Henry Luce's magazines. Observers watched the line between reporting and statecraft dissolve in his career.","number":5}],"burial":{"cemetery_name":"Stockbridge Cemetery","city":"Stockbridge","county":"Berkshire","state":"Massachusetts","country":"United States","plot_notes":"Buried within the Sedgwick family circle."},"education":[{"school_name":"Princeton University","type":"undergraduate","dates":"1924"}],"career":[{"role":"Senior executive and publisher (Fortune, Life)","organization":"Time Inc.","start_year":1931,"end_year":1964},{"role":"Deputy Chief, Psychological Warfare","organization":"Allied Force Headquarters and SHAEF","start_year":1943,"end_year":1945},{"role":"President","organization":"Free Europe Committee","start_year":1951,"end_year":1952},{"role":"Special Assistant to the President","organization":"Eisenhower administration","start_year":1953,"end_year":1954}],"slug":"charles-jackson-1902"},"X00758":{"id":"X00758","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1880},"death":{"year":1958},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2340","date_year":1932,"date_month":7,"children_ids":[]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Clementina Carroll Hill","first_name":"Clementina","middle_name":"Carroll","maiden_name":"Hill","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"clementina-hill-1880"},"X00746":{"id":"X00746","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_desce