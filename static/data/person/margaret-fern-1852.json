:[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Three children with Margaret Catharine Fern","body":"William Alonzo Root married Margaret Catharine Fern about 1882; she was born August 1852 in New York. Their three documented children were Edgar Francis Root (1883-1941, born Buffalo New York and died Bluefield West Virginia), Ethel M. Root (born 1885), and Margaret E. Root. Edgar Francis's career took him from Buffalo to West Virginia — a substantial geographic move from the family's Ashtabula County Ohio center."},{"number":2,"category":"family","header":"Ohio birth, Ontario death; eldest of five","body":"William Alonzo Root was the eldest of his father William Ezekiel Root's five sons born in Austinburg, Ashtabula County Ohio in the late 1850s and early 1860s. The five brothers — William Alonzo, E.L., E.W., S.L., and A.A. — formed an unusually compressed 1859-1861 birth cluster. William Alonzo eventually moved north into Ontario Canada, dying in Wentworth at age about seventy-one in 1930."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry #2350"},{"short":"Root Genealogical Records","page":"#6048"},{"short":"FamilySearch (M358-QMK)"}],"research_sources":[],"documents":[],"slug":"william-root-1859"},"HD5095":{"id":"HD5095","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"generation_from_thomas":9,"is_easter_egg":false},"parents":{"father_id":"HD3895","mother_id":"I01292"},"tags":[],"sources":[],"marriages":[],"number_of_marriages":0,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1883,"month":5,"day":1,"city":"Buffalo","county":"Erie County","state":"New York","country":"United States"},"death":{"year":1941,"month":4,"day":2,"city":"Bluefield","county":"Mercer County","state":"West Virginia","country":"United States","age":57},"cross_connections":[],"bio":{"display_name":"Edgar Francis Root","first_name":"Edgar","last_name":"Root","middle_name":"Francis","married_names":[],"gender":"male"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Buffalo NY birth, Bluefield West Virginia death","body":"Edgar Francis Root was born May 1, 1883 in Buffalo, Erie County New York — and died April 2, 1941 in Bluefield, Mercer County West Virginia at age fifty-seven. The Buffalo-to-Bluefield migration spanned a thousand miles and crossed two distinct American regions: the late-Gilded-Age industrial Northeast where his father William Alonzo had settled, and the early-twentieth-century Appalachian coal-and-rail South where he ended his life."}],"slug":"edgar-root-1883"},"HD5096":{"id":"HD5096","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"generation_from_thomas":9,"is_easter_egg":false},"parents":{"father_id":"HD3895","mother_id":"I01292"},"tags":[],"sources":[],"marriages":[],"number_of_marriages":0,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1885},"death":{},"cross_connections":[],"bio":{"display_name":"Ethel M. Root","first_name":"Ethel","last_name":"Root","middle_name":"M.","married_names":[],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ethel-root-1885"},"HD5097":{"id":"HD5097","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"d