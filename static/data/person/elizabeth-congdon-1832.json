false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H00487","mother_id":"I01023"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01025","date_year":1823,"date_month":10,"date_day":2,"location_country":"United States","children_ids":["HD4759","HD4760","HD4761","HD4762","HD4763","HD4764"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died at thirty; infant Joseph eight months old","body":"Ann Hooker Congdon married Joseph Congdon on October 2, 1823 and bore six children in eleven years; her youngest, Joseph, was born April 17, 1834, and she died December 17 that same year at Freedom, New York, at thirty years old — leaving an eight-month-old infant among her surviving children. Her husband Joseph Congdon outlived her by thirty-eight years, dying at Elmira in 1872; the eldest child she had named 'James Hooker' had himself died nine months before that, in May 1865, leaving her family's history as a study in how early death cascades through a generation."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"ann-congdon-1804"},"H00487":{"id":"H00487","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1758,"month":5,"day":14,"city":"Woodbury","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00254","mother_id":"I00162"},"tags":["veteran","revolutionary_war"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 487"}],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01023","date_year":1791,"location_city":"Litchfield","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1840,"children_ids":["H01266","H01267","H01268","H01268a","H01268b","H01268c","H01269"]}],"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1849,"month":1,"day":9,"city":"Clyde","state":"New York","country":"United States"},"cross_connections":[],"bio":{"display_name":"Gilbert Hooker","first_name":"Gilbert","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","rank":"Enlisted / Quartermaster's Dept","unit":"Quartermaster's Department","notes":"EH: 'He served in the Quarter-master's Department in the Revolutionary War.'"}],"narrative_blocks":[{"number":1,"category":"military","header":"Quartermaster's Department veteran; lived ninety years","body":"Gilbert Hooker served in the Quartermaster's Department during the Revolutionary War, then settled at Stillwater, New York with his wife Rebecca Andrews where their children were born, later moving the family to Clyde, New York — and lived to see all of it: the nation he helped supply through the Revolution, the expansion across New York State, the rise of his son James Harvey to wealthy merchant at Troy. He died January 9, 1849 at approximately ninety years of age, having outlived his wife Rebecca by eight years — born in Woodbury, Connecticut in 1758, dying when Abraham Lincoln was still an Illinois congressman and the gold rush was just beginning in California, his life spanning the entire arc from Puritan New England colony to young republic."}],"burial":{"cemetery_id":"CEM504","plot_notes":"Maple Grove Cemetery Clyde Wayne County NY per FA"},"slug":"gilbe