gory":[]},"death":{"year":1846,"month":1,"day":1},"cross_connections":[],"documents":["DOC008"],"bio":{"display_name":"Elizabeth Hart Percival","first_name":"Elizabeth","last_name":"Percival","maiden_name":"Hart","married_names":["Percival","Porter"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Mother of poet-geologist James Gates Percival","body":"Elizabeth Hart Percival's son James Gates Percival (born September 15, 1795) became a major American poet and the official state geologist of both Connecticut and Wisconsin after his Yale 1815 graduation. Elizabeth herself was described as 'by nature of a susceptible and delicate organization' who 'seems to have imparted to her son these qualities, with a tendency to excessive mental development.' She was understood to have transmitted depression and extreme sensitivity to her sons — James also suffered from depression throughout his life."},{"number":2,"category":"death","header":"Lost husband and daughter within five weeks, 1807","body":"Elizabeth's first husband Dr. James Percival Jr. died January 22, 1807 in Kensington Connecticut at age forty, and five weeks later her daughter Harriet died February 16, 1807 at age seventeen. The compressed loss of husband and eldest child within five weeks marked the family's catastrophic early-1807. Elizabeth waited five years before remarrying — to Samuel Porter on April 6, 1812."},{"number":3,"category":"family","header":"Son James worked Porter farm before re-entering Yale","body":"After her 1812 second marriage to Samuel Porter, Elizabeth's son James Gates Percival worked on Porter's farm before re-entering Yale to complete his 1815 degree. The interim farm labor between the family rebuild and resumption of Yale studies was the kind of practical stop-gap that interrupted many early-Republic professional-track educations after parental deaths reset family finances."},{"number":4,"category":"family","header":"Born Kensington 1769, four children with Dr. Percival","body":"Elizabeth Hart was born in 1769 in Kensington Connecticut (baptized December 24, 1769) and married Dr. James Percival Jr. there in January 1790 at age twenty. Four children survived to be documented: Harriet (died 1807 age 17), Edwin (died Troy NY), James Gates Percival (Yale 1815 poet-geologist), and Oswin Hart Percival (baptized 1809, died never married at a New Haven hospital). Elizabeth herself died around 1846."}],"slug":"elizabeth-percival-1769"},"X01045":{"id":"X01045","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00587","children_ids":["HD0730","HD2963"],"date_year":1822,"date_month":3,"date_day":14}],"parents":{"father_id":"X01935","mother_id":"H00610"},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1784,"month":7,"day":7},"death":{"year":1875,"month":7,"day":6},"cross_connections":[],"bio":{"display_name":"Mindwell Porter","first_name":"Mindwell","last_name":"Hart","maiden_name":"Porter","married_names":["Hart"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mindwell-porter-1784"},"H00587":{"id":"H00587","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1