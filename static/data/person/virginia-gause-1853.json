2,"city":"Wilmington","state":"Delaware","country":"United States","age":79},"residence":{},"burial":{"plot_notes":"Wilmington and Brandywine Cemetery, Wilmington DE"},"baptism":{},"cross_connections":[],"narrative_blocks":[],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Catharine I. Gause","first_name":"Catharine","last_name":"Gause","maiden_name":"Dougherty","middle_name":"I.","married_names":["Gause"],"gender":"female"},"slug":"catharine-dougherty-1903"},"HD5120":{"id":"HD5120","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":1,"descent_from_thomas_hooker_bool":true},"parents":{"father_id":"HD5108","mother_id":"I01300"},"tags":["governor","politician"],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"I01301","end_type":"death_of_spouse","end_year":1898,"children_ids":["HD5124","HD5125","HD5126","HD5127","HD5128"]}],"number_of_marriages":1,"notable":{"is_notable":true,"notable_blurb":"Governor of Connecticut, 1873-1877","notable_category":["politics"],"primary_url":"https://en.wikipedia.org/wiki/Charles_Roberts_Ingersoll","primary_url_label":"Wikipedia"},"birth":{"year":1821,"month":9,"day":16,"city":"North Haven","state":"Connecticut","country":"United States"},"death":{"year":1903,"month":1,"day":25,"city":"North Haven","state":"Connecticut","country":"United States","age":81},"residence":{},"burial":{"plot_notes":"Grove Street Cemetery, New Haven CT"},"baptism":{},"cross_connections":[{"type":"civic_peer","related_id":"HD2659","display_label":"New Haven attorney; Bristol law firm founder, almost lifelong friend","link_text":"Louis H. Bristol","notes":"Lifelong friendship documented in Bristol's CT Reports memorial. Bristol senior counsel for Yale University, founder of Bristol Stoddard & Bristol 1888."},{"type":"in_law","related_id":"X02896","display_label":"was his father-in-law; US Navy Rear Admiral"}],"narrative_blocks":[{"number":1,"category":"politics","header":"Governor of Connecticut, 1873-1877","body":"Charles Roberts Ingersoll served as Governor of Connecticut from 1873 through 1877 — four years that placed him at the head of the state during Reconstruction-era industrial expansion. He continued the family's prominent role in Connecticut public life that his father Ralph (US Minister to Russia, four-term Congressman) and grandfather Jonathan Ingersoll Jr. (Lieutenant Governor 1816-1823) had established before him. Three consecutive generations of Ingersolls held principal Connecticut state offices."},{"number":2,"category":"character","header":"Almost lifelong friendship with Louis H. Bristol","body":"Charles maintained an unusually close, almost lifelong friendship with New Haven attorney Louis H. Bristol — the senior counsel for Yale University and founder of the Bristol Stoddard Bristol law firm. The friendship was described as 'one of special closeness' that ran from their early careers at the New Haven bar through to Bristol's 1910 death. Both men were New Haven figures of the same generation, both descendants of prominent Connecticut legal families."},{"number":3,"category":"family","header":"Married Admiral Francis Gregory's daughter Virginia","body":"Charles married Virginia Gregory (1823-1898), daughter of Admiral Francis Gregory of the United States Navy. The couple had five children together — only three of whom survived to adulthood, two infant deaths and a childhood death marking the family. Virginia died November 30, 1898 in New Haven at age seventy-five, five years before Charles followed in 1903."},{"number":4,"category":"family","header":"North Haven 1821 to 1903, age eighty-one","body":"Charles Roberts Ingersoll was born September 16, 1821 in North Haven Connecticut and died January 25, 1903 in North Haven at age eighty-one. He is buried at Grove Street Cemetery in New Haven alongside three generations of the Ingersoll family. The Grove Street cluster includes his father Ralph, grandfather Jonathan Jr., his wife Virginia Gregory, and his children."}],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST001","role":"student","notes":"Hopkins Grammar School preparatory training"},{"institution_id":"INST022","role":"student","notes":"Yale College class of 1840; honorary LLD 1874"}],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Charles Roberts Ingersoll","first_name":"Charles","last_name":"Ingersoll","middle_name":"Roberts","married_names":[],"gender":"male"},"slug":"charles-ingersoll-1821"},"I01301":{"id":"I01301","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker_bool":false},"parents":{"father_id":"X02896","mother_id":"X02897"},"tags":[],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"HD5120","end_type":"death_of_spouse","end_year":1898,"children_ids":["HD5124","HD5125","HD5126","HD5127","HD5128"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1823,"month":8,"day":28,"country":"United States"},"death":{"year":1898,"month":11,"day":30,"age":75,"country":"United States"},"residence":{},"burial":{"plot_notes":"Grove Street Cemetery, New Haven CT"},"baptism":{},"cross_connections":[],"narrative_blocks":[],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Virginia Ingersoll","first_name":"Virginia","last_name":"Ingersoll","maiden_name":"Gregory","married_names":["Ingersoll"],"gender":"female"},"slug":"virginia-gregory-1823"},"HD5108":{"id":"HD5108","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":1,"descent_from_thomas_hooker_bool":true},"parents":{"father_id":"HD0121","mother_id":"I01299"},"tags":["congressman","diplomat","lawyer","mayor","politician","yale_graduate"],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"I01300","date_year":1814,"end_type":"death","end_year":1872,"children_ids":["HD5117","HD5118","HD5119","HD5120","HD5121","HD5122","HD5123"]}],"number_of_marriages":1,"notable":{"is_notable":true,"notable_blurb":"US Minister to Russia under Polk; Congressman 1825-33","notable_category":["politics","law"],"primary_url":"https://en.wikipedia.org/wiki/Ralph_I._Ingersoll","primary_url_label":"Wikipedia"},"birth":{"year":1789,"month":2,"day":8,"city":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1872,"month":8,"day":26,"city":"New Haven","state":"Connecticut","country":"United States","age":83},"residence":{},"burial":{"plot_notes":"Grove Street Cemetery, New Haven CT, 3 Maple Ave East"},"baptism":{},"cross_connections":[{"type":"in_law","related_id":"X02895","display_label":"was his father-in-law"}],"narrative_blocks":[{"number":1,"category":"politics","header":"US Minister to Russia under President Polk","body":"Ralph Isaacs Ingersoll was appointed by Democratic President James K. Polk as the sixteenth United States Minister Plenipotentiary to the Russian Empire on August 8, 1846. He presented his credentials in Russia on May 30, 1847, and served until his resignation on July 1, 1848. The appointment was unsought and unexpected — he served his government 'faithfully and ably' before gladly returning to his New Haven law practice."},{"number":2,"category":"politics","header":"Four consecutive Congressional terms 1825-1833","body":"Ralph served four consecutive terms in the United States Congress representing Connecticut at-large from March 4, 1825 through March 3, 1833 — first elected as an Adams candidate, then reelected as Anti-Jacksonian. He served on the powerful Ways and Means committee for four years, holding the second-ranking position during his final term. He was not a candidate for renomination in 1832."},{"number":3,"category":"politics","header":"Declined US Senate seat from Governor Edwards, 1835","body":"In 1835 Governor Henry W. Edwards offered Ralph the United States Senate seat made vacant by the death of Senator Nathan Smith. He peremptorily declined — though the legislature would undoubtedly have elected him to the position. He similarly declined repeated gubernatorial nominations from his party across many years, departing from his settled purpose only once when Polk appointed him to Russia."},{"number":4,"category":"character","header":"Best public speaker his contemporaries ever knew","body":"One of Ralph's contemporaries with wide experience said of him 'he was the best public speaker I ever knew.' His voice was pleasant and almost musical, with unusual compass — distinct in its lowest tones. He was eminently persuasive before a jury or popular assembly, with a documented personal magnetism that allowed him to sway crowds, by turns humorous and pathetic, sarcastic when needed."},{"number":5,"category":"family","header":"Yale 1808, New Haven law, Grove Street burial","body":"Ralph graduated from Yale College in 1808 and read law for two years with Seth P. Staples before opening his New Haven practice. He married Margaret Catherine Eleanor Van den Heuvel in 1814 and they had seven children together — including future Governor of Connecticut Charles Roberts Ingersoll and US Congressman Colin Macrae Ingersoll. He died in New Haven August 26, 1872 at age eighty-three, buried at Grove Street Cemetery."}],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","role":"student","notes":"Yale College class of 1808"},{"institution_id":"INST155","role":"student","notes":"Studied at Yale Law School after Yale College 1808"}],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Ralph Isaacs Ingersoll","first_name":"Ralph","last_name":"Ingersoll","middle_name":"Isaacs","married_names":[],"gender":"male"},"slug":"ralph-ingersoll-1789"},"I01300":{"id":"I01300","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker_bool":false},"parents":{"father_id":"X02895","mother_name":"Charlotte Augusta Apthorp","mother_research_notes":"Daughter of NY landowner Charles Ward Apthorp"},"tags":[],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"HD5108","date_year":1814,"end_type":"death","end_year":1872,"children_ids":["HD5117","HD5118","HD5119","HD5120","HD5121","HD5122","HD5123"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1788,"country":"United States"},"death":{"year":1878,"month":12,"day":23,"age":90,"country":"United States"},"residence":{},"burial":{"plot_notes":"Grove Street Cemetery, New Haven CT"},"baptism":{},"cross_connections":[],"narrative_blocks":[],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Margaret Catherine Eleanor Ingersoll","first_name":"Margaret","last_name":"Ingersoll","maiden_name":"Van den Heuvel","middle_name":"Catherine Eleanor","married_names":["Ingersoll"],"gender":"female"},"slug":"margaret-van-den-heuvel-1788"},"X02896":{"id":"X02896","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_progenitor":false,"is_easter_egg":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker_bool":false},"parents":{},"tags":["navy","war_of_1812","mexican_american_war","civil_war","admiral","notable"],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"X02897","end_type":"death","end_year":1866,"children_ids":["I01301"]}],"number_of_marriages":1,"notable":{"is_notable":true,"notable_blurb":"US Navy Rear Admiral — War of 1812, Mexican War, Civil War","notable_category":["military"],"primary_url":"https://en.wikipedia.org/wiki/Francis_Gregory","primary_url_label":"Wikipedia"},"birth":{"year":1789,"month":10,"day":9,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"death":{"year":1866,"month":10,"day":4,"city":"Brooklyn","county":"Kings County","state":"New York","country":"United States","age":76},"residence":{},"burial":{"plot_notes":"Grove Street Cemetery, New Haven CT"},"baptism":{},"cross_connections":[{"type":"in_law","related_id":"HD5120","display_label":"married his daughter Virginia"}],"narrative_blocks":[{"number":1,"category":"military","header":"Rear Admiral USN through three wars 1809-1865","body":"Francis Hoyt Gregory served the United States Navy for fifty-six years — from his 1809 appointment by President Jefferson through to his Civil War retirement. He served in the War of 1812 (Lake Ontario under Isaac Chauncey at Toronto, Kingston, and Fort George); commanded the USS Raritan blockade squadron off the coast of Mexico 1846-1847 in the Mexican-American War; and was promoted Rear Admiral July 16, 1862 during the Civil War as superintendent of private shipyards constructing iron-clad vessels. Two US Navy destroyers were later named USS Gregory in his honor (DD-82 and DD-802)."},{"number":2,"category":"military","header":"Wheelbarrow-stone escape story while in British custody","body":"Captured by the British in August 1814 during the War of 1812, Gregory refused parole and was sent to England where he remained until June 1815 — months after the war had ended. Under house arrest at a country estate, he was bound by a gentleman's agreement defining boundaries with a large stone marker. When he wished to attend a formal dinner party beyond the boundary, he arrived to accusations of breaking the terms — only to lead his accusers outside where they found his wheelbarrow containing the large marker stone parked at the corner of the dinner house."},{"number":3,"category":"family","header":"Father of Virginia Gregory, Governor Ingersoll's wife","body":"Francis's daughter Virginia Gregory (1823-1898) married Charles Roberts Ingersoll — future Governor of Connecticut 1873-1877 — bringing the Rear Admiral's bloodline into the Hooker-Ingersoll line. Through this marriage Francis became grandfather to five Ingersoll grandchildren including Virginia Ingersoll Gause (Wilmington DE; matriarch of the Gause-Canby line) and Elizabeth Shaw Ingersoll Haven (named for Francis's wife and her grandmother)."}],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[{"war":"War of 1812","war_id":"WAR-OF-1812","side":"American","rank_start":"Midshipman","rank_end":"Lieutenant","unit":"US Navy (USS Revenge under Oliver Hazard Perry, USS Vesuvius/Gun Boat 162, Lake Ontario under Isaac Chauncey)","service_years":"1809-1815","notes":"Appointed midshipman Jan 16, 1809 by Jefferson. Served USS Revenge (Oliver Hazard Perry). Capt anti-pirate actions 1810-1811 off Pensacola/Mobile/Brassa-Barataria captured La Franchise, Santa Maria, La Divina, La Sophie, Le Vengeance, La Pandrita, Diomede, Alexandria. Lake Ontario under Isaac Chauncey — attacks on Toronto, Kingston, Fort George. Promoted lieutenant Jan 28, 1814. Captured by British Aug 1814, refused parole, sent to England held until June 1815 (months after war ended). FAMOUS STORY: under house arrest with stone marker boundary; arrived at dinner party past boundary, then revealed he had wheeled the entire marker stone in a wheelbarrow."},{"war":"Mexican-American War","war_id":"WAR-MEXAM","side":"American","rank_start":"Captain","rank_end":"Captain","unit":"USS Raritan (blockade squadron off coast of Mexico)","service_years":"1846-1847","notes":"Commanded blockade squadron off Mexican coast 1846-1847 aboard USS Raritan."},{"war":"American Civil War","war_id":"WAR-CIVIL","side":"Union","rank_start":"Captain","rank_end":"Rear Admiral","unit":"Union Navy (Superintendent of Private Shipyards, iron-clad construction)","service_years":"1861-1865","notes":"Returned to naval service to superintend construction and fitting-out of naval vessels in private shipyards, including iron-clad vessels. Promoted to Rear Admiral July 16, 1862."}],"education":[],"career":[],"bio":{"display_name":"Rear Admiral Francis Hoyt Gregory","first_name":"Francis","last_name":"Gregory","middle_name":"Hoyt","married_names":[],"title":"Rear Admiral","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779827648/Francis_Gregory_abv61k.jpg"},"slug":"francis-gregory-1789"},"X02897":{"id":"X02897","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_progenitor":false,"is_easter_egg":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker_bool":false},"parents":{},"tags":[],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"X02896","end_type":"death","end_year":1866,"children_ids":["I01301"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1801,"month":7,"day":23,"country":"United States"},"death":{"year":1873,"month":12,"day":9,"age":72,"country":"United States"},"residence":{},"burial":{"plot_notes":"Grove Street Cemetery, New Haven CT"},"baptism":{},"cross_connections":[],"narrative_blocks":[],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Elizabeth Gregory","first_name":"Elizabeth","last_name":"Gregory","maiden_name":"Shaw","married_names":["Gregory"],"gender":"female","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779827727/elizshawgregory_zaoltb.png"},"slug":"elizabeth-shaw-1801"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}