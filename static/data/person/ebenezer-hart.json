:"career","header":"Thirty Ohio letters guided Connecticut Reserve buyers","body":"While garrisoned at Fort Washington Ohio in 1791, he wrote some thirty letters to his Farmington friend Maj William Judd about soil, climate, and the value of Ohio lands. The Connecticut Reserve commissioners 'wisely availed themselves of his knowledge' — the Judd descendants preserved the letters in New Britain through 1875."}],"education":[{"institution_id":"INST022","dates":"1768","notes":" — Yale 1768, with honors. Brigadier General. Killed at St. Clair's Defeat 1791. Cousin of Gen. Selah Hart (H00273, Hooker descendant). Not a direct Hooker descendant — included for community context."}],"slug":"gen-hart-1746"},"X00314":{"id":"X00314","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["revolutionary_war"],"sources":[],"birth":{"year":1754},"death":{"year":1832},"gender":"male","parents":{"father_id":"X00119","mother_name":"Elizabeth Lawrence","mother_research_notes":"Elizabeth Lawrence (no I-prefix entry — not built as no Hooker connection)."},"marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Thomas Hart","first_name":"Thomas","last_name":"Hart","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"thomas-hart-1754"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}