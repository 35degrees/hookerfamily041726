es"},"parents":{"father_id":"H00030","mother_id":"I00031"},"tags":["replacement_naming","politician","compiler_ancestor"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 98"}],"burial":{"cemetery_id":"CEM008"},"marriages":[{"marriage_number":1,"spouse_id":"I00041","date_year":1728,"date_month":7,"date_day":4,"location_city":"Kensington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1766,"children_ids":["H00264","H00265","H00266","H00267"]}],"cross_connections":[{"type":"family_connection","related_id":"H00277","display_label":"His niece's son Abel Hollister came under his guardianship","link_text":"Anna Hart"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Named for a brother who died nine days","body":"His older brother John was born and died in December 1693 — living only nine days. When the next son arrived in 1695, his parents gave him the same name. He carried it through 71 years, Justice of the Peace and prominent Kensington businessman."},{"number":2,"category":"marriage","header":"He and his three sisters all married into","body":"His sisters Abigail, Mary, and Sarah married three sons of Capt. John Hart between 1719 and 1725. John himself had already married Mercy Hart in 1728 — from a different Hart branch, through Dea. Ebenezer Hart. Four Hooker siblings, two separate Hart lines, one generation."},{"number":3,"category":"politics","header":"Justice of the Peace","body":"EH describes him as \"a prominent and active man in the business of the town.\" He held the office of Justice of the Peace in Kensington, a parish of Berlin CT, and died there on August 3, 1766, age 71."}],"bio":{"display_name":"John Hooker","first_name":"John","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-hooker-1695"},"H00264":{"id":"H00264","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"compiler_ancestor":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1729,"month":3,"day":19,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1777,"month":2,"day":6,"city":"Northampton","county":"Hampshire","state":"Massachusetts","country":"United States","cause":"smallpox"},"parents":{"father_id":"H00098","mother_id":"I00041"},"tags":["compiler_ancestor","yale_graduate","clergy","minister","epidemic_death"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 264"}],"marriages":[{"spouse_id":"I00043","children_ids":["H00524","H00525","H00526","H00527","H00528","H00529","H00530","H00531","H00532"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1777,"date_year":1755,"date_month":12,"date_day":10,"location_country":"United States"}],"compiler_ancestor":true,"ministry_positions":[{"role":"Minister","location":"Northampton, Massachusetts","dates":"1753-1777","duration_years":24,"notes":"Ordained Dec 5, 1753; settled there 24 years until death by smallpox"}],"ordination":{"date":{"year":1753,"month":12,"day":5},"location":"Northampton, Massachusetts"},"primary_residence":{"city":"Northampton","state":"Massachusetts","notes":"Minister here 24 years 1753-1777. Yale 1751, ordained Dec 5, 1753."},"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"religion","header":"Took Jonathan Edwards' Northampton pulpit, died of smallpox","body":"Ordained in 1753, he became pastor at Northampton, Massachusetts — the church where Jonathan Edwards had preached until his dismissal in 1750. He held that pulpit for nearly 25 years, dying of smallpox on February 6, 1777, in his 48th year. His was the most prominent pastoral appointment held by any Hooker descendant of his generation."},{"number":2,"category":"family","header":"His wife's father, Colonel Worthington, named Worthington Parish","body":"He married Sarah Worthington, daughter of Colonel Worthington of Springfield, Massachusetts — the man who gave his name to Worthington Parish in Berlin, Connecticut, the parish where the Hart and Hooker families had long been prominent. The marriage connected the Hooker line to one of western Massachusetts's most distinguished families."},{"number":1,"category":"death","header":"Smallpox took the Northampton pastor at forty-seven","body":"He served as pastor of the Northampton MA Congregational Church from 1753 until smallpox killed him in February 1777 at forty-seven. His daughter Sarah Hooker married the Northampton lawyer Caleb Strong nine months later — passing the Hooker name into the family of a future Massachusetts Governor and U.S. Senator."}],"cross_connections":[{"type":"civic_connection","related_id":"H00379","display_label":"Edwards's daughter refused his pulpit and her chair sat in the vestibule.","link_text":"Mary Edwards Dwight"}],"education":[{"degrees":[{"degree":"B.A.","year":1751}],"notes":"Yale College class of 1751","degree":"B.A.","school_name":"Yale College","graduation_year":1751,"institution_id":"INST022"}],"bio":{"display_name":"Rev. John Hooker","title":"Reverend","first_name":"John","last_name":"Hooker","married_names":[]},"landmarks":[],"residence":{"city":"Northampton","state":"Massachusetts","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1751"}],"artworks":[],"quotes":[],"military_service":[],"slug":"john-hooker-1729"},"H00265":{"id":"H00265","has_descenda