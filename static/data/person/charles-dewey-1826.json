":"https://www.findagrave.com/memorial/117090576/julius_yemans-dewey"},{"label":"Vermont Historical Society — Dr. Julius Yemans Dewey portrait","url":"https://hub.catalogit.app/vermont-historical-society/folder/entry/dr.-julius-yemans-dewey"}],"research_sources":[],"notable":{"is_notable":true,"notable_category":["medicine","business","religion"],"notable_blurb":"Vermont physician; founded National Life Insurance","primary_url":"https://en.wikipedia.org/wiki/Julius_Yemans_Dewey","primary_url_label":"Wikipedia"},"narrative_blocks":[{"number":1,"category":"business","header":"Founded Vermont's largest life insurance company","body":"Julius founded the National Life Insurance Company at Montpelier in 1850 and served as its president until his death twenty-seven years later. He personally delivered the remittance for the company's first claim, prompting a public thank-you from the surviving family. NLI remains one of the ten oldest insurance companies in the United States."},{"number":2,"category":"family","header":"Married three Susans and one Mary Perrin","body":"After his Berlin sweetheart Mary Polly Perrin died in 1843 leaving four young children, Julius married twice more — both wives named Susan, neither bore him children. His third wife Susan Elizabeth Griggs Lilley had a daughter from a prior marriage who later married Julius's own son Edward — making Edward and his stepsister-in-law husband and wife."},{"number":3,"category":"character","header":"Backed his son's beating from Pangborn the teacher","body":"When eleven-year-old George Dewey led an attack on his Montpelier schoolteacher Z.K. Pangborn — and Pangborn flogged the boys into submission with a stick of stove fuel and walked the bruised George home to explain — Julius listened gravely, then thanked the teacher and asked him to repeat the punishment whenever necessary. George later credited the discipline with saving him from prison."}],"cross_connections":[],"naming_inspiration":[],"education":[{"school_name":"Washington County Grammar School","type":"secondary","notes":"Montpelier VT preparatory study."},{"school_name":"American Literary Scientific and Military Academy (Norwich Military School)","type":"military","notes":"Norwich Military School (later Norwich University) attended pre-medical."},{"school_name":"University of Vermont Medical Department","dates":"graduated 1824","type":"medical","notes":"M.D. class of 1824."}],"career":[{"role":"Physician (general practice)","organization":"Self / private practice","location":"Montpelier, Vermont","start_year":1824,"end_year":1851,"notes":"Practiced as 'most prominent practitioner and one of the leading citizens of the capital of Vermont' until founding NLI."},{"role":"Surgeon","organization":"First Regiment, Vermont State Militia","location":"Vermont"},{"role":"Founder and President","organization":"National Life Insurance Company","location":"Montpelier, Vermont","start_year":1850,"end_year":1877,"notes":"Founded 1850 (some sources 1848). Personally delivered the company's first claim remittance, prompting public thank-you from surviving family. Served as president until his death."},{"role":"Trustee","organization":"Norwich University","location":"Northfield, Vermont","end_year":1877},{"role":"Founder and parishioner","organization":"Christ Episcopal Church (Montpelier VT)","notes":"Documented founder of Christ Episcopal of Montpelier."}],"military_service":[],"institutions":[{"institution_id":"INST112","relationship":"founder","years":"1850-1877","institution_blurb":"Founder and president of the National Life Insurance Company of Montpelier — Vermont's largest life insurer."},{"institution_id":"INST113","relationship":"trustee","institution_blurb":"Trustee of Norwich University; previously attended its predecessor American Literary Scientific and Military Academy."}],"landmarks":[],"artworks":[{"artwork_id":"ART052","role":"subject","blurb":"Vermont Historical Society oil portrait c.1860, gift of Susan Howland estate."}],"documents":[],"quotes":[],"statues":[],"slug":"julius-dewey-1801"},"TD0138":{"id":"TD0138","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"display_name":"Mary Polly Perrin Dewey","first_name":"Mary","middle_name":"Polly","last_name":"Dewey","maiden_name":"Perrin","married_names":["Dewey"],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777670322/marydewey_uh1h5i.jpg","photo_notes":"Portrait. Cloudinary."},"birth":{"year":1799,"month":1,"day":30,"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"baptism":{},"death":{"year":1843,"month":9,"day":30,"city":"Montpelier","county":"Washington","state":"Vermont","country":"United States"},"residence":{"city":"Montpelier","county":"Washington","state":"Vermont","country":"United States"},"burial":{"cemetery_id":"CEM180","plot_notes":"Green Mount Cemetery, Montpelier VT — alongside Julius."},"gender":"female","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":7,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_id":"X01832","mother_id":"T01387"},"marriages":[{"marriage_number":1,"spouse_id":"X02373","date_year":1825,"date_month":6,"date_day":9,"location_city":"Berlin","location_state":"Vermont","location_country":"United States","end_type":"death_of_self","end_year":1843,"children_ids":["TD0139","TD0140","TD0141","TD0142"]}],"number_of_marriages":1,"tags":["replacement_naming"],"research_tags":[],"sources":[{"label":"FindAGrave — Mary Polly Perrin Dewey","url":"https://www.findagrave.com/memorial/117090641/mary_polly-dewey"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"character","header":"Burned the log cabin where she was born","body":"Per family lore, Mary Polly was 'ashamed of having been born in a log cabin' — she and a sister later went up one night and burned the original Perrin cabin to the ground. Her father Zachariah's permanent farm at Scott Hill in Berlin Vermont stood on the same land, but the dirt-floor structure of her birth was gone by her own hand."},{"number":2,"category":"family","header":"Mother of Manila Bay's Admiral, died at forty-four","body":"Mary Polly bore Admiral George Dewey on December 26, 1837 — her third child. He was five years old when she died at age 44 in September 1843 Montpelier Vermont. Her husband Julius later married twice more, but Mary Polly was the mother of all his children."}],"cross_connections":[],"naming_inspiration":[{"name_element":"Mary","description":"Named for her elder sister Mary Perrin (1781-1798), born Hebron CT, who died at age seventeen — four months before her parents named the second baby Mary in her memory. The second Mary was sometimes called Polly to distinguish from her dead namesake."}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"mary-dewey-1799"},"X01832":{"id":"X01832","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"is_talcott_spouse":true},"tags":["revolutionary_war","vermont_migration","town_founder"],"sources":[{"label":"WikiTree — Zachariah Perrin Esq.","url":"https://www.wikitree.com/wiki/Perrin-2144"},{"label":"Vermont Genealogy — Biography of Rev. James Hobart","url":"https://vermontgenealogy.com/washington/biography-of-rev-james-hobart.htm"}],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"T01387","date_year":1779,"location_city":"Hebron","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1828,"children_ids":["T01391","TD0120","T01393","T01394","T01395","T01396","TD0170","TD0138","T01399"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1748,"month":3,"day":18,"city":"Hebron","county":"Tolland","state":"Connecticut","country":"United States"},"death":{"year":1838,"month":5,"day":25,"city":"Berlin Corners","county":"Washington","state":"Vermont","country":"United States"},"cross_connections":[],"bio":{"display_name":"Zachariah Perrin Esq.","first_name":"Zachariah","last_name":"Perrin","married_names":[],"suffix":"Esq.","gender":"male"},"residence":{"city":"Berlin Corners","county":"Washington","state":"Vermont","country":"United States","note":"Settled May 1789 from Hebron CT; farmed 1300 acres at Scott Hill/East Road intersection in East Road School District."},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[{"landmark_id":"LM066","landmark_blurb":"Established the 1300-acre East Road farmstead and built permanent buildings here after settling Berlin VT in 1789."}],"artworks":[],"quotes":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","unit":"8th Company, 12th Regiment Connecticut Militia","notes":"Documented Revolutionary War service."}],"burial":{"cemetery_id":"CEM176","plot_notes":"Berlin Corner Cemetery, Berlin Corners VT."},"narrative_blocks":[{"number":1,"category":"character","header":"Settled Berlin Vermont with collapsed-roof cabin","body":"Zachariah served in the Revolutionary War with the 8th company of the 12th Connecticut militia, then in February-March 1789 led his family from Hebron Connecticut to Berlin Vermont — up the Connecticut River with two teams of oxen, switching from wheels to runners in Brookfield. They found the log cabin he had built the previous summer crushed under three or four feet of snow."},{"number":2,"category":"legacy","header":"Founded a 1300-acre farm still in family","body":"Zachariah's 1300 acres in the East Road School District of Berlin VT — at what became the southeast corner of East Road and Scott Hill Road — passed down through generations of Perrins. His son Porter, the first boy born in Berlin, built the house at Scott Hill and Airport Road in 1815 (still standing). A descendant Henry Perrin still lived in 'Perrin territory' along Scott Hill Road into the modern era."}],"slug":"zachariah-perrin-1748"},"T01387":{"id":"T01387","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":6,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1758,"month":6,"day":17,"city":"Glastonbury","state":"Connecticut"},"death":{"year":1828,"month":9,"day":11,"city":"Berlin Corners","county":"Washington","state":"Vermont"},"parents":{"father_id":"T01001","mother_id":"U00042"},"marriages":[{"children_ids":["T01391","TD0120","T01393","T01394","T01395","T01396","TD0170","TD0138","T01399"],"spouse_id":"X01832","marriage_number":1,"date_year":1779,"location_city":"Hebron","location_county":"Tolland","location_state":"Connecticut","location_country":"United States","end_type":"death_of_self","end_year":1828}],"sources":[{"label":"WikiTree — Mary (Talcott) Perrin","url":"https://www.wikitree.com/wiki/Talcott-49"},{"label":"Clark Univ — Mary Talcott rr23/rr23_395","url":"http://aleph0.clarku.edu/~djoyce/gen/report/rr23/rr23_395.html"}],"gender":"female","tags":["vermont_migration"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"parallel_migration","related_id":"HD0233","display_label":"Settled Vermont 1789 after cousin David Newton's 1777 migration","link_text":"David Newton"}],"bio":{"display_name":"Mary Talcott Perrin","first_name":"Mary","last_name":"Perrin","maiden_name":"Talcott","married_names":["Perrin"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[{"landmark_id":"LM066","landmark_blurb":"Lived on the Perrin family farmstead from her arrival in Berlin in 1789 until her death in 1828."}],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM176","plot_notes":"Berlin Corner Cemetery, Berlin Corners VT — alongside Zachariah."},"narrative_blocks":[{"number":1,"category":"family","header":"Walked to Vermont with two oxen teams","body":"In February or March 1789 Mary and Zachariah moved their family from Hebron Connecticut to Berlin Vermont — traveling up the Connecticut River with two teams of oxen, then up the White River, switching from wheels to runners at Brookfield, then over a blazed trail. They arrived to find their log cabin's roof had collapsed under three to four feet of snow."},{"number":2,"category":"family","header":"Lost firstborn daughter Mary in 1798","body":"Mary's eldest child — also named Mary, born in Hebron — died in 1798. Four months later another daughter was born and named Mary in her sister's memory. The second Mary later married Julius Yemans Dewey and was the mother of Admiral George Dewey, hero of Manila Bay 1898."}],"slug":"mary-perrin-1758"}},"burialCemetery":{"id":"CEM180","name":"Green Mount Cemetery","city":"Montpelier","county":"Washington","state":"Vermont","country":"United States","gps":"44.257843, -72.5944519","primary_url":"https://www.findagrave.com/cemetery/104036/green-mount-cemetery","hooker_connections":["TD0138","TD0139","TD0140","TD0143","TD0144","TD0145","TD0146","TD0147","TD0148","TD0149","X02373","X02374","X02375"],"notes":"Green Mount Cemetery, Montpelier Vermont — primary burial ground of the Vermont Dewey dynasty. Burial site of Dr. Julius Yemans Dewey (X02373, NLI founder) and his first wife Mary Polly Perrin Dewey (TD0138); their eldest son Charles Dewey (TD0139) and his wife Betsey Tarbox (X02374) and their seven children TD0143-TD0149; second son Edward Dewey (TD0140) and his wife Susan Griggs Lilley (X02375). Three generations of Deweys in a single cemetery. GPS Latitude 44.257843, Longitude -72.5944519."},"institutionsById":{"INST112":{"id":"INST112","primary_name":"National Life Insurance Company","name":"National Life Insurance Company","alt_names":["NLI / National Life Group"],"type":"insurance","founding_year":1850,"location":{"city":"Montpelier","county":"Washington","state":"Vermont","country":"United States"},"primary_url":"https://en.wikipedia.org/wiki/National_Life_Group","wikipedia_url":"https://en.wikipedia.org/wiki/National_Life_Group","primary_persons":[],"hooker_connected_people":["X02373","TD0139","TD0140","X02377"],"person_ids":[],"related_institutions":[],"related_landmarks":[],"tags":[],"sources":[],"notes":"Founded 1850 by Dr. Julius Yemans Dewey (X02373) at Montpelier Vermont. One of the ten oldest insurance companies in the United States. Julius personally delivered the company's first claim remittance. Multi-generation Dewey family enterprise: Julius founder/president to 1877; son Charles Dewey (TD0139) succeeded as president; son Edward Dewey (TD0140) was assistant secretary 1865-1877 then vice-president 1877-1897; son-in-law James Loren Martin (X02377, US District Judge for Vermont) served as director. Still active 21st century with 250,000+ policyholders, 3,500 brokers in all 50 states; one of Montpelier's largest private employers."}},"crossConnections":[]}