in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["finance"],"notable_blurb":"steadying figure in Philadelphia banking"},"parents":{"father_id":"H02745","mother_id":"X00162"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01090","date_year":1882,"date_month":4,"date_day":14,"location_city":"Alexandria","location_county":"Alexandria","location_state":"Virginia","location_country":"United States","end_type":"death_of_spouse","end_year":1915,"children_ids":["H05230","H05231"]}],"education":[{"school_name":"Rugby Academy","notes":"Preparatory school in Philadelphia."},{"school_name":"University of Pennsylvania","institution_id":"INST143","degree_or_field":"B.S.","class_year":1880,"notes":"B.S. at age 20."}],"career":[{"role":"Secretary-Treasurer","organization":"Philadelphia Warehouse Company","location":"Philadelphia, PA","start_year":1880,"end_year":1884},{"role":"Treasurer","organization":"Washington Manufacturing Company","location":"Philadelphia, PA","start_year":1884,"end_year":1892},{"role":"Auditor then Treasurer then President then Chairman","organization":"Pennsylvania Company for Insurance on Lives and Granting Annuities","location":"Philadelphia, PA","start_year":1892,"end_year":1937,"notes":"Joined as auditor 1892; treasurer 1893; president 1899-1934 (35 years); chairman of board after 1934. Succeeded as president by C. Stevenson Newhall."}],"military_service":[],"institutions":[{"institution_id":"INST143","relationship":"alumnus"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["banker","finance","author"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Presided over Pennsylvania Company for 35 years","body":"From 1899 to 1934 he directed the destinies of the Pennsylvania Company for Insurance on Lives and Granting Annuities, keeping it in the front rank of Philadelphia banks. After resigning the presidency in 1934 he was made chairman of the board, holding twenty-plus directorships and trusteeships across the transportation, insurance, and banking fields."},{"number":2,"category":"career","header":"Saved depositors via tottering-bank mergers","body":"As an astute and conservative banker, he was a steadying influence in the Philadelphia financial world during difficult years. He was credited with saving the depositors of more than one tottering bank by merging their institutions with his own."},{"number":3,"category":"education","header":"UPenn B.S. at age twenty, 1880","body":"After Rugby Academy he graduated from the University of Pennsylvania in 1880 at the age of twenty with a Bachelor of Science. He later served the University as a trustee for eight years and as treasurer of the University Athletic Association."},{"number":4,"category":"civic","header":"Quiet philanthropist, Episcopal Hospital trustee","body":"His philanthropies were many but seldom publicized; for many years until his death he was a trustee of Episcopal Hospital and of a fund for widows of Episcopal clergymen. He belonged to the Philadelphia, Racquet, St. Anthony's, and Rittenhouse Clubs, and the Philadelphia Country Club."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"charles-packard-1860"},"I01090":{"id":"I01090","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Eliza","middle_name":"Gilpin","last_name":"Packard","maiden_name":"McLean","married_names":["Packard"],"gender":"female","display_name":"Eliza Gilpin McLean Packard"},"birth":{"year":1860,"month":2,"day":18,"city":"Alexandria","county":"Alexandria","state":"Virginia","country":"United States"},"baptism":{},"death":{"year":1915,"month":7,"day":5,"city":"Lower Gwynedd Township","county":"Montgomery","state":"Pennsylvania","country":"United States"},"burial":{"cemetery_id":"CEM532","plot_notes":