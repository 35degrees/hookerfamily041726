r_of_marriages":1,"notable":{"is_notable":true,"notable_category":["medicine"],"notable_blurb":"pioneer of modern American surgery","primary_url":"https://www.medicalantiques.com/civilwar/Medical_Authors_Faculty/Packard_John_H..htm","primary_url_label":"Dr. Echols & Dr. Arbittier — John H. Packard, M.D."},"cross_connections":[],"bio":{"display_name":"Dr. John Hooker Packard","first_name":"John","last_name":"Packard","middle_name":"Hooker","title":"Doctor","married_names":[],"gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779146282/johnhookerpackard_kbbw52.jpg","photo_notes":"Portrait photograph reproduced in Anesthesiology journal, Nov 2001 (Defalque, Panning, Wright)."},"residence":{"city":"Philadelphia","county":"Philadelphia","state":"Pennsylvania","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST143","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["HD0621"],"burial":{"cemetery_id":"CEM529","plot_notes":"Old Saint David's Church Cemetery, Wayne, Delaware County, PA"},"education":[{"school_name":"University of Pennsylvania","institution_id":"INST143","degree_or_field":"A.B. 1850; M.D. 1853","class_year":1853,"notes":"A.B. 1850, M.D. 1853. Resident physician at Philadelphia's University Hospital for 18 months after graduation; then 1.5 years visiting the great Paris hospitals before returning to Philadelphia practice."}],"career":[{"role":"Surgeon","organization":"Christian Street U.S. Army Hospital","location":"Philadelphia, PA","start_year":1862,"end_year":1865,"notes":"Acting assistant surgeon at Christian Street and Satterlee Union Army hospitals during the Civil War."},{"role":"Consulting surgeon","organization":"U.S. Army hospitals at Beverly NJ and Haddington PA","location":"PA / NJ","start_year":1862,"end_year":1865},{"role":"Surgeon","organization":"Episcopal Hospital","location":"Philadelphia, PA","start_year":1863,"end_year":1884},{"role":"Surgeon","organization":"Pennsylvania Hospital","location":"Philadelphia, PA","start_year":1884,"end_year":1896,"notes":"Surgeon to Pennsylvania Hospital from 1884 until his 1896 retirement following septicemia from a finger infection caught during surgery."},{"role":"Secretary then Vice President","organization":"College of Physicians of Philadelphia","location":"Philadelphia, PA","start_year":1862,"end_year":1896,"notes":"Secretary 1862-1877; Vice President from 1886."}],"narrative_blocks":[{"number":1,"category":"innovation","header":"Switched American surgeons from chloroform to ether","body":"In May 1865 he reported to the Philadelphia College of Physicians that after witnessing fatal chloroform accidents in his own and his colleagues' practices, he was switching to ether. Following his friend F. D."},{"number":2,"category":"publication","header":"Manual of Minor Surgery adopted by US Army","body":"His 1863 Manual of Minor Surgery — a working guide to bandaging, pain control, and field operations — was adopted by the United States Army and became one of the most reprinted surgical handbooks of the Civil War era. The Handbook of Operative Surgery followed in 1870."},{"number":3,"category":"war","header":"Civil War surgeon at Christian Street and Satterlee","body":"He served as acting assistant surgeon at Philadelphia's Christian Street and Satterlee U.S. Army hospitals throughout the Civil War. One soldier whose arm Packard rebuilt — Martin V.B. Keller — wrote afterward that the surgeon was 'very proud of the operation' and had photographs taken of the recovered arm."},{"number":4,"category":"death","header":"Septic finger ended career, 1896 retirement","body":"A finger infection caught during surgery in 1896 led to septicemia and forced his retirement at sixty-four after forty-three years of practice. He died of cardiorenal failure at the Hotel Chalfont in Atlantic City on 21 May 1907 and was buried at Old Saint David's Church Cemetery in Wayne, PA."},{"number":5,"category":"publication","header":"Sea-Air therapy book established resort medicine","body":"His 1880 book Sea-Air and Sea-Bathing was among the first American medical works to argue systematically that coastal air and bathing could benefit specific patient categories. The treatise helped establish the Atlantic City and Cape May resort culture that would shape East Coast medicine for a generation."}],"slug":"john-packard-1832"},"X00162":{"id":"X00162","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1835,"month":5,"day":2,"city":"Philadelphia","county":"Philadelphia","state":"Pennsylvania","country":"United States"},"death":{"year":1897,"month":3,"day":11,"city":"Devon","county":"Chester","state":"Pennsylvania","country":"United States"},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H02745","date_year":1858,"date_month":6,"date_day":3,"end_type":"death_of_self","end_year":1897,"children_ids":["H04333","H04334","H04335","H04336","H04337","H04338"]}],"parents":{"father_name":"Charles Stuart Wood of Philadelphia (Quaker)","mother_name":"Juliana Fitz Randolph Wood (Quaker)"},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Wood Packard","first_name":"Elizabeth","maiden_name":"Wood","married_names":["Packard"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elizabeth-wood-1835"}},"burialCemetery":{"id":"CEM533","former_ids":[],"primary_name":"Saint Thomas Episcopal Church Cemetery","city":"White