haracter","header":"He dared to call Rev. Davenport a liar","body":"In January 1646, Luke Atkinson was charged with defaming Rev. John Davenport — alleging Davenport had said things he later denied, and that his name had been \"darkned.\" After extensive testimony, Atkinson acknowledged \"he had sinned and slandered Mr. Davenport,\" and was fined forty pounds. He had told witnesses beforehand: \"I expected it.\""},{"number":2,"category":"career","header":"A Puritan emigrant who signed the New Haven","body":"He likely came to New Haven around 1640 aboard the St. John of London, one of 250 passengers licensed by Stephen Goodyear. He signed the fundamental agreement of New Haven colony after the initial 1639 signing, then removed to Middletown, Connecticut in 1656 — dying there before January 1667."}],"quotes":[],"sources":[{"label":"Colony Records of New Haven, January 5, 1646 — Atkinson defamation case"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"documents":[],"artworks":[],"military_service":[],"slug":"luke-atkinson-1633"},"X02114":{"id":"X02114","is_placeholder":false,"has_descendants_documented":false,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":true},"bio":{"first_name":"Mary","last_name":"Atkinson","maiden_name":"Platt","married_names":["Atkinson"],"gender":"female","display_name":"Mary Platt Atkinson"},"birth":{"year":1629,"month":11,"day":11,"city":"Roydon","county":"Essex","country":"England"},"baptism":{"year":1629,"month":11,"day":11,"city":"Roydon","county":"Essex","country":"England"},"death":{"year":1669,"month":6,"day":17,"city":"Middletown","county":"Middlesex","state":"Connecticut","country":"United States"},"residence":{"city":"Middletown","county":"Middlesex","state":"Connecticut","country":"United States"},"burial":{},"parents":{"father_id":"X00098","father_name":"Deacon Richard Platt","mother_id":"X00099","mother_name":"Mary Wood Platt"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02113","date_year":1651,"date_month":5,"date_day":1,"location_city":"Milford","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","officiant":"Captain Ashwood","end_type":"death","end_year":1669,"children_ids":["X00024"]}],"institutions":[],"landmarks":[],"naming_inspiration":[],"tags":["great_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"documents":[],"artworks":[],"military_service":[],"slug":"mary-platt-1629"},"X00098":{"id":"X00098","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"birth":{"year":1603,"month":9,"day":28,"city":"Ware","county":"Hertfordshire","country":"England"},"death":{"year":1684,"country":"United States","cause":"Died Milford shortly before Feb 13, 1684/5, when inventory of estate taken. Burial place unknown — probably in his orchard."},"burial":{"cemetery_id":"CEM005","plot_notes":"Cenotaph at Milford Cemetery commemorates him. Actual burial place unknown; probably in his orchard per family tradition."},"parents":{"mother_research_notes":"Mary (maiden name unknown), wife of George Platt","father_research_notes":"George Platt of Ware (bpt May 13, 1582; d. Apr 20, 1609) — tailor"},"marriages":[{"spouse_id":"X00099","children_ids":["X00076","X00100","X02114"],"marriage_number":1,"date_year":1629,"date_month":1,"date_day":26,"location_city":"Roydon","location_county":"Essex","location_country":"England"}],"migration":{"departure":"England 1637-1638 — sailed with Rev. Peter Prudden's Hertfordshire company","arrived":"New Haven 1638, Milford 1639","notes":"Sold his lands and houses at Ware by final concord at Westminster Apr 25, 1638. Was among the 66 men who formed themselves into a church society at New Haven under Rev. Peter Prudden Aug 22, 1639, which group then settled Milford. Enrolled among first settlers of Milford Nov 20, 1639, with four in his family. Home lot #38: 4 acres 1 rod near present West Main and Cherry Streets, Milford."},"church_roles":[{"role":"Deacon","church":"First Church","location":"Milford, Connecticut","dates":"1669","notes":"Chosen deacon 1669. Witnessed the will of Rev. Peter Prudden."}],"tags":["deacon","great_migration","milford_founder"],"cross_connections":[{"type":"civic_peer","related_id":"X00095","display_label":"Both came from Hertfordshire; both among Milford's Seven Pillars.","link_text":"William Fowler"},{"type":"civic_peer","related_id":"X00090","display_label":"Adjoining home lots in the Hertfordshire Quarter, New Haven.","link_text":"William Pantry"},{"type":"civic_peer","related_id":"H00001","display_label":"led the Cambridge circle Platt neighbored in Hertfordshire","link_text":"Rev. Thomas Hooker"}],"sources":[{"short":"Families of Early Milford","notes":"Full biography and children listed"}],"notable_persons":[{"name":"Ben Affleck","description":"Actor and director (Good Will Hunting, Batman v Superman, Gone Girl). Descended from Richard Platt through a daughter who married and lost the Platt surname — six generations documented on PBS Finding Your Roots (Season 3, October 2016), hosted by Henry Louis Gates Jr.","connection":"Descendant — 9th or 10th great-grandson approximately","source":"PBS Finding Your Roots Season 3; confirmed by Milford genealogist Richard Platt and Alvin Platt's 2003 Special Compilation of the History and Genealogy of Richard Platt","notes":"Gates presented Affleck with six generations of Platt charts on air. The Milford Richard Platt Society confirmed the identification matches their documented records."}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["religion"],"notable_blurb":"Milford founding settler, 1639; Deacon 1669","primary_url":"https://websites.umich.edu/~bobwolfe/gen/mn/m2165x2166.htm","primary_url_label":"Platt Family Genealogy (U-Michigan)"},"narrative_blocks":[{"number":1,"category":"career","header":"He left a Bible to each","body":"When Deacon Richard Platt made his will in 1683, he bequeathed a Bible to each of his nineteen grandchildren — a gesture that, as one historian noted, \"betrays a profound interest in the best things in life\" in rough pioneer days. His estate was valued at approximately £600 sterling."},{"number":2,"category":"religion","header":"From Rev. Chauncey's congregation in Ware to founding","body":"Richard Platt grew up in Ware, Hertfordshire — a hotbed of Puritanism where the famous Rev. Charles Chauncey (later president of Harvard) preached from 1627 to 1633. Deeply influenced by Chauncey's teaching, he came to New England in 1638 with Rev. Peter Prudden's Hertfordshire company, and became one of 66 founding members of the Milford church on August 22, 1639."},{"number":3,"category":"legacy","header":"His name is on Milford's Founder's Bridge","body":"The Platt stone on the Wepawaug Memorial Bridge in Milford reads: \"Deacon Richard Platt, Obit 1684 — Mary His Wife.\" He was chosen Deacon of First Church Milford in 1669, witnessed the will of Rev. Peter Prudden, and appears as a witness in the colony records. He is buried in his orchard at lot #38, West Main and Cherry Streets, Milford."},{"number":4,"category":"family","header":"Nine children — their descendants married throughout","body":"His nine children — Mary, John, Isaac, Samuel, Sarah, Epenetus, Hannah, Josiah, and Joseph — spread through the families of Milford and surrounding towns. Daughter Mary married Luke Atkinson; daughter Sarah married Thomas Beach then Miles Merwin; son Joseph married Mary Kellogg. Their descendants appear as spouses throughout the Newton-Hooker family network across three generations."},{"number":5,"category":"legacy","header":"He left his entire estate to son Joseph","body":"His will left Joseph Platt the entirety of his estate: \"I give my son Joseph Platt all the remainder of my estate... I make my son Joseph Platt my executor.\" The family had emigrated from Hertfordshire, England in 1639, helping found New Haven and Milford. Joseph was the first Platt child born in America."}],"baptism":{"year":1604,"month":5,"day":6,"city":"Ware","county":"Hertfordshire","country":"England"},"bio":{"title":"Deacon","display_name":"Deacon Richard Platt","first_name":"Richard","last_name":"Platt","married_names":[]},"residence":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"richard-platt-1603"},"X00099":{"id":"X00099","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1604,"month":11,"day":10,"city":"Roydon","county":"Essex","country":"England"},"death":{"year":1676,"month":3,"day":24,"city":"Milford","state":"Connecticut","country":"United States","cause":"Buried Milford March 24, 1675/6. Admitted to Milford church Aug 15, 1641."},"marriages":[{"spouse_id":"X00098","children_ids":["X00076","X00100","X02114"],"marriage_number":1}],"sources":[{"short":"Families of Early Milford"}],"gender":"female","tags":[],"number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Wood Platt","first_name":"Mary","last_name":"Platt","married_names":["Platt"],"maiden_name":"Wood"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-wood-1604"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}