t."},{"number":3,"category":"military","header":"The Sergeant title — but which war?","body":"He is styled Sergt. in Milford records throughout his life. Born in 1660, he was 15 during King Philips War (1675-76) — possible but young; he was 29-37 during King Williams War (1689-97), the more likely conflict. The specific service remains unconfirmed in surviving records."}],"cross_connections":[{"type":"family_connection","related_id":"H00042","display_label":"Married my daughter Mary; his cousin married my daughter Susanna","link_text":"Thomas Newton"},{"type":"family_connection","related_id":"H00054","display_label":"Both Hooker-line grandsons married his daughters","link_text":"John Burwell"}],"military_service":[{"war":"King Williams War (probable) or King Philips War (possible)","rank":"Sergeant","side":"Colonial","battles":[]}],"bio":{"title":"Sergeant","display_name":"Sgt. Zachariah Baldwin","first_name":"Zachariah","last_name":"Baldwin","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"slug":"zachariah-baldwin-1660"},"I00022":{"id":"I00022","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1678,"city":"Milford","state":"Connecticut"},"death":{"year":1744,"month":3,"day":29,"city":"Milford","state":"Connecticut"},"parents":{"father_id":"X00019","mother_id":"X00024"},"marriages":[{"spouse_id":"H00042","children_ids":["HD0034","H00135","H00136","H00137","H00138","H00139","H00140"],"marriage_number":1,"date_year":1704,"date_month":6,"date_day":20}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 42"},{"short":"Families of Early Milford"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connec