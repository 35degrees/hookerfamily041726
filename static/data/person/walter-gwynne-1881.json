id":"I01303"},"tags":[],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"I01305","date_year":1910,"date_month":4,"date_day":28,"end_type":"divorce","children_ids":[]},{"marriage_number":2,"spouse_id":"I01306","date_year":1928,"date_month":6,"date_day":28,"end_type":"death_of_spouse","end_year":1955,"children_ids":["HD5136"]}],"number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1891,"month":3,"day":11,"city":"Flushing","state":"New York","country":"United States"},"death":{"year":1970,"month":4,"day":13,"city":"Palm Beach","state":"Florida","country":"United States","age":79},"residence":{},"burial":{"plot_notes":"Gwynne family plot, Fair Mount Cemetery Chatham NJ (cremated remains)"},"baptism":{},"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Second husband Walter Gwynne uncle of actor","body":"Anita's second husband Walter Lee Gwynne (1881-1955), the New York stockbroker she married in 1928, was the uncle of actor Fred Gwynne (1926-1989) — Herman Munster on The Munsters and Judge Chamberlain Haller in My Cousin Vinny. The Gwynne family connection brought twentieth-century popular culture into the Ingersoll-Bristol-Hooker line. Walter and Anita lived in New York and Bermuda before moving to Delray Beach Florida."},{"number":2,"category":"family","header":"Twice-married after 1910 Minton divorce, NY society","body":"Anita first married Roger Medina Minton of New York on April 28, 1910 at age nineteen — they had one daughter Anita Minton before divorcing. After her divorce she moved to Santa Barbara California briefly before her 1928 second marriage to Walter Gwynne. The two-marriage pattern was unusual for early twentieth-century Ingersoll family women, and her cremated remains were ultimately buried in the Gwynne family plot at Fair Mount Cemetery Chatham New Jersey."},{"number":3,"category":"family","header":"Flushing Queens 1891 to Palm Beach 1970","body":"Anita Ingersoll was born March 11, 1891 in Flushing Queens New York and died April 13, 1970 in Palm Beach Florida at age seventy-nine. She was the daughter of Judge Charles Dennis Ingersoll (NYC lawyer-judge) and Katharine Corse Sanders Varnum Ingersoll. Her brothers and sister Hamilton, Justine continued the New York/Connecticut Ingersoll legal-and-professional traditions."}],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Anita Gwynne","first_name":"Anita","last_name":"Gwynne","maiden_name":"Ingersoll","married_names":["Minton","Gwynne"],"gender":"female","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779825011/anitagwynee_cijrgp.jpg"},"slug":"anita-gwynne-1891"},"HD5136":{"id":"HD5136","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":1,"descent_from_thomas_hooker_bool":true},"parents":{"father_id":"I01306","mother_id":"HD5133"},"tags":[],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"I01309","date_year":1948,"end_type":"death_of_spouse","end_year":2011,"children_ids":[]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1927,"month":5,"day":13,"city":"New York","county":"New York","state":"New York","country":"United States"},"death":{"year":2014,"month":9,"day":7,"city":"Portland","county":"Multnomah County","state":"Oregon","country":"United States","age":87},"residence":{},"burial":{"plot_notes":"River View Cemetery, Portland OR"},"baptism":{},"cross_connecti