e":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["replacement_naming","westward_migration"],"research_tags":[],"cross_connections":[{"type":"family_connection","related_id":"H00439","display_label":"Pioneered California while her grandfather served the Revolution.","link_text":"Ezekiel Cowles Jr."},{"type":"civic_connection","related_id":"HD3720","display_label":"Distant Hooker cousins, both touched by the Civil War.","link_text":"Sgt-Maj Giles Hooker Cowles"}],"narrative_blocks":[{"number":1,"category":"family","header":"Belleville Illinois to Ensenada Baja California","body":"Cornelia was born in Belleville Illinois in 1829, where her father Alfred practiced law. Her family migrated to California in 1853, and she married Mexican-War-era medical officer Erasmus Darwin French in San Jose January 1858. By 1894 the couple resided in Ensenada Baja California Mexico — three thousand miles from her father's Connecticut birthplace."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909 — entry #1139 Alfred Cowles"},{"short":"Cowles book #1695"}],"research_sources":[],"documents":[],"slug":"cornelia-french-1829"},"HD3692":{"id":"HD3692","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Elizabeth","middle_name":"Gleason","last_name":"Leavitt","maiden_name":"Cowles","married_names":["Leavitt"],"gender":"female","display_name":"Elizabeth Gleason Cowles Leavitt"},"birth":{"year":1833,"month":3,"day":15,"city":"Belleville","county":"St. Clair","state":"Illinois","country":"United States"},"baptism":{},"death":{"year":1885,"month":10,"day":16,"country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H01139","mother_id":"I00384"},"number_of_marriages":1,"marriages":[],"education":[{"institution":"Willoughby Female Seminary","notes":"Educated at Willoughby Female Seminary, Lake County Ohio."}],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Gleason","description":"Middle name 'Gleason' for her maternal grandmother Polly Gleason Cowles."}],"artworks":[],"tags":["westward_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"education","header":"Willoughby Seminary then a Nevada City marriage","body":"Elizabeth was born 1833 in Belleville Illinois and educated at Willoughby Female Seminary in Lake County Ohio (the same school as her elder sister Cornelia). She married enterprising Nevada City California merchant Charles Carroll Leavitt at her parents' San Jose home; the family later settled in Oakland while Leavitt served in the San Francisco Custom House for many years."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909 — entry #1139 Alfred Cowles"},{"short":"Cowles book #1696"}],"research_sources":[],"documents":[],"slug":"elizabeth-leavitt-1833"},"HD3693":{"id":"HD3693","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Alfred","middle_name":"Ezekiel","last_name":"Cowles","married_names":[],"gender":"male","display_name":"Alfred Ezekiel Cowles"},"birth":{"year":1835,"country":"United States"},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H01139","mother_id":"I00384"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Alfred Ezekiel","inspired_by_id":"H00439","description":"Named for both father (Alfred Cowles H01139) and paternal grandfather (Ezekiel Cowles Jr. H00439)."}],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"short":"Edward Hooker 1909 — entry #1139 Alfred Cowles"}],"research_sources":[],"documents":[],"slug":"alfred-cowles-1835"},"H00439":{"id":"H00439","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1757,"month":9,"day":14,"city":"Farmington","state":"Connecticut"},"parents":{"father_id":"I00156","mother_id":"H00232"},"tags":["politician","not_yet_fully_entered","revolutionary_war"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 439"},{"short":"Edward Hooker 1909 — entry #439 Ezekiel Cowles Jr."},{"short":"Cowles Families in America #303","url":"https://archive.org/details/genealogyofcowle00cowl"},{"short":"Native Northeast Portal — Cowles, Ezekiel, Jr. (1757-1850)","url":"https://www.nativenortheastportal.com/bio/bibliography/cowles-ezekiel-jr-1804"},{"short":"Library of Congress, Washington Papers, Correspondence with the Officers, Vol. 3 Page 2122 (May 20, 1782 Parsons letter)"}],"death":{"year":1850,"month":8,"day":14,"city":"Farmington","state":"Connecticut"},"marriages":[{"spouse_id":"X00268","children_ids":["H01138","H01139","H01140","HD0984"],"marriage_number":1,"date_year":1784,"date_month":6}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["politician","military","social_reform"],"notable_blurb":"Revolutionary War soldier and sergeant-major","primary_url":"https://www.nativenortheastportal.com/bio/bibliography/cowles-ezekiel-jr-1804","primary_url_label":"Native Northeast Portal — Cowles, Ezekiel, Jr."},"cross_connections":[{"type":"family_connection","related_id":"X00263","display_label":"Both Tunxis-related officials in early 1800s Farmington.","link_text":"Lt. John Mix"},{"type":"family_connection","related_id":"HD3691","display_label":"Revolutionary grandfather; she pioneered California through her marriage.","link_text":"Cornelia Cowles French"},{"type":"family_connection","related_id":"H00030","display_label":"Both Hooker descendants involved with Tunxis affairs, 1738 and 1804.","link_text":"Hon. John Hooker"}],"military_service":[{"war":"American Revolutionary War","rank":"Private → Sergeant-Major","notes":"Battle of Long Island Jul 1776; Saratoga and SURRENDER OF BURGOYNE Oct 17, 1777; under Col. Noadiah Hooker 1779; Sergeant-Major 1779; clerk to Lt.-Col. Austin 1781. Maj.-Gen. Parsons recommended him to Washington for commission, May 20, 1782 (Library of Congress, Washington Papers, Vol.3, p.2122). Pensioned 1832.","war_id":"WAR004"},{"branch":"Continental Army / Connecticut Militia","rank":"Private and Sergeant-Major","dates":"1776-1781","unit":"Various — see notes","notes":"Revolutionary War service per pension application: July 1776 under Capt. John Porter to NY (in Battle of Long Island, retreated to Harlem Plains and over King's Bridge to White Plains; regiment disbanded Sept 28, 1776); 1777 under Capt. Ichabod Norton (attacked fort at Kingsbridge, defeated, discharged); September 1777 joined Capt. Ichabod Norton commanding regt. of 4 cos. 15th Conn. Militia, proceeded to Saratoga, present at the decisive action of Oct 7 and at the surrender of Burgoyne Oct 17, 1777; 1779 under Capt. Elisha Scott Col. Noadiah Hooker to New Haven; served as Sergeant-Major under Major Ichabod Norton; September 1781 drafted for three-week tour to New Haven in Lt-Col. Aaron Austin's regt., taken into Col. Austin's family as clerk/secretary. Pensioned under Act of June 7, 1832 commencing March 4, 1831, paid to death August 4, 1850."}],"bio":{"display_name":"Ezekiel Cowles Jr.","first_name":"Ezekiel","last_name":"Cowles","suffix":"Jr.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[{"document_id":"DOC018","document_blurb":"1804 Connecticut General Assembly Resolve appointing Ezekiel Cowles Jr. as Overseer of the Farmington Tunxis Indians (replacing Capt. John Porter)."}],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"career":[{"title":"Collector of State Taxes","organization":"State of Connecticut","dates":"1794-1796, 1798","type":"government"},{"title":"Deputy Sheriff","organization":"Hartford County CT","dates":"1802-1814","type":"government"},{"title":"Member, Connecticut State Legislature","organization":"Connecticut General Assembly","dates":"1807-1810","type":"politics","notes":"Represented Farmington in the State Legislature."},{"title":"Justice of the Peace","organization":"Town of Farmington CT","dates":"1809-1818","type":"government"},{"title":"Overseer of the Tunxis Indians","organization":"Connecticut General Assembly","dates":"1804-?","type":"government","notes":"Appointed by the Connecticut Legislature in 1804 as overseer and advisor of the Tunxis (Farmington Indians), replacing Capt. John Porter (under whom Ezekiel had served in 1776). The position made him one of a series of state-appointed Anglo-American managers of what remained of the Tunxis people's affairs and lands during a period of dispossession."},{"title":"Farmer","type":"agriculture","notes":"Farmer at Farmington Connecticut throughout adult life."}],"narrative_blocks":[{"number":1,"category":"military","header":"Recommended to Washington for a commission","body":"On May 20, 1782 Maj.-Gen. Samuel Holden Parsons wrote to General Washington recommending Sergeant-Major Ezekiel Cowles for a subaltern commission. Ezekiel had been at Long Island, Harlem Plains, and the surrender of Burgoyne; the war ended before the commission could be granted. The Parsons letter is preserved at the Library of Congress."},{"number":2,"category":"law","header":"Appointed overseer of the Tunxis in 1804","body":"In 1804 the Connecticut General Assembly appointed Ezekiel Cowles Jr. overseer and advisor of the Tunxis Indians at Farmington, replacing Capt. John Porter — under whom Ezekiel had marched to the Battle of Long Island in 1776. The role placed him in the same Tunxis-management chain as Justice John Mix, who signed the 1802 Sue Squa land deed and the 1816 Titus emancipation."},{"number":3,"category":"politics","header":"Four overlapping offices across twenty-five years","body":"Ezekiel filled four overlapping public offices across twenty-five years in Farmington: State Tax Collector (1794-1798), Deputy Sheriff (1802-1814), State Legislator (1807-1810), and Justice of the Peace (1809-1818). His 1850 estate inventoried at $6,549.12 — a substantial farmer's wealth in mid-century Connecticut."}],"slug":"ezekiel-cowles-jr-1757"},"X00268":{"id":"X00268","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"Cowles Family Genealogy"},{"bib_id":"BIB003"}],"birth":{"year":1759,"month":5,"day":29,"city":"East Farms Parish","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1834,"month":10,"day":4,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"gender":"female","parents":{"father_name":"Samuel Woodruff","mother_name":"Elizabeth Norton Woodruff","father_research_notes":"Samuel Woodruff of Farmington CT (Ensign Samuel³, Matthew², Matthew¹) per Cowles book #303. Not built per Jalapeño.","mother_research_notes":"Elizabeth Norton Woodruff of Farmington CT. Not built per Jalapeño."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00439","date_year":1784,"date_month":6,"location_country":"United States","end_type":"death","end_year":1834,"children_ids":["H01138","H01139","H01140","HD0984"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Rachel Woodruff Cowles","first_name":"Rachel","last_name":"Cowles","maiden_name":"Woodruff","married_names":["Cowles"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"rachel-woodruff-1759"},"I00156":{"id":"I00156","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1721,"month":11,"day":4,"city":"Farmington","state":"Connecticut"},"death":{"year":1806,"month":9,"day":23,"city":"Farmington","state":"Connecticut"},"parents":{"father_id":"X00261","mother_id":"X00262"},"marriages":[{"spouse_id":"H00232","children_ids":["H00436","H00437","H00438","H00439","H00440","H00441","H00442","H00443","H00444","H00445","H00446","X00262"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 232"},{"short":"Genealogy of the Cowles family in America (Cowles, 1929)","url":"https://archive.org/stream/genealogyofcowle00cowl/genealogyofcowle00cowl_djvu.txt"},{"short":"Memorial History of Hartford County, Connecticut (Trumbull ed., 1886) — Unionville chapter by James L. Cowles","url":"https://archive.org/details/memorialhistoryo02trum_0/page/n253/mode/2up"}],"gender":"male","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Ezekiel Co