:[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Seven documented children with Thankful Asenath Perkins","body":"Eli Tuttle and his wife Thankful Asenath Perkins Tuttle had seven documented children between 1807 and the late 1820s. Five of the seven were Lucius (1807-1885 who stayed in Hamden), Leonard (1810-1875 Ohio migration), Lauren (1815-1860 two wives), Mehitable Tuttle Cooper (1819-1868 two husbands), and Lucy (died 1827). Two more — Louisa and Asahel — died young."},{"number":2,"category":"death","header":"Daughter Louisa died as an infant in 1822","body":"Eli and Thankful's daughter Louisa Tuttle was born in 1821 and died in 1822 — an infant death within her first year. The early death was one of three children Eli outlived: Louisa as infant; Lucy who died in 1827 as a young child; and Asahel by 1850 in his adulthood. The cumulative loss across both childhood and adult-child mortality was typical of nineteenth-century rural Connecticut family experience."},{"number":3,"category":"family","header":"Born and died in Hamden, Connecticut","body":"Eli Tuttle was born December 28, 1781 in Hamden, New Haven County Connecticut, son of Jotham Tuttle and Kezia Munson Tuttle. He died April 21, 1844 in Hamden at age sixty-two and is buried at Mount Carmel Burying Ground, Hamden. The lifelong-Hamden residence pattern was common among the Tuttle-Munson cluster of north New Haven County families."}],"burial":{"cemetery_id":"CEM312","plot_notes":"Mount Carmel Burying Ground, Hamden CT — alongside his mother Kezia Munson Tuttle"},"slug":"eli-tuttle-1781"},"HD4125":{"id":"HD4125","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Lucius","last_name":"Tuttle","married_names":[],"gender":"male","display_name":"Lucius Tuttle"},"birth":{"year":1807,"month":12,"day":7,"city":"Hamden","county":"New Haven County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1885,"month":1,"day":8,"city":"Hamden","county":"New Haven County","state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM312","plot_notes":"Mount Carmel Burying Ground, Hamden — same cemetery as father Eli, grandmother Kezia, and sister Lucy."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD3142","father_name":"Eli Tuttle","mother_id":"I00603","mother_name":"Thankful Asenath Perkins Tuttle"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"place","header":"Lived all seventy-seven years in Hamden CT","body":"Lucius Tuttle was born in Hamden in 1807 and died there in 1885 age 77 — unlike his Ohio-bound brother Leonard or far-traveling nephew Jonathan, he never left the New Haven County town where his grandmother Kezia and father Eli were also buried. All three rest at Mount Carmel Burying Ground."}],"quotes":[],"sources":[{"label":"FindAGrave #11269591","url":"https://www.findagrave.com/memorial/11269591/lucius-tuttle"}],"research_sources":[],"documents":[],"slug":"lucius-tuttle-1807"},"HD4126":{"id":"HD4126","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Leonard","last_name":"Tuttle","married_names":[],"gender":"male","display_name":"Leonard Tuttle"},"birth":{"year":1810,"month":9,"day":30,"city":"Hamden","county":"New Haven County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1875,"city":"Lodi","county":"Medina County