Connecticut","country":"United States"},"death":{"year":1814,"month":3,"day":19,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00478","date_year":1776,"date_month":6,"date_day":8,"location_city":"Norwalk","location_county":"Fairfield County","location_state":"Connecticut","location_country":"United States","end_type":"death_of_self","end_year":1814,"children_ids":["H01229","H01230","H01231","H01232","H01233","H01234","H01235"]}],"parents":{"father_name":"Deacon Peter Lockwood","mother_name":"Abigail (Hawley) Lockwood","father_research_notes":"Per Lockwood genealogy + EH. Wikipedia says mother was 'Mary Hawley' — discrepancy with Lockwood genealogy 'Abigail (Hawley) Lockwood.' Using genealogy/EH as higher-priority source."},"notable":{"is_notable":true,"notable_category":["politics","military"],"notable_blurb":"Nine-term Connecticut legislator; Revolutionary War captain","primary_url":"https://en.wikipedia.org/wiki/Eliphalet_Lockwood","primary_url_label":"Wikipedia — Eliphalet Lockwood"},"cross_connections":[],"bio":{"title":"Captain","first_name":"Eliphalet","last_name":"Lockwood","married_names":[],"gender":"male","display_name":"Captain Eliphalet Lockwood","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778786493/elipahletlockwood-resized_m9qkll.png","photo_notes":"Portrait of Capt. Eliphalet Lockwood"},"residence":{"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"baptism":{"year":1741,"month":10,"day":17,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","rank":"Captain","rank_start":"Private","rank_end":"Captain","rank_year_start":1775,"rank_year_end":1780,"unit":"First Company, Colonel Charles Webb's Seventh Connecticut Regiment","notes":"Enlisted Jul 12, 1775; discharged Dec 24, 1775. Assigned to Gen. Sullivan's Brigade on Winter Hill. Assistant Commissary of Issues 1778; captain of coast guards 1780."}],"former_ids":[],"is_placeholder":false,"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave #155694447. East Norwalk Historical Cemetery."},"education":[],"career":[{"role":"Assistant Commissary of Issues","organization":"Fifth Connecticut Regiment, Continental Army","start_year":1778,"end_year":1778,"notes":"Posted $5,000 bond to Henry Laurens, President of the Continental Congress, Jul 21, 1778."},{"role":"Captain, Coast Guard","organization":"Connecticut Militia","start_year":1780},{"role":"Member","organization":"Connecticut House of Representatives","start_year":1790,"end_year":1796,"notes":"Represented Norwalk nine sessions: May/Oct 1790, May/Oct 1791, Oct 1794, May/Oct 1795, May/Oct 1796."}],"narrative_blocks":[{"number":1,"category":"military","header":"Lost home when British torched Norwalk, 1779","body":"British forces burned Norwalk in July 1779, destroying Lockwood's home among hundreds of others along the shore. He had already served in the 7th Connecticut Regiment and organized a petition to the General Assembly for an armed sloop after British ships raided the harbor at night."},{"number":2,"category":"politics","header":"Organized Norwalk's first volunteer fire department","body":"After the war Lockwood organized the first voluntary fire department in Norwalk, building civic infrastructure in the town the British had burned. He went on to represent Norwalk nine terms in the Connecticut General Assembly between 1790 and 1796."},{"number":3,"category":"military","header":"Petitioned Assembly for armed sloop; British still came","body":"In October 1777, Lockwood joined neighbors in petitioning the Connecticut General Assembly for an armed sloop to patrol Long Island Sound after British vessels repeatedly raided Norwalk's harbor at night, firing on houses and stealing livestock. Two years later, the raids he had warned against culminated in the burning of the town that destroyed his home."}],"slug":"eliphalet-lockwood-1741"},"H00478":{"id":"H00478","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"descent_paths_to_thomas":1,"is_progenitor":false},"birth":{"year":1743,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"parents":{"father_name":"Capt. Joseph St. John of Norwalk","mother_id":"H00253","mother_name":"Susannah Selleck St. John","father_research_notes":"Capt. Joseph St. John of Norwalk CT; d. 1756. His estate included enslaved people.","father_id":"X00215"},"tags":[],"sources":[{"label":"FindAGrave — Susannah St. John Lockwood","url":"https://www.findagrave.com/memorial/155694447/eliphalet-lockwood"}],"death":{"year":1810,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"marriages":[{"marriage_number":1,"spouse_id":"X00218","date_year":1776,"date_month":6,"date_day":8,"location_city":"Norwalk","location_county":"Fairfield County","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1810,"children_ids":["H01229","H01230","H01231","H01232","H01233","H01234","H01235"]}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Susannah St. John Lockwood","first_name":"Susannah","last_name":"Lockwood","maiden_name":"St. John","married_names":["Lockwood"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["HD0366"],"is_placeholder":false,"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave — East Norwalk Historical Cemetery"},"education":[],"career":[],"narrative_blocks":[{"number":1,"category":"family","header":"Orphaned at six; married the town's future captain","body":"Her mother Susannah Selleck died in December 1749 when Susannah was barely six, and her father Capt. Joseph St. John died in 1756 when she was thirteen, leaving her to grow up in Norwalk without either parent. She married Captain Eliphalet Lockwood at thirty-three — he would go on to lose his home to British torches and organize the city's first volunteer fire department."}],"slug":"susannah-lockwood-1743"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}