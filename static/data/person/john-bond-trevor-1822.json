":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Mary Tallmadge","last_name":"Trevor","display_name":"Mary Tallmadge Trevor Winthrop","gender":"female","married_names":["Winthrop"],"maiden_name":"Trevor","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780942436/46375331_0366b343-43b0-4179-9355-3215e0fddeff_hrommf.jpg"},"military_service":[],"career":[],"birth":{"year":1871,"country":"United States"},"death":{"year":1900,"country":"United States","city":"Yonkers","state":"New York"},"burial":{"cemetery_id":"CEM582"},"education":[],"number_of_marriages":1,"slug":"mary-tallmadge-trevor-1871"},"I01635":{"id":"I01635","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["arts"],"notable_blurb":"Art collector; bequeathed his collection to Harvard","primary_url":"https://en.wikipedia.org/wiki/Grenville_Lindall_Winthrop","primary_url_label":"Wikipedia"},"parents":{"father_id":"X03138","mother_id":"X03139"},"number_of_marriages":1,"marriages":[{"spouse_id":"HD6042","children_ids":["HD6045","HD6046"],"marriage_number":1}],"tags":["lawyer"],"narrative_blocks":[{"category":"legacy","header":"He gave Harvard one of America's great collections","body":"Winthrop amassed some four thousand works, including the largest holdings of Ingres and Blake, Pre-Raphaelite paintings, French drawings, and Chinese jades. He bequeathed the entire collection to Harvard's Fogg Art Museum, having never lent a piece in his lifetime.","number":1},{"category":"character","header":"He posed as the butler for visitors","body":"Shy and reticent, Winthrop guarded his Fifth Avenue collection closely and pretended to be the butler when guiding guests through it. The critic Richard Dorment likened him to a figure out of Henry James.","number":2},{"category":"social_reform","header":"He restored the old village of Lenox","body":"From his estate Groton Place, Winthrop restored Lenox's Congregational church, academy, and colonial courthouse, the last becoming the Lenox Library. He served as the library's president for the rest of his life.","number":3}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"parallel_careers","related_id":"HD1170","display_label":"amassed a Gilded Age art collection rivaling Winthrop's"},{"type":"parallel_careers","related_id":"HD6608","link_text":"John Phillips Coolidge","display_label":"directed the Fogg Museum that received this collector’s gift"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Grenville Lindall","last_name":"Winthrop","display_name":"Grenville Lindall Winthrop","gender":"male","bio_blurb":"Art collector; bequeathed his collection to Harvard","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780942517/8876342_b0cc4d73-c1e7-4c2d-be40-d4fce72ad1a4_lsm1up.jpg"},"military_service":[],"career":[],"birth":{"year":1864,"country":"United States","city":"New York","state":"New York"},"death":{"year":1943,"country":"United States","city":"New York","state":"New York"},"burial":{"cemetery_id":"CEM582"},"education":[],"videos":[{"video_id":"VID017"}],"slug":"grenville-lindall-winthrop-1864"},"HD6045":{"id":"HD6045","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":true,"is_easter_egg":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"generation_from_thomas":11},"notable":{"is_notable":true,"notable_category":["arts"],"notable_blurb":"Sculptor, collector, and Audubon Sharon benefactor","primary_url":"https://en.wikipedia.org/wiki/Emily_Winthrop_Miles","primary_url_label":"Wikipedia"},"parents":{"father_id":"I01635","mother_id":"HD6042"},"number_of_marriages":1,"marriages":[{"spouse_id":"I01636","children_ids":[],"marriage_number":1}],"tags":["artist"],"narrative_blocks":[{"category":"arts","header":"Sculptor who studied with Daniel Chester French","body":"Miles trained under Daniel Chester French and leading women sculptors of the day, and worked also as a painter, poet, and photographer. Her sculpture entered the Metropolitan, Montclair, and Harvard's Fogg collections.","number":1},{"category":"character","header":"She eloped with her father's chauffeur","body":"In 1924 the heiress eloped with Corey Miles, the widowed estate chauffeur, in a double wedding alongside her sister Kate. Their father Grenville was reportedly bitter for years over the matches.","number":2},{"category":"legacy","header":"Her glass and ceramics went to Brooklyn","body":"An avid collector, Miles left some 948 pieces of eighteenth-century Wedgwood, glass, and ceramics to the Brooklyn Museum. She also endowed the Emily Winthrop Miles wildlife sanctuary at Audubon Sharon.","number":3}],"sources":[],"institutions":[],"landmarks":[],"artworks":[{"artwork_id":"ART083","role":"creator"}],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Emily Lindall","last_name":"Winthrop","display_name":"Emily Lindall Winthrop Miles","gender":"female","married_names":["Miles"],"maiden_name":"Winthrop","bio_blurb":"Sculptor, collector, and Audubon Sharon benefactor","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780942951/105427767_91fc0a9e-3b4b-46c8-bdf1-9eb24292d3e6_k7qkee.png"},"military_service":[],"career":[],"birth":{"year":1893,"country":"United States","city":"New York","state":"New York"},"death":{"year":1962,"country":"United States","city":"New York","state":"New York"},"burial":{},"education":[],"slug":"emily-lindall-winthrop-1893"},"HD6046":{"id":"HD6046","