nnections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Emily Howell","last_name":"Trevor","display_name":"Emily Howell Trevor","gender":"female","maiden_name":"Trevor","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780943373/182315173_7e508f47-ddc8-4e0b-8f5a-74ba10771dae_fqtobn.jpg"},"military_service":[],"career":[],"birth":{"year":1874,"country":"United States"},"death":{"year":1943,"country":"United States","city":"New York","state":"New York"},"burial":{"cemetery_id":"CEM112"},"education":[],"slug":"emily-howell-trevor-1874"},"HD6044":{"id":"HD6044","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":true,"is_easter_egg":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"generation_from_thomas":10},"notable":{"is_notable":true,"notable_category":["law","politics"],"notable_blurb":"Lawyer; architect of the 1924 immigration quotas","primary_url":"https://en.wikipedia.org/wiki/John_B._Trevor_Sr.","primary_url_label":"Wikipedia"},"parents":{"father_id":"I01634","mother_id":"HD6041"},"marriages":[{"spouse_id":"I01638","children_ids":["HD6047","HD6048"],"marriage_number":1}],"tags":["wwi","lawyer"],"narrative_blocks":[{"category":"law","header":"Architect of the 1924 immigration quota system","body":"A wealthy lawyer, Trevor devised the 'national origins' formula behind the Immigration Act of 1924, which sharply cut immigration from southern and eastern Europe and barred most Asian immigration. He spent decades defending the quota system, which stood until 1964.","number":1},{"category":"politics","header":"He founded a coalition of patriotic societies","body":"In 1927 Trevor founded what became the American Coalition of Patriotic Societies, an umbrella of more than a hundred groups. He was active in the eugenics movement and campaigned against admitting Jewish refugees from Nazi Germany.","number":2},{"category":"military","header":"Wartime intelligence officer and Lusk Committee counsel","body":"A World War I veteran decorated by France, Trevor ran the Army's New York military-intelligence branch during the postwar Red Scare. He served as counsel to the New York legislature's Lusk Committee investigating radical activity.","number":3}],"sources":[],"institutions":[],"landmarks":[{"landmark_id":"LM135","landmark_blurb":"His Carnegie Hill townhouse, opposite the Carnegie mansion."}],"artworks":[],"research_tags":[],"cross_connections":[{"type":"family_orbit","related_id":"X03140","display_label":"his father-in-law, Union Club president Lucius Wilmerding"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"John B.","last_name":"Trevor","display_name":"John B. Trevor Sr.","gender":"male","bio_blurb":"Lawyer and architect of the 1924 immigration quotas","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780943450/77887183_a5ed9ffa-fcc3-4105-8b30-a4485adb2537_zhlw0c.jpg","suffix":"Sr."},"military_service":[],"career":[],"birth":{"year":1878,"country":"United States","city":"Yonkers","state":"New York"},"death":{"year":1956,"country":"United States","city":"New York","state":"New York"},"burial":{"cemetery_id":"CEM112"},"education":[],"number_of_marriages":1,"slug":"john-b-trevor-sr-1878"},"I01638":{"id":"I01638","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"X03140","mother_id":"X03141"},"number_of_marriages":1,"marriages":[{"spouse_id":"HD6044","children_ids":["HD6047","HD6048"],"marriage_number":1}],"tags":["extraordinary_longevity"],"narrative_blocks":[],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Caroline Murray","last_name":"Wilmerding","display_name":"Caroline Murray Wilmerding Trevor","gender":"female","married_names":["Trevor"],"maiden_name":"Wilmerding","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780943732/77887248_90d23d99-fad0-4b89-8cb9-5f63a5abd7e4_fu6qhv.jpg"},"military_service":[],"career":[],"birth":{"year":1882,"country":"United States","city":"Islip","state":"New York"},"death":{"year":1975,"country":"United States","city":"Paul Smiths","state":"New York"},"burial":{"cemetery_id":"CEM112"},"education":[],"slug":"caroline-murray-wilmerding-1882"},"HD6047":{"id":"HD6047","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":true,"is_easter_egg":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"generation_from_thomas":11},"notable":{"is_notable":true,"notable_category":["science","politics"],"notable_blurb":"Naval engineer and Pioneer Fund director","primary_url":"https://en.wikipedia.org/wiki/John_B._Trevor_Jr.","primary_url_label":"Wikipedia"},"parents":{"father_id":"HD6044","mother_id":"I01638"},"number_of_marriages":1,"marriages":[{"spouse_id":"I01639","children_ids":[],"marriage_number":1}],"tags":["engineer","extraordinary_longevity","author"],"narrative_blocks":[{"category":"science","header":"Naval engineer who designed anti-aircraft systems","body":"An electrical engineer trained at Columbia, Trevor led development of shipborne anti-aircraft control systems at the Naval Research Laboratory during World War II. The Navy awarded him its Meritorious Civilian Service Award in 1945.","number":1},{"category":"politics","header":"He directed the Pioneer Fund for decades","body":"Trevor spent decades as a director and treasurer of the Pioneer Fund, a backer of race science, and carried on his father's immigration-restriction work. Testifying in 1965, he warned that mixing racial and ethnic groups would bring cultural decline.","number":2},{"category":"legacy","header":"Genealogist, sailor, and Trudeau Institute trustee","body":"Trevor was a past president of the New York Genealogical and Biographical Society and a trustee of the Trudeau Institute for twenty-two years. A lifelong sailor, he co-authored a book on yacht racing and was the oldest member of the Union Club at his death.","number":3}],"sources":[],"institutions":[{"institution_id":"INST164","relationship":"trustee"}],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"John B.","last_name":"Trevor","display_name":"John B. Trevor Jr.","gender":"male","bio_blurb":"Naval engineer and Pioneer Fund director","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780944664/486801118_1182907373342417_7862652821818757317_n_kurgui.jpg","suffix":"Jr."},"military_service":[],"career":[],"birth":{"year":1909,"country":"United States","city":"New York","state":"New York"},"death":{"year":2006,"country":"United States","city":"Paul Smiths","state":"New York"},"burial":{"cemetery_id":"CEM112"},"education":[],"slug":"john-b-trevor-jr-1909"},"HD6048":{"id":"HD6048","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":true,"is_easter_egg":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"generation_from_thomas":11},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD6044","mother_id":"I01638"},"number_of_marriages":1,"marriages":[{"spouse_id":"I01640","chi