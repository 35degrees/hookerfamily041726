endants_documented":true,"bio":{"first_name":"Lucius","middle_name":"Robert","last_name":"Hart","married_names":[],"gender":"male","display_name":"Lucius Robert Hart","bio_blurb":"Seth Hart's son who settled in New York"},"gender":"male","birth":{"year":1803,"month":6,"day":14,"city":"Rocky Hill","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1871,"month":2,"day":11,"city":"New York City","state":"New York","country":"United States"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H00558","father_name":"Seth Hart","mother_id":"I01421","mother_name":"Lydia (Williams) Bull"},"number_of_marriages":1,"marriages":[{"spouse_id":"I01426","children_ids":["HD5684","HD5694","HD5695","HD5696","HD5697"],"marriage_number":1}],"education":[],"career":[{"role":"Apprentice","organization":"Thomas D. Boardman","start_year":1819,"end_year":1825},{"role":"Partner","organization":"Boardman & Hart","start_year":1828,"end_year":1847},{"role":"Proprietor","organization":"Lucius Hart & Co.","start_year":1847,"end_year":1871}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["new_york_migration"],"research_tags":[],"cross_connections":[{"type":"professional_peer","display_label":"made Britannia lamps as Bradley made brass ones in Meriden","related_id":"I01253","link_text":"Nathaniel Lyman Bradley"}],"narrative_blocks":[{"number":1,"category":"character","header":"He made his life in New York City","body":"Of Seth's children, Lucius left Connecticut for New York City, where he married Hannah Robinson. He made his life there until his death in 1871, far from the Rocky Hill of his childhood."},{"number":2,"category":"career","header":"Half the pewter firm Boardman & Hart","body":"For two decades Hart was the New York partner in Boardman & Hart, one of the country's leading makers of Britannia and pewter ware. The firm's wares sold across the country from its Manhattan showrooms."},{"number":3,"category":"legacy","header":"His pewter survives in museum collections","body":"Tea sets, urns, and beakers stamped Boardman & Hart and Lucius Hart & Co. survive today in collections of early American pewter. Examples are held by museums documenting the nineteenth-century metalware trade."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909"},{"short":"FindAGrave","url":"https://www.findagrave.com/memorial/176809396/lucius_robert-hart"},{"short":"Boardman & Hart / silversmiths database","url":"https://freepages.rootsweb.com/~silversmiths/genealogy/makers/silversmiths/87039.htm"}],"research_sources":[],"documents":[],"slug":"lucius-hart-1803"},"I01426":{"id":"I01426","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Hannah","last_name":"Robinson","married_names":[],"gender":"female","display_name":"Hannah Robinson"},"gender":"female","birth":{"year":1802,"month":12,"day":23,"state":"New Jersey","country":"United States"},"baptism":{},"death":{"year":1871,"month":8,"day":2,"city":"New York City","state":"New York","country":"United States"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"spouse_id":"H01490","children_ids":["HD5684","HD5694","HD5695","HD5696","HD5697"],"marriage_number":1}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artw