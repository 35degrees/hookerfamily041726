ity College","body":"Throughout his life he was active in the Episcopal Church — in his own parish, supporting Trinity College, and in state and national conventions. He died in Hamilton, Bermuda on May 16, 1875, almost certainly while seeking a milder climate for failing health."}],"cross_connections":[],"sources":[{"label":"William L. Clements Library — George Brinley Papers","url":"https://findingaids.lib.umich.edu/catalog/umich-wcl-M-401bri"},{"label":"UMass Amherst — Brinley Family Papers 1643-1950","url":"https://scua.library.umass.edu/umarmot/brinley-family/"}],"former_ids":[],"education":[{"type":"unknown","notes":"Began collecting Americana while a student."}],"career":[],"military_service":[],"institutions":[{"institution_id":"INST076","relationship":"donor","institution_blurb":"Active Episcopal layman who supported Trinity College throughout his life."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"research_tags":[],"quotes":[],"research_sources":[],"documents":[],"is_placeholder":false,"residence":{},"baptism":{},"slug":"george-brinley-jr-1817"},"HD1352":{"id":"HD1352","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00421","mother_id":"HD1331"},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00302","children_ids":["HD3341","HD3342","HD3343","HD3344","HD3345","HD3346"],"date_year":1839,"location_city":"Hartford","location_state":"Connecticut","end_year":1875,"end_type":"death_of_spouse"}],"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1816,"month":3,"day":14,"city":"Hartford","state":"Connecticut"},"death":{"year":1876,"month":4,"day":8,"city":"Hartford","state":"Connecticut"},"cross_connections":[],"bio":{"display_name":"Frances Ellen Terry Brinley","first_name":"Frances","middle_name":"Ellen","last_name":"Brinley","maiden_name":"Terry","married_names":["Brinley"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":[],"education":[],"career":[],"narrative_blocks":[],"is_placeholder":false,"slug":"frances-brinley-1816"},"X02356":{"id":"X02356","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"George","last_name":"Brinley","suffix":"Sr.","married_names":[],"gender":"male","display_name":"George Brinley Sr."},"birth":{"year":1774,"month":10,"day":24,"city":"Boston","county":"Suffolk","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1857,"month":1,"day":21,"city":"Hartford","county":"Hartford","state":"Connecticut","country":"United States"},"residence":{"city":"Hartford","state":"Connecticut","country":"United States"},"burial":{"plot_notes":"Old Trinity Church Graveyard, Brooklyn CT — Brinley Memorial to the left and behind the church"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":true},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Edward Brinley","mother_name":"Sarah (Tyler) Brinley"},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02357","children_ids":["I00302"],"date_year":1805,"date_month":4,"date_day":30,"location_city":"Brooklyn","location_state":"Connecticut","location_country":"United States","end_year":1842,"end_type":"death_of_spouse"}],"education":[],"career":[{"role":"Druggist (proprietor)","location":"Boston, Massachusetts","notes":"Succeeded Dr. Dix at the head of a large Boston drug store; built family fortune. (Source: A History of the Putnam Family.)"}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["banker"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Vivid 1856 letter recalled his 1805 Brooklyn wedding","body":"Fifty years after marrying Catherine Putnam at Brooklyn CT in 1805, eighty-two-year-old George dictated a long letter recalling the scene. The bride's deaf-blind grandfather wore a freshly-powdered wig and bright scarlet suit, leaning over Rev Fogg's shoulder to catch the words — 'a scene for Hogarth's pencil,' he thought."},{"number":2,"category":"career","header":"Took over Dr Dix's Boston drug store","body":"For many years he ran one of Boston's largest drug stores, succeeding Dr Dix. The fortune he built there carried the family to Hartford and Brooklyn Connecticut homes by the early 1800s and eventually produced his son George Brinley Jr, one of America's most famous 19th-century book collectors."},{"number":3,"category":"family","header":"Most of their five children died young","body":"Of five known children with Catherine Hutchinson Putnam — Catherine, Harriet, Anne, Sarah Tyler, and George Brinley Jr — 'many died young' per the family record. Only George Jr (1817-1875), the future book collector, is documented as reaching adulthood with descendants."}],"quotes":[{"text":"April 30th, 1805 - an event (that) occurred never to be obliterated from my memory. My marriage with Col. Putnam's eldest daughter Catherine. It took place in the West parlor. Why it was not the church, I know not - as it was - what a scene for Hogarth's pencil - all the family of course present - the servants black and white - hired men all congregated in a crowded room.","attribution":"George Brinley Sr., letter Nov 22, 1856 — recollections of his 1805 marriage at Brooklyn CT","category":"family"}],"sources":[{"label":"A History of the Putnam Family","url":"https://archive.org/details/ahistoryputnamf01putngoog/page/n418"},{"label":"UMass Amherst — Brinley Family Papers 1643-1950","url":"https://scua.library.umass.edu/umarmot/brinley-family/"}],"research_sources":[],"documents":[],"slug":"george-brinley-sr-1774"},"X02357":{"id":"X02357","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Catherine","middle_name":"Hutchinson","last_name":"Brinley","maiden_name":"Putnam","married_names":["Brinley"],"gender":"female","display_name":"Catherine Hutchinson Putnam Brinley"},"birth":{"year":1785},"baptism":{},"death":{"year":1842},"residence":{},"burial":{"plot_notes":"Old Trinity Church Cemetery, Brooklyn CT (with husband)"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":true},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Col. Daniel Putnam","father_research_notes":"Son of Maj. Gen. Israel Putnam (Bunker Hill hero); Catherine was the eldest daughter of Col. Putnam.","mother_research_notes":"Surname Hutchinson per Catherine's middle name; Mr. Hutchinson described in George Brinley Sr.'s 1856 letter as a fixture by the parlor fireplace, blind and deaf in his old age."},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02356","children_ids":["I00302"],"date_year":1805,"date_month":4,"date_day":30,"location_city":"Brooklyn","location_state":"Connecticut","location_country":"United States","end_year":1842,"end_type":"death"}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[{"artwork_id":"ART049","role":"subject"}],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Granddaughter of Bunker Hill hero Israel Putnam","body":"She was the eldest daughter of Col Daniel Putnam — and thus granddaughter of Major General Israel Putnam, the Continental Army officer famous for the order 'Don't fire till you see the whites of their eyes' at Bunker Hill in June 1775. Her middle name Hutchinson preserved her mother's family line in the same gesture."},{"number":2,"category":"family","header":"Father defended grandfather's wartime record","body":"In 1818 her father Col Daniel Putnam published a defense of Israel Putnam against Henry Dearborn's revisionist history of Bunker Hill. Catherine grew up inside that argument — the Putnam family's effort to control the historical record of the grandfather's reputation."},{"number":3,"category":"family","header":"Many children died young; only George Jr survived","body":"She had five known children with George Brinley Sr — Catherine, Harriet, Anne, Sarah Tyler, and George Jr — but only George Jr is attached to the tree as a built entry. Several of her daughters died young, a recurring loss the 1856 Brinley family letter recalled with sorrow."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"catherine-putnam-1785"},"X00421":{"id":"X00421","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["politician","congressman","judge","lawyer","yale_connection","yale_graduate","banker"],"sources":[{"url":"https://en.wikipedia.org/wiki/Nathaniel_Terry","label":"Wikipedia — Nathaniel Terry"},{"url":"https://bioguide.congress.gov/scripts/biodisplay.pl?index=T000135","label":"Biographical Directory of US Congress"},{"url":"https://politicalgraveyard.com/bio/terry.html","label":"Political Graveyard"}],"birth":{"year":1768,"month":1,"day":30,"city":"Enfield","state":"Connecticu