ed after moving west from New York — and his whole arc tracked the same westward drift: Michigan to Ohio to Wisconsin, jeweler to jeweler, town to town across the Great Lakes tier."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"Pixley Family Genealogy","url":"https://www.seekingmyroots.com/members/files/G005299.pdf"},{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"william-pixley-1833"},"I01021":{"id":"I01021","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Hattie","last_name":"Pixley","maiden_name":"Fleming","married_names":["Pixley"],"gender":"female","display_name":"Hattie Fleming Pixley"},"birth":{"year":1837,"country":"United States"},"baptism":{},"death":{"year":1885,"city":"Sauk County","state":"Wisconsin","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM500","plot_notes":"Green Wood Cemetery Reedsburg Sauk County Wisconsin per FA — same as husband"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H03823","location_country":"United States","children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"hattie-fleming-1837"},"H01262":{"id":"H01262","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Ira","last_name":"Pixley","married_names":[],"gender":"male","display_name":"Ira Pixley"},"birth":{"year":1783,"month":1,"day":8,"city":"Great Barrington","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1863,"month":8,"day":25,"city":"East Bloomfield","state":"New York","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM498","plot_notes":"East Bloomfield Cemetery Ontario County NY per FA. Epitaph: 'Age 80 Years. One of the early settlers of East Bloomfield, Ontario County, New York'"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"generation_from_john_talcott":6,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00984","mother_id":"H00486"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00988","date_year":1809,"date_month":8,"date_day":6,"location_city":"East Bloomfield","location_state":"New York","location_country":"United States","children_ids":["H02390","H02391","H02392","H02393","H02394","H02395","H02396"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"migration","header":"One of the early settlers of East Bloomfield","body":"Ira Pixley was born at Great Barrington, Massachusetts in 1783 — in the same Berkshire hills where his parents' tavern burned in 1787 and his father died in 1790 — and by 1809 had moved his family west to East Bloomfield, Ontario County, New York, where he and Sarah Adams married that August and where he would spend the rest of his life. His gravestone at East Bloomfield Cemetery calls him simply 'one of the early settlers of East Bloomfield, Ontario County, New York' — the son of an innkeeper who died young, become himself a founding farmer of an upstate New York township, eighty years old when he died there in 1863."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"Pixley Family Genealogy","url":"https://www.seekingmyroots.com/members/files/G005299.pdf"},{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"ira-pixley-1783"},"I00988":{"id":"I00988","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Sarah","last_name":"Adams","married_names":[],"gender":"female","display_name":"Sarah Adams"},"birth":{"year":1788,"month":8,"day":11,"country":"United States"},"baptism":{},"death":{"year":1865,"month":12,"day":26,"city":"Litchfield","state":"Michigan","country":"United States"},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01262","date_year":1809,"date_month":8,"date_day":6,"location_country":"United States","children_ids":["H02390","H02391","H02392","H02393","H02394","H02395","H02396"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archiv