sorghum-molasses trade economy of Walworth County Wisconsin."},{"number":3,"category":"family","header":"Moriah NY 1843 to Elkhorn Wisconsin 1927","body":"Coris Ann Bartlett was born July 21, 1843 in Moriah, Essex County New York — during her father Truman Bartlett's New York years before the family's 1844 migration to Wisconsin. She died April 6, 1927 in Elkhorn, Walworth County Wisconsin at age eighty-three. She is buried at Mount Pleasant Cemetery, Tibbets Wisconsin alongside her parents — a three-generation Wisconsin family cemetery cluster."}],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"coris-hodges-1843"},"X02229":{"id":"X02229","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":false},"bio":{"first_name":"Levi","last_name":"Hare","married_names":[],"gender":"male","display_name":"Levi Hare"},"birth":{"year":1837,"month":5,"day":26,"state":"New York","country":"United States"},"death":{},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3192","location_country":"United States","children_ids":["HD3196","HD3197","HD3193","HD3198"]}],"tags":[],"sources":[{"short":"WikiTree (Levi Hare)"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"levi-hare-1837"},"X02230":{"id":"X02230","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"is_thomas_descendant":false,"is_talcott_descendant