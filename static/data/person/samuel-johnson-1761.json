1791 in Stratford — the son of Founding Father William Samuel Johnson, chairman of the U.S. Constitution's Committee of Style. Their son William Samuel Johnson (1795-1883) later married Laura Woolsey, herself a Hooker descendant through a separate Edwards line, reuniting two branches of the family in the next generation. The Johnson-Edwards alliance braided the Hooker tree into the founding-era Connecticut elite."}],"slug":"susan-edwards-1773"},"HD2112":{"id":"HD2112","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00675","mother_id":"HD2095"},"tags":[],"sources":[],"birth":{"year":1792},"death":{"year":1841},"gender":"female","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Ann Frances Johnson","first_name":"Ann","middle_name":"Frances","maiden_name":"Johnson","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ann-johnson-1792"},"HD2113":{"id":"HD2113","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00675","mother_id":"HD2095"},"tags":["double_hooker_ancestry"],"sources":[],"birth":{"year":1795,"month":12,"day":13,"city":"Stratford","state":"Connecticut"},"death":{"year":1883,"month":1,"day":17},"marriages":[{"spouse_id":"HD2074","children_ids":[],"marriage_number":1,"date_year":1825,"date_month":4,"date_day":20}],"gender":"male","number_of_marriages":1,"notable":{"