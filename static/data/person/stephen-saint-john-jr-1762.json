se_id":"X00216","children_ids":["H01238","H01239","H01237","H01240","H01236"],"marriage_number":1,"date_year":1757,"date_month":12,"date_day":9}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"military_service":[{"war":"American Revolutionary War","rank":"Lt. Col.","unit":"9th Regiment, Connecticut Militia","notes":"Capt. 1st Co. Norwalk May 1761; Major 9th Regt. May 1775; Major 1st Batt. Col. Whiting Nov 1776; Lt. Col. 9th Regt. May 1777. On committee of Articles of Confederation 1777.","war_id":"WAR004"}],"bio":{"display_name":"Lt. Col. Stephen Saint John","first_name":"Stephen","last_name":"St. John","title":"Lieutenant Colonel","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778792414/stephenstjohnesq-resized_cvqbdg.png","photo_notes":"Portrait of Lt. Col. Stephen Saint John Esq.","bio_blurb":"Norwalk officer of the Connecticut 9th"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"former_ids":["HD0365"],"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave #44152495. Stone: 'Lt Col command of the 9th Reg of Foot Guard of the State of Connecticut who departed this life May the 9th 1785, in the 50th year of his age.'"},"narrative_blocks":[{"number":1,"category":"military","header":"Led Connecticut's 9th Regiment of Foot as Lt.","body":"Stephen Saint John rose to Lieutenant Colonel in command of the 9th Regiment of Foot, Guard of the State of Connecticut — a rank inscribed on his tombstone in East Norwalk Historical Cemetery. His family's marriage alliances connected two of Norwalk's most prominent dynasties: the Saint Johns married into the Fitches across two consecutive generations."},{"number":2,"category":"military","header":"He sent no substitute; his brother did","body":"A Connecticut selectman and Revolutionary officer, he led the colony’s 9th Regiment of Foot. When the war came, an enslaved man named Dover was sent to fight in the Continental Army in place of his brother — while his own household still held two people, Peter and Phyllis, at his death."}],"career":[{"role":"Selectman","organization":"Norwalk, Connecticut","notes":"1763-1784"},{"role":"Representative","organization":"Connecticut House","notes":"1778-1785"},{"role":"Lt. Colonel","organization":"9th Connecticut Regiment"}],"slug":"stephen-st-john-1736"},"X00216":{"id":"X00216","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"label":"St. John Genealogy (Alexander, 1907)","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"}],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00479","date_year":1757,"date_month":12,"date_day":9,"children_ids":["H01238","H01239","H01237","H01240","H01236"]}],"parents":{"father_name":"Hon. Samuel Fitch","mother_name":"Susannah Fitch","father_research_notes":"Per St. John Genealogy (Alexander 1907), entry 141: 'the dau. of Hon. Samuel and Susannah Fitch.' NOT a daughter of Gov. Thomas Fitch IV (X02826)."},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1733},"death":{"year":1797,"month":4,"day":28,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"cross_connections":[],"bio":{"display_name":"Ann Fitch Saint John","first_name":"Ann","maiden_name":"St. John","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave. Died Apr 28, 1797."},"slug":"ann-st-john-1733"},"X00215":{"id":"X00215","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"label":"St. John Genealogy (Alexander, 1907)","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"}],"birth":{"year":1703},"death":{"year":1756},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00253","date_year":1733,"children_ids":["HD0364","H00479","H00478","HD0367","H00481","H00482"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Captain Joseph St. John","first_name":"Joseph","last_name":"St. John","title":"Captain","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"character","header":"Earned 'Blue Sheep' nickname by dyeing his flock","body":"Tradition holds that Capt. Joseph Saint John attempted to dye a sheep blue to create a matching flock — and the rains washed it out, leaving him with the lasting nickname 'The Blue Sheep.' He was a large landowner in Norwalk and among its founding civic leaders, serving as Selectman, Rate Constable, Fence Viewer, and Captain of the 1st Company of the Norwalk trainband (1748)."},{"number":2,"category":"legacy","header":"Wife Susanna's epitaph: Rachel's face, Leah's fruitful womb","body":"When Susanna Selleck Saint John died in December 1749 at forty, Capt. Joseph commissioned a tombstone epitaph comparing her to Rachel ('face'), Leah ('fruitful womb'), Abigail ('wisdom'), Lydia ('faithful heart'), and Martha ('care'). The epitaph — one of the most elaborate in the East Norwalk churchyard — captures how colonial Norwalk elites memorialized women through accumulated biblical virtues."}],"slug":"joseph-st-john-1703"},"H00253":{"id":"H00253","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1709,"month":9,"day":3,"city":"Stamford","state":"Connecticut"},"death":{"year":1749,"month":12,"day":4,"city":"Norwalk","state":"Connecticut"},"burial":{"cemetery_id":"CEM002","plot_notes":"East Norwalk Historical Cemetery, Norwalk, Fairfield, Connecticut"},"parents":{"father_id":"I00129","mother_id":"H00094"},"marriages":[{"children_ids":["HD0364","H00479","H00478","HD0367","H00481","H00482"],"spouse_id":"X00215","marriage_number":1,"date_year":1733}],"gravestone_inscription":"Susanna St. John, ye wife of Capt. Joseph St. John died December ye 4th, 1749 aged 40 years and 2 months. \"She that lies at rest within this tomb / Had Rachel's face and Leah's fruitful womb, / Abigail's wisdom, Lydia's faithful heart / With Martha's care — we hope Mary's better part.\"","tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 253"}],"enslaved_persons":[{"name":"Jenny","description":"Enslaved woman. Listed in estate inventory of Joseph St. John, Dec 7, 1756."},{"name":"London","description":"Enslaved man. Listed in estate inventory of Joseph St. John, Dec 7, 1756."},{"name":"Peter","description":"Enslaved boy. Listed in estate inventory of Joseph St. John, Dec 7, 1756."}],"cross_connections":[],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Susannah Selleck St. John","first_name":"Susannah","last_name":"St. John","married_names":["St. John"],"maiden_name":"Selleck"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Her mother died one month after her birth","body":"She was born September 3, 1709 in Norwalk. Her mother Hannah Hooker died October 5, 1709 — barely one month later, age nineteen, of complications from childbirth."},{"number":2,"category":"marriage","header":"Married 'The Blue Sheep' captain in 1729","body":"She married Capt. Joseph St. John in 1729 — known as 'The Blue Sheep' for the local tradition that he once dyed a sheep blue, though the rains washed it out. He served as Norwalk selectman seven times across thirty years."},{"number":3,"category":"social_reform","header":"Three generations of slaveholding descendants","body":"After her death, her husband's 1756 estate inventory listed three enslaved people: Jenny, London, and Peter. Three consecutive generations of her descendants held enslaved people — including grandson William St. John, who sent his enslaved man Dover to the Continental Army in his own place."}],"slug":"susannah-st-john-1709"}},"burialCemetery":{"id":"CEM002","name":"East Norwalk Historical Cemetery","city":"Norwalk","state":"Connecticut","gps":{"latitude":41.10257,"longitude":-73.40353},"founded":1655,"visitable":true,"access_notes":"Sometimes locked; managed by local taxing district","features":["First Settlers of Norwalk Memorial (lists 31 individuals from 1649)","Grave of Thomas 'Yankee Doodle' Fitch IV (1724-1795)"],"notes":"Oldest cemetery in Norwalk; triangle-shaped; near East Norwalk railway station. Mary Willet Hooker Buckingham buried here, near center of burying ground near East Norwalk railway station.","hooker_connections":["H00253","I00006","X00076","X01015","H00478","X00218","H01232","H00479","X00216","X02826","X02827","H01236","I00707","HD4354","I00708","HD4355","H01238","HD2791","I00723","HD2792","H00481","H01241","H01245","H01246","H00037","H01244","I00736","HD4397","I00742","HD4453"]},"institutionsById":{},"crossConnections":[{"type":"in_law","related_id":"X02827","display_label":"was his father-in-law","slug":"thomas-fitch-v-1725"}]}