isplay_name":"Susannah Edwards","first_name":"Susannah","maiden_name":"Edwards","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married widower Eleazer Porter Jr. in 1760","body":"In 1760 she married Eleazer Porter Jr. — Yale 1748, lawyer and judge in Hadley, Massachusetts. His first wife Anna Pitkin, his own first cousin, had died November 1758 leaving two young daughters; Susannah became their stepmother."},{"number":2,"category":"family","header":"Her brother married her sister-in-law","body":"Her brother Jonathan Edwards Jr. married her husband's sister Mary Porter in 1770. The two pairs of Edwards and Porter siblings married each other across the same Connecticut River Valley generation."},{"number":3,"category":"family","header":"Son's marriage doubled the Edwards descent","body":"Her son Jonathan Edwards Porter married Fidelia Dwight in the next generation. Both were grandchildren of Jonathan Edwards Sr. — a marriage that doubled the Edwards descent in their children's bloodline."}],"slug":"susannah-edwards-1740"},"X00128":{"id":"X00128","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1703,"month":10,"day":5,"city":"East Windsor","state":"Connecticut"},"death":{"year":1758,"month":3,"day":22,"city":"Princeton","state":"New Jersey","cause":"Complications from smallpox inoculation"},"burial":{"cemetery_id":"CEM026","plot_notes":"Princeton Cemetery, Princeton, New Jersey"},"parents":{"mother_research_notes":"Esther Stoddard — daughter of Rev. Solomon Stoddard of Northampton","father_research_notes":"Rev. Timothy Edwards of East Windsor CT — minister 60 years until death 1758 age 89"},"church_roles":[{"role":"Assistant Pastor then Senior Pastor","location":"Northampton, Massachusetts","dates":"1727-1750","notes":"Succeeded grandfather Solomon Stoddard. Led Great Awakening revivals. Dismissed 1750 over communion controversy."},{"role":"Missionary to Housatonic Indians","location":"Stockbridge, Massachusetts","dates":"1751-1757"},{"role":"President","location":"College of New Jersey (Princeton)","dates":"1757-1758","notes":"Died 34 days after installation."}],"prominent_name_reason":"Rev. Jonathan Edwards (1703-1758) — Yale 1720; greatest American theologian; leader of the Great Awakening; delivered \"Sinners in the Hands of an Angry God\" (1741); President of Princeton; grandfather of Aaron Burr Jr. (3rd U.S. Vice President). Father's father-in-law was Rev. Timothy Edwards who held one enslaved person named Ansars. Edwards himself enslaved at least six people: Venus (purchased 1731), Joab, Rose Binney, Titus (son of Joab and Rose), Joseph, Sue, and possibly Leah.","enslaved_persons":[{"name":"Venus","description":"Purchased June 1731 as a young teenager. Likely later baptized and given name Leah."},{"name":"Joab Binney","description":"Enslaved man. Married Rose 1751."},{"name":"Rose Binney","description":"Enslaved woman. Married Joab 1751."},{"name":"Titus","description":"Enslaved man. Son of Joab and Rose."},{"name":"Joseph","description":"Enslaved man. Married couple with Sue."},{"name":"Sue","description":"Enslaved woman. Married Joseph."}],"marriages":[{"spouse_id":"HD0418","children_ids":["H00376","H00377","H00378","H00379","H00380","H00381","H00382","H00383","H00384","H00385","H00386"],"marriage_number":1}],"sources":[{"short":"Wikipedia","notes":"Jonathan Edwards (theologian) article"}],"gender":"male","tags":["yale_graduate"],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["religion"],"notable_blurb":"Theologian, Great Awakening leader","primary_url":"https://en.wikipedia.org/wiki/Jonathan_Edwards_(theologian)","primary_url_label":"Wikipedia"},"cross_connections":[{"type":"mentor_student","related_id":"H00443","display_label":"Giles Hooker Cowles studied theology under him after graduating Yale in 1789.","link_text":"Rev. Giles Hooker Cowles"},{"type":"family_connection","related_id":"X00613","display_label":"Succeeded his son-in-law as Princeton president after his sudden death.","link_text":"Rev. Aaron Burr Sr."},{"type":"family_orbit","related_id":"X02351","display_label":"Hosted him in final illness; published his Life as bestseller","link_text":"Rev. David Brainerd"},{"type":"historical_connection","related_id":"I00140","display_label":"Physician-minister and intimate friend in his New York years","link_text":"Rev. Dr. John Smith"}],"artworks":["ART019"],"education":[{"notes":"Entered 1716 at age 13. Graduated with highest honors.","school_name":"Yale College","graduation_year":1720,"institution_id":"INST022"},{"degree":"M.A.","school_name":"Yale College","graduation_year":1722,"institution_id":"INST022"}],"bio":{"title":"Reverend","display_name":"Rev. Jonathan Edwards","first_name":"Jonathan","last_name":"Edwards","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/e7/Jonathan_Edwards_%28detail%29.jpg/440px-Jonathan_Edwards_%28detail%29.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1720"},{"institution_id":"INST023"}],"landmarks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"religion","header":"His 1741 sermon shocked New England","body":"On July 8, 1741, he delivered 'Sinners in the Hands of an Angry God' to a Connecticut congregation. The Great Awakening had been spreading from his Northampton parish for six years."},{"number":2,"category":"legacy","header":"Wrote his greatest works in frontier exile","body":"After Northampton he took the Stockbridge mission preaching to Housatonnuck families through an interpreter. There he composed Freedom of the Will, The Nature of True Virtue, and The Doctrine of Original Sin."},{"number":3,"category":"religion","header":"Town turned on him over a midwifery book","body":"In 1748 he disciplined young people in his Northampton parish for circulating what he called 'immoral books,' later identified as a midwifery manual. His own Williams and Hawley relatives led the council that dismissed him in 1750."},{"number":4,"category":"death","header":"Died thirty-five days into the Princeton presidency","body":"He accepted the College of New Jersey presidency in early 1758 after his son-in-law Aaron Burr Sr. died suddenly in office. A smallpox inoculation administered February 23 turned fatal on March 22."},{"number":5,"category":"education","header":"Yale valedictorian at sixteen, in Latin","body":"He entered Yale at twelve and graduated four years later as the youngest member of his class. He delivered the commencement valedictory address in Latin."}],"slug":"jonathan-edwards-1703"},"HD0418":{"id":"HD0418","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1710,"month":1,"day":9,"city":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1758,"month":10,"day":2,"city":"Philadelphia","state":"Pennsylvania","country":"United States"},"parents":{"father_id":"X00126","mother_id":"H00034"},"tags":[],"sources":[{"short":"Pierpont genealogy, entry 30"},{"short":"Life of Rev. Jonathan Edwards by Sereno Dwight"},{"short":"Wikipedia: Jonathan Edwards; Sarah Pierpont"}],"burial":{"cemetery_id":"CEM026","plot_notes":"Princeton Cemetery, Princeton, New Jersey — buried next to Jonathan Edwards"},"marriages":[{"spouse_id":"X00128","children_ids":["H00376","H00377","H00378","H00379","H00380","H00381","H00382","H00383","H00384","H00385","H00386"],"marriage_number":1,"date_year":1727,"date_month":7,"date_day":28,"location_country":"United States"}],"cross_connections":[{"type":"family_connection","related_id":"H00913","display_label":"Died trying to bring him home from Princeton at age two.","link_text":"Aaron Burr Jr."},{"type":"family_connection","related_id":"H00912","display_label":"Died trying to bring her home from Princeton at age four.","link_text":"Sarah Burr Reeve"},{"type":"family_connection","related_id":"H00372","display_label":"Her North Haven nephew — wealthiest man in town in 1786","link_text":"Giles Pierpont"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["religion"],"notable_blurb":"Wife of Jonathan Edwards, theologian","primary_url":"https://en.wikipedia.org/wiki/Sarah_Pierpont_Edwards","primary_url_label":"Wikipedia"},"bio":{"display_name":"Sarah Pierpont Edwards","first_name":"Sarah","last_name":"Edwards","married_names":["Edwards"],"maiden_name":"Pierpont","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777405945/sarahedwardsb1710_txo277.png","photo_notes":"Sarah Pierpont Edwards (1710-1758), wife of Jonathan Edwards.","bio_blurb":"Subject of Edwards’s famous meditation at thirteen"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"},{"institution_id":"INST023"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Edwards wrote about her when she was twelve","body":"Jonathan Edwards composed a private spiritual meditation about a 'young lady in New Haven who is beloved of that Great Being who made and rules the world.' She married him five years later, at seventeen."},{"number":2,"category":"family","header":"Brought home her orphaned Burr grandchildren","body":"After Jonathan's death she traveled south in autumn 1758 to retrieve four-year-old Sarah Burr and two-year-old Aaron Burr Jr. She fell sick with dysentery in Philadelphia before she could complete the journey."},{"number":3,"category":"death","header":"Died exactly six months after her husband","body":"Jonathan died of smallpox-inoculation complications on March 22, 1758, weeks into the Princeton presidency. Sarah died of dysentery on October 2, 1758, at forty-eight."},{"number":4,"category":"death","header":"Made her will the day she died","body":"On October 2, 1758, in Philadelphia, she dictated her last instructions hours before dysentery took her. The two Burr grandchildren she had been escorting were placed with Dr. William Shippen."},{"number":5,"category":"legacy","header":"Her portrait hangs in a Yale dining hall","body":"She and her husband were both painted in oils, traditionally attributed to John Smybert. The portraits were bequeathed to Yale in 1939 and now hang in Jonathan Edwards College."}],"slug":"sarah-edwards-1710"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}