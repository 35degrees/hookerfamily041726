rtford","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1874,"children_ids":[]},{"marriage_number":2,"spouse_id":"H02832","location_city":"Meriden","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1894,"children_ids":["HD4968","HD4969"]}],"education":[],"career":[{"role":"President","organization":"Home National Bank of Meriden","notes":"President of Home National Bank of Meriden — a substantial Meriden banking institution."}],"military_service":[{"branch":"Connecticut Volunteers (Union Army, Civil War)","war":"Civil War","notes":"Served in Company C, Seventh Regiment Connecticut Volunteers. The 7th CT fought in the Department of the South — Hilton Head, Fort Wagner, Olustee, Bermuda Hundred, Cold Harbor — and the regiment served alongside the 54th Massachusetts at Fort Wagner. Specific dates and battles for Butler personally not yet researched."}],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["civil_war","banker"],"research_tags":[],"cross_connections":[{"type":"military","related_id":"H03199","display_label":"16th Connecticut Volunteers — Antietam, left Yale to enlist","link_text":"Arthur De Neufville Talcott","notes":"Two Connecticut Volunteers in the same war. Edwin Howell Butler served in Company C, Seventh Connecticut Volunteers in the Department of the South — Hilton Head, Fort Wagner, Olustee, Bermuda Hundred. Arthur De Neufville Talcott (Hooker descendant on the Talcott side) mustered into Company A, Sixteenth Connecticut Volunteers in July 1862 — leaving Yale College in his freshman year — and was wounded at the Battle of Antietam two months later, fighting in the same 40-acre cornfield mentioned in the Bauer letters that document Nathaniel Lyman Bradley's domestic life."}],"narrative_blocks":[{"number":1,"category":"military","header":"Co. C, Seventh Connecticut Volunteers","body":"He served in Company C, Seventh Regiment Connecticut Volunteers during the Civil War. The Seventh fought in the Department of the South — Fort Wagner, Olustee, Bermuda Hundred — and served alongside the 54th Massachusetts at the assault on Fort Wagner. Specific battle service for Butler not yet researched."},{"number":2,"category":"career","header":"President of Home National Bank of Meriden","body":"After the war he returned to Meriden and entered banking, rising to the presidency of Home National Bank. He died at New Haven on December 21, 1894, aged fifty, and was buried at Walnut Grove Cemetery in Meriden."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"edwin-butler-1844"},"H02832":{"id":"H02832","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Harriet","middle_name":"Isabella","last_name":"Butler","maiden_name":"Norton","married_names":["Butler"],"extra_names":"EH #2832 records as 'Harriet Isabel'; FindAGrave and her own gravestone use 'Harriet Isabella'.","gender":"female","display_name":"Harriet Isabella Norton Butler","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779587014/hararietsisabvwlla_anibp2.png","photo_notes":"Photo provided by Sam Hooker (project compiler)."},"gender":"female","birth":{"year":1843,"month":7,"day":5,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1927,"month":10,"day":1,"city":"Meriden","county":"New Haven","state":"Connecticut","country":"United States"},"residence":{},"burial":{"plot_notes":"Walnut Grove Cemetery, Meriden CT. FindAGrave Memorial #12917851."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":2,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I01240","mother_id":"H01445"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01243","location_city":"Meriden","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1894,"children_ids":["HD4968","HD4969"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Isabella","inspired_by_id":"H02831","description":"Middle name honors her older sister Isabella Norton, who died at age nine three years before her birth."}],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Named for an older sister dead at nine","body":"Born July 5, 1843 at Kensington, second daughter of Capt. Albert Norton and Ruth Hart. Her sister Isabella had died at Kensington on December 15, 1840 aged nine, and her parents gave her the middle name Isabella to carry it forward. Edward Hooker's 1909 genealogy abbreviated it to 'Isabel' in EH 2832, but her gravestone and surviving records preserve the full form."},{"number":2,"category":"marriage","header":"Married Civil War veteran and Meriden banker","body":"She became the second wife of Edwin Howell Butler of Meriden, Civil War veteran of Company C of the Seventh Connecticut Volunteers and later president of Home National Bank. He had been previously married to Marie L. Brown, who died in 1874."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"harriet-butler-1843"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}