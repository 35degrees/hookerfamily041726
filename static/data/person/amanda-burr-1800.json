idence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Civil War","active_in_war":true,"rank":"Captain; later Lieutenant Colonel","unit":"Co. D, 5th Wisconsin Volunteer Infantry","notes":"Williamsburg, the Seven Days, Antietam, Fredericksburg, Chancellorsville (left wing at Marye’s Heights), Salem Church, Gettysburg, the Wilderness, and the siege of Petersburg; mustered out September 1864.","war_id":"WAR006"}],"burial":{"cemetery_id":"CEM589","plot_notes":"Woodlawn Cemetery, Allouez (Brown County) WI. SOURCE: FindAGrave."},"narrative_blocks":[{"number":1,"category":"arts","header":"He painted across Europe with George Catlin","body":"As a young man Theodore Burr Catlin worked as a portrait painter and traveled for years through Europe in the company of his uncle, the celebrated Indian painter George Catlin. He married Margaret Dowd in London before the couple settled briefly in New York and then moved west to Wisconsin."},{"number":2,"category":"military","header":"He led the 5th Wisconsin up Marye's Heights","body":"Commissioned captain of Company D, 5th Wisconsin Infantry in 1861 and later its lieutenant-colonel, Catlin commanded the regiment's left wing in the charge up Marye's Heights at Fredericksburg. Burnside had failed against those same heights at a cost of ten thousand men, and though Catlin's assault carried the slope, half his regiment fell."},{"number":3,"category":"military","header":"He fought from Williamsburg to Petersburg","body":"His regiment saw heavy action from Williamsburg and the Peninsula through Antietam, Chancellorsville, and Gettysburg. He led it through the first three days of the Wilderness before sickness sent him to the hospital, returning in time for the siege of Petersburg and muster-out in 1864."},{"category":"military","header":"He raised a company the week Sumter fell","body":"As soon as word of Fort Sumter reached Beaver Dam, Catlin began enrolling volunteers, and his men were mustered as Company D of the 5th Wisconsin. Comrades remembered him as a brave, kindly captain, popular though no strict disciplinarian.","number":4},{"category":"death","header":"He died on the sidewalk walking home","body":"The day after attending an old comrade's funeral, the seventy-one-year-old colonel walked several blocks on an errand, refusing to rest because he was tired and almost dead. He sat down on the sidewalk a short way on and was found dead minutes later.","number":5}],"career":[{"role":"Portrait painter"},{"role":"Captain, later Lieutenant Colonel","organization":"5th Wisconsin Volunteer Infantry","start_year":1861,"end_year":1864}],"education":[],"slug":"theodore-catlin-1817"},"HD5238":{"id":"HD5238","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":10},"birth":{"year":1846},"parents":{"father_id":"HD5236","mother_research_notes":"Margaret Dowd Catlin."},"tags":[],"sources":[],"gender":"female","marriages":[{"children_ids":["HD5251","HD5252"],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1878},"cross_connections":[],"bio":{"display_name":"Amanda Catlin","first_name":"Amanda","last_name":"Catlin","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM589"},"narrative_blocks":[],"career":[],"education":[],"slug":"amanda-catlin-1846"},"HD5239":{"id":"HD5239","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_de