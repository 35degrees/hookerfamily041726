homas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1817},"death":{"year":1895},"parents":{"father_id":"HD1671","mother_id":"X00539"},"marriages":[{"spouse_id":"X00540","children_ids":["HD1674","HD1675","HD1676","HD1677","HD1678","HD1679","HD1680"],"marriage_number":1,"date_year":1841,"date_month":9,"date_day":16,"location_city":"Jessamine","location_state":"Kentucky"}],"tags":["politician","military","slaveholder"],"sources":[],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Provisional Governor of Alabama, 1865","primary_url":"https://en.wikipedia.org/wiki/Lewis_E._Parsons"},"narrative_blocks":[{"header":"Provisional Governor of Alabama, 1865","detail":"President Andrew Johnson appointed Parsons provisional governor of Alabama on June 21, 1865. His first act was to reinstate the laws of 1861, except those pertaining to slavery. He ordered the election of delegates to a constitutional convention (Sep 12, 1865) which repealed the ordinance of secession, renounced the state's war debts, abolished slavery, and scheduled elections. He attempted to purchase the Florida panhandle for Alabama, sparking rumors he had access to unclaimed Confederate gold. Term ended Dec 13, 1865 with inauguration of Robert M. Patton. Subsequently elected to U.S. Senate but refused his seat by the Republican Party. Served as U.S. District Attorney, Northern District of Alabama 1877-78.","body":"Appointed by President Andrew Johnson as the 19th Governor of Alabama Jun 21-Dec 13, 1865.","number":1},{"header":"Slaveholder and Confederate officer","detail":"Lewis E. Parsons held enslaved people in Talladega, Alabama — 16 individuals recorded in the 1860 slave schedule. He served as a Confederate lieutenant at the brief Battle of Munford near Talladega in April 1865, one of the last engagements of the war. He was an Alabama House of Representatives member 1859-1865. Presidential elector 1856 and 1860. His appointment as provisional governor was intended to restore civil government under Democratic leadership in the immediate aftermath of Confederate surrender.","body":"Recorded as slave owner in 1850 and 1860; served as Confederate lieutenant at Battle of Munford, April 1865.","number":2},{"header":"Grandson James K. Parsons: Major General","detail":"Lewis E. Parsons Jr. (son, U.S. Attorney for Northern District of Alabama) had a son James K. Parsons who became a career U.S. Army officer, attaining the rank of major general and receiving the Distinguished Service Cross for heroism in World War I.","body":"His grandson James K. Parsons was a career U.S. Army officer who attained major general and received the DSC for WWI heroism.","number":3}],"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Lewis Eliphalet Parsons","first_name":"Lewis","last_name":"Parsons","middle_name":"Eliphalet","married_names":[],"photo_url":"https://www.wikitree.com/photo.php/f/f3/Parsons-4753.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"lewis-parsons-1817"},"X00540":{"id":"X00540","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1818},"death":{"year":1887},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1672","children_ids":["HD1674","HD1675","HD1676","HD1677","HD1678","HD1679","HD1680"],"marriage_number":1,"date_year":1841,"date_month":9,"date_day":16,"location_city":"Jessamine","location_state":"Kentucky"}],"gender":"female","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio