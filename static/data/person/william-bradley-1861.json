:[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"migration","header":"One of the early settlers of East Bloomfield","body":"Ira Pixley was born at Great Barrington, Massachusetts in 1783 — in the same Berkshire hills where his parents' tavern burned in 1787 and his father died in 1790 — and by 1809 had moved his family west to East Bloomfield, Ontario County, New York, where he and Sarah Adams married that August and where he would spend the rest of his life. His gravestone at East Bloomfield Cemetery calls him simply 'one of the early settlers of East Bloomfield, Ontario County, New York' — the son of an innkeeper who died young, become himself a founding farmer of an upstate New York township, eighty years old when he died there in 1863."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"Pixley Family Genealogy","url":"https://www.seekingmyroots.com/members/files/G005299.pdf"},{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"ira-pixley-1783"},"I00988":{"id":"I00988","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Sarah","last_name":"Adams","married_names":[],"gender":"female","display_name":"Sarah Adams"},"birth":{"year":1788,"month":8,"day":11,"country":"United States"},"baptism":{},"death":{"year":1865,"month":12,"day":26,"city":"Litchfield","state":"Michigan","country":"United States"},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spo