e":[],"institutions":[],"landmarks":[],"artworks":[],"tags":["politician","merchant"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Customs collector appointed by Tyler, Lincoln, and Grant","body":"Henry Hooker served as Collector of Customs at the Port of Morristown, appointed by President Tyler and reappointed by Presidents Lincoln and Grant — spanning decades across the Civil War era. He was also Justice of the Peace, town Supervisor, Episcopal Church Warden, and partner in the mercantile firm Miller, Hooker & Co."},{"number":2,"category":"legacy","header":"Son Alfred killed at Monocacy, 1864","body":"Henry Hooker's son Alfred Ives became Captain of Company B, 106th New York Infantry, and was killed at the Battle of Monocacy on July 9, 1864 — the engagement that slowed Jubal Early's Confederate march on Washington. Alfred died three years before his mother Melinda and eighteen years before his father."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{},"residence":{},"sources":[{"short":"EH 1909"}],"research_sources":[],"slug":"henry-hooker-1797"},"H00535":{"id":"H00535","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1768,"month":4,"day":17,"city":"Kensington","state":"Connecticut"},"death":{"year":1829,"month":4,"day":12,"city":"Morristown","county":"St. Lawrence","state":"New York"},"parents":{"father_id":"H00267","mother_id":"I00045"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 535"}],"gender":"male","marriages":[{"marriage_number":1,"spouse_id":"I01232","date_year":1790,"date_month":9,"date_day":5,"end_type":"death_of_spouse","end_year":1794,"children_ids":["H01435","H01436"]},{"marriage_number":2,"spouse_id":"I01233","date_year":1795,"date