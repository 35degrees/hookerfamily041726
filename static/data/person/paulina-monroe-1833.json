":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1806,"city":"Catskill","county":"Greene","state":"New York","country":"United States"},"death":{"year":1889,"month":8,"day":31,"city":"Lenox Township","county":"Ashtabula","state":"Ohio","country":"United States"},"parents":{"mother_id":"H00445","father_research_notes":"Stephen Root of Catskill NY","father_id":"X00264"},"tags":["ohio_migration"],"sources":[{"short":"Edward Hooker 1909","page":"Entry #1156"}],"gender":"male","number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"I00500","date_year":1827,"location_city":"Catskill","location_state":"New York","location_country":"United States","children_ids":["HD3895","HD3896","HD3897","HD3898","HD3899"]},{"marriage_number":2,"spouse_id":"I00501","date_year":1869,"date_month":7,"date_day":23,"location_city":"Lenox Township","location_state":"Ohio","location_country":"United States","children_ids":["HD3900"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"William Ezekiel Root","first_name":"William","last_name":"Root","middle_name":"Ezekiel","married_names":[]},"residence":{"city":"Austinburg Township","county":"Ashtabula","state":"Ohio","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM282"},"narrative_blocks":[{"number":1,"category":"family","header":"Remarried at sixty-three; only daughter at sixty-six","body":"William Ezekiel Root's first marriage to Harriet Leonard around 1827 produced five sons. After their separation or her departure (she 'still living' at his 1889 death and later married Orlin W. Spencer), William remarried on July 23, 1869 in Lenox Township Ohio to Paulina Monroe — and three years later, at age sixty-six, fathered his only documented daughter Mary E. Root. The late-life second-family arc was uncommon among Connecticut-Hooker-line men of his generation."},{"number":2,"category":"family","header":"Catskill NY birth, EH misrecorded as Farmington","body":"William Ezekiel Root was born in 1806 in Catskill New York, where his parents had settled before 1792 — though some early genealogical records mistakenly placed his birth in Farmington Connecticut. He died in Lenox Township, Ashtabula County Ohio on August 31, 1889 at age eighty-three, buried at West Lenox Cemetery. The Connecticut-to-New-York-to-Ohio migration arc spanned three states across his lifetime."},{"number":3,"category":"family","header":"Five sons, four documented only by initials","body":"William and Harriet's five sons were William Alonzo Root born 1832, and four others known in records only as E.L. (1859), E.W. (1860), S.L. (1860), and A.A. (1861). The use of initials for four of five sons may reflect contemporary practice or simply that fuller given names were never preserved. The 1859-1861 birth cluster of four boys came in close succession during William's middle-aged years."}],"slug":"william-root-1806"},"HD3900":{"id":"HD3900","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Mary","middle_name":"E.","last_name":"Root","married_names":[],"gender":"female","display_name":"Mary E. Root"},"birth":{"year":1872},"baptism":{},"death":{"year":1903},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD0533","mother_id":"I00501"},"number_of_marriages":0,"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[