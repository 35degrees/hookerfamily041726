 Benjamin was born on September 4, 1893 in Monroe County — the same landscape where his great-great-grandmother's family had deeded land for Hooker Cemetery fifty years earlier — and his middle name 'Hooker' traced back through Mary C. Hooker Benjamin, through her father Alexander Allin Hooker of Irondequoit, through Captain James Hooker of Windsor, to the Rev. Thomas Hooker who founded Hartford in 1636. That the name survived eight generations into a family that had long since become 'Benjamin' is one of the quieter acts of genealogical memory in the Hooker tree."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"homer-benjamin-1893"},"HD4660":{"id":"HD4660","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Milton","middle_name":"H","last_name":"Benjamin","married_names":[],"gender":"male","display_name":"Milton H Benjamin"},"birth":{"year":1895,"month":6,"day":14,"city":"Chili","county":"Monroe County","state":"New York","country":"United States"},"baptism":{},"death":{"year":1968,"month":3,"day":25,"city":"Rochester","county":"Monroe County","state":"New York","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM459","plot_notes":"Grove Place Cemetery Chili per FA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"generation_from_john_talcott":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD4655","mother_id":"I00938"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"l