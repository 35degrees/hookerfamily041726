tion_from_thomas":9,"generation_from_john_talcott":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD4655","mother_id":"I00938"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00951","date_year":1932,"location_country":"United States","children_ids":["HD4675","HD4676"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"caroline-sickles-1914"},"H00796":{"id":"H00796","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":true,"is_easter_egg":false,"generation_from_john_talcott":5},"birth":{"year":1789,"month":10,"day":30,"city":"Windsor","county":"Hartford County","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00348","mother_id":"X00319"},"tags":["named_for_hooker","war_of_1812"],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave","url":"https://www.findagrave.com"},{"label":"Chaffee Genealogy, Embracing the Chafe (1909)"},{"label":"Alexander Hooker Papers, D.344 — University of Rochester Special Collections","url":"https://rbscp.lib.rochester.edu/4293"}],"death":{"year":1849,"month":1,"day":2,"city":"Irondequoit","county":"Monroe County","state":"New York","country":"United States"},"gender":"unknown","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00901","date_year":1820,"date_month":3,"date_day":23,"location_country":"United States","children_ids":["H02022","H02023","H02024","H02025","H02026","H02027","H02028","H02029"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Alexander Allin Hooker No. 2","first_name":"Alexander","last_name":"Hooker","suffix":"No. 2","middle_name":"Allin","married_names":[],"gender":"male"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[{"name_element":"Alexander Allin","description":"Named for his dead half-brother Alexander Allin Hooker (b.1763; d.1781; FAG 22532503), son of Capt. James Hooker's second wife Hannah Allin — a memorial naming that also honors the Allin family name carried through Capt. James's second wife."}],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"War of 1812","war_id":"WAR009","rank":"Soldier","unit":"Unknown — service documented in son's obituary","years":"c.1812-1815","notes":"Fought at Battle of Lundy's Lane (July 25, 1814) and Battle of Queenston Heights (Oct 13, 1812). Documented in obituary of his son Capt. James Henry Hooker, Rochester newspaper, March 1907: 'His father, Alexander B. Hooker, served in the war of 1812, fighting in the battles of Lundy's Lane, Queenstown, and others.'"}],"career":[{"role":"Farmer","organization":"Rochester, New York"}],"burial":{"cemetery_id":"CEM454","plot_notes":"Hooker Cemetery — land he deeded to Irondequoit in 1840; family plot survived 1950s accidental destruction"},"narrative_blocks":[{"number":1,"category":"career","header":"Pioneer settler who gave Irondequoit its Hooker Cemetery","body":"Alexander Allin Hooker arrived in the Rochester area in 1816 — with his brother Horace — to visit their sister Dolly (Dolly Goodwin Hooker Strong, who had recently married and settled in Canandaigua) and stayed to open a general store that lasted three years; by 1828 he had purchased Jesse Tainter's farm and by 1839 he was Irondequoit's first Town Clerk, and in 1840 he deeded land that became Hooker Cemetery to the town. His family burial plot there is one of the few in the cemetery to survive intact when the town accidentally destroyed most of the grounds in the 1950s, leaving his stone among the more legible remnants of the family that gave Irondequoit its first civic institutions."},{"number":2,"category":"military","header":"Fought at Lundy's Lane before founding Irondequoit","body":"Before settling in the Rochester area, Alexander Allin Hooker served in the War of 1812, fighting at the battles of Lundy's Lane (July 25, 1814, one of the bloodiest engagements on the Canadian border) and Queenston Heights — service documented in his son's 1907 newspaper obituary, which called him 'a soldier' who 'served in the war of 1812, fighting in the battles of Lundy's Lane, Queenstown, and others.' He came to Rochester in 1816, the year after the war ended, and within two decades had deeded a cemetery and founded a town — a veteran who became a civic patriarch."},{"number":3,"category":"character","header":"An old Indian trail passed behind his cemetery","body":"The burying ground Alexander Hooker made public in 1840 sat on a sandy knoll traversed by an Old Indian Trail that ran from the Seneca Village on Boughton Hill (near Victor, New York) to the Indian Landing at the mouth of the Genesee River — meaning the Hooker Cemetery was not merely a settler burial ground but sat astride an ancient Seneca thoroughfare, and likely contains Seneca burials alongside those of the earliest European settlers. It is estimated that perhaps a thousand people are buried in the one-and-a-half acres, most without markers, interred by pioneers under pine and oak trees before the ground was formally enclosed."}],"slug":"alexander-hooker-1789"},"I00901":{"id":"I00901","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Lucy","middle_name":"Case","last_name":"Hooker","maiden_name":"Case","married_names":["Hooker"],"gender":"female","display_name":"Lucy Case Hooker"},"birth":{"year":1800,"country":"United States"},"baptism":{},"death":{"year":1885,"month":7,"day":26,"country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM454","plot_notes":"Hooker Cemetery Irondequoit — inscription: \"She acted well her part and sleeps in Jesus\""},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00796","date_year":1820,"date_month":3,"date_day":23,"location_country":"United States","children_ids":["H02022","H02023","H02024","H02025","H02026","H02027","H02028","H02029"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"lucy-case-1800"},"H00348":{"id":"H00348","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":true,"generation_from_john_talcott":4,"is_thomas_descendant":true,"is_talcott_descendant":true,"is_easter_egg":false},"birth":{"year":1742,"month":8,"day":15,"city":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1805,"month":12,"day":10,"city":"Windsor","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00115","mother_id":"I00054"},"tags":["revolutionary_war","hooker_talcott_descent"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 348"}],"burial":{"cemetery_id":"CEM107"},"marriages":[{"spouse_id":"X00317","children_ids":["H00793"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1765,"date_year":1763,"date_month":1,"date_day":6,"location_country":"United States"},{"spouse_id":"X00318","marriage_number":2,"children_ids":[],"end_type":"death_of_spouse","end_year":1784,"date_year":1777,"date_month":4,"date_day":30,"location_country":"United States"},{"spouse_id":"X00319","children_ids":["H00794","H00795","H00796","H00797","H00798","H00799","H00800","H00801"],"marriage_number":3,"date_year":1784,"date_month":11,"date_day":7,"location_country":"United States"}],"cross_connections":[{"type":"parallel_descent","related_id":"I00054","display_label":"His mother — daughter of Governor Joseph Talcott.","link_text":"Eunice Talcott Hooker"},{"type":"parallel_descent","related_id":"T00045","display_label":"His maternal grandfather, Governor of Connecticut 1724-1741.","link_text":"Gov. Joseph Talcott"},{"type":"parallel_descent","related_id":"T00387","display_label":"First cousin once removed via the Talcott family.","link_text":"Col. Jeremiah Wadsworth"},{"type":"parallel_descent","related_id":"H00362","display_label":"Wife of his cousin Wadsworth — also a Hooker descendant.","link_text":"Mehitable Russell"},{"type":"civic_connection","related_id":"X00433","display_label":"Father-in-law and partner in the Hooker and Chaffee firm.","link_text":"Dr. Hezekiah Chaffee"},{"type":"professional","related_id":"X00434","display_label":"his partner in the firm Hooker & Chaffee"},{"type":"family_connection","related_id":"X00434","display_label":"brother of his wife Mary Chaffee"}],"gender":"female","number_of_marriages":3,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"career","header":"Hooker and Chaffee supplied the Continental Army","body":"Hooker and Chaffee was one of New England's largest mercantile houses before the Revolution, transacting much business for the Colonial Government. The partners gave freely to the patriot cause and were seriously embarrassed at war's end."},{"number":2,"category":"military","header":"His firm provisioned alongside Wadsworth's commissary","body":"The Hooker and Chaffee firm operated alongside Jeremiah Wadsworth's larger commissary operation — both Hooker-Talcott descendants provisioning the same Continental Army. The Connecticut River Valley supply network was effectively a Hooker-tree internal collaboration."},{"number":3,"category":"legacy","header":"His Windsor house is on the National Register","body":"He built the James Hooker House ca. 1772 at 118 Palisado Avenue, Windsor — now part of the Palisado Avenue Historic District on the National Register of Historic Places. The interior was later gutted for Chaffee School classrooms but the Federal-period exterior survives under Greek Revival additions."}],"institutions":[{"institution_id":"INST070","institution_blurb":"Silent partner; one of New England's great Revolutionary-era trading houses."}],"landmarks":[{"landmark_id":"LM015","landmark_blurb":"He built this house c.1772; it survives on Palisado Avenue's National Register district."}],"bio":{"display_name":"Captain James Hooker","first_name":"James","maiden_name":"Hooker","title":"Captain","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778904974/captjameshooker_rjjclc.jpg","photo_notes":"Portrait of Captain James Hooker (1742-1805), Windsor CT merchant."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Merchant and Silent Partner","organization":"Hartford and Windsor, Connecticut","end_year":1805,"notes":"Principal of INST070 Hooker and Chaffee. Succeeded to father's Hartford business with brothers; established Windsor branch. See INST070 for full firm history."}],"slug":"james-hooker-1742"},"X00319":{"id":"X00319","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"Chaffee genealogy book, entries 269 and 702"}],"birth":{"year":1760,"month":7,"day":28,"city":"Windsor","county":"Hartford County","state":"Connecticut","country":"United States"},"death":{"year":1846,"month":10,"day":7,"city":"Windsor","county":"Hartford County","state":"Connecticut","country":"United States"},"parents":{"father_id":"X00433","mother_name":"Lydia (Griswold) Chaffee","mother_research_notes":"Lydia (Griswold) Chaffee, b.Dec 17, 1722 Simsbury CT; d.Oct 1, 1801 Windsor CT. Daughter of the Griswold family of Connecticut."},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":3,"spouse_id":"H00348","children_ids":["H00794","H00795","H00796","H00797","H00798","H00799","H00800","H00801"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Chaffee Hooker","first_name":"Mary","maiden_name":"Chaffee","married_names":["Hooker"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Brother John was partner in Hooker & Chaffee","body":"Her older brother John Chaffee was a partner in the firm Hooker & Chaffee — the business linking her birth family directly to her husband's. The 1784 marriage to Captain James Hooker thus joined both personal and commercial lines of the Windsor Connecticut Chaffee household."},{"number":2,"category":"death","header":"Lived 41 years past husband's 1805 death","body":"She survived her husband Captain James Hooker by forty-one years — he died December 1805, she lived until October 1846 at eighty-six. After James's death she returned from Rochester New York to Windsor Connecticut and lived with her unmarried sister Hepsibah Chaffee until Hepsibah's 1834 death."}],"slug":"mary-chaffee-1760"}},"burialCemetery":{"id":"CEM454","name":"Hooker Cemetery","location":{"city":"Irondequoit","county":"Monroe County","state":"New York","country":"United States"},"url":"https://www.findagrave.com/cemetery/2142682/hooker-cemetery","notes":"Named for the Hooker family. Land deeded to the Town of Irondequoit in 1840 by H00796 Alexander Allin Hooker, one of the town's founders and its first clerk. Family plot survived largely intact when much of the cemetery was accidentally bulldozed in the 1950s.","hooker_connections":["H00526","H00796","H02022","H02023","H02024","H02025","H02026","H02027","H02028","HD4652","I00039","I00901","I00935","X00041","X00042"],"city":"Hinsdale","state":"New Hampshire","country":"United States","gps":{"lat":42.77926,"lon":-72.50093},"primary_url":"https://www.findagrave.com/cemetery/2273344/hooker-cemetery"},"institutionsById":{},"crossConnections":[]}