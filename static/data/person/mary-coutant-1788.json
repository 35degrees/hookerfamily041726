is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1788},"death":{"year":1851},"tags":[],"sources":[{"short":"Wikipedia","note":"Aaron Burr; WikiTree"}],"marriages":[{"spouse_id":"HD1917","children_ids":["HD1932","HD1933","HD1934"],"marriage_number":1}],"gender":"female","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary C Coutant","first_name":"Mary","middle_name":"C","maiden_name":"Coutant","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-coutant-1788"},"HD1917":{"id":"HD1917","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1808,"month":9,"day":15,"city":"Paris","state":"France"},"death":{"year":1882,"month":7,"day":27,"city":"New York","state":"New York"},"parents":{"father_id":"H00913","mother_id":"X00619"},"marriages":[{"spouse_id":"X00622","children_ids":["HD1932","HD1933","HD1934"],"marriage_number":1},{"spouse_id":"X00623","children_ids":[],"marriage_number":2}],"tags":["adopted","reputed_biological","lincoln_colony","jeweler"],"sources":[{"short":"Wikipedia","note":"Aaron Burr — children section"}],"gender":"male","notable":{"is_notable":true,"notable_category":[],"primary_url":"https://en.wikipedia.org/wiki/Aaron_Columbus_Burr"},"narrative_blocks":[{"number":1,"category":"origin","header":"Born Paris 1808, possibly Aaron Burr's biological son","body":"Born 15 September 1808 in Paris as 'Aaron Burr Colombe.' Some historians (Schachner, Lomask) argue he was Aaron Burr's biological son, conceived during Burr's European exile after the Hamilton duel and treason trial. Others suggest his father was Count Verdi de Lesle; no definitive primary documents have resolved the question."},{"header":"Lobbied Lincoln on a Honduras freedmen colony","detail":"In August 1860, Aaron Columbus Burr received an offer of ~150 square miles in British Honduras's Stann Creek District and conceived a plan to use it as a colony for emancipated American slaves. He enlisted political writer Anna Ella Carroll to lobby Lincoln and Secretary of State Seward, titling the plan the \"Lincoln Colony.\" Carroll submitted memoranda arguing that minimal federal support could place freedpeople \"beyond U.S. racial conflicts\" under British protection. The scheme failed — undermined by the escalating war, British colonial reluctance, and freedpeople's wariness of tropical disease and unfamiliar terrain. Burr and James Grant then formed the American Honduras Company for mahogany export. In 1865 Burr helped found Linwood, Maryland — a cooperative settlement for freed Black laborers on 1,200 acres, housing over 100 families initially.","body":"During the Civil War he worked with Anna Ella Carroll to propose the 'Lincoln Colony' — a settlement for freed American slaves in British Honduras (modern Belize), lobbying President Lincoln starting August 1860. Offered ~150 square miles in Stann Creek District; scheme failed due to wartime priorities and British reluctance.","number":2},{"number":3,"category":"activism","header":"Founded a freed Black cooperative settlement, 1865","body":"With James Grant he co-founded a cooperative settlement for freed Black laborers at Linwood Maryland in 1865 on 1,200 acres — over 100 families initially housed. The successful Maryland settlement followed the earlier failed 'Lincoln Colony' Anna Ella Carroll proposal for British Honduras."},{"number":4,"category":"career","header":"NYC jeweler at 167 Broadway from 1828","body":"He entered the goldsmithing and silversmithing trade c.1825 and was listed in New York City directories as a jeweler from 1828 through 1870 — operating from 167 Broadway. Major importer of diamonds and fine jewelry; also traded in mahogany and tropical woods, accumulating significant wealth over four decades."}],"number_of_marriages":2,"cross_connections":[],"bio":{"display_name":"Aaron Columbus Burr","first_name":"Aaron","last_name":"Burr","middle_name":"Columbus","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"aaron-burr-1808"},"HD1932":{"id":"HD1932","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1828},"death":{"year":1898},"parents":{"father_id":"HD1917","mother_id":"X00622"},"marriages":[],"tags":["artist"],"sources":[{"short":"Wikipedia","note":"Aaron Burr; WikiTree"}],"gender":"male","notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Aaron Hippolyte Burr","first_name":"Aaron","last_name":"Burr","middle_name":"Hippolyte","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"aaron-burr-1828"},"HD1933":{"id":"HD1933","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1831},"death":{"year":1831},"parents":{"father_id":"HD1917","mother_id":"X00622"},"marriages":[],"tags":["died_in_infancy"],"sources":[{"short":"