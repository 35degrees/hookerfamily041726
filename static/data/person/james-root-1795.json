:"Woodbury","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00254","mother_id":"I00162"},"tags":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"Pixley Family Genealogy","url":"https://www.seekingmyroots.com/members/files/G005299.pdf"},{"label":"FindAGrave","url":"https://www.findagrave.com"}],"gender":"female","number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"I00984","location_country":"United States","end_type":"death_of_spouse","end_year":1790,"children_ids":["H01260","H01261","H01262","H01263","H01264"]},{"marriage_number":2,"spouse_id":"I00985","date_year":1793,"date_month":3,"date_day":2,"location_country":"United States","children_ids":["H01265"]}],"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1841,"month":1,"day":6,"city":"Henrietta","state":"New York","country":"United States"},"cross_connections":[],"bio":{"display_name":"Abigail Hooker","first_name":"Abigail","maiden_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM497","plot_notes":"Maplewood Cemetery Henrietta Monroe County NY per FA"},"narrative_blocks":[{"number":1,"category":"character","header":"Outlived two husbands; died at Henrietta at eighty-seven","body":"Abigail Hooker Pixley buried her first husband Isaac Pixley in 1790 when she was thirty-six — left with six children, the youngest barely two — remarried James Root in 1793, bore another child, then buried Root in 1802 when she was forty-eight, and spent the next thirty-nine years a widow in Henrietta, New York, dying on January 6, 1841 at age eighty-seven. She had migrated from Woodbury, Connecticut to the Berkshire hills of Massachusetts as a young wife, and then west again to upstate New York as an old widow, the arc of her life tracking the westward movement of her entire generation — and she outlived every chapter of it, the Puritan inheritance carried through two husbands, seven children, and eighty-seven years."}],"slug":"abigail-hooker-1753"},"H00254":{"id":"H00254","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1717,"month":10,"day":30,"city":"Farmington","state":"Connecticut"},"parents":{"father_id":"H00095","mother_id":"I00130"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 254"}],"death":{"year":1796,"city":"Woodbury","state":"Connecticut"},"cross_connections":[],"marriages":[{"spouse_id":"I00162","children_ids":["H00483","H00484","H00485","H00486","H00487","H00488","H00489","H00490"],"marriage_number":1,"date_year":1746,"date_month":1,"date_day":20}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Hezekiah Hooker","first_name":"Hezekiah","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"hezekiah-hooker-1717"},"I00162":{"id":"I00162","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1723,"month":3,"day":10},"parents":{"mother_research_notes":"Susannah Parmalee Stone","father_research_notes":"Joshua Stone"},"marriages":[{"spouse_id":"H00254","children_ids":["H00483","H00484","H00485","H00486","H00487","H00488","H00489","H00490"]