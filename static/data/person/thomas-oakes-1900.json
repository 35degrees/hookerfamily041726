usiness","header":"Steamships north, coal underfoot","body":"With Charles E. Peabody he co-founded the Puget Sound & Alaska Steamship Company and ran the Roslyn Fuel Company as president — the boats and the coal of the Klondike-era Sound. He led Seattle’s Harvard Club and was dead at forty-six."}],"sources":[{"label":"Seattle Daily Times, August 25, 1911"},{"label":"FindAGrave"}],"institutions":[{"institution_id":"INST002"},{"institution_id":"INST057"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"in_law","related_id":"TD0073","display_label":"married his son Thomas in 1936"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Walter","last_name":"Oakes","married_names":[],"display_name":"Walter Oakes"},"military_service":[],"education":[{"school_name":"Phillips Academy, Andover","type":"secondary"},{"school_name":"Harvard College","dates":"1887","type":"undergraduate"}],"career":[{"role":"Co-founder","organization":"Puget Sound & Alaska Steamship Co."},{"role":"President","organization":"Roslyn Fuel Company"},{"role":"President","organization":"Harvard Club of Seattle"}],"slug":"walter-oakes-1864"}},"burialCemetery":{"id":"CEM125","name":"Cider Brook Cemetery","city":"Avon","county":"Hartford","state":"Connecticut","country":"United States","visitable":true,"hooker_connections":["I00212"],"notes":"Avon, Hartford County CT. Burial site of I00212 Thomas Fletcher Oakes."},"institutionsById":{},"crossConnections":[]}