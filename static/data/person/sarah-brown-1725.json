"male","number_of_marriages":2,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Continental Army surgeon; Old Forge, PA namesake","primary_url":"https://ca.forceswarrecords.com/memorial/630047138/william-hooker-smith","primary_url_label":"Forces War Records"},"cross_connections":[{"type":"parallel_event","related_id":"H01927","display_label":"survived the same Wyoming Massacre as a child","link_text":"Deborah Sutton Bedford"},{"type":"civic_peer","display_label":"fought at the Battle of Wyoming with judge Matthias Hollenback","related_id":"X03090","link_text":"Matthias Hollenback"},{"type":"civic_peer","display_label":"Wyoming Valley physician who soldiered with Colonel John Spalding","related_id":"X03095","link_text":"Col. John Spalding"},{"type":"civic_peer","display_label":"Wyoming Valley patriot who soldiered with General Simon Spalding","related_id":"X03106","link_text":"Gen. Simon Spalding"}],"military_service":[{"war":"American Revolutionary War","active_in_war":true,"rank":"Captain then Surgeon","notes":"3rd Co., 1st Regt CT, May 1775, Wyoming Valley PA; marched under Gen. Schuyler to NY. 1776: 10th Continental Regt CT under Col. Parsons. 1777: commissioned Captain, 24th Regt CT (Westmoreland Regt). May 27, 1778: commissioned Surgeon. Surgeon to militia under Col. Dennison, Forty Fort 1778-1779. Participated in Battle of Wyoming. Congress 1836 special act: $2,400 to heirs for war services.","war_id":"WAR004"}],"bio":{"display_name":"William Hooker Smith","notes":"Middle name \"Hooker\" explicit tribute to ancestor Thomas Hooker","first_name":"William","last_name":"Smith","middle_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"military","header":"Continental Army surgeon at Wyoming Massacre 1778","body":"He served as Surgeon in the Continental Army — 3rd Company, 1st Regiment Connecticut — and was living in the Wyoming Valley when the July 3, 1778 massacre killed approximately 300 Patriots. His first wife Sarah had died three weeks earlier."},{"number":2,"category":"death","header":"Family Bible recorded wife's death before the massacre","body":"His Oxford-printed Bible (1772) preserves the record of her death at 'about nine o'clock at night' on Friday, June 12, 1778. She was buried on his own land at Jacob's Plains two days later, three weeks before the Wyoming Massacre."},{"number":3,"category":"legacy","header":"Old Forge, Pennsylvania was named for him","body":"He and his son-in-law James Sutton founded an iron works in the Lackawanna Valley. Those who knew him called him 'old forge' — and the town of Old Forge, Pennsylvania was named for him."},{"number":4,"category":"family","header":"Lived to ninety in Tunkhannock, Pennsylvania","body":"He died July 17, 1815 in Tunkhannock, Wyoming County, Pennsylvania, age 90. He had outlived his first wife by 37 years and his second wife as well."},{"number":5,"category":"military","header":"Congress paid his heirs for his war service","body":"Decades after his death, Congress passed a special act in the 1830s granting his heirs $2,400 in commutation for his Revolutionary service as the sole surgeon at the Wilkes-Barre garrison in the Wyoming Valley."}],"slug":"william-smith-1725"},"H00745":{"id":"H00745","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1744,"month":3,"day":13},"parents":{"father_id":"H00320","mother_id":"X00284"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 745"}],"death":{"year":1783,"month":2,"day":25,"city":"Scarsdale","state":"New York"},"burial":{"plot_notes":"First Presbyterian Church Cemetery,