I; buried at Fort Snelling","body":"Fred Eggleston Strong served as a Private First Class in the United States Army during World War II and was buried at Fort Snelling National Cemetery — the military cemetery at the confluence of the Minnesota and Mississippi rivers, consecrated to Minnesota's war dead from the Civil War forward. His great-great-grandmother Dolly Goodwin Hooker had married into the Strong family in 1813; the line that passed through Milwaukee, through the newspaper rooms of Saint Paul, had arrived at a military cemetery in 1987, nine generations from Thomas Hooker of Hartford."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"fred-strong-1927"},"HD4647":{"id":"HD4647","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Robert","middle_name":"Francis","last_name":"Strong","married_names":[],"gender":"male","display_name":"Robert Francis Strong"},"birth":{"year":1928,"month":5,"day":14,"city":"Saint Paul","county":"Ramsey County","state":"Minnesota","country":"United States"},"baptism":{},"death":{"year":2004,"month":5,"day":22,"city":"Saint Paul","county":"Ramsey County","state":"Minnesota","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM450","plot_notes":"Acacia Park Cemetery Mendota Heights Dakota Co MN per FA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"generation_from_john_talcott":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD4645","mother_id":"I00926"},"number_of_marri