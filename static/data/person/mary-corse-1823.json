ick Stiles","body":"Edith Mary Louise Lyman was the only known child of Frederick Stiles Lyman and his wife Louisa. She was born July 28, 1872 in Montreal and died November 19, 1892 at age twenty in Montreal — sixteen years before her father. She was buried at Mount Royal Cemetery; her parents would later be buried near her."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"edith-lyman-1872"},"HD4179":{"id":"HD4179","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Arthur","middle_name":"Ellis","last_name":"Lyman","married_names":[],"gender":"male","display_name":"Arthur Ellis Lyman"},"birth":{"year":1846,"city":"Montréal","state":"Quebec","country":"Canada"},"baptism":{},"death":{"year":1847,"city":"Montréal","state":"Quebec","country":"Canada"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD0583","mother_id":"X01252"},"number_of_marriages":0,"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_in_infancy"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"arthur-lyman-1846"},"HD4180":{"id":"HD4180","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Susan","middle_name":"Alice","last_name":"Lyman","maiden_name":"Lyman","married_names":[],"gender":"female","display_name":"Susan Alice Lyman"},"birth":{"year":1848,"city":"Montréal","state":"Quebec","country":"Canada"},"baptism":{},"death":{"year":1853,"city":"Montréal","state":"Quebec","country":"Canada"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD0583","mother_id":"X01252"},"number_of_marriages":0,"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_in_childhood"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"susan-lyman-1848"},"HD4181":{"id":"HD4181","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Roswell","middle_name":"Corse","last_name":"Lyman","married_names":[],"gender":"male","display_name":"Roswell Corse Lyman"},"birth":{"year":1850,"city":"Montréal","state":"Quebec","country":"Canada"},"baptism":{},"death":{"year":1892,"country":"Canada"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD0583","mother_id":"X01252"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Corse","inspired_by_id":"X01252","description":"Middle name Corse carries his mother's maiden surname."}],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"roswell-lyman-1850"},"HD0587":{"id":"HD0587","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1854,"month":12,"day":21,"city":"Montréal","state":"Quebec","country":"Canada"},"death":{"year":1914,"month":5,"day":29,"state":"St. Lawrence River","country":"Canada","cause":"drowning (RMS Empress of Ireland sinking)"},"parents":{"father_id":"HD0583","mother_research_notes":"Mary Corse Lyman","mother_id":"X01252"},"prominent_name_reason":"Henry Herbert Lyman (1854-1914) — entomologist, drug company heir. Leading authority on North American Lepidoptera; published 60+ papers. Bequeathed lepidoptera collection (~20,000 specimens) and $40,000 to McGill University at his death — founding the Lyman Entomological Museum at McGill. Perished with his wife on the Empress of Ireland, May 29, 1914.","marriages":[{"marriage_number":1,"spouse_id":"X01253","date_year":1912,"date_month":3,"date_day":14,"location_city":"Manhattan","location_county":"New York County","location_state":"New York","location_country":"United States","end_type":"death","end_year":1914,"children_ids":[]}],"tags":["empress_of_ireland","canada_migration","scientist","merchant"],"sources":[{"label":"Wikipedia — Henry Herbert Lyman","url":"https://en.wikipedia.org/wiki/Henry_Herbert_Lyman"},{"label":"Lyman Entomological Museum history","url":"http://lyman.mcgill.ca/History.htm"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["business","science"],"notable_blurb":"McGill entomology bequest, perished Empress of Ireland 1914","primary_url":"https://en.wikipedia.org/wiki/Henry_Herbert_Lyman","primary_url_label":"Wikipedia — Henry Herbert Lyman"},"cross_connections":[],"education":[{"school_name":"West End Academy","type":"preparatory","notes":"Early education at West End Academy, Montreal."},{"school_name":"Montreal High School","type":"preparatory"},{"school_name":"McGill University","dates":"1872-1876","type":"undergraduate","notes":"BA McGill University 1876 with the Logan medal in geology and natural science."},{"school_name":"McGill University","dates":"1880","type":"graduate","notes":"MA McGill University 1880."}],"bio":{"display_name":"Henry Herbert Lyman","first_name":"Henry","last_name":"Lyman","middle_name":"Herbert","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778700598/Henry_Herbert_Lyman_-_Annual_report_of_the_Fruit_Growers__Association_of_Ontario__1899__1900___19176714408_ksuqy5.jpg","photo_notes":"Portrait of Henry Herbert Lyman (1854-1914) from the Annual Report of the Fruit Growers' Association of Ontario, 1899-1900."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"rank":"Major (retired)","rank_end":"Major","rank_year_start":1877,"rank_year_end":1891,"unit":"5th Battalion (5th Royal Highlanders), Canadian Voluntary Force","notes":"Served 1877-1891, retired as Major. Peacetime service."}],"burial":{"cemetery_id":"CEM328","plot_notes":"Cenotaph at Cimetière Mont-Royal Montreal — body not recovered from the St. Lawrence River. Same cemetery as wife Florence's cenotaph."},"career":[{"role":"Senior partner and President","organization":"Lymans, Clare & Co. (later Lymans Limited)","location":"Montréal","start_year":1880,"end_year":1914,"notes":"Joined the pharmacist company Lymans, Clare & Co. (Canada's largest pharmaceutical company, owned by his father Henry Lyman) after his 1880 MA. Succeeded his father as senior partner and as president of Lymans Limited at Toronto."},{"role":"Major (retired 1891)","organization":"5th Battalion, Canadian Voluntary Force (5th Royal Highlanders)","location":"Montréal","start_year":1877,"end_year":1891,"notes":"Served in the 5th Battalion of the Canadian Voluntary Force from 1877; retired as Major in 1891. Also referred to as 5th Royal Highlanders."},{"role":"Organizer","organization":"Imperial Federation League of Canada","location":"Montréal","notes":"Supported the British Empire; was an organizer of the Imperial Federation League of Canada — late-19th-century movement advocating closer political and economic union between Britain and her self-governing colonies."},{"role":"Director","organization":"Montreal General Hospital","location":"Montréal"},{"role":"Director","organization":"British and Colonial Press Service"},{"role":"President (multiple terms)","organization":"Entomological Society of Ontario (Montreal Branch)","location":"Montréal","start_year":1881,"end_year":1899,"notes":"Member since 1875. Vice president of Montreal branch 1877. President 1881 and again 1888-1899. Published over 60 papers, mainly in The Canadian Entomologist. Collected butterflies and moths primarily on the Atlantic Coast on summer holidays; took interest in rearing them. Bequest of ~20,000 specimens + entomology books + $40,000 to McGill University founded what became the Lyman Entomological Museum and Research Laboratory (moved to Quebec 1961)."}],"narrative_blocks":[{"number":1,"category":"science","header":"McGill Logan medal, Lyman Entomological Museum bequest","body":"Henry Herbert Lyman graduated McGill University in 1876 with the Logan medal in geology and natural science, and added an MA in 1880. As Canada's leading authority on North American Lepidoptera he published over sixty papers, mainly in The Canadian Entomologist. His 1914 bequest to McGill University — approximately twenty thousand insect specimens, his entomology library, and forty thousand dollars — founded what became the Lyman Entomological Museum and Research Laboratory."},{"number":2,"category":"death","header":"Drowned on delayed honeymoon, Empress of Ireland","body":"Henry Herbert Lyman cared for his ailing mother until her death and married Florence Holwell Kirkby in March 1912 at age fifty-seven. The couple finally found time to travel two years later — boarding the Empress of Ireland on May 28, 1914 for their delayed honeymoon to Europe. Early on May 29, 1914 the ship collided in the St. Lawrence River and sank in fourteen minutes; both Lymans were among the 840 passengers and 172 crew lost."}],"slug":"henry-lyman-1854"},"X01253":{"id":"X01253","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["empress_of_ireland","canada_migration"],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0587","date_year":1912,"date_month":3,"date_day":14,"location_city":"Manhattan","location_county":"New York County","location_state":"New York","location_country":"United States","end_type":"death","end_year":1914,"children_ids":[]}],"parents":{"father_name":"Rev. Lawrence Holwell Kirkby","mother_name":"Mary Glascodine Hicks Kirkby","father_research_notes":"Rev. Lawrence Holwell Kirkby (b.1848 Wirral, Cheshire, England — d.?), Church of England clergyman. Father uncertain in Wikipedia (notes 'Rev. William West Kirkby' as alternate). m. Mary Glascodine Hicks Jun 12, 1869 Mitchell Ontario. Not built per Jalapeño Rule.","mother_research_notes":"Mary Glascodine Hicks Kirkby (b.Apr 13, 1848 Mitchell Ontario — d.Jan 7, 1928 Morehead City Carteret County North Carolina). Nine other children besides Florence."},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1877,"month":4,"day":19,"city":"Nottawasaga","county":"Simcoe County","state":"Ontario","country":"Canada"},"death":{"year":1914,"month":5,"day":29,"state":"St. Lawrence River","country":"Canada","cause":"drowning (RMS Empress of Ireland sinking)"},"cross_connections":[],"bio":{"display_name":"Florence Holwell Kirkby Lyman","first_name":"Florence","last_name":"Lyman","middle_name":"Holwell","maiden_name":"Kirkby","married_names":["Lyman"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM328","plot_notes":"Cenotaph at Cimetière Mont-Royal Montreal — body not recovered from St. Lawrence."},"slug":"florence-kirkby-1877"},"HD0588":{"id":"HD0588","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1856,"month":10,"day":19,"city":"Montréal","state":"Canada East (Quebec)","country":"Canada"},"death":{"year":1938,"month":4,"day":23,"state":"Quebec","country":"Canada"},"parents":{"father_id":"HD0583","mother_research_notes":"Mary Corse Lyman","mother_id":"X01252"},"marriages":[{"marriage_number":1,"spouse_id":"HD4213","date_year":1882,"date_month":6,"date_day":28,"location_city":"Montréal","location_state":"Quebec","location_country":"Canada","end_type":"death","end_year":1938,"children_ids":["HD4219","HD4220","HD4221"]}],"tags":["canada_migration","lawyer"],"sources":[],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Albert Clarence Lyman","first_name":"Albert","last_name":"Lyman","middle_name":"Clarence","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM328","plot_notes":"Mount Royal Cemetery Montreal."},"career":[{"role":"Notary Public","organization":"Montreal","location":"Montreal, Quebec, Canada","notes":"Practiced as a notary public in Montreal."}],"narrative_blocks":[{"number":1,"category":"career","header":"Montreal notary public, lived eighty-two years","body":"Albert Clarence Lyman was born in Montreal in 1856, the sixth of Henry and Mary Corse Lyman's seven children. He practiced as a notary public in Montreal — a Quebec civil-law legal profession distinct from his father Henry's role as advocate in the Lyman Class law firm. He lived to age eighty-two, dying in 1938 and buried at Mount Royal Cemetery with his parents."},{"number":2,"category":"family","header":"First documented within-tree cousin marriage 1882","body":"Albert Clarence Lyman married Florence Anna Whitney on June 28, 1882 in Montreal — the first within-tree cousin marriage documented in the Hooker descendants project. Albert and Florence were both Hooker descendants through different children of Hannah Stiles Lyman: Albert's father Henry Lyman and Florence's grandmother Hannah Lyman Mills were siblings. Their three children carry two independent paths of descent from Thomas Hooker."}],"slug":"albert-lyman-1856"},"HD4213":{"id":"HD4213","former_ids":["X01254"],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Florence","middle_name":"Anna","last_name":"Lyman","maiden_name":"Whitney","married_names":["Lyman"],"gender":"female","display_name":"Florence Anna Whitney Lyman"},"birth":{"year":1856,"month":1,"day":10,"state":"Canada East","country":"Canada"},"baptism":{},"death":{"year":1920,"month":2,"day":4},"residence":{},"burial":{"cemetery_id":"CEM328","plot_notes":"Cimetière Mont-Royal Montreal — buried alongside husband Albert Clarence Lyman."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"X01591","mother_id":"HD0584"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0588","date_year":1882,"date_month":6,"date_day":28,"location_city":"Montréal","location_state":"Quebec","location_country":"Canada","end_type":"death","end_year":1920,"children_ids":["HD4219","HD4220","HD4221"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["canada_migration","cousin_marriage"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"First documented within-tree cousin marriage 1882","body":"Florence Anna Whitney married her first cousin once removed Albert Clarence Lyman on June 28, 1882 in Montreal — the first within-tree cousin marriage documented in the Hooker descendants project. Both were great-grandchildren of Hannah Stiles Lyman through different children: Florence Anna descended through Hannah Stiles's daughter Hannah Lyman Mills and granddaughter Hannah Jane Mills Whitney, while Albert Clarence descended through Hannah Stiles's son Henry Lyman. Their three children carry two independent paths of descent from Thomas Hooker."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"florence-lyman-1856"},"HD4219":{"id":"HD4219","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Clarence","middle_name":"Sydney","last_name":"Lyman","married_names":[],"gender":"male","display_name":"Clarence Sydney Lyman"},"birth":{"year":1884,"month":10,"day":18,"city":"Montréal","state":"Quebec","country":"Canada"},"baptism":{},"death":{"year":1960,"month":7,"day":22,"state":"Quebec","country":"Canada"},"residence":{},"burial":{"cemetery_id":"CEM328","plot_notes":"Cimetière Mont-Royal Montreal."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":fal