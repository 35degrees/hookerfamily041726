married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"military","header":"Continental Army surgeon at Wyoming Massacre 1778","body":"He served as Surgeon in the Continental Army — 3rd Company, 1st Regiment Connecticut — and was living in the Wyoming Valley when the July 3, 1778 massacre killed approximately 300 Patriots. His first wife Sarah had died three weeks earlier."},{"number":2,"category":"death","header":"Family Bible recorded wife's death before the massacre","body":"His Oxford-printed Bible (1772) preserves the record of her death at 'about nine o'clock at night' on Friday, June 12, 1778. She was buried on his own land at Jacob's Plains two days later, three weeks before the Wyoming Massacre."},{"number":3,"category":"legacy","header":"Old Forge, Pennsylvania was named for him","body":"He and his son-in-law James Sutton founded an iron works in the Lackawanna Valley. Those who knew him called him 'old forge' — and the town of Old Forge, Pennsylvania was named for him."},{"number":4,"category":"family","header":"Lived to ninety in Tunkhannock, Pennsylvania","body":"He died July 17, 1815 in Tunkhannock, Wyoming County, Pennsylvania, age 90. He had outlived his first wife by 37 years and his second wife as well."},{"number":5,"category":"military","header":"Congress paid his heirs for his war service","body":"Decades after his death, Congress passed a special act in the 1830s granting his heirs $2,400 in commutation for his Revolutionary service as the sole surgeon at the Wilkes-Barre garrison in the Wyoming Valley."}],"slug":"william-smith-1725"},"X00284":{"id":"X00284","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"i