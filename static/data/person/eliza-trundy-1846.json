act","month":5,"day":2,"city":"Stockton Springs","state":"Maine"},"parents":{"father_id":"I01765","mother_id":"HD6398"},"marriages":[{"spouse_id":"I01766","marriage_number":1,"date_year":1794,"location_city":"Prospect","location_state":"Maine","location_country":"United States","children_ids":["HD6402","HD6403","HD6404","HD6405","HD6406"]}],"tags":["revolutionary_war","author"],"burial":{"cemetery_id":"CEM887"},"notable":{"is_notable":true,"notable_category":["military","literature"],"notable_blurb":"Revolutionary War memoirist, Sappers and Miners sergeant","primary_url":"https://en.wikipedia.org/wiki/Joseph_Plumb_Martin","primary_url_label":"Wikipedia"},"narrative_blocks":[{"header":"A teenager who vowed to run to war","body":"Fifteen and eager after Lexington and Concord, Joseph Plumb Martin won his grandparents’ consent to enlist only by threatening to run off as a privateer. He joined the Connecticut Militia in June 1776 and reached New York just as the British Long Island campaign opened.","category":"military","number":1},{"header":"He cleared the way for Hamilton at Yorktown","body":"Promoted to sergeant in Washington’s new Corps of Sappers and Miners, Martin dug the entrenchments before Yorktown. During the siege his corps cleared the abatis so Alexander Hamilton’s regiment could storm Redoubt #10.","category":"military","number":2},{"header":"His memoir became history’s common soldier","body":"Published anonymously in 1830 and lost for over a century, his narrative resurfaced in the 1950s to become one of the finest primary accounts of the Revolution. Historians prize it precisely because Martin was no general but an ordinary private.","category":"literature","number":3},{"header":"A war hero who died owning nothing","body":"Settling Maine’s frontier, Martin lost a bitter land dispute to Henry Knox and was insolvent by 1818, when a $96 annual pension finally came. He served his town of Prospect as clerk for twenty-five years.","category":"legacy","number":4},{"header":"Hollywood and a marching salute remembered him","body":"In 1836 a passing platoon of Light Infantry fired a salute outside his home. He has since been portrayed by Philip Seymour Hoffman among others, and a trail around Valley Forge bears his name.","category":"legacy","number":5}],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","rank":"Sergeant","rank_start":"Private","rank_end":"Sergeant","rank_year_start":1776,"rank_year_end":1783,"unit":"8th Connecticut Regiment; Corps of Sappers and Miners","notes":"Enlisted Connecticut Militia 1776 at age 15; Continental Army 1777. Corporal in Light Infantry 1778; Sergeant in Sappers & Miners 1780. Present at Yorktown clearing abatis ahead of Hamilton’s assault on Redoubt #10."}],"education":[],"cross_connections":[{"type":"parallel_descent","related_id":"HD6412","link_text":"Capt. Samuel Sanford","display_label":"shared a Plumb grandmother, unknown to either soldier"}],"slug":"joseph-martin-1760"},"I01766":{"id":"I01766","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":null},"bio":{"display_name":"Lucy Clewley Martin","first_name":"Lucy","last_name":"Martin","married_names":[],"maiden_name":"Clewley"},"birth":{"year":1776,"date_precision":"exact","month":2,"day":24,"city":"Prospect","state":"Maine","country":"United States"},"death":{"year":1857,"date_precision":"exact","month":4,"day":30,"city":"Prospect","state":"Maine"},"parents":{"father_id":null,"mother_id":null},"marriages":[{"spouse_id":"HD6400","marriage_number":1,"date_year":1794,"location_city":"Prospect","location_state":"Maine","location_country":"United States","children_ids":["HD6402","HD6403","HD6404","HD6405","HD6406"]}],"tags":[],"burial":{"cemetery_id":"CEM887"},"slug":"lucy-clewley-1776"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}