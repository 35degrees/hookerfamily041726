tion":{"include_in_path_calculation":true,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1892,"month":10,"day":26,"city":"Peace Dale","state":"Rhode Island"},"death":{"year":1968,"month":10,"day":13,"city":"Bedford","state":"Massachusetts"},"parents":{"father_id":"X00505","mother_id":"HD1577"},"marriages":[{"spouse_id":"X00507","children_ids":["HD1584","HD1585","HD1586","HD1587","HD1588"],"marriage_number":1,"date_year":1922,"date_month":5,"date_day":20,"location_city":"Philadelphia","location_state":"Pennsylvania"}],"tags":["military","yale_connection","politician"],"sources":[],"naming_inspiration":{"name_element":"Pierrepont","inspired_by_id":"HD1577","notes":"Named \"Pierrepont\" honoring the family name of his mother Mary Pierrepont Bushnell Hazard (HD1577)."},"gender":"male","notable":{"is_notable":true,"notable_category":[]},"narrative_blocks":[{"header":"RI Treasurer, Republican Senate nominee 1948","detail":"St. George's School Newport RI; Yale B.A. 1915 (Wolf's Head). WWI service included Mexican border intervention. Solvay Process Company 1915-1923 (rising to assistant to the president). RI State Senator 1930-1932; RI State Treasurer 1938-1940. WWII: Chief, New England War Production Board priorities section 1941-1943; Civil Affairs Officer in Tunisia, Palermo, and Naples; Liaison Officer to Chief Quartermaster, US Army — played a major role in food distribution to liberated northwestern Europe. Discharged Lt. Colonel November 1945. Published \"Civil Affairs: An Experiment in Reconstruction\" (1949). His papers (20 linear feet, 1893-1979) are at the Rhode Island Historical Society (RIHS MSS 483 sg 9). (Rhode Island Historical Society; Yale; FindAGrave)","body":"Served as Rhode Island State Treasurer 1938-1940; ran as Republican nominee for US Senate 1948 (lost to Theodore F. Green). The 1948 race was the high-water mark of his political career after South Kingstown Town Council, RI State Senate, and an unsuccessful 1932 US House run.","number":1},{"number":2,"category":"military","header":"Food distributor to liberated Europe, 1944-45","body":"As Liaison Officer to the Chief Quartermaster of the U.S. Army based in England from February 1944, he played a major role in food distribution to liberated northwestern Europe. Discharged Lt. Colonel November 1945 after Tunisia, Palermo, and Naples Civil Affairs assignments."},{"number":3,"category":"scholarship","header":"Wrote a 1949 book on civil affairs reconstruction","body":"Published 'Civil Affairs: An Experiment in Reconstruction' (1949) based on his WWII Liaison Officer experience. Also co-authored a 1951 American Fisheries Society paper on modification of the sexual cycle in brook trout — his family's American Fish Culture Company connection."},{"number":4,"category":"military","header":"Cavalry on the Mexican border, 1916","body":"He enlisted Troop D 1st NY Cavalry as a private in October 1915 at twenty-three; called to active duty for the Mexican border intervention June 1916; commissioned 2nd Lt. then promoted 1st Lt. in the 14th U.S. Cavalry at Del Rio TX. Discharged February 1919 — never went overseas in WWI."}],"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Thomas Pierrepont Hazard","first_name":"Thomas","last_name":"Hazard","middle_name":"Pierrepont","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1915"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"education":[{"institution_id":"INST022","dates":"1915","notes":" — Wolf's Head Senior Society. Psi Upsilon Fraternity."}],"slug":"thomas-hazard-1892"},"X00507":{"id":"X00507","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,