iagnosis that set off a chain of events leading directly to the founding of Alcoholics Anonymous.","number":1},{"number":2,"category":"character","header":"Carl Jung told him medicine couldn’t help","body":"Jung’s 1926 verdict — that only a vital spiritual experience could save him — sent Hazard to the Oxford Group. When he later arranged Ebby Thacher’s release from a Vermont commitment, Thacher carried that message to Bill Wilson, and Alcoholics Anonymous followed; Hazard himself never joined."}],"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Rowland Hazard III","first_name":"Rowland","last_name":"Hazard","suffix":"III","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1903"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"World War I","branch":"US Army Chemical Warfare Service","rank":"Captain"}],"education":[{"institution_id":"INST022","dates":"1903"}],"career":[{"role":"State Senator","organization":"Rhode Island","start_year":1914,"end_year":1916}],"slug":"rowland-hazard-iii-1881"},"X00506":{"id":"X00506","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1889},"death":{"year":1946},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1578","children_ids":["HD1580","HD1581","HD1582","HD1583"],"marriage_number":1,"date_year":1910,"date_month":10}],"gender":"female","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Helen Hamilton Campbell","first_name":"Helen","middle_name":"Hamilton","maiden_name":"Campbell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"resea