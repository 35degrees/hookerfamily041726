ins","last_name":"Betts","married_names":[],"gender":"male","display_name":"Hon. Thaddeus Betts"},"birth":{"year":1789,"month":2,"day":4,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1840,"month":4,"day":7,"city":"Washington","county":"Washington DC","state":"District of Columbia","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM369","plot_notes":"FindAGrave. Norwalk Union Cemetery CT. Also cenotaph at Congressional Cemetery Washington DC."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["politics","law"],"notable_blurb":"Senator who died in office; President attended funeral","primary_url":"https://en.wikipedia.org/wiki/Thaddeus_Betts","primary_url_label":"Wikipedia — Thaddeus Betts"},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2797","location_country":"United States","children_ids":["HD4404"]}],"education":[{"institution_id":"INST022","dates":"1803-1807","type":"undergraduate","notes":"Yale College graduate 1807. Admitted to Connecticut bar 1810."}],"career":[{"role":"Member","organization":"Connecticut House of Representatives — Norwalk","start_year":1815,"end_year":1815,"notes":"May-Oct 1815. Served alongside Benjamin Isaacs."},{"role":"Member","organization":"Connecticut Senate (at-large)","start_year":1828,"end_year":1830},{"role":"Member","organization":"Connecticut House of Representatives","start_year":1830,"end_year":1831},{"role":"Member","organization":"Connecticut Senate — 12th District","start_year":1831,"end_year":1832},{"role":"32nd Lieutenant Governor","organization":"Colony of Connecticut","start_year":1832,"end_year":1833,"notes":"Under Gove