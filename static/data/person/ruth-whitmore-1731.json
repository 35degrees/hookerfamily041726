ding house in China through 1891. Russell & Company partner Warren Delano Jr. became the maternal grandfather of Franklin Delano Roosevelt."}],"slug":"samuel-russell-1727"},"H00848":{"id":"H00848","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00359","mother_id":"X00437"},"tags":[],"sources":[{"short":"Edward Hooker 1909","entry":"848"},{"short":"Barbour Collection, Middletown CT"}],"birth":{"year":1758},"death":{"year":1780},"gender":"female","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Ruth Russell","first_name":"Ruth","maiden_name":"Russell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ruth-russell-1758"},"H00854":{"id":"H00854","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00359","mother_id":"X00437"},"tags":[],"sources":[{"short":"Edward Hooker 1909","entry":"854"},{"short":"Barbour Collection, Middletown CT"}],"birth":{"year":1761},"death":{"year":1784},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Samuel Russell Jr.","first_name":"Samuel","last_name":"Russell","suffix":"Jr.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"mil