sborough Massachusetts by 1790 — the year of the first US Census, which shows him already living there. He married Tirzah Platt that August in her hometown and they raised ten children in Lanesborough. He died there in 1848 at eighty-two."},{"number":2,"category":"death","header":"Died three months after his wife","body":"Tirzah Platt Talcott died in Lanesborough on July 14, 1848 at seventy-seven. Capt. Nehemiah followed her exactly three months later on October 13, 1848 at eighty-two. They were buried together in Talcott Cemetery — the Lanesborough burying ground that bore the family name."}],"slug":"nehemiah-talcott-1766"},"X01834":{"id":"X01834","has_descendants_documented":false,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"EH 1909"}],"gender":"unknown","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"T01390","date_year":1790,"date_month":8,"date_day":10,"location_city":"Lanesborough","location_county":"Berkshire","location_state":"Massachusetts","location_country":"United States","end_type":"death","end_year":1848,"children_ids":["T01469","T01470","T01471","T01472","T01474","T01475","T01473","T01476","T01477","T01478"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1771,"month":3,"day":30,"city":"Lanesborough","county":"Berkshire","state":"Massachusetts","country":"United States"},"death":{"year":1848,"month":7,"day":14,"city":"Lanesborough","county":"Berkshire","state":"Massachusetts","country":"United States"},"cross_connections":[],"bio":{"display_name":"Tirzah Platt Talcott","first_name":"Tirzah","last_name":"Talcott","maiden_name":"Platt","married_names":["Talcott"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM198","plot_notes":"Talcott Cemetery, Lanesborough, Berkshire County MA. FindAGrave 112083228."},"narrative_blocks":[{"number":1,"category":"family","header":"Brought her husband to her hometown","body":"Tirzah Platt was born in Lanesborough Massachusetts in 1771. When she married Capt. Nehemiah Talcott in August 1790 he had already migrated west from Glastonbury Connecticut and was living in Lanesborough by the time of the Census. She gave him ten children and never left her hometown — dying there in July 1848."}],"slug":"tirzah-platt-1771"},"T01001":{"id":"T01001","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":4,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1732,"month":7,"day":23,"city":"Glastonbury","state":"Connecticut"},"death":{"year":1780,"city":"Glastonbury","state":"Connecticut"},"parents":{"father_id":"T00458","mother_id":"U00041"},"marriages":[{"children_ids":["T01387","T01388","T01389","T01390"],"spouse_id":"U00042","marriage_number":1,"end_type":"death_of_spouse","date_year":1757},{"children_ids":[],"spouse_id":"U00043","marriage_number":2}],"open_questions":[],"sources":[{"short":"Talcott 1876","page":"Entry 1001"}],"compiler_ancestor":true,"compiler_connection":{"notes":"T01001 Samuel is the compiler's gen 4 Talcott ancestor. His son T01389 Samuel married Abigail Pantry Hooker — the key Hooker-Talcott intersection.","path":"T01001 → T01389 Samuel × Abigail Pantry Hooker → H01789 Seth → H03203 John Butler → Florence → Helen → Lea → compiler"},"primary_residence":{"city":"Glastonbury","state":"Connecticut","notes":"Born Glastonbury 1733; died there 1780."},"gender":"male","tags":[],"number_of_marriages":2,"notable":{"is_notable":true,"notable_category":["military","history"],"notable_blurb":"Great-grandfather of Adm. George Dewey of Manila Bay","primary_url":"https://www.findagrave.com/memorial/61929162/samuel-talcott","primary_url_label":"FindAGrave — Col. Samuel Talcott"},"cross_connections":[{"type":"event_overlap","related_id":"X00049","display_label":"Both buried in rubble of the 1766 schoolhouse explosion","link_text":"Levi Jones"}],"bio":{"display_name":"Col. Samuel Talcott","first_name":"Samuel","last_name":"Talcott","title":"Colonel","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777610222/colsamueltalcott_zzmsgg.jpg","photo_notes":"Portrait. Cloudinary."},"residence":{"city":"Glastonbury","county":"Hartford","state":"Connecticut","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","rank":"Colonel","rank_end":"Colonel","rank_year_end":1780,"unit":"Connecticut militia (precise unit pending)","notes":"FindAGrave Old Eastbury memorial designates him 'Col Samuel Talcott Veteran.' Active in the Revolutionary War period; died Glastonbury CT 16 March 1780, mid-war, leaving his fifteen-year-old son Samuel (T01389) without a father."}],"burial":{"cemetery_id":"CEM173","plot_notes":"Old Eastbury Cemetery, Glastonbury CT. FindAGrave 61929162. Stone surviving intact."},"narrative_blocks":[{"number":1,"category":"military","header":"Revolutionary War colonel from Glastonbury","body":"Samuel served as a Connecticut militia Colonel in the Revolutionary War — the rank by which his Old Eastbury Cemetery memorial designates him 'Col Samuel Talcott Veteran.' He was the third generation of Talcott military service, his father Capt. Samuel having served in the Connecticut militia of the colonial era and his ancestor Capt. Samuel Talcott having commanded Connecticut dragoons at Deerfield in 1690."},{"number":2,"category":"family","header":"Four children by Mary, none by Sarah","body":"Samuel married Mary Smith of Hartford in 1757; she bore him Mary, Hannah, Samuel, and Capt. Nehemiah before her 1770 death at thirty-seven. He remarried Sarah (surname not preserved); she had no children with him and outlived him."},{"number":3,"category":"death","header":"Died mid-Revolution leaving two young sons","body":"Samuel died in Glastonbury on 16 March 1780 at age 47, squarely in the middle of the Revolutionary War he had served. Sons Samuel and Nehemiah were just fifteen and thirteen at his death; older daughters Mary and Hannah were already grown. His Glastonbury gravestone survives intact at Old Eastbury Cemetery: 'In Memory of Mr. Samuel Talcott who departed this life March 16th, 1780 Aged 47 years.'"},{"number":4,"category":"family","header":"Descended from the Deerfield dragoon commander","body":"Samuel's ancestor Capt. Samuel Talcott (b.1635) commanded the Connecticut dragoons at Deerfield Massachusetts at the outbreak of King William's War in 1690. That ancestor's father had served as deputy governor of Connecticut Colony in 1637 and as the colony's treasurer through the 1650s. Three generations of Talcott civic and military service stand between Col. Samuel and the colony's founding."},{"number":5,"category":"legacy","header":"Great-grandfather of the Manila Bay admiral","body":"Samuel's great-grandson Admiral George Dewey commanded the U.S. fleet at the Battle of Manila Bay in May 1898, sinking all eight Spanish ships with no American deaths and only eight wounded. The Talcott military line continued forward from Samuel's Revolutionary service through three generations to one of the most decisive naval victories in American history."},{"number":6,"category":"character","header":"Survived the 1766 Hartford schoolhouse explosion","body":"On 23 May 1766 he was among twenty-eight men buried in the rubble when the Hartford schoolhouse exploded — gunpowder ignited during the town's Stamp Act repeal celebration. He survived with severe burns to his face and arms; six others, including Levi Jones, did not."}],"slug":"samuel-talcott-1732"},"U00042":{"id":"U00042","has_descendants_documented":false,"in_talcott_book":false,"visible_default":false,"classification":{"is_talcott_descendant":false,"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1733,"city":"Hartford","county":"Hartford","state":"Connecticut","country":"United States","note":"Per family source: 'Mary was born in 1733 in Hartford, CT'"},"death":{"year":1770,"city":"Glastonbury","county":"Hartford","state":"Connecticut","country":"United States"},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"T01001","date_year":1757,"end_type":"death_of_spouse","children_ids":["T01387","T01388","T01389","T01390"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Smith","first_name":"Mary","maiden_name":"Smith","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-smith-1733"}},"burialCemetery":{"id":"CEM198","name":"Talcott Cemetery","city":"Lanesborough","county":"Berkshire","state":"Massachusetts","country":"United States","lat":42.53106,"lng":-73.23031,"visitable":true,"primary_url":"https://www.findagrave.com/cemetery/91764/talcott-cemetery","hooker_connections":["T01390","T01471","T01473","T01474","T01475","T01478","T01479","T01480","T01481","T01482","T01483","T01484","T01485","T01496","T01497","T01498","T01499","T01500","X01834","X01881","X02443","X02445"],"notes":"Talcott Cemetery, Lanesborough, Berkshire County MA. The named family burying ground of the Capt. Nehemiah Talcott line in Lanesborough. Capt. Nehemiah migrated from Glastonbury CT around 1790 and the cemetery preserves three generations of his family. GPS 42.53106, -73.23031."},"institutionsById":{},"crossConnections":[]}