[]},"cross_connections":[],"bio":{"display_name":"Dr. William Hooker","first_name":"William","last_name":"Hooker","title":"Dr.","married_names":[]},"residence":{"city":"Westhampton","county":"Hampshire","state":"Massachusetts","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"is_placeholder":false,"burial":{"cemetery_id":"CEM544"},"education":[],"career":[{"role":"Physician","location":"Westhampton, Hampshire County, Massachusetts","notes":"Practiced medicine at Westhampton MA per EH 1909 #529. Established the Hooker physician tradition in Westhampton continued by son Dr. Anson Hooker (H01414, 1799-1869) and through several Westhampton descendants."},{"role":"Trader / Merchant","location":"Westhampton, Hampshire County, Massachusetts","notes":"Per EH 1909 #529: 'He was a physician and also a trader at West Hampton, Mass.' — supplementing physician income with a trading operation, common pattern for rural New England doctors of the period."}],"narrative_blocks":[{"number":1,"category":"career","header":"Lived to ninety-four as Westhampton physician","body":"Born Northampton MA 1766; died Westhampton MA February 27, 1861 at age ninety-four — extraordinary longevity spanning the early Republic through the Civil War's outbreak. Practiced medicine in Westhampton MA and also operated as a trader; both occupations supported a large family of seven children with first wife Anna Thompson before her 1810 death."},{"number":2,"category":"family","header":"Lost wife at forty-two, remarried after two years","body":"First wife Anna Thompson died Westhampton April 2, 1810 at age forty-two — leaving him with seven children ranging from twenty-four-year-old Henry down to eight-year-old Edward. William remarried 1812 to Rhoda Phelps, widow of Ensign Hartland of Hartland Connecticut. No documented children from the second marriage; Rhoda predeceased William by fourteen years."}],"former_ids":[],"slug":"william-hooker-1766"},"I01155":{"id":"I01155","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Anna","last_name":"Hooker","maiden_name":"Thompson","married_names":["Hooker"],"gender":"female","display_name":"Anna Thompson Hooker"},"gender":"female","birth":{"year":1768,"month":2,"day":25,"county":"Hartford","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1810,"month":4,"day":2,"city":"Westhampton","county":"Hampshire","state":"Massachusetts","country":"United States"},"residence":{"city":"Westhampton","county":"Hampshire","state":"Massachusetts","country":"United States"},"burial":{"cemetery_id":"CEM544"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Hugh Thompson of East Windsor CT (per EH 1909 #529)","father_research_notes":"Per Edward Hooker 1909 #529: 'm. 1798 [sic — likely 1788], Anna Thompson, daughter of Hugh Thompson of East Windsor, Conn.' EH date '1798' may be transcription error; her 1786 first child suggests marriage 1785-86. Hugh Thompson East Windsor specific parentage not yet built."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00529","date_year":1788,"location_country":"United States","end_type":"death","end_year":1810,"children_ids":["H01409","H01410","H01411","H01412","H01413","H01414","H01415"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"tragedy","header":"Died age forty-two leaving seven children","body":"Died Westhampton MA April 2, 1810 at age forty-two — leaving seven children ranging from twenty-four-year-old Henry down to eight-year-old Edward. Her son middle-named for her father Hugh Thompson (Hugh Thompson Hooker, born 1789) carries the East Windsor Connecticut Thompson family name forward."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"anna-thompson-1768"},"H00264":{"id":"H00264","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"compiler_ancestor":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1729,"month":3,"day":19,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1777,"month":2,"day":6,"city":"Northampton","county":"Hampshire","state":"Massachusetts","country":"United States","cause":"smallpox"},"parents":{"father_id":"H00098","mother_id":"I00041"},"tags":["compiler_ancestor","yale_graduate","clergy","minister","epidemic_death"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 264"}],"marriages":[{"spouse_id":"I00043","children_ids":["H00524","H00525","H00526","H00527","H00528","H00529","H00530","H00531","H00532"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1777,"date_year":1755,"date_month":12,"date_day":10,"location_country":"United States"}],"compiler_ancestor":true,"ministry_positions":[{"role":"Minister","location":"Northampton, Massachusetts","dates":"1753-1777","duration_years":24,"notes":"Ordained Dec 5, 1753; settled there 24 years until death by smallpox"}],"ordination":{"date":{"year":1753,"month":12,"day":5},"location":"Northampton, Massachusetts"},"primary_residence":{"city":"Northampton","state":"Massachusetts","notes":"Minister here 24 years 1753-1777. Yale 1751, ordained Dec 5, 1753."},"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"religion","header":"Took Jonathan Edwards' Northampton pulpit, died of smallpox","body":"Ordained in 1753, he became pastor at Northampton, Massachusetts — the church where Jonathan Edwards had preached until his dismissal in 1750. He held that pulpit for nearly 25 years, dying of smallpox on February 6, 1777, in his 48th year. His was the most prominent pastoral appointment held by any Hooker descendant of his generation."},{"number":2,"category":"family","header":"His wife's father, Colonel Worthington, named Worthington Parish","body":"He married Sarah Worthington, daughter of Colonel Worthington of Springfield, Massachusetts — the man who gave his name to Worthington Parish in Berlin, Connecticut, the parish where the Hart and Hooker families had long been prominent. The marriage connected the Hooker line to one of western Massachusetts's most distinguished families."},{"number":1,"category":"death","header":"Smallpox took the Northampton pastor at forty-seven","body":"He served as pastor of the Northampton MA Congregational Church from 1753 until smallpox killed him in February 1777 at forty-seven. His daughter Sarah Hooker married the Northampton lawyer Caleb Strong nine months later — passing the Hooker name into the family of a future Massachusetts Governor and U.S. Senator."}],"cross_connections":[{"type":"civic_connection","related_id":"H00379","display_label":"Edwards's daughter refused his pulpit and her chair sat in the vestibule.","link_text":"Mary Edwards Dwight"}],"education":[{"degrees":[{"degree":"B.A.","year":1751}],"notes":"Yale College class of 1751","degree":"B.A.","school_name":"Yale College","graduation_year":1751,"institution_id":"INST022"}],"bio":{"display_name":"Rev. John Hooker","title":"Reverend","first_name":"John","last_name":"Hooker","married_names":[]},"landmarks":[],"residence":{"city":"Northampton","state":"Massachusetts","country":"United States"},"baptism":{},"resear