],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elizabeth-edwards-1857"},"HD2637":{"id":"HD2637","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2636","mother_id":"X00889"},"tags":[],"sources":[{"short":"EH 1909; Online vital records; Yale biographical sketches"}],"birth":{"year":1862,"month":11,"day":28,"city":"Stonington","county":"New London County","state":"Connecticut","country":"United States"},"death":{"year":1938,"month":6,"day":10,"city":"Stonington","county":"New London County","state":"Connecticut","country":"United States"},"gender":"male","number_of_marriages":2,"marriages":[],"notable":{"is_notable":true,"notable_category":["legacy","history"],"notable_blurb":"Last male descendant of Jonathan Edwards; bequeathed portraits"},"burial":{"cemetery_id":"CEM045"},"artworks":["ART022"],"narrative_blocks":[{"header":"The last male Edwards descendant","detail":"The portraits — Jonathan Edwards and Sarah Pierpont by Joseph Badger, Jonathan Edwards Jr. by Reuben Moulthrop, Jonathan Walter Edwards and Elizabeth Tryon Edwards by Gerritt Schipper (1805), Eugene Edwards and Martha Ellen Phelps by George Whiting Flagg — were loaded into a station wagon and driven to the Yale Art Gallery. That same night, the Great Hurricane of 1938 struck. The hurricane killed hundreds across New England and devastated coastal Connecticut. Stone Acres, the ancestral mansion built by Charles Phelps in 1765, survived. The portraits, now hung in Jonathan Edwards College dining hall and Fellows' Room, were saved by hours. (The Record LXXI; New York Times, Nov. 3, 1938; Yale University)","body":"Eugene Phelps Edwards (1862-1938) of Stonington CT was the last direct male lineal descendant of Rev. Jonathan Edwards. In 1933, charmed that Yale had named a college after his ancestor, he wrote to offer the family portraits and manuscripts. Five years later, following his death in June 1938, a Yale representative drove to Stone Acres mansion in Stonington to collect the portraits.","number":1},{"number":2,"category":"arts","header":"The portraits reached Yale as the hurricane struck","body":"By family account, the 1740 Badger portraits of Jonathan Edwards and Sarah Pierpont — his bequest — were carried to Yale the day the Great Hurricane of 1938 bore down on New England. They hang today in the Jonathan Edwards College dining hall."}],"cross_connections":[],"bio":{"display_name":"Eugene Phelps Edwards","first_name":"Eugene","last_name":"Edwards","middle_name":"Phelps","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"quotes":[],"military_service":[],"slug":"eugene-edwards-1862"}},"burialCemetery":{"id":"CEM045","name":"Evergreen Cemetery","city":"Stonington","county":"New London County","state":"Connecticut","country":"United States","lat":41.3494,"lng":-71.9022,"visitable":true,"notes":"Burial place of Rev. John Erskine Edwards (HD2631), Ann R. Hammond Edwards (X01927), and Erskine Mason Phelps (X01928).","sources":[],"hooker_connections":["HD2631","HD2636","HD2637","X00889","X01927","X01928"]},"institutionsById":{},"crossConnections":[]}