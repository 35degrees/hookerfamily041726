ercer County","state":"New Jersey"},"parents":{"father_id":"X00518","mother_id":"HD1630"},"marriages":[{"marriage_number":1,"spouse_id":"I00176","end_type":"death_of_spouse","end_year":1994,"children_ids":["HD3136","HD3137","HD3138"],"date_year":1926,"date_month":1,"date_day":1}],"tags":["politician","diplomat","lawyer","author","harvard_graduate"],"sources":[{"label":"Wikipedia — Abbot Low Moffat","url":"https://en.wikipedia.org/wiki/Abbot_Low_Moffat"}],"gender":"male","notable":{"is_notable":true,"notable_category":["politics","diplomacy","author"],"notable_blurb":"Head of State Dept SE Asia Division 1944-47","primary_url":"https://en.wikipedia.org/wiki/Abbot_Low_Moffat","primary_url_label":"Wikipedia"},"number_of_marriages":1,"institutions":[{"institution_id":"INST002","institution_blurb":"Harvard University class of 1923."},{"institution_id":"INST063","institution_blurb":"Columbia University Law School class of 1926."}],"narrative_blocks":[{"header":"He warned Washington not to back France","body":"As head of the State Department's Division of Southeast Asian Affairs 1944-1947, Abbot Low Moffat was the point man on Indochina policy. He knew Ho Chi Minh, detailed FDR's vision for a post-colonial Indochina, and forcefully opposed the decision to back the French in their attempt to retake the colony after WWII. Under Truman, the State Department reversed course.","number":1},{"header":"He sponsored legislation to build the New York","body":"Abbot Low Moffat served in the New York State Assembly from 1929 to 1943, where he sponsored the legislation that authorized the New York State Thruway. He went on to serve as a diplomat at posts in Greece, the United Kingdom, Burma, and Ghana. He also published a biography of King Mongkut of Siam in 1961 and genealogical works on the Low and Pierrepont family lines.","number":2},{"header":"He compiled the Pierrepont genealogy","body":"In 1962, Abbot Low Moffat published The Pierreponts, 1802-1962, tracing the American forebears and descendants of Hezekiah Beers Pierpont and Anna Maria Constable. The Pierrepont family is central to the Hooker tree: Rev. James Pierpont, great-grandson of Mary Hooker Pierpont, co-founded Yale in 1701. Moffat's Pierrepont genealogy — compiled by a Hooker descendant — is a primary research source for this project.","number":3}],"cross_connections":[],"bio":{"display_name":"Ambassador Abbot Low Moffat","first_name":"Abbot","last_name":"Moffat","middle_name":"Low","title":"Ambassador","married_names":[],"photo_url":"https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcR5tg4syKJuBQ-DBgzaH01FlLpuvzUj8i0XktqF1-j79_MRsEuEq9BY9QJ7L7KvxeAb1wHj6Q&s"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"abbot-moffat-1901"},"HD3136":{"id":"HD3136","is_placeholder":false,"gender":"female","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"generation_from_thomas":11,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1931,"month":2,"day":28,"city":"New York","state":"New York"},"death":{"year":2021,"month":12,"day":10,"city":"Skillman","county":"Somerset County","state":"New Jersey"},"burial":{"cemetery_id":"CEM097","plot_notes":"Jay Family Cemetery, Rye NY — interred spring 2022"},"parents":{"father_id":"HD1641","mother_id":"I00176"},"marriages":[],"tags":["educator","environmentalist"],"sources":[{"label":"Jay Heritage Center — Remembering Jane-Kerin Moffat","url":"https://jayheritagecenter.org/2022/01/09/remembering-jane-kerin-moffat-1931-2021/"}],"notable":{"is_notable":true,"notable_category":["social_reform","education"],"notable_blurb":"Saved John Jay's estate from demolition","primary_url":"https://jayheritagecenter.org/2022/01/09/remembering-jane-kerin-moffat-1931-2021/","primary_url_label":"Jay Heritage Center"},"narrative_blocks":[{"header":"She saved her ancestor John Jay's childhood home","body":"Jane-Kerin Moffat was a direct descendant of John Jay, first Chief Justice of the United States. In the 1980s, the 23-acre Jay Estate in Rye, New York — where Jay had spent his childhood — was slated for development. She spent thirteen years rallying 65 environmental, historic, and government groups into the Jay Coalition.","number":1},{"header":"She coordinated 180 organizations to protect Long Island","body":"As coordinator of the National Audubon Society's Long Island Sound Watershed Alliance, Jane-Kerin Moffat organized over 180 groups and held hearings along the Connecticut and New York coastline to document the degradation of the Sound. She co-authored the resulting report and convened a Citizens Summit that drew 200 environmentalists and legislators from both states. The National Audubon Society gave her its Audubon Activist Award and published a feature article about her in 2000.","number":2}],"cross_connections":[],"bio":{"display_name":"Doctor Jane-Kerin Moffat","first_name":"Jane-Kerin","last_name":"Moffat","maiden_name":"Moffat","married_names":[],"title":"Doctor"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"jane-kerin-moffat-1931"},"HD3137":{"id":"HD3137","is_placeholder":false,"gender":"male","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"generation_from_thomas":11,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{},"death":{},"parents":{"father_id":"HD1641","mother_id":"I00176"},"marriages":[],"tags":[],"sources":[{"short":"FindAGrave"}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Burnham M