ld by the Vermont Historical Society."},{"number":2,"category":"family","header":"Outlived two wives and reached ninety-one","body":"Justus's first wife Arethusa Hosford died in 1855 at age thirty, leaving him with two young daughters. He remarried in 1858 to Mary Wild and had five more children. He lived to ninety-one and is buried at Berlin Corner Cemetery alongside generations of his Perrin and Talcott ancestors."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"justus-perrin-1822"},"X02409":{"id":"X02409","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Arethusa","middle_name":"Rosette","last_name":"Perrin","maiden_name":"Hosford","married_names":["Perrin"],"gender":"female","display_name":"Arethusa Rosette Hosford Perrin"},"birth":{"year":1824,"month":9,"day":1,"city":"Thetford","county":"Orange","state":"Vermont","country":"United States"},"baptism":{},"death":{"year":1855,"month":3,"day":27,"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM176","plot_notes":"Berlin Corner Cemetery, Berlin Corners, Vermont — alongside her husband Justus Newton Perrin (TD0200)."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Jared Hosford","mother_name":"Jemima Kinney","father_research_notes":"Jared Hosford. Not built — does not auto-qualify under Jalapeño Rule (no national notability). Per WikiTree Hosford-365.","mother_research_notes":"Jemima Kinney. POSSIBLE FAMILY CONNECTION: Jemima's Kinney maiden name and Plainfield-VT-region origin overlaps the Kinney family of Rev. Jonathan Kinney of Plainfield VT