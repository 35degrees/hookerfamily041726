ody":"Porter was born February 1, 1790, less than a year after his parents Zachariah Perrin and Mary Talcott Perrin migrated by ox-sled from Hebron, Connecticut, to settle the eastern frontier of Berlin. He married Lucy Kinney of Plainfield in November 1815, lived his entire life in Berlin, and died there in May 1871 at age eighty-one."},{"number":2,"category":"family","header":"Distributed his fortune to charity and his children","body":"Porter accumulated more property in farming than any other man before him in Berlin, according to the 1881 Vermont Historical Gazetteer. He gave a large share to charitable and religious purposes during his lifetime, distributed much of the rest among his many children, and left enough for his widow's support to her death."}],"quotes":[],"sources":[{"short":"Talcott 1876","page":"Entry 1395"}],"research_sources":[],"documents":[],"slug":"porter-perrin-1790"},"TD0200":{"id":"TD0200","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Justus","middle_name":"Newton","last_name":"Perrin","married_names":[],"gender":"male","display_name":"Justus Newton Perrin"},"birth":{"year":1822,"month":11,"day":21,"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"baptism":{},"death":{"year":1914,"month":1,"day":29,"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"residence":{"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"burial":{"cemetery_id":"CEM176","plot_notes":"Berlin Corner Cemetery, Berlin Corners, Vermont."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":8,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parent