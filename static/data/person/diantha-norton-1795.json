hire","location_state":"Massachusetts"},{"marriage_number":2,"spouse_id":"X02573","location_country":"United States","children_ids":[]},{"marriage_number":3,"spouse_id":"X02574","location_country":"United States","end_type":"death","end_year":1845,"children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["massachusetts_migration","new_york_migration","vermont_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Wife died three days after twins born","body":"Bela Norton's first wife Lydia Bushnell gave birth to unnamed twins on March 17, 1813. She died three days later on March 20 — strongly suggesting complications from the birth. Bela went on to marry Mary Paine and then Mary Ann Mulliken."},{"number":2,"category":"migration","header":"Migrated west to Mexico New York","body":"Bela Norton was born in East Guilford CT in 1772 but ended his life two thousand miles away — in Mexico, Oswego County, New York, where he died in June 1845 at age seventy-two. The migration date is not documented; he had spent his early married years in Connecticut."},{"number":3,"category":"migration","header":"Migrated four states across his lifetime","body":"Bela Norton's life traced the New England westward migration in four stages: born in Connecticut in 1772; married Lydia Bushnell in Cheshire, Massachusetts in 1794; raised his children in Addison, Vermont where Lydia died 1813; ultimately died in Mexico, Oswego County, New York in 1845. His remains appear to have been returned to Vermont — buried Hindes Cemetery, Addison."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"bela-norton-1772"},"X02572":{"id":"X02572","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Lydia","last_name":"Norton","maiden_name":"Bushnell","married_names":["Norton"],"gender":"female","display_name":"Lydia Bushnell Norton"},"birth":{"year":1772,"month":11,"day":30,"city":"Saybrook","county":"New London","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1813,"month":3,"day":20,"country":"United States","city":"Addison","county":"Addison","state":"Vermont"},"residence":{},"burial":{"cemetery_id":"CEM203","plot_notes":"Hindes Cemetery, Addison, Addison County VT. FindAGrave."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01050","date_year":1794,"date_month":3,"date_day":18,"location_country":"United States","end_type":"death","end_year":1813,"children_ids":["H02163","H02164","H02165","H02166","H02167","H02168","HD3482","HD3483","H02169","H02170","H02171","HD3484"],"location_city":"Cheshire","location_state":"Massachusetts"}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_in_childbirth"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Saybrook bride who died on the Vermont frontier","body":"Lydia Bushnell was born in Saybrook on the Connecticut shore in November 1772 and married Bela Norton at age twenty-one in Cheshire MA. They raised at least twelve children in Vermont, including unnamed twins born March 17, 1813. Lydia died three days after the twins' birth — almost certainly from childbirth complications — at age forty in Addison VT."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"lydia-bushnell-1772"},"H00401":{"id":"H00401","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1744,"month":1,"day":15,"city":"Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"parents":{"father_id":"I00148","mother_id":"H00126"},"tags":["replacement_naming"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 401"}],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02569","date_year":1762,"location_city":"Guilford","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1806,"children_ids":["H01046","H01047","H01048","H01049","H01050","H01051","H01052","H01053","H01054","H01055","H01056"],"location_county":"New Haven"}],"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1827,"month":7,"day":17,"city":"Madison","county":"New Haven","state":"Connecticut","country":"United States"},"cross_connections":[],"bio":{"display_name":"Hooker Norton","notes":"Replacement naming after first Hooker Norton (H00399) died Sep 29, 1742","first_name":"Hooker","last_name":"Norton","suffix":"No. 2","married_names":[],"gender":"male","extra_names":"Called 'No. 2' in EH 1909 because his elder brother Hooker Norton (H00399, b. 1741) had received the same name — the elder Hooker presumably died young and the parents reused the name in 1744."},"residence":{"city":"East Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Given his deceased elder brother's name","body":"Hooker Norton was the SECOND son of Reuben and Hannah Hooker Norton to be given the name Hooker. The first (, b. 1741) presumably died young. Three years later when this son was born in 1744 the parents reused the Hooker name — a common eighteenth-century replacement-naming pattern that EH itself notes by labeling him 'No. 2.'"},{"number":2,"category":"family","header":"Eleven children five died young","body":"Hooker and Sibyl Bradley Norton had eleven documented children. Five died in infancy or childhood: Daniel Hooker at nine months in 1764; Russell at age six in 1774; Hannah at age eight in 1787; a second Russell at age eleven in 1795; and Zenas at age nine that same year. The 1795 deaths of Russell and Zenas in the same year hint at an epidemic."},{"number":3,"category":"death","header":"Lived eighty-three years through three wars","body":"Hooker Norton was born in colonial Connecticut on January 15, 1744 — age eleven at the start of the French and Indian War, age thirty-two when Independence was declared. He outlived the Revolutionary War, the War of 1812, and his wife Sibyl by twenty-one years. He died July 17, 1827 in Madison CT at eighty-three."}],"slug":"hooker-norton-1744"},"X02569":{"id":"X02569","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Sibyl","last_name":"Norton","maiden_name":"Bradley","married_names":["Norton"],"gender":"female","display_name":"Sibyl Bradley Norton"},"birth":{"year":1745,"month":3,"day":29,"city":"Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1806,"month":5,"day":4,"city":"Sunderland","county":"Bennington","state":"Vermont","country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Joseph Bradley","mother_name":"Sibyl Meigs Bradley","father_research_notes":"Joseph Bradley of Vergennes VT. Per EH 1909 entry 401.","mother_research_notes":"Sibyl Meigs Bradley of Vergennes VT. Per EH 1909 entry 401."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00401","date_year":1762,"location_city":"Guilford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1806,"children_ids":["H01046","H01047","H01048","H01049","H01050","H01051","H01052","H01053","H01054","H01055","H01056"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"migration","header":"Family migrated to Vermont before her death","body":"Sibyl Bradley Norton was born in Guilford CT in 1745 and married Hooker Norton there in 1762 at seventeen. By her 1806 death the family had migrated to Sunderland, Bennington County, Vermont — establishing that the Hooker Norton household made the New England westward move sometime between 1786 (when her youngest son Zenas was born in CT) and 1806. Her husband Hooker returned to Madison CT to die in 1827."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"sibyl-bradley-1745"}},"burialCemetery":{"id":"CEM137","name":"West Side Cemetery","city":"Guilford","county":"New Haven","state":"Connecticut","country":"United States","visitable":true,"hooker_connections":["H02164","I00247","T02264","T02271","T02272","X02579","X03244","X03246","X03247","X03248","X03251","X03253","X03254","X03276"],"notes":"Guilford, New Haven County CT. Burial site of T02264 Dr. Alvan Talcott Jr. (1804-1891) and I00247 Olive Chittenden Talcott.","gps":{"latitude":41.28688,"longitude":-72.69158}},"institutionsById":{},"crossConnections":[]}