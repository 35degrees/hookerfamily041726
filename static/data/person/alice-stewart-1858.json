ther_id":"H00483","mother_id":"I00756"},"number_of_marriages":1,"marriages":[{"marriage_number":2,"spouse_id":"I00759","date_year":1814,"date_month":1,"date_day":7,"location_country":"United States","children_ids":["HD4445","HD4446","HD4447","H02368","HD4448","HD4449","H02370"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Married her late sister's husband; bore explorer-named twins","body":"Fourteen months after her sister Louisa's death — just twenty-four days into Louisa's marriage to Burnham Phelps — Mary Deming Hooker married Burnham herself on January 7, 1814, the practice of marrying a deceased wife's sister recognized in New England as a form of family continuity. Among their eight children were twins born July 7, 1823 named Christopher Columbus and Americus Vespusius — honoring both Atlantic explorers in a single act of naming, though Americus died at age three in 1826."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909), entries 483–2370","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"mary-phelps-1792"}},"burialCemetery":{"id":"CEM421","name":"Wenatchee City Cemetery","location":{"city":"Wenatchee","county":"Chelan County","state":"Washington","country":"United States"},"url":"https://www.findagrave.com/cemetery/1053458/wenatchee-city-cemetery","hooker_connections":["HD4477","I00845","HD4572","I00862","HD4580"]},"institutionsById":{},"crossConnections":[]}