ntry 275"},{"short":"Hart Genealogy (1948 ed.)"}],"marriages":[{"children_ids":["H00565","H00566","H00567","H00567a","H00568","H00569"],"spouse_id":"X01030","marriage_number":1,"end_type":"death_of_spouse","end_year":1785,"date_year":1760,"date_month":11,"date_day":20,"location_city":"Farmington","location_state":"Connecticut"},{"children_ids":["HD0754"],"spouse_id":"X01031","marriage_number":2,"date_year":1785,"date_month":9,"date_day":25}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"Lieutenant while his brother Selah was a General","detail":"The Hart family of Kensington had deep military roots: their father Nathaniel Hart (I00028) had married Abigail Hooker in 1719 in one of the three simultaneous Hart-Hooker marriages. A third brother, Rev. Asahel Hart (H00276, Yale 1764), became the first pastor of North Canaan Congregational Church — the three Hart brothers who survived to adulthood representing military service, Congregationalist ministry, and civic life respectively. Noadiah was appointed administrator of the estate of Jonathan Hurlbut Jr. in October 1761, confirming his standing in the Kensington community. (EH 1909; Hart Genealogy 1948)","body":"Noadiah Hart served as a Lieutenant in the American Revolutionary War while his older brother Selah Hart rose to General in the Connecticut Militia — captured by the British in September 1776 during the New York retreat. Both were sons of Nathaniel Hart × Abigail Hooker, 4th-generation descendants of Thomas Hooker. Noadiah served through the war, became a Deacon in the Harwinton church by 1804, and died in Southington in 1817 at 80.","number":1},{"number":2,"category":"religion","header":"Deacon of Harwinton church; lived to 80","body":"After the war, he became Deacon of the church in Harwinton in 1804, removed to Southington, and lived in his daughter Velina's household near her mill — a site later covered by the \"Plant Ponds.\" He died in 1817 at age 80, the longest-lived of the three brothers."}],"cross_connections":[],"military_service":[{"war":"American Revolutionary War","rank":"Lieutenant","side":"American","unit":"Connecticut Militia","battles":[],"war_id":"WAR004"}],"bio":{"display_name":"Lt. Noadiah Hart","first_name":"Noadiah","last_name":"Hart","title":"Lieutenant","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"slug":"noadiah-hart-1737"},"X01030":{"id":"X01030","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00275","children_ids":["H00565","H00566","H00567","H00567a","H00568","H00569"],"end_type":"death_of_spouse","end_year":1785,"date_year":1760,"date_month":11,"date_day":20,"location_city":"Farmington","location_state":"Connecticut"}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Lucy Hurlburt","first_name":"Lucy","maiden_name":"Hurlburt","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"lucy-hurlburt"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}