alse,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["religion","social_reform","business"],"notable_blurb":"Seamen's Church Institute founder, Liberty ship namesake","primary_url":"https://en.wikipedia.org/wiki/Archibald_Mansfield","primary_url_label":"Wikipedia: Archibald Mansfield"},"parents":{"father_id":"HD4004","mother_id":"I00548"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00550","date_year":1899,"date_month":6,"date_day":14,"location_city":"Manhattan","location_state":"New York","location_country":"United States","end_type":"death","end_year":1934,"children_ids":["HD4014","HD4015","HD4016","HD4017","HD4018","HD4019","HD4020"]}],"education":[{"institution":"St. John's School","degree":"Preparatory","end_year":1888,"location_city":"Ossining","location_state":"New York"},{"institution":"St. Stephen's College (Bard College)","degree":"Bachelor's","end_year":1892,"location_city":"Annandale-on-Hudson","location_state":"New York","notes":"St. Stephen's later renamed Bard College."},{"institution":"Seminary","degree":"Divinity","field":"Theology","end_year":1896,"notes":"Ordained Episcopal deacon 1896, priest 1897."}],"career":[{"employer":"Seamen's Church Institute of New York","employer_id":"INST101","role":"Superintendent","title":"Reverend","start_year":1895,"end_year":1934,"location_city":"New York","location_state":"New York","notes":"First Superintendent. Recruited by Benoni Lockwood in 1895. With Edmund Lincoln Baylies helped establish the Institute at 25 South Street. Created MEDICO radio medical service for ships."}],"military_service":[],"institutions":[{"institution_id":"INST101","role":"Founding Superintendent","start_year":1895,"end_year":1934,"notes":"38 years of service. After his death, a $100,000 memorial campaign was led by Rear Admiral Reginald R. Belknap."}],"landmarks":[],"naming_inspiration":[{"name":"SS Archibald R. Mansfield","type":"Liberty ship","year":1944,"url":"https://en.wikipedia.org/w/index.php?title=SS_Archibald_R._Mansfield","notes":"WWII Liberty ship built by the New England Shipbuilding Corporation 1944, named in Mansfield's honor 10 years after his death."}],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[{"related_id":"HD4021","display_label":"First cousins via Isaac Mansfield's sons Charles and Romaine","type":"family_connection","link_text":"George H. Mansfield"},{"related_id":"HD4028","display_label":"Both notable Mansfields via Isaac Mansfield common ancestor","type":"family_connection","link_text":"Lea Davison"}],"narrative_blocks":[{"category":"religion","header":"He led the Seamen's Church Institute for decades","body":"An Episcopal priest, Mansfield served as the first superintendent of the Seamen's Church Institute of New York for thirty-eight years. He helped build its great headquarters on South Street, a haven for sailors in the port.","number":1},{"category":"social_reform","header":"He gave ships medical advice by radio","body":"Mansfield created MEDICO, a pioneering radio service that relayed medical advice to ships at sea. It carried the Institute's care to sailors far beyond the harbor.","number":2},{"category":"legacy","header":"A wartime Liberty ship carried his name","body":"After his death a hundred-thousand-dollar memorial campaign honored him, and in 1944 a Liberty ship was launched as the SS Archibald R. Mansfield. His seven children carried the Hooker line into the tenth generation.","number":3}],"quotes":[],"sources":[{"label":"Wikipedia: Archibald Mansfield","url":"https://en.wikipedia.org/wiki/Archibald_Mansfield"},{"label":"FindAGrave 166489562","url":"https://www.findagrave.com/memorial/166489562/archibald_romaine-mansfield"},{"label":"FamilySearch 276T-Y8C","url":"https://ancestors.familysearch.org/en/tree/person/276T-Y8C"}],"research_sources":[],"documents":[],"slug":"archibald-mansfield-1871"},"HD4011":{"id":"HD4011","former_ids":[],"is_placeholder":false,"has_descendants_documented":fal