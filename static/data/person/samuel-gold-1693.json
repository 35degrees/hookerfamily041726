ing_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Deputy Governor","organization":"Colony of Connecticut","start_year":1708,"end_year":1723},{"role":"Chief Justice","organization":"Connecticut Superior Court","start_year":1712}],"narrative_blocks":[{"number":1,"category":"politics","header":"He died in office; a Talcott succeeded","body":"Gold held the deputy governorship from 1708 until his death in 1723, doubling as chief justice of the Superior Court from 1712. The man who succeeded him was Joseph Talcott — kin of Gold’s own first wife, Hannah Talcott of Hartford."},{"number":2,"category":"family","header":"Jay Gould and a duchess descend from him","body":"His grandson Lt. Col. Abraham Gould fell at the head of the 4th Connecticut Militia at Ridgefield in 1777; Abraham’s great-grandson was the financier Jay Gould, whose daughter Anna became Duchess of Talleyrand. His father’s troop, Gold’s Dragoons of 1660, still parades in Fairfield."}],"slug":"nathaniel-gold-1663"},"T00043":{"id":"T00043","has_descendants_documented":false,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":false,"generation_from_john_talcott":2,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1663,"month":12,"day":8},"death":{"year":1696},"parents":{"father_id":"T00035","mother_id":"U00012"},"tags":[],"sources":[{"short":"Talcott 1876","page":"Entry 43"}],"marriages":[{"spouse_id":"U00020","children_ids":["T00058","T00059","T00060","T00061","T00062","T00063"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1696}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Hannah Talcott","first_name":"Hannah","maiden_name":"Talcott","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"hannah-talcott-1663"},"T00035":{"id":"T00035","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":1,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1632,"city":"Braintree","county":"Essex","country":"England"},"death":{"year":1688,"month":7,"day":23,"city":"Hartford","state":"Connecticut"},"parents":{"father_id":"T00011","mother_id":"U00011"},"marriages":[{"spouse_id":"U00012","children_ids":["T00039","T00040","T00041","T00042","T00043","T00044","T00045","T00046"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1674,"date_year":1650,"date_month":10,"date_day":29},{"spouse_id":"U00013","children_ids":["T00047","T00049","T00051"],"marriage_number":2,"date_year":1676,"date_month":11,"date_day":9}],"sources":[{"short":"Talcott 1876","page":"Entry 35"},{"short":"Talcott 1876","url":"https://archive.org/details/talcottpedigreei00talc"}],"political_offices":[{"title":"Ensign","jurisdiction":"Connecticut Militia","dates":"1650"},{"title":"Captain","jurisdiction":"Connecticut Militia","dates":"1660"},{"title":"Deputy / Assistant Magistrate","jurisdiction":"Colony of Connecticut","dates":"from May 18, 1654","notes":"Elected before Connecticut joined New Haven Colony"},{"title":"Treasurer","jurisdiction":"Colony of Connecticut","dates":"1660-1676","notes":"Succeeded his father May 17, 1660; held office until 1676"},{"title":"Major, then Lieut.-Colonel","jurisdiction":"Connecticut Army","dates":"1676","notes":"Resigned Treasurer and took command of Connecticut army at outbreak of King Philip's War"}],"cross_connections":[],"gender":"male","tags":["king_philips_war"],"number_of_marriages":2,"notable":{"is_notable":true,"notable_category":["military"],"notable_blurb":"Colonial military commander, King Philip's War","primary_url":"https://en.wikipedia.org/wiki/John_Talcott_(military_officer)","primary_url_label":"Wikipedia"},"narrative_blocks":[{"category":"politics","header":"He was named guardian of the charter","body":"When Connecticut's royal charter arrived from Charles the Second in 1662, the freemen chose Talcott, with Samuel Wyllys and Lieutenant John Allyn, as the committee sworn to keep it in their custody. A quarter-century later he would help spirit that same charter away from Andros.","number":1},{"category":"politics","header":"He took the charter as the candles died","body":"By Roger Wolcott's 1764 account, when the candles were snuffed in the Hartford meeting-house in 1687, Talcott and Nathaniel Stanley lifted the two colonial charters from the table before Andros could seize them. Wolcott's telling names no oak; the tree entered the tradition later, and the duplicate passed to his son-in-law Joseph Wadsworth.","number":2},{"category":"military","header":"Connecticut's victorious commander in King Philip's War","body":"Talcott led Connecticut's forces through King Philip's War in 1675 and 1676, winning a string of engagements that earned him promotion to lieutenant-colonel. His campaigns ranged from the river towns down into the Narragansett country.","number":3},{"category":"politics","header":"He kept the colony's purse for sixteen years","body":"Talcott served as treasurer of Connecticut Colony from 1660 to 1676, taking the office directly from his father before him. The family's account books became a running ledger of early Hartford.","number":4},{"category":"death","header":"He died intestate, his estate worth thousands","body":"Talcott died in 1688 without a will, leaving an estate appraised at more than two thousand pounds, a substantial colonial fortune. It passed by primogeniture to his eldest surviving son, the future governor Joseph Talcott.","number":5}],"military_service":[{"war":"King Philip's War","active_in_war":true,"rank":"Lieutenant Colonel","dates":"1676","unit":"Connecticut Standing Army","role":"Commander of Connecticut forces","battles":["Multiple engagements with Wampanoag and allied tribes"],"notes":"Led Connecticut standing army with 200 Mohegan and Pequot Indian allies. 'In the various battles with the Indians in which he was engaged, he was always victorious, and obtained great renown as an Indian fighter.' Promoted from Major to Lieut.-Colonel during the war.","war_id":"WAR002"}],"bio":{"display_name":"Lieut.-Col. John Talcott Jr.","title":"Lieut.-Col.","first_name":"John","last_name":"Talcott","suffix":"Jr.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"slug":"john-talcott-jr-1632"},"U00012":{"id":"U00012","visible_default":false,"in_talcott_book":true,"classification":{"is_spouse_of_talcott_descendant":true,"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{},"death":{"year":1674,"month":6,"day":21},"parents":{"notes":"Her father John Wakeman was Colony Treasurer — the same office her husband John Talcott Jr. would later hold","father_research_notes":"John Wakeman, Treasurer of the Colony of Connecticut"},"marriages":[{"spouse_id":"T00035","children_ids":["T00039","T00040","T00041","T00042","T00043","T00044","T00045","T00046"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1674,"date_year":1650,"date_month":10,"date_day":29}],"sources":[{"short":"Talcott 1876","page":"Entry 35"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Helena Wakeman Talcott","first_name":"Helena","last_name":"Talcott","married_names":["Talcott"],"maiden_name":"Wakeman"},"