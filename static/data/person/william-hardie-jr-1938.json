blocks":[{"number":1,"category":"career","header":"LSU MFA in Creative Writing; best screenplay award","body":"Frank Hardie earned his MFA in Creative Writing at LSU, where he won the program's best screenplay award for his thesis and tied for best thesis in his class. He had earlier earned his BS from Rhodes College in Memphis, where he was president of his SAE fraternity chapter and played baseball. Before his cancer diagnosis he served as editor of the Civil War Book Review at LSU."},{"number":2,"category":"death","header":"Died of neuroendocrine cancer at age twenty-eight","body":"Frank Winter Hardie died of neuroendocrine cancer on December 26, 2007 — the day after Christmas — at age 28 in Mobile, Alabama. He had been a resident of Houston, Texas at the time. He was buried at Thornhill Cemetery in Talladega County, Alabama; his father Bill would join him there twelve years later."}],"slug":"frank-hardie-1979"},"X02877":{"id":"X02877","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD5039","spouse_name":"Frank Winter Hardie","marriage_number":1,"children_ids":[],"end_type":"death","end_year":2007}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Elaine de la Houssaye Hardie","first_name":"Elaine","last_name":"Hardie","maiden_name":"de la Houssaye","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elaine-de-la-houssaye"},"HD5035":{"id":"HD5035","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"desce