{"person":{"id":"HD0893","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00154","mother_id":"HD0887"},"tags":[],"sources":[],"birth":{"year":1911},"death":{"year":2001},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"Named for a family tradition","detail":"Captain John Kendrick pioneered American trade in the Pacific Northwest, Hawaii, and China, and was the first American to attempt to open trade with Japan. He was killed in 1794 in Hawaii during an exchange of cannon salutes, when a cannon was fired loaded by accident. His name carried enough prestige in the Kendrick family that it passed as a middle name into the Strong line: John Kendrick Strong's sister Louise carried it too (Louise Kendrick Brown, HD2780). Whether the Kendrick family descended directly from the captain or simply shared the surname and admired him is not documented. (Wikipedia — John Kendrick; family records)","body":"John Kendrick Strong was named for a family tradition rooted in his grandmother Henrietta Swan Kendrick Leavitt's surname. Captain John Kendrick (1740–1794) — the famous sea captain, Boston Tea Party participant, and leader of the first American expedition to the Pacific Northwest — inspired the Kendrick family's naming tradition across generations.","number":1}],"cross_connections":[],"bio":{"display_name":"John Kendrick Strong","first_name":"John","last_name":"Strong","middle_name":"Kendrick","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-strong-1911"},"neighborhood":{"focus":{"id":"HD0893","slug":"john