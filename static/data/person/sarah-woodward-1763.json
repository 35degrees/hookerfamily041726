drews","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"plot_notes":"Forest Lawn Cemetery, Buffalo NY"},"narrative_blocks":[{"number":1,"category":"career","header":"Postmaster of Buffalo, appointed April 1831","body":"Appointed Postmaster of Buffalo NY in April 1831 by President Andrew Jackson; held the office until his death on 2 July 1834. The Yale biographical sketch summarized: 'loved, esteemed, and respected by all who knew him.'"},{"number":2,"category":"politics","header":"NY Constitutional Convention 1821, Elector 1824","body":"Served as a delegate to the New York State Constitutional Convention of 1821 — which revised the state constitution to broaden suffrage and reorganize the judiciary. Selected as a Presidential Elector for New York in the 1824 election."},{"number":3,"category":"career","header":"Niagara County Judge from April 1817","body":"First appointed Judge in Niagara County NY in April 1817 — shortly after his removal from New York City to Buffalo. Held judicial office in western New York's frontier period when Niagara County still encompassed much of the territory later subdivided into Erie and other counties."},{"number":4,"category":"marriage","header":"Married two of the three Woodward sisters","body":"After his first wife Lucy Munson died at 29 in 1785 leaving a daughter, he married Sarah Woodward of New Haven in November 1790. She died suddenly in New York August 1807; around 1809 he then married her sister Susan Woodward, who died September 1819 in her 63rd year."},{"number":5,"category":"military","header":"Revolutionary War private under Capt. Peter Vail","body":"Served as a private in the Connecticut militia under Captain Peter Vail and Colonel Canfield during the Revolutionary War. SAR Patriot #P-283245 + DAR #A098524. His Yale studies followed wartime service and graduation around 1779 — he remained at Yale as graduate student and Butler until May 1783."}],"slug":"samuel-russell-1759"},"HD1324":{"id":"HD1324","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00844","mother_id":"X00414"},"tags":[],"sources":[],"birth":{"year":1791},"death":{"year":1828},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"William Andrew Russell","first_name":"William","last_name":"Russell","middle_name":"Andrew","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"william-russell-1791"},"HD1325":{"id":"HD1325","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00844","mother_id":"X00414"},"tags":[],"sources":[],"birth":{"year":1794},"death":{"year":1889},"gender":"female","marriages":[{"spouse_id":"X01643","children_ids":[],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Harriet Wadsworth Russell Williams","first_name":"Harriet","last_name":"Williams","maiden_name":"Russell","middle_name":"Wadsworth","married_names":["Williams"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes"