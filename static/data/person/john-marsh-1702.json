_id":"INST002","institution_blurb":"Left Harvard College soon after admission; educated by his father instead."}],"landmarks":[],"naming_inspiration":[],"research_tags":[],"quotes":[],"research_sources":[],"narrative_blocks":[{"number":1,"category":"legacy","header":"A regicide praised his preaching in 1682","body":"In 1682 John Wilson preached in New Haven for over a year. Col. John Dixwell — one of the English regicides then living in hiding in New Haven — wrote to Rev. Increase Mather calling him \"a veire hopefull yonge man of good abilities.\" Wilson returned to Medfield in 1684 and eventually abandoned the ministry."},{"number":2,"category":"career","header":"Left Harvard — his father taught him everything","body":"He left Harvard College soon after admission, but received a thorough private education from his father in divinity, medicine, and law. He settled in Braintree in 1692 and spent the rest of his life farming, practicing medicine, and performing legal services."},{"number":3,"category":"marriage","header":"Married his first cousin — both Hooker grandchildren","body":"His mother was Sarah Hooker Wilson (Thomas Hooker's daughter); his wife Sarah Newton's mother was Mary Hooker Newton (also Thomas Hooker's daughter). The two mothers were sisters. EH and the Wilson genealogy both explicitly note the cousin relationship."}],"career":[{"role":"Schoolmaster","organization":"Town of Medfield","end_year":1692,"notes":"Employed as schoolmaster in Medfield for several terms; also assisted father in ministry."},{"role":"Representative","organization":"Massachusetts General Court","start_year":1698,"end_year":1698,"notes":"Representative from Braintree, 1698."},{"role":"Justice of the Peace","organization":"Braintree, Massachusetts","start_year":1700,"notes":"Commission June 7, 1700. Held until death."}],"military_service":[{"rank":"Captain","unit":"Local militia company, Braintree","rank_year_start":1696,"notes":"Commission as captain of one of the local military companies, 1696."}],"bio":{"display_name":"John Wilson","first_name":"John","last_name":"Wilson","married_names":[]},"documents":[],"artworks":[],"slug":"john-wilson-1660"},"H00016":{"id":"H00016","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":3,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_progenitor":false},"birth":{"year":1662,"month":1,"day":24,"city":"Milford","state":"Connecticut","country":"United States"},"death":{"year":1725,"month":8,"day":20,"city":"Braintree","county":"Suffolk","state":"Massachusetts","country":"United States"},"parents":{"father_id":"I00003","mother_id":"H00003"},"marriages":[{"spouse_id":"H00024","children_ids":["H00060","H00061","H00062","H00063","H00064","H00065","H00066"],"marriage_number":1,"date_year":1683,"date_month":7,"date_day":4,"location_city":"Milford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1725}],"cross_connections":[{"type":"cousin_marriage","related_id":"H00024","display_label":"She and her first cousin John Wilson married — Hooker descendants.","link_text":"John Wilson"}],"tags":["cousin_marriage"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 16"},{"short":"Caroline Gaylord Newton 1914"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"burial":{},"is_placeholder":false,"former_ids":[],"baptism":{},"residence":{"country":"United States"},"institutions":[{"institution_id":"INST002"}],"landmarks":[],"naming_inspiration":[],"research_tags":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married her first cousin — both Hooker grandchildren","body":"Her husband John Wilson was her first cousin: her mother was Mary Hooker, his mother was Sarah Hooker — sisters, both daughters of Rev. Thomas Hooker. They married July 4, 1683 in Milford. EH and the Wilson family genealogy both confirm the cousin relationship explicitly."},{"number":2,"category":"marriage","header":"Married 27 days after her father's death","body":"Her father Roger Newton Sr. died June 7, 1683. She married John Wilson on July 4, 1683 — twenty-seven days later. The marriage had presumably been planned before his death, but she wed her cousin in the immediate shadow of her father's loss."},{"number":3,"category":"family","header":"Inherited 150 Farmington acres from her father","body":"Her father Roger Newton Sr.'s 1683 will left her 150 acres in 'Bohemia' Farmington. Family tradition speculates the land may have originally been given to her mother Mary Hooker by Governor Haynes — connecting it to the Hartford founding generation."}],"quotes":[],"research_sources":[],"artworks":[],"bio":{"display_name":"Sarah Newton Wilson","first_name":"Sarah","last_name":"Wilson","married_names":["Wilson"],"maiden_name":"Newton"},"documents":[],"military_service":[],"slug":"sarah-wilson-1662"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}