r Collection CT VR"}],"gender":"male","tags":["businessman","extraordinary_longevity"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"He lived to 96","body":"Moses Gilbert was baptized in Hartford in 1707 and died in Berlin, Connecticut in 1803 at approximately 96. His son Ebenezer was killed in the Revolutionary Army on February 15, 1776. His grandson Sylvanus, son of Ebenezer, enlisted in the same army and also died in service.","number":1},{"header":"His father's 1726 will inventoried four enslaved people","body":"Moses Gilbert's father Ebenezer Gilbert was a Hartford merchant who died in 1726. His estate of £4,455 included four enslaved people itemized by price: a negro (£100), a negro woman (£45), a boy (£100), a child (£30). He had also served on a 1717-1718 committee that divided Kensington into five school districts — using Gilbert's River as a boundary line.","number":2}],"cross_connections":[{"type":"family_connection","related_id":"H00228","display_label":"His daughter Sarah married my son Hooker Gilbert in 1807.","link_text":"Samuel Hooker Jr."}],"bio":{"display_name":"Moses Gilbert","first_name":"Moses","last_name":"Gilbert","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"moses-gilbert-1707"},"H00224":{"id":"H00224","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1714,"month":5,"day":10,"city":"Kensington","state":"Connecticut"},"parents":{"father_id":"H00086","mother_id":"I00119"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 224"}],"marriages":[{"spouse_id":"I00150","children_ids"