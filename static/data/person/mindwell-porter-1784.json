ary_service":[],"slug":"jane-dodd-1824"},"X01935":{"id":"X01935","has_descendants_documented":false,"is_placeholder":false,"gender":"male","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1750,"month":6,"day":14,"city":"Windsor","state":"Connecticut"},"death":{"year":1838,"month":1,"day":22,"city":"Berlin","state":"Connecticut"},"parents":{},"marriages":[{"marriage_number":1,"spouse_id":"H00610","children_ids":["X01045"],"date_year":1812,"date_month":4,"date_day":6}],"number_of_marriages":1,"tags":["revolutionary_war"],"sources":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Samuel Porter","first_name":"Samuel","last_name":"Porter","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"samuel-porter-1750"},"H00610":{"id":"H00610","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1769,"month":12,"day":24},"parents":{"father_id":"H00286","mother_research_notes":"Elizabeth Hopkins Hart","mother_id":"X01933"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 610"}],"gender":"female","number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"X01934","children_ids":["X01940","X01937","X01938","HD3158"],"end_type":"death_of_spouse","end_year":1807,"date_year":1790,"date_month":1,"location_city":"Kensington","location_state":"Connecticut"},{"marriage_number":2,"spouse_id":"X01935","children_ids":["X01045"],"date_year":1812,"date_month":4,"date_day":6}],"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1846,"month":1,"day":1},"cross_connections":[],"documents":["DOC008"],"bio":{"display_name":"Elizabeth Hart Percival","first_name":"Elizabeth","last_name":"Percival","maiden_name":"Hart","married_names":["Percival","Porter"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Mother of poet-geologist James Gates Percival","body":"Elizabeth Hart Percival's son James Gates Percival (born September 15, 1795) became a major American poet and the official state geologist of both Connecticut and Wisconsin after his Yale 1815 graduation. Elizabeth herself was described as 'by nature of a susceptible and delicate organization' who 'seems to have imparted to her son these qualities, with a tendency to excessive mental development.' She was understood to have transmitted depression and extreme sensitivity to her sons — James also suffered from depression throughout his life."},{"number":2,"category":"death","header":"Lost husband and daughter within five weeks, 1807","body":"Elizabeth's first husband Dr. James Percival Jr. died January 22, 1807 in Kensington Connecticut at age forty, and five weeks later her daughter Harriet died February 16, 1807 at age seventeen. The compressed loss of husband and eldest child within five weeks marked the family's catastrophic early-1807. Elizabeth waited five years before remarrying — to Samuel Porter on April 6, 1812."},{"number":3,"category":"family","header":"Son James worked Porter farm before re-entering Yale","body":"After her 1812 second marriage to Samuel Porter, Elizabeth's son James Gates Percival worked on Porter's farm before re-entering Yale to complete his 1815 degree. The interim farm labor between the family rebuild and resumption of Yale studies was the kind of practical stop-gap that interrupted many early-Republic professional-track educations after parental deaths reset family finances."},{"number":4,"category":"family","header":"Born Kensington 1769, four children with Dr. Percival","body":"Elizabeth Hart was born in 1769 in Kensington Connecticut (baptized December 24, 1769) and married Dr. James Percival Jr. there in January 1790 at age twenty. Four children survived to be documented: Harriet (died 1807 age 17), Edwin (died Troy NY), James Gates Percival (Yale 1815 poet-geologist), and Oswin Hart Percival (baptized 1809, died never married at a New Haven hospital). Elizabeth herself died around 1846."}],"slug":"elizabeth-percival-1769"},"H00286":{"id":"H00286","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1737,"month":1,"day":23,"city":"Kensington","state":"Connecticut"},"death":{"year":1811,"month":1,"day":1,"city":"De Ruyter","county":"Madison County","state":"New York","country":"United States"},"parents":{"father_id":"I00030","mother_id":"H00101"},"tags":["posthumous_birth"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 286"}],"marriages":[{"children_ids":["H00607","H00608","H00609","H00610","H00611","H00612"],"spouse_id":"X01933","marriage_number":1,"date_year":1759,"date_month":11,"date_day":15,"location_city":"Farmington","location_state":"Connecticut"}],"cross_connections":[{"type":"double_hooker_descent","related_id":"H00534","display_label":"His son Matthew Hart Jr. married Urania Hooker — both.","link_text":"Urania Hooker Hart"},{"type":"double_hooker_descent","related_id":"H00608","display_label":"His son Matthew Hart Jr. married Urania Hooker — both.","link_text":"Rev. Seth Hart"},{"type":"military","display_label":"commanded his Revolutionary militia company","related_id":"H00273","link_text":"Selah Hart"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Matthew Hart Jr.","first_name":"Matthew","last_name":"Hart","suffix":"Jr.","married_names":[],"bio_blurb":"Revolutionary War corporal of Kensington"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","rank":"Corporal","rank_start":"Private","rank_end":"Corporal","unit":"Connecticut militia","notes":"Served under Capts. Selah Hart and James Stoddard, Col. Wolcott's regiment."}],"narrative_blocks":[{"number":1,"category":"family","header":"Born three months after his father died","body":"His father Matthew Hart died on October 30, 1736; he was born January 23, 1737 — a posthumous child. He grew up in Kensington and joined the church there in October 1760 at age twenty-three."},{"number":2,"category":"family","header":"Son's marriage created double Hooker descent","body":"His son Matthew Hart III married Urania Hooker — both Hooker descendants. Their grandchildren carried double descent from Thomas Hooker through different family lines."},{"number":3,"category":"family","header":"Removed his household to New York around 1800","body":"Around the turn of the nineteenth century he sold the Sheldon Moore homestead in Kensington and moved to Madison County, New York — to either Whitestown or De Ruyter. He died there around 1811, more than a decade after the move."},{"number":4,"category":"legacy","header":"His grandson became America's foremost 1820s poet","body":"His grandson James Gates Percival (1795-1856) — son of daughter Elizabeth and Dr. James Percival Jr. — became the most recognized American poet of the 1820s and Connecticut's first state geologist. James was born in Kensington before Matthew Hart Jr. departed for New York."},{"number":5,"category":"family","header":"Born after his father had died","body":"Matthew Hart was born in January 1737, weeks after his father died the previous October. He grew up to serve as a Revolutionary corporal and later removed to New York."}],"slug":"matthew-hart-jr-1737"},"X01933":{"id":"X01933","has_descendants_documented":false,"is_placeholder":false,"gender":"female","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1740,"month":11,"day":29,"city":"Farmington","state":"Connecticut","country":"United States"},"death":{"year":1817,"month":1,"day":1},"parents":{},"marriages":[{"marriage_number":1,"spouse_id":"H00286","children_ids":["H00607","H00608","H00609","H00610","H00611","H00612"],"date_year":1759,"date_month":11,"date_day":15,"location_city":"Farmington","location_state":"Connecticut"}],"number_of_marriages":1,"tags":[],"sources":[{"short":"EH 1909; Hart Genealogy 1948"}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Hopkins Hart","first_name":"Elizabeth","last_name":"Hart","maiden_name":"Hopkins","married_names":["Hart"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elizabeth-hopkins-1740"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}