ty":"Plymouth","county":"Litchfield","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00353","mother_id":"X00355"},"tags":["westward_migration","drowned","ohio_migration"],"sources":[{"short":"Edward Hooker 1909","entry":"825"},{"short":"WikiTree (online genealogy)","url":"https://www.wikitree.com/"},{"short":"Rhoda Cowles Diary, vol. II"},{"short":"My Country, vol. 28 no. 1, winter 1994"},{"short":"Find a Grave — Cholera Cemetery Sandusky OH","url":"https://www.findagrave.com/cemetery/40290/cholera-cemetery"}],"death":{"year":1836,"month":5,"day":7,"city":"Sandusky","county":"Erie","state":"Ohio","country":"United States","cause":"Drowned in Lake Erie when sailboat capsized in a squall off Put-in-Bay (South Bass Island)"},"marriages":[{"spouse_id":"I00369","children_ids":["HD1179","HD1180"],"marriage_number":1,"date_year":1807,"date_month":12,"date_day":1,"location_city":"Litchfield","location_state":"Connecticut","location_country":"United States"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"place_overlap","related_id":"H01494","display_label":"War of 1812 soldier died at Sandusky, 1813","link_text":"Norman Hart","notes":"Both Hooker descendants died at Sandusky, Ohio, twenty-three years apart. Norman Hart (gen 7, Marietta Hart line) died there August 1813 as a soldier of the War of 1812 aged seventeen — likely at the August 1-2 defense of Fort Stephenson. Sherman drowned in Lake Erie there May 7, 1836 aged fifty-two. Different lines of Hooker descent ending at the same Ohio frontier town a generation apart."},{"type":"parallel_descent","related_id":"HD4969","display_label":"Drowned at Lake Garfield Massachusetts, 1915, age 38","link_text":"Albert Norton Butler","notes":"Both Hooker descendants drowned in lakes. Albert Norton Butler — Yale 1900, president of Butler & Klein Lumber Co. — drowned in Lake Garfield at Monterey, Berkshire County Massachusetts on September 28, 1915 when his rowboat capsized; aged thirty-eight. Seventy-nine years and two generations after Sherman's Lake Erie drowning at Sandusky in 1836."}],"bio":{"display_name":"Sherman Pierpont","first_name":"Sherman","last_name":"Pierpont","married_names":[]},"residence":{"city":"Sandusky","county":"Erie","state":"Ohio","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"title":"Wool merchant","organization":"Pierpont Family Wool Business","dates":"~1805-1830s","type":"commerce","notes":"Continued the Pierpont family wool business in Litchfield County. When Sherman and his wife Sidney moved to Sandusky Ohio (probably early 1830s), his younger brother James Morris Pierpont IV (H00832) took over the business. Per My Country (vol. 28 no. 1, winter 1994)."}],"burial":{"cemetery_id":"CEM258","plot_notes":"Buried May 27, 1836 after body washed ashore on Lake Erie. His name appears on a Find A Grave memorial with parents and siblings at Morris Burying Ground in Litchfield County CT, but this is in error — actual burial is at Cholera Cemetery in Sandusky OH per FG records."},"narrative_blocks":[{"number":1,"category":"death","header":"Drowned in Lake Erie squall, body washed ashore","body":"Sherman left Put-in-Bay on a sailboat heading for Sandusky Ohio May 7, 1836 with two other men, and all three drowned when the boat capsized in a squall. His body washed ashore on Lake Erie twenty days later. His brother Rev. John Pierpont, the Boston abolitionist, wrote in a poem of dreaming of his lost brother 'sleeping on Low Sandusky's shore.'"},{"number":2,"category":"death","header":"Body washed ashore three weeks after drowning","body":"His sailboat capsized in a squall off Put-in-Bay on South Bass Island in Lake Erie on 7 May 1836; all three men aboard drowned. His body was discovered 27 May 1836 on the shore of Lake Erie — three weeks after the squall — and brought to Sandusky for burial."},{"number":3,"category":"legacy","header":"Brother John's poem mourned him from Connecticut","body":"His older brother Rev John Pierpont wrote a posthumous poem preserved in the Rhoda Cowles Diary: 'I am awakened by my weeping / To know that thou art sleeping / on Low Sandusky's shore.' The grief crossed both the family wool business and the geographic separation of Connecticut from Ohio."}],"slug":"sherman-pierpont-1783"},"I00369":{"id":"I00369","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Sidney","last_name":"Pierpont","maiden_name":"Humiston","married_names":["Pierpont"],"gender":"female","display_name":"Sidney Humiston Pierpont"},"birth":{"year":1786,"city":"Plymouth","county":"Litchfield","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1841,"month":5,"day":16,"country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM259","plot_notes":"Find a Grave memorial 153077426"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Jesse Humiston","mother_name":"Abi Blakeslee Humiston","father_research_notes":"Jesse Humiston of Plymouth CT (not built per Jalapeño).","mother_research_notes":"Abi Blakeslee Humiston of Plymouth CT (not built per Jalapeño)."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00825","date_year":1807,"location_country":"United States","end_type":"death_of_spouse","end_year":1836,"children_ids":["HD1179","HD1180"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],