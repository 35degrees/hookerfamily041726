Hampden","state":"Massachusetts","country":"United States"},"cross_connections":[],"bio":{"display_name":"Dr. George Hooker","first_name":"George","last_name":"Hooker","title":"Doctor","married_names":[],"gender":"male"},"residence":{"city":"Longmeadow","county":"Hampden","state":"Massachusetts","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["HD0615"],"burial":{"cemetery_id":"CEM413","plot_notes":"Springfield Cemetery, Hampden County MA — with wife Rachel Breck and his parents Judge John (H00527) and Sarah Dwight Hooker"},"education":[{"school_name":"Yale College","institution_id":"INST022","degree_or_field":"A.B.","class_year":1814,"notes":"Yale 1814 undergraduate."},{"school_name":"Medical Institution of Yale College","institution_id":"INST022","degree_or_field":"M.D.","class_year":1817,"notes":"Studied medicine at the Medical Institution of Yale College, receiving M.D. in 1817. Practiced afterward with Dr. Eli Ives in New Haven."}],"career":[{"role":"Physician (apprentice/colleague)","organization":"Dr. Eli Ives medical practice","location":"New Haven, CT","start_year":1817,"notes":"Practiced with Dr. Eli Ives — Yale's Professor of Theory and Practice of Medicine, the same chair later occupied (1852-1867) by George's younger brother Worthington Hooker (H01407)."},{"role":"Physician","location":"Syracuse, NY","notes":"Removed to Syracuse, NY where he practiced medicine for several years."},{"role":"Physician","location":"Longmeadow, Hampden County, MA","end_year":1884,"notes":"Returned east to Longmeadow MA where he continued medical practice until his death there 14 March 1884 at age 91."}],"narrative_blocks":[{"number":1,"category":"education","header":"Yale 1817 M.D. under Dr. Eli Ives","body":"After Yale College 1814 he took his medical degree from the Medical Institution of Yale College in 1817, then practiced alongside Dr. Eli Ives in New Haven. Ives — Professor of Theory and Practice of Medicine at Yale until 1852 — would later be succeeded in that chair by George's younger brother Worthington Hooker (H01407)."},{"number":2,"category":"career","header":"Syracuse practice, then Longmeadow homecoming","body":"After his New Haven training he removed to Syracuse, New York, where he practiced medicine for some years before returning east to Longmeadow, Massachusetts. He continued practice at Longmeadow until his death there 14 March 1884 at age 91."},{"number":3,"category":"longevity","header":"Lived ninety-one years to 1884","body":"He was born 7 March 1793 to Judge John Hooker (H00527) and Sarah Dwight Hooker (X00227) at Springfield, and lived past his ninety-first birthday — dying just seven days after it on 14 March 1884 at Longmeadow. He had outlived his celebrated younger brother Dr. Worthington Hooker (H01407) by seventeen years."}],"slug":"george-hooker-1793"},"I01098":{"id":"I01098","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Rachel","last_name":"Hooker","maiden_name":"Breck","married_names":["Hooker"],"gender":"female","display_name":"Rachel Breck Hooker"},"birth":{"year":1792,"month":7,"day":22,"city":"Northampton","county":"Hampshire","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1879,"month":1,"day":6,"city":"Longmeadow","county":"Hampden","state":"Massachusetts","country":"United States"},"burial":{"cemetery_id":"CEM413","plot_notes":"Springfield Cemetery, Hampden County MA, with husband Dr. George Hooker"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Joseph Hunt Breck (1766-1801) of Northampton MA — died when Rachel was 9","mother_name":"Abigail Kingsley Breck (c.1766-1846) of Northampton MA"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01400","date_year":1819,"location_state":"Massachusetts","location_country":"United States","end_type":"death_of_self","end_year":1879,"children_ids":["H02734","H02735","H02736","H02737","H02738","H02739","H02740","H02741"]}],"education":[{"school_name":"Deerfield Academy","degree_or_field":"Three 12-week sessions","class_year":1806,"notes":"Attended three twelve-week sessions beginning 11 April 1806 at Deerfield Academy, approximately 17 miles north of Northampton."},{"school_name":"Misses Patten's School","degree_or_field":"Finishing school for young ladies","class_year":1810,"notes":"Attended Misses Patten's School in Hartford CT at age 18. Curriculum: Latin, Greek, English, French, mercantile arithmetic, bookkeeping, geography, astronomy, natural philosophy, writing, composition, drawing, painting, embroidery, filigree, and ornamental work. Stitched the 'Charity' silk embroidered picture (ART055) there in 1810; companion sampler from earlier years also extant in Smithsonian collection."}],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[{"artwork_id":"ART055","blurb":"Silk embroidered 'Charity' (1810) now in Smithsonian National Museum of American History; donated 1951 by Greenwood collectors."}],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Bore eight children, four survived adulthood","body":"From the Breck family of Northampton MA, she married Dr. George Hooker around 1819 and bore eight children between 1820 and 1833. Of those eight only four survived to adulthood — three daughters died young (two infants and one age 5), one son died at 29 — while she herself lived to age 86, dying at Longmeadow in 1879."},{"number":2,"category":"family","header":"Father dead at thirty-five, she was nine","body":"Her father Joseph Hunt Breck of Northampton died in 1801 at age thirty-five when she was nine, leaving her mother Abigail Kingsley Breck a widow at thirty-five with a young daughter. Abigail did not remarry and lived another forty-five years, dying in 1846 at age eighty."},{"number":3,"category":"arts","header":"Stitched at eighteen, now in the Smithsonian","body":"In 1810 at age eighteen, attending the Misses Patten's School in Hartford CT, she stitched a silk embroidered picture of Charity from a mezzotint engraving. Donated by collectors in 1951, it now lives in the Textile Collection of the National Museum of American History — reunited with her earlier Northampton sampler in the museum's first paired example of a girl's two needlework levels."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"rachel-breck-1792"},"H00527":{"id":"H00527","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1761,"month":10,"day":8,"city":"Northampton","state":"Massachusetts","county":"Hampshire"},"death":{"year":1829,"month":3,"day":7,"city":"Springfield","state":"Massachusetts","county":"Hampden"},"parents":{"father_id":"H00264","mother_id":"I00043"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 527"}],"marriages":[{"children_ids":["H01399","H01400","H01401","H01402","H01403","H01407","H01408","H01404","H01405","H01406"],"spouse_id":"X00227","marriage_number":1,"date_year":1791,"date_month":2,"date_day":9,"location_city":"Springfield","location_state":"Massachusetts"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"in_law","related_id":"X03111","display_label":"was his father-in-law; Richest man in old Hampshire County"}],"education":[{"school_name":"Yale College","graduation_year":1782,"institution_id":"INST022"}],"bio":{"display_name":"Judge John Hooker","first_name":"John","last_name":"Hooker","title":"Judge","married_names":[],"gender":"male"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1782"},{"institution_id":"INST041","relationship":"member"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM413","plot_notes":"Springfield Cemetery"},"narrative_blocks":[{"number":1,"category":"career","header":"Yale 1782, Springfield lawyer and judge","body":"He graduated from Yale College in 1782 and settled at Springfield, MA, where he practiced law and rose to Judge of the Court of Common Pleas and then Judge of Probate at his death. He was a Deacon of the First Congregational Church of Springfield throughout this period."},{"number":2,"category":"civic","header":"Member of American Board for Foreign Missions","body":"He was an active member of the American Board of Commissioners for Foreign Missions (ABCFM), the first US foreign-missions organization, founded 1810 in Williamstown MA. The Board sent New England missionaries to India, the Sandwich Islands (Hawaii), and Native American tribes — a defining institution of New England Federalist evangelical culture."}],"slug":"john-hooker-1761"},"X00227":{"id":"X00227","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1764,"month":12,"day":13,"city":"Springfield","county":"Hampden","state":"Massachusetts","country":"United States"},"death":{"year":1842,"month":9,"day":5,"city":"Chicopee","county":"Hampden","state":"Massachusetts","country":"United States"},"gender":"female","parents":{"father_id":"X03111","father_name":"Col. Josiah Dwight","mother_id":"X03113","mother_name":"Elizabeth Buckminster Dwight"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00527","date_year":1790,"date_month":12,"date_day":18,"location_city":"Springfield","location_county":"Hampden","location_state":"Massachusetts","location_country":"United States","end_type":"death_of_spouse","end_year":1829,"children_ids":["H01399","H01400","H01401","H01402","H01403","H01407","H01408","H01404","H01405","H01406"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sarah Dwight Hooker","first_name":"Sarah","last_name":"Hooker","maiden_name":"Dwight","married_names":["Hooker"],"gender":"female"},"residence":{"city":"Springfield","county":"Hampden","state":"Massachusetts","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[{"landmark_id":"LM120","landmark_blurb":"Her father built this house, later moved to Historic Deerfield."}],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM413","plot_notes":"Springfield Cemetery, beside her husband Judge John Hooker"},"narrative_blocks":[{"number":1,"category":"family","header":"Born to Springfield's mercantile gentry, 1764","body":"She was born 13 December 1764 to Col. Josiah Dwight — Yale 1736, owner of an iron foundry, a potash manufactory, and 5,000 acres of Hampshire County land — and to Elizabeth Buckminster of Brookfield. Her father died in 1768 leaving an estate worth £9,458 when she was four; her mother survived to 1798."},{"number":2,"category":"marriage","header":"Married Judge John Hooker, December 1790","body":"On 18 December 1790 in Springfield she married John Hooker, Yale 1782 graduate and son of the Rev. John of Northampton. She bore him ten children between 1791 and 1808, including Dr. Worthington Hooker (H01407) and Elizabeth Dwight Hooker Packard (H01403)."}],"slug":"sarah-dwight-1764"}},"burialCemetery":{"id":"CEM537","former_ids":[],"primary_name":"Evergreen Cemetery","city":"Hillside","county":"Union","state":"New Jersey","country":"United States","primary_url":"https://www.findagrave.com/cemetery/185168/evergreen-cemetery","primary_url_label":"FindAGrave — Evergreen Cemetery Hillside NJ","hooker_connections":["H02735","I01099","H04326","H04327","H04328","I01100","H05228","I01101","I01102"],"notes":"Burial site of the Robert Breck Hooker branch (Elizabeth NJ druggist family). Three generations of Hookers and spouses interred: Robert Breck Hooker + Mary Ophelia Young + their 3 children + George Breck's wife Amelia + George Annin Hooker + Mildred Anderson + Elizabeth Dwight's husband George Seaton."},"institutionsById":{},"crossConnections":[]}