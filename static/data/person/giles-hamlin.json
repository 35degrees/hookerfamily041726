_blocks":[{"number":1,"category":"marriage","header":"Second wife of Rev. Isaac Stiles","body":"She married Rev. Isaac Stiles of North Haven as his second wife. His first wife Keziah Taylor — daughter of the great Puritan poet Rev. Edward Taylor — had died in childbirth on December 4, 1727."},{"number":2,"category":"family","header":"Raised Ezra Stiles, future Yale president","body":"She raised her stepson Ezra Stiles from infancy after his birth mother Keziah Taylor's death. He became President of Yale (1778-1795) and one of the most important intellectuals of the American Founding."},{"number":3,"category":"family","header":"Ten children with Stiles between 1729 and 1750","body":"She and Isaac Stiles had ten children of their own between 1729 and 1750. Only Ezra was Keziah's son from the first marriage; all others were Esther's, carrying the Stiles-Hooker line forward through North Haven."},{"number":4,"category":"legacy","header":"Her name traveled five generations as Esther Hooker","body":"The name 'Esther Hooker' became a heritable token across five generations of Stiles women — from her (1702) to her granddaughter (1760), and onward through Alice Stiles Mills (1845). Her name carried farther than her lineage."}],"slug":"esther-stiles-1702"},"H00093":{"id":"H00093","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1706,"month":9,"day":30,"city":"Farmington","state":"Connecticut"},"parents":{"father_id":"H00028","mother_id":"I00056"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 93"}],"death":{"year":1763,"month":11,"day":17,"city":"New London","state":"Connecticut"},"marriages":[{"spouse_id":"I00127","children_ids":["H00248","H00249","H00250","H00251","H00252"],"marriage_number":1,"date_year":1742,"date_month":1,"date_day":21}]