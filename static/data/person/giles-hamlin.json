riage with no issue. Edward Hooker gives no further entry on him beyond his marriage and death."}],"slug":"thomas-hooker-1692"},"H00089":{"id":"H00089","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1694,"city":"Farmington","state":"Connecticut"},"parents":{"father_id":"H00028","mother_id":"I00056"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 89"}],"death":{"year":1782,"city":"Farmington","state":"Connecticut"},"marriages":[{"spouse_id":"I00122","children_ids":["H00233"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1723,"date_year":1721,"date_month":2,"date_day":15},{"spouse_id":"I00123","children_ids":["H00234","H00235"],"marriage_number":2,"end_type":"death_of_spouse","end_year":1727,"date_year":1724,"date_month":7,"date_day":16},{"spouse_id":"I00124","children_ids":["H00236","H00237"],"marriage_number":3,"end_type":"death_of_spouse","date_year":1731,"date_month":5,"date_day":20},{"spouse_id":"I00125","children_ids":[],"marriage_number":4,"end_type":"death_of_spouse","end_year":1780}],"gender":"male","tags":[],"number_of_marriages":4,"notable":{"is_notable":false,"notable_category":[]},"documents":["DOC004"],"cross_connections":[{"type":"family_connection","related_id":"H00030","display_label":"First cousin John registered his Sue Squa deed","link_text":"Hon. John Hooker"}],"bio":{"display_name":"William Hooker","first_name":"William","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Four wives, five children — only one survived","body":"He married four times across his 88 years. Of the five children produced across three of his four marriages, only one survived past childhood — and that son died unmarried at 27."},{"number":2,"category":"family","header":"Sue Squa deed grantee on his cousin's land","body":"On June 13, 1733 he received about three-quarters of an acre at Indian Neck, Farmington as part of the Sue Squa deed. His first cousin John Hooker — Hon. John Hooker, Probate Judge — served as witness, certifying official, and registrar of the same transaction."}],"slug":"william-hooker-1694"},"H00090":{"id":"H00090","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1698,"month":8,"city":"Farmington","state":"Connecticut"},"parents":{"father_id":"H00028","mother_id":"I00056"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 90"}],"death":{"year":1703,"month":8,"day":10},"tags":["died_in_childhood"],"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Roger Hooker","first_name":"Roger","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"roger-hooker-1698"},"H00091":{"id":"H00091","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1700,"month":10,"city":"Farmington","state":"Connecticut"},"parents":{"father_id":"H00028","mother_id":"I00056"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 91"}],"death":{},"gender":"male","t