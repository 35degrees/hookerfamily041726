r"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Postmaster","organization":"North Lansing NY","start_year":1828,"end_year":1902}],"narrative_blocks":[{"number":1,"category":"character","header":"Postmaster for seventy-four straight years","body":"Appointed at North Lansing in 1828 under John Quincy Adams — his brother’s law partner William H. Seward arranged it — Beardsley held the office through twenty presidents and thirty-four postmasters general. At his death in 1902 he was believed the only man in the country to have held one office for seventy-four years."},{"number":2,"category":"politics","header":"Seward arranged the boy’s appointment","body":"His brother Nelson’s law partner William H. Seward — the future Secretary of State — arranged the eighteen-year-old’s 1828 postmastership under John Quincy Adams. Roswell held it under twenty presidents, and died believed the only man to keep one federal office seventy-four years."}],"slug":"roswell-beardsley-1809"},"X00837":{"id":"X00837","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["banker"],"sources":[],"birth":{"year":1816},"death":{"year":1900},"gender":"male","parents":{"father_id":"X00802","mother_id":"HD2437"},"notable":{"is_notable":true,"notable_category":[]},"marriages":[],"cross_connections":[],"bio":{"display_name":"William Clinton Beardsley","first_name":"William","last_name":"Beardsley","middle_name":"Clinton","married_names":[],"bio_blurb":"Auburn banker and presidential elector"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":