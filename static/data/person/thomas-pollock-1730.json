ry.com/dc5clrqtw/image/upload/v1780858344/14087012_e2348499-9034-46a5-8801-2f454a46258e_kjjadp.png","bio_blurb":"New Bern heiress; matriarch of the Devereux family"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"business","header":"Husband described as 'Rothschild' of American business","body":"Frances Pollock's husband John Devereux — Irish-born, trained for the Catholic priesthood at Saint Omer's monastery in France before rejecting priesthood, served as a British Navy midshipman and then 1st Lieutenant during the American Revolution, then sailed penniless to America after his family rejected him — built an estate of approximately eight hundred thousand dollars combined with her Pollock plantation property. Per the North Carolina Biography Project, 'in business circles his name was similar to that of Rothschild in Europe.' Their sons Thomas and George were both sent to Yale."},{"number":2,"category":"family","header":"Inherited eight plantations and Spanish pieces of eight","body":"Frances Pollock inherited eight plantations plus 7,500 'milled Spanish pieces of eight' from her father Thomas Pollock III's estate. The Spanish pieces of eight were the silver dollars that circulated as the de facto currency of post-Revolutionary North Carolina before the federal Mint produced enough US coinage. Combined with husband John Devereux's substantial Charleston business holdings, the couple became one of the wealthiest planter-merchant families in the Carolinas."},{"number":3,"category":"religion","header":"Co-founded First Presbyterian Church, New Bern","body":"Frances Pollock Devereux co-founded the First Presbyterian Church in New Bern North Carolina, the family's antebellum home. Her daughter Frances Ann Devereux Polk would later marry Bishop Leonidas Polk in 1830 and become the wife of one of the most prominent Episcopal bishops of the antebellum South — carrying the family religious commitment into the next denomination and the next generation."},{"number":4,"category":"family","header":"Born New Bern 1771, died Raleigh 1849","body":"Frances Pollock was born March 18, 1771 in New Bern North Carolina, daughter of Thomas Pollock III and Eunice Edwards — making her granddaughter of Jonathan Edwards and great-great-granddaughter of Rev. Thomas Hooker through Sarah Pierpont Edwards. She died June 3, 1849 in Raleigh North Carolina at age seventy-eight and was buried in City Cemetery Raleigh."}],"burial":{"cemetery_name":"City Cemetery","city":"Raleigh","county":"Wake","state":"North Carolina","country":"United States"},"slug":"frances-pollock-1771"},"X00866":{"id":"X00866","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1761,"month":3,"day":12,"country":"Ireland","county":"County Wexford"},"death":{"year":1844,"month":7,"day":7,"city":"Raleigh","county":"Wake","state":"North Carolina","country":"United States"},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2591","date_year":1790,"location_city":"New Bern","location_state":"North Carolina","children_ids":["HD2592","HD2593","HD2594"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"John Devereux","first_name":"John","last_name":"Devereux","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780858437/14086980_134217821296_s2jza3.jpg","bio_blurb":"Irish-born New Bern merchant and shipowner"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_name":"City Cemetery","city":"Raleigh","county":"Wake","state":"North Carolina","country":"United States"},"narrative_blocks":[{"category":"character","header":"A shipwreck made him a Carolina merchant","body":"An Irish former British naval officer, John Devereux was wrecked off New Bern and stayed, building a fleet that traded between Boston and Barbados. There he married the heiress Frances Pollock, founding a family that would reach into Connecticut and beyond.","number":1}],"slug":"john-devereux-1761"},"HD2592":{"id":"HD2592","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00866","mother_id":"HD2591"},"tags":["lawyer","slaveholder"],"sources":[{"short":"Online vital records; The Record LXXI; EH 1909"}],"birth":{"year":1793,"month":11,"day":17,"city":"New Bern","county":"Craven","state":"North Carolina","country":"United States"},"death":{"year":1869,"month":3,"day":7,"city":"Halifax","county":"Halifax","state":"North Carolina","country":"United States"},"marriages":[{"spouse_id":"X00872","children_ids":["HD2607","HD5936"],"marriage_number":1},{"spouse_id":"X01883","children_ids":[],"marriage_number":2,"date_year":1837}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Thomas Pollock Devereux","first_name":"Thomas","last_name":"Devereux","middle_name":"Pollock","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780856771/thomdev_wgx3vv.png","bio_blurb":"North Carolina lawyer, Supreme Court reporter, planter"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_name":"City Cemetery","city":"Raleigh","county":"Wake","state":"North Carolina","country":"United States"},"career":[{"role":"U.S. Attorney for the District of North Carolina"},{"role":"Reporter of the North Carolina Supreme Court","start_year":1826,"end_year":1839,"notes":"Published four volumes of law and two of equity reports (\"Devereux's Reports\")."},{"role":"Trustee","organization":"University of North Carolina","start_year":1820,"end_year":1827}],"education":[{"school_name":"Yale College","type":"college","dates":"graduated 1813"},{"school_name":"Litchfield Law School","type":"law","dates":"1813-1815"}],"narrative_blocks":[{"category":"law","header":"His law reports still bear his name","body":"As reporter of the North Carolina Supreme Court from 1826, Devereux published four volumes of law and two of equity that lawyers cited for generations as Devereux's Reports. He took up law in earnest only after business reverses spent his inherited fortune.","number":1},{"category":"character","header":"He held fifteen hundred people in bondage","body":"Inheriting his uncle's plantations, Devereux became one of North Carolina's largest enslavers, the people he held valued near three-quarters of a million dollars at emancipation. A staunch Unionist before secession, he backed the Confederacy once war came.","number":2}],"slug":"thomas-devereux-1793"},"HD2593":{"id":"HD2593","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00866","mother_id":"HD2591"},"tags":[],"sources":[{"short":"Online vital records; The Record LXXI; EH 1909"}],"birth":{"year":1795},"death":{"year":1837},"marriages":[{"spouse_id":"X00873","children_ids":["HD2595"],"marriage_number":1}],"gender":"male","