itution_id":"INST035"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"plot_notes":"Christ Church Cathedral, New Orleans, LA — reinterred 1945 with husband Bishop Leonidas Polk."},"narrative_blocks":[{"number":1,"category":"family","header":"Great-great-granddaughter of Jonathan Edwards","body":"Frances Ann Devereux Polk was the great-great-granddaughter of Jonathan Edwards (1703-1758) through the line Frances → her mother Frances Pollock Devereux → grandmother Eunice Edwards → great-grandfather Pierpont Edwards → Jonathan Edwards. The descent gave her family ties to one of America's most influential theological-philosophical figures and indirectly to Aaron Burr Sr.'s wife Esther Edwards, Jonathan Edwards's daughter. Her own marriage in 1830 carried the Edwards-Hooker line into the Episcopal-Confederate Polk family."},{"number":2,"category":"family","header":"Civil War widow; outlived Bishop Polk eleven years","body":"Frances and Bishop Leonidas Polk had married May 13, 1830 in Raleigh North Carolina, the year of his Episcopal ordination. On June 14, 1864 at Pine Mountain Georgia a Federal artillery shell killed him in the field — 'nearly cut in two' per battle reports — while he commanded a Confederate corps. Frances outlived him eleven years until her death April 17, 1875 in New Orleans, where she was buried at Christ Church Cathedral; both were reinterred together at Sewanee in 1945."},{"number":3,"category":"family","header":"1873-74 diary survives in UNC Southern Historical Collection","body":"During her widowhood Frances kept a diary across 1873 and 1874 recording her activities at the Gale household near Nashville Tennessee, where her daughter Katherine Polk Gale and son-in-law William Dudley Gale lived. The diary survives in the Gale and Polk Family Papers at the Southern Historical Collection, University of North Carolina at Chapel Hill — alongside Bishop Polk's Civil War letters, William Dudley Gale's Civil War letters as her son-in-law's aide-de-camp, and her daughter Katherine's 1895 Civil War recollections."}],"slug":"frances-polk-1807"},"HD2590":{"id":"HD2590","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00864","mother_id":"H00383"},"tags":[],"sources":[{"short":"Online vital records; The Record LXXI; EH 1909"}],"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"George Pollock","first_name":"George","last_name":"Pollock","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"george-pollock"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}