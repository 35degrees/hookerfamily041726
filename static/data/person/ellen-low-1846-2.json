as_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1896},"death":{"year":1943},"parents":{"father_id":"X00518","mother_id":"HD1630"},"marriages":[{"spouse_id":"X00524","children_ids":["HD1647"],"marriage_number":1,"date_year":1927,"location_city":"Hancock","location_state":"New Hampshire"}],"tags":["military","diplomat"],"sources":[],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Diplomat","primary_url":"https://en.wikipedia.org/wiki/Jay_Pierrepont_Moffat"},"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Jay Pierrepont Moffat","first_name":"Jay","last_name":"Moffat","middle_name":"Pierrepont","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/a/a2/Jay_Pierrepont_Moffat.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"US Ambassador to Canada through early WWII","body":"Nominated by President Roosevelt, he served as U.S. Ambassador to Canada from 1940 until his death in 1943 — through the first year of U.S. participation in World War II. He had previously been Chief of the Western European Division of the State Department 1937-1940."},{"number":2,"category":"lineage","header":"Lineal descendant of Chief Justice John Jay","body":"He was a lineal descendant of Chief Justice John Jay — Treaty of Paris negotiator and first Chief Justice of the United States. The Jay ancestry was unusual for a career diplomat: the great Federalist diplomat-jurist's lineal heir served as ambassador 150 years later."},{"number":3,"category":"family","header":"Father-in-law was Pearl Harbor ambassador","body":"His wife Lilla Cabot Grew's father Joseph C. Grew was U.S. Ambassador to Japan at the time of the Pearl Harbor attack — and 'tried hard to avert the Pacific stage of WWII' per the NYT obituary. Two senior ambassador positions thus passed through one 1927 marriage."},{"number":4,"category":"death","header":"Died Ottawa surgery complications at forty-seven","body":"He died at Ottawa on 25 January 1943 from surgery complications for phlebitis — two and a half weeks after his 47th birthday. His service was held at Christ Church Cathedral Ottawa, attended by Canadian Prime Minister Mackenzie King."}],"slug":"jay-moffat-1896"},"HD1640":{"id":"HD1640","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1898},"death":{},"parents":{"father_id":"X00518","mother_id":"HD1630"},"marriages":[],"tags":[],"sources":[],"gender":"female","notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Barclay Moffat","first_name":"Elizabeth","middle_name":"Barclay","maiden_name":"Moffat","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elizabeth-moffat-1898"},"HD1641":{"id":"HD1641","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1901,"month":5,"day":12,"city":"Manhattan","county":"New York County","state":"New York"},"death":{"year":1996,"month":4,"day":17,"city":"Hightstown","county":"Mercer County","state":"New Jersey"},"parents":{"father_id":"X00518","mother_id":"HD1630"},"marriages":[{"marriage_number":1,"spouse_id":"I00176","end_type":"death_of_spouse","end_year":1994,"children_ids":["HD3136","HD3137","HD3138"],"date_year":1926,"date_month":1,"date_day":1}],"tags":["politician","diplomat","lawyer","author","harvard_graduate"],"sources":[{"label":"Wikipedia — Abbot Low Moffat","url":"https://en.wikipedia.org/wiki/Abbot_Low_Moffat"}],"gender":"male","notable":{"is_notable":true,"notable_category":["politics","diplomacy","author"],"notable_blurb":"Head of State Dept SE Asia Division 1944-47","primary_url":"https://en.wikipedia.org/wiki/Abbot_Low_Moffat","primary_url_label":"Wikipedia"},"number_of_marriages":1,"institutions":[{"institution_id":"INST002","institution_blurb":"Harvard University class of 1923."},{"institution_id":"INST063","institution_blurb":"Columbia University Law School class of 1926."}],"narrative_blocks":[{"header":"He warned Washington not to back France","body":"As head of the State Department's Division of Southeast Asian Affairs 1944-1947, Abbot Low Moffat was the point man on Indochina policy. He knew Ho Chi Minh, detailed FDR's vision for a post-colonial Indochina, and forcefully opposed the decision to back the French in their attempt to retake the colony after WWII. Under Truman, the State Department reversed course.","number":1},{"header":"He sponsored legislation to build the New York","body":"Abbot Low Moffat served in the New York State Assembly from 1929 to 1943, where he sponsored the legislation that authorized the New York State Thruway. He went on to serve as a diplomat at posts in Greece, the United Kingdom, Burma, and Ghana. He also published a biography of King Mongkut of Siam in 1961 and genealogical works on the Low and Pierrepont family lines.","number":2},{"header":"He compiled the Pierrepont genealogy","body":"In 1962, Abbot Low Moffat published The Pierreponts, 1802-1962, tracing the American forebears and descendants of Hezekiah Beers Pierpont and Anna Maria Constable. The Pierrepont family is central to the Hooker tree: Rev. James Pierpont, great-grandson of Mary Hooker Pierpont, co-founded Yale in 1701. Moffat's Pierrepont genealogy — compiled by a Hooker descendant — is a primary research source for this project.","number":3}],"cross_connections":[],"bio":{"display_name":"Ambassador Abbot Low Moffat","first_name":"Abbot","last_name":"Moffat","middle_name":"Low","title":"Ambassador","married_names":[],"photo_url":"https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcR5tg4syKJuBQ-DBgzaH01FlLpuvzUj8i0XktqF1-j79_MRsEuEq9BY9QJ7L7KvxeAb1wHj6Q&s"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"abbot-moffat-1901"},"HD1631":{"id":"HD1631","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1873},"death":{"year":1903},"parents":{"father_id":"HD1537","mother_id":"X00517"},"marriages":[],"tags":["never_married"],"sources":[],"gender":"male","notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Henry Evelyn Pierrepont III","first_name":"Henry","last_name":"Pierrepont","suffix":"III","middle_name":"Evelyn","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"henry-pierrepont-iii-1873"},"HD1632":{"id":"HD1632","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"