ty-two the same month he graduated Williams College."}],"burial":{"cemetery_id":"CEM023"},"slug":"lewis-strong-1785"},"X01168":{"id":"X01168","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0372","date_year":1810,"date_month":10,"date_day":3,"end_type":"death","end_year":1863,"children_ids":["H02686","H02687","H02688","H02689","H02690","H02691","H02692","H02693","H02694","H02695"]}],"parents":{"father_research_notes":"Hon. Stephen Chester, Sheriff of Hartford County CT."},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1791,"month":5,"day":17,"city":"Wethersfield","county":"Hartford","state":"Connecticut"},"death":{"year":1866,"month":6,"city":"Gorham","state":"Maine","county":"Cumberland"},"cross_connections":[],"bio":{"display_name":"Mariah Chester Strong","first_name":"Mariah","maiden_name":"Chester","married_names":["Strong"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM023"},"slug":"mariah-chester-1791"},"X00117":{"id":"X00117","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1745,"month":1,"day":9,"city":"Northampton","state":"Massachusetts"},"death":{"year":1819,"month":11,"day":7,"city":"Northampton","state":"Massachusetts","cause":"angina pectoris"},"burial":{"cemetery_id":"CEM023","plot_notes":"Bridge Street Cemetery, Northampton, Massachusetts"},"parents":{"mother_research_notes":"Phebe Lyman Strong","father_research_notes":"Lt. Caleb Strong of Northampton"},"marriages":[{"spouse_id":"H00525","children_ids":["HD0369","HD0370","HD0371","HD0372","HD0373","HD0374","HD0375","HD0376","HD0377"],"marriage_number":1}],"political_offices":[{"title":"6th Governor of Massachusetts","dates":"1800-1807"},{"title":"10th Governor of Massachusetts","dates":"1812-1816"},{"title":"U.S. Senator (Class 2), Massachusetts","dates":"1789-1796","notes":"Member of the inaugural U.S. Senate"},{"title":"Delegate, Philadelphia Convention","dates":"1787","notes":"Helped draft the U.S. Constitution"},{"title":"Massachusetts Constitutional Convention","dates":"1779","notes":"Member of committee that drafted the Massachusetts State Constitution"},{"title":"County Attorney, Hampshire County","dates":"1776-1800","notes":"24 years"}],"prominent_name_reason":"Gov. Caleb Strong — Founding Father; delegate to 1787 Philadelphia Convention; helped draft Massachusetts State Constitution (1779); U.S. Senator in inaugural Senate; 6th and 10th Governor of Massachusetts; instrumental in drafting Judiciary Act of 1789 and 11th Amendment; worked on Quock Walker cases establishing slavery incompatible with Massachusetts constitution. Married Sarah Hooker (H00525), daughter of Rev. John Hooker of Northampton.","sources":[{"short":"Wikipedia","notes":"Caleb Strong article"},{"label":"Wikipedia — Caleb Strong","url":"https://en.wikipedia.org/wiki/Caleb_Strong"}],"gender":"male","tags":[],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["politics"],"notable_blurb":"Governor of Massachusetts 1800-1807 (Federalist) and U.S. Senator","primary_url":"https://en.wikipedia.org/wiki/Caleb_Strong","primary_url_label":"Wikipedia"},"cross_connections":[],"education":[{"notes":"Temporarily blinded by smallpox shortly after graduation — prevented him from military service during the Revolution","school_name":"Harvard College","graduation_year":1764,"institution_id":"INST002"}],"bio":{"title":"Governor","display_name":"Gov. Caleb Strong","first_name":"Caleb","last_name":"Strong","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married his pastor's daughter, 1777","body":"He joined Rev. John Hooker's Northampton congregation in 1772 at age 27. Five years later, when Rev. Hooker died of smallpox in February 1777, the newly-licensed lawyer married his late pastor's daughter Sarah Hooker in November 1777. The Hooker name thus passed directly into the family of a future Founding Father."},{"number":2,"category":"politics","header":"U.S. Senator from Massachusetts, 1789-1796","body":"In 1788 he was elected as one of the first two U.S. Senators from Massachusetts and served 1789-1796 in the Federalist majority of the early Senate. He had previously served at the 1787 Constitutional Convention as a Massachusetts delegate, though he left Philadelphia before the document was signed because of family illness."},{"number":3,"category":"politics","header":"Federalist Governor of Massachusetts, 1800-1807","body":"He served seven consecutive one-year terms as Federalist Governor of Massachusetts 1800-1807, then a four-term return 1812-1816. During the War of 1812 his Federalist stance against the war and against New England troop mobilization drew Madison administration ire but was popular in Massachusetts."},{"number":4,"category":"family","header":"Father of nine, source of the Strong-Hooker line","body":"With his wife Sarah Hooker Strong he had nine children: 5 sons and 4 daughters including Clarissa Strong Dwight, the matriarch of the New Haven Dwight-Lyman branch. The family thereby connected the Massachusetts political elite to the Hooker founding line of Hartford CT."}],"slug":"caleb-strong-1745"},"H00525":{"id":"H00525","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1758,"month":1,"day":30,"city":"Northampton","state":"Massachusetts"},"death":{"year":1817,"month":2,"day":12,"city":"Northampton","state":"Massachusetts"},"parents":{"father_id":"H00264","mother_id":"I00043"},"tags":[],"sources":[{"short":"Edward Hooker 1909"},{"short":"Wikipedia","notes":"Caleb Strong article"}],"burial":{"cemetery_id":"CEM023","plot_notes":"Bridge Street Cemetery, Northampton, Massachusetts"},"prominent_name_reason":"Wife of Gov. Caleb Strong — 6th and 10th Governor of Massachusetts (1800-1807, 1812-1816), U.S. Senator, Founding Father, delegate to the Philadelphia Convention of 1787. Daughter of Rev. John Hooker of Northampton (H00264). 5th-generation descendant of Thomas Hooker.","marriages":[{"spouse_id":"X00117","children_ids":["HD0369","HD0370","HD0371","HD0372","HD0373","HD0374","HD0375","HD0376","HD0377"],"marriage_number":1,"date_year":1777,"date_month":11,"date_day":29,"location_city":"Northampton","location_state":"Massachusetts"}],"gravestone_inscription":"In Memory of Mrs. Sarah Strong, the wife of Caleb Strong and daughter of the Rev John Hooker who having early devoted herself to the service of her Redeemer and through life exemplified the virtues & graces of his religion gently breathed out her spirit in humble reliance upon his power and love on the 12th day of February AD 1817 in the 60th year of her age.","gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[],"notable_blurb":null,"primary_url":null,"primary_url_label":null},"cross_connections":[],"bio":{"display_name":"Sarah Hooker Strong","first_name":"Sarah","last_name":"Strong","married_names":["Strong"],"maiden_name":"Hooker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Father died of smallpox before her wedding","body":"Her father Rev. John Hooker pastor of Northampton MA died of smallpox in February 1777 when she was 19. Caleb Strong, a lawyer who had joined her father's congregation five years earlier, married her in November 1777 — nine months after the funeral."},{"number":2,"category":"family","header":"Matriarch of the Strong-Hooker-Dwight branch","body":"Mother of nine children with Gov. Caleb Strong including Clarissa Strong Dwight, who married Timothy Dwight Jr. in 1809 and produced the New Haven Dwight-Lyman cluster — three sons of whom were Yale-educated and one of whom Sam's tree records as ancestor of two generations of Yale presidents."}],"slug":"sarah-strong-1758"}},"burialCemetery":{"id":"CEM023","name":"Bridge Street Cemetery","city":"Northampton","county":"Hampshire County","state":"Massachusetts","country":"United States","gps":{"latitude":42.325,"longitude":-72.6278},"visitable":true,"hooker_connections":["H00377","H00378","H00379","H00525","H00916","H00918","H00923","H00925","H00926","H00943","H00945","H00949","HD0609","HD1998","HD2406","HD2407","I00168","X00117","X00641","X00786","H00532","HD0372","H02674","H02675","H02686","H02688","H02690","H02691","H02692","H02693","H02694","X01168","I01221","H05241","H05248","I01180","I01182","I01183","I01184","HD4935","HD4936","HD4937","HD4938","HD4939","HD4940","X03309","X03310"]},"institutionsById":{},"crossConnections":[]}