:{"father_id":"H01254","mother_id":"I00871"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00886","date_year":1851,"date_month":2,"date_day":19,"location_country":"United States","children_ids":["H03794","H03795","H03796","H03797"]}],"education":[{"school_name":"Ithaca Academy","dates":"before 1846","type":"secondary","notes":"Per UW archives biography. Also taught school for several years before leaving New York in 1846."}],"career":[{"role":"Teacher","organization":"New York (various)","end_year":1846,"notes":"Taught school for several years before leaving for Wisconsin per UW archives."},{"role":"Newspaper Co-founder","organization":"Fond du Lac Journal, Fond du Lac Wisconsin","start_year":1846,"end_year":1846,"notes":"Co-founded with J.O. Henning. First newspaper established in Fond du Lac County. Sold within six months."},{"role":"Newspaper Co-owner","organization":"Fond du Lac Whig, Fond du Lac Wisconsin","start_year":1846,"end_year":1848,"notes":"Bought half interest with J.M. Gellett after selling Journal. Sold interest January 1848 and moved to Waupun."},{"role":"Attorney","organization":"Waupun, Wisconsin","start_year":1848,"end_year":1889,"notes":"Read law in Waupun from 1848. Admitted to bar Aug 6, 1850 per personal diary (USBD says Apr 17, 1854 — discrepancy). Practiced ~40 years. Traveled on horseback across Dodge County to court in Juneau; sometimes stayed overnight at inn between Minnesota Junction and Juneau."},{"role":"Lobbyist","organization":"Wisconsin legislature","notes":"Active as lobbyist in 1850s per Waupun city history records."},{"role":"Newspaper Publisher","organization":"Waupun Times, Waupun Wisconsin","start_year":1866,"end_year":1867,"notes":"Published Republican paper 1866; sold personal interest 1867 but remained corresponding editor. Firm Hooker, Bell & Hooker continued until paper was sold in 1894."},{"role":"Printer","organization":"Waupun, Wisconsin","notes":"Operated printing press alongside law practice; with son Culver ran printing business for many years."},{"role":"Co-founder","organization":"Waupun Oil Company, Waupun Wisconsin","start_year":1866,"notes":"With others formed oil company 1866; sold oil by the barrel from West Virginia well."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["wisconsin_migration"],"research_tags":["has_discrepancy"],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Lawyer who published Fond du Lac's first newspaper","body":"Eli Hooker settled in Fond du Lac, Wisconsin in 1846, co-founded the city's first newspaper the Fond du Lac Journal, and became a Waupun attorney who rode horseback across Dodge County to court in Juneau — sometimes staying overnight at an inn between Minnesota Junction and Juneau. He attended the 1860 Republican convention in Chicago that nominated Lincoln, gave temperance talks, and died December 10, 1889 — his wife Catherine following exactly one month later."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"eli-hooker-1820"},"I00886":{"id":"I00886","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Catherine","middle_name":"Richardson","last_name":"Hooker","maiden_name":"Sharp","married_names":["Hooker"],"gender":"female","display_name":"Catherine Richardson Hooker"},"birth":{"year":1832,"month":1,"day":6,"city":"Gambier","county":"Knox County","state":"Ohio","country":"United States"},"baptism":{},"death":{"year":1890,"month":1,"day":10,"city":"Waupun","county":"Dodge County","state":"Wisconsin","country":"United States"},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_d