 1701, and for years the records assumed she had died with him. In fact she lived on, married a second time, and raised three children before her death a quarter-century later."}],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"rachel-talcott-1676"},"T00437":{"id":"T00437","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":2,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1678,"month":1,"day":28},"death":{"year":1758,"month":1,"day":30,"city":"Glastonbury","state":"Connecticut"},"parents":{"father_id":"T00036","mother_id":"U00025"},"marriages":[{"spouse_id":"U00031","children_ids":["T00462","T00463","T00464","T00465","T00466","T00467","T00468","TD0377"],"marriage_number":1,"end_type":"death_of_survivor","end_year":1768,"date_year":1703,"date_month":3,"date_day":18}],"tags":[],"sources":[{"short":"Talcott 1876","page":"Entry 437"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sgt. Nathaniel Talcott","title":"Sergt.","first_name":"Nathaniel","last_name":"Talcott","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"nathaniel-talcott-1678"},"X01778":{"id":"X01778","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"EH 1909"}],"gender":"unknown","number_of_marriages":1,"marri