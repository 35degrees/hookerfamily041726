"day":1},"parents":{},"marriages":[{"marriage_number":1,"spouse_id":"HD2817","children_ids":["HD2818","HD2819"],"date_year":1861,"date_month":5,"date_day":14}],"number_of_marriages":1,"tags":[],"sources":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Henriette Caroline Maltby Cushman","first_name":"Henriette","middle_name":"Caroline","last_name":"Cushman","maiden_name":"Maltby","married_names":["Cushman"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"henriette-maltby-1837"},"X01916":{"id":"X01916","has_descendants_documented":true,"is_placeholder":false,"gender":"male","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"birth":{"year":1784,"month":3,"day":8,"city":"Plainfield","county":"Windham County","state":"Connecticut","country":"United States"},"death":{"year":1848,"month":9,"day":16,"city":"Troy","county":"Rensselaer County","state":"New York","country":"United States"},"burial":{"cemetery_id":"CEM039"},"parents":{"father_research_notes":"Judge Isaac Cushman","mother_research_notes":"Sarah Paine Cushman"},"marriages":[{"marriage_number":1,"spouse_id":"HD1033","children_ids":["HD6062","HD6063","HD6064","HD6065","HD2816","HD6066","HD2817","HD6067"],"date_year":1812}],"number_of_marriages":1,"political_offices":[{"title":"U.S. Representative","jurisdiction":"New York 10th District","dates":"1817-1819","notes":"Elected as Federalist to 15th Congress."},{"title":"Regent","jurisdiction":"University of the State of New York","dates":"1830-1834"},{"title":"Recorder","jurisdiction":"Troy, New York","dates":"1834-1838"},{"title":"Judge","jurisdiction":"Third Circuit Court, New York","dates":"1838-1844"}],"tags":["yale_alumni","litchfield_law_school","federalist","congressman","yale_graduate"],"sources":[{"short":"Wikipedia — John P. Cushman","url":"https://en.wikipedia.org/wiki/John_P._Cushman"}],"notable":{"is_notable":true,"notable_category":["government","law"],"notable_blurb":"U.S. Congressman, New York circuit judge, Litchfield Law","primary_url":"https://en.wikipedia.org/wiki/John_P._Cushman","primary_url_label":"Wikipedia"},"narrative_blocks":[{"header":"U.S. Congressman, circuit judge, and rector of Troy","detail":"Cushman prepared for Yale at Plainfield Academy alongside John Adams (Yale 1795) and read law under Judge Zephaniah Swift of Windham before arriving at Litchfield. At Litchfield he became close friends with William L. Marcy — who went on to serve as U.S. Senator, Governor of New York, Secretary of War, and Secretary of State. Cushman's Litchfield Law School classmate John Allen Collier gave a memorial address at the opening of the Supreme Court after his death. He was also a trustee of Union College from 1833 until his death, and a regent of New York University. His father-in-law was Colonel Benjamin Tallmadge, Washington's spymaster. (Wikipedia; Litchfield Historical Society)","body":"John Paine Cushman graduated Yale in 1807, studied at the Litchfield Law School in 1808, and was admitted to the bar in 1809. He was elected to the 15th Congress (1817-1819) as a Federalist, then served as Recorder of Troy (1834-1838) and Judge of the Third Circuit Court (1838-1844). Upon his death in 1848, the U.S. Supreme Court adjourned in his honor.","number":1},{"header":"The Cushman Mansion","detail":"The mansion remained in the family's orbit through much of the 19th century. Maria's father Colonel Benjamin Tallmadge was a frequent correspondent; their social circle included the leading legal and political figures of early New York State. (Landmark; YouTube documentary)","body":"The Cushman family home at 39 First Street in Troy, built in 1820, is a four-story all-brick Federal-style house. Its original owners were direct descendants of Revolutionary War heroes and Plymouth Colony settlers.","number":2}],"cross_connections":[],"bio":{"display_name":"Hon. John Paine Cushman","first_name":"John","middle_name":"Paine","last_name":"Cushman","title":"Honorable","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/8/89/John_Paine_Cushman.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST024","relationship":"alumnus","institution_blurb":"Attended 1808; admitted bar 1809; permanently settled Troy NY."},{"institution_id":"INST022"}],"landmarks":[{"landmark_id":"LM137","landmark_blurb":"His 1820 Troy townhouse, near the Washington Park he helped found."}],"artworks":[],"quotes":[],"military_service":[],"slug":"john-cushman-1784"},"HD1033":{"id":"HD1033","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00757","mother_id":"X00297"},"tags":[],"sources":[],"birth":{"year":1790,"month":3,"day":25,"city":"Litchfield","county":"Litchfield County","state":"Connecticut","country":"United States"},"death":{"year":1878,"month":3,"day":19,"city":"Troy","county":"Rensselaer County","state":"New York","country":"United States"},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X01916","children_ids":["HD6062","HD6063","HD6064","HD6065","HD2816","HD6066","HD2817","HD6067"],"date_year":1812}],"notable":{"is_notable":true,"notable_category":["education","social_history"],"notable_blurb":"Litchfield Female Academy; daughter of Culper Ring's Benjamin","primary_url":"https://ledger.litchfieldhistoricalsociety.org/ledger/students/1","primary_url_label":"Litchfield Historical Society"},"burial":{"cemetery_id":"CEM039"},"narrative_blocks":[{"header":"Student at the Litchfield Female Academy","detail":"Maxcy's friend Lemuel Williams wrote to him on Christmas Eve 1808, the week before his own wedding: 'O! my Virgil! How ardently I wish that we might all meet together, you & your Maria, I and my Sarah, in the bonds of wedded love.' The letter suggests Maria had already ended the engagement by then. Cushman and Maxcy had been classmates at Litchfield Law School — making the social circle of early American legal education small enough that broken hearts and new marriages overlapped by a season. (Galloway-Maxcy-Markoe Papers, Library of Congress; Litchfield Historical Society)","body":"Maria Jones Tallmadge studied at the Litchfield Female Academy in 1801 and 1802. Before meeting John Cushman, she was engaged to Virgil Maxcy, a Litchfield Law School student. A surviving letter from Tapping Reeve consoling Maria suggests the break came around 1807 — after which John Cushman, who had just arrived at the same law school, became her husband in 1812.","number":1},{"header":"Daughter of Colonel Benjamin Tallmadge","detail":"Benjamin Tallmadge is credited with uncovering the treason of Benedict Arnold and thwarting the British capture of West Point. He corresponded with his son-in-law John Cushman on legal matters throughout the 1820s. A 1824 letter survives in which Tallmadge wrote to Cushman about a domestic incident at his Litchfield home — a reminder that even the Culper Ring's spymaster kept up a lively family correspondence. (Litchfield Historical Society; Wikipedia on Benjamin Tallmadge)","body":"Maria's father was Colonel Benjamin Tallmadge, Yale 1773, who ran General Washington's spy network — the Culper Ring — during the Revolutionary War. He later served as a U.S. Congressman. Her maternal grandfather was General William Floyd, member of the Continental Congress and signer of the Declaration of Independence.","number":2}],"cross_connections":[{"type":"cousin_marriage","related_id":"HD2277","display_label":"is the mother of Edwards Williams, who married Mary Floyd Cushman"}],"bio":{"display_name":"Maria Jones Tallmadge Cushman","first_name":"Maria","last_name":"Cushman","maiden_name":"Tallmadge","middle_name":"Jones Tallmadge","married_names":["Cushman"],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780949421/99813834_9431142c-ad76-43ca-81bc-0f858c6f8faf_ig4tdh.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[{"artwork_id":"ART079","role":"subject"}],"quotes":[],"military_service":[],"slug":"maria-cushman-1790"}},"burialCemetery":{"id":"CEM760","name":"Union Cemetery","city":"Laconia","county":"Belknap","state":"New Hampshire","country":"United States","hooker_connections":["HD2818","HD2819","I01647"]},"institutionsById":{},"crossConnections":[]}