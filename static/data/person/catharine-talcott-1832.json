calculation":true,"generation_from_john_talcott":5,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1766,"month":8,"day":5,"city":"Glastonbury","state":"Connecticut","country":"United States","county":"Hartford"},"death":{"year":1848,"month":10,"day":13,"city":"Lanesborough","state":"Massachusetts","country":"United States","county":"Berkshire"},"parents":{"father_id":"T01001","mother_id":"U00042"},"marriages":[{"children_ids":["T01469","T01470","T01471","T01472","T01474","T01475","T01473","T01476","T01477","T01478"],"spouse_id":"X01834","marriage_number":1,"date_year":1790,"date_month":8,"date_day":10,"location_city":"Lanesborough","location_county":"Berkshire","location_state":"Massachusetts","location_country":"United States","end_type":"death","end_year":1848}],"sources":[{"short":"Talcott 1876","page":"Entry 1390"}],"gender":"male","tags":["massachusetts_migration"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Captain Nehemiah Talcott","title":"Captain","first_name":"Nehemiah","last_name":"Talcott","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM198","plot_notes":"Talcott Cemetery, Lanesborough, Berkshire County MA."},"narrative_blocks":[{"number":1,"category":"migration","header":"Migrated to Lanesborough at twenty-four","body":"Capt. Nehemiah Talcott was born in Glastonbury Connecticut in 1766 and migrated to Lanesborough Massachusetts by 1790 — the year of the first US Census, which shows him already living there. He married Tirzah Platt that August in her hometown and they raised ten children in Lanesborough. He died there in 1848 at eighty-two."},{"number":2,"category":"death","header":"Died three months after his wife","body":"Tirzah Platt Talcott died in Lanesborough on July 14, 1848 at seventy-seven. Capt. Nehemiah followed her exactly three months later on October 13, 1848 at eighty-two. They were buried together in Talcott Cemetery — the Lanesborough burying ground that bore the family name."}],"slug":"nehemiah-talcott-1766"},"X01834":{"id":"X01834","has_descendants_documented":false,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"EH 1909"}],"gender":"unknown","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"T01390","date_year":1790,"date_month":8,"date_day":10,"location_city":"Lanesborough","location_county":"Berkshire","location_state":"Massachusetts","location_country":"United States","end_type":"death","end_year":1848,"children_ids":["T01469","T01470","T01471","T01472","T01474","T01475","T01473","T01476","T01477","T01478"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1771,"month":3,"day":30,"city":"Lanesborough","county":"Berkshire","state":"Massachusetts","country":"United States"},"death":{"year":1848,"month":7,"day":14,"city":"Lanesborough","county":"Berkshire","state":"Massachusetts","country":"United States"},"cross_connections":[],"bio":{"display_name":"Tirzah Platt Talcott","first_name":"Tirzah","last_name":"Talcott","maiden_name":"Platt","married_names":["Talcott"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM198","plot_notes":"Talcott Cemetery, Lanesborough, Berkshire County MA. FindAGrave 112083228."},"narrative_blocks":[{"number":1,"category":"family","header":"Brought her husband to her hometown","body":"Tirzah Platt was born in Lanesborough Massachusetts in 1771. When she married Capt. Nehemiah Talcott in August 1790 he had already migrated west from Glastonbury Connecticut and was living in Lanesborough by the time of the Census. She gave him ten children and never left her hometown — dying there in July 1848."}],"slug":"tirzah-platt-1771"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}