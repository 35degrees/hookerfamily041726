sidence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST018"},{"institution_id":"INST121"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"edward-parsons-1863"},"HD1861":{"id":"HD1861","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1902},"death":{"year":1979},"parents":{"father_id":"X00600","mother_id":"HD1854"},"marriages":[{"spouse_id":"X00606","children_ids":["HD1883"],"marriage_number":1,"date_year":1927,"date_month":4,"date_day":30}],"tags":["academic","author"],"sources":[],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Harvard sociologist; father of structural functionalism","primary_url":"https://en.wikipedia.org/wiki/Talcott_Parsons"},"narrative_blocks":[{"header":"Named \"Talcott\" after his Talcott ancestry","detail":"Talcott Parsons's mother Mary Augusta Ingersoll (HD1854) was the daughter of George Lyman Ingersoll and Catharine L. Talcott — a descendent of T01001 Samuel Talcott and through him of the Hartford founder John Talcott. The name \"Talcott\" was chosen in honor of that line, making Talcott Parsons simultaneously an 9th-generation Hooker descendant and a direct link between the two founding Hartford families that this database tracks. His father Edward Smith Parsons was a Yale Divinity graduate and Congregational minister — the Puritan tradition running directly to Harvard's leading sociologist.","body":"His name \"Talcott\" honored his maternal great-grandmother Catharine L. Talcott, great-great-great-great-granddaughter of John Talcott, Hartford founder. He was himself a 9th-generation descendant of Rev. Thomas Hooker.","number":1},{"header":"Theorized that Hooker's Puritanism created American democracy","detail":"Parsons maintained that Calvinist radicalism, as expressed in New England Puritanism, established something unique in the world: \"radical views on individuality, egalitarianism, skepticism toward state power, and the zeal of the religious calling.\" He traced American democracy and exceptionalism directly to the Puritan Revolution. The extraordinary irony: Rev. Thomas Hooker founded Hartford CT in 1636 by leading his congregation out of Massachusetts to establish a civil covenant. His 9th-generation descendant — carrying both the Hooker and Talcott blood of Hartford's founding generation — became the 20th century's foremost theorist of how that very Puritan act shaped all of American civilization.","body":"Parsons argued that Calvinist-Puritan value patterns — the tradition of Thomas Hooker himself — became institutionalized as the foundational \"American value system.\"","number":2},{"header":"Harvard's most influential — and most criticized — sociologist","detail":"Parsons joined Harvard's newly created sociology department in 1930 and helped found the Department of Social Relations. His translations of Max Weber introduced Weber's thought to English-speaking scholarship. He was president of the American Sociological Association in 1949. His structural functionalism dominated American sociology for three decades before being widely criticized in the 1970s as too abstract and socially conservative. FBI director J. Edgar Hoover authorized a security investigation of Parsons in 1952 on accusations of communist sympathies. Parsons responded: \"This allegation is so preposterous that I cannot understand how any reasonable person could come to the conclusion that I was a member of the Communist Party or ever had been.\"","body":"One of the most famous sociologists in the world from the 1940s to the 1970s; translated Max Weber into English; founding member of Harvard's sociology department; investigated by FBI during McCarthy era.","number":3}],"number_of_marriages":1,"cross_connections":[{"type":"parallel_careers","related_id":"HD5950","display_label":"the Chicago anthropologist of the same era"},{"type":"parallel_careers","related_id":"X00748","display_label":"a 1902-born kinsman who waged Cold War propaganda"}],"bio":{"display_name":"Talcott Parsons","first_name":"Talcott","last_name":"Parsons","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST018","relationship":"alumnus"},{"institution_id":"INST002","relationship":"faculty"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"talcott-parsons-1902"},"T01473":{"id":"T01473","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":6,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1802,"country":"United States","city":"Lanesborough","county":"Berkshire","state":"Massachusetts"},"death":{"year":1841,"country":"United States","month":9,"day":7},"parents":{"father_id":"T01390","mother_research_notes":"Tirzah Platt (b. Mar 30, 1771 Lanesboro MA)","mother_id":"X01834"},"marriages":[{"children_ids":["T01488","T01495","T01496","T01497","T01498","T01499","T01500"],"spouse_id":"X01881","marriage_number":1,"date_year":1826,"date_month":10,"date_day":24,"location_country":"United States","end_type":"death","end_year":1841}],"sources":[{"short":"Talcott 1876","page":"Entry 1473"},{"short":"Ingersoll genealogy (Avery 1926)"}],"gender":"male","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Nehemiah Platt Talcott","first_name":"Nehemiah","last_name":"Talcott","middle_name":"Platt","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"resea