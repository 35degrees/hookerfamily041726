m_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00366","mother_id":"X00456"},"tags":["politician"],"sources":[{"short":"Edward Hooker 1909","entry":"877"},{"short":"Pierpont genealogy (Moffat)"}],"birth":{"year":1775,"month":5,"day":16},"death":{"year":1851,"month":11,"day":16,"city":"North Haven","state":"Connecticut"},"marriages":[{"spouse_id":"X00468","children_ids":["HD1444","HD1445","HD1446","HD1447","HD1448","HD1449","HD1450"],"marriage_number":1,"date_year":1799,"date_month":9,"date_day":26}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Daniel Pierpont Esq.","first_name":"Daniel","last_name":"Pierpont","suffix":"Esq.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Forty-four years as North Haven Town Clerk","body":"Daniel Pierpont succeeded his father as Town Clerk of North Haven Connecticut and served in the role for forty-four years — from about 1807 until his death in 1851. The continuous-tenure record was one of the longer documented town-clerkships in early-Republic Connecticut, and combined with his cabinetmaking work, it positioned him as 'one of North Haven's leading citizens.'"},{"number":2,"category":"politics","header":"Five legislative terms, Constitutional Convention delegate","body":"Daniel Pierpont represented North Haven in the Connecticut General Assembly for five terms (1813, 1815, 1818, 1824, and one other), served as a Justice of the Peace for many years, and was a delegate to the Connecticut Constitutional Convention in Hartford. The combined civic portfolio — Town Clerk, JP, state representative, constitutional delegate — built one of the more complete antebellum local-leadership Connecticut careers."},{"number":3,"category":"family","header":"Pierpont Homestead 1809, now local historic district","body":"Around 1809 Daniel Pierpont purchased the Pierpont Homestead at 29 State Street North Haven — a Georgian Colonial built 1785 by Stephen Jacobs to which he added a rear addition in 1846. The homestead and the adjacent store run by son Rufus for over a hundred years became 'the center of life at the Pines Bridge in North Haven' and is today a local historic district. The house does not face State Street because the road originally curved to a ford across the river."},{"number":4,"category":"family","header":"Born and died North Haven, age seventy-six","body":"Daniel Pierpont was born May 16, 1775 in North Haven Connecticut and died there November 16, 1851 at age seventy-six, buried at Old Cemetery North Haven. He had married Esther Humiston on September 26, 1799 — she outlived him by thirteen years, dying August 17, 1864 in New Haven at age ninety. Their seven children were Bede, Elias, Esther/Stiles, Harriet, Sally, Jared, and Rufus."}],"slug":"daniel-pierpont-1775"},"X00468":{"id":"X00468","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1774},"death":{"year":1864},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00877","date_year":1799,"date_month":9,"date_day":26,"children_ids":["HD1444","HD1445","HD1446","HD1447","HD1448","HD1449","HD1450"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Esther Humiston","first_name":"Esther","maiden_name":"Humiston","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"