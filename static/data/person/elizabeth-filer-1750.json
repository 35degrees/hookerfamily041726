quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died at twenty-seven; two young children survived her","body":"Hannah Hooker married Richard Lord Jones in Hartford in 1793 and died on May 18, 1800 in Granville, New York, at twenty-seven — leaving behind two children, Elizabeth (born August 1792) and Horace (born January 1795), who were seven and five years old when she died. Her husband Richard Lord Jones outlived her by fifty-two years, dying in Indiana in 1852 at eighty-five; their daughter Elizabeth lived to eighty-nine, outliving her mother by eighty-two years."}],"burial":{"cemetery_id":"CEM495","plot_notes":"Old Yard, Middle Granville, Washington County NY per FA"},"slug":"hannah-hooker-1773"},"I00981":{"id":"I00981","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Richard","middle_name":"Lord","last_name":"Jones","married_names":[],"gender":"male","display_name":"Richard Lord Jones","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778906177/Nathan_Sanford_Portrait-resized_pkhczl.jpg","photo_notes":"Richard Lord Jones (1767-1852); photo attribution: see research_notes re filename discrepancy"},"birth":{"year":1767,"month":5,"day":15,"city":"Colchester","county":"New London County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1852,"month":7,"day":23,"city":"New Albany","county":"Floyd County","state":"Indiana","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM494","plot_notes":"Fairview Cemetery New Albany Indiana; stone reads 'A musician in the Army of the Revolution'; newer government stone reads 'Ten Year Old Fifer'"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"H00803","date_year":1793,"location_city":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1800,"children_ids":["H02055","H02056"]},{"marriage_number":2,"spouse_id":"I00982","location_country":"United States","children_ids":[]}],"education":[],"career":[{"role":"Merchant / cotton manufacturer","organization":"Hartford, Connecticut","end_year":1818,"notes":"Engaged in cotton manufacturing business in Connecticut after the war. EH describes him as 'a merchant at Hartford.'"},{"role":"Farmer","organization":"Gallipolis, Ohio; later New Albany, Indiana","start_year":1818,"end_year":1852,"notes":"Relocated to Gallipolis Ohio in 1818, then to a farm near New Albany Indiana where he died in 1852."}],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","rank":"Fifer / Musician","unit":"Captain James Watson's Company, Third Connecticut Regiment (Colonel Samuel B. Webb)","years":"1777-1780","notes":"Enlisted June 20, 1777 at age 10 — one of the youngest soldiers in the Revolutionary War. Served as fifer; participated in each march and engagement of his unit. Met both George and Martha Washington and General Lafayette. Served full 3-year term; discharged June 20, 1780. Gravestone: 'A musician in the Army of the Revolution' / 'Ten Year Old Fifer'."}],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["veteran","revolutionary_war"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"military","header":"His tombstone reads: 'Ten Year Old Fifer'","body":"Richard Lord Jones enlisted in June 1777 in Colonel Samuel B. Webb's Regiment and was put under the Master of the Band to learn fife; arriving at Morristown in January 1780, he would later write: 'The Inhabitants remarked that it was the coldest winter ever known by the oldest inhabitants. The troops drew no rations of meat for two days (hungry times.)' His gravestone at Fairview Cemetery in New Albany, Indiana carries two inscriptions — the original reads 'A musician in the Army of the Revolution,' and a government-issued stone beside it reads 'Ten Year Old Fifer,' for a man who was ten when he shouldered a fife into the Continental Army."},{"number":2,"category":"character","header":"He sang God Save America for Martha Washington","body":"Colonel Webb directed Jones to go to Colonel Jackson's hut, where Martha Washington and some ladies were, and sing her a song; Jones later wrote: 'I did so sing the song when she presented me with a bill of three dollars, Continental Currency. The bill has been kept, folded as she gave it to me.' The three-dollar Continental bill — kept folded precisely as Martha Washington handed it to a ten-year-old fifer in a New Jersey officer's hut in 1780 — is one of the most extraordinary artifacts in this entire family's history, passed from Washington's hands to a child soldier who would live to farm in Indiana and die at eighty-five in 1852."},{"number":3,"category":"military","header":"Walked 150 miles home to Hartford at thirteen","body":"When Jones received his discharge on June 20, 1780 — having served his full three-year term from age ten to thirteen — he left Jockey Hollow with two other discharged men and walked 150 miles north to Hartford, Connecticut, recording in his memoir that he arrived home 'without any accident.' That phrase — 'without any accident,' after a 150-mile walk home from a war entered at ten — is a small window into what it meant to be a child soldier in the Continental Army, and into the plainspoken Yankee temperament with which Jones recorded his entire service in the memoir he would write decades later in Indiana."}],"quotes":[],"sources":[{"label":"FamilySearch","url":"https://www.familysearch.org"}],"research_sources":[],"documents":[],"slug":"richard-jones-1767"},"H02055":{"id":"H02055","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Elizabeth","middle_name":"Hooker","last_name":"Jones","maiden_name":"Jones","married_names":["Jones"],"gender":"female","display_name":"Elizabeth Hooker Jones"},"birth":{"year":1792,"month":8,"day":14,"country":"United States"},"baptism":{},"death":{"year":1882,"month":2,"day":4,"city":"Sackets Harbor","county":"Jefferson County","state":"New York","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM496","plot_notes":"Lakeside Cemetery Sackets Harbor Jefferson County NY per FA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"generation_from_john_talcott":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00981","mother_id":"H00803"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"character","header":"Born before the Hartford wedding; lived ninety years","body":"Elizabeth Hooker Jones was born August 14, 1792 — a year before her parents Richard Lord Jones and Hannah Hooker were recorded as marrying in Hartford in 1793, a discrepancy in the records that may reflect an earlier ceremony, an error in the marriage date, or a gap in the documentary record. Her mother Hannah died in May 1800 when Elizabeth was seven; Elizabeth lived to eighty-nine, dying February 4, 1882 in Sackets Harbor, New York — outliving her mother by eighty-two years and her brother Horace Hooker Jones by thirty-one."}],"quotes":[],"sources":[{"label":"FamilySearch","url":"https://www.familysearch.org"},{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"elizabeth-jones-1792"},"H02056":{"id":"H02056","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Horace","middle_name":"Hooker","last_name":"Jones","married_names":[],"gender":"male","display_name":"Horace Hooker Jones"},"birth":{"year":1795,"month":1,"day":6,"country":"United States"},"baptism":{},"death":{"year":1851,"month":12,"city":"Louisville","county":"Jefferson County","state":"Kentucky","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM275","plot_notes":"Cave Hill Cemetery Louisville KY per FA; burial delayed to Feb 17, 1852"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"generation_from_john_talcott":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00981","mother_id":"H00803"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00983","date_year":1845,"date_month":2,"date_day":4,"location_city":"Louisville","location_state":"Kentucky","location_country":"United States","children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Hooker","inspired_by_id":"H00001","description":"Middle name 'Hooker' preserves his mother Hannah Hooker's birth family in the Jones line — she died in 1800 when he was approximately five years old."}],"artworks":[],"tags":["named_for_hooker"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"His mother died before he turned six","body":"Horace Hooker Jones was born January 6, 1795 with 'Hooker' as his middle name, carrying his mother Hannah Hooker's birth family forward into the Jones line. His mother died in May 1800 when he was five; he died in December 1851 at fifty-six in Louisville, Kentucky — a businessman and member of the firm Jones and Halbert — his burial delayed until February 17, 1852 while his widow Flora located a site at Cave Hill Cemetery."}],"quotes":[],"sources":[{"label":"FamilySearch","url":"https://www.familysearch.org"},{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"horace-jones-1795"},"H00804":{"id":"H00804","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":true,"is_easter_egg":false,"generation_from_john_talcott":5},"birth":{"year":1775},"parents":{"father_id":"H00350","mother_id":"X00321"},"tags":["has_discrepancy"],"sources":[{"short":"Edward Hooker 1909","entry":"804"}],"death":{"year":1810},"marriages":[{"spouse_id":"X00322","children_ids":["HD1063","HD1064"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Nathaniel Hooker","first_name":"Nathaniel","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"nathaniel-hooker-1775"},"X00322":{"id":"X00322","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_de