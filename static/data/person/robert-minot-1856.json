ve. He was promoted to Lieutenant Colonel in 1932 and became the first commander of the 771st Tank Destroyer Battalion when it was activated on December 15, 1941 — two weeks after Pearl Harbor. He led the early training stages but was forced to leave the unit in 1942 due to illness, never deploying with the battalion he had formed.","number":3}],"cross_connections":[],"bio":{"display_name":"Major Wayland Manning Minot","first_name":"Wayland","last_name":"Minot","middle_name":"Manning","title":"Major","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/en/9/93/Wayland_Minot_%28Harvard_Crimson_football_player%29_circa_1910.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"wayland-minot-1889"},"X00749":{"id":"X00749","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1893},"death":{"year":1960},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2337","end_type":"death_of_spouse","end_year":1957,"children_ids":["HD2343","HD2344","HD2372","HD2373","HD2374"],"date_year":1913,"date_month":4,"date_day":12,"location_city":"Boston","location_state":"Massachusetts"}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Anna Marie Shaughnessy Minot","first_name":"Anna","last_name":"Minot","middle_name":"Marie","maiden_name":"Shaughnessy","married_names":["Minot"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"anna-shaughnessy-1893"},"HD2343":{"id":"HD2343","h