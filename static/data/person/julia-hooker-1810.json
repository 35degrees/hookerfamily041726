0","mother_id":"I01192"},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":0,"marriages":[],"career":[],"education":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died at about two","body":"Martha Vinal Hopkins was born about 1840 and died February 16, 1843, at about two years old — the second of Julia Ann Hooker's two children to outlive their mother, who had died in Chicago the previous year. Her first name honored Martha Vinal Chickering, wife of her uncle Henry Brown Hooker."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM553"},"residence":{"country":"United States"},"sources":[{"short":"EH 1909 #2774"}],"research_sources":[],"slug":"martha-hopkins-1839"},"H00530":{"id":"H00530","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1770,"month":5,"day":20,"city":"Northampton","state":"Massachusetts","county":"Hampshire"},"death":{"year":1836,"month":4,"day":14,"city":"Rutland","county":"Rutland","state":"Vermont"},"parents":{"father_id":"H00264","mother_id":"I00043"},"tags":["merchant","vermont_migration"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 530"}],"gender":"male","marriages":[{"marriage_number":1,"spouse_id":"I01188","date_year":1796,"end_type":"death_of_spouse","end_year":1832,"children_ids":["H01416","H01417","H01418","H01419","H01420"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Thomas Hooker","first_name":"Thomas","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM553"},"career":[{"role":"Apothecary and Grocer","location":"Rutland, Rutland County, Vermont","end_year":1836,"notes":"Per EH 1909 #530: 'an apothecary and grocer at Rutland, Vt.'"}],"narrative_blocks":[{"number":1,"category":"career","header":"Apothecary and grocer at Rutland; wife predeceased him","body":"Thomas Hooker was an apothecary and grocer at Rutland, Vermont, where he spent his adult life and died in 1836 at sixty-five. His wife Sarah Brown died four years before him in 1832, predeceasing him despite being nine years younger."},{"number":2,"category":"marriage","header":"Married daughter of Col. John Brown of Pittsfield","body":"Sarah Brown's father, Colonel John Brown of Pittsfield, Massachusetts, is almost certainly the Revolutionary War officer killed at the Battle of Stone Arabia, New York, on October 19, 1780 — when Sarah was barely a year old. If confirmed, Thomas Hooker married the daughter of a Revolutionary War martyr."},{"number":3,"category":"family","header":"Twin sons: one to Boston missions","body":"John Worthington and Henry Brown Hooker were born the same day — August 31, 1802 — and their lives diverged completely: John moved to Chicago in 1836 among the city's earliest New England settlers, while Henry graduated Middlebury College, entered the ministry, and became Secretary of Missions at Boston."},{"number":4,"category":"family","header":"Two of five children died in Chicago","body":"John Worthington Hooker moved to Chicago in 1836 and died there in 1866; his sister Julia Ann married a Rutland lawyer and also died in Chicago in 1842. Two of Thomas Hooker's five children ended their days in the city that barely existed when they were born."}],"number_of_marriages":1,"slug":"thomas-hooker-1770"},"I01188":{"id":"I01188","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Sarah Brown Hooker","first_name":"Sarah","middle_name":"Brown","last_name":"Hooker","married_names":[]},"gender":"female","birth":{"year":1779,"city":"Pittsfield","county":"Berkshire","state":"Massachusetts","country":"United States"},"death":{"year":1832,"month":1,"day":11,"city":"Rutland","county":"Rutland","state":"Vermont","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"parents":{},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00530","date_year":1796,"end_type":"death","end_year":1832,"children_ids":["H01416","H01417","H01418","H01419","H01420"]}],"career":[],"education":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Probably daughter of a Revolutionary War martyr","body":"Sarah Brown's father, Colonel John Brown of Pittsfield Massachusetts named in the Hooker genealogy, is almost certainly the Revolutionary War officer killed at the Battle of Stone Arabia, New York, on October 19, 1780 — when Sarah was barely a year old. She married Thomas Hooker in 1796 and died at Rutland, Vermont, in 1832, four years before her husband."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM553"},"residence":{"country":"United States"},"sources":[{"short":"FindAGrave #43726558 + EH 1909 #530"}],"research_sources":[],"slug":"sarah-hooker-1779"},"H00264":{"id":"H00264","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"compiler_ancestor":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1729,"month":3,"day":19,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1777,"month":2,"day":6,"city":"Northampton","county":"Hampshire","state":"Massachusetts","country":"United States","cause":"smallpox"},"parents":{"father_id":"H00098","mother_id":"I00041"},"tags":["compiler_ancestor","yale_graduate","clergy","minister","epidemic_death"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 264"}],"marriages":[{"spouse_id":"I00043","children_ids":["H00524","H00525","H00526","H00527","H00528","H00529","H00530","H00531","H00532"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1777,"date_year":1755,"date_month":12,"date_day":10,"location_country":"United States"}],"compiler_ancestor":true,"ministry_positions":[{"role":"Minister","location":"Northampton, Massachusetts","dates":"1753-1777","duration_years":24,"notes":"Ordained Dec 5, 1753; settled there 24 years until death by smallpox"}],"ordination":{"date":{"year":1753,"month":12,"day":5},"location":"Northampton, Massachusetts"},"primary_residence":{"city":"Northampton","state":"Massachusetts","notes":"Minister here 24 years 1753-1777. Yale 1751, ordained Dec 5, 1753."},"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"religion","header":"Took Jonathan Edwards' Northampton pulpit, died of smallpox","body":"Ordained in 1753, he became pastor at Northampton, Massachusetts — the church where Jonathan Edwards had preached until his dismissal in 1750. He held that pulpit for nearly 25 years, dying of smallpox on February 6, 1777, in his 48th year. His was the most prominent pastoral appointment held by any Hooker descendant of his generation."},{"number":2,"category":"family","header":"His wife's father, Colonel Worthington, named Worthington Parish","body":"He married Sarah Worthington, daughter of Colonel Worthington of Springfield, Massachusetts — the man who gave his name to Worthington Parish in Berlin, Connecticut, the parish where the Hart and Hooker families had long been prominent. The marriage connected the Hooker line to one of western Massachusetts's most distinguished families."},{"number":1,"category":"death","header":"Smallpox took the Northampton pastor at forty-seven","body":"He served as pastor of the Northampton MA Congregational Church from 1753 until smallpox killed him in February 1777 at forty-seven. His daughter Sarah Hooker married the Northampton lawyer Caleb Strong nine months later — passing the Hooker name into the family of a future Massachusetts Governor and U.S. Senator."}],"cross_connections":[{"type":"civic_connection","related_id":"H00379","display_label":"Edwards's daughter refused his pulpit and her chair sat in the vestibule.","link_text":"Mary Edwards Dwight"}],"education":[{"degrees":[{"degree":"B.A.","year":1751}],"notes":"Yale College class of 1751","degree":"B.A.","school_name":"Yale College","graduation_year":1751,"institution_id":"INST022"}],"bio":{"display_name":"Rev. John Hooker","title":"Reverend","first_name":"John","last_name":"Hooker","married_names":[]},"landmarks":[],"residence":{"city":"Northampton","state":"Massachusetts","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1751"}],"artworks":[],"quotes":[],"military_service":[],"slug":"john-hooker-1729"},"I00043":{"id":"I00043","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1732,"month":1,"day":27,"city":"Springfield","state":"Massachusetts"},"death":{"year":1817,"month":4,"day":5,"city":"Northampton","state":"Massachusetts"},"marriages":[{"spouse_id":"H00264","children_i