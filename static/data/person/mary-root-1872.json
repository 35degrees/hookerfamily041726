iage_number":2,"spouse_id":"I00501","date_year":1869,"date_month":7,"date_day":23,"location_city":"Lenox Township","location_state":"Ohio","location_country":"United States","children_ids":["HD3900"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"William Ezekiel Root","first_name":"William","last_name":"Root","middle_name":"Ezekiel","married_names":[]},"residence":{"city":"Austinburg Township","county":"Ashtabula","state":"Ohio","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM282"},"narrative_blocks":[{"number":1,"category":"family","header":"Remarried at sixty-three; only daughter at sixty-six","body":"William Ezekiel Root's first marriage to Harriet Leonard around 1827 produced five sons. After their separation or her departure (she 'still living' at his 1889 death and later married Orlin W. Spencer), William remarried on July 23, 1869 in Lenox Township Ohio to Paulina Monroe — and three years later, at age sixty-six, fathered his only documented daughter Mary E. Root. The late-life second-family arc was uncommon among Connecticut-Hooker-line men of his generation."},{"number":2,"category":"family","header":"Catskill NY birth, EH misrecorded as Farmington","body":"William Ezekiel Root was born in 1806 in Catskill New York, where his parents had settled before 1792 — though some early genealogical records mistakenly placed his birth in Farmington Connecticut. He died in Lenox Township, Ashtabula County Ohio on August 31, 1889 at age eighty-three, buried at West Lenox Cemetery. The Connecticut-to-New-York-to-Ohio migration arc spanned three states across his lifetime."},{"number":3,"category":"family","header":"Five sons, four documented only by initials","body":"William and Harriet's five sons were William Alonzo Root born 1832, and four others known in records only as E.L. (1859), E.W. (1860), S.L. (1860), and A.A. (1861). The use of initials for four of five sons may reflect contemporary practice or simply that fuller given names were never preserved. The 1859-1861 birth cluster of four boys came in close succession during William's middle-aged years."}],"slug":"william-root-1806"},"I00501":{"id":"I00501","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Paulina","middle_name":"Monroe","maiden_name":"Monroe","married_names":["Root"],"gender":"female","display_name":"Paulina Monroe Monroe Root"},"birth":{"year":1833,"month":5,"state":"New York","country":"United States"},"baptism":{},"death":{"year":1905,"month":10,"day":2,"city":"Cleveland","state":"Ohio","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM282"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_research_notes":"Paulina Monroe. m1 Edwin Sikes (one child by that marriage) — both non-Hooker, not built. After Edwin's death m2 William Ezekiel Root."},"number_of_marriages":1,"marriages":[{"marriage_number":2,"spouse_id":"HD0533","date_year":1869,"date_month":7,"date_day":23,"location_city":"Lenox Township","location_state":"Ohio","location_country":"United States","children_ids":["HD3900"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"short":"FamilySearch (familysearch.org/tree, person LWR5-ZNQ); FindAGrave #61668187"}],"research_sources":[],"documents":[],"slug":"paulina-monroe-1833"},"X00264":{"id":"X00264","ha