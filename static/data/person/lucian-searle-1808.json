ndant":false,"is_easter_egg":false},"birth":{"year":1772,"month":4,"day":21,"city":"Middletown","state":"Connecticut"},"parents":{"mother_id":"H00296","father_id":"X01067"},"tags":["episcopal","new_york_migration","ohio_migration"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 655"}],"death":{"year":1849,"month":1,"day":17,"city":"Ogdensburg","county":"St. Lawrence County","state":"New York"},"marriages":[{"children_ids":["HD0833","HD0834"],"spouse_id":"X01330","marriage_number":1,"date_year":1800,"date_month":8,"date_day":7}],"burial":{"cemetery_id":"CEM080"},"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sally Pomeroy","first_name":"Sally","maiden_name":"Pomeroy","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Husband organized first Episcopal parish in Ohio","body":"Sally's husband Rev. Roger Searle organized the first Episcopal parish in Ohio — St. Peter's at Ashtabula on February 19, 1817 — and preached the first religious service in Medina County Ohio on March 11, 1817. He went on to organize Trinity Cleveland, St. Mark's Columbia, St. James' Boardman, and St. Luke's Ravenna. Sally lived alongside this Ohio Episcopal circuit-rider mission through its founding decade."},{"number":2,"category":"family","header":"Widowed at Ohio frontier age fifty-four","body":"Sally was widowed at age fifty-four when Rev. Searle died September 6, 1826 in Ashtabula Ohio. She lived another twenty-three years and ultimately died in 1849 at Ogdensburg, Saint Lawrence County New York — having migrated from her Ohio widowhood home northeast to the Saint Lawrence River frontier. The Connecticut-to-Ohio-to-Ogdensburg migration arc spanned three frontier regions across her seventy-six years."},{"number":3,"category":"family","header":"Two children: son Lucian and daughter Nancy","body":"Sally and Rev. Searle had two documented children. Their son Lucian Theodoscius Searle (1808-1895) lived to age eighty-seven; their daughter Nancy Sarah Marie Searle Johnston (1817-1906) lived to age eighty-eight or eighty-nine. Both children outlived the parents by half a century and represent the surviving Searle line through Sally Pomeroy's marriage."},{"number":4,"category":"family","header":"Middletown CT 1772 to Ogdensburg NY 1849","body":"Sally Pomeroy was born April 21, 1772 in Middletown Connecticut, daughter of Adino Pomeroy and Lois Strong Pomeroy. She married Rev. Roger Searle on August 7, 1800 and died January 17, 1849 at Ogdensburg, Saint Lawrence County New York at age seventy-six. She is buried at Ogdensburg Cemetery."}],"slug":"sally-pomeroy-1772"},"X01067":{"id":"X01067","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00296","children_ids":["H00650","H00651","H00652","H00653","H00654","H00655","H00656","H00657","H00658","H00659"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1732,"month":9,"day":22,"city":"Northampton","county":"Hampshire County","state":"Massachusetts"},"death":{"year":1809,"month":10,"day":14,"city":"Pittsfield","county":"Berkshire County","state":"Massachusetts"},"cross_connections":[],"bio":{"display_name":"Adino Pomeroy","first_name":"Adino","last_name":"Pomeroy","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug