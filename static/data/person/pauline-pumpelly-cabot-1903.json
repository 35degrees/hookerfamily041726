his forebears","body":"Michael Pierce Metcalf served as publisher, chief executive, and chairman of the Providence Journal Company, continuing a family tradition reaching back generations. The paper was known for hard-edged investigative reporting on organized crime in Rhode Island.","number":1},{"category":"death","header":"His own paper sought a death inquiry","body":"Metcalf died in September 1987, a week after a freak bicycle accident near his Westport summer home left him with severe head injuries. His own company asked prosecutors to examine the unusual circumstances, though no foul play was ever established.","number":2},{"category":"family","header":"He left trusts for his young children","body":"Metcalf died with three children still in their early teens, leaving a web of family trusts to provide for them. Decades later those trusts became the subject of litigation among his heirs.","number":3}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Michael Pierce","last_name":"Metcalf","married_names":[],"display_name":"Michael Pierce Metcalf","gender":"male"},"military_service":[],"generation_from_john_talcott":9,"burial":{"cemetery_name":"Swan Point Cemetery","city":"Providence","state":"Rhode Island","country":"United States"},"slug":"michael-pierce-metcalf-1933"},"I01564":{"id":"I01564","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","birth":{"year":1897,"country":"United Kingdom"},"death":{"year":1972},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"include_in_path_calculation":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"spouse_id":"TD0344","spouse_name":"Pauline Pumpelly Cabot","marriage_year":1959,"children_ids":[