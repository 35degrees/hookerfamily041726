ologist Raphael Pumpelly in 1869 and shared his homes at Newport and in the New Hampshire hills.","number":1}],"sources":[],"institutions":[],"landmarks":[],"artworks":[{"artwork_id":"ART070","role":"subject"}],"research_tags":[],"cross_connections":[{"type":"artifact","related_id":"I01660","display_label":"also drawn by John Singer Sargent"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Eliza Frances","last_name":"Shepard","married_names":["Pumpelly"],"display_name":"Eliza Frances Shepard Pumpelly","gender":"female","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780758136/1280px-John_Singer_Sargent_-_Portrait_of_Mrs._Raphael_Pumpelly_-_Google_Art_Project_itkol9.jpg"},"military_service":[],"slug":"eliza-frances-shepard-1840"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[{"type":"in_law","related_id":"X03121","display_label":"was her father-in-law","slug":"stephen-olney-metcalf-1857"}]}