me":"Rev. Horace Hooker","first_name":"Horace","last_name":"Hooker","middle_name":"Rev.","title":"Reverend","married_names":[],"bio_blurb":"Hartford minister, editor, and children's author"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST079","relationship":"chaplain","years":"?-1864","institution_blurb":"Chaplain at end of life; died there December 17, 1864."},{"institution_id":"INST022","relationship":"alumnus","years":"1815","institution_blurb":"Yale College 1815; later tutor 1817-1822."}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"He continued Gallaudet's Bible series after Gallaudet died","body":"In collaboration with Rev. Thomas Hopkins Gallaudet — the pioneer of American deaf education who co-founded the American School for the Deaf in Hartford — Horace Hooker co-authored The Practical Spelling Book and The School and Family Dictionary, two educational works that circulated widely in New England schools and were reprinted under both names for decades after Gallaudet's death in 1851. When Gallaudet died, Hooker continued the Scripture Biographies for the Young series his collaborator had begun — completing it as an act of literary stewardship that kept both names in circulation in Connecticut's religious education networks through the Civil War era, and that reflected his role as one of Hartford's most productive clerical authors across four decades."},{"number":2,"category":"career","header":"Secretary of CT Missionary Society for twenty years","body":"For more than twenty years he served as secretary of the Connecticut Missionary Society. He ended his life as chaplain of the Hartford insane retreat — where he died December 17, 1864, having ministered there until the end."},{"number":3,"category":"religion","header":"Founding student of Yale's theological department","body":"As a Yale tutor in 1817 he joined the small group of students who studied theology informally under Professor Eleazar T. Fitch — the cohort that became the founding class of what grew into Yale Divinity School. The twelve students formalized the program by inviting Professor Kingsley to teach Hebrew and Professor Goodrich elocution and sermon composition, transforming twice-weekly evenings at Fitch's house into Yale's first theological department."}],"burial":{"cemetery_id":"CEM056"},"number_of_marriages":2,"slug":"horace-hooker-1793"},"I00298":{"id":"I00298","prefix":"I","classification":{"descent_from_thomas_hooker":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"include_in_path_calculation":false},"bio":{"display_name":"Harriet Watkinson Hooker","first_name":"Harriet","maiden_name":"Watkinson","last_name":"Hooker","married_names":["Hooker"],"gender":"female"},"birth":{"year":1815,"country":"United States"},"death":{"year":1884,"month":3,"day":6,"county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_name":"Edward Watkinson"},"marriages":[{"marriage_number":1,"spouse_id":"H00546","date_year":1843,"date_month":11,"date_day":22,"children_ids":["H01466","H01467"]}],"tags":[],"narrative_blocks":[],"cross_connections":[],"burial":{"cemetery_id":"CEM056"},"number_of_marriages":1,"slug":"harriet-watkinson-1815"},"H00267":{"id":"H00267","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1746,"month":4,"day":12,"city":"Kensington","state":"Connecticut"},"death":{"year":1823,"month":9,"day":27,"city":"Kensington","state":"Connecticut"},"parents":{"father_id":"H00098","mother_id":"I00041"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 267"}],"marriages":[{"spouse_id"