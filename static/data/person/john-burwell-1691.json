tate":"Connecticut","location_country":"United States"},{"spouse_id":"I00011","children_ids":["H00053","H00054"],"marriage_number":2,"end_type":"death","end_year":1703,"date_year":1687,"location_city":"Milford","location_country":"United States"}],"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 13"},{"short":"Caroline Gaylord Newton 1914"}],"burial":{"cemetery_id":"CEM005"},"gender":"female","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"is_placeholder":false,"former_ids":[],"baptism":{},"residence":{"country":"United States"},"institutions":[],"landmarks":[],"naming_inspiration":[],"research_tags":[],"narrative_blocks":[{"number":1,"category":"family","header":"Brother and husband both married Fenn sisters","body":"Her brother Samuel Newton married Martha Fenn in 1669. Her second husband Samuel Burwell had previously been married to Sarah Fenn — Martha's sister, same parents. Two Newton siblings married into the same Fenn family, though into different branches of it."},{"number":2,"category":"family","header":"Father left her his three hour-glasses","body":"Because Susannah had already received her portion at marriage, Roger Newton Sr.'s 1683 will left her only one cow and all three of his hour-glasses. She was living in Guilford with five children at the time. The genealogical note adds dryly: 'No one can tell why she should have all the hour-glasses.'"},{"number":3,"category":"family","header":"Two marriages, six children, two Connecticut towns","body":"She had four children with her first husband John Stone, then married Samuel Burwell as his second wife. She was living in Guilford with five children when her father's 1683 will was written, then moved to Milford with the Burwells. She died at Milford in July 1703, age 48."}],"quotes":[],"research_sources":[],"artworks":[],"bio":{"display_name":"Susannah Newton Burwell","first_name":"Susannah","last_name":"Burwell","married_names":["Stone","Burwell"],"maiden_name":"Newton"},"documents":[],"military_service":[],"slug":"susannah-burwell-1654"},"I00003":{"id":"I00003","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"descent_paths_to_thomas":0,"is_progenitor":false},"birth":{"year":1620,"month":1,"day":1,"country":"England","date_precision":"approximate"},"death":{"year":1683,"month":6,"day":7,"city":"Milford","state":"Connecticut","country":"United States","date_precision":"exact"},"parents":{"father_research_notes":"Said to be of the family of Sir Isaac Newton; possibly son of a Samuel Newton. Parentage unproven — see research_notes."},"marriages":[{"spouse_id":"H00003","children_ids":["H00011","H00012","H00013","H00014","H00015","H00016","H00017","H00018"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1676,"date_year":1644,"location_country":"United States"}],"tags":["minister","farmington_founder","seven_pillars","yale_connection","missionary","great_migration","indigenous_rights","yale_founder"],"sources":[{"short":"Edward Hooker 1909","page":"Entry g-45"},{"short":"Flagg 1926","page":"pp. 255-256"},{"short":"Caroline Gaylord Newton 1914","full":"Caroline Gaylord Newton, Rev. Roger Newton, Deceased 1683, and One Line of his Descendants (Durham, Conn., 1914), pp. 3-10"},{"short":"Leonard 1915","full":"Ermina Newton Leonard, Newton Genealogy (Salem, Mass: Higginson Book Company, 1915), p. 700"},{"short":"Hulburt 1967","full":"Mabel S. Hulburt, Farmington Church and Town (Stonington, Conn: The Pequot Press, 1967), p. 8"},{"short":"Cutter 1913","full":"William Richard Cutter, New England Families, Genealogical and Memorial (New York: Lewis Historical Publishing, 1913), vol. 3, p. 1730"},{"short":"N.E. Reg.","volume":"11","page":"323"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["religion","education"],"notable_blurb":"Founding Farmington pastor; trained Yale's first rector","primary_url":"https://www.nativenortheastportal.com/bio/bibliography/newton-roger-1683","primary_url_label":"Native Northeast Portal biography"},"narrative_blocks":[{"number":1,"category":"religion","header":"Hooker trained him; he founded Farmington's church","body":"Roger Newton studied theology at Hartford under Thomas Hooker and, around 1645, married Hooker's eldest daughter, Mary. Ordained the first pastor of Farmington in 1652, he later served twenty-three years as the second pastor of Milford."},{"number":2,"category":"legacy","header":"He trained Yale's first rector at his table","body":"As Hooker had trained him, Newton took young men into his Milford home for theological study. One was Abraham Pierson Jr., who became the first rector of Yale College."},{"number":3,"category":"religion","header":"He sheltered the fugitive regicides near Milford","body":"From 1661 the regicide judges Edward Whalley and William Goffe — hunted for signing the death warrant of Charles I — hid in a cellar near Newton in Milford. Their presence was kept secret through the two years they remained."},{"number":4,"category":"social_reform","header":"He brought Tunxis members into the church","body":"Newton did missionary work among the Tunxis and witnessed the 1650 agreement between Connecticut and the tribe. A few Tunxis became members of his Farmington church, with the standing that membership carried."},{"number":5,"category":"character","header":"He left Farmington in a year of calamity","body":"Newton departed Farmington in 1657 after a season of disaster — a man named Scott was murdered, and the house of John Hart burned with most of the family inside. He waited months in Boston for passage to England before settling instead at Milford."}],"cross_connections":[{"type":"civic_connection","related_id":"X00094","display_label":"was received into Milford Church by Newton, 1661","link_text":"Miles Merwin"},{"type":"civic_peer","related_id":"X00067","display_label":"also sheltered the regicides, at Guilford","link_text":"Gov. William Leete"},{"type":"civic_connection","related_id":"X02127","display_label":"trained by Newton; became Yale's first rector","link_text":"Rev. Abraham Pierson Jr."},{"type":"civic_peer","related_id":"H00007","display_label":"succeeded Newton as Farmington's pastor","link_text":"Rev. Samuel Hooker"}],"quotes":[],"is_placeholder":false,"baptism":{},"residence":{"city":"Milford","county":"New Haven","state":"Connecticut","country":"United States"},"landmarks":[],"naming_inspiration":[],"research_tags":[],"research_sources":[],"education":[{"dates":"Easter 1636","type":"matriculation","school_name":"King's College, Cambridge"},{"institution_id":"INST002","notes":"Studied at Harvard but name not on graduate list. Some early Harvard records in which his name would naturally appear were accidentally burned; uncertain he received a diploma. Cotton Mather nevertheless speaks of him as one of the young students who came from England to finish their education in America."}],"bio":{"title":"Reverend","display_name":"Rev. Roger Newton Sr.","first_name":"Roger","last_name":"Newton","married_names":[],"suffix":"Sr.","bio_blurb":"First pastor of Farmington; second of Milford","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781475281/rogernewtonsr_mspjci.png"},"documents":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"}],"artworks":[],"military_service":[],"career":[{"role":"Pastor (founding)","organization":"First Church of Farmington","location":"Farmington, Connecticut","start_year":1652,"end_year":1657,"notes":"Ordained the church's first pastor, October 13, 1652."},{"role":"Pastor","organization":"First Church of Milford","location":"Milford, Connecticut","start_year":1660,"end_year":1683,"notes":"Second pastor; installed August 22, 1660."}],"burial":{"cemetery_id":"CEM005","plot_notes":"Buried in Founders' Cemetery (Rev. Peter Prudden's Garden) on the Wepawaug; 1889 memorial at Founders Memorial Bridge, Milford."},"slug":"roger-newton-sr-1620"},"H00003":{"id":"H00003","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":2,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"descent_paths_to_thomas":1,"is_progenitor":false},"birth":{"year":1623,"month":1,"day":1,"country":"England"},"death":{"year":1676,"month":2,"day":4,"city":"Milford","county":"New Haven County","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM005","plot_notes":"Buried in Peter Prudden's Garden — no tombstone remains"},"parents":{"father_id":"H00001","mother_id":"I00001"},"marriages":[{"spouse_id":"I00003","children_ids":["H00011","H00012","H00013","H00014","H00015","H00016","H00017","H00018"],"marriage_number":1,"end_type":"death","end_year":1676,"date_year":1644,"location_country":"United States"}],"tags":["great_migration"],"sources":[{"short":"Edward Hooker 1909","page":"Entry g-46"},{"short":"Flagg 1926","page":"pp. 256-257"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"is_placeholder":false,"baptism":{},"residence":{"city":"Milford","county":"New Haven","state":"Connecticut","country":"United States"},"institutions":[],"landmarks":[],"naming_inspiration":[],"research_tags":[],"cross_connections":[{"type":"cousin_marriage","related_id":"H00024","display_label":"Her daughter Sarah Newton married her first cousin John Wilson.","link_text":"John Wilson"}],"quotes":[],"research_sources":[],"narrative_blocks":[{"number":1,"category":"family","header":"Cared for her mother on the Hartford migration","body":"According to the Newton family genealogy, Mary was the daughter responsible for caring for her mother Susanna on the arduous journey from Cambridge to Hartford in 1636 — a journey in which Mrs. Hooker 'was carried on a horse litter' in poor health. Mary was roughly 13 years old."},{"number":2,"category":"family","header":"Stayed in Hartford while Newton built Farmington","body":"When Roger Newton went to establish the church at Farmington in the late 1640s, Mary remained in Hartford — their son Samuel's baptism on October 20, 1646 appears on the Hartford register, placing her there while her husband laid the groundwork for the congregation he would formally organize."},{"number":3,"category":"family","header":"Eight children born across three Connecticut towns","body":"The family's migrations are recorded in their children's birthplaces: Samuel and Roger Jr. born in Hartford; Susannah and John in Farmington; Ezekiel back in Hartford; then Sarah, Mary, and Alice in Milford — where the family finally settled and where Mary died on February 4, 1676."},{"number":4,"category":"family","header":"Probably born in Esher near Hooker's curacy","body":"Newton family genealogy says she was born around 1623, probably at Esher, Surrey — where Thomas Hooker had served as curate from c. 1618 to 1625. Esher was also where Hooker met her mother Susanna Garbrand."}],"bio":{"display_name":"Mary Hooker Newton","first_name":"Mary","last_name":"Newton","married_names":["Newton"],"maiden_name":"Hooker"},"documents":[],"artworks":[],"military_service":[],"slug":"mary-newton-1623"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[{"type":"family_connection","related_id":"H00042","link_text":"Thomas Newton","display_label":"My cousin who married my wife Susanna's half-sister Mary","slug":"thomas-newton-1682"},{"type":"family_connection","related_id":"X00019","link_text":"Sergeant Zachariah Baldwin","display_label":"His daughters married two Hooker first-cousin brothers","slug":"zachariah-baldwin-1660"}]}