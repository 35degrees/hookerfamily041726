ame":"Page","married_names":[],"nickname":"Tom","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777600729/tom-page_xbr5kc.webp","photo_notes":"Portrait. Cloudinary."},"birth":{"country":"United States"},"baptism":{},"death":{"country":"United States"},"residence":{"city":"Hailey","county":"Blaine","state":"Idaho","country":"United States"},"burial":{},"gender":"male","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":true,"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":12,"generation_from_john_talcott":11,"is_easter_egg":false,"descent_paths_to_thomas":1},"parents":{"father_id":"X02366","mother_id":"TD0107"},"marriages":[{"marriage_number":1,"spouse_id":"I00337","location_country":"United States","children_ids":["TD0116","TD0117"]}],"number_of_marriages":1,"tags":["hooker_talcott_descent","living_or_recent","environmentalist"],"research_tags":[],"sources":[{"label":"Idaho Wildlife Federation — Board Page","url":"https://idahowildlife.org/meet-the-board"},{"label":"American Landowner — Mike and Tom Page profile (Big Creek Ranch)"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"career","header":"Reconnected the Pahsimeroi River after 125 years","body":"After their father's 2004 death Tom and brother Michael acquired several connected ranches in Idaho's Upper Salmon River Basin and named them Big Creek Ranch — 5,500 deeded acres plus 120,000 acres of BLM grazing permits in core sage-grouse habitat with three endangered fish species. Working with a coalition of agencies and conservation organizations, the Page brothers helped reconnect the Pahsimeroi River for the first time in 125 years, drawing on Bonneville Power Administration mitigation funding under the Endangered Species Act."},{"number":2,"category":"character","header":"Continues father's Madison Valley conservation legacy","body":"Tom's first restoration project was the Madison Valley Montana ranch his father Harry Page bought in the late 1990s and rebuilt with him — the habitat-restoration legacy continued through Harry's Page Foundation and into Big Creek Ranch. 'I look at the public lands as a huge asset, assuming you take the time to understand how they work and get to know the people involved,' Tom says."},{"number":3,"category":"legacy","header":"Carries conservation legacy from both parental lines","body":"Tom inherits wildlife-conservation philanthropy from both parental sides of his family — his maternal great-grandfather Walter Ewing Hope donated 1,800 Suffolk County acres as a wildlife refuge in 1949, and his father Harry Page restored a degraded Madison Valley Montana ranch in the 1990s through the Page Foundation. Tom's Big Creek Ranch work in the Upper Salmon River Basin operates the same family impulse at landscape scale."}],"cross_connections":[{"type":"parallel_careers","related_id":"X02362","display_label":"Great-grandfather donated 1,800 acres for a wildlife refuge","link_text":"Walter Ewing Hope"}],"naming_inspiration":[],"education":[],"career":[{"role":"Co-owner","organization":"Big Creek Ranch (Pahsimeroi Valley)","location":"Pahsimeroi Valley, Idaho","notes":"Conservation-oriented cattle and hay operation acquired with brother Michael following their father Harry's 2004 death. ~5,500 deeded acres, 13,000 acres state leases, 7 BLM grazing permits totaling 120,000 acres in the Upper Salmon River Basin."},{"role":"Board President","organization":"Idaho Wildlife Federation","location":"Idaho","notes":"Joined the IWF board to maintain public ownership of Idaho's mountains and rivers. Currently serves as Board President."},{"role":"Member","organization":"Central Idaho Rangelands Network (CIRN)","location":"Idaho","notes":"Collaborative organization of ranchers and conservationists."},{"role":"Former member, Land Water and Wildlife Levy Advisory Board","organization":"Blaine County, Idaho","location":"Blaine County, Idaho"}],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[{"quote":"I look at the public lands as a huge asset, assuming you take the time to understand how they work and get to know the people involved.","context":"Big Creek Ranch profile, on the Pahsimeroi reconnection project."},{"quote":"We intentionally looked for properties that were underutilized, hadn't been well managed, had permits that had been litigated, and those sorts of challenges. I looked at it as an opportunity to use the skills I had developed working with non-profits.","context":"Big Creek Ranch profile."}],"statues":[],"slug":"thomas-page"},"TD0116":{"id":"TD0116","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"display_name":"Henry Page","first_name":"Henry","last_name":"Page","married_names":[]},"birth":{"year":2008,"country":"United States","note":"Year approximated from compiler 'age 17 in April 2026'."},"baptism":{},"death":{"country":"United States"},"residence":{"city":"Hailey","county":"Blaine","state":"Idaho","country":"United States"},"burial":{},"gender":"male","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":true,"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":13,"generation_from_john_talcott":12,"is_easter_egg":false,"descent_paths_to_thomas":1},"parents":{"father_id":"TD0114","mother_id":"I00337"},"marriages":[],"tags":["hooker_talcott_descent","living_or_recent"],"research_tags":[],"sources":[],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"naming_inspiration":[],"education":[{"school_name":"Wood River High School","type":"secondary","notes":"Hailey, ID. Plays on the boys soccer team."