"Colonel","first_name":"Thomas","last_name":"Fitch","suffix":"V","married_names":[],"gender":"male","display_name":"Col. Thomas Fitch V"},"birth":{"year":1725,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1795,"month":1,"day":16,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave. Stone: 'Son of Governor Fitch Colonel in the Revolutionary War. Called by the British YANKEE DOODLE'"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":true},"notable":{"is_notable":true,"notable_category":["military","politics"],"notable_blurb":"Yankee Doodle's legendary inspiration; 14-term legislator","primary_url":"https://en.wikipedia.org/wiki/Thomas_Fitch_V","primary_url_label":"Wikipedia — Thomas Fitch V"},"parents":{"father_id":"X02826"},"number_of_marriages":1,"marriages":[{"children_ids":["I00707"],"marriage_number":1}],"education":[],"career":[{"role":"Member","organization":"Connecticut House of Representatives","start_year":1761,"end_year":1776,"notes":"Represented Norwalk 14 terms: Oct 1761, May+Oct 1763-66, May 1767, Oct 1768, May+Oct 1769, Oct 1770-73, Oct 1775, May 1776."}],"military_service":[{"war":"French and Indian War","war_id":"WAR003","rank":"Senior Colonel","rank_start":"Captain","rank_end":"Senior Colonel","rank_year_start":1755,"rank_year_end":1762,"unit":"Four New England Regiments","notes":"Command of 16 regiments by war's end. Campaigns at Ticonderoga and Crown Point 1759."}],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["revolutionary_war","french_indian_war","army","politician"],"research_tags":[],"cross_connections":[{"type":"in_law","related_id":"H01236","display_label":"married his daughter Sarah"}],"narrative_blocks":[{"number":1,"category":"military","header":"Song mocking his troops became America's Revolutionary march","body":"In 1755, British surgeon Dr. Richard Shuckburgh wrote mocking verses about Captain Fitch's Connecticut recruits — wearing chicken feathers in their hats for lack of uniforms — dubbing them 'Yankee Doodle.' Colonial soldiers turned the insult into a rallying cry, playing it triumphantly at British troops after Burgoyne's surrender at Saratoga in 1777."},{"number":2,"category":"military","header":"Senior Colonel of sixteen regiments at Ticonderoga, 1759","body":"By the end of his service in the French and Indian War, Fitch held the rank of Senior Colonel in command of sixteen regiments — the highest-ranking Norwalk officer in the conflict. His Connecticut troops suffered disproportionate casualties in the attacks on Ticonderoga and Crown Point in 1759, with the campaign ultimately ending in British victory."},{"number":3,"category":"legacy","header":"Helped rebuild Norwalk after British burned it, 1779","body":"After British forces burned Norwalk in July 1779, Fitch — who had already represented the town fourteen terms in the Connecticut House of Representatives — helped lead the reconstruction effort. He had served in the first Norwalk delegation to the General Assembly after the Revolution began, and continued as a civic pillar until his death in 1795."}],"quotes":[],"sources":[{"label":"Wikipedia — Thomas Fitch V","url":"https://en.wikipedia.org/wiki/Thomas_Fitch_V"}],"research_sources":[],"documents":[],"slug":"thomas-fitch-v-1725"},"X02826":{"id":"X02826","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"title":"Governor","first_name":"Thomas","last_name":"Fitch","suffix":"IV","married_names":[],"gender":"male","display_name":"Governor Thomas Fitch IV","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778792829/thomasfitchiv_tk0oih.png","photo_notes":"Portrait of Governor Thomas Fitch IV of Connecticut"},"birth":{"year":1699,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1774,"month":7,"day":18,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave #5014 (Thomas Fitch IV). Gravestone: 'THE HONORABLE THOMAS FITCH ESQ., GOV. OF THE COLONY OF CONNECTICUT... fell asleep July 18 in Domini 1774, in the 75th year of his age.'"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":true},"notable":{"is_notable":true,"notable_category":["politics","law","education"],"notable_blurb":"Governor of Connecticut Colony, 1754-1766","primary_url":"https://en.wikipedia.org/wiki/Thomas_Fitch_(governor)","primary_url_label":"Wikipedia — Thomas Fitch (governor)"},"parents":{"father_name":"Thomas Fitch III (1675-1731)","mother_name":"Sarah Boardman Fitch"},"number_of_marriages":1,"marriages":[{"children_ids":["X02827"],"marriage_number":1}],"education":[{"institution_id":"INST022","dates":"1717-1721","type":"undergraduate","notes":"A.B. Yale 1721; obtained master's degree thereafter. Timothy Dwight called him 'probably the most learned lawyer who had ever been an inhabitant of the Colony.'"}],"career":[{"role":"Justice of the Peace","organization":"Norwalk","start_year":1727,"end_year":1737},{"role":"Deputy","organization":"Connecticut General Assembly","start_year":1726,"end_year":1731},{"role":"Assistant","organization":"Connecticut General Assembly","start_year":1734,"end_year":1750},{"role":"Chief Justice","organization":"Connecticut Superior Court","start_year":1750,"end_year":1754},{"role":"Deputy Governor","organization":"Colony of Connecticut","start_year":1750,"end_year":1754},{"role":"Governor","organization":"Colony of Connecticut","start_year":1754,"end_year":1766,"notes":"Longest-serving Connecticut colonial governor. Lost re-election after signing the Stamp Act in 1765."},{"role":"Deputy","organization":"Connecticut General Assembly","start_year":1766,"end_year":1773,"notes":"Returned after losing governorship."}],"military_service":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1721","institution_blurb":"Yale A.B. 1721. Praised by Yale's president Timothy Dwight as Connecticut's most learned lawyer."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["yale_graduate","governor","lawyer","politician","judge","revolutionary_war"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"politics","header":"Signed Stamp Act; lost re-election the following year","body":"In November 1765, facing a five-thousand-pound fine and removal from office, Fitch waited until two days before the deadline and signed the Stamp Act on behalf of Connecticut. The act was repealed five months later, but Fitch lost the 1766 election — a casualty of taking the legally correct but politically ruinous position."},{"number":2,"category":"law","header":"Assigned alone to rewrite all Connecticut law, 1744","body":"In 1744, after a committee had stalled, Fitch was given sole responsibility for revising all of Connecticut's statutes — a task he completed largely on his own, producing a 256-page code the General Assembly accepted in 1749. The initial printing of 150 copies fell so far short of demand that it was four years before the full thousand were printed."},{"number":3,"category":"legacy","header":"Yale's president called him colony's most learned lawyer","body":"Timothy Dwight, president of Yale, called Fitch 'probably the most learned lawyer who had ever been an inhabitant of the Colony' — praise earned through his representation of Connecticut in the decades-long Mohegan land case and numerous boundary disputes. He graduated Yale in 1721 and later obtained a master's degree."}],"quotes":[],"sources":[{"label":"Wikipedia — Thomas Fitch (governor)","url":"https://en.wikipedia.org/wiki/Thomas_Fitch_(governor)"}],"research_sources":[],"documents":[],"slug":"thomas-fitch-iv-1699"}},"burialCemetery":{"id":"CEM002","name":"East Norwalk Historical Cemetery","city":"Norwalk","state":"Connecticut","gps":{"latitude":41.10257,"longitude":-73.40353},"founded":1655,"visitable":true,"access_notes":"Sometimes locked; managed by local taxing district","features":["First Settlers of Norwalk Memorial (lists 31 individuals from 1649)","Grave of Thomas 'Yankee Doodle' Fitch IV (1724-1795)"],"notes":"Oldest cemetery in Norwalk; triangle-shaped; near East Norwalk railway station. Mary Willet Hooker Buckingham buried here, near center of burying ground near East Norwalk railway station.","hooker_connections":["H00253","I00006","X00076","X01015","H00478","X00218","H01232","H00479","X00216","X02826","X02827","H01236","I00707","HD4354","I00708","HD4355","H01238","HD2791","I00723","HD2792","H00481","H01241","H01245","H01246","H00037","H01244","I00736","HD4397","I00742","HD4453"]},"institutionsById":{},"crossConnections":[]}