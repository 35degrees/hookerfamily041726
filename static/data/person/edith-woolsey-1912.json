pedia.org/wiki/Theodore_Salisbury_Woolsey_Jr.","primary_url_label":"Wikipedia"},"parents":{"father_id":"HD04888","mother_name":"Annie Gardner Salisbury Woolsey (1847-1892)"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01111","date_year":1908,"date_month":3,"date_day":15,"location_country":"United States","end_type":"death_of_self","end_year":1933,"children_ids":["HD04893","HD04894","HD04895","HD04896","HD04897"]}],"education":[],"career":[{"role":"Forester","organization":"U.S. Forest Service","location":"Western United States","end_year":1917},{"role":"Major","organization":"U.S. Army 10th Engineers (Forestry) — later 20th Engineers","location":"France","start_year":1917,"end_year":1919,"notes":"WWI commission as Major. The 10th Engineers were organized to produce timber in France for the American Expeditionary Forces; his duties included purchasing standing timber for manufacture into AEF use."},{"role":"Consulting forester + lecturer","organization":"Yale School of Forestry","location":"New Haven, CT","start_year":1919,"end_year":1933,"notes":"Post-WWI returned to CT as consulting forester and Yale forestry school lecturer; worked with national forestry organizations and conservation groups."}],"military_service":[{"war_id":"WAR_WWI","branch":"U.S. Army","rank":"Major","unit":"10th Engineers (Forestry) / later 20th Engineers","service_dates":"1917-1919","theater":"France","notes":"Forestry timber procurement for AEF in France"}],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["wwi","army","author","academic","suicide"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"WWI Major procuring timber in France for AEF","body":"In 1917 he was commissioned Major in the 10th Engineers (Forestry) — a unit organized to produce timber in France for the American Expeditionary Forces. His duties included purchasing standing timber for manufacture into AEF use; he served until 1919 then returned to Connecticut as a consulting forester and Yale forestry school lecturer."},{"number":2,"category":"literature","header":"Author of American Forest Regulation textbook","body":"A Yale forestry lecturer and consulting forester, he wrote 'American Forest Regulation' along with other books and articles on forestry and forest regulation. His work bridged the practical forestry of the U.S. Forest Service and the academic forestry program Yale pioneered."},{"number":3,"category":"death","header":"Mount Woolsey named for him after death","body":"He died by self-inflicted gunshot on 10 July 1933 at fifty-three. Days later, his daughter Betty Woolsey was on a climbing party in Wyoming's Bighorn Mountains; on hearing of his death she left for New Haven, and the remaining four climbers named the unclimbed peak they then summited Mount Woolsey in his memory. The name was formally approved in 1961."}],"quotes":[],"sources":[{"label":"Wikipedia — Theodore Salisbury Woolsey Jr.","url":"https://en.wikipedia.org/wiki/Theodore_Salisbury_Woolsey_Jr."}],"research_sources":[],"documents":[],"slug":"theodore-woolsey-jr-1879"},"I01111":{"id":"I01111","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Ruby","middle_name":"Hilsman","last_name":"Woolsey","maiden_name":"Pickett","married_names":["Woolsey"],"gender":"female","display_name":"Ruby Hilsman Pickett Woolsey"},"birth":{"year":1884,"city":"Dawson","county":"Terrell","state":"Georgia","country":"United States"},"baptism":{},"death":{"year":1973,"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage