ilies of Early Milford","platform":"Ancestry.com"}],"death":{"year":1769,"month":2,"day":24,"city":"Durham","state":"Connecticut"},"marriages":[{"spouse_id":"I00026","children_ids":["H00147","H00148","H00149","H00150","H00151","X00027"],"marriage_number":1,"date_year":1724}],"marriage_date":{"year":1724,"notes":"Married early 1724; deed dated June 18, 1724 gives \"Abner Newton of Milford and Mary his wife\""},"primary_residence":{"city":"Durham","state":"Connecticut","notes":"Removed from Milford to Durham, settling there in late 1724. Deed of July 1724 calls him \"Abner Newton of Milford\"; deed of December 1724 calls him \"Abner Newton, late of Milford, now of Durham.\""},"tags":["durham_newton"],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Abner Newton","first_name":"Abner","last_name":"Newton","married_names":[]},"landmarks":[],"residence":{"city":"Durham","state":"Connecticut","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Half-brother shared same first name, Abner","body":"This Abner Newton was born 1699 to Samuel Newton's second wife Sarah Welch Fowler — distinguishing him from his half-brother Abner Newton baptized May 1689, who had been born to Samuel's first wife Martha Fenn ten years earlier. The repeated Abner name across both marriages was uncommon. The 1699 Abner became the documented ancestor of the Durham Newton branch — earning the 'durham_newton' tag in this entry."},{"number":2,"category":"family","header":"1724 Milford-to-Durham move; wife sold inherited share","body":"In 1724 Abner Newton and Mary Burwell removed from Milford to Durham Connecticut — and on the move Mary sold her own inherited property, a quarter share of a dwelling house and home-lot in Milford, to Susannah Burwell (widow of John Burwell) for eighty pounds. Per the deed boundaries this was the homestead of the first John Burwell, occupied since 1639. Mary had kept a share in her family's original Milford homestead until the day she left for Durham."},{"number":3,"category":"character","header":"Son Roger received Alice Newton's Yale bequest","body":"Abner's son Roger Newton was the beneficiary of Alice Newton's ca.1740 conditional Yale bequest — establishing the family's Yale-funded ministerial track. Roger graduated Yale 1758 and served fifty-six years as minister at Greenfield Massachusetts until 1816 — one of the longest continuous American pastorates of the Revolutionary-Republican era."}],"burial":{"cemetery_id":"CEM569"},"slug":"abner-newton-1699"},"I00026":{"id":"I00026","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1698,"month":8,"day":28},"death":{"year":1759,"month":4,"day":9},"parents":{"father_id":"X00027","mother_id":"X00028"},"marriages":[{"spouse_id":"HD0007","children_ids":["H00147","H00148","H00149","H00150","H00151","X00027"],"marriage_number":1,"date_year":1724}],"sources":[{"short":"Families of Early Milford, Connecticut","platform":"Ancestry.com"}],"gender":"male","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Burwell","first_name":"Mary","last_name":"Burwell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-burwell-1698"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}