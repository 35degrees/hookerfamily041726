n American immigrant colony in San Juan Province. It ended as an Argentine settlement instead — but from that project grew the city of Caucete and the irrigation of the left bank of the San Juan River."}],"cross_connections":[{"type":"family_orbit","related_id":"X02061","display_label":"He smuggled Sarmiento's Facundo into San Juan hidden in medicine drawers —.","link_text":"Domingo Faustino Sarmiento"}],"bio":{"display_name":"Amán Rawson","first_name":"Haman","last_name":"Rawson","married_names":[],"nickname":"Haman","photo_url":"https://upload.wikimedia.org/wikipedia/commons/1/1e/Aman_rawson.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"haman-rawson-1792"},"HD0280":{"id":"HD0280","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1833,"month":8,"day":25,"city":"San Juan","country":"Argentina"},"death":{"year":1902,"month":8,"day":13,"city":"Buenos Aires","country":"Argentina"},"parents":{"father_id":"HD0277","mother_id":"X02060"},"tags":["argentina_migration"],"sources":[{"short":"FindAGrave"}],"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"He was illegitimate","body":"Juan de Dios Rawson Martínez was born in 1833, eleven years after the death of his father's wife Justina. He took the hyphenated surname Rawson Martínez — his mother's name first. His grandson was General Arturo Rawson, who served as provisional president of Argentina in 1943 following a military coup.","number":1}],"cross_connections":[],"bio":{"display_name":"Juan de Dios Rawson Martínez","first_name":"Juan","last_name":"Rawson","middle_name":"de Dios",