"Boudinot Seeley","mother_id":"HD3714","mother_name":"Charlotte Cowles Austin Seeley"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00405","location_country":"United States","end_type":"death","end_year":1920,"children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Wife of UVA's Miller Chair of Biology","body":"Kate married Albert Henry Tuttle, a Cleveland-born biologist who held the Miller Chair of Biology at the University of Virginia from 1888 to 1913. The couple lived on the UVA Lawn in Charlottesville for twenty-five years before retiring to California, where Kate died in Berkeley in 1920. Three children including Anna Seeley Tuttle, born 1877."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"kate-austin-tuttle-1849"},"I00405":{"id":"I00405","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Albert Henry","last_name":"Tuttle","married_names":[],"gender":"male","display_name":"Albert Henry Tuttle"},"birth":{"year":1844,"state":"Ohio","country":"United States"},"baptism":{},"death":{"year":1927,"state":"California","country":"United States"},"residence":{},"burial":{"plot_notes":"Buried at the University of Virginia, Charlottesville VA"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["science","education"],"notable_blurb":"UVA Miller Chair of Biology 1888-1913","primary_url":"https://community.village.virginia.edu/unionist/node/620","primary_url_label":"UVA Unionists: Albert Henry Tuttle"},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3742","location_country":"United States","end_type":"death_of_wife","end_year":1920,"children_ids":[]}],"education":[{"institution":"Pennsylvania State College","degree":"B.S.","notes":"Penn State undergraduate degree."},{"institution":"Harvard University","notes":"Taught microscopy at Harvard."}],"career":[{"title":"Union officer, Civil War","organization":"Union Army","dates":"1862-1865","type":"military","notes":"Confined as Confederate POW at Johnson's Island Military Prison, Sandusky OH."},{"title":"Microscopy instructor","organization":"Harvard University","type":"academic","notes":"Taught microscopy at Harvard before professorship.","institution_id":"INST002"},{"title":"Professor of Zoology and Comparative Anatomy","organization":"Ohio State University","dates":"1874-1888","type":"academic","notes":"Held the chair at OSU for fourteen years."},{"title":"Miller Chair of Biology","organization":"University of Virginia","dates":"1888-1913","type":"academic","notes":"Chairman of the biology department for twenty-five years. Author of numerous books and articles in bacteriology and histology including 'The Principles of Histology, Descriptive and Practical.' Turned down an offer to become president of Ohio State to remain at UVA. Tuttle-Dunnington dormitory at UVA named in his honor."}],"military_service":[],"institutions":[{"institution_id":"INST002"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["scientist","educator","civil_war","academic","author"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"science","header":"UVA Miller Chair of Biology for 25 years","body":"Held the Miller Chair of Biology at the University of Virginia from 1888 to 1913, chairing the biology department. Authored books and articles on bacteriology and histology, including The Principles of Histology, Descriptive and Practical. Turned down an offer to become president of Ohio State University to stay at UVA — the Tuttle-Dunnington dormitory at UVA is named in his honor."},{"number":2,"category":"military","header":"Union officer held as POW at Johnson's Island","body":"Served as a Union officer in the Civil War and was held as a Confederate prisoner of war at Johnson's Island Military Prison in Sandusky Ohio. After the war he embodied the reconciliationist trend in American Civil War memory — a UVA colleague observed that 'one does not feel that Tuttle is a Yankee or Westerner but a genuine old Virginian.'"},{"number":3,"category":"education","header":"Taught at Harvard, Ohio State, and Virginia","body":"After his Penn State B.S., Tuttle taught microscopy at Harvard before becoming professor of zoology and comparative anatomy at Ohio State University from 1874 to 1888. He moved to UVA in 1888 and remained there for the rest of his teaching career, retiring in 1913 to California."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"albert-henry-tuttle-1844"},"I00411":{"id":"I00411","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Boudinot","last_name":"Seeley","married_names":[],"gender":"male","display_name":"Boudinot Seeley"},"birth":{},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3714","date_year":1848,"date_month":8,"date_day":22,"location_city":"Austinburg","location_county":"Ashtabula County","location_state":"Ohio","location_country":"United States","children_ids":["HD3742","HD3743","HD374