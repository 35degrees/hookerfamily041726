mas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"spouse_id":"TD0335","spouse_name":"Margarita \"Daisy\" Pumpelly Smyth","children_ids":["TD0338","TD0339","TD0340","TD0341"],"marriage_year":1894,"marriage_place":"England"}],"tags":[],"narrative_blocks":[{"category":"career","header":"A Harvard professor of mining and geology","body":"Born in Ontario and raised in Pennsylvania, Henry Lloyd Smyth graduated from Harvard in 1883 and became a professor of mining and geology there. He married Daisy Pumpelly in England in 1894.","number":1},{"category":"character","header":"Husband and wife kept separate houses","body":"Though married for half a century, Smyth and Daisy lived largely apart, he in Cambridge and Plainfield, she in New York. Census takers sometimes recorded him as a widower while his wife was living elsewhere.","number":2}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Henry Lloyd","last_name":"Smyth","married_names":[],"display_name":"Henry Lloyd Smyth","gender":"male"},"military_service":[],"slug":"henry-lloyd-smyth-1862"},"TD0335":{"id":"TD0335","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"female","birth":{"year":1873,"month":8,"day":6,"city":"Newburgh","state":"New York","country":"United States"},"death":{"year":1959,"month":2,"day":22,"city":"Boston","state":"Massachusetts","country":"United States"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":false,"generation_from_john_talcott":7},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"TD0334","father_name":"Raphael Pumpelly","mother_id":"I01540","mother_name":"Eliza Frances Shepard Pumpelly"},"number_of_marriages":1,"marriages":[{"spouse_id":"I01541","spouse_name":"Henry Lloyd Smyth","children_ids":["TD0338","TD0339","TD0340","TD0341"],"marriage_year":1894,"marriage_place":"England"}],"tags":[],"narrative_blocks":[{"category":"arts","header":"An exhibited portrait painter and Bahá'í","body":"Margarita 'Daisy' Pumpelly Smyth painted portraits shown in New York exhibitions, among them a likeness of the architect Rose Standish Nichols. She joined the Bahá'í Faith after hearing 'Abdu'l-Bahá speak at her parents' New Hampshire home in 1912.","number":1},{"category":"character","header":"Her Greenwich Village home drew many faiths","body":"In the 1940s Daisy shared a house at 48 West 10th Street with the Bahá'í artist Juliet Thompson, making it a gathering place for people of many races and religions. Visitors came for fireside meetings that ran almost continually.","number":2},{"category":"family","header":"Wife and husband lived largely apart","body":"Daisy married the Harvard geology professor Henry Lloyd Smyth in England in 1894. Though never divorced, the two kept separate households for much of their long marriage.","number":3}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Margarita","last_name":"Smyth","married_names":[],"display_name":"Margarita \"Daisy\" Pumpelly Smyth","gender":"female"},"military_service":[],"slug":"margarita-smyth-1873"},"TD0334":{"id":"TD0334","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"gender":"male","birth":{"year":1837,"month":9,"day":8,"city":"Owego","state":"New York","country":"United States"},"baptism":{},"death":{"year":1923,"month":8,"day":10,"city":"Newport","state":"Rhode Island","country":"United States"},"burial":{},"residence":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":6,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["science","exploration"],"notable_blurb":"Geologist and explorer of Asia's interior","primary_url":"https://en.wikipedia.org/wiki/Raphael_Pumpelly","primary_url_label":"Wikipedia"},"parents":{"father_id":"I01523","father_name":"William Pumpelly","mother_id":"T01812","mother_name":"Mary H. Welles"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_name":"Eliza F. Shepard","date_year":1869,"spouse_id":"I01540","children_ids":["TD0335","TD0336","TD0337"]}],"tags":[],"narrative_blocks":[{"number":1,"category":"science","header":"He mapped Asia's deserts for American science","body":"Trained as a mining engineer, Raphael Pumpelly surveyed mineral country across Japan, China, and Mongolia in the 1860s and crossed the Gobi Desert. His later expeditions into Russian Central Asia searched for the origins of agriculture and early civilization."},{"number":2,"category":"science","header":"He tied windblown dust to climate history","body":"Pumpelly's studies of loess, the fine wind-laid soil of northern China, helped show how such deposits record ancient climate. At home he directed the northern transcontinental railroad survey and led major government geological surveys."},{"category":"career","header":"He held Harvard's first chair in mining","body":"From 1866 to 1875 Pumpelly served as Harvard's first professor of mining, between expeditions that carried him around the world. He later organized the economic-geology division of the new U.S. Geological Survey and directed its New England branch.","number":3},{"category":"science","header":"His Anau dig pushed Central Asian history back","body":"In 1903 Pumpelly led a Carnegie-funded expedition to the Anau mounds in Turkmenistan, uncovering a settlement he dated to about 4500 BCE. The mineral pumpellyite, found in Michigan's copper country, was later named in his honor.","number":4},{"category":"legacy","header":"He blazed the Pumpelly Trail up Monadnock","body":"From his summer place at Dublin, New Hampshire, Pumpelly cut a ridge trail to the summit of Mount Monadnock that still carries his name. He spent his last decades at Newport and presided over the Geological Society of America in 1905.","number":5}],"sources":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"family_connection","display_label":"descends from Springfield's founder William Pynchon","related_id":"Y00004","link_text":"Hon. William Pynchon"},{"type":"family_connection","display_label":"descends from Connecticut governor Thomas Welles","related_id":"X02354","link_text":"Gov. Thomas Welles"},{"type":"parallel_careers","display_label":"the mineralogist in whose system pumpellyite is classed","related_id":"X00898","link_text":"Edward Salisbury Dana"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Raphael","last_name":"Pumpelly","married_names":[],"display_name":"Raphael Pumpelly","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780757921/18514323_ba588cd9-8d5f-46cb-89d2-794a87890734_j2tjyt.jpg"},"military_service":[],"education":[{"school_name":"Bergakademie Freiberg","dates":"1856-1859","type":"graduate","notes":"Mining engineering."}],"career":[{"role":"Geologist & explorer","organization":"Surveys of Japan, China, Mongolia","start_year":1861,"notes":"Mining & geological surveys."},{"role":"Director","organization":"Northern Transcontinental Survey","notes":"Railroad route survey."}],"slug":"raphael-pumpelly-1837"},"I01540":{"id":"I01540","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"female","birth":{"year":1840,"month":3,"day":14,"city":"Dorchester","county":"Suffolk County","state":"Massachusetts","country":"United States"},"death":{"year":1915,"month":2,"day":5,"city":"Newport","county":"Newport County","state":"Rhode Island","country":"United States"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Otis Shepard","mother_name":"Ann Pope"},"number_of_marriages":1,"marriages":[{"spouse_id":"TD0334","spouse_name":"Raphael Pumpelly","marriage_year":1869,"marriage_place":"Dorchester, Massachusetts","children_ids":["TD0335","TD0336","TD0337"]}],"tags":[],"narrative_blocks":[{"category":"arts","header":"John Singer Sargent painted her portrait","body":"In 1887 John Singer Sargent painted a waist-length portrait of Eliza Shepard Pumpelly, now held by the Berkshire Museum. She had married the geologist Raphael Pumpelly in 1869 and shared his homes at Newport and in the New Hampshire hills.","number":1}],"sources":[],"institutions":[],"landmarks":[],"artworks":[{"artwork_id":"ART070","role":"subject"}],"research_tags":[],"cross_connections":[{"type":"artifact","related_id":"I01660","display_label":"also drawn by John Singer Sargent"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Eliza Frances","last_name":"Shepard","married_names":["Pumpelly"],"display_name":"Eliza Frances Shepard Pumpelly","gender":"female",