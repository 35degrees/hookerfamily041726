49","H00350"]}],"tags":["yale_graduate","hooker_talcott_convergence","politician","replacement_naming"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 115"}],"cross_connections":[{"type":"parallel_marriage","related_id":"H00356","display_label":"Both families joined through Talcott siblings.","link_text":"Mary Russell Talcott"},{"type":"founding_family_nexus","related_id":"T00070","display_label":"His wife's brother Matthew also married into the Hooker family line.","link_text":"Col. Matthew Talcott"},{"type":"founding_family_nexus","related_id":"I00053","display_label":"Both tied to separate Talcott branches in the same family generation.","link_text":"Hon. Daniel Edwards"},{"type":"founding_family_nexus","related_id":"H00118","display_label":"Both families joined through Talcott siblings a generation later.","link_text":"Mary Pierpont Russell"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"marriage","header":"Married Governor Talcott's daughter Eunice","body":"Eunice Talcott was the second daughter of Joseph Talcott, Governor of Connecticut from 1725 to 1741. Their marriage directly joined the two founding Hartford families — reinforced when Eunice's brother Matthew simultaneously married Mary Russell, herself a Hooker descendant."},{"number":2,"category":"legacy","header":"Named co-heir in the Governor's estate","body":"On December 25, 1742, Nathaniel and Eunice appeared before the Court of Probate in Hartford to sign Governor Joseph Talcott's estate distribution as co-heirs. It was one of the final official acts binding the Hooker family to the colonial governor's wealth."},{"number":3,"category":"career","header":"Yale man, militia captain, Assembly representative","body":"He graduated Yale College in 1729 and held the rank of Captain in the Connecticut Militia as early as 1734. He served as Hartford's representative in the General Assembly across three sessions, while running a substantial Hartford mercantile estate."},{"number":4,"category":"family","header":"Son James partnered in Hooker & Chaffee","body":"His son James Hooker was a partner in the mercantile firm Hooker & Chaffee, which grew very successful during the Revolutionary War era. The firm continued the family's Hartford commercial standing into the next generation."}],"baptism":{"year":1710,"month":10,"day":8,"city":"Hartford","state":"Connecticut","country":"United States"},"institutions":[{"institution_id":"INST022","institution_blurb":"Yale College 1729.","relationship":"alumnus","years":"1729"}],"education":[{"school_name":"Yale College","graduation_year":1729,"institution_id":"INST022"}],"bio":{"display_name":"Captain Nathaniel Hooker","first_name":"Nathaniel","last_name":"Hooker","title":"Captain","married_names":[]},"residence":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"nathaniel-hooker-1710"},"I00054":{"id":"I00054","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"generation_from_john_talcott":3,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1709,"month":1,"day":26,"city":"Hartford","county":"Hartford County","state":"Connecticut","country":"United States"},"death":{"year":1795,"month":7,"day":12,"city":"Windsor","county":"Hartford County","state":"Connecticut","country":"United States"},"parents":{"father_id":"T00045","mother_id":"U00017"},"marriages":[{"marriage_number":1,"spouse_id":"H00115","location_city":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1763,"children_ids":["H00346","H00347","H00348","H00349","H00350"]}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 115"}],"talcott_book_id":"69","burial":{"cemetery_id":"CEM107"},"cross_connections":[{"type":"founding_family_nexus","related_id":"H00356","display_label":"Sister-in-law — Mary Russell married her brother Matthew Talcott.","link_text":"Mary Russell Talcott"}],"gender":"female","tags":["hooker_talcott_convergence"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"She and brother Matthew both married Hooker descendants","body":"She married Captain Nathaniel Hooker — a direct Hooker-surname descendant. Her brother Matthew Talcott simultaneously married Mary Russell, herself a Hooker descendant through the Pierpont line. Two of Governor Joseph Talcott's children marrying into the Hooker family in the same generation is why \"Talcott\" became a permanent name in the Hooker tree."}],"bio":{"display_name":"Eunice Talcott Hooker","first_name":"Eunice","last_name":"Hooker","maiden_name":"Talcott","married_names":["Hooker"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"eunice-talcott-1709"},"H00033":{"id":"H00033","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":3,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1671,"month":9,"day":18,"city":"Farmington","state":"Connecticut","country":"United States"},"death":{"year":1711,"month":11,"day":21,"city":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00007","mother_id":"I00006"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 33"}],"marriages":[{"marriage_number":1,"spouse_id":"I00051","date_year":1698,"date_month":12,"date_day":28,"location_city":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1711,"children_ids":["H00110","H00111","H00112","H00113","H00114","H00115"]}],"burial":{"cemetery_id":"CEM003"},"cross_connections":[{"type":"family_connection","related_id":"T00042","display_label":"His daughter married her son, founding lines merged.","link_text":"Mary Talcott"}],"gender":"male","tags":["politician"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"marriage","header":"His bride had been promised to his brother","body":"Mary Standley had been betrothed to Nathaniel's brother Roger Hooker, who died April 29, 1698. Seven months later — December 28, 1698 — Nathaniel married her instead."},{"number":2,"category":"career","header":"His wedding gift was half of Main Street","body":"When Nathaniel married, his father-in-law Hon. Nathaniel Stanley gave him half his Hartford lot — extending from the Second Burial Ground to the little river. This became his place of business on the main street, just below the present Centre Church."},{"number":3,"category":"marriage","header":"Two different Stanley families both married Hooker brothers","body":"His brother John had married Abigail Standley of one Stanley family; Nathaniel married Mary Standley of a completely separate Stanley branch — Hon. Nathaniel Stanley of Hartford's line. Two unrelated families sharing the same name both converged on the Hooker brothers in the same generation."},{"number":4,"category":"politics","header":"Hartford's Colonial Assembly representative, dead at 40","body":"He represented Hartford in the Connecticut Colonial Assembly for several years. He died November 21, 1711, at age 40, still in office."},{"number":5,"category":"family","header":"His daughter married into the Talcott-Edwards line","body":"His daughter Sarah Hooker married Hon. Daniel Edwards in 1728 — whose mother was Mary Talcott, daughter of Lt.-Col. John Talcott. Their children thus descend from both Rev. Thomas Hooker and the founding Talcott line."}],"bio":{"display_name":"Nathaniel Willett Hooker","first_name":"Nathaniel","last_name":"Hooker","middle_name":"Willett","married_names":[],"bio_blurb":"Hartford colonial assemblyman; grandson of Thomas Hooker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"nathaniel-hooker-1671"},"I00051":{"id":"I00051","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1677,"month":10,"day":8,"city":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1753,"month":8,"day":23,"city":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"X00057","mother_id":"X00058"},"marriages":[{"marriage_number":1,"spouse_id":"H00033","date_year":1698,"date_month":12,"date_day":28,"location_city":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1711,"children_ids":["H00110","H00111","H00112","H00113","H00114","H00115"]},{"marriage_number":2,"spouse_id":"X01058","date_year":1713,"date_month":12,"date_day":8,"location_city":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1743,"children_ids":[]}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 33"}],"gender":"female","tags":[],"number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"family_connection","related_id":"I00031","display_label":"Both Standley women married Hooker brothers — different families.","link_text":"Abigail Standley Hooker"}],"bio":{"display_name":"Mary Standley Hooker Austin","first_name":"Mary","last_name":"Austin","married_names":["Hooker","Austin"],"maiden_name":"Standley"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Half a Hartford house lot came with marriage","body":"When Mary Stanley married the Hartford merchant Nathaniel Hooker in 1698, her father gave the couple half his house lot, which ran from the Center Church burying-yard down to the Little River. Nathaniel served in the legislature until his death in 1711, after which she married another noted Hartford merchant, John Austin."}],"slug":"mary-standley-1677"},"T00045":{"id":"T00045","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":2,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1669,"month":11,"day":16,"city":"Hartford","state":"Connecticut"},"death":{"year":1741,"month":10,"day":11,"city":"Hartford","state":"Connecticut"},"parents":{"father_id":"T00035","mother_id":"U00012"},"tags":[],"sources":[{"short":"Talcott 1876","page":"Entry 45"}],"marriages":[{"spouse_id":"U00022","children_ids":["T00065","T00066","T00067","X00436"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1705,"date_year":1693},{"spouse_id":"U00017","children_ids":["T00068","I00054","T00070","T00071","T00072","T00073","X00446"],"marriage_number":2,"end_type":"death_of_spouse","end_year":1738}],"political_offices":[{"title":"Governor","jurisdiction":"Colony of Connecticut","dates":"1724-1741","duration_years":17,"notes":"First Governor of Connecticut born within its limits. Longest-serving after Gov. Winthrop. Died in office Oct 11, 1741."}],"cross_connections":[{"type":"historical_connection","related_id":"H00115","display_label":"Son-in-law signed his estate — 'Nathaniel Hooker and Eunice Hooker'","link_text":"Captain Nathaniel Hooker"},{"type":"family_connection","related_id":"H00360","display_label":"His granddaughter Esther married Rev. Noadiah Russell in 1758","link_text":"Noadiah Russell"},{"type":"civic_peer","related_id":"U00020","display_label":"was the Deputy Governor whose death opened his path","link_text":"Nathan Gold"}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":true,"notable_category":["politics"],"notable_blurb":"First Connecticut governor born within its limits","primary_url":"https://en.wikipedia.org/wiki/Joseph_Talcott","primary_url_label":"Wikipedia"},"narrative_blocks":[{"header":"First Connecticut governor born within the colony","body":"Born in Hartford on November 16, 1669, Joseph Talcott was the first Governor of Connecticut born within the colony rather than in England. He served from 1724 until his death on October 11, 1741 — 17 years in office, longer than any predecessor except Governor Winthrop and any successor until the modern era. His funeral expenses of £69 12s. 6d. were paid from the Colonial Treasury.","number":1,"category":"politics"},{"header":"He presided in the upper house the afternoon","body":"When his wife Eunice died suddenly about noon on Thursday, May 25, 1738, the Deputy Governor was absent at Norwich. Governor Talcott did not let his private grief interfere with his official duty — he returned and presided in the upper house that same afternoon. The General Assembly appointed a committee to draw an address of condolence to the Governor.","number":2,"category":"politics"},{"header":"His estate was signed by 'Nathaniel Hooker","body":"At the Court of Probate, Hartford, on December 25, 1742, the distribution of Governor Talcott's estate was signed by all children as co-heirs. Among the signatures: 'Nathaniel Hooker and Eunice Hooker' — his daughter Eunice Talcott and her husband Nathaniel Hooker 2d. The Talcott-Hooker convergence was entered into the public record.","number":3,"category":"family"},{"header":"Three of his children each found a separate","body":"His daughter Eunice married Nathaniel Hooker 2d — direct Hooker surname. His son Matthew married Mary Russell, a Hooker descendant through the Pierpont branch. His daughter Abigail married Rev. Daniel Wadsworth; their son Jeremiah later married Mary's own sister Mehitable Russell, also a Hooker descendant.","number":4,"category":"family"},{"header":"Petitioned for his father's estate by primogeniture","body":"Joseph Talcott was the fourth son of Lt.-Col. John Talcott Jr. but the eldest to survive his father. In 1691, at age 21, he petitioned the General Court for his father's estate by right of primogeniture — an assertive legal claim for colonial Connecticut. He was first mentioned in public life in 1711 as a committee member to lay out the town of Coventry.","number":5,"category":"law"}],"bio":{"display_name":"Gov. Joseph Talcott","title":"Governor","first_name":"Joseph","last_name":"Talcott","married_names":[],"bio_blurb":"Colonial governor of Connecticut"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM003"},"slug":"joseph-talcott-1669"},"U00017":{"id":"U00017","visible_default":true,"in_talcott_book":true,"classification":{"is_spouse_of_talcott_descendant":true,"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1678,"month":8,"day":18,"city":"Southampton","county":"Suffolk","state":"New York","country":"United States"},"death":{"year":1738,"month":5,"day":25,"city":"Hartford","county":"Hartford","state":"Connecticut","country":"United States"},"marriages":[{"children_ids":[],"spouse_id":"X01733","marriage_number":1},{"spouse_id":"T00045","children_ids":["T00068","I00054","T00070",