{"person":{"id":"H00655","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1772,"month":4,"day":21,"city":"Middletown","state":"Connecticut"},"parents":{"mother_id":"H00296","father_id":"X01067"},"tags":["episcopal","new_york_migration","ohio_migration"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 655"}],"death":{"year":1849,"month":1,"day":17,"city":"Ogdensburg","county":"St. Lawrence County","state":"New York"},"marriages":[{"children_ids":["HD0833","HD0834"],"spouse_id":"X01330","marriage_number":1,"date_year":1800,"date_month":8,"date_day":7}],"burial":{"cemetery_id":"CEM080"},"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sally Pomeroy","first_name":"Sally","maiden_name":"Pomeroy","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Husband organized first Episcopal parish in Ohio","body":"Sally's husband Rev. Roger Searle organized the first Episcopal parish in Ohio — St. Peter's at Ashtabula on February 19, 1817 — and preached the first religious service in Medina County Ohio on March 11, 1817. He went on to organize Trinity Cleveland, St. Mark's Columbia, St. James' Boardman, and St. Luke's Ravenna. Sally lived alongside this Ohio Episcopal circuit-rider mission through its founding decade."},{"number":2,"category":"family","header":"Widowed at Ohio frontier age fifty-four","body":"Sally was widowed at age fifty-four when Rev. Searle died September 6, 1826 in Ashtabula Ohio. She lived another twenty-three years and u