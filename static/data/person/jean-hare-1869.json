"state":"Wisconsin","country":"United States"},"parents":{"father_id":"HD0949","mother_id":"X02228"},"burial":{"plot_notes":"Mount Pleasant Cemetery, Tibbets, Walworth County WI (per Findagrave). Same as parents."},"number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"X02229","location_country":"United States","end_type":"death_of_spouse","children_ids":["HD3196","HD3197","HD3193","HD3198"]},{"marriage_number":2,"spouse_id":"X02230","location_country":"United States","children_ids":[]}],"tags":["wisconsin_migration"],"sources":[{"short":"Findagrave (Mount Pleasant Cemetery, Tibbets WI)"},{"short":"WikiTree (Corris A Bartlett Hare)"},{"short":"Walworth County 1882 history"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Second husband made superior-quality sorghum molasses","body":"After her first husband Levi Hare died, Coris Ann married William Hodges — a Wisconsin manufacturer known locally for his 'superior quality sorghum molasses,' the cane-syrup product that became a mid-nineteenth-century Northern alternative to slavery-produced Southern sugar. The Walworth County Wisconsin sorghum trade reached its peak during the 1860s-1880s as a documented anti-slavery agricultural economy. William Hodges's specific reputation for quality placed him among the regional leaders."},{"number":2,"category":"family","header":"Two marriages; four children with Levi Hare","body":"Coris Ann's first marriage to Levi Hare (born May 26, 1837 New York) produced four documented children. After Levi's death she married William Hodges without further documented children. The two-marriage household was typical of nineteenth-century American widows who remarried for economic and social support; her second marriage placed her in the sorghum-molasses trade economy of Walworth County Wisconsin."},{"number":3,"category":"family","header":"Moriah NY 1843 to Elkhorn Wisconsin 1927","body":"Coris Ann Bartlett was born July 21, 1843 in Moriah, Essex County New York — during her father Truman Bartlett's New York years before the family's 1844 migration to Wisconsin. She died April 6, 1927 in Elkhorn, Walworth County Wisconsin at age eighty-three. She is buried at Mount Pleasant Cemetery, Tibbets Wisconsin alongside her parents — a three-generation Wisconsin family cemetery cluster."}],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"coris-hodges-1843"},"HD0949":{"id":"HD0949","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD0436","mother_id":"X00206"},"tags":["pioneer_settler","wisconsin_migration"],"sources":[],"birth":{"year":1815,"month":8,"day":3,"state":"Vermont","country":"United States"},"death":{"year":1907,"month":9,"day":4,"city":"Lafayette","county":"Walworth County","state":"Wisconsin","country":"United States"},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02228","date_year":1838,"location_country":"United States","end_type":"death_of_spouse","end_year":1890,"children_ids":["HD3190","HD3191","HD3192"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Truman Bartlett","first_name":"Truman","last_name":"Bartlett","married_names":[],"photo_url":"https://images.findagrave.com/photos/2017/138/60834891_1495246133.jpg","photo_notes":"Findagrave portrait."},"burial":{"plot_notes":"Mount Pleasant Cemetery, Tibbets, Walworth County WI (per Findagrave). Photo URL: https://images.findagrave.com/photos/2017/138/60834891_1495246133.jpg"},"career":[{"role":"Lumberman","start_year":1836,"end_year":1844,"notes":"Worked in lumbering at Essex County NY from age 21 (1836-1838); back to Vermont 1838-1844; relocated to Wisconsin Oct 1844."},{"role":"Sawmill operator","start_year":1844,"end_year":1856,"notes":"Operated a sawmill in Spring Prairie, Walworth County, Wisconsin for 12 years."},{"role":"Farmer","organization":"Truman Bartlett farm (later Lauderdale Farms)","start_year":1856,"notes":"In 1856 bought a 100-acre farm north of Elkhorn (Section 6, town of LaFayette, Walworth County WI). By 1882 had increased to 180 acres (100 acres farmland $50/acre + 80 acres in Troy at $12/acre). Property later became Lauderdale Farms (Sylvandale 1908; bought by S.J. Lauderdale 1908)."}],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"truman-bartlett-1815"},"X02228":{"id":"X02228","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":false},"bio":{"first_name":"Syrena","middle_name":"Strong","last_name":"Bartlett","maiden_name":"Strong","married_names":["Bartlett"],"extra_names":"aka Serena (per Walworth County 1882 history)","gender":"female","display_name":"Syrena Strong Bartlett"},"birth":{"year":1823,"month":2,"day":18,"city":"Moriah","county":"Essex County","state":"New York","country":"United States"},"death":{"year":1890,"month":6,"day":9,"city":"Lafayette","county":"Walworth County","state":"Wisconsin","country":"United States"},"parents":{},"burial":{"plot_notes":"Mount Pleasant Cemetery, Tibbets, Walworth County WI (per Findagrave)."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0949","date_year":1838,"location_country":"United States","end_type":"death","end_year":1907,"children_i