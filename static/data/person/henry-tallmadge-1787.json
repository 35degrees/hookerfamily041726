r_of_marriages":2,"marriages":[{"spouse_id":"X03134","children_ids":["X00297"],"marriage_number":1},{"spouse_id":"X03135","children_ids":[],"marriage_number":2}],"tags":["declaration_signer","revolutionary_war"],"narrative_blocks":[{"category":"politics","header":"A New York signer of the Declaration","body":"Floyd sat in the First and Second Continental Congresses and was the only signer of the Declaration of Independence from Suffolk County. The British seized his Long Island estate and used it as a cavalry base for seven years.","number":1},{"category":"military","header":"His militia met the British on Long Island","body":"A major general of the Suffolk County militia, Floyd resisted an early British landing before the island fell. His family fled across the Sound to Connecticut and lived as refugees until the war's end.","number":2},{"category":"career","header":"First Congressman, then a frontier pioneer","body":"Floyd served in the first United States Congress from 1789 to 1791 and twice sat as a presidential elector. At sixty-nine he moved to the Mohawk frontier, where Oneida County's town of Floyd bears his name.","number":3}],"sources":[],"institutions":[],"landmarks":[{"landmark_id":"LM128","landmark_blurb":"His Long Island home, the Old Mastic House, now a National Park Service site."}],"artworks":[{"artwork_id":"ART078","role":"subject"}],"research_tags":[],"cross_connections":[{"type":"family_orbit","related_id":"H00757","display_label":"father-in-law of this Hooker descendant"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"William","last_name":"Floyd","display_name":"William Floyd","gender":"male","bio_blurb":"Signer of the Declaration of Independence","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780934991/William_floyd-resized_ub5gmm.jpg"},"military_service":[],"career":[],"birth":{"year":1734,"country":"United States","month":12,"day":17,"city":"Brookhaven","state":"New York"},"death":{"year"