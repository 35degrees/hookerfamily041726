"is_notable":false,"notable_category":[]},"parents":{"father_id":"I01585","mother_id":"HD5932"},"number_of_marriages":1,"marriages":[{"spouse_id":"I01586","children_ids":["HD5950","HD5951"]}],"tags":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"She married at her sickbed with pneumonia","body":"Stricken with pneumonia two weeks before her 1911 wedding to the pediatrician William McKim Marriott, Elizabeth Robinson refused to postpone; the ceremony was performed at her bedside by a cousin, with no reception. She recovered to raise a family that included the anthropologist McKim Marriott."}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Elizabeth Devereux Robinson","last_name":"Marriott","display_name":"Elizabeth Devereux Robinson Marriott","gender":"female","married_names":[],"maiden_name":"Robinson"},"military_service":[],"career":[],"birth":{"year":1886,"month":4,"day":6,"city":"New York","county":"New York","state":"New York","country":"United States"},"death":{"year":1954,"month":1,"day":5,"city":"St. Louis","state":"Missouri","country":"United States"},"slug":"elizabeth-devereux-robinson-marriott-1886"},"I01586":{"id":"I01586","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"include_in_path_calculation":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"spouse_id":"HD5934","children_ids":["HD5950","HD5951"]}],"tags":["physician"],"narrative_blocks":[{"number":1,"category":"science","header":"He decoded the chemistry of sick infants","body":"Marriott's research into acidosis and infant feeding reshaped pediatric care in the early twentieth century. He served as dean of Washington University's medical school and, just before his death, of the University of California's."},{"category":"career","header":"He led two medical schools as dean","body":"Marriott served for years as dean of Washington University's medical school and in 1936 took the deanship at the University of California, only to die months later. He was twice president of the American College of Physicians.","number":2}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"William McKim","last_name":"Marriott","display_name":"Dr. William McKim Marriott","gender":"male","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780853794/237179701_f354d3e4-1bff-4545-9204-e4c63d6a6456_bn4wca.jpg","bio_blurb":"Pediatric researcher and medical-school dean"},"military_service":[],"birth":{"year":1885,"month":3,"day":5,"city":"Baltimore","state":"Maryland","country":"United States"},"death":{"year":1936,"month":11,"day":11,"city":"San Francisco","state":"California","country":"United States"},"burial":{"cemetery_name":"Green Mount Cemetery","city":"Baltimore","state":"Maryland","country":"United States"},"career":[{"role":"Dean, School of Medicine","organization":"Washington University","location":"St. Louis, Missouri","start_year":1917,"end_year":1923},{"role":"Dean, Medical School","organization":"University of California","location":"Berkeley, California","start_year":1936}],"education":[{"school_name":"University of North Carolina","type":"college","dates":"1904"},{"school_name":"Cornell University","type":"medical","dates":"M.D. 1910"}],"slug":"william-mckim-marriott-1885"},"HD5950":{"id":"HD5950","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"include_in_path_calculation":true,"is_easter_egg":false,"generation_from_thomas":11},"notable":{"is_notable":true,"notable_category":["science"],"notable_blurb":"Anthropologist who reframed the study of caste","primary_url":"https://en.wikipedia.org/wiki/McKim_Marriott"},"parents":{"father_id":"I01586","mother_id":"HD5934"},"number_of_marriages":0,"marriages":[],"tags":["academic","veteran","wwii","extraordinary_longevity"],"narrative_blocks":[{"number":1,"category":"career","header":"He revolutionized how scholars study caste","body":"At the University of Chicago, McKim Marriott built the leading center for South Asian anthropology and reframed the study of caste around Indian categories rather than Western ones. His 1955 volume Village India became a founding text of the field."},{"number":2,"category":"education","header":"A wartime posting to India shaped him","body":"Drafted as an army private who knew Japanese, Marriott was sent to India to translate radio transmissions and spent his days exploring villages near Delhi. The experience drew him from Harvard to a Chicago doctorate on rural Indian life."},{"number":3,"category":"character","header":"He turned Hindu cosmology into a game","body":"Marriott invented Samsara, a cube-based board game in which players took on caste statuses and occupations to inhabit traditional Hindu society. Students recalled the delight of stepping into the lives of the people they studied."},{"number":4,"category":"legacy","header":"He reached one hundred, teaching to the end","body":"Remembered as a spritely presence leaping up Haskell Hall's steps, Marriott trained generations of South Asia scholars across half a century at Chicago. He turned one hundred in February 2024 and died five months later."}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"parallel_careers","related_id":"HD1861","display_label":"the eminent Harvard sociologist of the same era"}],"quotes":[],"research