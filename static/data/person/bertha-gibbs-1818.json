"},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"generation_from_john_talcott":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00922","mother_id":"H02017"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_in_infancy"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"History of Descendants of Elder John Strong, Vol. 1 (1871)","url":"https://dn720908.ca.archive.org/0/items/historyofdescend0001dwig/historyofdescend0001dwig.pdf"}],"research_sources":[],"documents":[],"slug":"unnamed-hd4638"},"I00900":{"id":"I00900","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"title":"Judge","first_name":"Elisha","middle_name":"Beebe","last_name":"Strong","married_names":[],"gender":"male","display_name":"Elisha Beebe Strong"},"birth":{"year":1788,"month":11,"day":29,"city":"Hartford","county":"Hartford County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1867,"month":10,"day":12,"city":"Detroit","county":"Wayne County","state":"Michigan","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM436","plot_notes":"Mount Hope Cemetery Rochester NY per FA"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["politics","law"],"notable_blurb":"First Judge of Monroe County, NY; Yale 1809","primary_url":"https://en.wikipedia.org/wiki/Elisha_Beebe_Strong","primary_url_label":"Wikipedia"},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00795","date_year":1813,"date_month":6,"date_day":24,"location_country":"United States","end_type":"death_of_spouse","end_year":1850,"children_ids":["H02014","H02015","H02016","H02017","H02018","H02019","H02020","H02021"]}],"education":[{"institution_id":"INST022","school_name":"Yale College","dates":"1809","type":"bachelor","notes":"Prepared for college by Nathan Johnson. Yale class of 1809."},{"institution_id":"INST024","school_name":"Litchfield Law School","dates":"1810","type":"law","notes":"Attended Litchfield Law School 1810; thereafter read law in Canandaigua NY."}],"career":[{"role":"Lawyer","organization":"Canandaigua, New York","start_year":1812,"end_year":1816,"notes":"Partner with William H. Adams. Admitted to bar 1812."},{"role":"Land Developer","organization":"Rochester, New York","start_year":1816,"notes":"Purchased 1,000 acres near Rochester with Elisha Beach; developed Carthage area; erected storehouses, incline railway, bridge over lower falls."},{"role":"Member of NY State Assembly","organization":"Ontario County, New York","start_year":1819,"end_year":1820,"notes":"Elected from Ontario County."},{"role":"First Judge of Monroe County","organization":"Monroe County, New York","start_year":1821,"end_year":1823,"notes":"Appointed March 5, 1821 by Governor DeWitt Clinton. Monroe County organized February 23, 1821."},{"role":"Lawyer","organization":"Detroit, Michigan","start_year":1861,"end_year":1867,"notes":"Moved to Detroit 1861; died there Oct 14, 1867."}],"military_service":[],"institutions":[{"institution_id":"INST024","relationship":"alumnus","institution_blurb":"Attended 1810; appointed first judge of Monroe County NY by 1821."},{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["yale_graduate","lawyer","judge","politician"],"research_tags":[],"cross_connections":[{"type":"parallel_descent","related_id":"I00055","display_label":"Both Strong men who married Hooker descendants, 84 years apart","link_text":"Capt. Asahel Strong Jr."}],"narrative_blocks":[{"number":1,"category":"politics","header":"First Judge of Monroe County, appointed 1821","body":"Elisha Beebe Strong was appointed the first judge of Monroe County, New York on March 5, 1821 by Governor DeWitt Clinton — just days after the county itself was organized by the state legislature from Ontario County territory. A Yale graduate (1809) and Litchfield Law School alumnus, he had also served in the New York State Assembly in 1819-1820 and as a presidential elector in 1824, becoming one of the most prominent legal figures in upstate New York."},{"number":2,"category":"marriage","header":"His Hooker marriage repeated a Strong family tradition","body":"When Elisha Beebe Strong married Dolly Goodwin Hooker in 1813 at Canandaigua, New York, he was not the first Strong to wed a Thomas Hooker descendant: 84 years earlier, his ancestral kin Captain Asahel Strong Jr. had married Sarah Hooker of Farmington, Connecticut in 1729, producing a line that named a grandson 'Asahel Hooker Strong' to preserve the memory. The two unions — Farmington 1729, Canandaigua 1813 — trace the same Strong-Hooker affinity across the Great Migration and the early Republic, from a Farmington lawyer's household to a frontier judge's courtroom on the Erie Canal."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave","url":"https://www.findagrave.com"},{"label":"Wikipedia — Elisha Beebe Strong","url":"https://en.wikipedia.org/wiki/Elisha_Beebe_Strong"},{"label":"Litchfield Law School Biographical Ledger","url":"https://ledger.litchfieldhistoricalsociety.org/ledger/students/2494"}],"research_sources":[],"documents":[],"slug":"elisha-strong-1788"},"H00795":{"id":"H00795","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":true,"is_easter_egg":false,"generation_from_john_talcott":5},"birth":{"year":1787},"parents":{"father_id":"H00348","mother_id":"X00319"},"tags":[],"sources":[{"short":"Edward Hooker 1909","entry":"795"},{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"death":{"year":1850,"month":2,"day":15,"city":"Rochester","county":"Monroe County","state":"New York","country":"United States"},"gender":"female","marriages":[{"spouse_id":"I00900","children_ids":["H02014","H02015","H02016","H02017","H02018","H02019","H02020","H02021"],"marriage_number":1,"date_year":1813,"date_month":6,"date_day":24}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"parallel_descent","related_id":"H00103","display_label":"Hooker women who married Strongs in 1729 and 1813","link_text":"Sarah Hooker Strong"}],"bio":{"display_name":"Dolly Goodwin Hooker","first_name":"Dolly","middle_name":"Goodwin","maiden_name":"Hooker","married_names":[],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"politics","header":"Her husband was Monroe County's first judge","body":"Dolly Goodwin Hooker married Elisha Beebe Strong, who in 1821 became the first judge of Monroe County, New York. She died in Rochester in 1850; he remarried and moved to Detroit, dying there in 1867."},{"number":2,"category":"marriage","header":"Her Hooker-Strong marriage echoed one from 1729","body":"When Dolly Goodwin Hooker married Elisha Beebe Strong in 1813, she entered a family that had already wed into the Hooker line 84 years before: Captain Asahel Strong Jr. had married her distant cousin Sarah Hooker at Farmington in 1729, and a grandson of that marriage — Asahel Hooker Strong — was already carrying her maiden name as his own middle name by 1776. Dolly's marriage completed the second arc; her great-grandson Beebe Hooker Strong, born in Milwaukee in 1866, would carry the name to a third generation on the Wisconsin frontier."}],"burial":{"cemetery_id":"CEM436","plot_notes":"Mount Hope Cemetery Rochester NY per FA"},"slug":"dolly-hooker-1787"},"H00348":{"id":"H00348","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":true,"generation_from_john_talcott":4,"is_thomas_descendant":true,"is_talcott_descendant":true,"is_easter_egg":false},"birth":{"year":1742,"month":8,"day":15,"city":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1805,"month":12,"day":10,"city":"Windsor","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00115","mother_id":"I00054"},"tags":["revolutionary_war","hooker_talcott_descent"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 348"}],"burial":{"cemetery_id":"CEM107"},"marriages":[{"spouse_id":"X00317","children_ids":["H00793"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1765,"date_year":1763,"date_month":1,"date_day":6,"location_country":"United States"},{"spouse_id":"X00318","marriage_number":2,"children_ids":[],"end_type":"death_of_spouse","end_year":1784,"date_year":1777,"date_month":4,"date_day":30,"location_country":"United States"},{"spouse_id":"X00319","children_ids":["H00794","H00795","H00796","H00797","H00798","H00799","H00800","H00801"],"marriage_number":3,"date_year":1784,"date_month":11,"date_day":7,"location_country":"United States"}],"cross_connections":[{"type":"parallel_descent","related_id":"I00054","display_label":"His mother — daughter of Governor Joseph Talcott.","link_text":"Eunice Talcott Hooker"},{"type":"parallel_descent","related_id":"T00045","display_label":"His maternal grandfather, Governor of Connecticut 1724-1741.","link_text":"Gov. Joseph Talcott"},{"type":"parallel_descent","related_id":"T00387","display_label":"First cousin once removed via the Talcott family.","link_text":"Col. Jeremiah Wadsworth"},{"type":"parallel_descent","related_id":"H00362","display_label":"Wife of his cousin Wadsworth — also a Hooker descendant.","link_text":"Mehitable Russell"},{"type":"civic_connection","related_id":"X00433","display_label":"Father-in-law and partner in the Hooker and Chaffee firm.","link_text":"Dr. Hezekiah Chaffee"},{"type":"professional","related_id":"X00434","display_label":"his partner in the firm Hooker & Chaffee"},{"type":"family_connection","related_id":"X00434","display_label":"brother of his wife Mary Chaffee"}],"gender":"female","number_of_marriages":3,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"career","header":"Hooker and Chaffee supplied the Continental Army","body":"Hooker and Chaffee was one of New England's largest mercantile houses before the Revolution, transacting much business for the Colonial Government. The partners gave freely to the patriot cause and were seriously embarrassed at war's end."},{"number":2,"category":"military","header":"His firm provisioned alongside Wadsworth's commissary","body":"The Hooker and Chaffee firm operated alongside Jeremiah Wadsworth's larger commissary operation — both Hooker-Talcott descendants provisioning the same Continental Army. The Connecticut River Valley supply network was effectively a Hooker-tree internal collaboration."},{"number":3,"category":"legacy","header":"His Windsor house is on the National Register","body":"He built the James Hooker House ca. 1772 at 118 Palisado Avenue, Windsor — now part of the Palisado Avenue Historic District on the National Register of Historic Places. The interior was later gutted for Chaffee School classrooms but the Federal-period exterior survives under Greek Revival additions."}],"institutions":[{"institution_id":"INST070","institution_blurb":"Silent partner; one of New England's great Revolutionary-era trading houses."}],"landmarks":[{"landmark_id":"LM015","landmark_blurb":"He built this house c.1772; it survives on Palisado Avenue's National Register district."}],"bio":{"display_name":"Captain James Hooker","first_name":"James","maiden_name":"Hooker","title":"Captain","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778904974/captjameshooker_rjjclc.jpg","photo_notes":"Portrait of Captain James Hooker (1742-1805), Windsor CT merchant."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Merchant and Silent Partner","organization":"Hartford and Windsor, Connecticut","end_year":1805,"notes":"Principal of INST070 Hooker and Chaffee. Succeeded to father's Hartford business with brothers; established Windsor branch. See INST070 for full firm history."}],"slug":"james-hooker-1742"},"X00319":{"id":"X00319","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"Chaffee genealogy book, entries 269 and 702"}],"birth":{"year":1760,"month":7,"day":28,"city":"Windsor","county":"Hartford County","state":"Connecticut","country":"United States"},"death":{"year":1846,"month":10,"day":7,"city":"Windsor","county":"Hartford County","state":"Connecticut","country":"United States"},"parents":{"father_id":"X00433","mother_name":"Lydia (Griswold) Chaffee","mother_research_notes":"Lydia (Griswold) Chaffee, b.Dec 17, 1722 Simsbury CT; d.Oct 1, 1801 Windsor CT. Daughter of the Griswold family of Connecticut."},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":3,"spouse_id":"H00348","children_ids":["H00794","H00795","H00796","H00797","H00798","H00799","H00800","H00801"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Chaffee Hooker","first_name":"Mary","maiden_name":"Chaffee","married_names":["Hooker"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Brother John was partner in Hooker & Chaffee","body":"Her older brother John Chaffee was a partner in the firm Hooker & Chaffee — the business linking her birth family directly to her husband's. The 1784 marriage to Captain James Hooker thus joined both personal and commercial lines of the Windsor Connecticut Chaffee household."},{"number":2,"category":"death","header":"Lived 41 years past husband's 1805 death","body":"She survived her husband Captain James Hooker by forty-one years — he died December 1805, she lived until October 1846 at eighty-six. After James's death she returned from Rochester New York to Windsor Connecticut and lived with her unmarried sister Hepsibah Chaffee until Hepsibah's 1834 death."}],"slug":"mary-chaffee-1760"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}