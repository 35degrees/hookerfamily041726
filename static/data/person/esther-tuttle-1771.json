city":"North Haven","county":"New Haven County","state":"Connecticut","country":"United States"},"death":{"year":1884,"month":7,"day":22,"city":"North Haven","county":"New Haven County","state":"Connecticut","country":"United States","age":83},"marriages":[{"spouse_id":"X00488","children_ids":["HD1525"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Zerah Pierpont Tuttle","first_name":"Zerah","last_name":"Tuttle","middle_name":"Pierpont","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST011"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Son Newton became Mormon pioneer to Utah","body":"Zerah's son Newton Tuttle (1825-1905) converted to the Church of Jesus Christ of Latter-day Saints and emigrated to Utah in the William Field Company in 1854. Newton's first wife Lucinda died of cholera at Fort Leavenworth before reaching Utah, and his four-year-old daughter Clara died two days into the overland journey on June 23, 1854. Newton reached Bountiful, Davis County Utah on October 21, 1854 and later served as territorial militiaman during the Utah War of 1857; his diary survives in the LDS Church archives in Salt Lake City."},{"number":2,"category":"family","header":"Named Pierpont for his mother's family","body":"Zerah was given the middle name 'Pierpont' for his mother's Pierpont family line — the same Hooker-line Pierpont ancestry that the project tracks back to John Pierpont of New Haven. His own daughter Eunice Tuttle Pierpont (born 1827) carried the Pierpont name forward another generation as a deliberate naming pattern."},{"number":3,"category":"family","header":"Two marriages across his eighty-three years","body":"Zerah married Maria Todd on April 28, 1824 at North Haven Connecticut; Maria died on April 28, 1860 — exactly thirty-six years later, on the same calendar day as their marriage. He remarried Mary Cook on October 28, 1861 in New Haven Connecticut. The calendar-coincidence of Maria's death-date and their marriage anniversary was either coincidental or noted at the time as a striking anniversary marker."},{"number":4,"category":"family","header":"Born and died at North Haven Connecticut","body":"Zerah Pierpont Tuttle was born October 2, 1800 in North Haven, New Haven County Connecticut and died July 22, 1884 in North Haven at age eighty-three. The lifelong-North Haven residence pattern was characteristic of the Tuttle-Pierpont-Munson cluster of New Haven County families through the nineteenth century."}],"slug":"zerah-tuttle-1800"},"X00488":{"id":"X00488","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1797},"death":{"year":1860},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1522","children_ids":["HD1525"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Maria Todd","first_name":"Maria","maiden_name":"Todd","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"maria-todd-1797"},"HD1525":{"id":"HD1525","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1522","mother_id":"X00488"},"tags":[],"sources":[],"birth":{"year":1825},"death":{"year":1905},"cross_connections":[{"type":"parallel_descent","related_id":"H00372","display_label":"Newton Tuttle (1825-1905), great-great-grandson of Rev. Thomas Hooker through the.","link_text":"Giles Pierpont"},{"type":"parallel_descent","related_id":"HD1522","display_label":"Newton Tuttle (1825-1905), great-great-grandson of Rev. Thomas Hooker through the.","link_text":"Zerah Pierpont Tuttle"}],"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Newton Tuttle","first_name":"Newton","last_name":"Tuttle","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST011"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"death","header":"First wife buried among Kansas walnut trees, 1854","body":"Lucinda Mix Tuttle died of cholera at Fort Leavenworth Kansas on 14 May 1854 — buried 'on the right side of the road just before you get to Salt Creek, in a cluster of walnut trees' per his diary. Two days into the overland journey their four-year-old daughter Clara died as well; he completed the trek to Bountiful Utah alone that October."},{"number":2,"category":"religion","header":"Seven generations from Hartford Puritan to Utah pioneer","body":"He was a fourth-great-grandson of Rev Thomas Hooker through the Pierpont-Tuttle line — from the Puritan founding of Hartford in 1636 to Latter-day Saints emigration to Bountiful Utah in 1854. His diary of the overland journey and the 1857 Utah War is held in the LDS Church archives in Salt Lake City."},{"number":3,"category":"marriage","header":"Heber Kimball married him in Salt Lake, 1855","body":"Less than a year after arriving in Utah and burying his first wife and daughter, he married Emily Amelia Stone on 7 April 1855 in Salt Lake City. The ceremony was performed by Heber Kimball — one of the original LDS apostles and counselor in the First Presidency under Brigham Young."}],"slug":"newton-tuttle-1825"},"HD1523":{"id":"HD1523","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1488","mother_id":"X00487"},"tags":[],"sources":[{"short":"Online vital records / primary documents"}],"birth":{"year":1809},"death":{"year":1849},"gender":"female","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Tuttle","first_name":"Elizabeth","maiden_name":"Tuttle","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elizabeth-tuttle-1809"},"H00372":{"id":"H00372","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD0416","mother_id":"I00145"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 372"}],"birth":{"year":1741,"month":6,"day":4,"city":"North Haven","state":"Connecticut"},"death":{"year":1832,"month":1,"day":16,"city":"North Haven","state":"Connecticut"},"marriages":[{"spouse_id":"X00480","children_ids":["HD1486","H00897","HD1488","HD1489","H00898","H00899"],"marriage_number":1,"date_year":1766,"date_month":1,"date_day":22}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"family_connection","related_id":"HD0418","display_label":"His paternal aunt — J