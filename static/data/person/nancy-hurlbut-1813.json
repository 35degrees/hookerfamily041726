utions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","rank":"Corporal","rank_start":"Private","rank_end":"Corporal","rank_year_start":1776,"rank_year_end":1776,"unit":"Col. Erastus Wolcott's Regt. (Capt. Selah Hart's 3rd Co.); Gen. Wadsworth's Brigade; Maj. Sheldon's Light Horse (Capt. Daniel Sloper's Co.)","service_years":"January–December 1776","battles":["BTL013","BTL007"],"notes":"1776 campaign across three commands. Winter 1776: guarded besieged Boston about six weeks in Capt. Selah Hart's 3rd Company, Col. Erastus Wolcott's Regiment. Summer 1776: present at the Battle of Long Island (Aug 27) with Gen. James Wadsworth's Brigade and the retreat from New York. Nov 4–Dec 24, 1776: Corporal in Capt. Daniel Sloper's Company, Maj. Sheldon's Regiment of Light Horse, on Washington's retreat through New Jersey. Source: Record of Service of Connecticut Men in the War of the Revolution (1889), pp. 381, 392, 475; Berlin-Peck, Revolutionary War Soldiers of the Town of Berlin."}],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married three times, his last two wives widows","body":"After Ann Hooker died in 1808 he married twice more, both times to widows: Sabra Winchell Stanley, and in 1822 Abigail Hart Smith, herself already twice-widowed. His will, presented in court July 1827, left the farm and stock to his son Seth and the remainder to his daughters Lydia, Nancy, and Amelia."},{"number":2,"category":"military","header":"His whole war fit in one brutal year","body":"Seth's Revolutionary service was crowded into 1776. That year he helped guard besieged Boston through the winter, stood with the army in its rout at the Battle of Long Island, and rode in the light horse covering Washington's retreat across New Jersey."}],"slug":"seth-stanley-1755"},"H00429":{"id":"H00429","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"des