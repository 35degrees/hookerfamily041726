lcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00825","mother_id":"I00369"},"tags":[],"sources":[{"short":"WikiTree (online genealogy)","url":"https://www.wikitree.com/"},{"short":"Find a Grave — West Cemetery Plymouth CT","url":"https://www.findagrave.com/cemetery/1353921/west-cemetery"}],"birth":{"year":1819,"month":5,"day":21,"county":"Litchfield","state":"Connecticut","country":"United States"},"death":{"year":1884,"month":2,"day":14,"state":"Connecticut","country":"United States"},"marriages":[{"marriage_number":1,"spouse_id":"I00371","location_country":"United States","end_type":"death_of_spouse","end_year":1874,"children_ids":[]},{"marriage_number":2,"spouse_id":"I00372","date_year":1875,"date_month":1,"date_day":19,"location_country":"United States","end_type":"death","end_year":1884,"children_ids":[]}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"George Pierpont","first_name":"George","last_name":"Pierpont","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778085093/georgepierpont-resized_w2hkzm.png","photo_notes":"Compiler's research collection."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM262","plot_notes":"Find a Grave memorial 67550601"},"narrative_blocks":[{"number":1,"category":"death","header":"Father drowned in Lake Erie when seventeen","body":"George's father Sherman Pierpont drowned in Lake Erie when George was seventeen — a sudden water-accident death that left him fatherless during his teen years. Five years later when George was twenty-two, his mother Sidney Humiston Pierpont also died. The compressed double parental loss within five years left him an orphaned young adult in mid-nineteenth-century Litchfield County Connecticut."},{"number":2,"category":"family","header":"Remarried one year after first wife's death","body":"George's first wife Caroline Eunice Beach died January 18, 1874. Exactly one year and one day later on January 19, 1875, George remarried Ellen Amelia Hazen. The compressed grief-and-remarriage cycle reflected mid-nineteenth-century social expectations that widowers would not be expected to maintain prolonged single status, particularly for men with household responsibilities."},{"number":3,"category":"family","header":"Born ten years after his only sister","body":"George was born May 21, 1819 in Litchfield County Connecticut when his father was thirty-six and ten years after his only sister Minerva. The wide sibling spacing made him in effect a near-only-child during his most formative early years, before the sudden father-death of 1836 left him to navigate adolescence and early adulthood without parental guidance."},{"number":4,"category":"family","header":"Born Litchfield 1819, died Plymouth CT 1884","body":"George Pierpont was born May 21, 1819 in Litchfield County Connecticut and died February 14, 1884 in Connecticut at age sixty-four. He is buried at West Cemetery in Plymouth, Litchfield County Connecticut. No children are documented from either of his two marriages."}],"slug":"george-pierpont-1819"}},"burialCemetery":{"id":"CEM263","primary_name":"Washington Cemetery On The Green","location":{"city":"Washington","county":"Litchfield","state":"Connecticut","country":"United States"},"find_a_grave_url":"https://www.findagrave.com/cemetery/1678194/washington-cemetery-on-the-green","hooker_connections":["I00372"],"notes":"Washington Cemetery On The Green in Washington Litchfield County CT. Resting place of Ellen Amelia Titus Pierpont (I00372, 1844-1926) — second wife of George Pierpont."},"institutionsById":{},"crossConnections":[]}