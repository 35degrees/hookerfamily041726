Nathaniel and Abigail Tuttle of New Haven"},"marriages":[{"marriage_number":1,"spouse_id":"H00459","end_type":"death_of_spouse","end_year":1799,"children_ids":["HD3142","HD3143","HD3144","HD3145"],"date_year":1780,"date_month":12,"date_day":4,"location_city":"New Haven","location_state":"Connecticut"},{"marriage_number":2,"spouse_id":"X02100","children_ids":["X02820"],"date_year":1799,"date_month":12,"date_day":2,"location_city":"Woodbridge","location_state":"Connecticut"}],"number_of_marriages":2,"tags":["revolutionary_war","military"],"sources":[{"short":"DAR Ancestor A131826"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"Continental Army veteran and DAR Patriot Ancestor","body":"Jotham Tuttle served as a Private in the American Revolution under Captain Stephen Goodyear and later with the 2nd Connecticut Regiment. He is documented as a Daughters of the American Revolution Patriot Ancestor (A131826), meaning his Revolutionary War service has been verified by the DAR. He married Kezia Munson in New Haven in 1780, four days after she turned 17.","number":1},{"number":2,"category":"family","header":"Remarried four months after his first wife's death","body":"Jotham Tuttle's first wife Kezia Munson died August 2, 1799 at age 36, leaving him with five children ranging from infancy to 17 years old. He married his second wife, Elizabeth Perkins, on December 2, 1799 — exactly four months and a day after Kezia's death. Quick widowhood remarriage was common in early American farming families with young children needing maternal care."}],"cross_connections":[],"bio":{"display_name":"Private Jotham Tuttle","first_name":"Jotham","last_name":"Tuttle","married_names":[],"title":"Private"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM313","plot_notes":"Center Street Cemetery, Wallingford CT"},"slug":"jotham-tuttle-1752"},"HD3142":{"id":"HD3142","is_placeholder":false,"gender":"male","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1781,"month":12,"day":28,"city":"Hamden","county":"New Haven County","state":"Connecticut","country":"United States"},"death":{"year":1844,"month":4,"day":21,"city":"Hamden","county":"New Haven County","state":"Connecticut","country":"United States"},"parents":{"father_id":"I00177","mother_id":"H00459"},"marriages":[{"marriage_number":1,"spouse_id":"I00603","location_state":"Connecticut","location_country":"United States","children_ids":["HD4125","HD4126","HD4127","HD4128","HD4129","HD4136"]}],"number_of_marriages":1,"tags":[],"sources":[{"short":"FindAGrave"}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Eli Tuttle","first_name":"Eli","last_name":"Tuttle","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Seven documented children with Thankful Asenath Perkins","body":"Eli Tuttle and his wife Thankful Asenath Perkins Tuttle had seven documented children between 1807 and the late 1820s. Five of the seven were Lucius (1807-1885 who stayed in Hamden), Leonard (1810-1875 Ohio migration), Lauren (1815-1860 two wives), Mehitable Tuttle Cooper (1819-1868 two husbands), and Lucy (died 1827). Two more — Louisa and Asahel — died young."},{"number":2,"category":"death","header":"Daughter Louisa died as an infant in 1822","body":"Eli and Thankful's daughter Louisa Tuttle was born in 1821 and died in 1822 — an infant death within her first year. The early death was one of three children Eli outlived: Louisa as infant; Lucy who died in 1827 as a young child; and Asahel by 1850 in his adulthood. The cumulative loss across both childhood and adult-child mortality was typical of nineteenth-century rural Connecticut family experience."},{"number":3,"category":"family","header":"Born and died in Hamden, Connecticut","body":"Eli Tuttle was born December 28, 1781 in Hamden, New Haven County Connecticut, son of Jotham Tuttle and Kezia Munson Tuttle. He died April 21, 1844 in Hamden at age sixty-two and is buried at Mount Carmel Burying Ground, Hamden. The lifelong-Hamden residence pattern was common among the Tuttle-Munson cluster of north New Haven County families."}],"burial":{"cemetery_id":"CEM312","plot_notes":"Mount Carmel Burying Ground, Hamden CT — alongside his mother Kezia Munson Tuttle"},"slug":"eli-tuttle-1781"},"I00603":{"id":"I00603","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Thankful","middle_name":"Asenath","last_name":"Tuttle","maiden_name":"Perkins","married_names":[],"gender":"female","display_name":"Thankful Asenath Perkins Tuttle"},"birth":{"year":1783,"month":1,"day":16,"city":"Woodbridge","county":"New Haven County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1861,"country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3142","location_state":"Connecticut","location_country":"United States","children_ids":["HD4125","HD4126","HD4127","HD4128","HD4129","HD4136"]}],"education":[],"career":[],