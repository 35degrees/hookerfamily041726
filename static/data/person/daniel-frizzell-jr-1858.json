"educator","arkansas_migration"],"research_tags":[],"sources":[{"label":"FindAGrave — Louise Matilda 'Lula' Perrin Frizzell","url":"https://www.findagrave.com/memorial/126875942/louise_matilda-frizzell"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Father remarried nine days after her wedding","body":"Louise married Dr. Daniel Harrison Frizzell on October 8, 1889 at Camden Arkansas. Just nine days later, her widowed father William Alexander Perrin remarried — to Sarah Bullard at Thornton Arkansas. The compressed nine-day father-and-daughter wedding sequence in October 1889 marked the end of their three-year shared widowhood-and-grief after the mother's 1886 Waxahachie Texas death."},{"number":2,"category":"death","header":"Christmas Eve 1925 pneumonia death at sixty-three","body":"Louise died of pneumonia on Christmas Eve, December 24, 1925 at Banks Arkansas at age sixty-three. She is buried at Williams Cemetery in Warren Arkansas. She was survived by her husband, three sons, and two daughters per the Arkansas Gazette obituary published December 27, 1925."},{"number":3,"category":"career","header":"Arkansas schoolteacher across multiple county towns","body":"Louise was a schoolteacher in addition to mothering five children. The Frizzell family moved across Arkansas towns — Princeton and Bucksnort in Dallas County, then Kingsland in Cleveland County, then finally Banks in Bradley County. Five children all named with Hooker-Talcott family-tradition names: Clara Amanda, Francis Niven, Lillie Irene, Garland, and James Austin."},{"number":4,"category":"family","header":"Born Amite LA 1862, eldest of Perrin daughters","body":"Louise Matilda 'Lula' Perrin was born April 19, 1862 in Amite, Tangipahoa Parish Louisiana — eldest daughter of William Alexander Perrin and Clarentine 'Clara' Niven Perrin. After her mother's 1886 death in Waxahachie Texas, Louise and her widowed father moved east to Thornton in Calhoun County Arkansas, where she met her future husband Dr. Daniel Harrison Frizzell."}],"cross_connections":[],"naming_inspiration":[{"name_element":"Louise","description":"Named after her mother's sister Louise Mathilde Niven (not in tree)."}],"education":[],"career":[{"role":"Schoolteacher","organization":"Self / Arkansas","location":"Arkansas","notes":"Schoolteacher per FindAGrave biography."}],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"louise-frizzell-1862"},"TD0179":{"id":"TD0179","former_ids":[],"is_placeholder":true,"has_descendants_documented":false,"bio":{"display_name":"Clara Amanda Alvira Frizzell Thompson","first_name":"Clara","middle_name":"Amanda Alvira","last_name":"Thompson","maiden_name":"Frizzell","married_names":["Thompson"],"gender":"female"},"birth":{"year":1891,"country":"United States"},"baptism":{},"death":{"year":1983,"country":"United States"},"residence":{},"burial":{},"gender":"female","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":10,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_id":"X02391","mother_id":"TD0174"},"marriages":[],"tags":["not_yet_fully_entered","arkansas_migration"],"research_tags":[],"sources":[],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"naming_inspiration":[{"name_element":"Clara","inspired_by_id":"X02390","description":"First name 'Clara' honors her maternal grandmother Clarentine 'Clara' Niven Perrin who died 1886 Texas before Clara Frizzell's 1891 birth."}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"clara-amand