"United States"},"residence":{},"burial":{"cemetery_id":"CEM301"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4004","date_year":1868,"end_type":"death","end_year":1914,"children_ids":["HD4010","HD4011","HD4012","HD4013"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"FamilySearch L5Z7-64F","url":"https://ancestors.familysearch.org/en/tree/person/L5Z7-64F"},{"label":"FindAGrave 166489426","url":"https://www.findagrave.com/memorial/166489426/emelia_a-mansfield"}],"research_sources":[],"documents":[],"slug":"emelia-moore-1837"},"HD3998":{"id":"HD3998","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Isaac","last_name":"Mansfield","married_names":[],"gender":"male","display_name":"Isaac Mansfield"},"birth":{"year":1815,"month":11,"day":26,"city":"Hamden","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1895,"month":4,"day":6,"city":"Morris","state":"New York","country":"United States"},"residence":{"city":"Morris","state":"New York","country":"United States"},"burial":{"cemetery_id":"CEM300"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00546","mother_id":"H01180"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00547","date_year":1842,"date_month":5,"date_day":15,"location_state":"New York","location_country":"United States","end_type":"death","end_year":1895,"children_ids":["HD4004","HD4005","HD4006","HD4007","HD4008","HD4009"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Isaac","inspired_by_id":"H00454","description":"First name 'Isaac' honors his maternal grandfather Captain Isaac Clark Stiles (1767-1834). The Stiles-family Isaac name carried forward through his mother Laura Stiles Mansfield's line."}],"artworks":[],"tags":["new_york_migration","politician"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Local-office portfolio in Morris, Otsego County NY","body":"Isaac Mansfield held a layered local-government portfolio in Morris, Otsego County New York: town assessor, supervisor, and Justice of the Peace, plus service on the Board of Education of Morris Union School. The combination — fiscal, executive, judicial, and educational — was characteristic of nineteenth-century Upstate New York village civic leadership where leading citizens rotated through every available board."},{"number":2,"category":"politics","header":"Whig who switched to the Republican Party","body":"Isaac Mansfield was a Whig who later switched to the Republican Party — following the typical mid-nineteenth-century anti-slavery realignment trajectory of Northern Whigs after the 1854 party collapse. The realignment placed him among the antislavery majority of his Otsego County community in the years before and during the Civil War."},{"number":3,"category":"family","header":"Connecticut to New York migration before 1842","body":"Isaac was born November 26, 1815 in Hamden, New Haven County Connecticut, but had migrated to New York State before his May 15, 1842 marriage to Maria Hitchcock. He died April 6, 1895 in Morris, Otsego County New York at age seventy-nine, buried at Harmony Cemetery. The Connecticut-to-Upstate-New-York migration was part of the broader 1830s-40s wave that resettled Connecticut Yankees across Otsego and Chenango Counties."},{"number":4,"category":"family","header":"Named for maternal grandfather Captain Isaac Stiles","body":"Isaac was named for his maternal grandfather Captain Isaac Clark Stiles, carrying the Stiles-family Isaac name forward through his mother Laura Stiles Mansfield's line. He had six children with Maria Hitchcock — including Romaine Stiles Mansfield (Episcopal clergyman) whose son Archibald Romaine Mansfield became the founder of the Seamen's Church Institute."}],"quotes":[],"sources":[{"label":"FamilySearch person KDQ9-D71","url":"https://ancestors.familysearch.org/en/tree/person/KDQ9-D71"},{"label":"FindAGrave Memorial 52492289 (Harmony Cemetery, Morris NY)","url":"https://www.findagrave.com/memorial/52492289/isaac-mansfield"}],"research_sources":[],"documents":[],"slug":"isaac-mansfield-1815"},"I00547":{"id":"I00547","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Maria","last_name":"Mansfield","maiden_name":"Hitchcock","married_names":["Mansfield"],"gender":"female","display_name":"Maria Hitchcock Mansfield"},"birth":{"year":1819,"month":10,"day":4},"baptism":{},"death":{"year":1901,"month":1,"day":2,"state":"New York","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM300"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3998","date_year":1842,"date_month":5,"date_day":15,"location_state":"New York","location_country":"United States","end_type":"death_of_spouse","end_year":1895,"children_ids":["HD4004","HD4005","HD4006","HD4007","HD4008","HD4009"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"FamilySearch L5Z7-VHS","url":"https://ancestors.familysearch.org/en/tree/person/L5Z7-VHS"},{"label":"FindAGrave 52492291","url":"https://www.findagrave.com/memorial/52492291/maria-mansfield"}],"research_sources":[],"documents":[],"slug":"maria-hitchcock-1819"}},"burialCemetery":{"id":"CEM301","name":"Moravian Cemetery","city":"New Dorp","county":"Richmond","state":"New York","country":"United States","findagrave_id":"65299","primary_url":"https://www.findagrave.com/cemetery/65299/moravian-cemetery","hooker_connections":["HD4004","HD4010","I00548","I00550"],"notes":"Cemetery in New Dorp, Staten Island NY. Burial site of Rev. Romaine Stiles Mansfield (HD4004, clergyman) + wife Emelia A Moore (I00548) + son Archibald Romaine Mansfield (HD4010, NOTABLE — Seamen's Church Institute founder) + Archibald's wife Ella Louise Huntington (I00550)."},"institutionsById":{"INST101":{"id":"INST101","primary_name":"Seamen's Church Institute of New York and New Jersey","name":"Seamen's Church Institute of New York and New Jersey","alt_names":["Seamen's Church Institute","Seaman's Church Institute"],"type":"religious_charitable","founding_year":1834,"location":{"city":"New York","state":"New York","country":"United States"},"primary_url":"https://en.wikipedia.org/wiki/Seamen%27s_Church_Institute_of_New_York_and_New_Jersey","primary_persons":[],"hooker_connected_people":["HD4010"],"person_ids":[],"related_institutions":[],"related_landmarks":[],"tags":[],"sources":[],"notes":"Episcopal-affiliated mission serving merchant mariners. Rev. Archibald Romaine Mansfield (HD4010, NOTABLE) served as first Superintendent for 38 years (1895-1934), helping establish the institute at 25 South Street NYC alongside Edmund Lincoln Baylies, and creating MEDICO (radio medical advice for ships)."}},"crossConnections":[{"type":"family_connection","related_id":"HD4021","link_text":"George H. Mansfield","display_label":"First cousins via Isaac Mansfield's sons Charles and Romaine","slug":"george-mansfield-1894"},{"type":"family_connection","related_id":"HD4028","link_text":"Lea Davison","display_label":"Both notable Mansfields via Isaac Mansfield common ancestor","slug":"lea-davison-1983"}]}