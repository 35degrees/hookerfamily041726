ons":[],"bio":{"display_name":"Col. Samuel Andrews Russell","first_name":"Samuel","last_name":"Russell","title":"Colonel","middle_name":"Andrews","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"plot_notes":"Forest Lawn Cemetery, Buffalo NY"},"narrative_blocks":[{"number":1,"category":"career","header":"Postmaster of Buffalo, appointed April 1831","body":"Appointed Postmaster of Buffalo NY in April 1831 by President Andrew Jackson; held the office until his death on 2 July 1834. The Yale biographical sketch summarized: 'loved, esteemed, and respected by all who knew him.'"},{"number":2,"category":"politics","header":"NY Constitutional Convention 1821, Elector 1824","body":"Served as a delegate to the New York State Constitutional Convention of 1821 — which revised the state constitution to broaden suffrage and reorganize the judiciary. Selected as a Presidential Elector for New York in the 1824 election."},{"number":3,"category":"career","header":"Niagara County Judge from April 1817","body":"First appointed Judge in Niagara County NY in April 1817 — shortly after his removal from New York City to Buffalo. Held judicial office in western New York's frontier period when Niagara County still encompassed much of the territory later subdivided into Erie and other counties."},{"number":4,"category":"marriage","header":"Married two of the three Woodward sisters","body":"After his first wife Lucy Munson died at 29 in 1785 leaving a daughter, he married Sarah Woodward of New Haven in November 1790. She died suddenly in New York August 1807; around 1809 he then married her sister Susan Woodward, who died September 1819 in her 63rd year."},{"number":5,"category":"military","header":"Revolutionary War private under Capt. Peter Vail","body":"Served as a private in the Connecticut militia under Captain Peter Vail and Colonel Canfield during the Revolutionary War. SAR Patriot #P-283245 + DAR #A098524. His Yale studies followed wartime service and graduation around 1779 — he remained at Yale as graduate student and Butler until May 1783."}],"slug":"samuel-russell-1759"},"X00414":{"id":"X00414","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"death":{"year":1807,"month":8,"day":8,"city":"New York","state":"New York","country":"United States"},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00844","date_year":1790,"children_ids":["HD1324","HD1325","HD1326","HD1327","HD6128"],"marriage_year":1790}],"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1763,"country":"United States"},"cross_connections":[],"bio":{"display_name":"Sarah Woodward","first_name":"Sarah","maiden_name":"Woodward","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-woodward-1763"},"H00358":{"id":"H00358","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1725,"month":7,"day":23,"city":"Middletown","state":"Connecticut"},"parents":{"father_id":"I00144","mother_id":"H00118"},"tags":["minister","yale_graduate"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 358"}],"death":{"year":1775,"month":4,"day":20,"city":"Windsor","state":"Connecticut"},"church_roles":[{"role":"Pastor","location":"First Church of Windsor","dates":"1751-1775 (ordained Jul 24, 1754)"}],"marriages":[{"spouse_id":"X00411","children_ids":["H00843","H00844","H00845","H00846"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1765,"date_year":1752},{"spouse_id":"X00412","children_ids":["H00847","X00411"],"marriage_number":2,"date_year":1770,"date_month":1,"date_day":18}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"education":[{"notes":"Berkeley Scholar; tutor Yale 1749-1750","school_name":"Yale College","graduation_year":1745,"institution_id":"INST022"}],"bio":{"display_name":"William Russell","first_name":"William","last_name":"Russell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1745"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"religion","header":"Yale 1745 tutor, then twenty-four years at Windsor","body":"He graduated Yale in 1745, served as Berkeley scholar and Yale tutor 1749-1750, and was ordained pastor of the First Church of Windsor Connecticut in 1754. He served Windsor for twenty-four years until his death in 1775."},{"number":2,"category":"religion","header":"Resolved a contentious meetinghouse debate at Windsor","body":"He oversaw a contentious debate at Windsor about building the new meetinghouse and found resolution. His estate at his 1775 death was inventoried at £994 including 130 books — a substantial library for a colonial pastor."},{"number":3,"category":"family","header":"Lost his first wife after thirteen years","body":"His first wife Abigail Andrews of Milford died June 13, 1765 after thirteen years of marriage. He remarried Abigail Newberry of Wintonbury in 1770, five years before his own death."}],"slug":"william-russell-1725"},"X00411":{"id"