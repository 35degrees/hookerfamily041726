classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4974","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","children_ids":["HD4976","HD4977"]}],"education":[],"career":[{"role":"Executive","organization":"Carter Carburetor (St. Louis)","notes":"Executive position at Carter Carburetor in St. Louis. Restored the family 1688 East Haddam farmhouse (Bragdon side)."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"dudley-bragdon-jr-1906"},"HD4976":{"id":"HD4976","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Margaret","last_name":"Shepley","maiden_name":"Bragdon","married_names":["Meyer","Shepley"],"nickname":"Peggy","gender":"female","display_name":"Margaret \"Peggy\" Bragdon Shepley"},"gender":"female","birth":{"year":1934,"month":11,"day":24,"city":"Darlington","county":"Harford","state":"Maryland","country":"United States"},"baptism":{},"death":{"year":2019,"month":7,"day":25},"residence":{},"burial":{"plot_notes":"Christ Church Cathedral, Saint Louis, City of St. Louis MO. FindAGrave Memorial #201729277."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":11,"include_in_path_calculation":true,"descent_paths_to_thomas":2,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I01246","mother_id":"HD4974"},"number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"I01248","date_year":1954,"location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"divorce","end_year":1969,"children_ids":[]},{"marriage_number":2,"spouse_id":"I01249","date_year":1970,"location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1991,"children_ids":[]}],"education":[{"school_name":"Wheaton College","dates":"~1953-1954","type":"undergraduate","notes":"Attended Wheaton College at her father's insistence over Rhode Island School of Design (her preferred choice); transferred to Washington University."},{"school_name":"Washington University in St. Louis","dates":"1954-","type":"undergraduate","notes":"Transferred from Wheaton."}],"career":[{"role":"Television host","organization":"St. Louis television (local)","notes":"Created and hosted a review of St. Louis attractions on local television."},{"role":"Writer","organization":"St. Louis magazine","notes":"Wrote for St. Louis magazine after the television show."},{"role":"Residential real estate agent","start_year":1970,"notes":"Encouraged by her second husband Ethan Shepley Jr. to enter real estate; known for visualizing where clients should live and seeing a home's potential."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Slept under Kihn's Alice in Wonderland murals","body":"As a child she lived in her grandmother's 1688 wood-frame farmhouse in East Haddam, Connecticut, while her father restored the home and installed plumbing and central heat. The walls of her bedroom were painted with Alice in Wonderland murals by her uncle W. Langdon Kihn — the same painter who illustrated for National Geographic, where the murals were later profiled."},{"number":2,"category":"family","header":"Survived the 1938 New England hurricane","body":"Her family survived the surprise 1938 hurricane that devastated the New England coast — she was three years old. Soon afterward the Bragdon family moved from Connecticut to St. Louis, where her paternal grandfather was a founding executive at D'Arcy Advertising and her father took an executive position at Carter Carburetor."},{"number":3,"category":"career","header":"Wheaton over Rhode Island, then St. Louis television","body":"She dreamed of Rhode Island School of Design but her father insisted on the more practical Wheaton College, which failed to inspire her. She transferred to Washington University in St. Louis and married Dr. John Meyer in 1954. For a time she hosted a local television review of St. Louis attractions, then wrote for St. Louis magazine."},{"number":4,"category":"marriage","header":"Two marriages — second a real-estate partnership","body":"Her first marriage to Dr. John Meyer produced three children but ended in divorce in 1969. In 1970 she married Ethan Allen Hitchcock Shepley Jr., a B-17G radio operator with thirty-four missions over Germany, who encouraged her sharp eye into a residential real estate career. Their twenty-one years together until his death in 1991 were marked by affection, joy, and lots of laughter."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"margaret-shepley-1934"},"I01248":{"id":"I01248","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"title":"Dr.","first_name":"John","last_name":"Meyer","married_names":[],"gender":"male","display_name":"Dr. John Meyer"},"gender":"male","birth":{},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4976","date_year":1954,"location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"divorce","end_year":1969,"children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"john-meyer"},"I01249":{"id":"I01249","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Ethan","middle_name":"Allen Hitchcock","last_name":"Shepley","suffix":"Jr.","married_names":[],"gender":"male","display_name":"Ethan Allen Hitchcock Shepley Jr."},"gender":"male","birth":{"year":1923,"month":3,"day":5,"city":"St. Louis","county":"City of St. Louis","state":"Missouri","country":"United States"},"baptism":{},"death":{"year":1991,"month":12,"day":15,"city":"St. Louis","county":"City of St. Louis","state":"Missouri","country":"United States"},"residence":{},"burial":{"plot_notes":"Christ Church Cathedral, Saint Louis MO. FindAGrave Memorial #180180055."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4976","date_year":1970,"location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1991,"children_ids":[]}],"education":[],"career":[],"military_service":[{"branch":"8th United States Army Air Force","rank":"Technical Sergeant (TSGT)","war":"World War II","notes":"334th Bomb Squadron, 95th Bomb Group (Heavy), 8th AAF. Radio Operator on B-17G Flying Fortress. Completed 34 combat missions over Germany — beyond the standard 25-mission tour, completing a full extended tour. The 95th Bomb Group was based at Horham, Suffolk, England."}],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["wwii","air_force"],"research_tags":[],"cross_connections":[{"type":"military","related_id":"HD4979","display_label":"Army Air Corps Meteorology Division, Brown 1945","link_text":"Wesley William Yando Jr.","notes":"Two WWII Army Air Corps men in the same Butler-Bragdon family circle. Ethan Shepley Jr. flew thirty-four combat missions over Germany as B-17G radio operator with the 95th Bomb Group (Heavy), 8th AAF. His wife Peggy Bragdon Shepley's first cousin Wesley W. Yando Jr. served in the Army Air Corps Meteorology Division — the discipline that fed weather forecasts to bomber crews like Shepley's. They never met as fellow servicemen but the family connection ties their war service together."}],"narrative_blocks":[{"number":1,"category":"military","header":"Thirty-four B-17G missions as radio operator","body":"He served as a Technical Sergeant in the 334th Bomb Squadron of the 95th Bomb Group (Heavy), 8th Army Air Force, based at Horham in Suffolk, England. As radio operator on a B-17G Flying Fortress he completed thirty-four combat missions over Germany — beyond the standard twenty-five-mission tour. The 95th was the only USAAF group to receive three Distinguished Unit Citations."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"ethan-shepley-jr-1923"},"HD4977":{"id":"HD4977","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Dudley","middle_name":"Acton","last_name":"Bragdon","suffix":"III","married_names":[],"gender":"male","display_name":"Dudley Acton Bragdon III"},"gender":"male","birth":{"year":1936,"month":10,"day":31,"city":"Middl