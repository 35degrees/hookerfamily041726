ame into Connecticut law."},{"number":2,"category":"family","header":"He once left a day’s clams behind","body":"A cousin’s fond letter recalled Gaylord spending a whole day gathering clams at Long Pond, only to drive home and realize — on seeing the water — that he had left every clam behind. It was offered as a gentle emblem of how memory fades with age."}],"slug":"gaylord-newton-1804"},"I01783":{"id":"I01783","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":null},"bio":{"display_name":"Nancy Maria Merwin Newton","first_name":"Nancy Maria","last_name":"Newton","married_names":[],"maiden_name":"Merwin","gender":"female"},"birth":{"year":1810,"date_precision":"exact","month":3,"day":29,"city":"Durham","state":"Connecticut","country":"United States"},"death":{"year":1857,"date_precision":"exact","month":2,"day":9,"city":"Durham","state":"Connecticut","country":"United States"},"parents":{"father_id":null,"mother_id":null},"marriages":[{"spouse_id":"HD6445","marriage_number":1,"date_year":1838,"children_ids":["HD6447","HD6448","HD6449"]}],"tags":[],"burial":{"cemetery_id":"CEM569"},"slug":"nancy-maria-merwin-1810"},"I01784":{"id":"I01784","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":null},"bio":{"display_name":"Harriet Lane Newton","first_name":"Harriet","last_name":"Newton","married_names":[],"maiden_name":"Lane"},"birth":{"year":1812,"date_precision":"exact","month":1,"day":12},"death":{"year":1897,"date_precision":"exact","month":10,"day":23},"parents":{"father_id":null,"mother_id":null},"marriages":[{"spouse_id":"HD6445","marriage_number":2,"children_ids":[]}],"tags":[],"burial":{"cemetery_id":"CEM569"},"slug":"harriet-lane-1812"},"HD6447":{"id":"HD6447","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":8},"bio":{"display_name":"Ellen Maria 