57,"end_year":1660},{"role":"Pastor","organization":"First Church of Hartford","start_year":1663,"end_year":1669},{"role":"Pastor","organization":"Second Church of Hartford","start_year":1670,"end_year":1689}],"narrative_blocks":[{"number":1,"category":"religion","header":"His church split; he founded another","body":"The half-way covenant fight broke Hartford’s First Church in 1669, and thirty-two members walked out. Whiting petitioned the Assembly “for a distinct walking in Congregational Church Order,” won, and was ordained pastor of the new Second Church — which celebrated its 350th anniversary in 2020."},{"number":2,"category":"family","header":"His bride’s father sailed the phantom ship","body":"His second wife Phebe was the daughter of Thomas Gregson of New Haven, lost at sea in 1646 aboard the famous “phantom ship.” Phebe outlived Whiting by forty-one years, remarrying Rev. John Russell of Hadley."}],"slug":"john-whiting-1635"},"X00084":{"id":"X00084","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"marriages":[{"spouse_id":"X00083","children_ids":["X00081"],"marriage_number":1},{"spouse_id":"U00014","marriage_number":2,"date_year":1692,"end_type":"death_of_spouse","children_ids":[]}],"sources":[{"short":"Russell Genealogy","full":"Phebe (Grigson) Russell: third wife of Rev. John Russell, widow of Rev. John Whiting; d. 19 Sep 1730, New Haven.","type":"genealogy"}],"gender":"female","tags":[],"number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1643,"city":"New Haven","state":"Connecticut"},"death":{"year":1730,"month":9,"day":19,"city":"New Haven","state":"Connecticut"},"cross_connections":[],"bio":{"display_name":"Phebe Gregson Whiting","first_name":"Phebe","last_name":"Whiting","married_names":["Whiting","Russell"],"maiden_name":"Gregson"},"residence