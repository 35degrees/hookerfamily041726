nary War.'"}],"narrative_blocks":[{"number":1,"category":"military","header":"Quartermaster's Department veteran; lived ninety years","body":"Gilbert Hooker served in the Quartermaster's Department during the Revolutionary War, then settled at Stillwater, New York with his wife Rebecca Andrews where their children were born, later moving the family to Clyde, New York — and lived to see all of it: the nation he helped supply through the Revolution, the expansion across New York State, the rise of his son James Harvey to wealthy merchant at Troy. He died January 9, 1849 at approximately ninety years of age, having outlived his wife Rebecca by eight years — born in Woodbury, Connecticut in 1758, dying when Abraham Lincoln was still an Illinois congressman and the gold rush was just beginning in California, his life spanning the entire arc from Puritan New England colony to young republic."}],"burial":{"cemetery_id":"CEM504","plot_notes":"Maple Grove Cemetery Clyde Wayne County NY per FA"},"slug":"gilbert-hooker-1758"},"I01023":{"id":"I01023","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Rebecca","last_name":"Hooker","maiden_name":"Andrews","married_names":["Hooker"],"gender":"female","display_name":"Rebecca Hooker"},"birth":{"year":1769,"country":"United States"},"baptism":{},"death":{"year":1840,"month":12,"day":18,"city":"Clyde","state":"New York","country":"United States"},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00487","location_country":"United States","end_type":"death","end_year":1840,"children_ids":[