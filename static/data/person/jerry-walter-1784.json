cent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00365","mother_id":"X00455"},"tags":[],"sources":[{"short":"Edward Hooker 1909","entry":"868"},{"short":"Pierpont genealogy"}],"birth":{"year":1758,"month":2,"day":22,"city":"North Haven","state":"Connecticut"},"death":{"year":1806},"cross_connections":[],"gender":"female","marriages":[{"spouse_id":"X01651","children_ids":["HD5098","HD5099","HD5100","HD5101","HD5102"],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Theodosia Pierpont Walter","first_name":"Theodosia","last_name":"Walter","maiden_name":"Pierpont","married_names":["Walter"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"death","header":"Daughter Louisa died thirty days after marriage","body":"Theodosia's daughter Louisa Walter married Timothy Bishop on April 3, 1800 — and died on May 3, 1800, just thirty days after the marriage. Louisa was twenty. The compressed marriage-and-death cycle within a single calendar month captured the period's vulnerability to acute disease across all socioeconomic groups, even within the Pierpont-Walter household at New Haven."},{"number":2,"category":"family","header":"Great-granddaughter named Theodocia Pierpont in her honor","body":"A generation after Theodosia's 1806 death, her son William Walter's daughter named her own daughter Theodocia Pierpont Walter Hayden (born August 20, 1817) — honoring the Pierpont great-grandmother through both first name and middle name. The naming carried the Theodosia-and-Pierpont identity forward across three generations of women in the family."},{"number":3,"category":"death","header":"Grandson William Walter Hayden drowned in childhood","body":"Theodosia's great-grandson William Walter Hayden — son of Theodocia Pierpont Walter Hayden — drowned on August 2, 1850 in Windsor Connecticut at age twelve. The cascading family losses — daughter at twenty in 1800, great-granddaughter at twenty in 1838, great-great-grandson at twelve in 1850 — touched four consecutive generations of the Walter-Hayden line."},{"number":4,"category":"family","header":"Born North Haven 1758, died New Haven 1806","body":"Theodosia Pierpont was born February 22, 1758 in North Haven Connecticut and died July 15, 1806 in New Haven Connecticut at age forty-eight. She married William Jay Walter on November 17, 1777 in North East Village, New Haven — he survived her by eighteen years, dying April 19, 1824. Her five documented children were Joel, Louisa, Lovina, Jerry, and William Jr."}],"slug":"theodosia-walter-1758"},"H00365":{"id":"H00365","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD0416","mother_id":"I00145"},"tags":["revolutionary_war","episcopal","extraordinary_longevity"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 365"}],"birth":{"year":1729,"month":4,"day":16,"city":"North Haven","state":"Connecticut"},"death":{"year":1820,"month":12,"day":24,"city":"North Haven","state":"Connecticut"},"marriages":[{"spouse_id":"X00455","children_ids":["H00865","H00866","H00867","H00868","H00869","H00870","H00871","HD1427","HD1428","HD1429"],"marriage_number":1,"date_year":1751,"date_month":11,"date_day":5}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Samuel Pierpont","first_name":"Samuel","last_name":"Pierpont","married_names":[],"bio_blurb":"Brick maker, Episcopal founder, warden fifty years"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"religion","header":"Founded Royalist Episcopal church at North Haven","body":"He was a founder and the first senior warden of St. John's Church of England in North Haven, elected at age thirty-two in 1761. The rector and majority of members were Royalists during the Revolution but accepted the new government afterward."},{"number":2,"category":"religion","header":"Senior warden for fifty years until death","body":"He continued as senior warden of St. John's, with few exceptions, for fifty years — until his death in 1820 at age ninety-one. He outlived his wife Elizabeth Frost by sixteen years."},{"number":3,"category":"career","header":"Brick maker who served the Revolution","body":"His occupation was brick maker in North Haven. Despite his Episcopal church's Royalist majority, he served in the Revolution — a fact recorded on his gravestone in the Old Cemetery."}],"burial":{"cemetery_id":"CEM307"},"slug":"samuel-pierpont-1729"},"X00455":{"id":"X00455","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1728,"month":3,"day":3,"city":"New Haven","state":"Connecticut"},"death":{"year":1804,"month":9,"day":20,"city":"New Haven","state":"Connecticut"},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00365","children_ids":["H00865","H00866","H00867","H00868","H00869","H00870","H00871","HD1427","HD1428","HD1429"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Frost","first_name":"Elizabeth","maiden_name":"Frost","marri