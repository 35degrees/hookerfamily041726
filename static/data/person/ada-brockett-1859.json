:[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Wrote for Hearth and Home and agricultural papers","body":"William Bentley Brockett was a writer for HEARTH AND HOME and other agricultural papers in New York City through the mid-nineteenth century — the era when the agricultural press shaped both urban-elite ideas of country gentility and actual farming practice. Around 1880 he 'removed to Orient, Long Island' himself and 'engaged in gardening' — moving from writing about agriculture to practicing it. He died at Yaphank Long Island where his only surviving son Clarence lived."},{"number":2,"category":"family","header":"Three of four children died young in NYC","body":"William and Helen's four children: Helen Josephine died in New York City at age five in 1854, Emma B. died there at eight days old in 1854, Ada Isabella died there at eleven months old in 1860, and only Clarence William born 1856 survived into adulthood. The three NYC infant-and-child deaths spanned the same six-year window that saw waves of urban epidemic disease sweep through dense Manhattan neighborhoods. Cholera, scarlet fever, and diphtheria were the era's leading causes of child mortality in New York."}],"slug":"william-brockett-1817"},"I01291":{"id":"I01291","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{},"tags":[],"sources":[],"marriages":[{"marriage_number":1,"spouse_id":"HD5088","date_year":1846,"date_month":10,"date_day":17,"children_ids":["HD5090","HD5091","HD5092","HD5093"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{"year":1888},"cross_connections":[],"bio":{"display_name":"Helen Lovida Brockett","first_name":"Helen","last_name":"Brockett","maiden_name":"Brewer","middle_name":"Lovida","married_names":["Brockett"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"helen-brewer"},"HD5085":{"id":"HD5085","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"generation_from_thomas":7,"is_easter_egg":false},"parents":{"father_id":"HD1527","mother_id":"X00492"},"tags":["army","deacon","politician","war_of_1812"],"sources":[],"marriages":[{"marriage_number":1,"spouse_id":"I01290","children_ids":["HD5086","HD5087","HD5088","HD5089"],"end_type":"death_of_spouse","end_year":1857}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1785,"month":5,"day":28,"state":"Connecticut","country":"United States"},"death":{"year":1850},"cross_connections":[],"bio":{"display_name":"Jesse Brockett","first_name":"Jesse","last_name":"Brockett","married_names":[],"gender":"male"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"War of 1812","war_id":"WAR003","side":"United States","rank":"Lieutenant 1812, Captain 1815","units":["Connecticut militia"],"role":"Connecticut militia officer; Lieutenant 1812 (war year) and Captain 1815 (postwar promotion)."}],"burial":{"place":"North Haven","state":"Connecticut"},"narrative_blocks":[{"number":1,"category":"religion","header":"Baptized with brother Pierpont in 1810","body":"In 1810 Baptist preacher Rev. Joshua Bradley came to North Haven and drew crowds — among those converted were Jesse Brockett and his younger brother Pierpont, both baptized together and forming the nucleus of the new North Haven Baptist Church. Pierpont went on to forty-one years in the Baptist ministry; Jesse remained a layman but rose to deacon of the same North Haven church. The shared conversion shaped the next generation: Pierpont's son Edward Judson became chairman of the American Baptist Home Mission Society."},{"number":2,"category":"military","header":"War of 1812 lieutenant, postwar Connecticut militia captain","body":"Jesse Brockett served as Lieutenant in 1812 at the outbreak of the War of 1812, then was promoted to Captain in 1815 in the postwar reorganization of the Connecticut militia. Like his younger brother Pierpont — who also served in the War of 1812 under Commander Abraham Hubbard at Groton and New London — Jesse answered the wartime call along Connecticut's vulnerable Long Island Sound coastline."},{"number":3,"category":"politics","header":"Connecticut General Assembly across two decades","body":"Jesse Brockett served in the Connecticut General Assembly in 1829 and 1830, then returned a decade later for the 1839 session. He had also served for many years as Justice of the Peace in North Haven. The political career layered on his deacon role at the Baptist Church and his militia captaincy — a complete profile of the local-leadership Connecticut churchman-farmer of the early Republic."}],"slug":"jesse-brockett-1785"},"I01290":{"id":"I01290","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_research_notes":"Medad Taintor of Northfield CT. Not built per Jalapeño rule.","mother_research_notes":"Anna Linsley Taintor of Northfield CT. Not built per Jalapeño rule."},"tags":[],"sources":[],"marriages":[{"marriage_number":1,"spouse_id":"HD5085","children_ids":["HD5086","HD5087","HD5088","HD5089"],"end_type":"death_of_spouse","end_year":1850}],"number_of_marriages":1,"notable":{"is_nota