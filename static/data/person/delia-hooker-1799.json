041","mother_id":"X00042"},"marriages":[{"spouse_id":"H00526","children_ids":["H01392","H01393","H01394","H01395","H01396","H01397","H01398"],"marriage_number":1,"date_year":1789,"date_month":5,"date_day":6}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 526"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Abigail Gay Hooker","first_name":"Abigail","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Gay"},"residence":{"city":"Hinsdale","county":"Cheshire","state":"New Hampshire","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[{"landmark_id":"LM106","landmark_blurb":"Born and raised on her father Rev. Bunker Gay's homestead; her 1789 marriage to Seth Hooker brought him onto the farm."}],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM454"},"slug":"abigail-gay-1764"},"H00264":{"id":"H00264","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"compiler_ancestor":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1729,"month":3,"day":19,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1777,"month":2,"day":6,"city":"Northampton","county":"Hampshire","state":"Massachusetts","country":"United States","cause":"smallpox"},"parents":{"father_id":"H00098","mother_id":"I00041"},"tags":["compiler_ancestor","yale_graduate","clergy","minister","epidemic_death"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 264"}],"marriages":[{"spouse_id":"I00043","children_ids":["H00524","H00525","H00526","H00527","H00528","H00529","H00530","H00531","H00532"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1777,"date_year":1755,"date_month":12,"date_day":10,"location_country":"United States"}],"compiler_ancestor":true,"ministry_positions":[{"role":"Minister","location":"Northampton, Massachusetts","dates":"1753-1777","duration_years":24,"notes":"Ordained Dec 5, 1753; settled there 24 years until death by smallpox"}],"ordination":{"date":{"year":1753,"month":12,"day":5},"location":"Northampton, Massachusetts"},"primary_residence":{"city":"Northampton","state":"Massachusetts","notes":"Minister here 24 years 1753-1777. Yale 1751, ordained Dec 5, 1753."},"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"religion","header":"Took Jonathan Edwards' Northampton pulpit, died of smallpox","body":"Ordained in 1753, he became pastor at Northampton, Massachusetts — the church where Jonathan Edwards had preached until his dismissal in 1750. He held that pulpit for nearly 25 years, dying of smallpox on February 6, 1777, in his 48th year. His was the most prominent pastoral appointment held by any Hooker descendant of his generation."},{"number":2,"category":"family","header":"His wife's father, Colonel Worthington, named Worthington Parish","body":"He married Sarah Worthington, daughter of Colonel Worthington of Springfield, Massachusetts — the man who gave his name to Worthington Parish in Berlin, Connecticut, the parish where the Hart and Hooker families had long been prominent. The marriage connected the Hooker line to one of western Massachusetts's most distinguished families."},{"number":1,"category":"death","header":"Smallpox took the Northampton pastor at forty-seven","body":"He served as pastor of the Northampton MA Congregational Church from 1753 until smallpox killed him in February 1777 at forty-seven. His daughter Sarah Hooker married the Northampton lawyer Caleb Strong nine months later — passing the Hooker name into the family of a future Massachusetts Governor and U.S. Senator."}],"cross_connections":[{"type":"civic_connection","related_id":"H00379","display_label":"Edwards's daughter refused his pulpit and her chair sat in the vestibule.","link_text":"Mary Edwards Dwight"}],"education":[{"degrees":[{"degree":"B.A.","year":1751}],"notes":"Yale College class of 1751","degree":"B.A.","school_name":"Yale College","graduation_year":1751,"institution_id":"INST022"}],"bio":{"display_name":"Rev. John Hooker","title":"Reverend","first_name":"John","last_name":"Hooker","married_names":[]},"landmarks":[],"residence":{"city":"Northampton","state":"Massachusetts","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1751"}],"artworks":[],"quotes":[],"military_service":[],"slug":"john-hooker-1729"},"I00043":{"id":"I00043","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1732,"month":1,"day":27,"city":"Springfield","state":"Massachusetts"},"death":{"year":1817,"month":4,"day":5,"city":"Northampton","state":"Massachusetts"},"marriages":[{"spouse_id":"H00264","children_ids":["H00524","H00525","H00526","H00527","H00528","H00529","H00530","H00531","H00532"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1777,"date_year":1755,"date_month":12,"date_day":10}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 526"}],"parents":{"father_id":"X00053","mother_id":"X00054"},"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sarah Worthington Hooker","first_name":"Sarah","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Worthington"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-worthington-1732"},"X00041":{"id":"X00041","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"birth":{"year":1735,"month":7,"day":31,"city":"Dedham","county":"Norfolk","state":"Massachusetts","country":"United States"},"death":{"year":1815,"month":10,"day":19,"city":"Hinsdale","county":"Cheshire","state":"New Hampshire","country":"United States"},"marriages":[{"spouse_id":"X00042","children_ids":["I00039"],"marriage_number":1,"date_year":1763,"date_month":9,"date_day":22,"location_city":"Cambridge","location_county":"Middlesex","location_state":"Massachusetts","location_country":"United States"}],"sources":[],"parents":{"father_name":"Lusher Gay","mother_name":"Mary Ellis"},"tags":["clergy","minister","harvard_graduate","author"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"naming_pattern","related_id":"H02703","display_label":"Great-grandson Charles bore Gay middle name in his honor","link_text":"Charles Gay Hooker"},{"type":"naming_pattern","related_id":"H04266","display_label":"Two-greats-grandson Robert continued Gay middle name","link_text":"Robert Gay Hooker"},{"type":"naming_pattern","related_id":"HD3384","display_label":"Four-greats-grandson Michael carried Gay name into 20th century","link_text":"Michael Gay Hooker"}],"bio":{"display_name":"Rev. Bunker Gay","title":"Reverend","first_name":"Bunker","last_name":"Gay","married_names":[],"gender":"male"},"residence":{"city":"Hinsdale","county":"Cheshire","state":"New Hampshire","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[{"bib_id":"BIB001","page":"Entry 526"},{"bib_id":"BIB011","page":"Hinsdale chapter"}],"documents":[{"document_id":"DOC023","role":"author","notes":"Published 1792; first-person captivity narrative dictated to him by his Hinsdale neighbor Jemima Howe Tute."}],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus","years":"1756-1760","institution_blurb":"Graduated Harvard College 1760 before settling at Hinsdale."},{"institution_id":"INST134","relationship":"founder","years":"1763-1810","institution_blurb":"First settled pastor and effective founder of the Congregational church organized 1763."}],"landmarks":[{"landmark_id":"LM106","landmark_blurb":"Settled the Hinsdale homestead in 1763; the farm passed to his daughter Abigail when she married Seth Hooker in 1789."}],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM454"},"education":[{"institution_id":"INST002","dates":"1756-1760","type":"undergraduate","notes":"Harvard College class of 1760."}],"career":[{"role":"First Settled Pastor","organization":"First Congregational Church of Hinsdale","location":"Hinsdale, New Hampshire","start_year":1763,"end_year":1810,"notes":"47-year pastorate. Original parish embraced all of Hinsdale plus Vernon (later separated when Vermont became a state). Continued as nominal pastor and officiated weddings and funerals into old age."}],"narrative_blocks":[{"number":1,"category":"family","header":"His daughter brought the Hooker family to Hinsdale","body":"Five of his six children with Abigail Prentice died young; only daughter Abigail survived to marriage. Her 1789 wedding to Seth Hooker brought Seth onto the Gay homestead, beginning the four-generation Hooker tenure on what locals called the Hooker place."},{"number":2,"category":"family","header":"His Gay middle name passed down five generations","body":"Through his daughter Abigail's marriage to Seth Hooker, the Gay name entered the Hooker line as a middle name. Great-grandson Charles Gay, great-great-grandson Robert Gay, and four-greats-grandson Michael Gay all carried it forward into the twentieth century."},{"number":3,"category":"career","header":"Forty-seven years as Hinsdale's first pastor","body":"Ordained at the founding of the First Congregational Church of Hinsdale in 1763, he served the same pulpit through the Revolution and into old age. His parish originally embraced all of Hinsdale plus the Vermont side at Vernon, until Vermont's statehood split the territory."},{"number":4,"category":"literature","header":"Published the Jemima Howe captivity narrative, 1792","body":"His Hinsdale neighbor Jemima Howe had been carried off to Quebec by Abenaki raiders in 1755 and spent years in French captivity before her ransom. He recorded her oral testimony and published it as 'A Genuine and Correct Account of the Captivity, Sufferings & Deliverance of Mrs. Jemima Howe.'"},{"number":5,"category":"family","header":"Dedham roots in the 1636 founding wave","body":"His great-grandfather John Gay was an original proprietor of Dedham, Massachusetts in 1636, the same year Thomas Hooker founded Hartford. Two Great Migration foundings, joined a century and a half later when Abigail Gay married Seth Hooker."}],"slug":"bunker-gay-1735"},"X00042":{"id":"X00042","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"birth":{"year":1740,"month":5,"day":25,"city":"Cambridge","county":"Middlesex","state":"Massachusetts","country":"United States"},"death":{"year":1792,"month":7,"day":15,"city":"Hinsdale","county":"Cheshire","state":"New Hampshire","country":"United States"},"marriages":[{"spouse_id":"X00041","children_ids":["I00039"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 526"}],"gender":"female","tags":[],"number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Abigail Prentice Gay","first_name":"Abigail","last_name":"Gay","married_names":["Gay"],"maiden_name":"Prentice"},"residence":{"city":"Hinsdale","county":"Cheshire","state":"New Hampshire","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[{"landmark_id":"LM106","landmark_blurb":"Raised her six children on the Gay homestead at Hinsdale; buried beside her husband on the property's cemetery."}],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM454"},"narrative_blocks":[{"number":1,"category":"family","header":"Buried five of six children in fifteen years","body":"Between 1773 and 1788 she lost five of her six children — Bunker Jr. at eleven, Calvin at six, John at thirteen, Henry at twenty-six, and Sally as an infant — to a series of family tragedies in frontier Hinsdale. Daughter Abigail alone survived, marrying Seth Hooker in 1789 and carrying the line forward."}],"slug":"abigail-prentice-1740"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}