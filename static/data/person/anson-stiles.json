unty":"San Francisco County","state":"California","country":"United States"},"baptism":{},"death":{"year":1950,"month":5,"day":9,"city":"Cambridge","county":"Middlesex County","state":"Massachusetts","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM311"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["academic","scholar"],"notable_blurb":"American Byzantinist; scholar of Armenian and Georgian cultures","primary_url":"https://www.findagrave.com/memorial/126755114/robert_pierpont-blake","primary_url_label":"FindAGrave: Robert Pierpont Blake"},"parents":{"father_id":"HD1567","father_name":"Charles Thompson Blake","mother_id":"X01504","mother_name":"Harriet Waters Stiles Blake"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00594","date_year":1920,"date_month":1,"date_day":7,"location_city":"Tiflis","location_state":"Georgia","location_country":"Democratic Republic of Georgia","end_type":"death","end_year":1950,"children_ids":[]}],"education":[{"institution":"Harvard University","degree":"John Harvard Traveling Fellow","field":"Byzantine Studies","start_year":1911,"end_year":1918,"notes":"Fellowship years primarily spent in Russia studying Russian, Arabic, Syriac, Armenian, and Georgian languages."}],"career":[{"role":"Professor","organization":"Tbilisi State University, Georgia","start_year":1918,"end_year":1920,"notes":"Helped found Tbilisi State University in 1918 and taught Greek language and Byzantine history there through 1920."},{"role":"Professor of Byzantine Studies","organization":"Harvard University","start_year":1920,"end_year":1950,"notes":"Instrumental in promoting Byzantine studies in the United States. Contributed to the study of medieval Georgian manuscripts found at Palestine and Mount Athos.","institution_id":"INST002"}],"military_service":[],"institutions":[{"institution_id":"INST002"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"scholarship","header":"Lived the Russian Revolution at Tbilisi, 1918","body":"Robert Pierpont Blake was already in Russia on a Harvard fellowship when the Revolution broke; he relocated to Tbilisi in 1918 on behalf of Saint Petersburg State University to investigate Tbilisi's manuscripts and the texts of the Bible. When Tbilisi State University was founded that same year he became one of its first professors, teaching Greek and Byzantine history through 1920."},{"number":2,"category":"scholarship","header":"Mount Athos, Palestine, and the Georgian manuscripts","body":"Robert was instrumental in establishing Byzantine studies in the United States from his Harvard professorship beginning in 1920. He revealed and catalogued many medieval Georgian manuscripts at Palestine and Mount Athos, becoming a foundational figure in modern Byzantine and Caucasian-Christian scholarship."},{"number":3,"category":"family","header":"Married in Tiflis as Soviet power consolidated, 1920","body":"On January 7, 1920 Robert married Nadezhda Nikolavena Kryzhanovskaya in Tiflis, Georgia — months before the Soviets absorbed independent Georgia. The couple soon left for Harvard, where Robert would teach for thirty years."}],"quotes":[],"sources":[{"label":"FindAGrave memorial 126755114","url":"https://www.findagrave.com/memorial/126755114/robert_pierpont-blake"}],"research_sources":[],"documents":[],"slug":"robert-blake-1886"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[{"type":"in_law","related_id":"HD1567","display_label":"married his daughter Harriet in 1868","slug":"charles-blake-1826"}]}