ry_service":[{"war":"American Revolutionary War","active_in_war":true,"rank":"Captain then Surgeon","notes":"3rd Co., 1st Regt CT, May 1775, Wyoming Valley PA; marched under Gen. Schuyler to NY. 1776: 10th Continental Regt CT under Col. Parsons. 1777: commissioned Captain, 24th Regt CT (Westmoreland Regt). May 27, 1778: commissioned Surgeon. Surgeon to militia under Col. Dennison, Forty Fort 1778-1779. Participated in Battle of Wyoming. Congress 1836 special act: $2,400 to heirs for war services.","war_id":"WAR004"}],"bio":{"display_name":"William Hooker Smith","notes":"Middle name \"Hooker\" explicit tribute to ancestor Thomas Hooker","first_name":"William","last_name":"Smith","middle_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"military","header":"Continental Army surgeon at Wyoming Massacre 1778","body":"He served as Surgeon in the Continental Army — 3rd Company, 1st Regiment Connecticut — and was living in the Wyoming Valley when the July 3, 1778 massacre killed approximately 300 Patriots. His first wife Sarah had died three weeks earlier."},{"number":2,"category":"death","header":"Family Bible recorded wife's death before the massacre","body":"His Oxford-printed Bible (1772) preserves the record of her death at 'about nine o'clock at night' on Friday, June 12, 1778. She was buried on his own land at Jacob's Plains two days later, three weeks before the Wyoming Massacre."},{"number":3,"category":"legacy","header":"Old Forge, Pennsylvania was named for him","body":"He and his son-in-law James Sutton founded an iron works in the Lackawanna Valley. Those who knew him called him 'old forge' — and the town of Old Forge, Pennsylvania was named for him."},{"number":4,"category":"family","header":"Lived to ninety in Tunkhannock, Pennsylvania","body":"He died July 17, 1815 