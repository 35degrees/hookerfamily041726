ined across chemistry, psychology, and engineering","body":"Krulee took an MIT degree in chemical engineering, a master's in psychology, and an MIT doctorate in industrial engineering before settling into academic life. He taught at Michigan, Tufts, and Case before joining Northwestern in 1960.","number":3},{"category":"military","header":"He served as a Navy engineer in wartime","body":"During the Second World War, Krulee was a Navy engineering officer from 1943 to 1946. In civilian life he kept up his trombone in a community ensemble well into old age.","number":4}],"quotes":[],"sources":[{"short":"Northwestern McCormick obituary Jan 26 2017; Daily Northwestern Jan 26 2017"}],"research_sources":[],"documents":[],"slug":"gilbert-krulee-1924"},"HD3877":{"id":"HD3877","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Carolyn","maiden_name":"Hall","married_names":["Krulee"],"gender":"female","display_name":"Carolyn Hall Krulee"},"birth":{"year":1936},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":13,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00494","mother_id":"HD3874"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00495","children_ids":["HD3878","HD3879","HD3880"]}],"education":[],"career":[{"role":"Secretary, then administrator and program founder","organization":"Northwestern University McCormick School of Engineering","institution_id":"INST124","location":"Evanston Illinois","end_year":1996,"notes":"From early 1960s as Associate Dean William Brazelton's secretary; founded Women in Tech, helped create Northwestern SWE chapter (1976), launched Career Day for Girls (1971). Retired 1996. Profiled with successor Ellen Worsdall in McCormick Magazine Spring 2020."}],"military_service":[],"institutions":[{"institution_id":"INST124"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["living_or_recent"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"education","header":"Launched Career Day for Girls at Northwestern, 1971","body":"Working as Associate Dean Brazelton's secretary at McCormick in the early 1960s, Carolyn found the six women enrolled in engineering studying alone — she convened them into a single class so they had partners. In 1971 she organized the first Career Day for Girls, drawing twenty grade-school students; by 2020 the program drew 139."}],"quotes":[],"sources":[{"short":"Northwestern McCormick Magazine Spring 2020; FindAGrave"}],"research_sources":[],"documents":[],"slug":"carolyn-krulee-1936"},"I00494":{"id":"I00494","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Edward","middle_name":"Barton","last_name":"Hall","suffix":"Jr.","married_names":[],"gender":"male","display_name":"Edward Barton Hall Jr."},"birth":{"year":1909},"baptism":{},"death":{"year":1989},"residence":{},"burial":{"cemetery_id":"CEM153"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3874","children_ids":["HD3877"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"short":"FindAGrave"}],"research_sources":[],"documents":[],"slug":