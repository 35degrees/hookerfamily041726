insdale","county":"Cheshire","state":"New Hampshire","country":"United States"},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":true},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Cyrus Jones","mother_name":"Sally Bowker","father_research_notes":"Died when Henry was about two years old.","mother_research_notes":"Removed family to Athol, Massachusetts after husband's death."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H02701","date_year":1842,"date_month":12,"date_day":7,"location_city":"Hinsdale","location_county":"Cheshire","location_state":"New Hampshire","location_country":"United States","end_type":"death_of_self","end_year":1886,"children_ids":["HD04829","HD04830","HD04831"]}],"education":[],"career":[{"role":"Errand and Farm Boy","organization":"Abram Hinds (first lawyer of Hinsdale)","location":"Hinsdale, NH","notes":"About four years in Hinds's household, starting around age fourteen."},{"role":"Sawmill Owner","organization":"Kilbourn Brook sawmill","location":"Hinsdale, NH","start_year":1835,"end_year":1838,"notes":"Bought a saw-mill on Kilbourn brook a short distance from the village, ran it about three years."},{"role":"Manufacturer","organization":"Canal Street shop","location":"Hinsdale, NH","start_year":1838,"notes":"Manufacturer of doors, sash, blinds, and dressed lumber for many years on Canal Street."},{"role":"Selectman (three terms)","organization":"Town of Hinsdale","location":"Hinsdale, NH","notes":"Served three years as selectman; re-elected to a fourth term but resigned."},{"role":"State Representative","organization":"New Hampshire General Court","location":"Concord, NH","start_year":1876,"end_year":1877,"notes":"Representative for Hinsdale 1876–77; also delegate to the 1876 New Hampshire Constitutional Convention."},{"role":"Captain","organization":"Ashuelot Guards (militia)","location":"Hinsdale, NH","notes":"Local military company."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["politician"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Orphaned at two, brought to Hinsdale at twelve","body":"His father Cyrus Jones died when he was about two years old and his mother Sally Bowker moved the family to Athol, Massachusetts. At twelve he was sent to Hinsdale to live with his uncle Windsor Bowker; he never left."},{"number":2,"category":"family","header":"Married Julia Worthington Hooker, December 1842","body":"He married Julia W., daughter of Henry Hooker of the Hinsdale homestead, on 7 December 1842. They raised three children, two of whom became mechanics in Keene."},{"number":3,"category":"business","header":"Built a Canal Street doors-and-sash factory","body":"After three years running a Kilbourn brook sawmill in the mid-1830s, he bought a shop on Canal Street in Hinsdale village and manufactured doors, sash, blinds, and dressed lumber for many years. The shop was a fixture of the manufacturing village."},{"number":4,"category":"politics","header":"Constitutional convention delegate, 1876","body":"He served three terms as selectman, represented Hinsdale in the state legislature in 1876–77, and sat as a delegate to the 1876 New Hampshire constitutional convention. Earlier he had been captain of the Ashuelot Guards, a Hinsdale militia company."},{"number":5,"category":"family","header":"Born in Gerry, Massachusetts — renamed Phillipston, 1814","body":"His birthplace was named for Elbridge Gerry, fifth vice-president of the United States, but the town was renamed Phillipston in 1814 after Gerry's political fall from grace. He was thus born in Gerry but always identified as a Phillipston native."}],"quotes":[],"sources":[],"research_sources":[{"bib_id":"BIB011","page":"Hinsdale chapter — Henry M. Jones biographical sketch"}],"documents":[],"slug":"henry-jones-1811"},"H02701":{"id":"H02701","former_ids":[],"is_placeholder":false,"gender":"female","has_descendants_documented":false,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"is_easter_egg":false,"include_in_path_calculation":true,"descent_from_thomas_hooker":true},"bio":{"first_name":"Julia","middle_name":"Worthington","last_name":"Hooker","married_names":[],"gender":"female","display_name":"Julia Worthington Hooker"},"birth":{"city":"Hinsdale","county":"Cheshire County","state":"New Hampshire","country":"United States","year":1818,"month":11,"day":15},"death":{},"parents":{"father_id":"H01393","mother_id":"X02247"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02834","date_year":1842,"date_month":12,"date_day":7,"location_city":"Hinsdale","location_county":"Cheshire","location_state":"New Hampshire","location_country":"United States","children_ids":["HD04829","HD04830","HD04831"]}],"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 2701"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[{"landmark_id":"LM106","landmark_blurb":"Born and raised on the homestead; married Henry M. Jones at Hinsdale in 1842 and remained in town."}],"artworks":[],"quotes":[],"military_service":[],"slug":"julia-hooker-1818"},"H01393":{"id":"H01393","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"bir