ative_blocks":[{"number":1,"category":"family","header":"His sons launched three California empires","body":"Six of his eleven children left Hinsdale for the West. Charles Gay built the San Francisco hardware fortune, Henry Clay founded Arizona's first cattle ranch, and John Daggett funded the 100-inch Hooker Telescope at Mount Wilson."},{"number":2,"category":"character","header":"Ninety-three years in one Hinsdale farmhouse","body":"Born July 1791 in the room overlooking the Gay homestead and dying in March 1885, he passed his entire life on one farm in Hinsdale. The Gazetteer of Cheshire County called him 'a hale and hearty old man.'"},{"number":3,"category":"character","header":"Crossed to California twice in his eighties","body":"After eighty he made two trips out to visit his California sons, riding the railroads across a continent he had been born too early to see imagined. He returned each time to the Hinsdale homestead."}],"slug":"henry-hooker-1791"},"X02247":{"id":"X02247","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":false},"bio":{"first_name":"Mary","last_name":"Hooker","maiden_name":"Daggett","married_names":["Hooker"],"gender":"female","display_name":"Mary Daggett Hooker"},"birth":{"year":1795,"month":11,"day":10,"city":"Hinsdale","county":"Cheshire County","state":"New Hampshire","country":"United States"},"death":{"year":1864,"month":8,"day":18,"city":"Hinsdale","county":"Cheshire County","state":"New Hampshire","country":"United States"},"parents":{"father_research_notes":"Simeon Daggett (1758-1819). Per WikiTree (cited in Sam's research). Likely descended from the Massachusetts colonial Daggett line (John Daggett of Watertown MA, immigrant ~1630s).","mother_research_notes":"Anna Dean (1758-c.1819). The matching birth/death dates with Simeon (per WikiTree) are likely a data error in the WikiTree record — almost certainly Anna had different death date than Simeon. Maiden name Dean."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01393","date_year":1816,"date_month":10,"date_day":23,"location_state":"New Hampshire","location_country":"United States","end_type":"death","end_year":1864,"children_ids":["H02700","H02701","H02702","H02703","H02704","H02705","H02706","H02707","H02708","H02709","H02710"]}],"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 1393"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Mother of Henry Clay Hooker, Arizona cattle baron","body":"She raised eleven children at Hinsdale on the Connecticut River. Her son Henry Clay Hooker founded the Sierra Bonita Ranch in Arizona Territory."},{"number":2,"category":"family","header":"Two Daggetts married into the Hooker line","body":"Her 1816 marriage to Henry Hooker came four years after Elisabeth Daggett, in a separate Hooker branch, married Edward Hooker. The two Daggett brides may share earlier Massachusetts ancestry."}],"cross_connections":[],"siblings_research":"Per WikiTree: 8 documented Daggett siblings: Simeon Jr (M, 1780-1854), Sarah M. (F, 1783-?), (unnamed son b.1784-?), Nathaniel (M, 1785-1826), Nancy (F, 1788-1854), Caleb C (M, 1792-1879), Silvey (F, 1792-1883 — possibly twin of Caleb), and Mary herself (1795-1864). Mary was the youngest of 8.","residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM527"},"slug":"mary-daggett-1795"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}