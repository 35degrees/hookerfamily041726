tion of a dynastic alliance running across at least four consecutive generations."},{"number":2,"category":"legacy","header":"Last witness to where Norwalk's first church stood","body":"By 1847, at seventy-three, Buckingham was quoted by Norwalk's city historian on the exact location of the town's original meeting-house — a site he could still picture as open common ground. He was among the last living residents with a direct memory of colonial Norwalk's original layout."}],"slug":"buckingham-lockwood-1774"},"H01243":{"id":"H01243","former_ids":["I00685"],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Mary","middle_name":"Esther","last_name":"Lockwood","maiden_name":"St. John","married_names":["Lockwood"],"nickname":"Polly","gender":"female","display_name":"Mary Esther St. John Lockwood","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778787504/maryesterlockwood_ka145o.png","photo_notes":"Portrait of Mary Esther (St. John) Lockwood"},"birth":{"year":1783,"month":3,"day":10,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1850,"month":10,"day":20,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H00481","mother_id":"X00217"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01232","date_year":1808,"date_month":2,"date_day":17,"location_city":"Norwalk","location_county":"Fairfield County","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1850,"children_ids":["HD4306","HD4307","HD4308","HD4309","HD4310","HD4311"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["cousin_marriage"],"research_tags":[],"cross_connections":[{"type":"cousin_marriage","related_id":"H01232","display_label":"Born St. John; wed Lockwood second cousin in 1808","link_text":"Col. Buckingham St. John Lockwood"}],"narrative_blocks":[{"number":1,"category":"family","header":"Born St. John; wed a Lockwood second cousin","body":"Polly Esther St. John married Buckingham St. John Lockwood in 1808 — her second cousin through their common great-grandmother Susannah Selleck St. John of Norwalk, continuing the St. John-Lockwood intermarriage pattern across yet another generation. Her father William Saint John and his grandmother Susannah Saint John Lockwood were siblings."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"mary-lockwood-1783"},"X00218":{"id":"X00218","has_descendants_documented":false,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"tags":["revolutionary_war","politician","army"],"sources":[{"label":"Wikipedia — Eliphalet Lockwood","url":"https://en.wikipedia.org/wiki/Eliphalet_Lockwood"},{"label":"Lockwood Genealogy (archive.org)","url":"https://archive.org/details/descendantsofrob00inhold/page/n3/mode/2up?q=eliphalet"}],"birth":{"year":1741,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"death":{"year":1814,"month":3,"day":19,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00478","date_year":1776,"date_month":6,"date_day":8,"location_city":"Norwalk","location_county":"Fairfield County","location_state":"Connecticut","location_country":"United States","end_type":"death_of_self","end_year":1814,"children_ids":["H01229","H01230","H01231","H01232","H01233","H01234","H01235"]}],"parents":{"father_name":"Deacon Peter Lockwood","mother_name":"Abigail (Hawley) Lockwood","father_research_notes":"Per Lockwood genealogy + EH. Wikipedia says mother was 'Mary Hawley' — discrepancy with Lockwood genealogy 'Abigail (Hawley) Lockwood.' Using genealogy/EH as higher-priority source."},"notable":{"is_notable":true,"notable_category":["politics","military"],"notable_blurb":"Nine-term Connecticut legislator; Revolutionary War captain","primary_url":"https://en.wikipedia.org/wiki/Eliphalet_Lockwood","primary_url_label":"Wikipedia — Eliphalet Lockwood"},"cross_connections":[],"bio":{"title":"Captain","first_name":"Eliphalet","last_name":"Lockwood","married_names":[],"gender":"male","display_name":"Captain Eliphalet Lockwood","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778786493/elipahletlockwood-resized_m9qkll.png","photo_notes":"Portrait of Capt. Eliphalet Lockwood"},"residence":{"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"baptism":{"year":1741,"month":10,"day":17,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","rank":"Captain","rank_start":"Private","rank_end":"Captain","rank_year_start":1775,"rank_year_end":1780,"unit":"First Company, Colonel Charles Webb's Seventh Connecticut Regiment","notes":"Enlisted Jul 12, 1775; discharged Dec 24, 1775. Assigned to Gen. Sullivan's Brigade on Winter Hill. Assistant Commissary of Issues 1778; captain of coast guards 1780."}],"former_ids":[],"is_placeholder":false,"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave #155694447. East Norwalk Historical Cemetery."},"education":[],"career":[{"role":"Assistant Commissary of Issues","organization":"Fifth Connecticut Regiment, Continental Army","start_year":1778,"end_year":1778,"notes":"Posted $5,000 bond to Henry Laurens, President of the Continental Congress, Jul 21, 1778."},{"role":"Captain, Coast Guard","organization":"Connecticut Militia","start_year":1780},{"role":"Member","organization":"Connecticut House of Representatives","start_year":1790,"end_year":1796,"notes":"Represented Norwalk nine sessions: May/Oct 1790, May/Oct 1791, Oct 1794, May/Oct 1795, May/Oct 1796."}],"narrative_blocks":[{"number":1,"category":"military","header":"Lost home when British torched Norwalk, 1779","body":"British forces burned Norwalk in July 1779, destroying Lockwood's home among hundreds of others along the shore. He had already served in the 7th Connecticut Regiment and organized a petition to the General Assembly for an armed sloop after British ships raided the harbor at night."},{"number":2,"category":"politics","header":"Organized Norwalk's first volunteer fire department","body":"After the war Lockwood organized the first voluntary fire department in Norwalk, building civic infrastructure in the town the British had burned. He went on to represent Norwalk nine terms in the Connecticut General Assembly between 1790 and 1796."},{"number":3,"category":"military","header":"Petitioned Assembly for armed sloop; British still came","body":"In October 1777, Lockwood joined neighbors in petitioning the Connecticut General Assembly for an armed sloop to patrol Long Island Sound after British vessels repeatedly raided Norwalk's harbor at night, firing on houses and stealing livestock. Two years later, the raids he had warned against culminated in the burning of the town that destroyed his home."}],"slug":"eliphalet-lockwood-1741"},"H00478":{"id":"H00478","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"descent_paths_to_thomas":1,"is_progenitor":false},"birth":{"year":1743,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"parents":{"father_name":"Capt. Joseph St. John of Norwalk","mother_id":"H00253","mother_name":"Susannah Selleck St. John","father_research_notes":"Capt. Joseph St. John of Norwalk CT; d. 1756. His estate included enslaved people.","father_id":"X00215"},"tags":[],"sources":[{"label":"FindAGrave — Susannah St. John Lockwood","url":"https://www.findagrave.com/memorial/155694447/eliphalet-lockwood"}],"death":{"year":1810,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"marriages":[{"marriage_number":1,"spouse_id":"X00218","date_year":1776,"date_month":6,"date_day":8,"location_city":"Norwalk","location_county":"Fairfield County","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1810,"children_ids":["H01229","H01230","H01231","H01232","H01233","H01234","H01235"]}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Susannah St. John Lockwood","first_name":"Susannah","last_name":"Lockwood","maiden_name":"St. John","married_names":["Lockwood"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["HD0366"],"is_placeholder":false,"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave — East Norwalk Historical Cemetery"},"education":[],"career":[],"narrative_blocks":[{"number":1,"category":"family","header":"Orphaned at six; married the town's future captain","body":"Her mother Susannah Selleck died in December 1749 when Susannah was barely six, and her father Capt. Joseph St. John died in 1756 when she was thirteen, leaving her to grow up in Norwalk without either parent. She married Captain Eliphalet Lockwood at thirty-three — he would go on to lose his home to British torches and organize the city's first volunteer fire department."}],"slug":"susannah-lockwood-1743"},"H00481":{"id":"H00481","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1744,"month":4,"day":7,"city":"Norwalk","state":"Connecticut"},"parents":{"mother_id":"H00253","father_research_notes":"Capt. Joseph St. John of Norwalk","father_id":"X00215"},"tags":["yale_graduate","revolutionary_war","slaveholder","moral_complexity"],"sources":[{"label":"St. John Genealogy — entry 144","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"},{"label":"DAR Patriot Ancestor A099267","url":"https://services.dar.org/Public/DAR_Research/search_adb/?action=full&p_id=A099267"}],"death":{"year":1800,"month":2,"day":1,"city":"Norwalk","state":"Connecticut"},"marriages":[{"children_ids":["H01241","H01242","H01246","H01243","H01244","H01245"],"spouse_id":"X00217","marriage_number":1,"date_year":1777,"date_month":6,"date_day":19}],"enslaved_persons":[{"name":"Dover","description":"Enslaved man, jointly owned with brother Stephen. On June 3, 1777, William sent Dover to fight in the Continental Army in his stead, receiving half-ownership of Dover as credit from Stephen. \"Received of my brother Stephen St. John, the one half of his Negro boy named Dover, now inlisted into the Continental Service, for the one half of which boy I am obliged to pay sixty dollars on demand, to exempt me from all actual service. William St. John.\" William was a Loyalist; his wife's 1800 census shows 1 enslaved person still in household."}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"education":[{"notes":"A.B. 1766, A.M. 1769. Same class as Jared Ingersoll and Jonathan Ingersoll.","school_name":"Yale College","graduation_year":1766,"institution_id":"INST022"}],"bio":{"display_name":"William St. John","first_name":"William","last_name":"St. John","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1762-1766","institution_blurb":"Yale A.B. 1766, A.M. 1769 — same class as Hons. Jared and Jonathan Ingersoll of Connecticut."}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["HD0368"],"burial":{"cemetery_id":"CEM002","plot_notes":"East Norwalk Historical Cemetery. FA confirmation."},"narrative_blocks":[{"number":1,"category":"education","header":"Yale class of 1766","body":"William Saint John graduated Yale with A.B. 1766 and A.M. 1769, in the same class as Hon. Jared and Jonathan Ingersoll — two of Connecticut's most prominent legal and political figures — and served as private tutor in the wealthy Phillipse family of Phillipse, New York. He was described by contemporaries as 'a very fine looking, superior man, a person of fine address and manners, presiding handsomely at his own table.'"},{"number":2,"category":"legacy","header":"Two verdicts: DAR Patriot Ancestor and colonial Loyalist","body":"One chronicler records that Saint John 'was a Loyalist and was sent to New York with the Army,' yet he is simultaneously honored as a DAR Patriot Ancestor (A099267) for Civil Service during the Revolution — a tension common among colonial Norwalk families divided by the conflict. In June 1777 he received from his brother Stephen 'the one half of his Negro boy named Dover, now inlisted into the Continental Service,' paying sixty dollars to exempt himself from actual military service."},{"number":3,"category":"death","header":"Suffered heavy losses when Tryon burned Norwalk, 1779","body":"William Saint John suffered significant property losses in General Tryon's burning of Norwalk in July 1779, the same raid that destroyed or damaged much of the town. He died February 1, 1800, in his fifty-sixth year — survived by his wife Mary Esther Belden, who would outlive him by fifty years, dying at ninety-seven in 1850."}],"slug":"william-st-john-1744"},"X00217":{"id":"X00217","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["slaveholder","moral_complexity"],"sources":[],"birth":{"year":1753},"death":{"year":1850},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00481","date_year":1777,"date_month":6,"date_day":19,"children_ids":["H01241","H01242","H01246","H01243","H01244","H01245"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Esther Belden","first_name":"Mary","middle_name":"Esther","maiden_name":"Belden","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-belden-1753"}},"burialCemetery":{"id":"CEM365","name":"Center Cemetery","city":"New Milford","state":"Connecticut","country":"United States","primary_url":"https://www.findagrave.com/cemetery/2338390/center-cemetery","hooker_connections":["I00687","HD4308","HD4312","HD4313","HD4314","HD4316","I00693","HD4327","