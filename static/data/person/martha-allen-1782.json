 Strong","first_name":"Sarah","middle_name":"Elizabeth","last_name":"Strong","married_names":[]},"gender":"female","birth":{"year":1809,"month":4,"day":30,"city":"Northampton","state":"Massachusetts","country":"United States"},"death":{"year":1857,"month":5,"day":11,"city":"Somerville","state":"Massachusetts","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"parents":{"father_id":"HD0369","mother_id":"I01211"},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01218","date_year":1841,"date_month":6,"date_day":3,"end_type":"death","end_year":1857,"children_ids":["H04223","H04224","H04225","H04226","H04227"]}],"career":[],"education":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[{"type":"civic_peer","related_id":"H02770","display_label":"Husband Thompson's deputation visited Capron's Madura mission","link_text":"Sarah Brown Hooker Capron"}],"narrative_blocks":[{"number":1,"category":"death","header":"Her husband outlived her by forty-four years","body":"Sarah Elizabeth Strong Thompson died May 11, 1857 at forty-eight years old in Somerville, Massachusetts — forty-four years before her husband Rev. Augustus Thompson, who lived to eighty-nine and served as senior pastor of Eliot Congregational Church in Roxbury for fifty-nine unbroken years. She saw five children born; he outlived three of them."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM098"},"residence":{"country":"United States"},"sources":[{"short":"EH 1909","page":"EH 1909 #2673"}],"research_sources":[],"slug":"sarah-strong-1809"},"I01218":{"id":"I01218","is_placeholder":false,"former_ids":[],"bio":{"display_name":"Rev. Augustus Charles Thompson Sr.","first_name":"Augustus","middle_name":"Charles","last_name":"Thompson","married_names":[],"title":"Rev.","suffix":"Sr."},"gender":"male","birth":{"year":1812,"month":4,"day":30,"city":"Goshen","county":"Litchfield","state":"Connecticut","country":"United States"},"death":{"year":1901,"month":9,"day":26,"city":"Roxbury","county":"Suffolk","state":"Massachusetts","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"is_easter_egg":false},"parents":{"father_research_notes":"Augustus Thompson","mother_research_notes":"Kesiah (Hopkins) Thompson"},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H02673","date_year":1841,"date_month":6,"date_day":3,"end_type":"death_of_spouse","end_year":1857,"children_ids":["H04223","H04224","H04225","H04226","H04227"]}],"career":[{"role":"Senior Pastor","organization":"Eliot Congregational Church","location":"Roxbury, Suffolk County, Massachusetts","start_year":1842,"end_year":1901,"notes":"59 years as senior pastor of Eliot Congregational Church, Roxbury."},{"role":"Committee Member and Deputation","organization":"American Board of Commissioners for Foreign Missions","location":"India and Sri Lanka","start_year":1854,"end_year":1855,"notes":"ABCFM deputation with Rev. Rufus Anderson to resolve educational policy at India and Sri Lanka missions."}],"education":[{"institution_id":"INST022","type":"undergraduate","institution_blurb":"Yale College graduate."},{"school_name":"Theological Seminary at East Windsor Hill, CT","type":"graduate","notes":"Studied theology at East Windsor Hill CT seminary."},{"school_name":"University of Berlin","type":"graduate","notes":"Studied in Germany at University of Berlin."}],"military_service":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"},{"institution_id":"INST041"}],"landmarks":[],"artworks":[],"tags":["minister","clergy","author","yale_graduate","missionary"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Pastor of Roxbury's Eliot Church for fifty-nine years","body":"Rev. Augustus Thompson began his pastorate at Eliot Congregational Church, Roxbury, Massachusetts in 1842 and remained senior pastor until his death on September 26, 1901 — fifty-nine unbroken years. In that time he published more than fifteen devotional books, outlived two wives and three children, and became one of the most prolific Congregationalist authors of the mid-Victorian era."},{"number":2,"category":"career","header":"Led ABCFM deputation to India in 1854","body":"In 1854-5, Thompson accompanied Rev. Dr. Rufus Anderson as the ABCFM's deputation to its missions in India and Sri Lanka — visiting stations to resolve disputes over educational policy at a time when British colonial grants were pressuring missionaries toward English-language instruction. The same visit brought him to the Madura mission in South India where William Banfield Capron — husband of Hooker descendant Sarah Brown Hooker Capron — was then serving."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM098"},"residence":{"city":"Roxbury","county":"Suffolk","state":"Massachusetts","country":"United States"},"sources":[{"short":"FindAGrave","page":"FGA #97317843"}],"research_sources":[],"slug":"augustus-thompson-sr-1812"},"H04223":{"id":"H04223","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Rear Adm. Theodore Strong Thompson","first_name":"Theodore","middle_name":"Strong","last_name":"Thompson","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779551900/strongthompson_fidiey.jpg","photo_notes":"Portrait. FGA/