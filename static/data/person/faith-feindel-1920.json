4182"]}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["law","business","religion"],"notable_blurb":"Quebec lawyer, Lyman Brothers Montreal drug merchant","primary_url":"https://www.findagrave.com/memorial/108258986/henry-lyman","primary_url_label":"FindAGrave memorial #108258986"},"cross_connections":[],"bio":{"display_name":"Henry Lyman","first_name":"Henry","last_name":"Lyman","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778699480/henrylyman-resized_xyprdu.jpg","photo_notes":"Portrait of Henry Lyman (1813-1897), Montreal lawyer and Lyman Brothers partner."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"unit":"Montreal Militia","notes":"Some military service in Montreal per EH bio — specific war and dates undocumented."}],"burial":{"cemetery_id":"CEM328","plot_notes":"Cimetière Mont-Royal Montreal — buried with wife Mary Corse Lyman."},"education":[{"school_name":"McGill College, Montreal","type":"undergraduate","notes":"Graduated McGill College, Montreal — per EH bio. McGill founded 1821 in Montreal; Henry would have attended in the 1830s."},{"school_name":"College in England (unnamed)","type":"graduate","notes":"Further study at a college in England per EH bio — specific institution undocumented."},{"school_name":"Bar of the Province of Quebec","type":"law","notes":"Admitted to practice law in the Province of Quebec."}],"career":[{"role":"Drug merchant, partner","organization":"Lyman Brothers (Lyman Bros & Co.), Montreal","location":"Montreal, Quebec, Canada","start_year":1829,"notes":"Joined the family drug firm in 1829 at age 15-16. Partner in Lyman Brothers — the largest pharmaceutical wholesaler in Canada — alongside his older brothers William and Benjamin. Listed as Drug Merchant in St Antoine Ward Montreal in the 1881 census."},{"role":"Lawyer, partner","organization":"Lyman, Class & Co. (law firm)","location":"Montreal, Quebec, Canada","notes":"Admitted to practice law in the Province of Quebec; partner in Lyman, Class & Co. law firm. Distinct from Lyman Brothers drug firm."},{"role":"Superintendent of West Ward","organization":"Montreal City Council","location":"Montreal","notes":"Served on Montreal City Council as Superintendent of West Ward."},{"role":"Deacon","organization":"Congregational Church, Montreal","location":"Montreal"}],"narrative_blocks":[{"number":1,"category":"career","header":"McGill graduate, Quebec lawyer, Lyman Brothers partner","body":"Henry Lyman graduated McGill College Montreal and studied further in England before being admitted to practice law in the Province of Quebec. He joined the family drug firm in 1829 at age fifteen and became a partner in Lyman Brothers — the largest pharmaceutical wholesaler in Canada — while also serving on Montreal City Council as Superintendent of West Ward and as Deacon in the Congregational Church."},{"number":2,"category":"family","header":"Three sons died young, four to old age","body":"Henry and Mary Corse Lyman had seven children together in Montreal between 1844 and 1861. Three died young: Arthur Ellis as an infant in 1847, Susan Alice at age five in 1853, and Roswell Corse at forty-two in 1892. The four surviving sons lived long lives, including Henry Herbert (who perished on the Empress of Ireland 1914) and Walter Ernest who reached eighty-nine."}],"slug":"henry-lyman-1813"},"X01252":{"id":"X01252","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["canada_migration"],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0583","date_year":1841,"date_month":8,"date_day":24,"location_city":