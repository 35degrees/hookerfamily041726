nt","first_name":"Mary","last_name":"Stuyvesant","married_names":["Stuyvesant"],"middle_name":"Rutherfurd","maiden_name":"Pierrepont","photo_url":"https://images.findagrave.com/photos/2023/222/50743096_39c98b56-61e7-4cde-a0ff-b791b8c99831.jpeg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-stuyvesant-1842"},"X00515":{"id":"X00515","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1843,"month":9,"day":2,"city":"Manhattan","county":"New York County","state":"New York","country":"United States"},"death":{"year":1909,"cause":"Heart attack while walking on the Champs-Élysées","month":7,"day":4,"city":"Paris","country":"France"},"tags":["orbit_notable"],"sources":[],"marriages":[{"spouse_id":"HD1623","children_ids":[],"marriage_number":1,"date_year":1863,"date_month":10,"date_day":13}],"gender":"male","notable":{"is_notable":true,"notable_category":[],"primary_url":"https://en.wikipedia.org/wiki/Rutherfurd_Stuyvesant"},"number_of_marriages":1,"parents":{},"cross_connections":[],"bio":{"display_name":"Rutherfurd Stuyvesant","first_name":"Rutherfurd","last_name":"Stuyvesant","married_names":[],"photo_url":"https://images.findagrave.com/photos/2018/1/14841584_75e7676d-e51a-410e-a19a-36a249456890.jpeg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"category":"death","header":"Heart attack on Champs-Élysées morning walk, 1909","body":"He died on 4 July 1909 while taking a morning walk on the Champs-Élysées in Paris at age sixty-five. The Stuyvesant and Rutherfurd family holdings in New York he had spent a lifetime managing passed to his two Dutch-born sons by his second wife.","number":1},{"category":"family","header":"Renamed at six to inherit Stuyvesant fortune","body":"Born John Stuyvesant Rutherfurd in Manhattan in 1843, he was renamed 'Rutherfurd Stuyvesant' at age six per the will of his grand-uncle Peter Gerard Stuyvesant. The renaming preserved the Stuyvesant surname across a female-line succession into the next generation.","number":2},{"category":"business","header":"Built first true NYC apartment building, 1869","body":"In 1869 he hired architect Richard Morris Hunt to build what the New York Tribune called 'the first true apartment building in New York' at 142 East 18th Street near Gramercy Park. The five-story walkup for middle-class tenants was modeled on Parisian apartments and described as 'wholly different from the plan of the tenement house.'","number":3},{"category":"death","header":"Built memorial chapel after wife died in childbirth","body":"His first wife Mary Rutherfurd Pierrepont died in childbirth on 31 December 1879; the child did not survive. In her memory he built the Memorial Chapel of St Mark's Parish at 288 East 10th Street Manhattan in 1882-83.","number":4}],"slug":"rutherfurd-stuyvesant-1843"},"HD1624":{"id":"HD1624","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1849},"death":{"year":1923},"parents":{"father_id":"HD1533","mother_id":"X00496"},"marriages":[{"spouse_id":"X00516","children_ids":["HD1628"],"marriage_number":1,"date_year":1876,"date_month":4,"date_day":26}],"tags":[],"sources":[],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["business","arts"],"notable_blurb":"Donated Virgil collection to Princeton; amateur photographer","primary_url":"https://en.wikipedia.org/wiki/John_Jay_Pierrepont","primary_url_label":"Wikipedia"},"narrative_blocks":[{"number":1,"category":"death","header":"His wife died at 29; he never remarried","body":"He married Elise de Rham in April 1876; their only child died in infancy and Elise herself died in October 1879 at age 29. He never remarried and lived out his life at the family property on Brooklyn Heights."},{"number":2,"category":"legacy","header":"He sent Virgil editions to Princeton every year","body":"As a student he began collecting early editions of the Latin poet Virgil and donated the collection to Princeton University Library in 1896, adding new volumes every year until his death in 1923. He was also a major donor of European prints and drawings to what is now the Princeton University Art Museum."}],"cross_connections":[],"bio":{"display_name":"John Jay Pierrepont","first_name":"John","last_name":"Pierrepont","middle_name":"Jay","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-pierrepont-1849"},"X00516":{"id":"X00516","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1850},"death":{"year":1879},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1624","children_ids":["HD1628"],"marriage_number":1,"date_year":1876,"date_month":4,"date_day":26}],"gender":"female","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elise de Rham","first_name":"Elise","maiden_name":"de Rham","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"nami