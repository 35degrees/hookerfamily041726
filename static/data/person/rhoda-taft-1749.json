ification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1810,"month":11,"day":5,"city":"Townshend","state":"Vermont"},"death":{"year":1891,"month":5,"day":21,"city":"San Diego","state":"California"},"parents":{"father_id":"HD0336","mother_id":"X01153"},"marriages":[{"marriage_number":1,"spouse_id":"X01154","end_type":"death_of_spouse","end_year":1852,"children_ids":["HD3067","HD3068","HD3069","HD3070","HD3071"],"date_year":1841,"date_month":1,"date_day":1},{"marriage_number":2,"spouse_id":"X01155","children_ids":["HD3072","HD0338","HD3073","HD3074","HD3075"],"date_year":1853,"date_month":12,"date_day":26,"location_city":"Millbury","location_state":"Massachusetts"}],"tags":["lawyer","judge","politician","diplomat","skull_and_bones","yale_graduate","ohio_migration","abolitionist"],"sources":[{"label":"Wikipedia — Alphonso Taft","url":"https://en.wikipedia.org/wiki/Alphonso_Taft"}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":true,"notable_category":["politics","law"],"notable_blurb":"U.S. Attorney General 1876","primary_url":"https://en.wikipedia.org/wiki/Alphonso_Taft","primary_url_label":"Wikipedia"},"burial":{"cemetery_id":"CEM083"},"narrative_blocks":[{"header":"He co-founded Skull and Bones","body":"Alphonso Taft co-founded Skull and Bones at Yale in 1832 with William Huntington Russell — who was also a Hooker descendant, though neither man knew it. His son William Howard Taft joined the same society, as did Henry Waters Taft and Horace Dutton Taft. Alphonso served as Attorney General, Secretary of War, and U.S. Minister to both Austria-Hungary and Russia — but his greatest legacy was the political dynasty: William became the only person to hold both the presidency and the Chief Justiceship.","number":1},{"header":"He dissented in the Bible-in-schools case","body":"In 1872, Alphonso Taft dissented from his own court's ruling requiring Bible reading in Cincinnati's public schools. He argued that the government must be neutral toward all religions, referencing Jewish taxpayers' right to secular education. The opinion was widely admired but killed his 1875 bid for the Republican nomination for Governor of Ohio.","number":2},{"number":3,"category":"family","header":"His father Peter Rawson honored Hooker ancestry","body":"His father was Peter Rawson Taft — the middle name \"Rawson\" an explicit tribute to Peter's mother Rhoda Rawson Taft, who descended from Rev. Grindal Rawson and Susanna Wilson Rawson, herself a daughter of Rev. Thomas Hooker's daughter Sarah Hooker Wilson. The name traveled three generations to Alphonso's father before reaching him."}],"cross_connections":[{"type":"civic_peer","related_id":"HD1395","display_label":"Co-founded Skull and Bones at Yale in 1832 — both were Thomas Hooker descendants, though neither knew it.","link_text":"William Huntington Russell"},{"type":"civic_connection","related_id":"HD3711","display_label":"Ohio Republican Party founding-era figures — lawyer-jurist and newspaper editor.","link_text":"Edwin Cowles"}],"bio":{"display_name":"Alphonso Taft","first_name":"Alphonso","last_name":"Taft","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/b/b9/Alphonso_Taft_-_cropped_and_retouched.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"founder","years":"1833"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"education":[{"institution_id":"INST022","dates":"1833","notes":" — Co-founder of Skull and Bones 1832 with William Huntington Russell. Father of President William Howard Taft. Hooker descendant."}],"slug":"alphonso-taft-1810"},"HD0342":{"id":"HD0342","has_descendants_documented":false,"classification":{"include_in_path_cal