age_number":1,"spouse_id":"H00382","date_year":1761,"date_month":9,"date_day":17,"location_city":"Northampton","location_state":"Massachusetts","children_ids":["HD2432","HD2433","X00660","HD2434","HD2540","HD2435"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Eleazer Porter","first_name":"Eleazer","last_name":"Porter","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002"},{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"law","header":"JP at 30 — dual judge by 1779","body":"He received his first commission as Justice of the Peace in 1758, at age thirty. In 1777 he was made Judge of the Court of Common Pleas and in 1779 Judge of Probate — both offices held until his death in 1797."},{"number":2,"category":"marriage","header":"First wife was his first cousin","body":"His first wife Anna Pitkin was his first cousin through the Pitkin grandfather they shared. She died November 7, 1758 in her twenty-fourth year, leaving two daughters; two years later he married Susannah Edwards."}],"slug":"eleazer-porter-1728"},"H00382":{"id":"H00382","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1740,"month":6,"day":21,"city":"Northampton","state":"Massachusetts"},"death":{"year":1803},"parents":{"father_id":"X00128","mother_id":"HD0418"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 382"}],"marriages":[{"spouse_id":"X00799","children_ids":["HD2432","HD2433","X00660","HD2434","HD2540","HD2435"],"marriage_number":1,"date_year":1761,"date_month":9,"date_day":17,"location_city":"Northampton","location_state":"Massachusetts"}],"gender":"female","notable":{"is_notable":true,"notable_category":[]},"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Susannah Edwards","first_name":"Susannah","maiden_name":"Edwards","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married widower Eleazer Porter Jr. in 1760","body":"In 1760 she married Eleazer Porter Jr. — Yale 1748, lawyer and judge in Hadley, Massachusetts. His first wife Anna Pitkin, his own first cousin, had died November 1758 leaving two young daughters; Susannah became their stepmother."},{"number":2,"category":"family","header":"Her brother married her sister-in-law","body":"Her brother Jonathan Edwards Jr. married her husband's sister Mary Porter in 1770. The two pairs of Edwards and Porter siblings married each other across the same Connecticut River Valley generation."},{"number":3,"category":"family","header":"Son's marriage doubled the Edwards descent","body":"Her son Jonathan Edwards Porter married Fidelia Dwight in the next generation. Both were grandchildren of Jonathan Edwards Sr. — a marriage that doubled the Edwards descent in their children's bloodline."}],"slug":"susannah-edwards-1740"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}