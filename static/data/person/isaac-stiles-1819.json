_ids":["HD3922"],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Isaac","last_name":"Stiles","married_names":[],"gender":"male","display_name":"Isaac Stiles"},"birth":{"year":1792,"month":8,"day":2,"city":"North Haven","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1842,"month":2,"day":4,"city":"North Haven","county":"New Haven","state":"Connecticut","country":"United States"},"residence":{"city":"North Haven","county":"New Haven","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM293"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H00454","father_name":"Capt. Isaac Clark Stiles","mother_id":"X01370","mother_name":"Eunice Blakeslee"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00524","date_year":1815,"date_month":11,"date_day":28,"location_city":"North Haven","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1842,"children_ids":["HD3933","HD3923","HD3934","HD3935","HD3936","HD3937"]}],"education":[],"career":[{"role":"Farmer + brick manufacturer","location":"North Haven, Connecticut","end_year":1842,"notes":"Family business — established brick mfg trade that became I. L. Stiles & Son under son Isaac Lorenzo."},{"role":"State Representative","organization":"Connecticut General Assembly","location":"Hartford, Connecticut","start_year":1831,"end_year":1831,"notes":"Represented N. Haven 1831 per Stiles book #601."},{"role":"Justice of the Peace","organization":"Town of North Haven, Connecticut","location":"North Haven, Connecticut","notes":"Per Stiles book #601."},{"role":"Postmaster","organization":"US Postal Service, North Haven, Connecticut","location":"North Haven, Connecticut","notes":"Per Stiles book #601."},{"role":"Warden","organization":"St. John's Episcopal Church, North Haven","location":"North Haven, Connecticut","end_year":1842,"notes":"Many years as Warden per Stiles book #601."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["episcopal","politician","postmaster"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Brickmaker, postmaster, JP, state representative","body":"Isaac Stiles built a multi-role public life in North Haven Connecticut — farmer and brick manufacturer, Justice of the Peace and Postmaster for many years, warden of St. John's Episcopal Church, and representative of North Haven in the Lower House of the Connecticut General Assembly in 1831. He 'held all important town offices' per the Stiles family book — typical of the local-elite figure who structured pre-Civil-War Connecticut town life."},{"number":2,"category":"family","header":"Two young sons died 1832, probable epidemic","body":"Two of Isaac Stiles's documented six children — Edward C. and William H. — both died in 1832. The shared death year strongly suggests an epidemic; 1832 was the year of the first North American cholera pandemic that reached Connecticut. Isaac himself died February 4, 1842 at age forty-nine, leaving widow Lois Cooper Stiles to live until 1872 — thirty years past him."}],"quotes":[],"sources":[],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"slug":"isaac-stiles-1792"},"I00524":{"id":"I00524","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Lois","last_name":"Stiles","maiden_name":"Cooper","married_names":["Stiles"],"gender":"female","display_name":"Lois Cooper Stiles"},"birth":{"year":1792,"month":3,"day":31,"city":"North Haven","cou