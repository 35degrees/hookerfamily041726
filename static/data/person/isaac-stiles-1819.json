 Blakeslee Clinton"},{"related_id":"HD3928","display_label":"First cousins through Stiles brothers Isaac Lorenzo and Henry Hobart","type":"family_connection","link_text":"Mary Cyrilla Stiles Clinton"},{"type":"parallel_event","related_id":"HD4096","display_label":"Two Stiles cousins, both dead on their birthday","link_text":"Ellen Amanda Stiles Hartley"}],"narrative_blocks":[{"number":1,"category":"career","header":"Seventeen years a Chapel Street dentist, New Haven","body":"Isaac Wadsworth Stiles practiced dentistry on New Haven's Chapel Street for seventeen years before dying of heart disease at his West Haven home in February 1907 age 64. Before dentistry he had served as postmaster in North Haven, where his father Isaac Lorenzo Stiles ran the family brick manufacturing company."},{"number":2,"category":"death","header":"Died on his sixty-fourth birthday","body":"Isaac Wadsworth Stiles was born February 28, 1843 and died of heart disease on February 28, 1907 — his sixty-fourth birthday. He had been an invalid for several years before his death at home in West Haven."}],"quotes":[],"sources":[{"label":"FindAGrave 126757444","url":"https://www.findagrave.com/memorial/126757444/isaac_wadsworth-stiles"},{"label":"New Haven Morning Journal and Courier obit, Feb 11, 1907"}],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"slug":"isaac-stiles-1843"},"I00527":{"id":"I00527","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Margaret","middle_name":"Ella","last_name":"Stiles","maiden_name":"Dickerman","married_names":["Stiles"],"gender":"female","display_name":"Margaret Ella Dickerman Stiles"},"birth":{"year":1846,"month":12,"day":25,"county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1889,"month":10,"day":21,"city":"North Haven","county":"New Haven","state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM293"},"classification":{"is_thomas_