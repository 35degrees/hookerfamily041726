sx":"u","hd":false,"td":false,"ee":false,"g":null}}},"grandchildren":[],"siblings_count":2},"context":{"HD4266":{"id":"HD4266","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Elbert","last_name":"Lyman","married_names":[],"gender":"male","display_name":"Elbert Lyman"},"birth":{"year":1851,"city":"Norwich","county":"Hampshire County","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1851,"city":"Norwich","county":"Hampshire County","state":"Massachusetts","country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00663","mother_id":"HD4245"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_in_infancy","massachusetts_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"elbert-lyman-1851"},"I00663":{"id":"I00663","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"John","middle_name":"Burt","last_name":"Lyman","suffix":"Jr.","married_names":[],"gender":"male","display_name":"John Burt Lyman Jr."},"birth":{"year":1825,"month":12,"day":29,"city":"Norwich (now Huntington)","county":"Hampshire County","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1864,"month":5,"day":22,"city":"Fredericksburg","county":"City of Fredericksburg","state":"Virginia","country":"United States","cause":"Killed in action / died of wounds during Grant's Overland Campaign"},"residence":{},"burial":{"cemetery_id":"CEM348","plot_notes":"Norwich Hill Cemetery Huntington MA — body returned home from Virginia after Civil War death."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Deacon John Burt Lyman Sr.","mother_name":"Ruth Strong Lyman","father_research_notes":"Deacon John Burt Lyman Sr. (1792-1876) — per FA #121993556. Not built per Jalapeño Rule.","mother_research_notes":"Ruth Strong Lyman (1783-1856) — per FA #121993530. POTENTIAL HOOKER DESCENDANT through the extensive Strong family Hooker connections at Northampton MA (43 Strong-surname Hooker descendants in tree). Sam flagged 'cousins through ruth maybe?' — if Ruth Strong descends from the Asahel Strong / Sarah Hooker Strong line, this marriage could be a within-tree cousin marriage. Lineage of this Ruth Strong (b.1783) not yet verified. Not built per Jalapeño Rule pending research."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4245","date_year":1850,"location_state":"Massachusetts","location_country":"United States","end_type":"death_of_spouse","end_year":1861,"children_ids":["HD4266","HD4267","HD4268"]}],"education":[],"career":[],"military_service":[{"war":"American Civil War","war_id":"WAR006","rank_year_end":1864,"unit":"Massachusetts regiment (specific unit undocumented; Hampshire County MA recruitment)","notes":"Civil War veteran (per FA 'Veteran' designation). Died of wounds May 22, 1864 at Fredericksburg Virginia field hospital depot — one day after the Battle of Spotsylvania Court House officially ended (May 8-21). Wounded at Spotsylvania during Grant's Overland Campaign and transported to the Fredericksburg hospital depot, where he died. The Overland Campaign timeline: Battle of the Wilderness May 5-7, Spotsylvania Court House May 8-21, North Anna May 23-26 — Fredericksburg was the major Union field hospital depot receiving wounded from all these battles."}],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["civil_war","massachusetts_migration","killed_in_action"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"military","header":"Civil War death at Fredericksburg, May 22 1864","body":"John Burt Lyman Jr was wounded at Spotsylvania Court House during Grant's Overland Campaign and died of his wounds at the Fredericksburg Virginia field hospital depot on May 22, 1864 — one day after the battle officially ended. He was thirty-eight years old. His body was returned to Massachusetts and buried at Norwich Hill Cemetery Huntington."},{"number":2,"category":"family","header":"Three young orphans left by his battlefield death","body":"His wife Luthena had died at Northampton three years earlier in August 1861. His Civil War death therefore left their three children fully orphaned — the eldest son Asahel Hubert only eleven, the youngest daughter Catherine 'Katie' just four. Their middle child Elbert had already died in infancy in 1851."}],"quotes":[],"sources":[{"label":"FindAGrave memorial #120362403","url":"https://www.findagrave.com/memorial/120362403/john_burt-lyman"}],"research_sources":[],"documents":[],"slug":"john-lyman-jr-1825"},"HD4245":{"id":"HD4245","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Luthena","middle_name":"Elizabeth","last_name":"Lyman","maiden_name":"Ellis","married_names":["Lyman"],"gender":"female","display_name":"Luthena Elizabeth Ellis Lyman"},"birth":{"year":1828,"month":4,"day":10,"city":"Northampton","county":"Hampshire County","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1861,"month":8,"day":26,"city":"Northampton","county":"Hampshire County","state":"Massachusetts","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM348","plot_notes":"Norwich Hill Cemetery, Huntington Hampshire Co MA — with husband John Burt Lyman Jr (KIA Civil War 1864) and daughter Catherine Elizabeth 'Katie' Lyman."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD4234","mother_id":"I00655"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00663","date_year":1850,"location_state":"Massachusetts","location_country":"United States","end_type":"death","end_year":1861,"children_ids":["HD4266","HD4267","HD4268"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["massachusetts_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died young Northampton, three years before husband","body":"Luthena Elizabeth Ellis Lyman died at Northampton Massachusetts on August 26, 1861 at age thirty-three, leaving her husband John Burt Lyman Jr a widower with three young children — the youngest, Catherine 'Katie,' only two years old. Three years later her husband was killed at Fredericksburg Virginia during the Civil War, orphaning all three children."},{"number":2,"category":"family","header":"Daughter of Samuel Ellis, twice-widowed farmer","body":"Luthena's mother Betsey Kirkland Ellis died at twenty-eight in 1832, when Luthena was four — her father Samuel Ellis subsequently remarried Sarah Moore of Worthington. Luthena and her older brother Lathrop, both born in 1828, were the only children of Samuel's first marriage to survive infancy; her two half-siblings from the second marriage both died young."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"luthena-lyman-1828"},"HD4234":{"id":"HD4234","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Samuel","last_name":"Ellis","married_names":[],"gender":"male","display_name":"Samuel Ellis"},"birth":{"year":1802,"month":3,"day":10,"city":"Norwich (now Huntington)","county":"Hampshire County","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1875,"month":3,"day":1,"city":"Cummington","county":"Hampshire County","state":"Massachusetts","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM340","plot_notes":"Dawes Cemetery Cummington Hampshire Co MA — with second wife Sarah Moore Ellis."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00652","mother_id":"H00465"},"number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"I00655","date_year":1825,"location_state":"Massachusetts","location_country":"United States","end_type":"death_of_spouse","end_year":1832,"children_ids":["HD4244","HD4245"]},{"marriage_number":2,"spouse_id":"I00656","location_state":"Massachusetts","location_country":"United States","end_type":"death","end_year":1875,"children_ids":["HD4246","HD4247"]}],"education":[],"career":[{"role":"Farmer","location":"Goshen, Hampshire County, Massachusetts (later Cummington)","end_year":1875,"notes":"Farmer at Goshen Mass. per Edward Ellis Salisbury's 1885 family biographical compilation."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["massachusetts_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Twice-widowed farmer, four children across marriages","body":"Samuel Ellis was a farmer at Goshen and Cummington Massachusetts. He married first Betsey Kirkland in 1825, who died at age twenty-eight in 1832; they had twin children Lathrop Stiles and Luthena Elizabeth, both born February 14, 1828. He later married Sarah Moore of Worthington MA, with whom he had two more children — Jane Betsey (1835-1851, age sixteen) and John Holland (1839-1860, age twenty-one) — both of whom died young."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"samuel-ellis-1802"},"I00655":{"id":"I00655","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Betsey","middle_name":"Kirkland","last_name":"Ellis","maiden_name":"Kirkland","married_names":[],"gender":"female","display_name":"Betsey Kirkland Ellis"},"birth":{"year":1804,"month":2,"day":25,"state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1832,"month":3,"day":3,"state":"Massachusetts","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM338","plot_notes":"Ellis Cemetery, Huntington Hampshire County MA."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4234","date_year":1825,"location_state":"Massachusetts","location_country":"United States","end_type":"death","end_year":1832,"children_ids":["HD4244","HD4245"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["massachusetts_migration"],"research_tags":[],"cros