:[{"number":1,"category":"career","header":"St. Lawrence River hotel owner; first port collector","body":"John Hooker moved his family from Turin to Morristown in the fall of 1815 — a village of only a few houses on the St. Lawrence River — where he bought Arnold Smith's hotel and ran it until 1823. When the town was organized on March 27, 1821, he was appointed overseer of the poor and became its first collector of the port."},{"number":2,"category":"legacy","header":"From Connecticut to Turin to the St. Lawrence","body":"John Hooker left Kensington, Connecticut after his first wife Abigail Goodrich died in 1794, remarried Mary Ives in 1795, and removed the family to Turin, New York in 1802 — then in 1814 to Morristown, beautifully situated on the St. Lawrence River, where he died April 12, 1829."}],"number_of_marriages":2,"slug":"john-hooker-1768"},"I01232":{"id":"I01232","is_placeholder":false,"former_ids":[],"bio":{"display_name":"Abigail Goodrich Hooker","first_name":"Abigail","last_name":"Goodrich","married_names":["Hooker"]},"gender":"female","birth":{"year":1768,"month":10,"day":23,"city":"Kensington","state":"Connecticut","country":"United States"},"death":{"year":1794,"month":7,"day":30,"city":"Kensington","state":"Connecticut","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"is_easter_egg":false},"parents":{},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00535","date_year":1790,"children_ids":["H01435","H01436"]}],"career":[],"education":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{},"residence":{"country":"United States"},"sources":[{"short":"EH 1909","page":"EH #53