 Wood School as a playground — dedicated October 31, 1930. A stone marker placed by local volunteers named it the Lewis Kennedy Morse Playground; the land is now part of Cole School grounds."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM110"},"residence":{"country":"United States"},"sources":[{"short":"FamilySearch + Boxford Historic Document Center"}],"research_sources":[],"slug":"lewis-morse-1869"},"H04378":{"id":"H04378","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Annie Hooker Capron","first_name":"Annie","middle_name":"Hooker","last_name":"Capron","married_names":["Morse"],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779498028/anniehookercapron_igf04o.jpg","photo_notes":"Portrait. Cloudinary collection via Sam."},"gender":"female","birth":{"year":1860,"month":9,"day":17,"city":"Madura","country":"India"},"death":{"year":1909,"month":10,"day":31,"country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"parents":{"father_id":"I01195","mother_id":"H02770"},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01204","spouse_name":"Lewis Kennedy Morse","date_year":1897,"date_month":4,"date_day":21,"children_ids":["HD4949","HD4950"]}],"career":[],"education":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":["named_for_hooker"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Born in South India","body":"Annie Hooker Capron was born September 17, 1860 at Madura in South India — the daughter of Rev. William Capron and Sarah Brown Hooker, who had followed the ABCFM mission to the subcontinent. She married Lewis Kennedy Morse on April 21, 1897 and died October 31, 1909 at forty-nine — leaving two children, Anna Hooker and Arthur Webster Morse."}],"naming_inspiration":[{"name_element":"Hooker","description":"Named Annie Hooker — born in India, honoring the Hooker lineage through her mother Sarah Brown Hooker."}],"quotes":[],"documents":[],"burial":{},"residence":{"country":"United States"},"sources":[{"short":"EH 1909 #4378"},{"short":"Congregational Library Capron Family Papers","page":"https://www.congregationallibrary.org/wp-content/uploads/2023/08/CapronWilliamSarah0044.pdf"}],"research_sources":[],"slug":"annie-capron-1860"}},"burialCemetery":{"id":"CEM556","name":"Village Cemetery","city":"Boxford","county":"Essex","state":"Massachusetts","country":"United States","primary_url":"https://www.findagrave.com/cemetery/91804/village-cemetery","hooker_connections":["HD4949","HD4950","I01205","HD4951","HD4952"],"notes":"Boxford, Essex County MA. FGA Cemetery #91804. Contains: HD4949 Anna Hooker Morse Haynes (1899-1992), HD4950 Arthur Webster Morse (1900-1975), I01205 Winthrop Perrin Haynes (1887-1979), HD4951 Lewis Rogerson Haynes (1926-1946), HD4952 Edward Hamilton Haynes (1928-2018)."},"institutionsById":{},"crossConnections":[]}