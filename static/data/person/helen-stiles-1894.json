ry":"politics","header":"He returned to the legislature after thirty years","body":"A New Haven brickmaker and church warden who filled nearly every town office, he sat in the Connecticut house in 1854 — then again in 1884 and 1885, three decades later. He led the firm I. L. Stiles & Son into his late sixties."},{"number":2,"category":"marriage","header":"He married a Hooker cousin without the name","body":"His first wife, Sophronia Blakeslee, turned out to descend from the same Stiles-Hooker root he did, through a different daughter — a cousin match neither surname revealed."}],"quotes":[],"sources":[{"label":"Stiles book (BIB008) #950/#603"},{"label":"FindAGrave 126791136","url":"https://www.findagrave.com/memorial/126791136/isaac_lorenzo-stiles"}],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"slug":"isaac-stiles-1819"},"HD3948":{"id":"HD3948","former_ids":["I00525"],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Sophronia","middle_name":"Maria","last_name":"Stiles","maiden_name":"Blakeslee","married_names":["Stiles"],"gender":"female","display_name":"Sophronia Maria Blakeslee Stiles","bio_blurb":"New Haven bride of a Hooker cousin"},"birth":{"year":1819,"month":2,"day":16,"city":"North Haven","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1886,"month":11,"day":17,"city":"North Haven","county":"New Haven","state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM293"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00531","mother_id":"H01162","father_research_notes":"Daughter of Anson Blakeslee + Julia (Frost) Blakesle