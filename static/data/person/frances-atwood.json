 #1140a Ebenezer Mix Cowles"}],"research_sources":[],"documents":[],"slug":"frances-atwood"},"neighborhood":{"focus":{"id":"I00385","slug":"frances-atwood","n":"Frances M. Atwood Cowles","by":null,"dy":null,"sx":"u","hd":false,"td":false,"ee":false,"g":null},"spouses":[{"order":1,"spouse":{"id":"HD0984","slug":"ebenezer-cowles-1801","n":"Ebenezer Mix Cowles","by":1801,"dy":null,"sx":"u","hd":true,"td":false,"ee":false,"g":7},"year":1841,"children":[{"id":"HD3774","slug":"florence-werner-1843","n":"Florence Woodruff Cowles Werner","by":1843,"dy":1911,"sx":"u","hd":true,"td":false,"ee":false,"g":8},{"id":"HD3779","slug":"irene-kirkpatrick-1847","n":"Irene Cowles Kirkpatrick","by":1847,"dy":null,"sx":"u","hd":true,"td":false,"ee":false,"g":8},{"id":"HD3780","slug":"clifford-cowles-1860","n":"Clifford Atwood Cowles","by":1860,"dy":1939,"sx":"u","hd":true,"td":false,"ee":false,"g":8}]}],"parents":{},"grandparents":{"paternal":{},"maternal":{}},"grandchildren":[{"id":"HD3775","slug":"edward-werner-jr-1874","n":"Edward Alphonso Werner Jr.","by":1874,"dy":1955,"sx":"u","hd":true,"td":false,"ee":false,"g":9,"via_parent_id":"HD3774"},{"id":"HD3776","slug":"lynn-werner-1877","n":"Lynn Woodruff Werner","by":1877,"dy":1955,"sx":"u","hd":true,"td":false,"ee":false,"g":9,"via_parent_id":"HD3774"},{"id":"HD3777","slug":"florence-brine-1879","n":"Florence Brine","by":1879,"dy":1966,"sx":"u","hd":true,"td":false,"ee":false,"g":9,"via_parent_id":"HD3774"},{"id":"HD3778","slug":"ray-werner-1885","n":"Ray Cowles Werner","by":1885,"dy":1962,"sx":"u","hd":true,"td":false,"ee":false,"g":9,"via_parent_id":"HD3774"},{"id":"HD3781","slug":"clifford-cowles-jr-1890","n":"Clifford Atwood Cowles Jr.","by":1890,"dy":1973,"sx":"u","hd":true,"td":false,"ee":false,"g":9,"via_parent_id":"HD3780"},{"id":"HD3782","slug":"florence-hardisty-1892","n":"Florence Cowles Hardisty","by":1892,"dy":1920,"sx":"u","hd":true,"td":false,"ee":false,"g":9,"via_parent_id":"HD3780"},{"id":"HD3783","slug":"jane-cunningham-1894","n":"Jane Cowles Cunningham","by":1894,"dy":1970,"sx":"u","hd":true,"td":false,"ee":false,"g":9,"via_parent_id":"HD3780"}],"siblings_count":0},"context":{"I00385":{"id":"I00385","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Frances","middle_name":"M","last_name":"Cowles","maiden_name":"Atwood","married_names":["Cowles"],"gender":"female","display_name":"Frances M. Atwood Cowles"},"birth":{},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0984","date_year":1841,"date_month":8,"date_day":2,"location_country":"United States","children_ids":["HD3774","HD3779","HD3780"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["needs_research"],"research_tags":["needs_research"],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"character","header":"Her Atwood family gave her children Mayflower descent","body":"Frances's maiden name Atwood gave her son Clifford his middle name and the family its Mayflower Descendants membership — he was ninth in descent from Pilgrim Richard Warren. She is the ancestral source of the Cowles-Atwood Mayflower thread that runs through Florence, Irene, and Clifford's lines."},{"number":2,"category":"family","header":"Raised three children alone after the Civil War","body":"When the Civil War stripped Ebenezer of everything he had built in Georgia and Alabama, Frances was left to support herself and their children. Her eldest daughter Florence's marriage to Georgia Railroad agent Edward Werner in 1872 became the family's economic anchor in the post-war years."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909 — entry #1140a Ebenezer Mix Cowles"}],"research_sources":[],"documents":[],"slug":"frances-atwood"},"HD0984":{"id":"HD0984","has_descendants_documented":true,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"parents":{"father_id":"H00439","mother_id":"X00268"},"tags":["georgia_migration"],"sources":[{"short":"Cowles Family Genealogy"},{"bib_id":"BIB003"},{"short":"Edward Hooker 1909 — entry #1140a Ebenezer Mix Cowles"}],"birth":{"year":1801,"month":12,"day":12,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"gender":"unknown","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00385","date_year":1841,"date_month":8,"date_day":2,"location_country":"United States","children_ids":["HD3774","HD3779","HD3780"]}],"notable":{"is_notable":false,"notable_category":[]},"death":{"country":"United States"},"cross_connections":[],"bio":{"display_name":"Ebenezer Mix Cowles","first_name":"Ebenezer","last_name":"Cowles","middle_name":"Mix","married_names":[]},"residence":{"city":"Milledgeville","state":"Georgia","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"title":"Merchant","type":"commerce","notes":"Merchant at Milledgeville Georgia per EH #1140a."}],"narrative_blocks":[{"number":1,"category":"family","header":"Lost his Southern fortune in the Civil War","body":"Ebenezer had emigrated from Farmington, Connecticut to Milledgeville, Georgia before 1843 — Georgia's state capital and center of antebellum planter society. By 1860 the family had moved to Huntsville, Alabama. The Civil War erased everything he had built in the South, leaving his widow to support herself and their children alone."},{"number":2,"category":"family","header":"His daughter and son-in-law anchored Atlanta's rail economy","body":"His eldest daughter Florence married Edward A. Werner, a pioneer Atlanta citizen and Georgia Railroad agent who had arrived in Atlanta in 1845. His son Clifford Atwood got his first railroad job as a messenger in Werner's office in 1874, climbing through railroad management positions across the South for the next two decades."},{"number":3,"category":"family","header":"Connecticut native who chose the cotton South","body":"Ebenezer's 1840s move from Farmington, Connecticut to Milledgeville — Georgia's antebellum state capital — followed a pattern of Northern professionals drawn to the cotton-and-rail economy emerging in the Deep South. The choice ran counter to other branches of the Cowles family: his abolitionist Cleveland kinsmen worked the Underground Railroad while he built a life in slaveholding Georgia. The Civil War ended his Southern enterprise and the inheritance it might have left."}],"slug":"ebenezer-cowles-1801"},"HD3774":{"id":"HD3774","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Florence","middle_name":"Woodruff","last_name":"Werner","maiden_name":"Cowles","married_names":["Werner"],"gender":"female","display_name":"Florence Woodruff Cowles Werner"},"birth":{"year":1843,"month":3,"day":6,"city":"Milledgeville","county":"Baldwin County","state":"Georgia","country":"United States"},"baptism":{},"death":{"year":1911,"month":11,"day":29,"state":"Georgia","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM270","plot_notes":"Oakland Cemetery, Atlanta — with husband Edward and all four children"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD0984","mother_id":"I00385","father_name":"Ebenezer Mix Cowles","mother_name":"Frances M. Atwood Cowles"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00425","date_year":1872,"date_month":12,"date_day":19,"location_city":"Huntsville","location_county":"Madison County","location_state":"Alabama","location_country":"United States","end_type":"death","end_year":1911,"children_ids":["HD3775","HD3776","HD3777","HD3778"]}],"education":[{"institution":"Huntsville Female Seminary, Huntsville, Alabama","notes":"Per EH: 'educated at the Huntsville Female Seminary, Huntsville, Ala., a Presbyterian institution, which at that time was foremost in educating young ladies.'"}],"career":[],"military_service":[],"institutions":[{"institution_id":"INST118","role":"student","dates":"1850s-1860s","notes":"Per EH 1909, attended Huntsville Female Seminary."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["georgia_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Born in Georgia's capital, educated in Alabama","body":"Florence was born March 6, 1843 in Milledgeville — Georgia's state capital — and educated at the Huntsville Female Seminary, a Presbyterian institution then foremost in educating young Southern women. She married Georgia Railroad agent Edward Werner in Huntsville in December 1872 and settled permanently in Atlanta."},{"number":2,"category":"family","header":"Her estate sparked a Georgia Supreme Court battle","body":"Florence died November 29, 1911, never having distributed her late husband Edward's estate to their four children. Her son Lynn assumed management without court authority; by 1943 the estate dispute reached the Georgia Supreme Court, where Edward Jr. sued Lynn, Florence, and Ray over property mismanagement and a disputed sale of 528 West Peachtree Street Atlanta."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909, entry #1698 (Florence Woodruff Cowles)","url":"https://archive.org/details/descendantsofrev00hook","accessed":"2026-05"},{"short":"FamilySearch KD7Q-YNP","url":"https://ancestors.familysearch.org/en/tree/person/KD7Q-YNP","accessed":"2026-05"},{"short":"Find a Grave Memorial 97125562","url":"https://www.findagrave.com/memorial/97125562","accessed":"2026-05"},{"short":"Werner v. Werner, 195 Ga. 868 (Ga. Sup. Ct. May 6, 1943, Reid CJ)","accessed":"2026-05"}],"research_sources":[],"documents":[],"slug":"florence-werner-1843"},"I00425":{"id":"I00425","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Edward","middle_name":"Alphonso","last_name":"Werner","suffix":"Sr.","married_names":[],"gender":"male","display_name":"Edward Alphonso Werner Sr."},"birth":{"year":1835,"month":1,"day":15,"state":"South Carolina","country":"United States"},"baptism":{},"death":{"year":1896,"month":6,"day":10,"city":"Atlanta","county":"Fulton County","state":"Georgia","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM270","plot_notes":"Oakland Cemetery, Atlanta"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3774","date_year":1872,"date_month":12,"date_day":18,"location_city":"Madison","location_county":"Madison County","location_state":"Alabama","location_country":"United States","end_type":"death","end_year":1896,"children_ids":["HD3775","HD3776","HD3777","HD3778"]}],"education":[],"career":[{"title":"Pioneer Atlanta citizen + railroad agent","organization":"Macon & Western Railroad; later Georgia Railroad","dates":"1845-1896","type":"railroad","notes":"Arrived Atlanta 1845 at age 10. Originally with Macon & Western Railroad as chief clerk; remained through the Civil War. Later served as agent for the Georgia Railroad for many years. Said to be the first man to record a legal paper on the books of the City of Atlanta. 'Saw Atlanta build up from a little village.' At his 1896 death was one of Atlanta's oldest citizens."}],"military_service":[],"institutions":[],"landmarks":[{"landmark_id":"LM101","role":"resident_owner","notes":"Built Werner home on Washington Street, Atlanta 1870s; home demolished 1912."}],"naming_inspiration":[],"artworks":[],"tags":["railroad"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Pioneer Atlanta citizen since 1845, Georgia Railroad agent","body":"Edward arrived in Atlanta in 1845 when it was barely a village, began as Macon & Western Railroad chief clerk, and remained through the Civil War. He was said to be the first man to record a legal paper in the city's books. He served as Georgia Railroad agent for many years and was one of Atlanta's oldest citizens at his 1896 death."}],"quotes":[],"sources":[{"short":"FamilySearch LCZ9-941","url":"https://ancestors.familysearch.org/en/tree/person/LCZ9-941","accessed":"2026-05"},{"short":"Find a Grave (E.A. Werner Sr, Oakland Cemetery Atlanta)","accessed":"2026-05"},{"short":"Atlanta Historical Society — E.A. Werner Home, Washington Street","accessed":"2026-05"}],"research_sources":[],"documents":[],"slug":"edward-werner-sr-1835"},"HD3775":{"id":"HD3775","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Edward","middle_name":"Alphonso","last_name":"Werner","suffix":"Jr.","married_names":[],"gender":"male","display_name":"Edward Alphonso Werner Jr."},"birth":{"year":1874,"month":9,"day":5,"city":"Huntsville","county":"Madison County","state":"Alabama","country":"United States"},"baptism":{},"death":{"year":1955,"month":5,"day":24,"city":"Atlanta","county":"Fulton County","state":"Georgia","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM270","plot_notes":"Oakland Cemetery, Atlanta"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00425","mother_id":"HD3774","father_name":"Edward Alphonso Werner Sr","mother_name":"Florence Woodruff Cowles Werner"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00426","location_country":"United States","end_type":"divorce_or_death","children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["alabama_migration","georgia_migration","lawyer"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Plaintiff in 1943 Georgia Supreme Court estate suit","body":"Edward Werner Jr. was named plaintiff in the Georgia Supreme Court 1943 estate case Werner versus Werner — number 14530 — in which he sued his brothers Lynn and Ray and sister Florence Brine over their parents' estate. Edward alleged that brother Lynn had mismanaged the estate and appropriated profits from the sale of 528 West Peachtree Street Atlanta. The reported case became part of the published record of mid-twentieth-century Georgia probate law."},{"number":2,"category":"family","header":"Two marriages and three documented children","body":"Edward had two marriages with three documented children. His wife Elizabeth Weakley bore daughters Elisabeth Werner born 1908 and Harriette Werner born 1915; his wife Ethel Margaret Cook of Atlanta bore daughter Elizabeth C. Werner born 1907. The chronological ordering of the two marriages remains unsettled across descendant records."},{"number":3,"category":"family","header":"Huntsville Alabama 1874 to Atlanta Georgia 1955","body":"Edward Werner Jr. was born September 5, 1874 in Huntsville, Madison County Alabama and died May 24, 1955 in Atlanta, Fulton County Georgia at age eighty. He is buried at Oakland Cemetery Atlanta — one of the most prominent nineteenth-century Southern garden cemeteries, holding the graves of Margaret Mitchell, Bobby Jones, and many of Atlanta's founding families."},{"number":4,"category":"family","header":"Hooker descent through mother Florence Cowles Werner","body":"Edward inherited Hooker descent through his mother Florence Woodruff Cowles Werner — the Connecticut Cowles family being one of the major mid-nineteenth-century New England-to-Deep South migration lines that brought Connecticut Yankees south of the Mason-Dixon. His father Edward Alphonso Werner Sr. was a non-Hooker line spouse."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909, entry #3695","url":"https://archive.org/details/descendantsofrev00hook","accessed":"2026-05"},{"short":"FamilySearch MBGM-Q4Q","url":"https://ancestors.familysearch.org/en/tree/person/MBGM-Q4Q","accessed":"2026-05"},{"short":"Find a Grave Memorial 52098668","url":"https://www.findagrave.com/memorial/52098668","accessed":"2026-05"},{"short":"Werner v. Werner, 195 Ga. 868 (1943) — named plaintiff","accessed":"2026-05"}],"research_sources":[],"documents":[],"slug":"edward-werner-jr-1874"},"HD3776":{"id":"HD3776","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"