descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["politics","business","banking"],"notable_blurb":"US Comptroller of Currency 1914-1921","primary_url":"https://en.wikipedia.org/wiki/John_Skelton_Williams","primary_url_label":"Wikipedia — John Skelton Williams"},"parents":{"father_name":"John Langbourne Williams","mother_name":"Maria Ward (Skelton) Williams"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4371","date_year":1895,"location_state":"Virginia","location_country":"United States","end_type":"death","end_year":1926,"children_ids":["HD4373","HD4374"]}],"education":[{"school_name":"University of Virginia","type":"undergraduate","notes":"Educated at Richmond VA and Univ. of Virginia."}],"career":[{"role":"President and organizer","organization":"Seaboard Air Line Railway","start_year":1900,"end_year":1903,"notes":"Organized railroad into single company; first president."},{"role":"First Assistant Secretary of the Treasury","organization":"U.S. Treasury","start_year":1913,"end_year":1914,"notes":"One of first acts: ordered segregation of Bureau of Engraving and Printing work areas."},{"role":"Comptroller of the Currency (13th)","organization":"U.S. Government","start_year":1914,"end_year":1921,"notes":"Ex officio member of original Federal Reserve Board. Appointed by Woodrow Wilson. Reappointed 1919 despite controversy. Resigned Mar 2, 1921."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["banker","federal_reserve","politician","moral_complexity"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Organized Seaboard Air Line; then became Comptroller","body":"Williams organized the Seaboard Air Line into a single railway company and served as its first president from 1900 to 1903, establishing his reputation as a leading Southern financier. President Woodrow Wilson appointed him Comptroller of the Currency in 1914, making him an ex officio member of the newly created Federal Reserve Board."},{"number":2,"category":"legacy","header":"Ordered Treasury segregation; later attacked the Federal Reserve","body":"Among his first acts as Assistant Secretary of the Treasury was ordering the segregation of work areas at the Bureau of Engraving and Printing and ending promotions for Black workers. After resigning as Comptroller in 1921, he became an outspoken critic of the Federal Reserve, charging deliberate deflation against farmers — prompting Congress to form a joint investigative committee."},{"number":3,"category":"career","header":"1920 report exposed insider manipulation of call-money rates","body":"On July 31, 1920, Williams released a detailed public report showing how call-money interest rates were manipulated by insider speculators to the disadvantage of ordinary borrowers nationwide. The statement was published verbatim in a subsequent book, and Williams's aggressive oversight as Comptroller kept him in repeated conflict with the Federal Reserve's leadership."}],"quotes":[],"sources":[{"label":"Wikipedia — John Skelton Williams","url":"https://en.wikipedia.org/wiki/John_Skelton_Williams"},{"label":"Federal Reserve History — John Skelton Williams","url":"https://www.federalreservehistory.org/people/john-skelton-williams"}],"research_sources":[],"documents":[],"slug":"john-williams-sr-1865"},"HD4371":{"id":"HD4371","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Lila","middle_name":"Lefebvre","last_name":"Willingham","maiden_name":"Isaacs","married_names":["Williams","Willingham"],"gender":"female","display_name":"Lila Lefebvre Isaacs Williams-Willingham","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778795336/lilawillingham_dbxktv.png","photo_notes":"Portrait of Lila Lefebvre Isaacs Williams-Willingham"},"birth":{"year":1874,"month":1,"day":24,"city