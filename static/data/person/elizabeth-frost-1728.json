}],"birth":{"year":1771,"city":"North Haven","state":"Connecticut","country":"United States"},"death":{"year":1854,"month":3,"day":4,"city":"North Haven","state":"Connecticut","country":"United States","age":83},"marriages":[{"spouse_id":"X00490","children_ids":["HD1526"],"marriage_number":1}],"cross_connections":[{"type":"longevity","related_id":"X00490","display_label":"Ebenezer Pierpont's wife Lydia Blakeslee (b.1768, d.1863) lived to age.","link_text":"Lydia Blakeslee"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Ebenezer Pierpont","first_name":"Ebenezer","last_name":"Pierpont","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"legacy","header":"His five-thousand-dollar bequest transformed North Haven church","body":"On Ebenezer Pierpont's death in 1854, North Haven Congregational Church 'came into a legacy of five thousand dollars on the death of one of its oldest members.' The bequest was 'a munificent gift and marked the turning point in the history of the church.' His widow Lydia Blakeslee Pierpont added another thousand dollars at her own 1863 death nine years later — six thousand total, a remarkable sum for a mid-century Connecticut parish congregation."},{"number":2,"category":"family","header":"Wife Lydia Blakeslee outlived him by nine years","body":"Ebenezer married Lydia Blakeslee (born July 2, 1768) — daughter of Joel and Elizabeth Sackett Blakeslee. Lydia outlived him by nine years, dying July 22, 1863 in North Haven at age ninety-five, her own thousand-dollar bequest to the church supplementing his earlier five-thousand. The couple's combined legacy effectively endowed the North Haven Congregational Church mid-century operations."},{"number":3,"category":"family","header":"Born and died North Haven, age eighty-three","body":"Ebenezer Pierpont was born in 1771 in North Haven Connecticut and died March 4, 1854 in North Haven at approximately age eighty-three. His entire life unfolded within his birthplace town — a stability characteristic of the eighteenth-and-early-nineteenth-century New Haven County Pierpont families. His wife Lydia would live to ninety-five, an extraordinarily long life for her generation."}],"slug":"ebenezer-pierpont-1771"},"X00490":{"id":"X00490","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1768,"month":7,"day":2},"death":{"year":1863,"month":7,"day":22},"parents":{"father_id":"X00478"},"tags":[],"sources":[{"short":"Online vital records / Pierpont genealogy"}],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1429","children_ids":["HD1526"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Lydia Blakeslee","first_name":"Lydia","maiden_name":"Blakeslee","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"lydia-blakeslee-1768"},"HD1526":{"id":"HD1526","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1429","mother_id":"X00490"},"birth":{"year":1795},"death":{"year":1821},"tags":[],"sources":[],"gender":"female","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Rox