landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died Charleston South Carolina age thirty","body":"William Walter Jr. died October 6, 1817 in Charleston, South Carolina at age thirty — four days short of his thirty-first birthday. His body was returned to New Haven Connecticut for burial at Grove Street Cemetery. The Charleston-to-New Haven body return tracks the established New England merchant-and-professional travel patterns of the period, when business interests took young New Englanders to southern coastal cities."},{"number":2,"category":"family","header":"Three young children at his death","body":"William Jr. left three young children at his 1817 death: Ann K. (age 5), Lavinia (already deceased as an infant in 1815), and Theodocia Pierpoint (born about a year before his death). His wife Nancy Kirby continued raising the surviving children before her own death in 1830 at age thirty-nine."}],"slug":"william-walter-jr-1786"},"H00869":{"id":"H00869","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00365","mother_id":"X00455"},"tags":[],"sources":[{"short":"Edward Hooker 1909","entry":"869"},{"short":"Pierpont genealogy"}],"birth":{"year":1760,"month":6,"day":2,"city":"North Haven","state":"Connecticut"},"death":{"year":1795},"gender":"female","marriages":[{"spouse_id":"X01652","children_ids":[],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mehitable Pierpont Blakeslee","first_name":"Mehitable","last_name":"Blakeslee","maiden_name":"Pierpont","married_names":["Blakeslee"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"na