emale"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died thirty days after her April marriage","body":"Louisa Walter married Timothy Bishop on April 3, 1800 and died on May 3, 1800 at age nineteen — about thirty days after the marriage, with no children. The compressed marriage-and-death cycle within a single calendar month was striking even by the period's standards of vulnerability to acute disease. Her husband Timothy lived another seventy-three years and remarried twice."},{"number":2,"category":"family","header":"Buried Grove Street Cemetery, New Haven","body":"Louisa is buried at Grove Street Cemetery in New Haven, Plot 11 Cypress Avenue East. The cemetery — one of America's first planned burial grounds and a National Historic Landmark — became the family-burial cluster for the Walter-Pierpont line, with her parents William Jay Walter and Theodosia and several siblings later joining her there."}],"slug":"louisa-bishop-1780"},"HD5100":{"id":"HD5100","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"generation_from_thomas":7,"is_easter_egg":false},"parents":{"father_id":"X01651","mother_id":"H00868"},"tags":[],"sources":[],"marriages":[],"number_of_marriages":0,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1782},"death":{"year":1821,"age":39},"cross_connections":[],"bio":{"display_name":"Lovina Walter","first_name":"Lovina","last_name":"Walter","married_names":[],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"