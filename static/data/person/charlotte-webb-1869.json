ges":[{"spouse_id":"HD1914","children_ids":["HD1921","HD1928","HD1929","HD1930","HD1931"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Francis Webb","first_name":"Francis","last_name":"Webb","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"francis-webb-1788"},"HD1914":{"id":"HD1914","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1788},"death":{"year":1878,"month":8,"day":16,"city":"Philadelphia","state":"Pennsylvania"},"parents":{"father_id":"H00913","mother_id":"X00619"},"marriages":[{"spouse_id":"X00620","children_ids":["HD1921","HD1928","HD1929","HD1930","HD1931"],"marriage_number":1,"date_year":1817}],"tags":["dna_confirmed_2018","unacknowledged_by_burr"],"sources":[{"short":"Wikipedia","note":"Aaron Burr — children section"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Louisa Charlotte Burr Darius","nickname":"Louisa","first_name":"Louisa","last_name":"Darius","married_names":["Webb","Darius"],"middle_name":"Charlotte","maiden_name":"Burr"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"DNA confirmed her Burr paternity 230 years later","body":"Louisa Charlotte Burr was born around 1788 in Philadelphia to Mary Emmons, during Aaron Burr Jr.'s marriage to Theodosia Bartow Prevost — and Burr kept the relationship hidden. Her descent was suspected for two centuries but only formally confirmed in 2018, when DNA evidence accepted by the Aaron Burr Association established her paternity beyond doubt. She lived to roughly ninety, dying August 16, 1878 in Philadelphia."},{"number":2,"category":"character","header":"Age fifteen, saved Philadelphia mansion from circus fire","body":"Working as a servant for the prominent Philadelphia family of Elizabeth Powel Francis Fisher and her sister Sophia Francis Harrison, Louisa at about age fifteen helped save the Harrison mansion from a 1799 circus fire by soaking blankets and carpets to smother the flames. She later nursed Joshua Fisher, born 1807, who grew deeply attached to her. Upon his 1873 death his estate provided her an annuity and a funeral fund — recognition outside any acknowledged Burr legacy."},{"number":3,"category":"family","header":"Wrote father Burr for Theodosia's portrait miniature","body":"Letters from Louisa to her unacknowledged father Aaron Burr survived among his papers. In one she asked him to lend a miniature portrait of his 'beloved Theodosia' — half-sister Theodosia Burr Alston, lost at sea in 1813 — so that brother John Pierre Burr could copy it. The three unacknowledged Burr children — Louisa, John Pierre, and the recognized Theodosia — had a documented sibling relationship across the color line that Burr never publicly acknowledged."}],"slug":"louisa-darius-1788"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}