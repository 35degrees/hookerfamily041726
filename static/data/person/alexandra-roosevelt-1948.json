descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":true,"is_easter_egg":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"generation_from_thomas":10},"notable":{"is_notable":true,"notable_category":["military","politics"],"notable_blurb":"Medal of Honor general; eldest Roosevelt son","primary_url":"https://en.wikipedia.org/wiki/Theodore_Roosevelt_Jr.","primary_url_label":"Wikipedia"},"parents":{"father_id":"X00744","mother_id":"HD6083"},"marriages":[{"spouse_id":"I01654","children_ids":["HD6091","HD6092","HD6093","HD6094"],"marriage_number":1,"marriage_year":1910}],"tags":["wwi","wwii","army","general","medal_of_honor","silver_star"],"narrative_blocks":[{"category":"military","header":"Only general in D-Day's first wave","body":"At fifty-six, with a heart condition and walking with a cane, Roosevelt was the only general to land with the first wave at Utah Beach on June 6, 1944. He died of a heart attack five weeks later and received the Medal of Honor posthumously.","number":1},{"category":"military","header":"He turned a landing error into a foothold","body":"When the first craft drifted a mile south of their mark, he walked the fire-swept beach, met each arriving regiment, and improvised the attack from where they actually stood. Bradley later called it the bravest thing he saw in the war.","number":2},{"category":"legacy","header":"A father-son Medal of Honor, a century apart","body":"His posthumous Medal of Honor and his father's, awarded at last in 2001 for San Juan Hill, made the Roosevelts only the second father and son both to earn it. The other pair were the two MacArthurs.","number":3},{"category":"family","header":"Father and son both hit the beaches","body":"He was the only father to land with a son on D-Day; his boy Quentin came ashore at Omaha while he led at Utah. The family's soldiering instinct had carried into a second world war.","number":4},{"category":"death","header":"Dead of a heart attack five weeks later","body":"He never saw the medal coming; a heart attack killed him in Normandy about five weeks after the landing. He was buried near the front and later moved to lie beside his brother Quentin, lost flying in the first war.","number":5}],"sources":[],"institutions":[{"institution_id":"INST062","relationship":"alumnus"},{"institution_id":"INST002","relationship":"alumnus"}],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Theodore","last_name":"Roosevelt","display_name":"Brig. Gen. Theodore Roosevelt Jr.","gender":"male","bio_blurb":"Medal of Honor general; eldest Roosevelt son","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780965398/5998_127893647434_w79wi7.jpg","suffix":"Jr."},"military_service":[{"war":"World War I","branch":"United States Army","rank":"Lieutenant Colonel","unit":"26th Infantry Regiment, 1st Infantry Division","awards":"Distinguished Service Cross; French Croix de Guerre","notes":"Wounded at Soissons and gassed at Cantigny."},{"war":"World War II","branch":"United States Army","rank":"Brigadier General","unit":"Assistant Division Commander, 4th Infantry Division","awards":"Medal of Honor (posthumous, presented to his widow September 1944)","notes":"Operation Torch (North Africa), Tunisia, and Sicily before leading the first wave ashore at Utah Beach on D-Day; died of a heart attack at Meautis, France, July 12, 1944."}],"career":[{"role":"Co-founder","organization":"The American Legion","start_year":1919},{"role":"Member","organization":"New York State Assembly","start_year":1920,"end_year":1921},{"role":"Assistant Secretary of the Navy","organization":"United States Navy","start_year":1921,"end_year":1924},{"role":"Governor","organization":"Puerto Rico","start_year":1929,"end_year":1932},{"role":"Governor-General","organization":"Philippines","start_year":1932,"end_year":1933},{"role":"Chairman of the Board","organi