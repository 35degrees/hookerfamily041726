uilt. The Promenade as it exists today follows the route he proposed."},{"number":4,"category":"career","header":"Pirates seized his ship and bankrupted him","body":"The Confederacy was taken at sea in 1797 carrying his firm's cargo. The loss ended his Paris-based mercantile career and forced him home to start again."},{"number":5,"category":"character","header":"Witnessed Robespierre's execution from the crowd","body":"He spent seven years in France during the 1790s tending his firm's shipments. He was in Paris for the Reign of Terror and saw the head of the Jacobin regime guillotined."}],"slug":"hezekiah-pierpont-1768"},"HD1550":{"id":"HD1550","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1773},"death":{"year":1773},"parents":{"father_id":"H00388","mother_id":"X00494"},"marriages":[],"tags":["died_in_infancy"],"sources":[],"gender":"female","notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sarah Pierpont","first_name":"Sarah","maiden_name":"Pierpont","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-pierpont-1773"},"H00977":{"id":"H00977","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1770,"month":6,"day":22,"city":"New Haven","state":"Connecticut"},"death":{"year":1772,"city":"New Haven","state":"Connecticut"},"parents":{"father_id":"H00388","mother_id":"X00494"},"marriages":[],"tags":