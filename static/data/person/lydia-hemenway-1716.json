hospital","body":"During the 1779 British invasion of New Haven, soldiers raided the house her husband John Pierpont had built and took it for use as a hospital and headquarters. The home stood at the center of the town's worst wartime days."},{"number":3,"category":"military","header":"Her brother guarded the captured spy Major André","body":"Sarah's brother, Captain Nathan Beers, commanded the guard over the British spy Major John André at his trial and execution in 1780. André's hanging, in the wake of Benedict Arnold's treason, was among the most talked-of events of the war."}],"slug":"sarah-beers-1744"},"H00451":{"id":"H00451","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1760,"month":4,"day":1,"city":"North Haven","state":"Connecticut"},"parents":{"father_id":"H00238","mother_id":"I00158"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 451"}],"marriages":[{"children_ids":["HD0558","HD0559","HD0560","HD0561","HD0562","HD0563"],"spouse_id":"H00388","marriage_number":1,"date_year":1789,"date_month":2,"date_day":26}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"death":{},"cross_connections":[],"bio":{"display_name":"Ruth Stiles","first_name":"Ruth","maiden_name":"Stiles","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ruth-stiles-1760"},"H00976":{"id":"H00976","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_desce