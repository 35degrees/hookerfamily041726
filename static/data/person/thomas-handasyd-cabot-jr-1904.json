lse,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":false,"generation_from_john_talcott":7},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"TD0334","father_name":"Raphael Pumpelly","mother_id":"I01540","mother_name":"Eliza Frances Shepard Pumpelly"},"number_of_marriages":1,"marriages":[{"spouse_id":"I01542","spouse_name":"Thomas Handasyd Cabot","children_ids":["TD0342","TD0343","TD0344"],"marriage_year":1898}],"tags":[],"narrative_blocks":[],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"in_law","related_id":"X03117","display_label":"was her father-in-law; Architect and Emerson's first biographer"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Elise","last_name":"Cabot","married_names":[],"display_name":"Elise Pumpelly Cabot","gender":"female"},"military_service":[],"burial":{"cemetery_name":"Dublin Town Cemetery","city":"Dublin","county":"Cheshire County","state":"New Hampshire","country":"United States"},"slug":"elise-cabot-1875"},"X03117":{"id":"X03117","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","birth":{"year":1821,"month":6,"day":18,"city":"Boston","state":"Massachusetts","country":"United States"},"death":{"year":1903,"month":1,"day":17,"city":"Brookline","state":"Massachusetts","country":"United States"},"burial":{"cemetery_name":"Walnut Hills Cemetery","city":"Brookline","state":"Massachusetts","country":"United States"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"is_easter_egg":true},"notable":{"is_notable":true,"notable_category":["arts","literature"],"notable_blurb":"Architect and Emerson's first biographer","primary_url":"https://www.walden.org/what-we-do/library/the-transcendentalists-their-lives-writings/james-elliot-cabot-1821-1903/","primary_url_label":"The Thoreau Society / Walden Woods"},"parents":{},"number_of_marriages":1,"marriages":[{"spouse_id":"X03118","spouse_name":"Elizabeth \"Lizzie\" Dwight Cabot","marriage_year":1857,"children_ids":["I01542"]}],"tags":["author","harvard_graduate","architect"],"narrative_blocks":[{"category":"literature","header":"He wrote the first life of Emerson","body":"A close friend of Ralph Waldo Emerson, James Elliot Cabot served as his literary executor and wrote the first authorized biography, A Memoir of Ralph Waldo Emerson (1887). He had earlier helped found the Atlantic Monthly.","number":1},{"category":"arts","header":"A reluctant lawyer who turned to architecture","body":"Harvard College and Harvard Law trained, Cabot found trial work daunting and left the bar. He joined his brother Edward's architectural practice, designing buildings and helping run the office.","number":2},{"category":"arts","header":"He gave Boston's museum its plaster casts","body":"An early trustee of the Museum of Fine Arts, Cabot championed acquiring plaster casts of famous Greek and Roman statues. He believed the young museum would never afford originals, and also served the Boston Athenaeum.","number":3},{"category":"literature","header":"His first essay graced the final Dial","body":"Cabot's essay on Immanuel Kant opened the last issue of The Dial in April 1844, his first appearance in print. He later helped edit the short-lived Massachusetts Quarterly Review alongside Emerson and Theodore Parker.","number":4}],"sources":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus and overseer","years":"1840"}],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"in_law","related_id":"TD0336","display_label":"married his son Thomas"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"James Elliot","last_name":"Cabot","married_names":[],"display_name":"James Elliot Cabot","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780763461/59686021_134437993477_xntkj2.jpg"},"military_service":[],"education":[{"institution_id":"INST002","dates":"1840","type":"college","degree":"A.B."},{"institution_name":"Harvard Law School","dates":"1845","type":"law_school","degree":"LL.B."}],"slug":"james-elliot-cabot-1821"},"X03118":{"id":"X03118","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"female","birth":{"year":1830,"month":2,"day":13,"country":"United States"},"death":{"year":1901,"month":12,"day":12,"city":"Brookline","state":"Massachusetts","country":"United States"},"burial":{"cemetery_name":"Walnut Hills Cemetery","city":"Brookline","state":"Massachusetts","country":"United States"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"include_in_path_calculation":false,"is_easter_egg":true},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Jonathan Dwight (1743–1831)","mother_name":"Margaret Ashley"},"number_of_marriages":1,"marriages":[{"spouse_id":"X03117","spouse_name":"James Elliot Cabot","marriage_year":1857,"children_ids":["I01542"]}],"tags":[],"narrative_blocks":[{"category":"family","header":"She taught her seven sons their letters","body":"Elizabeth Dwight Cabot raised seven sons with James Elliot Cabot, teaching each their letters, numbers, and geography before regular school. All seven went on to graduate from Harvard College."}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Elizabeth","last_name":"Dwight","married_names":[],"display_name":"Elizabeth \"Lizzie\" Dwight Cabot","gender":"female","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780763622/Dwight-899_pn13yg.jpg"},"military_service":[],"slug":"elizabeth-dwight-1830"},"TD0334":{"id":"TD0334","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"gender":"male","birth":{"year":1837,"month":9,"day":8,"city":"Owego","state":"New York","country":"United States"},"baptism":{},"death":{"year":1923,"month":8,"day":10,"city":"Newport","state":"Rhode Island","country":"United States"},"burial":{},"residence":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":6,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["science","exploration"],"notable_blurb":"Geologist and explorer of Asia's interior","primary_url":"https://en.wikipedia.org/wiki/Raphael_Pumpelly","primary_url_label":"Wikipedia"},"parents":{"father_id":"I01523","father_name":"William Pumpelly","mother_id":"T01812","mother_name":"Mary H. Welles"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_name":"Eliza F. Shepard","date_year":1869,"spouse_id":"I01540","children_ids":["TD0335","TD0336","TD0337"]}],"tags":[],"narrative_blocks":[{"number":1,"category":"science","header":"He mapped Asia's deserts for American science","body":"Trained as a mining engineer, Raphael Pumpelly surveyed mineral country across Japan, China, and Mongolia in the 1860s and crossed the Gobi Desert. His later expeditions into Russian Central Asia searched for the origins of agriculture and early civilization."},{"number":2,"category":"science","header":"He tied windblown dust to climate history","body":"Pumpelly's studies of loess, the fine wind-laid soil of northern China, helped show how such deposits record ancient climate. At home he directed the northern transcontinental railroad survey and led major government geological surveys."},{"category":"career","header":"He held Harvard's first chair in mining","body":"From 1866 to 1875 Pumpelly served as Harvard's first professor of mining, between expeditions that carried him around the world. He later organized the economic-geology division of the new U.S. Geological Survey and directed its New England branch.","number":3},{"category":"science","header":"His Anau dig pushed Central Asian history back","body":"In 1903 Pumpelly led a Carnegie-funded expedition to the Anau mounds in Turkmenistan, uncovering a settlement he dated to about 4500 BCE. The mineral pumpellyite, found in Michigan's copper country, was later named in his honor.","number":4},{"category":"legacy","header":"He blazed the Pumpelly Trail up Monadnock","body":"From his summer place at Dublin, New Hampshire, Pumpelly cut a ridge trail to the summit of Mount Monadnock that still carries his name. He spent his last decades at Newport and presided over the Geological Society of America in 1905.","number":5}],"sources":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"family_connection","display_label":"descends from Springfield's founder William Pynchon","related_id":"Y00004","link_text":"Hon. William Pynchon"},{"type":"family_connection","display_label":"descends from Connecticut governor Thomas Welles","related_id":"X02354","link_text":"Gov. Thomas Welles"},{"type":"parallel_careers","display_label":"the mineralogist in whose system pumpellyite is classed","related_id":"X00898","link_text":"Edward Salisbury Dana"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Raphael","last_name":"Pumpelly","married_names":[],"display_name":"Raphael Pumpelly","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780757921/18514323_ba588cd9-8d5f-46cb-89d2-794a87890734_j2tjyt.jpg"},"military_service":[],"education":[{"school_name":"Bergakademie Freiberg","dates":"1856-1859","type":"graduate","notes":"Mining engineering."}],"career":[{"role":"Geologist & explorer","organization":"Surveys of Japan, China, Mongolia","start_year":1861,"notes":"Mining & geological surveys."},{"role":"Director","organization":"Northern Transcontinental Survey","notes":"Railroad route survey."}],"slug":"raphael-pumpelly-1837"},"I01540":{"id":"I01540","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"female","birth":{"year":1840,"month":3,"day":14,"city":"Dorchester","county":"Suffolk County","state":"Massachusetts","country":"United States"},"death":{"year":1915,"month":2,"day":5,"city":"Newport","county":"Newport County","state":"Rhode Island","country":"United States"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Otis Shepard","mother_name":"Ann Pope"},"number_of_marriages":1,"marriages":[{"spouse_id":"TD0334","spouse_name":"Raphael Pumpelly","marriage_year":1869,"marriage_place":"Dorchester, Massachusetts","children_ids":["TD0335","TD0336","TD0337"]}],"tags":[],"narrative_blocks":[{"category":"arts","header":"John Singer Sargent painted her portrait","body":"In 1887 John Singer Sargent painted a waist-length portrait of Eliza Shepard Pumpelly, now held by the Berkshire Museum. She had married the geologist Raphael Pumpelly in 1869 and shared his homes at Newport and in the New Hampshire hills.","number":1}],"sources":[],"institutions":[],"landmarks":[],"artworks":[{"artwork_id":"ART070","role":"subject"}],"research_tags":[],"cross_connections":[{"type":"artifact","related_id":"I01660","display_label":"also drawn by John Singer Sargent"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":