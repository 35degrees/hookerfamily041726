:"Ruth Hooker was born November 2, 1784 in Poultney, Vermont — fourteen days before her mother Ruth Hickok Hooker died on November 16, 1784, leaving the infant motherless before she was a month old. She was the sole child of Captain Thomas Hooker's second marriage, and her existence was the last thing her mother witnessed; she went on to marry Rev. Sylvester Perkins in October 1805 and raised at least seven children in New York and Illinois, dying at Cortland, Illinois in September 1864 at seventy-nine, eighty years after the mother she never knew."}],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM515","plot_notes":"Mound Rest Cemetery Cortland DeKalb County Illinois per FA"},"slug":"ruth-perkins-1784"}},"burialCemetery":{"id":"CEM520","name":"Elmwood Cemetery","location":{"city":"Sycamore","county":"DeKalb County","state":"Illinois","country":"United States"},"url":"https://www.findagrave.com/cemetery/105569/elmwood-cemetery","hooker_connections":["HD4791","I01059"]},"institutionsById":{},"crossConnections":[]}