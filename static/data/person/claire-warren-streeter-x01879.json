_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"World War II","war_id":"WAR008","side":"United States","rank":"Naval Aviator","unit":"United States Naval Air Force","notes":"Awarded Distinguished Flying Cross for heroism and extraordinary achievement in aerial flight during World War II."}],"narrative_blocks":[{"number":1,"category":"character","header":"Bought blue school bus, drove to Costa Rica","body":"In retirement John Pierpont Woods bought a blue school bus, loaded his possessions and his dog into it, and drove to Costa Rica — where he lived for seven years before returning north to settle in Harpswell Maine. The deliberate post-career adventure stood in sharp contrast to the conventional retirement of his American Airlines pilot and Connecticut General Assembly representative careers. He spoke fluent Spanish, French, German, and Chinese."},{"number":2,"category":"military","header":"Distinguished Flying Cross, Naval Air Force WWII","body":"John served in the United States Naval Air Force during World War II and was awarded the Distinguished Flying Cross for 'heroism and extraordinary achievement in aerial flight.' He then became an American Airlines pilot for a long civilian aviation career, followed by Director of Operations and Air Traffic Control at the National Business Aircraft Association until his 1980 retirement. The military-to-civilian-aviation arc was characteristic of his mid-century Naval Air Force generation."},{"number":3,"category":"character","header":"Set world swim records into his nineties","body":"John ran marathons and was a master swimmer who set world records in his age category into his nineties. The lifelong-athleticism extended his physical practice five decades beyond most men's competitive careers. He died at age ninety-four in Harpswell Maine, still active in the master-swimming community into his final years."},{"number":4,"category":"family","header":"NYC 1918 to Harpswell Maine 2012 age ninety-four","body":"John Pierpont Woods was born February 6, 1918 in New York City and died May 23, 2012 in Harpswell, Cumberland County Maine at age ninety-four. He was a Brooks School 5th-graduating-class alumnus and Harvard University graduate. His mother was Helen Morgan Hamilton Burgess, the WAC Lt. Colonel Deputy Director during World War II."}],"slug":"john-woods-1918"},"HD1244":{"id":"HD1244","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":12,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1234","mother_id":"X01879"},"tags":["living_or_recent"],"sources":[{"short":"Obituary, John Pierpont Woods, May 2012"}],"gender":"female","marriages":[{"spouse_id":"X01456","children_ids":[],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Julie Woods McCarthy","first_name":"Julie","last_name":"McCarthy","maiden_name":"Woods","married_names":["McCarthy"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"julie-mccarthy"},"X01456":{"id":"X01456","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1244","children_ids":[]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"