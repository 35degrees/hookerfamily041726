"tags":["engineer","extraordinary_longevity","author"],"narrative_blocks":[{"category":"science","header":"Naval engineer who designed anti-aircraft systems","body":"An electrical engineer trained at Columbia, Trevor led development of shipborne anti-aircraft control systems at the Naval Research Laboratory during World War II. The Navy awarded him its Meritorious Civilian Service Award in 1945.","number":1},{"category":"politics","header":"He directed the Pioneer Fund for decades","body":"Trevor spent decades as a director and treasurer of the Pioneer Fund, a backer of race science, and carried on his father's immigration-restriction work. Testifying in 1965, he warned that mixing racial and ethnic groups would bring cultural decline.","number":2},{"category":"legacy","header":"Genealogist, sailor, and Trudeau Institute trustee","body":"Trevor was a past president of the New York Genealogical and Biographical Society and a trustee of the Trudeau Institute for twenty-two years. A lifelong sailor, he co-authored a book on yacht racing and was the oldest member of the Union Club at his death.","number":3}],"sources":[],"institutions":[{"institution_id":"INST164","relationship":"trustee"}],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"John B.","last_name":"Trevor","display_name":"John B. Trevor Jr.","gender":"male","bio_blurb":"Naval engineer and Pioneer Fund director","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780944664/486801118_1182907373342417_7862652821818757317_n_kurgui.jpg","suffix":"Jr."},"military_service":[],"career":[],"birth":{"year":1909,"country":"United States","city":"New York","state":"New York"},"death":{"year":2006,"country":"United States","city":"Paul Smiths","state":"New York"},"burial":{"cemetery_id":"CEM112"},"education":[],"slug":"john-b-trevor-jr-1909"}},"burialCemetery":{"id":"CEM112","name":"Woodlawn Cemetery","ci