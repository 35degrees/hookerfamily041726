arch_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Grandson of the Northern Pacific Railway's president","body":"His grandfather Thomas Fletcher Oakes (1843-1919) entered railway service in 1863 and rose to the presidency of the Northern Pacific from 1888 to 1893, after starting on the Kansas Pacific. The line that he ran from the Great Lakes to Puget Sound was central to the Pacific Northwest's transformation from frontier to settled commerce."}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Thomas","middle_name":"Fletcher","last_name":"Oakes","married_names":[],"display_name":"Thomas Fletcher Oakes"},"military_service":[],"slug":"thomas-oakes-1900"},"TD0053":{"id":"TD0053","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":9,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":true,"is_thomas_descendant":true,"is_easter_egg":false},"birth":{"year":1915,"month":4,"day":16,"city":"New Britain","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":2009,"month":5,"day":7,"city":"Bloomfield","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"TD0052","mother_id":"TD0050"},"marriages":[{"marriage_number":1,"spouse_id":"I00214","date_year":1938,"date_month":5,"date_day":20,"location_city":"New Britain","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","officiant":"Rev. Theodore Ainsworth Greene and Rev. Dr. Frank Lattimer Janeway","end_type":"death_of_spouse","end_year":1994,"children_ids":["TD0113"]}],"sources":[{"label":"Frances (Stanley) Stout obituary, Hartford Courant, May 2009"},{"label":"NYT wedding announcement, April 25, 1938"},{"label":"FindAGrave"}],"gender":"female","tags":["hooker_talcott_descent","extraordinary_longevity"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"burial":{"cemetery_id":"CEM127","plot_notes":"Old St. Andrew's Church Cemetery, 59 Tariffville Road, Bloomfield CT. Died at Caleb Hitchcock Health Center, Bloomfield."},"baptism":{},"institutions":[{"institution_id":"INST083","institution_blurb":"Attended The Oxford School before Ethel Walker."},{"institution_id":"INST082","institution_blurb":"Graduated Ethel Walker School (sister TD0073 Jeanne also attended)."}],"narrative_blocks":[{"number":1,"category":"family","header":"In 1938 her divorced sister was her matron","body":"At Frances's wedding on May 20, 1938, her sister Jeanne — \"Mrs. Thomas F. Oakes of Bloomfield\" — served as matron of honor. Jeanne would divorce Thomas Oakes within two years, move alone to Manhattan, and die in her apartment on December 12, 1942, at age 29."},{"number":2,"category":"character","header":"Fifty years sailing the Bahamas on the Anne","body":"Frances and her husband Jack Stout began cruising to the Bahamas in 1966 aboard their 40-foot ketch, Anne Bonny — a name with a touch of piracy. They bought a house on Man-O-War Cay in the Abacos in 1972 and named it too Anne Bonny, making \"many intrepid Gulf Stream crossings for boat work and supplies.\" After Jack's death in 1994 she kept sailing to the Bahamas alone until 2006, when — as she said — \"the stairs became a bit too steep.\""},{"number":3,"category":"legacy","header":"Local and national recognition for her daffodil collection","body":"A lifelong member of the Garden Club of Hartford, Frances received both local and national recognition for her remarkable daffodil collection. Her obituary notes she \"was delighted, in this, her final season, by copious bouquets from her own planting.\" She was also a dedicated birdwatcher, skier, and tennis player."}],"bio":{"display_name":"Frances Stanley Stout","first_name":"Frances","last_name":"Stout","married_names":["Stout"],"middle_name":"Tal