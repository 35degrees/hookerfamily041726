nn.","number":2},{"category":"family","header":"His son married into the Hooker-Talcott line","body":"Stanley's son Philip married Helen Hooker Talcott, knitting the toolmaking family into the Hooker and Talcott descent. The Stanley name thus enters the tree by marriage as well as by industry.","number":3}],"sources":[{"label":"Political Graveyard — Timothy Wadsworth Stanley","url":"https://politicalgraveyard.com/bio/stanley.html#397.75.66"},{"label":"Historic Buildings of Connecticut — Timothy Wadsworth Stanley House","url":"https://historicbuildingsct.com/timothy-wadsworth-stanley-house-1860/"},{"label":"Official souvenir and program, dedication Soldiers' Monument, New Britain CT, Sept 19 1900 (J.W. Ringrose)"},{"label":"FindAGrave"}],"institutions":[{"institution_id":"INST111","relationship":"founder","years":"1857-1897","institution_blurb":"Co-founder and original incorporator in 1857."},{"institution_id":"INST085","relationship":"founder","years":"1858-1897","institution_blurb":"Original incorporator of the New Britain Institute in 1858 (later NBMAA)."}],"naming_inspiration":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"civic_peer","related_id":"H03203","display_label":"Both incorporated the New Britain Institute in 1858","link_text":"John B Talcott"},{"type":"professional_peer","display_label":"built Stanley hardware as Bradley built Meriden lamps","related_id":"I01253","link_text":"Nathaniel Lyman Bradley"},{"type":"in_law","related_id":"TD0050","display_label":"married his son Philip in 1911"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Timothy","middle_name":"Wadsworth","last_name":"Stanley","married_names":[],"display_name":"Timothy Wadsworth Stanley","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777583216/timothystanley_gcgy9n.png","photo_notes":"Portrait. Cloudinary."},"military_service":[],"slug":"timothy-stanley-1817"},"I00213":{"id":"I00213","former_ids":[],"is_placeholder"