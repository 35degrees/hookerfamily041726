d the Community Chest (now United Way) in 1953 and was Life Trustee of the Greater Hartford Boys and Girls Club. He and Frances (\"Francie\") sailed their 40-foot ketch Anne Bonny between New England and the Bahamas beginning in 1966, buying a house on Man-O-War Cay in the Abacos in 1972."},{"number":2,"category":"character","header":"Sailed New England to the Abacos every year","body":"John kept a home at Man-o-War Cay in the Bahamas Abacos and sailed there from New England most years through his life as a member of the Cruising Club of America. He was a Hartford banker and trust officer by profession, but the sea was his second life."}],"sources":[{"label":"John D. Stout Jr. obituary, Hartford Courant, April 1994"},{"label":"FindAGrave"}],"institutions":[{"institution_id":"INST023","relationship":"alumnus","years":"1929-1933","institution_blurb":"Princeton 1933, Quadrangle Club."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"John","middle_name":"Deming","last_name":"Stout","married_names":[],"suffix":"Jr.","nickname":"Jack","display_name":"John Deming Stout Jr."},"military_service":[],"slug":"john-stout-jr-1911"},"TD0113":{"id":"TD0113","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"display_name":"Samuel Deming Stout","first_name":"Samuel","middle_name":"Deming","last_name":"Stout","married_names":[]},"birth":{"country":"United States"},"baptism":{},"death":{"country":"United States"},"residence":{},"burial":{},"gender":"male","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":true,"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":11,"generation_from_john_talcott":11,"is_easter_egg":false,"descent_paths_to_thomas":1},"parents":{"father_id":"I00214","moth