r":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died at thirty; infant Joseph eight months old","body":"Ann Hooker Congdon married Joseph Congdon on October 2, 1823 and bore six children in eleven years; her youngest, Joseph, was born April 17, 1834, and she died December 17 that same year at Freedom, New York, at thirty years old — leaving an eight-month-old infant among her surviving children. Her husband Joseph Congdon outlived her by thirty-eight years, dying at Elmira in 1872; the eldest child she had named 'James Hooker' had himself died nine months before that, in May 1865, leaving her family's history as a study in how early death cascades through a generation."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"ann-congdon-1804"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}