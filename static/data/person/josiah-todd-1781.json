s":["HD1772"],"marriage_number":1}],"tags":[],"sources":[],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sereno Edwards Todd Jr.","first_name":"Sereno","last_name":"Todd","suffix":"Jr.","middle_name":"Edwards","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sereno-todd-jr-1850"},"HD1758":{"id":"HD1758","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1855},"death":{"year":1939},"parents":{"father_id":"HD1753","mother_id":"X00567"},"marriages":[{"spouse_id":"X00568","children_ids":["HD1759"],"marriage_number":1,"date_year":1879,"date_month":3,"date_day":5,"location_city":"Washington","location_state":"D.C."}],"tags":["academic"],"sources":[],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Amherst astronomer who hunted eclipses worldwide","primary_url":"https://en.wikipedia.org/wiki/David_Peck_Todd"},"narrative_blocks":[{"header":"Photographed the 1882 Transit of Venus","detail":"David Peck Todd was the chief astronomer at the Lick Observatory during the transit of Venus in 1882, and created the first known photographs of the transit. The still photos were found and animated by astronomers at Lick during the 2004 transit of Venus. He led more than 11 eclipse expeditions worldwide and asteroid 511 Davida (named for him) and 510 Mabella (named for his wife) honor the pair.","body":"Chief astronomer at Lick Observatory during the 1882 transit of Venus; produced the first known photographs of the transit.","number":1},{"header":"Maxwell's letter → Michelson's speed-of-light experiment","detail":"On March 19, 1879 — the last year of his life — James Clerk Maxwell wrote to Todd at the U.S. Nautical Almanac Office asking whether Jupiter satellite eclipse data could detect Earth's motion through the luminiferous ether. The letter came to the attention of Todd's colleague Albert Michelson (1852-1932), who had already conducted the best measurement of the speed of light. G.G. Stokes read the letter at a Royal Society meeting in January 1880. This is a direct link between an 8th-generation Hooker descendant and the foundations of modern physics.","body":"James Clerk Maxwell wrote to Todd asking about Jupiter satellite data to detect ether drift; the letter reached Albert Michelson and influenced his famous experiments.","number":2},{"header":"Astronomer husband to Emily Dickinson's editor","detail":"David Todd married Mabel Loomis on March 5, 1879. Their move to Amherst in 1881 set the stage for Mabel's 13-year affair with Austin Dickinson (Emily's brother), which \"was an open secret in Amherst, and David Todd seems to have accepted it willingly\" (Wikipedia). Despite this unconventional arrangement, they traveled the world together on astronomical expeditions and had one daughter, Millicent. David was institutionalized in 1922 due to mental deterioration; he survived in care facilities until 1939, dying at age 84.","body":"Married Mabel Loomis Todd (first editor of Emily Dickinson); apparently accepted her 13-year affair with Austin Dickinson as an open secret in Amherst.","number":3}],"number_of_marriages":1,"cross_connections":[{"type":"family_orbit","related_id":"X03127","display_label":"his father-in-law, an eclipse astronomer too"}],"bio":{"display_name":"David Peck Todd","first_name":"David","last_name":"Todd","middle_name":"Peck","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780863578/76802015_3e6f62b0-5fa6-4704-b63b-60c6aee884e0_w4qwl1.jpg"},"residence":{},"baptism":{},"rese