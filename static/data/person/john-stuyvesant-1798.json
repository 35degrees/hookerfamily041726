rriages":[{"children_ids":["I00904","X03076"],"marriage_number":1}],"education":[],"career":[{"role":"Landowner","organization":"New York City","notes":"Inherited \"the Bowery House\" from uncle. Educated in Scotland."},{"role":"Real Estate Developer","organization":"44 Stuyvesant Street, Greenwich Village","start_year":1795,"notes":"Built Federal-style house in 1795, now the oldest house in Greenwich Village."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["merchant"],"research_tags":[],"cross_connections":[{"type":"kinship_by_marriage","display_label":"their wives, Catherine and Helen Reade, were sisters","related_id":"H00797","link_text":"Judge James Hooker"},{"type":"in_law","related_id":"H02005","display_label":"married his son John in 1840"}],"narrative_blocks":[{"number":1,"category":"family","header":"He built the Village’s oldest house","body":"The merchant built what survives today as Greenwich Village’s oldest house. His wife’s sister married James Hooker of Poughkeepsie, and his son John Reade Stuyvesant married Mary Austin Yates, a sixth-generation Hooker descendant — the family’s double tie to this tree."},{"number":2,"category":"family","header":"His nephew became Secretary of State","body":"His sister Elizabeth married Adjutant General Nicholas Fish, and their son Hamilton Fish rose to New York’s governorship, the U.S. Senate, and the State Department under Grant."}],"quotes":[],"sources":[{"label":"Wikipedia","url":"https://en.wikipedia.org/wiki/Nicholas_William_Stuyvesant"}],"research_sources":[],"documents":[],"slug":"nicholas-stuyvesant-1769"},"X02830":{"id":"X02830","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Peter","last_name":"Stuyvesant","married_names":[],"extra_names":"Petrus","nickname":"Petrus","gender":"male","display_name":"Peter Stuyvesant","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778905532/Peter_Stuyvesant