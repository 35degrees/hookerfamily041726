"bio":{"display_name":"Hezekiah Beers Pierrepont Pierpont","first_name":"Hezekiah","last_name":"Pierpont","middle_name":"Beers Pierrepont","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/3/30/Hezekiah_Beers_Pierrepont.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Aged Brooklyn gin a full year for mellowness","body":"In 1801 he bought Philip Livingston's old brewery on the Brooklyn waterfront and converted it to the Anchor Gin Distillery. The site closed in 1819 and is now part of One Brooklyn Bridge Park."},{"number":2,"category":"family","header":"Half a million acres at eight cents apiece","body":"His 1802 marriage to Anna Maria Constable made him heir to her father William Constable's Northern New York holdings. The land had been bought decades earlier when there was no buyer for it."},{"number":3,"category":"legacy","header":"Proposed the Brooklyn Heights Promenade","body":"He sketched a public walkway along the bluffs above the harbor more than a century before it was built. The Promenade as it exists today follows the route he proposed."},{"number":4,"category":"career","header":"Pirates seized his ship and bankrupted him","body":"The Confederacy was taken at sea in 1797 carrying his firm's cargo. The loss ended his Paris-based mercantile career and forced him home to start again."},{"number":5,"category":"character","header":"Witnessed Robespierre's execution from the crowd","body":"He spent seven years in France during the 1790s tending his firm's shipments. He was in Paris for the Reign of Terror and saw the head of the Jacobin regime guillotined."}],"slug":"hezekiah-pierpont-1768"},"X00495":{"id":"X00495","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooke