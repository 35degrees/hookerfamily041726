s":[{"header":"Mother of an author and a Union general","body":"Catherine Wadsworth married Nathaniel Terry, one of Hartford's most prominent citizens, in 1798. The Hooker-Talcott blood that ran through her passed to her grandchildren: Rose Terry Cooke became one of New England's most celebrated regional authors, and Gen. Alfred Howe Terry led the Union assault on Fort Wagner and later commanded the Department of the Dakotas — present at the aftermath of the Little Bighorn. Catherine never lived to see either of them distinguish themselves; she died in 1841.","number":1,"category":"family"}],"burial":{"cemetery_id":"CEM056"},"cross_connections":[],"bio":{"display_name":"Catherine Wadsworth Terry","first_name":"Catherine","last_name":"Terry","maiden_name":"Wadsworth","married_names":["Terry"],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777484083/catherineterry_gl7mvk.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"quotes":[],"military_service":[],"former_ids":[],"education":[],"career":[],"is_placeholder":false,"slug":"catherine-terry-1774"},"X00430":{"id":"X00430","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"Hurlbut genealogy book"}],"birth":{"year":1770},"death":{"year":1808,"cause":"smallpox"},"marriages":[{"spouse_id":"X00431","children_ids":["X00422"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"parents":{"mother_id":"X00429","father_id":"X00428"},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Captain John Hurlbut","first_name":"John","last_name":"Hurlbut","title":"Captain","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sou