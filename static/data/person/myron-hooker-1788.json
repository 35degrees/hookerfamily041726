{"person":{"id":"H01272","former_ids":[],"is_placeholder":false,"gender":"male","has_descendants_documented":true,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"is_easter_egg":false,"include_in_path_calculation":true,"descent_from_thomas_hooker":true},"bio":{"first_name":"Myron","last_name":"Hooker","married_names":[],"gender":"male","display_name":"Myron Hooker"},"birth":{"year":1788,"month":1,"day":17,"city":"Poultney","county":"Rutland County","state":"Vermont","country":"United States","historical_notes":"Per EH 1272: b. Jan 1788 Poultney VT (year only). WikiTree records exact date Jan 17, 1787 — one-year discrepancy. Going with EH year 1788 per Sam's rule that EH overrides WikiTree on dates, but using WikiTree's day=17."},"death":{"year":1858,"month":12,"day":25,"city":"Kendall","county":"Orleans County","state":"New York","country":"United States","note":"Per WikiTree: d. Dec 25, 1858 Kendall NY age 71. EH 1272 says \"He died 1859\" — likely an EH error since WikiTree has more specific date."},"parents":{"father_id":"H00491","mother_id":"X01958"},"number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"X02277","location_country":"United States","end_type":"death_of_spouse","children_ids":["H02436","H02437","H02438"]},{"marriage_number":2,"spouse_id":"X02278","location_country":"United States","end_type":"death","end_year":1858,"children_ids":["HD3260"]}],"tags":["new_york_migration","vermont_migration"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 1272"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Vermont-born, Christmas Day death in upstate New York","body":"Myron Hooker was born January 17, 1788 in Poultney, Rutland County Vermont, the son of Captain Thomas Hooker by his third wife Mary Coleman. By the 1850 census he had migrated west to Kendall, Orleans County New York, where he died Christmas Day 1858 at age seventy. He was buried at Greenwood Cemetery Kendall, far from the Hooker-line Connecticut center."},{"number":2,"category":"family","header":"Presumed daughter's line reconverged Hooker branches","body":"Through Laura E. Hooker Shader — Myron's presumed daughter by first wife Sally Brooks — the line runs forward to Caroline E. Shader who married Thomas Harvey Hooker, descendant of Myron's half-brother Thomas Gould Hooker. That third-cousin marriage between two branches of Captain Thomas Hooker's descendants reconverged a line that had split four generations earlier. Their child Charles Theodore Hooker qualifies as double Hooker ancestry."}],"cross_connections":[],"burial":{"plot_notes":"Greenwood Cemetery, Kendall, Orleans County NY (per WikiTree). Cemetery not yet built as separate CEM entry."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"myron-hooker-1788"},"neighborhood":{"focus":{"id":"H01272","slug":"myron-hooker-1788","n":"Myron Hooker","by":1788,"dy":1858,"sx":"m","hd":true,"td":false,"ee":false,"g":7},"spouses":[{"order":1,"spouse":{"id":"X02277","slug":"sally-brooks","n":"Sally Brooks Hooker","by":null,"dy":null,"sx":"u","hd":false,"td":false,"ee":false,"g":null},"year":null,"children":[{"id":"H02436","slug":"betsey-bacon-1839","n":"Betsey Hooker Bacon","by":1839,"dy":1839,"sx":"u","hd":true,"td":false,"ee":false,"g":8},{"id":"H02437","slug":"thomas-hooker-1822","n":"Thomas Cullen Hooker","by":1822,"dy":1907,"sx":"u","hd":true,"td":false,"ee":false,"g":8},{"id":"H02438","slug":"myron-hooker-1820","n":"Myron Smith Hooker","by":1820,"dy":null,"sx":"u","hd":true,"td":false,"ee":false,"g":8}]},{"order":2,"spouse":{"id":"X02278","slug":"betsey-hooker-1792","n":"Betsey Bacon Hooker","by":1792,"dy":1877,"sx":"u","hd":false,"td":false,"ee":false,"g":null},"year"