cott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":true,"generation_from_thomas":9},"bio":{"first_name":"Ida","middle_name":"May","last_name":"Gordon","maiden_name":"Hooker","married_names":["Gordon"],"extra_names":"Per Mt. Hope Cemetery + Gordon family records: also recorded as 'Ida Mae'","gender":"female","display_name":"Ida May Hooker Gordon","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777244550/IdaMaeHooker_zmfjdf.jpg","photo_notes":"Cloudinary-hosted; supplied by Sam"},"birth":{"year":1855,"month":1,"day":23,"city":"Kendall","county":"Orleans County","state":"New York","country":"United States"},"death":{"year":1946,"month":5,"day":11,"city":"Brockport","county":"Monroe County","state":"New York","country":"United States"},"parents":{"father_id":"H02437","mother_id":"X02279"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02281","date_year":1875,"date_month":10,"date_day":18,"location_state":"New York","location_country":"United States","end_type":"death_of_spouse","end_year":1898,"children_ids":["HD3261","HD3268","HD3262","HD3266","HD3267"],"notes":"Per EH 3892: m. Nov 18, 1873 George Cooley Gordon (b. July 1, 1849 Rushford NY, son of Luther + Florilla Cooley Gordon; d. Aug 25, 1898). FOUR sons per EH 5049-5052: Luther Gordon (b.1875, m.1904 Augusta Moore, 2 children Luther + Emeline), George Cooley Gordon (b.1877, m.1906 Cecelia Mitchell Kimball, dau Cecelia), Fred Hooker Gordon (b.1881, m.1906 Florence De Moss Robinson), Thomas Cullen Gordon (b.1884, m.1908 Ruth Little Perry). Two of her sons named for Hooker family: Fred HOOKER Gordon and Thomas CULLEN Gordon — `named_for_hooker` pattern applies to those two."}],"tags":["extraordinary_longevity"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 3892"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"public_service","header":"Brockport's banker matriarch served Rochester children","body":"Ida May Hooker — born January 1855 in Kendall NY, daughter of Thomas Cullen Hooker — moved to Brockport NY when her father relocated the family there. She married George Cooley Gordon Sr. on October 18, 1875 when she was 20. George went on to become president of the First National Bank of Brockport, a 'millionaire banker' per his New York Times obituary."},{"number":2,"category":"memorial","header":"Gordon Hall and Tiffany window honor her","body":"Ida and George's enduring presence in Brockport survived her death by decades. In 1927, a Tiffany window made by Louis C. Tiffany was installed at St. Luke's Episcopal Church in Brockport, dedicated to George and Ida's memory."},{"number":3,"category":"achievement","header":"Among first women on SUNY Brockport Board, 1917","body":"In 1917 Ida May Hooker Gordon was appointed to the Board of Trustees of SUNY Brockport, one of the first two women to serve on the board. The appointment paralleled her presidency of the Rochester Children's Nursery — extending her institutional leadership beyond philanthropy into educational governance. She continued to serve into her later years before her death at 91."}],"cross_connections":[],"burial":{"plot_notes":"Mt. Hope Cemetery, Rochester NY — Lot 61 Range 2 — purchased by her father-in-law Luther Gordon Sr. Plot features a stunning monument with columns and an allegorical figure with drapery. George C. Gordon her husband paid $9,229.54 for perpetual care in 1883."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ida-gordon-1855"},"H03893":{"id":"H03893","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":true,"generation_from_thomas":9},"bio