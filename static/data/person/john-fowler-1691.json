into the next century."},{"number":4,"category":"death","header":"His stone asks if this is life's end","body":"Captain Fowler died on August 17, 1787, only thirty-nine years old. His Milford gravestone carries a startled, grieving verse: “All gracious Heaven, is this the end of man, a dreadful thought, a melancholy plan.”"}],"slug":"john-fowler-1748"},"HD0197":{"id":"HD0197","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1751,"month":3,"day":8},"death":{"year":1751,"month":3,"day":8},"parents":{"father_id":"H00164","mother_id":"H00155"},"tags":["died_in_infancy"],"sources":[],"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Fletcher Fowler","first_name":"Fletcher","last_name":"Fowler","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"merged_ids":["HD0176"],"slug":"fletcher-fowler-1751"},"HD0929":{"id":"HD0929","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1752},"death":{"year":1752},"parents":{"father_id":"H00164","mother_id":"H00155"},"tags":["died_in_infancy"],"sources":[],"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Stephen Fowler","first_name":"Stephen","last_name":"Fowler","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"nami