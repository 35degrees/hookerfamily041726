","end_year":1875,"children_ids":["TD0212","TD0213"]},{"marriage_number":2,"spouse_id":"X02419","children_ids":[]}],"education":[{"school_name":"Hobart Hall Institute","type":"preparatory","notes":"Public schools and Hobart Hall Institute (Trenton NY area)."}],"career":[{"role":"Member","organization":"Oregon House of Representatives","location":"Oregon Territorial Legislature","start_year":1852,"end_year":1853,"notes":"Helped draft the memorial to Congress calling for the establishment of Washington Territory — splitting off the territory that would become Washington, Idaho, and western Montana."},{"role":"Mercantile and steamboat operator","location":"Willamette River, Oregon Territory","notes":"Engaged in mercantile pursuits and steamboat transportation on the Willamette River."},{"role":"Clerk","organization":"United States District Court of Oregon","location":"Oregon","start_year":1859,"end_year":1860},{"role":"Delegate","organization":"38th United States Congress","location":"Washington Territory at-large district","start_year":1863,"end_year":1865,"notes":"Elected as a Democrat to the 38th Congress March 4, 1863 to March 3, 1865. First Washington Territorial Delegate to Congress to hail from the East side of the state. Last Democrat to represent the Washington Territory in Congress until 1885. Did not seek renomination in 1864."},{"role":"Governor","organization":"Washington Territory","location":"Olympia, Washington Territory","start_year":1867,"end_year":1867,"notes":"6th Governor of Washington Territory. Appointed by President Andrew Johnson November 1866; served January 8 to March 4, 1867. Preceded by William Pickering, succeeded by Marshall F. Moore."},{"role":"Railroad official","organization":"Oregon & California Railroad","location":"Portland to Roseburg, Oregon","start_year":1867,"end_year":1872,"notes":"Helped oversee construction of railroad line from Portland to Roseburg."},{"role":"Postmaster","organization":"United States Post Office Department"