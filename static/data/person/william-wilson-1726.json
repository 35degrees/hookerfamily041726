er). The two mothers were sisters. EH and the Wilson genealogy both explicitly note the cousin relationship."}],"career":[{"role":"Schoolmaster","organization":"Town of Medfield","end_year":1692,"notes":"Employed as schoolmaster in Medfield for several terms; also assisted father in ministry."},{"role":"Representative","organization":"Massachusetts General Court","start_year":1698,"end_year":1698,"notes":"Representative from Braintree, 1698."},{"role":"Justice of the Peace","organization":"Braintree, Massachusetts","start_year":1700,"notes":"Commission June 7, 1700. Held until death."}],"military_service":[{"rank":"Captain","unit":"Local militia company, Braintree","rank_year_start":1696,"notes":"Commission as captain of one of the local military companies, 1696."}],"bio":{"display_name":"John Wilson","first_name":"John","last_name":"Wilson","married_names":[]},"documents":[],"artworks":[],"slug":"john-wilson-1660"},"H00016":{"id":"H00016","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":3,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_progenitor":false},"birth":{"year":1662,"month":1,"day":24,"city":"Milford","state":"Connecticut","country":"United States"},"death":{"year":1725,"month":8,"day":20,"city":"Braintree","county":"Suffolk","state":"Massachusetts","country":"United States"},"parents":{"father_id":"I00003","mother_id":"H00003"},"marriages":[{"spouse_id":"H00024","children_ids":["H00060","H00061","H00062","H00063","H00064","H00065","H00066"],"marriage_number":1,"date_year":1683,"date_month":7,"date_day":4,"location_city":"Milford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1725}],"cross_connections":[{"type":"cousin_marriage","related_id":"H00024","display_label"