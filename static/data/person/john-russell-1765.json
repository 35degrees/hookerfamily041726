rles River Railroad MA","dates":"unknown"}],"marriages":[{"spouse_id":"X00444","children_ids":["HD1384","HD1385"],"marriage_number":1}],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"China trader; Mayor of Middletown 1859-1861","primary_url":"https://en.wikipedia.org/wiki/Edward_Augustus_Russell_House"},"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Edward Augustus Russell","first_name":"Edward","last_name":"Russell","middle_name":"Augustus","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST009","institution_blurb":"His 1841-1842 Greek Revival house (LM017, 318 High Street) is now Wesleyan property used for lectures, concerts, and events."},{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Russell & Company trader in China, 1825-1838","body":"Edward Augustus Russell joined his elder brother Samuel in China in 1825, working for Russell & Company — the dominant American firm in the Canton trade. He stayed thirteen years, returning to Middletown in 1838. The fortune accumulated in the China trade financed his return to civic life in Connecticut."},{"number":2,"category":"achievement","header":"Built Greek Revival on Noadiah Russell's homelot","body":"In 1841-1842 Russell built a Greek Revival mansion at 318 High Street, Middletown — the last Greek Revival house on what had become the city's most prestigious street. The lot was the original Noadiah Russell homelot, dating to the seventeenth century. Rev. Noadiah Russell had been a founding trustee of Yale in 1701 and was Edward Augustus Russell's great-great-grandfather."},{"number":3,"category":"career","header":"Mayor of Middletown, 1859-1861","body":"Russell served as Mayor of Middletown from 1859 to 1861, as a Connecticut State Representative, and as a national convention delegate. He held railroad directorships including the presidency of the Charles River Railroad in Massachusetts. Both of his sons predeceased him."}],"landmarks_associated":["LM017"],"slug":"edward-russell-1797"},"X00444":{"id":"X00444","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1374","children_ids":["HD1384","HD1385"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Eliza Brown Hall","first_name":"Eliza","middle_name":"Brown","maiden_name":"Hall","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"eliza-hall"},"HD1384":{"id":"HD1384","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1374","mother_id":"X00444"},"tags":[],"sources":[{"short":"Barbour Collection Middletown CT / Online vital records"}],"marriages":[],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Mary Osborn Russell deZeng","first_name":"Mary","last_name":"deZeng","maiden_name":"Russell","middle_name":"Osborn","married_names":["deZeng"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-dezeng"},"HD1385":{"id":"HD1385","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1374","mother_id":"X00444"},"tags":[],"sources":[{"short":"Barbour Collection Middletown CT / Online vital records"}],"gender":"female","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Frances Ann Russell","first_name":"Frances","middle_name":"Ann","maiden_name":"Russell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"frances-russell"},"H00359":{"id":"H00359","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1727,"month":7,"day":7,"city":"Middletown","state":"Connecticut"},"parents":{"father_id":"I00144","mother_id":"H00118"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 359"}],"death":{"year":1794,"month":3,"day":14,"city":"Middletown","state":"Connecticut"},"marriages":[{"spouse_id":"X00437","children_ids":["H00848","H00854","H00849","H00850","H00851","H00852","H00853"],"marriage_number":1,"date_year":1758,"date_month":8,"date_day":29},{"marriage_number":2,"spouse_id":"HD1438","children_ids":[]}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Samuel Russell","first_name":"Samuel","last_name":"Russell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"military","header":"Rose from ensign to captain of Middletown militia","body":"By 1763 Barbour Collection records call him 'Ensign Samuel'; by 1773, 'Capt. Samuel.' He served as a militia officer of Middletown across the decade leading up to the Revolution."},{"number":2,"category":"family","header":"Wife died at 41 leaving eight children","body":"Ruth Whitmore Russell died April 13, 1773 in Middletown at age 41, after fifteen years of marriage and eight children. Samuel did not remarry; he raised the family alone for twenty more years before his own death in 1794."},{"number":3,"category":"legacy","header":"Grandson founded Russell & Company, China giant","body":"His grandson Samuel Russell (1789-1862) founded Russell & Company in 1819 — the largest American trading house in China through 1891. Russell & Company partner Warren Delano Jr. became the maternal grandfather of Franklin Delano Roosevelt."}],"slug":"samuel-russell-1727"},"X00437":{"id":"X00437","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1731},"death":{"year":1773},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00359","children_ids":["H00848","H00854","H00849","H00850","H00851","H00852","H00853"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Ruth Whitmore","first_name":"Ruth","maiden_name":"Whitmore","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ruth-whitmore-1731"},"I00144":{"id":"I00144","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1690,"month":11,"day":30,"city":"Middletown","state":"Connecticut","country":"United States"},"death":{"year":1761,"month":6,"day":1,"city":"Middletown","state":"Connecticut","country":"United States"},"parents":{"mother_research_notes":"Mary Hamlin Russell — her sister Mehitable Hamlin married Samuel Hooker Jr., making Rev. William Russell's aunt the wife of Mary Pierpont's maternal uncle. EH notes this double family connection explicitly.","father_research_notes":"Rev. Noadiah Russell of Middletown — founding trustee of Yale College"},"church_roles":[{"role":"Pastor","location":"Middletown, Connecticut","dates":"1715-1761","notes":"Successor to his father Rev. Noadiah Russell"}],"marriages":[{"spouse_id":"H00118","children_ids":["H00356","H00357","H00358","H00359","H00360","H00360a","H00361","H00362","H00363"],"marriage_number":1,"date_year":1719,"date_month":8,"date_day":19,"location_country":"United States"}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 118"}],"gender":"male","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"cousin_marriage","related_id":"HD0416","display_label":"Married the sister of his own sister's husband, both Pierpont-Russell siblings.","link_text":"Joseph Pierpont"}],"education":[{"school_name":"Yale College","dates":"1709","type":"college"}],"bio":{"title":"Reverend","display_name":"Rev. William Russell","first_name":"William","last_name":"Russell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"founder","years":"1709"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"lineage","header":"Son of Yale's founding trustee Noadiah Russell","body":"His father Rev. Noadiah Russell was one of the ten founding trustees of Yale College in 1701 — the same founding cohort as Rev. James Pierpont Sr (his future father-in-law). Two Yale founding-trustee families thus merged through his marriage to Mary Pierpont in 1718."},{"number":2,"category":"lineage","header":"Double Hamlin family connection to Hooker line","body":"His mother Mary Hamlin's sister Mehitable Hamlin had married Samuel Hooker Jr. - brother of Mary Pierpont's mother Mary Hooker. Edward Hooker's 1909 genealogy notes this double family connection explicitly: two Hamlin sisters married into the Hooker-Pierpont line one generation apart."},{"number":3,"category":"career","header":"Pastor of Middletown First Church for decades","body":"Served as pastor of Middletown First Church through the mid-18th century until his death 1 June 1761 at age 70. Father of nine surviving children — five sons + four daughters — through whom the Russell name carried into the Wadsworth, Talcott, Anthony, and Dwight branches of the Hooker tree."},{"number":4,"category":"career","header":"Forty-six years in the pulpit, to the day","body":"Settled as Middletown’s pastor on June 1, 1715, William Russell died on June 1, 1761 — forty-six years in the same pulpit to the day."}],"career":[{"role":"Pastor","organization":"First Church of Middletown","start_year":1715,"end_year":1761}],"slug":"william-russell-1690"},"H00118":{"id":"H00118","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1703,"month":11,"day":23,"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1740,"month":6,"day":24,"city":"Middletown","county":"Middlesex","state":"Connecticut","country":"United States"},"parents":{"father_id":"X00126","mother_id":"H00034"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 118"}],"marriages":[{"marriage_number":1,"spouse_id":"I00144","date_year":1719,"date_month":8,"date_day":19,"location_city":"New Haven","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1740,"children_ids":["H00356","H00357","H00358","H00359","H00360","H00360a","H00361","H00362","H00363"]}],"cross_connections":[{"type":"founding_family_nexus","related_id":"H00115","display_label":"Both families joined through Talcott siblings a generation later.","link_text":"Capt. Nathaniel Hooker"},{"type":"family_connection","related_id":"T00070","display_label":"Her daughter's marriage to Talcott converged founding lines.","link_text":"Col. Matthew Talcott"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"institutions":[{"institution_id":"INST022","institution_blurb":"Father Rev. James Pierpont Sr. and father-in-law Rev. Noadiah Russell were both founding trustees of Yale in the same 1701 charter."},{"institution_id":"INST013"}],"narrative_blocks":[{"number":1,"category":"legacy","header":"Her father and father-in-law both founded Yale","body":"She was the daughter of Rev. James Pierpont Sr., one of the ten founding trustees who chartered Yale College on October 16, 1701. She married Rev. William Russell, son of Rev. Noadiah Russell of Middletown — who was also one of those ten founding trustees."},{"number":2,"category":"legacy","header":"Four founding families converge in her children's generation","body":"Through her parents she carried the Hooker line and the Pierpont-Yale line. Through marriage she joined the Russell-Yale line. Her daughter Mary Russell married Matthew Talcott — adding the Talcott founding line to the convergence her children embodied."},{"number":3,"category":"family","header":"A hidden Hooker-Hamlin connection in her husband's family","body":"Rev. William Russell's mother Mary Hamlin was the sister of Mehitable Hamlin, who married Samuel Hooker Jr. — a brother of Mary Pierpont's own mother. This made William Russell's aunt the wife of Mary's uncle, drawing a second bond between the families before their own marriage."},{"number":4,"category":"family","header":"Granddaughter of Hartford's founder — nine children","body":"Her grandfather was Rev. Thomas Hooker, who led the 1636 migration from Cambridge that founded Hartford. She settled in Middletown with her husband and bore nine children: Mary, Esther, William, Samuel, Noadiah, James, Sarah, Mehitable, and Hannah."},{"number":5,"category":"family","header":"Her daughter Mary married Matthew Talcott","body":"Her daughter Mary Russell married Matthew Talcott of Hartford — the marriage that created the Russell-Talcott convergence. Their children were both Hooker and Talcott descendants, connecting two of colonial Connecticut's founding families."},{"number":6,"category":"legacy","header":"She may have stitched the family apron","body":"Of the three Marys linked to a surviving 1730s silk apron, she is one of two likeliest embroiderers, depending on which attended a Boston finishing school and when. The apron’s Chinese silk and French metallic thread mark the family’s reach into global trade."}],"bio":{"display_name":"Mary Pierpont Russell","first_name":"Mary","last_name":"Russell","married_names":["Russell"],"maiden_name":"Pierpont","bio_blurb":"Mother of the Russell nine at Middletown"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"videos":[{"video_id":"VID009"}],"slug":"mary-russell-1703"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}