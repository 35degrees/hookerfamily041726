":[],"artworks":[],"quotes":[],"military_service":[],"slug":"abigail-warner-1759"},"HD1371":{"id":"HD1371","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00850","mother_id":"X00438"},"tags":[],"sources":[],"birth":{"year":1789},"death":{"year":1862},"marriages":[{"spouse_id":"X00440","children_ids":["HD1375","HD1376"],"marriage_number":1,"date_year":1815,"date_month":10,"date_day":6},{"spouse_id":"X00439","children_ids":["HD1377"],"marriage_number":2,"date_year":1825,"date_month":10,"date_day":26}],"cross_connections":[{"type":"artifact","related_id":"HD1378","display_label":"His great-grandson donated the firm's Canton archive to the Library of Congress.","link_text":"Thomas Macdonough Russell Sr."},{"type":"parallel_descent","related_id":"HD1395","display_label":"Second cousins — both great-grandsons of Noadiah Russell. Russell co-founded Skull and Bones in 1832, the same year Samuel's Russell & Company reached its peak opium operation in Canton.","link_text":"William Huntington Russell"}],"gender":"male","notable":{"is_notable":true,"notable_category":[],"primary_url":"https://en.wikipedia.org/wiki/Russell_%26_Company"},"number_of_marriages":2,"bio":{"display_name":"Samuel Wadsworth Russell","first_name":"Samuel","last_name":"Russell","middle_name":"Wadsworth","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST009","institution_blurb":"His 1828 Greek Revival house (LM016, 350 High Street) is now Wesleyan's Department of Philosophy."},{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"business","header":"Largest American opium trader in 1830s China","body":"Arrived Canton 1819; founded Samuel Russell & Co.; from 1824 restructured as Russell & Company. By early 1831 had smuggled 3,500 chests of Indian opium into China — approximately twenty percent of the country's total annual opium imports that year. Russell & Company was the largest American opium trading house in China."},{"number":2,"category":"legacy","header":"Skull and Bones founded by his Russell cousin","body":"His second cousin William Huntington Russell co-founded Skull and Bones at Yale in 1832 with Alphonso Taft — both Hooker descendants themselves. The Russell family fortune that helped support the society's early decades had been substantially built on his own Russell & Company opium trading at Canton, China."},{"number":3,"category":"family","header":"Business partner was FDR's maternal grandfather","body":"Among the partners at Russell & Company was Warren Delano Jr. — the maternal grandfather of President Franklin Delano Roosevelt. The Russell-Delano connection ran through the China opium trade two generations before Delano's grandson reached the White House."},{"number":4,"category":"architecture","header":"Greek Revival mansion 1828 by Ithiel Town","body":"On returning from Canton 1831 he commissioned a major Greek Revival mansion at Middletown CT, designed 1826-1828 by Ithiel Town — the same architect Daniel Wadsworth used for the Wadsworth Atheneum. The Middletown mansion remains a landmark of the Greek Revival movement in American domestic architecture."},{"number":5,"category":"marriage","header":"Lost his first wife at twenty-three, 1819","body":"Married Mary Cotton Osborn on 6 October 1815 in New York; she died in 1819 leaving him with two sons. Six years later in October 1825 he married her sister Frances Ann Osborn — the family stabilization pattern echoed in many Dwight cousins of his generation."}],"slug":"samuel-russell-1789"},"X00440":{"id":"X00440","has_descendants_documented":false,"classification":{"includ