egory":"family","header":"Died same year as wife Roxanna, 1919","body":"He died at Madison January 10, 1919 aged eighty-three. His wife Roxanna Rebecca Scranton Hart followed five months later on June 13, 1919 aged eighty-four. Together fifty-nine years and buried side by side at West Cemetery, Madison CT."}],"slug":"william-hart-1835"},"I01287":{"id":"I01287","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Roxanna","middle_name":"Rebecca","last_name":"Hart","maiden_name":"Scranton","married_names":["Hart"],"gender":"female","display_name":"Roxanna Rebecca Scranton Hart"},"gender":"female","birth":{"year":1834,"month":9,"day":4,"state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1919,"month":6,"day":13,"city":"Madison","county":"New Haven","state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM038","plot_notes":"West Cemetery, Madison CT (FindAGrave Memorial #61366887)."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01878","date_year":1859,"date_month":7,"date_day":14,"end_type":"death_of_spouse","end_year":1919,"children_ids":["HD5032","HD5033"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Outlived husband by only five months","body":"She married Capt. William Winthrop Hart on July 14, 1859 — they were together fifty-nine years. He died at Madison January 10, 1919 aged eighty-three; she followed June 13, 1919 aged eighty-four, just five months later. They lie side by side at West Cemetery, Madison."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"roxanna-scranton-1834"},"HD5032":{"id":"HD5032","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"William","middle_name":"Scranton","last_name":"Hart","married_names":[],"gender":"male","display_name":"William Scranton Hart"},"gender":"male","birth":{"year":1861,"city":"Madison","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1862,"city":"Madison","county":"New Haven","state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM038","plot_notes":"West Cemetery, Madison CT (FindAGrave Memorial #61366881)."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H01878","mother_id":"I01287"},"number_of_marriages":0,"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Scranton","inspired_by_id":"I01287","description":"Middle name 'Scranton' carries his mother Roxanna Rebecca Scranton Hart's maiden line."}],"artworks":[],"tags":["died_in_infancy"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"william-hart-1861"},"HD5033":{"id":"HD5033","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Susan","middle_name":"Josephine","last_name":"Hart","married_names":[],"gender":"female","display_name":"Susan Josephine Hart"},"gender":"female","birth":{"year":1863,"month":4,"day":5,"state":"Connecticut","co