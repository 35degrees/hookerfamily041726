ley","mother_id":"HD3714","mother_name":"Charlotte Cowles Austin Seeley"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00410","date_year":1890,"location_country":"United States","children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"orville-willard-seeley-1859"},"I00410":{"id":"I00410","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Mary E.","last_name":"Whiting Seeley","maiden_name":"Whiting","married_names":["Seeley"],"gender":"female","display_name":"Mary E. Whiting Seeley"},"birth":{},"baptism":{},"death":{},"residence":{"city":"Austinburg","county":"Ashtabula County","state":"Ohio"},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3747","date_year":1890,"location_country":"United States","children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"mary-e-whiting"},"X01418":{"id":"X01418","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["clergy","abolitionist","minister"],"sources":[{"short":"Cowles Families in America #688 — Sally Berrien Cowles Austin"},{"short":"Dudley Genealogy 1892"},{"short":"Find a Grave Memorial 47267856 (Rev. Eliphalet Austin)","url":"https://www.findagrave.com/memorial/47267856/eliphalet-austin","accessed":"2026-05"},{"short":"Edward Hooker 1909, entry #688 (re: Sally Berrien Cowles + husband)","url":"https://archive.org/details/descendantsofrev00hook","accessed":"2026-05"},{"short":"Williams Brothers 'History of Ashtabula County' (1878)","accessed":"2026-05"}],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01142","date_year":1819,"date_month":8,"date_day":31,"location_country":"United States","children_ids":["HD3713","HD3714","HD3715","HD3716"]}],"parents":{"father_id":"X02782","mother_id":"X02783","father_name":"Judge Eliphalet Austin Sr","mother_name":"Sybil Dudley Austin"},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1793,"city":"Torrington","county":"Litchfield County","state":"Connecticut","country":"United States"},"death":{"year":1837,"month":8,"day":4,"city":"Austinburg","county":"Ashtabula County","state":"Ohio","country":"United States"},"cross_connections":[],"bio":{"display_name":"Rev. Eliphalet Austin Jr.","first_name":"Eliphalet","last_name":"Austin","title":"Reverend","married_names":[],"suffix":"Jr."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST044","role":"founder","dates":"1825-1826","notes":"Member of the Grand River Presbytery board that founded Western Reserve College at Hudson; charter 1826."}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM035","plot_notes":"Austinburg Center Cemetery"},"narrative_blocks":[{"number":1,"category":"social_reform","header":"Recording secretary of Ashtabula's antislavery society","body":"Eliphalet served as recording secretary at the May 1834 founding of the Anti-Slavery Society of Ashtabula County. The society's preamble declared all men created free and equal and called for 'the utter extinction of slavery by immediate emancipation.' His own father-in-law's parsonage and his household served as an Underground Railroad station for fleeing slaves."}],"slug":"eliphalet-austin-jr-1793"},"H01142":{"id":"H01142","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1796,"month":2,"day":21,"city":"Bristol","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00443","mother_id":"X00259"},"tags":["abolitionist","ohio_migration","underground_railroad"],"sources":[{"short":"Cowles Families in America #688 — Sally Berrien Cowles Austin"},{"short":"Edward Hooker 1909","entry":"1142"},{"short":"Williams Brothers 1878","page":"Ashtabula County history, Cowles family"}],"gender":"female","marriages":[{"marriage_number":1,"spouse_id":"X01418","date_year":1819,"date_month":8,"date_day":31,"location_country":"United States","children_ids":["HD3713","HD3714","HD3715","HD3716"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1872,"month":9,"country":"United States"},"cross_connections":[],"bio":{"display_name":"Sally Berrien Cowles Austin","first_name":"Sally","last_name":"Austin","maiden_name":"Cowles","middle_name":"Berrien","married_names":["Austin"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"First Cowles bride of the Austinburg generation","body":"At twenty-three Sally married a son of Judge Eliphalet Austin in 1819, joining the founding family of the Ohio settlement her father had been recruited to plant. The wedding fused two of Austinburg's pioneer households."},{"number":2,"category":"social_reform","header":"Their farmhouse hid passengers on the Underground Railroad","body":"The Austin household ran one of Ashtabula County's documented Underground Railroad stations through the 1830s and 1840s, sheltering fugitives moving north toward Lake Erie. Sally kept the kitchen fires going for travelers who never appeared in the daylight record."},{"number":3,"category":"family","header":"Widowed at forty-one — outlived him by thirty-five years","body":"Her husband died in 1837 and left her a young widow with the household to keep. She managed the farm and raised the children alone for thirty-five years until her own death in 1872."}],"burial":{"cemetery_id":"CEM035","plot_notes":"Austinburg Center Cemetery, Austinburg, Ashtabula County, Ohio."},"slug":"sally-austin-1796"},"X02782":{"id":"X02782","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"title":"Judge","first_name":"Eliphalet","last_name":"Austin","suffix":"Sr.","married_names":[],"gender":"male","display_name":"Judge Eliphalet Austin Sr."},"birth":{"year":1761,"county":"Litchfield County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1838,"month":1,"day":28,"city":"Austinburg","county":"Ashtabula County","state":"Ohio","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM035","plot_notes":"Austinburg Center Cemetery"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":true},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02783","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1838,"children_ids":["X01418"]}],"education":[],"career":[{"title":"Connecticut Land Company partner","organization":"Connecticut Land Company","dates":"late 1790s","type":"business","notes":"Joined the Connecticut Land Company, formed to settle and develop the section of western Connecticut later called the Connecticut Western Reserve in Ohio. Purchased wide tracts including present-day Austinburg Township, which bears his name."},{"title":"Founder","organization":"Austinburg Township, Ashtabula County, Ohio","dates":"1799","type":"civic","notes":"Settled at present-day Austinburg in 1799. The township is named for him. Responsible for carrying the mail in the region; operated a cattle-dealing operation."},{"title":"State Senator","organization":"Ohio State Senate","dates":"1829-1831","type":"politics"}],"military_service":[],"institutions":[],"landmarks":[{"landmark_id":"LM102","role":"resident_owner","notes":"Built the Eliphalet Austin House Austinburg OH 1815 (per Wikipedia; 1811 per local tradition). NRHP listed 1975. Heavily modified Italianate style by his grandson Louis B. Austin in the 1860s."}],"naming_inspiration":[],"artworks":[],"tags":["town_founder","ohio_migration","senator"],"research_tags":[],"cross_connections":[{"type":"civic_peer","related_id":"H00443","display_label":"Co-founders of Austinburg church and Western Reserve College","link_text":"Rev. Giles Hooker Cowles"}],"narrative_blocks":[{"number":1,"category":"family","header":"Founder of Austinburg Township, Ohio Western Reserve","body":"A Connecticut Land Company partner, Eliphalet purchased wide tracts across the Connecticut Western Reserve in the late 1790s and settled at present-day Austinburg in 1799 — the township still bears his name. He carried the mail across the region, operated a cattle-dealing business, and served in the Ohio Senate 1829-1831."},{"number":2,"category":"religion","header":"His wife rode horseback to recruit a minister","body":"In spring 1810, his wife Sybil Dudley Austin rode six hundred miles by horseback to Bristol Connecticut — alone, with her wardrobe in a portmanteau — to recruit Rev. Giles Hooker Cowles to settle Ashtabula County's first Congregational minister. Giles, his wife Sally, and their eight children arrived in Austinburg the following summer 1811. The Austin-Cowles partnership defined Austinburg's pioneer era."},{"number":3,"category":"legacy","header":"His Austinburg house is on the National Register","body":"Eliphalet built the brick house at 1879 State Route 45 Austinburg in 1811 (or 1815 per Wikipedia). His grandson Louis B. Austin remodelled it in the Italianate style during the 1860s."}],"quotes":[],"sources":[{"short":"Wikipedia: Eliphalet Austin House","url":"https://en.wikipedia.org/wiki/Eliphalet_Austin_House","accessed":"2026-05"},{"short":"Williams Brothers 'History of Ashtabula County' (1878), biography of Rev. Giles Hooker Cowles (re: Mrs. Austin's recruitment ride)","url":"https://ohiogenealogyexpress.com/ashtabula/ashtaco_1878_bios/ashtaco_1878_bios_cowlesGiles.html","accessed":"2026-05"},{"short":"National Register of Historic Places, NRHP reference No. 75001313","accessed":"2026-05"}],"research_sources":[],"documents":[],"slug":"eliphalet-austin-sr-1761"},"X02783":{"id":"X02783","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Sybil","last_name":"Austin","maiden_name":"Dudley","married_names":["Austin"],"extra_names":"Also recorded as 'Sibyl Dudley' (per EH); 'Sibbell' (per WikiTree variant)","gender":"female","display_name":"Sybil Dudley Austin"},"birth":{"year":1761,"city":"Conway","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1844,"month":4,"day":2,"city":"Austinburg","county":"Ashtabula County","state":"Ohio","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM035","plot_notes":"Austinburg Center Cemetery — buried with husband Eliphalet"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":true},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Daniel Dudley (Daniel, Caleb, Joseph, William Dudley line) — William Dudley b. Richmond/Sheen Surrey England, came to Guilford CT 1636"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02782","location_state":"Connecticut","location_country":"United States","end_type":"death_of_husband","end_year":1838,"children_ids":["X01418"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["ohio_migration"],"research_tags":[],"cross_connections":[{"type":"family_orbit","related_id":"H00443","display_label":"Recruited the Connecticut minister who founded Austinburg's church","link_text":"Rev. Giles Hooker Cowles"}],"narrative_blocks":[{"number":1,"category":"character","header":"Rode 600 miles alone to recruit a minister","body":"In spring 1810 Sybil concluded that the new settlement of Austinburg needed a settled Congregational minister. She rode alone by horseback over six hundred miles to Bristol Connecticut — clothing in a portmanteau, thirty-day journey through unsettled forest — to persuade Sally and Rev. Giles Hooker Cowles to migrate to the Western Reserve. Her ride succeeded; the Cowles family arrived in Austinburg in 1811."},{"number":2,"category":"education","header":"Daughters all attended Litchfield Female Academy","body":"Four of her daughters attended the Litchfield Female Academy — Sybil Webb in 1818, Chloe, Florilla, and Sophia. The Academy founded by Sarah Pierce in 1792 was among the earliest formal secondary schools for women in the United States."}],"quotes":[],"sources":[{"short":"Williams Brothers 'History of Ashtabula County' (1878), biography of Rev. Giles Hooker Cowles","url":"https://ohiogenealogyexpress.com/ashtabula/ashtaco_1878_bios/ashtaco_1878_bios_cowlesGiles.html","accessed":"2026-05"},{"short":"Edward Hooker 1909, entry #688 (re: marriage of Rev. Eliphalet Austin Jr to Sally Berrien Cowles, identifies mother as Sibyl Dudley)","url":"https://archive.org/details/descendantsofrev00hook","accessed":"2026-05"}],"research_sources":[],"documents":[],"slug":"sybil-dudley-1761"},"H00443":{"id":"H00443","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1766,"month":8,"day":26,"city":"Farmington","state":"Connecticut","country":"United States"},"parents":{"father_id":"I00156","mother_id":"H00232"},"tags":["named_for_hooker","minister","town_founder","ohio_migration","yale_graduate"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 443"},{"short":"Williams Brothers 1878","page":"Cowles biography, Ashtabula County history"},{"short":"Kent State Cowles Papers","page":"Cowles family archive"},{"short":"Tracy Peck 1859","page":"Bristol Congregational church history"}],"death":{"year":1835,"month":7,"day":5,"city":"Austinburg","state":"Ohio","country":"United States"},"marriages":[{"spouse_id":"X00259","children_ids":["H01141","H01142","H01143","H01144","H01145","H01146","H01147","H01148","H01149"],"marriage_number":1,"date_year":1793,"date_month":2,"date_day":5,"location_country":"United States","end_type":"death_of_spouse","end_year":1830}],"cross_connections":[{"type":"mentor_student","related_id":"X00128","display_label":"He studied theology under Jonathan Edwards the Younger in New Haven.","link_text":"Rev. Jonathan Edwards Jr."},{"type":"hooker_talcott_convergence","related_id":"H00386","display_label":"Both Hooker descendants built the Connecticut Western Reserve.","link_text":"Pierpont Edwards"},{"type":"family_orbit","related_id":"X02783","display_label":"She rode 600 miles in 1810 to recruit him to Ohio","link_text":"Sybil Dudley Austin"},{"type":"civic_peer","related_id":"X02782","display_label":"Co-founders of Austinburg church and Western Reserve College","link_text":"Judge Eliphalet Austin Sr."}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["religion","education"],"notable_blurb":"Pioneer minister, founded Austinburg Ohio 1811","primary_url":"https://ohiogenealogyexpress.com/ashtabula/ashtaco_1878_bios/ashtaco_1878_bios_cowlesGiles.html","primary_url_label":"Ohio Genealogy Express"},"burial":{"cemetery_id":"CEM035","plot_notes":"Buried beside his wife Sallie White Cowles and son Edward. Funeral held in the church he helped build."},"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1786-1789","institution_blurb":"Graduated Yale College 1789 with honors; D.D. awarded by Williams College 1823."},{"institution_id":"INST044","relationship":"founder","years":"1825-1826","institution_blurb":"One of the original founders of Western Reserve College (now Case Western Reserve University) in 1826; drove the founding stake on College Hill, Hudson Ohio."},{"institution_id":"INST003","relationship":"member","years":"1792-1810","institution_blurb":"Ordained minister at First Congregational Church, Bristol CT 1792-1810."},{"institution_id":"INST043","relationship":"alumnus"}],"narrative_blocks":[{"number":1,"category":"religion","header":"A thirty-day wagon journey from Bristol","body":"In 1811 Cowles loaded his family of nine children onto two wagons and traveled thirty to forty days over mud roads to Austinburg, Ohio — a journey so final that returning was considered nearly impossible. His congregation built the first church with a steeple in the state of Ohio, and he served it for nearly twenty-five years."},{"number":2,"category":"education","header":"Drove the founding stake of Ohio's first college","body":"In 1825 Cowles helped found Western Reserve College — called 'Yale of the West' for sharing Yale's motto, standards, and curriculum. He was among those who drove a stake on College Hill in Hudson, Ohio, and his name appears as an original incorporator. The college is now Case Western Reserve University."},{"number":3,"category":"religion","header":"Yale 1789, then theology with Edwards the Younger","body":"After Yale 1789 Cowles read theology with tutor William Robinson before continuing under Rev. Dr. Jonathan Edwards Jr. at New Haven, son of the Great Awakening preacher. Edwards Jr. ordained him at Bristol's First Church on October 17, 1792."},{"number":4,"category":"religion","header":"'A year never to be forgotten' — 1799","body":"A revival swept his Bristol parish in 1799 and added 218 members to the church, the harvest of his early ministry. Three years later he was preaching publicly against the Bristol Baptists in defense of infant baptism, sermons that drew fierce reply."},{"number":5,"category":"social_reform","header":"His Austinburg parsonage gathered the era's reformers","body":"His 320-acre Austinburg parsonage built in 1815 housed the Western Reserve's largest county library and a steady traffic of visitors — Bishop Philander Chase passing through on his Ohio diocese rounds, anti-slavery orators stopping for hospitality. The Cowles household became a way-station for the reform circuits of the Reserve."},{"number":6,"category":"death","header":"Resigned the pulpit 1830, died still preaching","body":"Cowles resigned his Austinburg pulpit in 1830 with a farewell sermon on 1 Samuel 12:23: 'God forbid that I should sin against the Lord in ceasing to pray for you.' Five years later, on Sunday July 5, 1835, he died at his parsonage and the Western Reserve's clergy gathered to bury him in his own churchyard."}],"career":[{"title":"Congregational Minister","start_year":1792,"end_year":1835,"location_city":"Bristol","location_state":"Connecticut","notes":"Ordained Oct 17, 1792. Bristol CT 1792-1810. Austinburg OH 1811-1835."},{"title":"Theological Student under Rev. Dr. Jonathan Edwards Jr.","location_city":"New Haven","location_state":"Connecticut","start_year":1789,"end_year":1791,"notes":"Read theology under Edwards the Younger after Yale graduation; tutored earlier under William Robinson."},{"title":"Licensed Candidate to Preach","organization":"Hartford North Association","location_state":"Connecticut","start_year":1791,"end_year":1792,"notes":"Licensed May 31, 1791."},{"title":"Pastor","organization":"First Congregational Church of Bristol (New Cambridge)","location_city":"Bristol","location_state":"Connecticut","start_year":1792,"end_year":1810,"notes":"Ordained October 17, 1792. Dismissed May 24, 1810 in preparation for Ohio migration."},{"title":"Pastor","organization":"United Church of Austinburg and Morgan","location_city":"Austinburg","location_state":"Ohio","start_year":1811,"end_year":1830,"notes":"Installed September 25, 1811. Built first steepled church in Ohio. Resigned pulpit 1830."},{"title":"Co-founder","organization":"Western Reserve College","location_city":"Hudson","location_state":"Ohio","start_year":1825,"end_year":1826,"notes":"Original incorporator; drove the founding stake on College Hill, Hudson Ohio. Now Case Western Reserve University."}],"education":[{"degree":"B.A. with honors; M.A.","notes":"Prepared under Rev. Wm. Robinson of Southington; entered Yale Jun 1, 1786; graduated Sep 9, 1789.","school_name":"Yale College","graduation_year":1789,"institution_id":"INST022"},{"degree":"D.D. (honorary)","school_name":"Williams College","graduation_year":1823,"institution_id":"INST043"}],"bio":{"display_name":"Rev. Giles Hooker Cowles","first_name":"Giles","last_name":"Cowles","middle_name":"Hooker","title":"Reverend","married_names":[],"photo_url":"https://ohiogenealogyexpress.com/ashtabula/graphics/1878_CowlesGHRev_Res_austinburgO.jpg","photo_notes":"Illustration of the Cowles family residence, Austinburg, Ohio (1878). No portrait survives."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"giles-cowles-1766"},"X00259":{"id":"X00259","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["ohio_migration"],"sources":[{"short":"Find a Grave Memorial 47260486 (Sally White Cowles)","url":"https://www.findagrave.com/memorial/47260486/sally-cowles","accessed":"2026-05"},{"short":"Williams Brothers 'History of Ashtabula County' (1878), biography of Rev. Giles Hooker Cowles","url":"https://ohiogenealogyexpress.com/ashtabula/ashtaco_1878_bios/ashtaco_1878_bios_cowlesGiles.html","accessed":"2026-05"}],"birth":{"year":1774,"month":1,"day":1,"city":"Stamford","state":"Connecticut","country":"United States"},"death":{"year":1830,"month":7,"day":31,"city":"Austinburg","county":"Ashtabula County","state":"Ohio","country":"United States"},"gender":"female","number_of_marriages":1,"marriages":[{"spouse_id":"H00443","children_ids":["H01141","H01142","H01143","H01144","H01145","H01146","H01147","H01148","H01149"],"marriage_number":1,"date_year":1793,"date_month":2,"date_day":5,"location_city":"Stamford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1830}],"parents":{"father_research_notes":"Lebbeus White, b. Stamford Jun 10, 1748; Revolutionary War private; drowned 1779 (NOT at Delaware crossing — family tradition incorrect; drowned event inscribed on Stamford tombstone). d. Jul 5, 1779.","mother_research_notes":"Abigail Weed White, b. Stamford Oct 24, 1750. Descended from Huguenot family De Grasse (name later changed to Weed)."},"notable":{"is_notable":false,"notable_category":[]},"burial":{"cemetery_id":"CEM035","plot_notes":"Buried beside her mother Abigail White, who died the year before."},"narrative_blocks":[{"number":1,"category":"character","header":"She convinced her husband to move to Ohio","body":"It was Sally who first embraced the idea of emigrating to the Western Reserve — seeing in the distant Ohio lands cheap land and opportunity for her boys. She persuaded her husband to make the scouting journey on horseback that led to the family's migration in 1811, loading nine children onto two wagons for a thirty-day journey from which return was considered nearly impossible."},{"number":2,"category":"legacy","header":"First child born to the Mayflower settlers","body":"Sally White was a direct descendant of Peregrine White, born aboard the Mayflower in Provincetown Harbor in 1620 — the first child born to the Mayflower settlers in the New World. She was also descended, on her mother's side, from the Huguenot family De Grasse, whose name was later anglicized to Weed."}],"cross_connections":[],"bio":{"display_name":"Sally White Cowles","first_name":"Sally","last_name":"Cowles","maiden_name":"White","married_names":["Cowles"],"photo_url":"https://ohiogenealogyexpress.com/ashtabula/graphics/1878_CowlesGHRev_Res_austinburgO.jpg","photo_notes":"Illustration of the Cowles family residence, Austinburg, Ohio (1878). No portrait survives."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sally-white-1774"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}