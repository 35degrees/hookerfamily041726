ategory":"history","header":"Donated his ancestor's sea chest, 1888","body":"In 1888 he donated his ancestor William Russell's sea chest to the New Haven Colony Historical Society — preserving a tangible 18th-century Russell-family artifact. The chest later passed through the family with George Huntington Larned loaning it back for further display."},{"number":4,"category":"family","header":"Father of ten including Talcott Huntington Russell","body":"He married Mary Elizabeth Hubbard on 29 August 1836 at Clinton NY; they had ten children including Talcott Huntington Russell. His son carried the Talcott + Russell + Huntington surname chain — three founding-era Connecticut family names compressed into one given-name string."}],"bio":{"display_name":"William Huntington Russell","first_name":"William","last_name":"Russell","middle_name":"Huntington","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1833"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"education":[{"institution_id":"INST022","dates":"1833","notes":" — Yale 1833. Co-founded Skull and Bones 1832 with Alphonso Taft. Son of Matthew Talcott Russell (H00856). Second cousin of Samuel Wadsworth Russell (China trader)."}],"slug":"william-russell-1809"},"X00449":{"id":"X00449","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1816},"death":{"year":1890},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1395","children_ids":["HD1402","HD1403","HD1404","HD1405","HD1406","HD1407","HD1408","HD1409","HD1410","HD1411"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]}