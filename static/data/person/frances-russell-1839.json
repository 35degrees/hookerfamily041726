_blocks":[{"number":1,"category":"family","header":"His childless uncle paid for his Yale education","body":"Col. Matthew Talcott had married his aunt Mary Russell and they had no children of their own. The Colonel met the expenses of his namesake nephew's schooling at Yale."},{"number":2,"category":"education","header":"Studied law under future Chief Justice Ellsworth","body":"He read law in Windsor with Oliver Ellsworth, who would later draft the Constitution and serve as third Chief Justice of the United States. He was admitted to the Connecticut bar in January 1786."},{"number":3,"category":"family","header":"His son co-founded Skull and Bones at Yale","body":"His fifth son William Huntington Russell graduated Yale in 1833. William had co-founded the Skull and Bones secret society there in 1832 as an undergraduate."},{"number":4,"category":"career","header":"Sixteen years as Middletown City Treasurer","body":"He held the office continuously while serving as State's Attorney for Middlesex County. He was ordained Deacon of the church in April 1798."},{"number":5,"category":"career","header":"Yale tutor before settling into law","body":"He served as Yale tutor from November 1782 until May 1786. He was admitted to the College Church in 1785 during this period."}],"slug":"matthew-russell-1761"},"X00448":{"id":"X00448","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"Online vital records / Talcott Pedigree"}],"birth":{"year":1769},"death":{"year":1857},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00856","date_year":1797,"date_month":9,"date_day":17,"children_ids":["HD1388","HD1389","HD1390","HD1391","HD1392","HD1393","HD1394","HD1395","HD1396","HD1397","HD1398","HD1399","HD1400"]}],"notable":{