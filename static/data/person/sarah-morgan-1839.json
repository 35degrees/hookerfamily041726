:false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1840},"death":{"year":1911},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1217","children_ids":["HD1238","HD1239"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"George Hale Morgan","first_name":"George","last_name":"Morgan","middle_name":"Hale","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"george-morgan-1840"},"HD1238":{"id":"HD1238","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00386","mother_id":"HD1217"},"tags":["episcopal","merchant","princeton_graduate"],"sources":[],"birth":{"year":1867,"month":6,"day":5,"city":"Irvington","county":"Westchester County","state":"New York"},"death":{"year":1932,"month":8,"day":18,"city":"Valmont","state":"Vaud","country":"Switzerland","age":65},"marriages":[{"spouse_id":"X00387","children_ids":["HD1240","HD1241","HD3126c"],"marriage_number":1,"date_year":1891,"date_month":1,"date_day":1}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["banker","art_collector","bibliophile"],"notable_blurb":"Princeton librarian; Virgil collection; Order of Crown","primary_url":"https://en.wikipedia.org/wiki/Junius_Spencer_Morgan_II","primary_url_label":"Junius Spencer Morgan II — Wikipedia"},"burial":{"cemetery_id":"CEM025"},"landmarks":[{"landmark_id":"LM026","landmark_blurb":"He leased the Jay Estate 1892-1897; his first child was born here."}],"cross_connections":[{"type":"naming_pattern","related_id":"HD1218","display_label":"Named after maternal uncle who died at age eleven","notes":"HD1238 (1867-1932) was named after his maternal uncle HD1218 (1846-1858), who died at age 11 in London nine years before HD1238's birth. The 'II' suffix was re-used by the family for the next-generation namesake. The Wikipedia article for HD1238 also titles him 'Junius Spencer Morgan II' — the convention disregards HD1218 the boy who died young."}],"bio":{"display_name":"Junius Spencer Morgan II","first_name":"Junius","last_name":"Morgan","middle_name":"Spencer","married_names":[],"suffix":"II","gender":"male","photo_url":"https://images.findagrave.com/photos/2017/220/140315213_1502289320.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[{"name_element":"Junius Spencer Morgan II","inspired_by_id":"HD1218","description":"Named after his maternal uncle Junius Spencer Morgan II 'the elder' (HD1218, 1846-1858), who died at age 11 in London nine years before HD1238's 1867 birth. The 'II' suffix was effectively re-used by the family for the next-generation namesake — the common nineteenth-century New England elite family pattern when a child died young."}],"institutions":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"character","header":"Virgil collection bears his name at Princeton","body":"As a Princeton student Junius Spencer Morgan II began collecting early editions of the Latin poet Virgil and donated them to the Princeton University Library starting in 1896, adding new volumes annually until his death in 1932. His lifetime collection of over seven hundred Virgil titles bears his name at the Princeton library — among the most significant private classical-text collections of the era. In January 1932 he was awarded the Order of the Crown of Italy (Commendatore) by Italian Consul General Emanuele Grazzi 'for spreading culture of the Old World in the New.'"},{"number":2,"category":"character","header":"Major Metropolitan Museum benefactor of Dürer prints","body":"Junius was a generous benefactor of the Metropolitan Museum of Art in New York, giving many works to the future Department of Drawings and Prints. His 1919 gift to the Met included two Dürer woodblocks and a wide range of prints dating mainly from the sixteenth century. He also gave significantly to the Princeton University Art Museum and collected Baskerville editions, incunables, French silver, Delft pottery, and Sevres porcelain."},{"number":3,"category":"career","header":"Princeton Associate Librarian during library's expansion","body":"Junius served as Associate Librarian of Princeton University Library from 1898 to 1908 — a period during which the library greatly enlarged and transformed into a true research library. At his death he was honorary chairman of the newly founded Friends of the Princeton University Library. He had also been a banker as partner in Cuyler Morgan and Company before retiring from banking in 1906."},{"number":4,"category":"family","header":"Encouraged his uncle to form Morgan Library NYC","body":"Junius Spencer Morgan II supposedly encouraged his uncle J. Pierpont Morgan Sr. to collect, organize, and form what became the Morgan Library in New York City. The Morgan Library would later open to the public as a major American repository of medieval manuscripts and rare books. The nephew's bibliophilic influence on the older Morgan's collecting habits placed him at the origins of one of the foremost private-library institutions of the American Gilded Age."},{"number":5,"category":"family","header":"Born Irvington NY 1867, died Switzerland 1932","body":"Junius Spencer Morgan II was born June 5, 1867 in Irvington, Westchester County New York and died August 18, 1932 in Valmont (Montreux area), Vaud canton Switzerland, at age sixty-five. He is buried at Cedar Hill Cemetery, Hartford Connecticut. He married Josephine Adams Perry (1869-1963) — daughter of Brigadier General Perry — and they had two children, leasing the Jay Estate in Rye NY 1892-1897 where their first child was born."}],"slug":"junius-morgan-ii-1867"},"X00387":{"id":"X00387","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1869,"month":10,"day":21,"city":"Washington","state":"D.C."},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1238","children_ids":["HD1240","HD1241","HD3126c"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1963,"month":1,"day":1},"burial":{"cemetery_id":"CEM025"},"cross_connections":[],"bio":{"display_name":"Josephine A. Perry Morgan","first_name":"Josephine","last_name":"Morgan","middle_name":"A","maiden_name":"Perry","married_names":["Morgan"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"josephine-perry-1869"},"HD1240":{"id":"HD1240","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1238","mother_id":"X00387"},"tags":[],"sources":[],"birth":{"year":1893,"month":2,"day":17,"city":"Rye","county":"Westchester County","state":"New York"},"gender":"female","marriages":[{"spouse_id":"X01455","children_ids":["HD3126a","HD3126b","HD3126"],"marriage_number":1,"date_year":1914,"date_month":1,"date_day":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1949,"month":7,"day":14,"city":"Princeton","state":"New Jersey"},"burial":{"cemetery_id":"CEM026"},"narrative_blocks":[{"header":"Her mother hosted a Colony Club dance","body":"On January 11, 1920, the New York Times noted that Mrs. Junius Spencer Morgan and Miss Caroline Morgan would give a dance at the Colony Club for 'her son-in-law and daughter, Mr. and Mrs. Henry Burchell Gardner.' She had married Henry Burchell Gardner in 1914 — the Harvard quarterback named to the 1912 All-America team.","number":1}],"cross_connections":[],"bio":{"display_name":"Sarah Spencer Morgan Gardner","first_name":"Sarah","last_name":"Gardner","suffix":"Jr.","maiden_name":"Morgan","middle_name":"Spencer","married_names":["Gardner"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-gardner-jr-1893"},"HD1241":{"id":"HD1241","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1238","mother_id":"X00387"},"tags":["architect","wwii","military"],"sources":[{"label":"FindAGrave — Alexander Perry Morgan Sr."}],"birth":{"year":1900,"month":10,"day":10,"city":"Princeton","county":"Mercer County","state":"New Jersey"},"marriages":[{"spouse_id":"X00388","children_ids":["HD1242"],"marriage_number":1,"date_year":1923,"date_month":2,"date_day":10}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1968,"month":12,"day":19,"city":"New York","state":"New York"},"burial":{"cemetery_id":"CEM025"},"narrative_blocks":[{"header":"He went to Paris to study Beaux-Arts","body":"Alexander Perry Morgan Sr. graduated from Princeton in 1922 and moved to Paris to study architecture at the École des Beaux-Arts, the historic school that trained the designers of the Boston and New York Public Libraries. Among his works, he designed the distinctive top of the Empire State Building, originally conceived as a Zeppelin docking station — one of the more audacious engineering proposals of the 1930s.","number":1}],"cross_connections":[{"type":"parallel_careers","related_id":"I01138","display_label":"Same-era Paris Beaux-Arts architect — Baltimore houses and Richland Farm","link_text":"Bayard Turnbull"},{"type":"parallel_careers","related_id":"TD0250","display_label":"Paris Prize 1912 Beaux-Arts architect; Penn Christian Association","link_text":"Donald Morris Kirkpatrick"}],"bio":{"display_name":"Alexander Perry Morgan Sr.","first_name":"Alexander","last_name":"Morgan","middle_name":"Perry","married_names":[],"suffix":"Sr."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"alexander-morgan-sr-1900"},"HD3126c":{"id":"HD3126c","is_placeholder":false,"gender":"male","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1913,"month":1,"day":1},"death":{"year":1916,"month":1,"day":1},"parents":{"father_id":"HD1238","mother_id":"X00387"},"marriages":[],"number_of_marriages":0,"tags":["died_in_childhood"],"sources":[{"short":"FindAGrave"}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"John Hubert Morgan","first_name":"John","last_name":"Morgan","married_names":[],"middle_name":"Hubert"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slu