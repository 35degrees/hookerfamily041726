rue,"notable_category":[],"notable_blurb":"Rev., generation 5 from Hooker"},"number_of_marriages":2,"bio":{"display_name":"Rev. John Pierpont","first_name":"John","last_name":"Pierpont","title":"Reverend","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST024","relationship":"alumnus","institution_blurb":"Studied law there before turning to Unitarian ministry."},{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"religion","header":"Boston Unitarian who fought slavery from the pulpit","body":"He served as Pastor of Boston's Hollis-Street Church from 1819 to 1845, one of America's most prominent Unitarian pulpits. From there he published anti-slavery poems, championed temperance, and earned a national reputation as a reformer."},{"number":2,"category":"career","header":"Yale 1804 lawyer turned poet and minister","body":"He graduated Yale College in 1804 and trained at Litchfield Law School before practicing in Newburyport, Massachusetts. He left law for the Unitarian ministry, publishing his volume of religious verse 'Airs of Palestine' to wide acclaim."},{"number":3,"category":"legacy","header":"Grandfather of J.P. Morgan","body":"His daughter Juliet Pierpont married Junius Spencer Morgan in 1836, making him the maternal grandfather of financier J. Pierpont Morgan. The Morgan banking dynasty descends from him through this single marriage."},{"number":4,"category":"legacy","header":"His son James composed 'Jingle Bells' in 1857","body":"His son James Lord Pierpont (1822-1893) composed 'Jingle Bells' in 1857, originally as a Thanksgiving song. The song became one of the most-recorded Christmas standards of the 20th century."},{"number":5,"category":"military","header":"Served as Civil War chaplain at seventy-six","body":"He volunteered as a regimental chaplain in 1861 at age 76 — among the oldest serving in the Union Army. The age was no obstacle to his commitment to the abolitionist cause."}],"slug":"john-pierpont-1785"},"X00357":{"id":"X00357","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1787},"death":{"year":1855},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00826","date_year":1810,"date_month":9,"date_day":23,"children_ids":["HD1164","HD1165","HD1166","HD1167","HD1168","HD1169"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Sheldon Lord","first_name":"Mary","middle_name":"Sheldon","maiden_name":"Lord","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-lord-1787"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}