Entry 262"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Anne Parmalee Hooker","first_name":"Anne","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Parmalee"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"anne-parmalee-1737"}},"burialCemetery":null,"institutionsById":{"INST054":{"id":"INST054","primary_name":"Middlebury College","name":"Middlebury College","short_name":"Middlebury","alt_names":[],"type":"college","founding_year":1800,"location":{"city":"Middlebury","state":"Vermont","country":"United States"},"primary_url":"https://en.wikipedia.org/wiki/Middlebury_College","primary_url_label":"Wikipedia","primary_persons":[],"hooker_connected_people":["H02539","HD0934","HD0935","HD0936","HD1142","H00840","H01354","T01396","TD0206","I00168","HD1148","HD5478","HD5489","HD5536","HD4028"],"person_ids":["X00541","X03029","X03002","X03027"],"related_institutions":[],"related_landmarks":[],"tags":[],"sources":[],"notes":"Liberal arts college founded 1800 in Middlebury VT."},"INST041":{"id":"INST041","primary_name":"American Board of Commissioners for Foreign Missions (ABCFM)","name":"American Board of Commissioners for Foreign Missions (ABCFM)","alt_names":[],"type":"religious_organization","founding_year":1810,"location":{"city":"Boston","state":"Massachusetts"},"primary_url":"https://en.wikipedia.org/wiki/American_Board_of_Commissioners_for_Foreign_Missions","primary_url_label":"Wikipedia","secondary_url":"https://www.okhistory.org/publications/enc/entry?entry=DW001","secondary_url_label":"Oklahoma Historical Society — Dwight Mission","primary_persons":[],"hooker_connected_people":["H01138","H00914","H01354","HD2376","HD2818","H01418","I01195","H02770","I01197","I01218","I01220","H01355","H00527"],"person_ids":["X00724","X01977","X02115","X02121","X02122","X02862"],"related_institutions":[],"related_landmarks":[],"tags":["missions","native_american_contact","congregationalist"],"sources":[],"notes":"Founded 1810 at Andover Seminary, Massachusetts by prominent Congregationalists. First American foreign missionary society; first missions to China and Ceylon. Yale President Rev. Timothy Dwight IV (H00914) was among the founding figures; Dwight Mission (established 1820 in present-day Arkansas/Oklahoma for the Cherokee) was named in his honor. The board operated Brainerd Mission (Chattanooga TN, est.1817) where Harriet Ellsworth Blunt (X02121) and Ainsworth Blunt (X02122) served the Cherokee. HOOKER TREE CONNECTIONS: 1. Rev. Timothy Dwight IV (H00914) — Yale President 1795-1817; founding ABCFM figure; Dwight Mission named for him. 5th-generation Hooker descendant. 2. Elias Cornelius (X00724) — ABCFM Secretary of Domestic Correspondence 1819-1832; conducted 1817 missionary tour to Creek and Cherokee; m. Mary Ann Hooker (H01355). 3. Rev. Edward William Hooker (H01354) — corporate ABCFM member from 1840. 4. Harriet Ellsworth Blunt (X02121) — served at Brainerd Mission 1821-1837; granddaughter of Rev. Cyprian Strong (H00299). 5. Ainsworth Blunt (X02122) — Brainerd missionary 1822-1837; accompanied Cherokee on Trail of Tears 1838; first mayor of Dalton GA. 6. Dr. Mary Floyd Cushman (HD2818, gen 8) — ABCFM medical missionary in Angola 1922-1953. 7. Samuel Gelston Dwight (HD2376) — ABCFM missionary to Hawaii; children named for ABCFM colleagues Juliette Cooke and Samuel Castle."},"INST137":{"id":"INST137","primary_name":"Andover Theological Seminary","name":"Andover Theological Seminary","alt_names":["Andover Newton Theological School (post-1908 merger with Newton Theological Institution)"],"type":"theological_seminary","denomination":"Congregational","founding_year":1807,"location":{"city":"Andover","county":"Essex","state":"Massachusetts","country":"United States"},"primary_url":"https://en.wikipedia.org/wiki/Andover_Theological_Seminary","primary_persons":[],"hooker_connected_people":["H00703","H01354","H02539","HD1983","HD2631","I00449","I00470","T02202","I01195","H01418"],"person_ids":["X02847","X02862"],"related_institutions":[],"related_landmarks":[],"tags":[],"sources":[],"notes":"Founded 1807 as a conservative Trinitarian Congregational response to Unitarian Harvard. The most prestigious Protestant theological seminary in antebellum America. Trained ministers including Rev. John Ripley Adams (X02847, 1826), Rev. Edward Strong Dwight (HD1983), and many ABCFM missionaries. Merged with Newton Theological Institution 1908 to form Andover Newton Theological School; relocated to Newton MA. Now affiliated with Yale Divinity School (as of 2017). | Merged from INST050: Founded 1808 in Andover MA. Leading Calvinist seminary. Notable Hooker-tree connection: Rev. John Erskine Edwards (HD2631) graduated 1835."}},"crossConnections":[]}