":"HD1371","display_label":"Donated his great-grandfather's Canton trade archive to the Library of Congress.","link_text":"Samuel Wadsworth Russell"}],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Library of Congress in 1931"},"number_of_marriages":1,"bio":{"display_name":"Thomas Macdonough Russell Sr.","first_name":"Thomas","last_name":"Russell","suffix":"Sr.","middle_name":"Macdonough","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[{"name_element":"Macdonough","description":"Named for great-uncle Commodore Thomas Macdonough, hero of the Battle of Lake Champlain 1814."}],"institutions":[{"institution_id":"INST009","institution_blurb":"Russell family Wesleyan-campus property descent (great-grandson of Samuel Wadsworth Russell, the China trade founder)."}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Chaired the Russell Manufacturing Company","body":"He led the Middletown company his great-grandfather Samuel Wadsworth Russell had founded in 1834. He also served as Vice President of Central National Bank."},{"number":2,"category":"legacy","header":"Donated his great-grandfather's Canton archive to Congress","body":"In 1931 he gave the Library of Congress the Russell & Company records — five linear feet documenting the firm's nineteenth-century opium operations. The collection runs to ten microfilm reels and 3,900 items."},{"number":3,"category":"family","header":"Named for his great-uncle, the Lake Champlain hero","body":"Commodore Thomas Macdonough won the decisive 1814 naval engagement that preserved American control of the lake. The Commodore's grandnephew received the name sixty years later."},{"number":4,"category":"death","header":"Died on his couch waiting for the doctor","body":"On July 30, 1936 he came home to 350 High Street after lunch at the Middletown Yacht Club and suffered a heart attack. He was lying on a couch awaiting the physician when he died."},{"number":5,"category":"legacy","header":"His house is now a Wesleyan center","body":"The 1902 Colonial Revival mansion at 350 High Street stands across from his ancestor Samuel Russell's Greek Revival house. Wesleyan University now operates it as the Center for African American Studies."}],"burial":{"cemetery_id":"CEM859"},"education":[{"school_name":"St. Mark’s School","type":"secondary"},{"school_name":"Sheffield Scientific School, Yale","type":"undergraduate"}],"career":[{"role":"Chairman","organization":"Russell Manufacturing Company"},{"role":"Mayor","organization":"Middletown, Connecticut"},{"role":"Civil engineer","organization":"Middletown & Berlin railroad line"}],"slug":"thomas-russell-sr-1874"},"HD1387":{"id":"HD1387","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1386","mother_id":"X00445"},"tags":[],"sources":[],"birth":{"year":1876},"death":{"year":1937},"gender":"female","marriages":[{"spouse_id":"X01481","children_ids":[],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Lucy Hubbard Russell Dabney","first_name":"Lucy","last_name":"Dabney","maiden_name":"Russell","middle_name":"Hubbard","married_names":["Dabney"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"lucy-dabney-1876"},"HD1371":{"id":"HD1371","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00850","mother_id":"X00438"},"tags":[],"sources":[],"birth":{"year":1789},"death":{"year":1862},"marriages":[{"spouse_id":"X00440","children_ids":["HD1375","HD1376"],"marriage_number":1,"date_year":1815,"date_month":10,"date_day":6},{"spouse_id":"X00439","children_ids":["HD1377"],"marriage_number":2,"date_year":1825,"date_month":10,"date_day":26}],"cross_connections":[{"type":"artifact","related_id":"HD1378","display_label":"His great-grandson donated the firm's Canton archive to the Library of Congress.","link_text":"Thomas Macdonough Russell Sr."},{"type":"parallel_descent","related_id":"HD1395","display_label":"Second cousins — both great-grandsons of Noadiah Russell. Russell co-founded Skull and Bones in 1832, the same year Samuel's Russell & Company reached its peak opium operation in Canton.","link_text":"William Huntington Russell"}],"gender":"male","notable":{"is_notable":true,"notable_category":[],"primary_url":"https://en.wikipedia.org/wiki/Russell_%26_Company"},"number_of_marriages":2,"bio":{"display_name":"Samuel Wadsworth Russell","first_name":"Samuel","last_name":"Russell","middle_name":"Wadsworth","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST009","institution_blurb":"His 1828 Greek Revival house (LM016, 350 High Street) is now Wesleyan's Department of Philosophy."},{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"business","header":"Largest American opium trader in 1830s China","body":"Arrived Canton 1819; founded Samuel Russell & Co.; from 1824 restructured as Russell & Company. By early 1831 had smuggled 3,500 chests of Indian opium into China — approximately twenty percent of the country's total annual opium imports that year. Russell & Company was the largest American opium trading house in China."},{"number":2,"category":"legacy","header":"Skull and Bones founded by his Russell cousin","body":"His second cousin William Huntington Russell co-founded Skull and Bones at Yale in 1832 with Alphonso Taft — both Hooker descendants themselves. The Russell family fortune that helped support the society's early decades had been substantially built on his own Russell & Company opium trading at Canton, China."},{"number":3,"category":"family","header":"Business partner was FDR's maternal grandfather","body":"Among the partners at Russell & Company was Warren Delano Jr. — the maternal grandfather of President Franklin Delano Roosevelt. The Russell-Delano connection ran through the China opium trade two generations before Delano's grandson reached the White House."},{"number":4,"category":"architecture","header":"Greek Revival mansion 1828 by Ithiel Town","body":"On returning from Canton 1831 he commissioned a major Greek Revival mansion at Middletown CT, designed 1826-1828 by Ithiel Town — the same architect Daniel Wadsworth used for the Wadsworth Atheneum. The Middletown mansion remains a landmark of the Greek Revival movement in American domestic architecture."},{"number":5,"category":"marriage","header":"Lost his first wife at twenty-three, 1819","body":"Married Mary Cotton Osborn on 6 October 1815 in New York; she died in 1819 leaving him with two sons. Six years later in October 1825 he married her sister Frances Ann Osborn — the family stabilization pattern echoed in many Dwight cousins of his generation."}],"slug":"samuel-russell-1789"},"X00440":{"id":"X00440","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1796},"death":{"year":1819},"gender":"female","number_of_marriages