"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM035","plot_notes":"Austinburg Center Cemetery"},"narrative_blocks":[{"number":1,"category":"social_reform","header":"Recording secretary of Ashtabula's antislavery society","body":"Eliphalet served as recording secretary at the May 1834 founding of the Anti-Slavery Society of Ashtabula County. The society's preamble declared all men created free and equal and called for 'the utter extinction of slavery by immediate emancipation.' His own father-in-law's parsonage and his household served as an Underground Railroad station for fleeing slaves."}],"slug":"eliphalet-austin-jr-1793"},"H01142":{"id":"H01142","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1796,"month":2,"day":21,"city":"Bristol","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00443","mother_id":"X00259"},"tags":["abolitionist","ohio_migration","underground_railroad"],"sources":[{"short":"Cowles Families in America #688 — Sally Berrien Cowles Austin"},{"short":"Edward Hooker 1909","entry":"1142"},{"short":"Williams Brothers 1878","page":"Ashtabula County history, Cowles family"}],"gender":"female","marriages":[{"marriage_number":1,"spouse_id":"X01418","date_year":1819,"date_month":8,"date_day":31,"location_country":"United States","children_ids":["HD3713","HD3714","HD3715","HD3716"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1872,"month":9,"country":"United States"},"cross_connections":[],"bio":{"display_name":"Sally Berrien Cowles Austin","first_name":"Sally","last_name":"Austin","maiden_name":"Cowles","middle_name":"Berrien","married_names":["Austin"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"First Cowles bride of the Austinburg generation","body":"At twenty-three Sally married a son of Judge Eliphalet Austin in 1819, joining the founding family of the Ohio settlement her father had been recruited to plant. The wedding fused two of Austinburg's pioneer households."},{"number":2,"category":"social_reform","header":"Their farmhouse hid passengers on the Underground Railroad","body":"The Austin household ran one of Ashtabula County's documented Underground Railroad stations through the 1830s and 1840s, sheltering fugitives moving north toward Lake Erie. Sally kept the kitchen fires going for travelers who never appeared in the daylight record."},{"number":3,"category":"family","header":"Widowed at forty-one — outlived him by thirty-five years","body":"Her husband died in 1837 and left her a young widow with the household to keep. She managed the farm and raised the children alone for thirty-five years until her own death in 1872."}],"burial":{"cemetery_id":"CEM035","plot_notes":"Austinburg Center Cemetery, Austinburg, Ashtabula County, Ohio."},"slug":"sally-austin-1796"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}