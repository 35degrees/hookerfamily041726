ards and may reflect undocumented infant losses or simply a smaller completed family size."},{"number":3,"category":"family","header":"Hartford 1772 to West Haven 1851 age seventy-eight","body":"Eunice Hooker was born December 25, 1772 in Hartford Connecticut — daughter of Daniel Hooker (the family's third Daniel) and Mary Sedgwick Hooker — and died December 9, 1851 in West Haven Connecticut at age seventy-eight. The Hartford-to-coastal-Connecticut life arc tracked her marriage migration south to the Hubbell family's coastal New Haven County settlement."}],"slug":"eunice-hubbell-1772"},"X00935":{"id":"X00935","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["revolutionary_war"],"sources":[{"short":"EH 1909; FamilySearch"}],"birth":{"year":1765,"month":5,"day":9,"city":"Weston","county":"Fairfield County","state":"Connecticut","country":"United States"},"death":{"year":1829,"month":2,"day":22,"city":"Weston","county":"Fairfield County","state":"Connecticut","country":"United States"},"gender":"male","number_of_marriages":1,"marriages":[{"spouse_id":"H00994","children_ids":["H02078"],"date_year":1791,"location_state":"Connecticut","marriage_number":1}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"military_service":[{"war":"American Revolutionary War","role":"Soldier","notes":"Per EH 389, served as Revolutionary War soldier.","war_id":"WAR004"}],"bio":{"display_name":"Joseph Hubbell","first_name":"Joseph","last_name":"Hubbell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"slug":"joseph-hubbell-1765"},"H02078":{"id":"H02078","has_descendants_documented":true,"classification":{"include_in_pat