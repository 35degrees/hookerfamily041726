rd","last_name":"Dewey","married_names":[]},"birth":{"year":1829,"month":3,"day":27,"city":"Montpelier","county":"Washington","state":"Vermont","country":"United States"},"baptism":{},"death":{"year":1900,"month":10,"day":26,"city":"Montpelier","county":"Washington","state":"Vermont","country":"United States"},"residence":{"city":"Montpelier","county":"Washington","state":"Vermont","country":"United States","note":"120 State Street; built new home 1889 on family site, moved old house to 144 State Street."},"burial":{"cemetery_id":"CEM180","plot_notes":"Green Mount Cemetery, Montpelier VT."},"gender":"male","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":8,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_id":"X02373","mother_id":"TD0138"},"marriages":[{"marriage_number":1,"spouse_id":"X02375","date_year":1856,"date_month":8,"date_day":27,"location_city":"Montpelier","location_state":"Vermont","location_country":"United States","end_type":"death_of_self","end_year":1900,"children_ids":["TD0150","TD0151","TD0152","TD0153"]}],"number_of_marriages":1,"tags":["civil_war"],"research_tags":[],"sources":[{"label":"Vermont Historical Society — Edward Dewey 8th Vermont Papers (1864)","note":"Quartermaster invoices and inventories from one year of regiment service."},{"label":"FindAGrave — Edward Dewey","url":"https://www.findagrave.com/memorial/49228431/edward_bradley-dewey"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"marriage","header":"Married his stepsister-in-law in 1856","body":"In August 1856 Edward married Susan Griggs Lilley — the daughter of his father Julius's third wife Susan Elizabeth Griggs Lilley (married 1855). Edward and Susan had been stepsiblings-by-marriage for one year before becoming husband and wife. They had six children, four documented in this tree."},{"number":2,"category":"military","header":"Quartermaster at Cedar Creek and Opequon","body":"Edward joined the 8th Vermont Volunteer Infantry as Lieutenant Quartermaster in Louisiana January 1864, accompanied the regiment to Virginia in July, and saw action at Opequon and Cedar Creek. He was promoted Captain in February 1865, resigned three months later, and returned home. His quartermaster invoices for 1864 survive at the Vermont Historical Society."},{"number":3,"category":"legacy","header":"Built the 1889 Queen Anne State Street mansion","body":"Edward commissioned a Queen Anne brick house at 120 State Street Montpelier in 1889 — designed by city mayor and architect George Guernsey on the site of his family's earlier home. The old house was moved to 144 State Street where it stood until 1969. Edward's 1889 house was moved to 128 State Street in 1948 to make way for the Vermont State Office Building."}],"cross_connections":[],"naming_inspiration":[],"education":[],"career":[{"role":"Mercantile (apprentice)","organization":"Various Vermont firms","end_year":1860,"notes":"Prepared for college but chose mercantile life until 1860."},{"role":"Assistant Secretary","organization":"Vermont Mutual Fire Insurance Co.","start_year":1860,"end_year":1864,"notes":"Four-year tenure before Civil War service."},{"role":"Assistant Secretary, then Vice-President","organization":"National Life Insurance Company","start_year":1865,"end_year":1897,"notes":"Returned from Civil War and joined NLI under his father's presidency. Elected vice-president June 1877; held position to January 1897."}],"military_service":[{"war":"American Civil War","rank":"Captain","rank_start":"Lieutenant","rank_end":"Captain","rank_year_start":1864,"rank_year_end":1865,"unit":"8th Regiment, Vermont Volunteer Infantry (Quartermaster)","notes":"Joined 8th VT Volunteers as Quartermaster in Louisiana January 1864; accompanied regiment to Virginia July 1864; participated in battles of Opequon and Cedar Creek. Promoted Captain and Assistant Quartermaster, U.S. volunteers staff department February 11, 1865; resigned three months later. Quartermaster papers preserved at Vermont Historical Society."}],"institutions":[{"institution_id":"INST112","relationship":"executive","years":"1865-1897","institution_blurb":"Civil War quartermaster who returned to serve as assistant secretary then vice-president of his father Julius's National Life Insurance Company until 1897."}],"landmarks":[{"landmark_id":"LM062","landmark_blurb":"Built the 1889 Queen Anne brick house at 120 State Street Montpelier (designed by mayor George Guernsey) on the site of his family home."}],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"edward-dewey-1829"},"X02375":{"id":"X02375","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"display_name":"Susan Griggs Lilley Dewey","first_name":"Susan","middle_name":"Griggs","last_name":"Dewey","maiden_name":"Lilley","married_names":["Dewey"]},"birth":{"year":1834,"month":10,"day":4,"city":"Sutton","county":"Worcester","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1909,"month":3,"day":22,"city":"Montpelier","county":"Washington","state":"Vermont","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM180","plot_notes":"Green Mount Cemetery, Montpelier VT."},"gender":"female","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_research_notes":"Father Lilley (no further detail). Not built.","mother_research_notes":"Mother Susan Elizabeth Griggs (1816-1886) later became third wife of Edward's father Julius Yemans Dewey March 9, 185