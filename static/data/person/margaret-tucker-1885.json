ent_paths_to_thomas":0},"parents":{"father_research_notes":"Father James Martin of Landgrove VT. Not built.","mother_research_notes":"Mother Lucy (Gray) Martin. Not built."},"marriages":[{"marriage_number":2,"spouse_id":"TD0151","date_year":1884,"location_country":"United States","end_type":"death_of_self","end_year":1915,"children_ids":["TD0156"]}],"number_of_marriages":1,"tags":["lawyer","judge","politician"],"research_tags":[],"sources":[{"label":"Wikipedia — James Loren Martin","url":"https://en.wikipedia.org/wiki/James_Loren_Martin"},{"label":"FindAGrave — James Loren Martin","url":"https://www.findagrave.com/memorial/136051568/james_loren-martin"}],"research_sources":[],"notable":{"is_notable":true,"notable_category":["politics","law"],"notable_blurb":"Vermont Speaker; US District Judge 1906-1915","primary_url":"https://en.wikipedia.org/wiki/James_Loren_Martin","primary_url_label":"Wikipedia"},"narrative_blocks":[{"number":1,"category":"career","header":"Law clerkship at fourteen; federal bench at sixty","body":"James paid his own tuition at age fourteen by working in a chair factory, producing maple sugar, and clearing land. He read law with Hoyt Henry Wheeler — and forty years later succeeded that same Wheeler on the federal bench when Theodore Roosevelt appointed him United States District Judge for Vermont in 1906."},{"number":2,"category":"politics","header":"Speaker of Vermont House for four straight years","body":"James served in the Vermont House of Representatives 1874-1882 and was elected Speaker 1878-1882 — four consecutive years presiding over the chamber. Subsequent service: State Tax Commissioner three terms, US Attorney for Vermont 1898-1906, and Federal District Judge from 1906 to his death in 1915."},{"number":3,"category":"family","header":"Lost three children of first marriage by 1882","body":"James's first marriage in 1869 to Delia Howard ended with her death in 1881 and the loss of all three of their children — Jimmie who lived 1873 to 1880, an unnamed infant who lived only days in 1877, and a second Delia who lived from 1881 to 1882. None survived to adulthood, and James remarried in 1884 to Jessie Dewey — with whom he had three daughters who all reached adulthood."}],"cross_connections":[],"naming_inspiration":[],"education":[{"school_name":"Albany Law School","dates":"1869","type":"law","notes":"LL.B. 1869."},{"school_name":"Read law with Hoyt Henry Wheeler","dates":"pre-1869","type":"law","notes":"Clerkship study before Albany Law."}],"career":[{"role":"Attorney","organization":"Self / private practice","location":"Londonderry then Brattleboro, Vermont","start_year":1869,"end_year":1906,"notes":"Purchased Charles N. Davenport's Brattleboro practice."},{"role":"State's Attorney","organization":"Windham County Vermont","start_year":1876,"end_year":1877},{"role":"State Representative","organization":"Vermont House of Representatives","start_year":1874,"end_year":1882,"notes":"From Londonderry. Re-elected from Brattleboro 1892."},{"role":"Speaker of the House","organization":"Vermont House of Representatives","start_year":1878,"end_year":1882},{"role":"Vermont State Tax Commissioner","organization":"State of Vermont","start_year":1888,"end_year":1894,"notes":"1888, 1890-1892, 1894 (intermittent)."},{"role":"United States Attorney","organization":"District of Vermont","start_year":1898,"end_year":1906,"notes":"Succeeded John H. Senter; succeeded by Alexander Dunnett."},{"role":"United States District Judge","organization":"United States District Court for the District of Vermont","start_year":1906,"end_year":1915,"notes":"Recess appointment by Theodore Roosevelt October 20, 1906; formally nominated December 3, 1906; Senate confirmed December 11, 1906. Filled position vacated by Hoyt Henry Wheeler — Martin's former law-reading mentor. Served until his death."}],"military_service":[],"institutions":[{"institution_id":"INST112","relationship":"trustee","institution_blurb":"Director of the National Life I