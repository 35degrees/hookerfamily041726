s":{"father_id":"HD4189","mother_id":"I00635"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00636","date_year":1932,"location_country":"Canada","end_type":"death_of_spouse","end_year":1969,"children_ids":["HD4203","HD4204","HD4205"]}],"education":[],"career":[{"role":"President","organization":"Dome Mines Limited","location":"Toronto","start_year":1959,"end_year":1977,"notes":"President of Dome Mines Limited 1959-1977. Dome Mines was a major Canadian gold mining company."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["canada_migration","alberta_migration","merchant"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"business","header":"Dome Mines president, eighteen years at the top","body":"James Botterell Redpath spent his career in Canadian mining, ultimately serving as President of Dome Mines Limited — a major Canadian gold mining company — from 1959 to 1977. He raised his family at Val-d'Or in northern Quebec where his son James Stockton Redpath grew up around mining operations. The family business orientation extended forward when his son founded J.S. Redpath Ltd., a global leader in mining contracting services."},{"number":2,"category":"family","header":"He raised his family at the minehead","body":"He and Margaret raised three children at Val-d’Or among the mining operations — one founded the J.S. Redpath contracting firm and took the Order of Ontario, one went to the World Bank, one to a Stanford anesthesiology career."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"james-redpath-1908-2"},"I00636":{"id":"I00636","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Margaret","middle_name":"Isobel","last_name":"Redpath","maiden_name":"Stockton","married_names":[],"nickname":"Margot","gender":"female","display_name":"Margaret Isobel Stockton Redpath"},"birth":{"year":1910,"month":2,"day":1,"country":"Canada"},"baptism":{},"death":{"year":1969,"month":11,"day":12,"state":"Ontario","country":"Canada"},"residence":{},"burial":{"cemetery_id":"CEM332","plot_notes":"Mount Pleasant Cemetery Toronto — with husband James Botterell Redpath."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4197","date_year":1932,"location_country":"Canada","end_type":"death","end_year":1969,"children_ids":["HD4203","HD4204","HD4205"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["canada_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"margaret-stockton-1910"},"HD4203":{"id":"HD4203","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"James","middle_name":"Stockton","last_name":"Redpath","married_names":[],"nickname":"Jim","gender":"male","display_name":"James Stockton 'Jim' Redpath","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778702663/jimredpath_g2dkgv.jpg","photo_notes":"Portrait of James Stockton 'Jim' Redpath (1936-2025), founder of J.S. Redpath Ltd."},"birth":{"year":1936,"month":9,"day":24,"city":"Montréal","state":"Quebec","country":"Canada"},"baptism":{},"death":{"year":2025,"month":8,"day":2,"city":"St. John's","county":"Avalon Peninsula Census Division","state":"Newfoundland and Labrador","country":"Canada","cause":"Parkinson's Disease (after 20-year journey)"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":11,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["business"],"notable_blurb":"Founded JS Redpath Ltd. mining contractor, Order of","primary_url":"https://www.findagrave.com/memorial/285664956/james_stockton-redpath","primary_url_label":"FindAGrave memorial #285664956"},"parents":{"father_id":"HD4197","mother_id":"I00636"},"number_of_marriages":1,"marriages":[],"education":[{"school_name":"McGill University","type":"undergraduate","notes":"McGill University degree in mining engineering."},{"school_name":"Sotheby's, New York","type":"professional","notes":"Studied art curation at Sotheby's New York after leaving the mining industry at age 50."}],"career":[{"role":"Founder and CEO","organization":"J.S. Redpath Ltd.","location":"North Bay, Ontario, Canada","start_year":1962,"end_year":1986,"notes":"Founded J.S. Redpath Ltd. at age 26 — mining contracting company specializing in shaft sinking. Built it into a global leader in mining services before stepping away at age 50."},{"role":"Director","organization":"Capitol Arts Centre","location":"North Bay, Ontario, Canada","start_year":1986,"notes":"Led the Capitol Arts Centre North Bay for several years after leaving mining; supported local artists and cultural growth."},{"role":"First Chancellor","organization":"Nipissing University","location":"North Bay, Ontario, Canada","start_year":1994,"notes":"Served as the first Chancellor of Nipissing University in 1994."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["canada_migration","merchant"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"business","header":"Founded global mining contractor at twenty-six","body":"James Stockton 'Jim' Redpath grew up at a mine site in Val-d'Or Quebec where his father James Botterell Redpath worked for Dome Mines. After McGill mining engineering and two formative summers on a Hudson Bay exploration boat as a teenager, he founded J.S. Redpath Limited at age twenty-six — a shaft-sinking mining contractor that became a global leader in mining services. He stepped away from the company at fifty to pursue art curation studies at Sotheby's and lead the Capitol Arts Centre in North Bay."},{"number":2,"category":"honors","header":"Order of Ontario, Queen's Jubilee Medals, two doctorates","body":"Jim Redpath received honorary doctorates from both McGill University and Nipissing University, served as the first Chancellor of Nipissing in 1994, and was awarded Queen Elizabeth II's Golden and Diamond Jubilee Medals along with the Order of Ontario. He retired with his wife Bobbi to St. John's Newfoundland — closing a family arc that began with his great-great-uncle Sir Thomas Roddick's birth at Harbour Grace Newfoundland in 1846. He died there in 2025 after a twenty-year journey with Parkinson's Disease."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"james-redpath-1936"},"HD4204":{"id":"HD4204","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Florence","middle_name":"Anne","last_name":"Redpath","married_names":[],"nickname":"Anne","gender":"female","display_name":"Florence Anne 'Anne' Redpath"},"birth":{"state":"Quebec","country":"Canada"},"baptism":{},"death":{"year":2013,"month":8,"day":9,"country":"Canada"},"residence":{},"burial":{"plot_notes":"Cremated — no specific cemetery."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":11,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD4197","mother_id":"I00636"},"marriages":[],"education":[{"school_name":"McGill University","type":"undergraduate","notes":"McGill University graduate."},{"school_name":"York University","type":"graduate","notes":"One of the first women to receive an MBA from York University."}],"career":[{"role":"Analyst","organization":"World Bank","location":"Washington, D.C., United States","notes":"Started career with World Bank in Washington."},{"role":"Business consultant","notes":"Helped small growing companies as business consultant."},{"role":"Advisory Board Member","organization":"Inanna Publications + Canadian Woman Studies","location":"Canada","notes":"Long-time committed advisory board member of Inanna Publications and its academic journal Canadian Woman Studies."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Florence","inspired_by_id":"I00635","description":"First name Florence honors paternal grandmother Florence Amelia Botterell Redpath."}],"artworks":[],"tags":["canada_migration","new_york_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Among first women MBAs at York, World Bank","body":"Florence Anne 'Anne' Redpath grew up in Val-d'Or northern Quebec and graduated from McGill University. She was one of the first women to receive an MBA from York University, then started her career with the World Bank in Washington before returning to Canada to work on public and private research projects and eventually as a business consultant. She was an ardent supporter of York's School of Women's Studies and a long-time advisory board member of Inanna Publications and Canadian Woman Studies."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"florence-redpath"},"HD4205":{"id":"HD4205","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"John","middle_name":"Huntly","last_name":"Redpath","married_names":[],"gender":"male","display_name":"John Huntly Redpath","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778702722/johnhuntleyredpath_src2fv.jpg","photo_notes":"Portrait of John Huntly Redpath (1942-2024), Stanford-trained anesthesiologist."},"birth":{"year":1942,"month":8,"day":13,"city":"Val-d'Or","county":"Abitibi-Témiscamingue Region","state":"Quebec","country":"Canada"},"baptism":{},"death":{"year":2024,"month":3,"day":3,"city":"Palo Alto","county":"Santa Clara County","state":"California","country":"United States","cause":"cancer and treatment complications"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":11,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["medicine"],"notable_blurb":"Stanford-trained anesthesiologist, Palo Alto Medical Foundation","primary_url":"https://www.findagrave.com/memorial/285658983/john_huntly-redpath","primary_url_label":"FindAGrave memorial #285658983"},"parents":{"father_id":"HD4197","mother_id":"I00636"},"number_of_marriages":2,"marriages":[],"education":[{"school_name":"Bishop's College School","type":"preparatory","notes":"Attended Bishop's College School; was Head Prefect."},{"institution_id":"INST023","school_name":"Princeton University","dates":"-1964","type":"undergraduate","notes":"Graduated Princeton 1964."},{"school_name":"McGill University Medical School","dates":"-1968","type":"medical","notes":"McGill MD 1968."},{"school_name":"Calgary + Stanford University","dates":"1975-1977","type":"residency","notes":"Began anesthesia residency Calgary AB 1975; completed at Stanford."}],"career":[{"role":"Partner Anesthesiologist","organization":"Palo Alto Medical Foundation","location":"Palo Alto, California, United States","start_year":1977,"end_year":1998,"notes":"Partner at Palo Alto Medical Foundation 1977 until retirement 1998. Also served on Medical Board of Stanford Hospital. Active in Interplast (international plastic surgery charity)."},{"role":"Family practitioner (early career)","organization":"Toronto, Canada","location":"Toronto","start_year":1968,"end_year":1975,"notes":"Internship Toronto then opened family practice. Changed course in 1975 to anesthesia."}],"military_service":[],"institutions":[{"institution_id":"INST023","relationship":"alumnus"}],"landmarks":[],"naming_inspiration":[{"name_element":"Huntly","inspired_by_id":"HD4198","description":"Middle name Huntly carries his uncle Huntly Roddick Redpath's first name into the next generation — Huntly was John Huntly's father James Botterell's brother."}],"artworks":[],"tags":["physician","canada_migration","california_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Princeton, McGill MD, Stanford anesthesia partner","body":"John Huntly Redpath was born at Val-d'Or northern Quebec where his father James Botterell Redpath ran Dome Mines operations. After Bishop's College School (Head Prefect), Princeton 1964, and McGill MD 1968, he practiced family medicine in Toronto before changing course to anesthesia in 1975 — completing his residency at Stanford and joining the Palo Alto Medical Foundation in 1977 where he remained a partner for twenty-one years. He died in Palo Alto in March 2024 after a long fight with aggressive cancer."},{"number":2,"category":"career","header":"He volunteered with Interplast overseas","body":"The Palo Alto anesthesiologist worked with Interplast, the international reconstructive-surgery charity, and sat on Stanford Hospital’s medical board. He retired in 1998 to Angels Camp and a calendar of kayaks, ducks, and golf."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"john-redpath-1942"},"HD4198":{"id":"HD4198","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Huntly","middle_name":"Roddick","last_name":"Redpath","married_names":[],"gender":"male","display_name":"Huntly Roddick Redpath"},"birth":{"year":1911,"city":"Pincher Creek","county":"Claresholm Census Division","state":"Alberta","country":"Canada"},"baptism":{},"death":{"year":1972,"month":12,"day":21,"city":"Montréal","state":"Quebec","country":"Canada"},"residence":{},"burial":{"cemetery_id":"CEM328","plot_notes":"Cimetière Mont-Royal Montreal."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD4189","mother_id":"I00635"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00637","location_country":"Canada","end_type":"death","end_year":1972,"children_ids":["HD4206","HD4207","HD4208","HD4209"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Roddick","inspired_by_id":"I00634","description":"Middle name Roddick honors his aunt Amy Linda Redpath's husband Sir Thomas George Roddick — McGill surgery professor and namesake of the Roddick Gates. Born in 1911 between Amy and Sir Thomas's 1906 marriage and Sir Thomas's death in 1923."}],"artworks":[],"tags":["canada_migration","alberta_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Roddick middle name from celebrated McGill uncle","body":"Huntly Roddick Redpath was born in Pincher Creek Alberta in 1911 — youngest son of John Reginald Redpath and Florence Amelia Botterell. His middle name Roddick honored his aunt Amy's husband Sir Thomas George