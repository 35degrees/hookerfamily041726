","dates":"1803-1807","type":"undergraduate","notes":"Yale College graduate 1807. Admitted to Connecticut bar 1810."}],"career":[{"role":"Member","organization":"Connecticut House of Representatives — Norwalk","start_year":1815,"end_year":1815,"notes":"May-Oct 1815. Served alongside Benjamin Isaacs."},{"role":"Member","organization":"Connecticut Senate (at-large)","start_year":1828,"end_year":1830},{"role":"Member","organization":"Connecticut House of Representatives","start_year":1830,"end_year":1831},{"role":"Member","organization":"Connecticut Senate — 12th District","start_year":1831,"end_year":1832},{"role":"32nd Lieutenant Governor","organization":"Colony of Connecticut","start_year":1832,"end_year":1833,"notes":"Under Governor John Samuel Peters."},{"role":"34th Lieutenant Governor","organization":"Colony of Connecticut","start_year":1834,"end_year":1835,"notes":"Under Governor Samuel A. Foot."},{"role":"United States Senator (Whig)","organization":"U.S. Senate — Connecticut","start_year":1839,"end_year":1840,"notes":"Served from March 4, 1839 until death April 7, 1840. Died in office Washington DC."}],"military_service":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1807","institution_blurb":"Yale College 1807; later twice Lt. Governor and US Senator from Connecticut."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["senator","lawyer","politician","yale_graduate"],"research_tags":[],"cross_connections":[{"type":"civic_peer","related_id":"HD2789","display_label":"Served with Benjamin Isaacs in CT House, May 1815","link_text":"Benjamin Isaacs"}],"narrative_blocks":[{"number":1,"category":"death","header":"Funeral at US Capitol; President Van Buren attended","body":"Thaddeus Betts died in Washington on April 7, 1840, just over a year into his Senate term as Connecticut's Whig senator. His funeral took place at the US Capitol with Congressional chaplains officiating and President Martin Van Buren in attendance — a