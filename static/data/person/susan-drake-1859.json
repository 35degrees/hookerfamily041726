tions":[],"narrative_blocks":[{"number":1,"category":"family","header":"Married at forty-five, fathered twin sons at fifty-six","body":"Theodore M. Blakeslee did not marry until February 9, 1885, age forty-five, when he wed Susan Anne 'Susie' Drake (1859-1933) at Middleborough Massachusetts. Their first daughter Hattie May was born ten months later in November 1885 but died age five in 1891. After their daughter Lottie was born in 1889, Theodore and Susan had twin sons Merwin Theodore Blakeslee and Miles Edwin Blakeslee on the same day, July 23, 1896 — Theodore was fifty-six."},{"number":2,"category":"death","header":"Civil War veteran; body returned to North Haven","body":"Theodore Blakeslee served as a Civil War veteran — specific unit and rank are not documented in surviving records, but his veteran status is confirmed. He died January 5, 1901 in New York City at age sixty-one. His body was returned to his Connecticut hometown of North Haven for burial at New Center Cemetery, where the Blakeslee-Stiles family clustered four generations of graves around the Stiles-Hooker line center."}],"quotes":[],"sources":[{"label":"FindAGrave (Memorial 127493351)","url":"https://www.findagrave.com/memorial/127493351/theodore_m-blakeslee"},{"label":"Goodyear book #6852-1"}],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"slug":"theodore-blakeslee-1839"},"HD3954":{"id":"HD3954","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Hattie","middle_name":"May","last_name":"Blakeslee","married_names":[],"gender":"female","display_name":"Hattie May Blakeslee"},"birth":{"year":1885,"month":11,"day":28,"state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1891,"month":8,"day":28},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"include_in_path_calculation":true,"descent_paths_to