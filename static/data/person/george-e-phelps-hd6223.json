s":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Married her late sister's husband; bore explorer-named twins","body":"Fourteen months after her sister Louisa's death — just twenty-four days into Louisa's marriage to Burnham Phelps — Mary Deming Hooker married Burnham herself on January 7, 1814, the practice of marrying a deceased wife's sister recognized in New England as a form of family continuity. Among their eight children were twins born July 7, 1823 named Christopher Columbus and Americus Vespusius — honoring both Atlantic explorers in a single act of naming, though Americus died at age three in 1826."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909), entries 483–2370","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"mary-phelps-1792"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}