:1,"spouse_id":"I00306","children_ids":["HD3351"],"date_year":1922,"end_year":1923,"end_type":"death_of_spouse"},{"marriage_number":2,"spouse_id":"I00307","children_ids":[],"end_year":1965,"end_type":"death_of_spouse"},{"marriage_number":3,"spouse_id":"I00308","children_ids":[],"end_year":1978,"end_type":"death_of_spouse"},{"marriage_number":4,"spouse_id":"I00309","children_ids":[],"date_year":1980,"end_year":1981,"end_type":"death"}],"education":[{"school_name":"Middlesex School","type":"preparatory","notes":"Middlesex School, Concord MA — preparatory school."},{"institution_id":"INST002","type":"undergraduate","notes":"A.B. Harvard."},{"institution_id":"INST002","school_name":"Harvard Law School","type":"law","notes":"Harvard Law School."}],"career":[{"role":"Partner (retired)","organization":"Hill & Barlow","location":"Boston, Massachusetts","notes":"Boston law firm Hill & Barlow."},{"role":"President","organization":"Cambridge Center for Adult Education","location":"Cambridge, Massachusetts"}],"military_service":[{"war":"World War I","war_id":"WAR007","rank":"Unknown","notes":"Veteran (war service flagged on FindAGrave; war unspecified in source — WWI inferred from age 19-20 at US entry 1917-18)."}],"institutions":[{"institution_id":"INST002","relationship":"alumnus"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["harvard_graduate","lawyer","wwi"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"First wife died in childbirth same day","body":"Benjamin's first wife Rose Bradley died July 20, 1923 in childbirth at age twenty-three — the same day she bore their son Faneuil 'Fan' Adams Jr. Rose was twenty-four at the marriage in 1922 and was dead within a year. Benjamin was twenty-five at her death, and the simultaneous birth and death framed the start of his decades of subsequent widowhood and remarriage."},{"number":2,"category":"family","header":"Four marriages including final at age eighty-two","body":"Benjamin had four marriages across his eighty-three-year life — Rose Bradley in 1922 who died 1923, then Susanne Root, then Helen Weston Thompson, and finally Mary Manning in 1980 at age eighty-two — that final late-life marriage ending within a year by his own April 1981 death. Only the first marriage produced a documented child."},{"number":3,"category":"career","header":"Hill and Barlow partner; Cambridge adult education president","body":"Benjamin earned an A.B. from Harvard followed by Harvard Law School, and retired as a partner at the Boston law firm Hill and Barlow. In civic life he served as President of the Cambridge Center for Adult Education — the long-running Cambridge institution founded in 1938. The combined corporate-law and adult-education leadership tracked the typical second-career trajectory of established Boston-area lawyers."},{"number":4,"category":"family","header":"Born Concord MA 1898, died Duxbury MA 1981","body":"Benjamin Faneuil Dunkin Adams II was born May 11, 1898 in Concord, Middlesex County Massachusetts and died April 22, 1981 in Duxbury, Plymouth County Massachusetts at age eighty-two. He is buried at Mayflower Cemetery, Duxbury — the family ground where Rose Bradley, son Fan Adams Jr., and his mother Rebecca Ames are also interred."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"benjamin-adams-ii-1898"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}