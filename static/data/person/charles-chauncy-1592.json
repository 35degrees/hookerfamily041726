{"person":{"id":"X01903","has_descendants_documented":false,"is_placeholder":false,"gender":"male","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"birth":{"year":1592,"month":11,"day":5,"city":"Yardley Bury","county":"Hertfordshire","country":"England"},"death":{"year":1672,"month":2,"day":19,"city":"Cambridge","state":"Massachusetts","country":"United States"},"parents":{},"marriages":[{"children_ids":["X01902"],"marriage_number":1}],"number_of_marriages":1,"tags":["minister","harvard_president","puritan","harvard_graduate"],"sources":[{"short":"Wikipedia — Charles Chauncy","url":"https://en.wikipedia.org/wiki/Charles_Chauncy_(1592%E2%80%931672)"}],"notable":{"is_notable":true,"notable_category":["academia","religion"],"notable_blurb":"Second president of Harvard College, 1654–1672","primary_url":"https://en.wikipedia.org/wiki/Charles_Chauncy_(1592%E2%80%931672)","primary_url_label":"Wikipedia"},"narrative_blocks":[{"header":"Harvard's second president","detail":"Chauncy was educated at Trinity College, Cambridge, and served as a Church of England minister before emigrating under Puritan pressure. At Plymouth he became minister of Scituate, then succeeded Henry Dunster as Harvard's president in 1654. He held the post for 18 years. His son Nathaniel (X01902) graduated Harvard in 1661 and became minister of Hatfield, Massachusetts. His grandson Nathaniel Chauncey (X01904) received Yale's first M.A. degree in 1702 and served as Durham's minister for 50 years. His great-granddaughter Sarah Chauncey married Rev. Samuel Whittlesey (X01900) of Wallingford, whose son Chauncey Whittlesey (I00074) married Martha Newton — a 4th-generation descendant of Thomas Hooker. (Wikipedia)","body":"Charles Chauncy served as the second President of Harvard College from 1654 until his death in 1672. A Cambridge-educated Puritan who emigrated to Plymouth Colony in 1638, he was one of the most rigorous classical scholars in early New England — and the patriarch of a remarkable dynasty of Yale and Harvard clergy.","number":1,"category":"character"},{"number":2,"category":"education","header":"Harvard kept him until seventy-nine","body":"The Trinity College, Cambridge scholar emigrated to Plymouth Colony in 1638 and took Harvard’s presidency in 1654 — holding it eighteen years until his death in office in 1672, at seventy-nine."}],"cross_connections":[],"bio":{"display_name":"Rev. Charles Chauncy","first_name":"Charles","last_name":"Chauncy","title":"Reverend","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/ea/Chauncy_Charles.jpg/440px-Chauncy_Charles.jpg","bio_blurb":"Second president of Harvard College"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"President","organization":"Harvard College","start_year":1654,"end_year":1672}],"slug":"charles-chauncy-1592"},"neighborhood":{"focus":{"id":"X01903","slug":"charles-chauncy-1592","n":"Rev. Charles Chauncy","by":1592,"dy":1672,"sx":"m","hd":false,"td":false,"ee":true,"g":null},"spouses":[{"order":1,"spouse":null,"year":null,"children":[{"id":"X01902","slug":"nathaniel-chauncy-1639","n":"Nathaniel Chauncy","by":1639,"dy":1685,"sx":"m","hd":false,"td":false,"ee":false,"g":null}]}],"parents":{},"grandparents":{"paternal":{},"maternal":{}},"grandchildren":[{"id":"X01901","slug":"sarah-chauncey-1683","n":"Sarah Chauncey Whittlesey","by":1683,"dy":1767,"sx":"f","hd":false,"td":false,"ee":false,"g":null,"via_parent_id":"X01902"},{"id":"X01904","slug":"nathaniel-chauncey-1681","n":"Rev. Nathaniel Chauncey","by":1681,"dy":1756,"sx":"m","hd":false,"td":false,"ee":true,"g":null,"via_parent_id":"X01902"}],"siblings_count":0},"context":{"X0