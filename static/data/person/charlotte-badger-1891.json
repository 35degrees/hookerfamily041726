y":"United States"},"baptism":{},"death":{"year":1942,"month":7,"day":2,"country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM268","plot_notes":"Fairlawn Section, Block 1, Graceland Cemetery"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD3710","mother_id":"I00412","mother_name":"Anna L. Wooster Cowles"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00404","location_city":"Chicago","location_county":"Cook County","location_state":"Illinois","location_country":"United States","children_ids":["HD3748","HD3749","HD3750","HD3751"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"sarah-frances-badger-1867"},"HD3710":{"id":"HD3710","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"title":"Honorable","first_name":"Samuel","last_name":"Cowles","married_names":[],"gender":"male","display_name":"Hon. Samuel Cowles","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778178113/samuelcowles-resized_q8gvvx.png"},"birth":{"year":1823,"month":3,"day":21,"city":"Austinburg","county":"Ashtabula","state":"Ohio","country":"United States"},"baptism":{},"death":{"year":1880,"month":11,"day":17,"country":"United States"},"residence":{"city":"San Francisco","county":"San Francisco","state":"California","country":"United States"},"burial":{"cemetery_id":"CEM267","plot_notes":"Cowles family plot, Cypress Lawn Memorial Park, Colma CA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["law","politics"],"notable_blurb":"San Francisco police judge then county judge","primary_url":"https://www.carpelibrumbooks.com/the-diary-of-samuel-cowles-cleveland-1849-1850","primary_url_label":"Diary of Samuel Cowles, Cleveland 1849-1850"},"parents":{"father_id":"H01141","mother_id":"I00396"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00412","date_year":1849,"date_month":3,"date_day":28,"location_city":"Cleveland","location_county":"Cuyahoga","location_state":"Ohio","location_country":"United States","end_type":"death","end_year":1880,"children_ids":["HD3725","HD3726","HD3727","HD3728","HD3729","HD3730","HD3731"]}],"education":[{"institution":"Grand River Institute","notes":"Several terms at Grand River Institute Austinburg OH."},{"institution":"Western Reserve College","notes":"Finished his education at Western Reserve College."}],"career":[{"title":"Cleveland lawyer","dates":"1847-1852","type":"law","notes":"Admitted to the Ohio bar 1847. Partnered first with Loren Prentiss; in 1850 parted with Prentiss to join a new enterprise with childhood friend Edwin P. Mastick. Cleveland practice focused on criminal defense (clients accused of rape, arson, insanity), real estate transactions, and a range of civil matters."},{"title":"Secretary-Treasurer, Cataract Fire Company No. V","organization":"Cataract Fire Company No. V, Cleveland","dates":"~1849-1851","type":"civic","notes":"Volunteer fire-company role during his Cleveland years."},{"title":"California migration","dates":"1852","type":"migration","notes":"Migrated to San Francisco with childhood friend and law partner Edwin P. Mastick — both 'struck with California fever' two years after the diary ends."},{"title":"Deputy Clerk, Supreme Court of California","organization":"Supreme Court of California","dates":"early 1850s","type":"law","notes":"First California position upon arriving in San Francisco."},{"title":"Member, San Francisco Vigilance Committee","organization":"San Francisco Committee of Vigilance of 1856","dates":"1856","type":"civic","notes":"Active member of the 1856 Vigilance Committee — one of the largest extralegal civic-purification movements in 19th-century US history."},{"title":"San Francisco Police Judge","organization":"City of San Francisco","dates":"1860-1863","type":"law","notes":"Elected Police Judge — also one of three commissioners selecting the SF police force during a period of civic reform. (Earlier project notes had this as 1856; correct dates per the new Carpe Librum biographical source are 1860-1863.)"},{"title":"County Judge of San Francisco","organization":"San Francisco County Court","dates":"1863-1868","type":"law","notes":"Presided over the SF County Court for four years; recorded decisions form a significant chapter in California jurisprudence."},{"title":"Member, Committee of Safety","organization":"San Francisco Committee of Safety","dates":"1877","type":"civic","notes":"Active during the 1877 SF railroad strikes."},{"title":"President, Savings and Loan Society (Clay Street Bank)","organization":"Savings and Loan Society, San Francisco","dates":"1879-1880","type":"business","notes":"Long-time legal adviser to the Clay Street Bank; elected its president 1879. Held the post until his Nov 17, 1880 death."},{"title":"Senior partner, Cowles & Brown","dates":"1868-1880","type":"law","notes":"Returned to private SF practice 1868; partnership with Albert N. Brown until his 1880 death."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["lawyer","judge","diarist","california_migration","politician"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"law","header":"San Francisco police then county judge 1860-1868","body":"Samuel was elected San Francisco Police Judge in 1860 — also one of three commissioners selecting the SF police force — and served the County Court bench from 1863 to 1868. His recorded decisions form a significant chapter in California jurisprudence during the state's formative years."},{"number":2,"category":"social_reform","header":"Member of San Francisco's 1856 Vigilance Committee","body":"An earnest and efficient worker in 'the great social purification' of San Francisco, Samuel served the 1856 Vigilance Committee — one of the largest extralegal civic movements in 19th-century US history. He gloried in those days and rehearsed the story in later life."},{"number":3,"category":"literature","header":"His Cleveland diary documents the 1849 cholera epidemic","body":"Samuel kept a clear daily diary from July 1849 through July 1850 in Cleveland, recording the cholera epidemic that he himself contracted and survived; an hour-by-hour account of President Zachary Taylor's death; steamboat-fire disasters; and his own self-recorded depression. The diary survives as an important primary source for early Cleveland history."},{"number":4,"category":"family","header":"Migrated to California with childhood friend Mastick","body":"Struck with 'California fever,' Samuel left Cleveland in 1852 with his childhood friend and law partner Edwin P. Mastick. He had been preceded by his brother Edwin Cowles' departure for Chicago — both sons of Dr. Edwin Weed Cowles fanning out from Austinburg Ohio in the same gold-rush decade."}],"quotes":[],"sources":[{"short":"Cowles Families in America #1718"},{"short":"History of Ashtabula Co., Ohio (biographical sketch)"}],"research_sources":[],"documents":[{"document_id":"DOC021","role":"author"}],"slug":"samuel-cowles-1823"},"I00412":{"id":"I00412","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Anna L.","last_name":"Wooster Cowles","maiden_name":"Wooster","married_names":["Cowles"],"gender":"female","display_name":"Anna L. Wooster Cowles"},"birth":{"year":1826,"month":10,"day":1,"city":"Newburg","county":"Wyoming County","state":"New York","country":"United States"},"baptism":{},"death":{"year":1919,"month":1,"day":14,"city":"Evanston","county":"Cook County","state":"Illinois","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM267","plot_notes":"Cowles family plot, Cypress Lawn — buried with husband Hon. Samuel Cowles"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3710","date_year":1849,"date_month":3,"date_day":28,"location_city":"Cleveland","location_county":"Cuyahoga County","location_state":"Ohio","location_country":"United States","end_type":"death","end_year":1880,"children_ids":["HD3725","HD3726","HD3727","HD3728","HD3729","HD3730","HD3731"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["extraordinary_longevity"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"anna-l-wooster-1826"}},"burialCemetery":{"id":"CEM268","name":"Graceland Cemetery","city":"Chicago","county":"Cook County","state":"Illinois","country":"United States","gps":"41.9587, -87.6602","founded":1860,"wikipedia_url":"https://en.wikipedia.org/wiki/Graceland_Cemetery","primary_url":"https://www.gracelandcemetery.org/","hooker_connections":["HD3731",