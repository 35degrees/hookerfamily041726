ooker","notes":"Named \"Griswold\" for maternal Griswold ancestry — mother Rebecca Griswold, daughter of Major Josiah Griswold of Wethersfield.","first_name":"William","last_name":"Hooker","middle_name":"Griswold","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"william-hooker-1782"},"I00283":{"id":"I00283","former_ids":[],"is_placeholder":false,"gender":"female","has_descendants_documented":false,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"is_easter_egg":false},"birth":{"year":1785,"month":10,"day":30,"city":"Lebanon","state":"Connecticut","country":"United States"},"death":{"year":1868,"month":8,"day":28,"city":"New Haven","state":"Connecticut","country":"United States"},"parents":{"father_research_notes":"David Metcalf of Lebanon CT.","mother_research_notes":"Anne Champion of Lebanon CT — surname source for grandchildren named Champion."},"burial":{"cemetery_id":"CEM009","plot_notes":"Grove Street Cemetery, New Haven CT"},"tags":[],"sources":[{"short":"Edward Hooker 1909, entry 629"},{"short":"Findagrave, Grove Street Cemetery"}],"narrative_blocks":[],"cross_connections":[],"documents":[],"bio":{"first_name":"Melinda","last_name":"Hooker","maiden_name":"Metcalf","married_names":["Hooker"],"display_name":"Melinda Metcalf Hooker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"marriages":[{"marriage_number":1,"spouse_id":"H00629","date_year":1807,"date_month":10,"date_day":20,"location_city":"Lebanon","location_state":"Connecticut","location_country":"United States","children_ids":["H01623"]}],"number_of_marriages":1,"slug":"melinda-metcalf-1785"},"H00288":{"id":"H00288","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1737,"month":8,"day":29,"city":"Farmington","state":"Connecticut"},"death":{"year":1823,"month":6,"day":3,"city":"Farmington","state":"Connecticut"},"parents":{"father_id":"H00102","mother_id":"I00132"},"political_offices":[{"title":"Town Representative, Farmington","notes":"Many sessions"},{"title":"Justice of the Peace","notes":"40 years"},{"title":"Treasurer, Church Society Farmington","notes":"Many years"},{"title":"Colonel, 15th Regiment, Connecticut State Militia","notes":"Post-war appointment"}],"prominent_name_reason":"Col. Noadiah Hooker — Revolutionary War officer who raised the first Farmington troops and commanded a regiment at Burgoyne's surrender (Saratoga, 1777); 40 years Justice of the Peace; Farmington representative many sessions. \"In all relations of life, both public and private, he discharged every duty with credit to himself and benefit to his fellow citizens.\"","marriages":[{"spouse_id":"I00133","children_ids":["HD0387","HD0388","HD0389","HD0390","HD0391","HD0392","HD0393","HD0394","HD0395","H00629","H00630"],"marriage_number":1,"date_year":1765,"date_month":1,"date_day":2,"location_city":"Wethersfield","location_state":"Connecticut"}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 288"}],"cross_connections":[{"type":"civic_connection","related_id":"X00152","display_label":"Bull engraved the Farmington Library bookplate; both on founding committee.","link_text":"Martin Bull"},{"type":"parallel_careers","related_id":"H00306","display_label":"First cousins who served together — Roger enlisted in his company.","link_text":"Maj. Roger Hooker"},{"type":"military","related_id":"H00351","display_label":"Friend-compatriots in the Revolutionary War.","link_text":"Lt. Evelyn Pierpont"},{"type":"military","related_id":"X01068","display_label":"Norton served under his command at Peekskill in spring 1777.","link_text":"Col. Ichabod Norton"}],"gender":"male","tags":["revolutionary_war","indigenous_rights","connecticut_notable","judge"],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["military","government","indigenous_rights"],"notable_blurb":"Revolutionary War Colonel; 40 years Justice of Peace","primary_url":"https://www.nativenortheastportal.com/bio/bibliography/hooker-noadiah","primary_url_label":"Native Northeast Portal"},"narrative_blocks":[{"number":1,"category":"military","header":"Commanded a regiment at Burgoyne's surrender","body":"His Connecticut regiment fought in the Saratoga Campaign of 1777, where John Burgoyne's British army laid down its arms. The victory turned the war and brought France in on the American side."},{"number":2,"category":"military","header":"First Farmington troops to reach Boston","body":"He raised a hundred-man company of Farmington's elite and arrived at Roxbury three weeks before any other Connecticut soldiers. The Colonial Assembly commissioned him captain on arrival."},{"number":3,"category":"social_reform","header":"Sent an Oneida boy to mission school","body":"In 1819 he paid for the education of eighteen-year-old Peter Augustus Takonotas at the Cornwall Foreign Mission School. The boy later took Hooker's surname."},{"number":4,"category":"law","header":"Justice of the Peace for forty years","body":"After the war he served as Farmington's Justice of the Peace from the 1780s through the 1820s. The role made him the local arbiter of debt, marriage, and civil disputes for two generations."},{"number":5,"category":"character","header":"Late returning a library book in 1795","body":"The Farmington Monthly Library, founded that year, recorded 'Col. Noadiah Hooker his shilling' for a late-return fine. Julius Gay's nineteenth-century history pamphlets preserved the entry."}],"education":[{"school_name":"No college noted — rose through militia ranks"}],"military_service":[{"war":"American Revolutionary War","active_in_war":true,"rank":"Colonel","notes":"Raised the first troops enlisted at Farmington and marched in command of a company of 100+ men — the very elite of the vicinity. Arrived in Boston (Roxbury) three weeks before any other enlisted men from Connecticut. Commissioned Captain by Colonial Assembly. Commissioned Colonel by State Legislature 1776. Served in several regiments until close of War. Had command of a regiment at the capture of Burgoyne's army (Saratoga, 1777). Facebook genealogy research (2024) confirms: Samuel Woodruff (1734-1816) of Farmington CT served as private in Capt. Jesse Curtiss' company, Col. Noadiah Hooker's regiment, 1777. Also confirmed by Orderly Book of Capt. Ichabod Norton (1777, Peekskill): Norton served \"under Colonel Hooker\" at Peekskill 1777. Norton was husband of Ruth Strong (H00297), daughter of Ruth Hooker Strong — a Hooker descendant herself. Two branches of the Hooker tree serving together.","unit":"Col. Noadiah Hooker's Regiment, Connecticut Militia","war_id":"WAR004"}],"bio":{"title":"Colonel","display_name":"Col. Noadiah Hooker","first_name":"Noadiah","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"slug":"noadiah-hooker-1737"},"I00133":{"id":"I00133","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1744,"month":9,"day":7,"city":"Wethersfield","state":"Connecticut"},"death":{"year":1816,"month":11,"day":9,"city":"Farmington","state":"Connecticut"},"parents":{"mother_research_notes":"Mabel Belden","father_research_notes":"Major Josiah Griswold of Wethersfield"},"marriages":[{"spouse_id":"H00288","children_ids":["HD0387","HD0388","HD0389","HD0390","HD0391","HD0392","HD0393","HD0394","HD0395","H00629","H00630"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 288"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Rebecca Griswold Hooker","first_name":"Rebecca","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Griswold"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"rebecca-griswold-1744"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}