":"arts","header":"He gave RISD prints and a Monet","body":"Through his wife, Raphael Pumpelly's granddaughter, Metcalf held a rare album of Japanese surimono prints the geologist had carried home in 1863, which he gave to the Rhode Island School of Design in 1956. He also gave the museum a Monet landscape, Honfleur."}],"sources":[],"institutions":[{"institution_id":"INST161","relationship":"donor","years":"1956"}],"landmarks":[{"landmark_id":"LM121","landmark_blurb":"His father built this house, now the RISD president’s house."}],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"George Pierce","last_name":"Metcalf","married_names":[],"display_name":"George Pierce Metcalf","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780767252/gerogemetcalf_q8gmlf.png"},"military_service":[],"slug":"george-pierce-metcalf-1890"},"I01564":{"id":"I01564","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","birth":{"year":1897,"country":"United Kingdom"},"death":{"year":1972},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"include_in_path_calculation":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"spouse_id":"TD0344","spouse_name":"Pauline Pumpelly Cabot","marriage_year":1959,"children_ids":[]}],"tags":[],"narrative_blocks":[],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Cecil Wingfield Twisleton","last_name":"Wykeham-Fiennes","married_names":[],"display_name":"Cecil Wykeham-Fiennes","gender":"male"},"military_service":[],"slug":"cecil-wingfield-twisleton-wykeham-fiennes-1897"},"TD0365":{"id":"TD0365","former_ids":[],"is_plac