e"},"burial":{"cemetery_id":"CEM050","plot_notes":"Memorial burial at Weybridge Hill Cemetery VT; KIA at Savage's Station VA."},"parents":{"father_id":"X01948","mother_id":"HD3214"},"marriages":[],"number_of_marriages":0,"tags":["civil_war","died_in_service","killed_in_action"],"sources":[{"short":"University of Vermont — Henry Harrison Wilder Papers","url":"https://scfindingaids.uvm.edu/repositories/2/resources/559","notes":"4 folders of Civil War correspondence 1861-1862. Letters from Henry to family + condolence letters + Sergeant Merrill Samson account of his death."},{"short":"Findagrave (Weybridge Hill Cemetery, Weybridge VT)"}],"notable":{"is_notable":false,"notable_category":[],"primary_url":"https://scfindingaids.uvm.edu/repositories/2/resources/559","primary_url_label":"UVM Civil War Letters Collection"},"cross_connections":[],"military_service":[{"war":"American Civil War","war_id":"WAR006","side":"Union","rank_start":"Corporal","rank_end":"Corporal","rank_year_start":1861,"rank_year_end":1862,"unit":"Company F, 5th Regiment, Vermont Volunteer Infantry","role":"Soldier","service_years":"Sept 19, 1861 - Aug 16, 1862 (post-mortem records)","enlistment_year":1861,"enlistment_month":9,"battles_id":["BTL037"],"killed_in_action":true,"killed_at":"Battle of Savage's Station","killed_at_war_id":"WAR006","killed_at_battle_id":"BTL037","notes":"Enlisted Sept 19, 1861 in Weybridge VT as a corporal in Company F, 5th Vermont Volunteer Infantry. Wrote home about Camp Holbrook (St. Albans VT) and Camp Griffin (Virginia) where the regiment was hit hard by disease. Described the Peninsula Campaign in spring 1862, including the battles of Lee's Mill and Williamsburg. Killed in action at Battle of Savage's Station (Henrico County VA) on Jun 29, 1862, age ~22. Best friend Sergeant Merrill Samson of Weybridge wrote a letter to Henry's family describing his death."}],"bio":{"display_name":"PVT Henry Harrison Wilder","first_name":"Henry","middle_name":"Harrison","last_name":"Wilder","married_names":[],"photo_url":"https://images.findagrave.com/photos/2024/77/46269070_8e985aee-c9b1-49b9-a092-61cab4133506.jpeg"},"former_ids":["X01953"],"narrative_blocks":[{"number":1,"category":"military","header":"Killed at Savage's Station age 22","body":"Cpl. Henry Harrison Wilder of Weybridge VT enlisted in the 5th Vermont Volunteer Infantry, Company F, on Sept 19, 1861 at age 21. He survived the disease-ridden winter at Camp Griffin VA, then marched through the Peninsula Campaign — Lee's Mill and Williamsburg. On June 29, 1862, during the Seven Days Battles, his regiment was thrown into the Battle of Savage's Station in Henrico County VA."},{"number":2,"category":"legacy","header":"His mother saved his Civil War letters","body":"Henry Harrison Wilder's mother Amanda Murray Hayward saved his correspondence from the war along with Sgt. Merrill Samson's account of her son's death and the letters of condolence the family received. The collection — four folders spanning 1861-1862 — is now at the University of Vermont Special Collections (Henry Harrison Wilder Papers). Amanda is the principal correspondent in the archive."}],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"slug":"henry-wilder-1840"}},"burialCemetery":{"id":"CEM051","name":"Woodbury Cemetery","city":"Lyle","county":"Mower County","state":"Minnesota","country":"United States","visitable":true,"notes":"Burial place of Orlando Wilder (X01948).","sources":[{"short":"FindAGrave"}],"hooker_connections":["X01948"]},"institutionsById":{},"crossConnections":[]}