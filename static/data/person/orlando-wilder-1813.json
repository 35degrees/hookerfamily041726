":1840,"location_country":"United States","end_type":"death_of_spouse","end_year":1865,"children_ids":["X01949","X01950","X01951"]}],"number_of_marriages":2,"tags":[],"sources":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Amanda Murray Hayward","first_name":"Amanda","last_name":"Hayward","maiden_name":"Murray","married_names":["Hayward"]},"former_ids":["X01943"],"burial":{"cemetery_id":"CEM050","plot_notes":"Weybridge Hill Cemetery, Weybridge, Addison County VT (per Findagrave). Same cemetery as son Henry Harrison Wilder (HD3219, KIA buried memorial)."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"First husband abandoned the family, then vanished","body":"Amanda's first husband Orlando Wilder — biological father of her two children Marion Eliza (born 1836) and Henry Harrison (born 1840) — last appeared in the 1840 Addison County Vermont census and then disappeared from all records. He had either abandoned the family or moved to Minnesota alone, leaving Amanda widow-like at age thirty with two young children. The disappearance was permanent."},{"number":2,"category":"family","header":"Remarried Judge Joseph Hayward with three stepchildren","body":"Between 1840 and 1850 Amanda remarried — to Judge Joseph Hayward of Vermont (1796-1865). Hayward already had three children from his prior marriage (Asaph, Josephine, and Benjamin); they were Amanda's stepchildren, not her own biological children. The blended Wilder-Hayward household took shape across the 1840s, with Amanda raising her two Wilder children alongside her three Hayward stepchildren."},{"number":3,"category":"family","header":"Daughter Marion married into Drake family","body":"Amanda's daughter Marion Eliza Wilder (born 1836) eventually married Drake — establishing the Wilder-Drake line that descended from the Hooker connection through Amanda's mother Lucinda Murray. Amanda's son Henry Harrison Wilder served as a private in the Civil War."},{"number":4,"category":"family","header":"Born Addison County VT 1810, died Vermont 1887","body":"Amanda Murray was born April 30, 1810 in Addison County Vermont and died December 9, 1887 in Vermont at age seventy-seven. Her two marriages with their distinct biological-vs-step parentage have been cross-checked against source records to establish the marriage order and parentage definitively."}],"slug":"amanda-hayward-1810"},"HD3218":{"id":"HD3218","has_descendants_documented":false,"is_placeholder":false,"gender":"female","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_easter_egg":false,"include_in_path_calculation":true},"birth":{"year":1836,"month":8,"day":15,"city":"Addison","county":"Addison County","state":"Vermont","country":"United States"},"death":{"year":1923,"month":1,"day":17,"city":"Rutland","county":"Rutland County","state":"Vermont","country":"United States"},"burial":{"cemetery_id":"CEM050","plot_notes":"Weybridge Hill Cemetery, Weybridge, Addison County VT (per Findagrave). Same as mother + brother Henry."},"parents":{"father_id":"X01948","mother_id":"HD3214"},"marriages":[{"marriage_number":1,"spouse_id":"X01954","children_ids":[],"end_type":"death_of_spouse","end_year":1885},{"marriage_number":2,"spouse_id":"HD3221","children_ids":["X01960"]}],"number_of_marriages":2,"tags":[],"sources":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"cousin_marriage","related_id":"HD3221","display_label":"Both descended from Rev. Thomas Hooker; married cousins","link_text":"Franklin Hooker"}],"bio":{"display_name":"Marion Eliza Wilder Drake","first_name":"Marion","