,"marriages":[{"marriage_number":1,"spouse_id":"I00947","location_country":"United States","children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[{"institution_id":"INST020","relationship":"alumnus","years":"B.A. History","institution_blurb":"Attended the University of Rochester, where her great-great-grandfather Asahel Clark Kendrick had been inaugural professor of Greek in 1850, completing the fourth generation of the Hooker-Kendrick family at the institution."}],"landmarks":[],"naming_inspiration":[{"name_element":"Kendrick","inspired_by_id":"HD4668","description":"Middle name 'Kendrick' preserves the family's scholarly identity — her grandfather Ryland Morris Kendrick had been a Rochester classics professor and her great-grandfather Asahel Clark Kendrick had founded the Greek program at the university she would herself attend."}],"artworks":[],"tags":["civil_rights"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"legacy","header":"Four generations taught at her alma mater","body":"Ann Kendrick McNabb attended the University of Rochester — where her great-great-grandfather Asahel Clark Kendrick had been its founding professor of Greek in 1850, her great-grandfather Ryland Morris Kendrick had taught Greek and Latin, and where the family had maintained a continuous scholarly presence across four generations — and named her own grandson Ryland to carry the family lineage forward. She spent her life in Rochester as a civil rights activist, tutor, early childhood advocate, and supporter of refugee families, sustaining the family's commitment to public service that had begun with a Baptist minister's son teaching Greek in 1831."}],"quotes":[],"sources":[{"label":"FindAGrave","url":"https://www.findagrave.com"},{"label":"Ann Kendrick McNabb obituary, Rochester, March 2021"}],"research_sources":[],"documents":[],"slug":"ann-mcnabb-1929"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]