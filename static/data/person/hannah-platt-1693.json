ion":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"martha-merwin-1727"},"X00177":{"id":"X00177","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00157","children_ids":[]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Joseph Merwin","first_name":"Joseph","last_name":"Merwin","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"joseph-merwin"},"X00076":{"id":"X00076","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"birth":{"year":1649,"month":4,"day":1,"city":"Milford","county":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1703,"month":11,"day":10,"city":"Milford","county":"New Haven","state":"Connecticut","country":"United States"},"marriages":[{"marriage_number":1,"spouse_id":"X00077","date_year":1680,"location_city":"Milford","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1703,"children_ids":["I00064","I00021"]}],"sources":[{"short":"Families of Early Milford","notes":"Joseph Platt entry confirms children Hannah (m. Fletcher Newton) and Phebe (m. Samuel Newton)"},{"short":"Edward Hooker 1909","page":"Entries 41, 47"}],"parents":{"father_id":"X00098","mother_id":"X00099"},"gender":"male","tags":["milford_founder","politician"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"baptism":{"year":1649,"month":4,"day":1,"city":"Milford","state":"Connecticut","country":"United States"},"narrative_blocks":[{"number":1,"category":"family","header":"Two daughters each married a Newton first cousin","body":"His daughters Phebe and Hannah both married into the Newton family of Milford — Phebe to Samuel Newton, Hannah to Samuel's first cousin Fletcher Newton. Two Platt sisters from the same household, two Newton cousins. Joseph was himself the son of Deacon Richard Platt, one of Milford's founding settlers."},{"number":2,"category":"character","header":"At dead of night he and his friends","body":"In 1671, young Joseph Platt and companions George Clark, Joseph Northrup, and Samuel Clark destroyed the Wepawaug Indians' fort \"with the utmost secrecy, at dead of night.\" The fort was probably vacant. They were tried before the General Court at New Haven, each fined £10, and ordered to rebuild what they had torn down."},{"number":3,"category":"military","header":"Lieutenant of the Milford Train Band, 1698","body":"Trainbands were the basic colonial militia unit — periodic training companies from which fighting forces were selected. He was Lieutenant of the Eldest Train Band at Milford in October 1698, and was elected Deputy from Milford to the Connecticut General Assembly in May 1700."},{"number":4,"category":"legacy","header":"No will — his son Joseph administered","body":"No will of Joseph is on record. His inventory was taken March 21, 1703/4. His widow Mary and son Joseph were appointed administrators, though the son was still a minor at the time."}],"cross_connections":[{"type":"civic_peer","related_id":"X00096","display_label":"Both destroyed the Wepawaug fort — fined £10.","link_text":"John Fowler"}],"bio":{"display_name":"Joseph Platt","first_name":"Joseph","last_name":"Platt","married_names":[]},"residence":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"joseph-platt-1649"},"X00077":{"id":"X00077","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"city":"Milford","county":"New Haven","state":"Connecticut","country":"United States"},"death":{},"marriages":[{"marriage_number":1,"spouse_id":"X00076","date_year":1680,"location_city":"Milford","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","children_ids":["I00064","I00021"]}],"sources":[{"short":"Families of Early Milford, Connecticut","platform":"Ancestry.com"}],"marriage_date":{"year":1680,"month":5,"day":5},"gender":"female","tags":[],"number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Two daughters each married a Newton first cousin","body":"Her daughters Phebe and Hannah both married into the Newton family — Phebe to Samuel Newton, Hannah to Samuel's first cousin Fletcher Newton. Two sisters, two cousins, all from Milford."}],"cross_connections":[],"bio":{"display_name":"Mary Kellogg Platt","first_name":"Mary","last_name":"Platt","married_names":["Platt"],"maiden_name":"Kellogg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-kellogg"},"X00098":{"id":"X00098","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"birth":{"year":1603,"month":9,"day":28,"city":"Ware","county":"Hertfordshire","country":"England"},"death":{"year":1684,"country":"United States","cause":"Died Milford shortly before Feb 13, 1684/5, when inventory of estate taken. Burial place unknown — probably in his orchard."},"burial":{"cemetery_id":"CEM005","plot_notes":"Cenotaph at Milford Cemetery commemorates him. Actual burial place unknown; probably in his orchard per family tradition."},"parents":{"mother_research_notes":"Mary (maiden name unknown), wife of George Platt","father_research_notes":"George Platt of Ware (bpt May 13, 1582; d. Apr 20, 1609) — tailor"},"marriages":[{"spouse_id":"X00099","children_ids":["X00076","X00100","X02114"],"marriage_number":1,"date_year":1629,"date_month":1,"date_day":26,"location_city":"Roydon","location_county":"Essex","location_country":"England"}],"migration":{"departure":"England 1637-1638 — sailed with Rev. Peter Prudden's Hertfordshire company","arrived":"New Haven 1638, Milford 1639","notes":"Sold his lands and houses at Ware by final concord at Westminster Apr 25, 1638. Was among the 66 men who formed themselves into a church society at New Haven under Rev. Peter Prudden Aug 22, 1639, which group then settled Milford. Enrolled among first settlers of Milford Nov 20, 1639, with four in his family. Home lot #38: 4 acres 1 rod near present West Main and Cherry Streets, Milford."},"church_roles":[{"role":"Deacon","church":"First Church","location":"Milford, Connecticut","dates":"1669","notes":"Chosen deacon 1669. Witnessed the will of Rev. Peter Prudden."}],"tags":["deacon","great_migration","milford_founder"],"cross_connections":[{"type":"civic_peer","related_id":"X00095","display_label":"Both came from Hertfordshire; both among Milford's Seven Pillars.","link_text":"William Fowler"},{"type":"civic_peer","related_id":"X00090","display_label":"Adjoining home lots in the Hertfordshire Quarter, New Haven.","link_text":"William Pantry"},{"type":"civic_peer","related_id":"H00001","display_label":"led the Cambridge circle Platt neighbored in Hertfordshire","link_text":"Rev. Thomas Hooker"}],"sources":[{"short":"Families of Early Milford","notes":"Full biography and children listed"}],"notable_persons":[{"name":"Ben Affleck","description":"Actor and director (Good Will Hunting, Batman v Superman, Gone Girl). Descended from Richard Platt through a daughter who married and lost the Platt surname — six generations documented on PBS Finding Your Roots (Season 3, October 2016), hosted by Henry Louis Gates Jr.","connection":"Descendant — 9th or 10th great-grandson approximately","source":"PBS Finding Your Roots Season 3; confirmed by Milford genealogist Richard Platt and Alvin Platt's 2003 Special Compilation of the History and Genealogy of Richard Platt","notes":"Gates presented Affleck with six generations of Platt charts on air. The Milford Richard Platt Society confirmed the identification matches their documented records."}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["religion"],"notable_blurb":"Milford founding settler, 1639; Deacon 1669","primary_url":"https://websites.umich.edu/~bobwolfe/gen/mn/m2165x2166.htm","primary_url_label":"Platt Family Genealogy (U-Michigan)"},"narrative_blocks":[{"number":1,"category":"career","header":"He left a Bible to each","body":"When Deacon Richard Platt made his will in 1683, he bequeathed a Bible to each of his nineteen grandchildren — a gesture that, as one historian noted, \"betrays a profound interest in the best things in life\" in rough pioneer days. His estate was valued at approximately £600 sterling."},{"number":2,"category":"religion","header":"From Rev. Chauncey's congregation in Ware to founding","body":"Richard Platt grew up in Ware, Hertfordshire — a hotbed of Puritanism where the famous Rev. Charles Chauncey (later president of Harvard) preached from 1627 to 1633. Deeply influenced by Chauncey's teaching, he came to New England in 1638 with Rev. Peter Prudden's Hertfordshire company, and became one of 66 founding members of the Milford church on August 22, 1639."},{"number":3,"category":"legacy","header":"His name is on Milford's Founder's Bridge","body":"The Platt stone on the Wepawaug Memorial Bridge in Milford reads: \"Deacon Richard Platt, Obit 1684 — Mary His Wife.\" He was chosen Deacon of First Church Milford in 1669, witnessed the will of Rev. Peter Prudden, and appears as a witness in the colony records. He is buried in his orchard at lot #38, West Main and Cherry Streets, Milford."},{"number":4,"category":"family","header":"Nine children — their descendants married throughout","body":"His nine children — Mary, John, Isaac, Samuel, Sarah, Epenetus, Hannah, Josiah, and Joseph — spread through the families of Milford and surrounding towns. Daughter Mary married Luke Atkinson; daughter Sarah married Thomas Beach then Miles Merwin; son Joseph married Mary Kellogg. Their descendants appear as spouses throughout the Newton-Hooker family network across three generations."},{"number":5,"category":"legacy","header":"He left his entire estate to son Joseph","body":"His will left Joseph Platt the entirety of his estate: \"I give my son Joseph Platt all the remainder of my estate... I make my son Joseph Platt my executor.\" The family had emigrated from Hertfordshire, England in 1639, helping found New Haven and Milford. Joseph was the first Platt child born in America."}],"baptism":{"year":1604,"month":5,"day":6,"city":"Ware","county":"Hertfordshire","country":"England"},"bio":{"title":"Deacon","display_name":"Deacon Richard Platt","first_name":"Richard","last_name":"Platt","married_names":[]},"residence":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"richard-platt-1603"},"X00099":{"id":"X00099","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1604,"month":11,"day":10,"city":"Roydon","county":"Essex","country":"England"},"death":{"year":1676,"month":3,"day":24,"city":"Milford","state":"Connecticut","country":"United States","cause":"Buried Milford March 24, 1675/6. Admitted to Milford church Aug 15, 1641."},"marriages":[{"spouse_id":"X00098","children_ids":["X00076","X00100","X02114"],"marriage_number":1}],"sources":[{"short":"Families of Early Milford"}],"gender":"female","tags":[],"number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Wood Platt","first_name":"Mary","last_name":"Platt","married_names":["Platt"],"maiden_name":"Wood"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-wood-1604"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}