:1,"date_year":1767,"date_month":10,"date_day":22}],"tags":["military","navy","revolutionary_war"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 155"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"military_service":[{"war":"American Revolutionary War","rank":"Lieutenant (1775); Captain (later)","unit":"Captain Samuel Peck's Company, Connecticut Militia, 1775","notes":"Died age 39.","war_id":"WAR004"}],"bio":{"title":"Captain","display_name":"Captain John Fowler","first_name":"John","last_name":"Fowler","married_names":[],"bio_blurb":"Milford sea captain and Revolutionary officer"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"career":[{"role":"Sea Captain","organization":"Milford, Connecticut"},{"role":"Lieutenant","organization":"Captain Samuel Peck's Company, Connecticut Militia","start_year":1775}],"narrative_blocks":[{"number":1,"category":"career","header":"He commanded ships out of Milford","body":"John Fowler made his living as a sea captain, sailing out of the harbor town of Milford. The title that clung to his name came from the deck rather than the parade ground."},{"number":2,"category":"military","header":"A lieutenant under Captain Peck in 1775","body":"When the Revolution broke out, Fowler took a lieutenant's commission in Captain Samuel Peck's company of the Connecticut militia in 1775. He was one of many Milford men who answered the first call to arms."},{"number":3,"category":"family","header":"He married into a French refugee line","body":"In 1767 Fowler married Mary Ann Harpin of Milford. Her family traced back to Dr. John Harpin, who had fled Rochefort in France and reached America around 1690. Their sons carried the Harpin name into the next century."},{"number":4,"category":"death","header":"His stone asks if this is life's end","body":"Captain Fowler died on August 17, 1787, only thirty-nine years old. His Milford gravestone carries a startled, grieving verse: “All gracious Heaven, is this the end of man, a dreadful thought, a melancholy plan.”"}],"slug":"john-fowler-1748"},"HD0197":{"id":"HD0197","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1751,"month":3,"day":8},"death":{"year":1751,"month":3,"day":8},"parents":{"father_id":"H00164","mother_id":"H00155"},"tags":["died_in_infancy"],"sources":[],"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Fletcher Fowler","first_name":"Fletcher","last_name":"Fowler","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"merged_ids":["HD0176"],"slug":"fletcher-fowler-1751"},"HD0929":{"id":"HD0929","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1752},"death":{"year":1752},"parents":{"father_id":"H00164","mother_id":"H00155"},"tags":["died_in_infancy"],"sources":[],"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Stephen Fowler","first_name":"Stephen","last_name":"Fowler","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"stephen-fowl