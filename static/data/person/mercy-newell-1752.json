name":"Roger Sherman Newell","first_name":"Roger","last_name":"Newell","middle_name":"Sherman","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[{"type":"namesake","person_id":"X02819","person_name":"Hon. Roger Sherman","relationship":"namesake (precise kinship not yet documented)","notes":"Named for Hon. Roger Sherman of New Haven, signer of the Declaration of Independence and the Constitution. Per existing research_notes, 'a close' relation — specific kinship requires further research. Newell's parents are X00258 (unnamed) and H00307 Mercy Hooker Newell."}],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"naming","header":"Named for Hon. Roger Sherman, Constitution signer","body":"Roger Sherman Newell was born in 1791 in Southington CT, less than two years before his namesake Hon. Roger Sherman died in 1793. The Newell family clearly traveled in the Sherman family's orbit — Roger Sherman of New Haven was the only Founding Father to sign all four great state papers, and the choice to give an infant the full 'Roger Sherman' as first and middle name was a strong family memorial."}],"slug":"roger-newell-1791"},"H00694":{"id":"H00694","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1793},"parents":{"father_id":"X00258","mother_id":"H00307"},"tags":["died_young"],"sources":[{"short":"Edward Hooker 1909","entry":"694"}],"death":{"year":1794},"gender":"unknown","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Dolly Newell","first_name":"Dolly","last_name":"Newell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],