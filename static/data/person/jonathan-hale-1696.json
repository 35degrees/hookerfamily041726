 sister Jerusha died that September, leaving her mother widowed with three children buried in one Revolutionary year."},{"number":2,"category":"family","header":"Six of nine children predeceased her","body":"Of the nine children she bore Rev Joseph Huntington between 1773 and 1790, six died before she did — Septimus (age 3), George Washington (age 1), Hannah (age 15), Penelope (age 6), James (age 3), and Henry (age 25 same year as her own death). Only Elizabeth, Septimus George, and Lucretia outlived their mother to maturity."}],"slug":"elizabeth-huntington-1747"},"TD0305":{"id":"TD0305","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","birth":{"year":1735,"month":2,"day":6,"city":"Glastonbury","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1807,"month":5,"day":14,"city":"Glastonbury","state":"Connecticut","country":"United States"},"burial":{},"residence":{"city":"Glastonbury","state":"Connecticut","country":"United States"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":4,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"U00045","mother_id":"T00454"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"T01010","date_year":1759,"date_month":2,"date_day":23,"location_city":"Glastonbury","location_state":"Connecticut","location_country":"United States","children_ids":[]}],"tags":["cousin_marriage"],"narrative_blocks":[],"sources":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Theodore","last_name":"Hale","married_names":[