try":"United States","end_type":"death","end_year":1776,"children_ids":["TD0237"]}],"education":[],"career":[],"military_service":[{"war":"American Revolution","war_id":"WAR001","rank":"Captain","rank_start":"Ensign","rank_end":"Captain","rank_year_start":1764,"rank_year_end":1776,"unit":"6th Company, Col. Wolcott's Regiment, Connecticut Militia (19th Regiment)","notes":"Commissioned Ensign of the 4th Company in the 6th Regiment May 1764; Lieutenant October 1768; Captain of the same May 1772. Captain of the 6th Company, Col. Wolcott's Regiment in service 1776 — Siege of Boston, encamped at Jamaica Plain. Died of camp fever (typhus) Mar 7, 1776 at Roxbury Mass. DAR Ancestor #A049261. Will dated Feb 8, 1773, proved May 9, 1776."}],"institutions":[],"landmarks":[],"artworks":[],"tags":["revolutionary_war","epidemic_death","slaveholder","army"],"research_tags":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"quotes":[],"documents":[],"sources":[],"narrative_blocks":[{"number":1,"category":"death","header":"Camp fever killed him at Siege of Boston","body":"He died March 7, 1776 at Roxbury MA of camp fever — epidemic typhus — while serving as Captain of the 6th Company, Col Wolcott's CT Militia Regiment encamped at Jamaica Plain during the Siege of Boston. He was fifty-five and never saw the Declaration his fellow officers would sign four months later."},{"number":2,"category":"death","header":"Will mentioned enslaved man named Newport","body":"His will dated February 8, 1773 — three years before his Revolutionary death — named 'my negro man named Newport' alongside his wife and ten surviving children. The Connecticut Militia captain who died for the Revolution himself held a person enslaved, the contradiction documented in the same will that probated his patriot service."},{"number":3,"category":"family","header":"Three children died in his epidemic year 1776","body":"Within months of his March 7 death, his eldest son Jonathan died unmarried October 1, 1776 at age thirty, and his fifteen-year-old daughter Jerusha died September 26, 1776. The Hale household at Glastonbury lost father, son, and daughter in the same Revolutionary year."}],"slug":"jonathan-hale-jr-1721"},"U00056":{"id":"U00056","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"bio":{"display_name":"Elizabeth Welles Hale","first_name":"Elizabeth","last_name":"Hale","maiden_name":"Welles","married_names":["Hale"]},"gender":"female","birth":{"year":1722,"month":11,"day":15,"city":"Glastonbury","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1804,"month":3,"day":23,"city":"Glastonbury","county":"Hartford","state":"Connecticut","country":"United States"},"burial":{"cemetery_name":"Green Cemetery","city":"Glastonbury","state":"Connecticut","country":"United States"},"parents":{"father_name":"Col. Thomas Welles","mother_name":"Martha Pitkin Welles","father_research_notes":"Col. Thomas Welles of Glastonbury CT.","mother_research_notes":"Martha Pitkin Welles."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"TD0236","date_year":1744,"date_month":1,"date_day":18,"location_city":"Glastonbury","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1776,"children_ids":["TD0237"]}],"education":[],"career":[],"institutions":[],"landmarks":[],"artworks":[],"tags":[],"research_tags":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"quotes":[],"documents":[],"sources":[],"narrative_blocks":[],"slug":"elizabeth-welles-1722"},"TD0237":{"id":"TD0237","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"generation_f