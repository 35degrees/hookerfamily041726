r_of_marriages":1,"marriages":[],"tags":[],"narrative_blocks":[{"category":"business","header":"He published the Providence Journal like his forebears","body":"Michael Pierce Metcalf served as publisher, chief executive, and chairman of the Providence Journal Company, continuing a family tradition reaching back generations. The paper was known for hard-edged investigative reporting on organized crime in Rhode Island.","number":1},{"category":"death","header":"His own paper sought a death inquiry","body":"Metcalf died in September 1987, a week after a freak bicycle accident near his Westport summer home left him with severe head injuries. His own company asked prosecutors to examine the unusual circumstances, though no foul play was ever established.","number":2},{"category":"family","header":"He left trusts for his young children","body":"Metcalf died with three children still in their early teens, leaving a web of family trusts to provide for them. Decades later those trusts became the subject of litigation among his heirs.","number":3}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Michael Pierce","last_name":"Metcalf","married_names":[],"display_name":"Michael Pierce Metcalf","gender":"male"},"military_service":[],"generation_from_john_talcott":9,"burial":{"cemetery_name":"Swan Point Cemetery","city":"Providence","state":"Rhode Island","country":"United States"},"slug":"michael-pierce-metcalf-1933"},"X03117":{"id":"X03117","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","birth":{"year":1821,"month":6,"day":18,"city":"Boston","state":"Massachusetts","country":"United States"},"death":{"year":1903,"month":1,"day":17,"city":"Brookline","state":"Massachusetts","country":"United States"},"burial":{"cemetery_name":"Walnut Hills Cemetery","city":"Brookline","state":"Massachusetts","country":"United States"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"is_easter_egg":true},"notable":{"is_notable":true,"notable_category":["arts","literature"],"notable_blurb":"Architect and Emerson's first biographer","primary_url":"https://www.walden.org/what-we-do/library/the-transcendentalists-their-lives-writings/james-elliot-cabot-1821-1903/","primary_url_label":"The Thoreau Society / Walden Woods"},"parents":{},"number_of_marriages":1,"marriages":[{"spouse_id":"X03118","spouse_name":"Elizabeth \"Lizzie\" Dwight Cabot","marriage_year":1857,"children_ids":["I01542"]}],"tags":["author","harvard_graduate","architect"],"narrative_blocks":[{"category":"literature","header":"He wrote the first life of Emerson","body":"A close friend of Ralph Waldo Emerson, James Elliot Cabot served as his literary executor and wrote the first authorized biography, A Memoir of Ralph Waldo Emerson (1887). He had earlier helped found the Atlantic Monthly.","number":1},{"category":"arts","header":"A reluctant lawyer who turned to architecture","body":"Harvard College and Harvard Law trained, Cabot found trial work daunting and left the bar. He joined his brother Edward's architectural practice, designing buildings and helping run the office.","number":2},{"category":"arts","header":"He gave Boston's museum its plaster casts","body":"An early trustee of the Museum of Fine Arts, Cabot championed acquiring plaster casts of famous Greek and Roman statues. He believed the young museum would never afford originals, and also served the Boston Athenaeum.","number":3},{"category":"literature","header":"His first essay graced the final Dial","body":"Cabot's essay on Immanuel Kant opened the last issue of The Dial in April 1844, his first appearance in print. He later helped edit the short-lived Massachusetts Quarterly Review alongside Emerson and Theodore Parker.","number":4}],"sources"