works":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Russell & Company trader in China, 1825-1838","body":"Edward Augustus Russell joined his elder brother Samuel in China in 1825, working for Russell & Company — the dominant American firm in the Canton trade. He stayed thirteen years, returning to Middletown in 1838. The fortune accumulated in the China trade financed his return to civic life in Connecticut."},{"number":2,"category":"achievement","header":"Built Greek Revival on Noadiah Russell's homelot","body":"In 1841-1842 Russell built a Greek Revival mansion at 318 High Street, Middletown — the last Greek Revival house on what had become the city's most prestigious street. The lot was the original Noadiah Russell homelot, dating to the seventeenth century. Rev. Noadiah Russell had been a founding trustee of Yale in 1701 and was Edward Augustus Russell's great-great-grandfather."},{"number":3,"category":"career","header":"Mayor of Middletown, 1859-1861","body":"Russell served as Mayor of Middletown from 1859 to 1861, as a Connecticut State Representative, and as a national convention delegate. He held railroad directorships including the presidency of the Charles River Railroad in Massachusetts. Both of his sons predeceased him."}],"landmarks_associated":["LM017"],"slug":"edward-russell-1797"},"HD1384":{"id":"HD1384","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1374","mother_id":"X00444"},"tags":[],"sources":[{"short":"Barbour Collection Middletown CT / Online vital records"}],"marriages":[],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Mary Osborn Russel