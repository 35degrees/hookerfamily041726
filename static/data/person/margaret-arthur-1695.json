ttees during the war","war_id":"WAR004"}],"bio":{"title":"Deacon","display_name":"Dea. Edward Rawson","first_name":"Edward","last_name":"Rawson","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"family","header":"Named his firstborn son 'Hooker' in 1749","body":"In 1749, four generations after Thomas Hooker's death, he named his firstborn son Hooker Rawson. The deliberate act of family memory was carried in a generation that knew their Hooker descent only as received tradition."},{"number":2,"category":"marriage","header":"Married his first cousin once removed","body":"He married Mary Morse — granddaughter of his aunt Susannah Rawson Reynolds of Bristol, Rhode Island. Edward Hooker confirmed the relationship in his 1909 genealogy as 'Gr. dau. of his Aunt Reynolds.'"},{"number":3,"category":"military","header":"Revolutionary War deacon and town leader","body":"He served in the Revolution and lived to age 86 in Leicester, Massachusetts. EB Crane wrote that 'Nature did much for him' — he was a leading man in the town's affairs."}],"slug":"edward-rawson-1721"},"HD0260":{"id":"HD0260","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1716,"month":11,"day":20,"city":"Bristol","county":"Bristol","state":"Rhode Island","country":"United States"},"parents":{"father_id":"I00105","mother_id":"H00077"},"tags":["cousin_marriage","replacement_naming"],"sources":[],"gender":"female","number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"I01088","date_year":1738,"date_month":10,"date_day":19,"location_city":"Bristol","location_county":"Bristol","location_state":