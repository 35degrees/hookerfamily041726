ne. Their marriage was a documented Pierpont-Reynolds first-cousin union. The 'Aunt Reynolds' relationship was sometimes recorded ambiguously as grandmother rather than mother, but Mary was the daughter, not the granddaughter, of Susannah Rawson Reynolds."}],"slug":"mary-rawson-1716"},"HD0282":{"id":"HD0282","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1749,"month":4,"day":21},"parents":{"father_id":"H00208","mother_id":"HD0260"},"tags":["named_for_hooker"],"sources":[],"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"death":{},"cross_connections":[],"bio":{"display_name":"Hooker Rawson","notes":"Named \"Hooker\" — a deliberate family tribute to ancestor Thomas Hooker, 100 years after his death","first_name":"Hooker","last_name":"Rawson","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"hooker-rawson-1749"},"HD0283":{"id":"HD0283","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1750,"month":4,"day":4},"parents":{"father_id":"H00208","mother_id":"HD0260"},"tags":[],"sources":[],"gender":"unknown","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"death":{},"cross_connections":[],"bio":{"display_name":"Elisabeth Rawson","first_name":"Elisabeth","last_name":"Rawson","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],