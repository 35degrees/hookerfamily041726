les-solomon"},{"bib_id":"BIB003"}],"notable":{"is_notable":true,"notable_category":["military","business"],"notable_blurb":"Capt., CT Militia; innkeeper; 'Solomon Cowles and Sons'","primary_url":"https://www.nativenortheastportal.com/bio/bibliography/cowles-solomon","primary_url_label":"Native Northeast Portal"},"narrative_blocks":[{"header":"Fined for drinking East India tea","body":"On March 23, 1775, Solomon Cowles and his wife Martha were 'convicted of partaking of that detestable and obnoxious vegetable called East India tea' — forced to sign a public confession printed in the Connecticut Courant. Yet by 1774 Cowles had already served on the committee to collect provisions for the relief of Boston's inhabitants, and in 1775 receipted for supplies furnished to the Rifle Battalion marching to the American camp near Boston. He was a patriot despite the tea.","number":1,"category":"character"},{"category":"military","header":"He rose to captain of the Farmington trainband","body":"Cowles was commissioned an ensign in the Farmington trainband in 1759 and made captain in the colony's first regiment two years later. He also kept an inn on the town's main street and ran the firm Solomon Cowles and Sons.","number":2}],"cross_connections":[{"type":"family_orbit","related_id":"H00309","display_label":"married his son Isaac Cowles"}],"bio":{"display_name":"Captain Solomon Cowles","first_name":"Solomon","last_name":"Cowles","title":"Captain","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"solomon-cowles-1719"},"X01976":{"id":"X01976","is_placeholder":false,"gender":"female","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true}