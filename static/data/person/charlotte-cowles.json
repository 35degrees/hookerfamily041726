les; the family lawyered in Belleville, Illinois, then followed two daughters to California. Neither the Hooker genealogy nor the Cowles book ever learned when he died — last seen “a lawyer of note” in San Diego, past ninety-seven."}],"slug":"alfred-cowles-1787"},"HD3687":{"id":"HD3687","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Frederick","last_name":"Cowles","married_names":[],"gender":"male","display_name":"Frederick Cowles"},"birth":{"year":1817,"country":"United States"},"baptism":{},"death":{"year":1819,"country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H01139","mother_id":"I00384"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Frederick","inspired_by_id":"H01140","description":"Named for his uncle Frederick Woodruff Cowles (H01140) who died at 18 months before this Frederick was born."}],"artworks":[],"tags":["died_in_infancy"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"short":"Edward Hooker 1909 — entry #1139 Alfred Cowles"}],"research_sources":[],"documents":[],"slug":"frederick-cowles-1817"},"HD3688":{"id":"HD3688","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Cornelia","last_name":"Cowles","married_names":[],"gender":"female","display_name":"Cornelia Cowles"},"birth":{"year":1819,"country":"United States"},"baptism":{},"death":{"year":1829,"country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas