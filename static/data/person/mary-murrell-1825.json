ation":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1763,"month":6,"day":24,"city":"Kensington","state":"Connecticut"},"death":{"year":1832,"month":3,"day":16,"city":"Hempstead","state":"New York"},"parents":{"father_id":"H00286","mother_research_notes":"Elizabeth Hopkins Hart","mother_id":"X01933"},"marriages":[{"spouse_id":"X00535","children_ids":["H01564","H01565","H01566","H01567","H01568","H01569","H01570"],"marriage_number":1,"date_year":1788,"date_month":10,"date_day":7}],"tags":["yale_connection","episcopal","revolutionary_war","inventor"],"sources":[{"page":"Entry 608","label":"Edward Hooker 1909"},{"url":"https://archive.org/details/biographicalsket04dextuoft/page/342/mode/2up","label":"Dexter — Biographical Sketches Yale Vol 4"}],"gender":"male","narrative_blocks":[{"header":"Yale 1784; ordained by Bishop Seabury; Hempstead rector","detail":"He served as agent for the Connecticut Land Company (1796-1797) surveying lands in Cleveland, Ohio. Among his boarding school students around 1809 was his nephew James Gates Percival (X01936) — son of his sister Elizabeth Hart (H00610) — who later became a noted poet, Connecticut state geologist, and Wisconsin state geologist, writing his final report from memory without notes. The Hofstra University library holds the Hart-Nichols family papers, including correspondence compiled by Seth's granddaughter Mary Amelia Hart (1838-1932). His portrait was painted by Edwin Percival (nephew James Gates's brother) around 1829. (Hart Genealogy 1948; Hofstra Hart-Nichols Family Papers)","body":"Seth Hart graduated Yale in 1784 and was ordained by Bishop Samuel Seabury — deacon in 1791, priest in 1792. He served as rector of St. George's Church in Hempstead, Long Island for 28 years (1800-1829), until paralysis forced his resignation. He died in 1832, 'much beloved and lamented by his former parishioners.'","number":1,"category":"religion"},{"number":2,"category":"family","header":"His boarding school launched nephew Percival's poetry","body":"He ran a boarding school at Hempstead where his nephew James Gates Percival was sent in 1807 after their father's death. Despite Percival's resentment of his uncle's 'amiable, cheerful, almost jovial' efforts to draw him out, the Hempstead years were where Percival first wrote poetry."},{"number":3,"category":"career","header":"Officiated Cleveland's first baptism, marriage, and burial","body":"In spring 1797 he went to the Western Reserve of Ohio as General Agent and Chaplain of the surveying party sent by the Connecticut Land Company to develop their settlement at Cleveland. He spent six months in service and officiated at the first baptism, the first marriage, and the first burial occurring in Cleveland."}],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["religion","education"],"notable_blurb":"Yale 1784; rector St. George's Hempstead 28 years","primary_url":"https://www.hofstra.edu/pdf/library/libspc_lisi_oe_hartnichols_selections.pdf","primary_url_label":"Hofstra Hart Nichols Collection"},"institution_affiliations":[],"artworks":["ART024"],"cross_connections":[{"type":"mentor_student","display_label":"His boarding school was where nephew Percival first wrote poetry","related_id":"HD3158","link_text":"James Gates Percival"},{"type":"artifact","related_id":"X01938","display_label":"His portrait painted by his nephew Edwin Percival — a Hooker descendant","link_text":"Edwin Percival"}],"education":[{"institution_id":"INST022","school_name":"Yale College","type":"university","degree":"B.A.","graduation_year":1784,"notable":false,"institution_blurb":"Graduated Yale 1784; became Episcopal rector at Hempstead LI for 28 years."}],"bio":{"title":"Reverend","display_name":"Rev. Seth Hart","first_name":"Seth","last_name":"Hart","married_names":[],"photo_u