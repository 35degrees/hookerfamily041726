descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"T00057","mother_id":"X01751"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01518","date_year":1753,"location_city":"Glastonbury","location_state":"Connecticut","location_country":"United States","children_ids":["I01517"],"date_month":3}],"tags":["unusual_death"],"narrative_blocks":[{"number":1,"category":"death","header":"Killed by a mislabeled medicine bottle","body":"Feeling unwell, Jerusha Welles was advised to take a small dose of variolated tartar. A wrong label led her to swallow corrosive sublimate of mercury instead, and she died within days in 1778, leaving five children and a reputation for piety and charity."}],"sources":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Jerusha","last_name":"Edwards","married_names":["Jerusha Edwards Welles"],"display_name":"Jerusha Edwards Welles","gender":"female"},"military_service":[],"slug":"jerusha-edwards-1732"},"T00459":{"id":"T00459","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":3,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1709,"month":12,"day":31,"city":"Glastonbury","state":"Connecticut","country":"United States"},"death":{"year":1797,"month":11,"day":24,"city":"Glastonbury","state":"Connecticut","country":"United States","cause":"old age"},"parents":{"father_id":"T00135","mother_id":"U00030"},"tags":["politician","revolutionary_war"],"sources":[{"short":"Talcott 1876","page":"Entry 459"},{"label":"Talcott Pedigree 1876"},{"short":"Berlin-Peck F&I War PDF","url":"https://berlinpeck.org/wp-content/uploads/2022/08/Berlin-in-the-French-and-Indian-War-1753-%E2%80%93-1763.pdf","source_id":"berlin_peck_french_indian_war"}],"marriages":[{"marriage_number":1,"spouse_id":"U00049","date_year":1730,"date_month":12,"date_day":31,"location_city":"Glastonbury","location_state":"Connecticut","location_country":"United States","end_type":"death","children_ids":["T01018","T01010","TD0306","TD0307","TD0308","TD0309","TD0310","TD0311","T01012","T01016","T01017","T01019"]}],"gender":"unknown","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"military","related_id":"H00228","display_label":"Hooker descendant served in his Troop of horses, 1757 alarm.","link_text":"Samuel Hooker Jr."}],"baptism":{},"burial":{},"narrative_blocks":[{"number":1,"category":"politics","header":"Chaired Glastonbury's denunciation of the Boston Port Bill","body":"As chairman of the Glastonbury town meeting he led the formal denunciation of the Boston Port Bill — one of the acts that precipitated the Revolution. He already held a commission as Colonel of a Troop of Horse and would lead that troop into the field."},{"number":2,"category":"military","header":"Carried home from Long Island on a litter","body":"Present at the Battle of Long Island in August 1776 at age 67, he fell so ill during the campaign that he was carried back to Glastonbury on a litter. He resigned his commission three months later and never rejoined the Continental Army."},{"number":3,"category":"legacy","header":"Lost a Susquehanna land claim in court","body":"He held substantial Connecticut Susquehanna lands in Pennsylvania — claimed under Connecticut's sea-to-sea royal charter. He lost that investment entirely when the courts ruled against the Connecticut claim."},{"number":4,"category":"family","header":"Wife Ruth brought a large fortune to him","body":"His wife Ruth Wright brought a substantial fortune to the marriage, inherited from her wealthy father Daniel Wright Jr. They married on his 21st birthday — December 31, 1730 — and son George later served with him in the Revolution."},{"number":5,"category":"family","header":"He lost four sons to black canker","body":"Of Colonel Elizur Talcott's twelve children with Ruth Wright, four young sons died of what the family record called 'black canker' between 1748 and 1750. He twice gave a dead son's name to a later child, and only a handful of the twelve lived to marry."}],"artworks":[],"documents":[],"quotes":[],"statues":[],"research_tags":[],"naming_inspiration":[],"landmarks":[],"institutions":[],"research_sources":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","rank":"Colonel","unit":"Sixth Connecticut Militia (Sixth Regiment, Colony of Connecticut)","allegiance":"United States (Continental cause)","service_years":"1775-1776","battles":["BTL007"],"notes":"Colonel of the Sixth Connecticut Militia 1775-1776. At age 67, present at the Battle of Long Island (Aug 27, 1776). Became ill during the campaign and was carried back to Glastonbury CT on a litter; resigned his commission three months later. Surviving documentation: a holograph order signed by Col. Elizur Talcott in Glastonbury CT June 12, 1776 to Capt. Benjamin Wright of the Fourth Company directing election of a new Lieutenant — the document was signed off by Titus Hosmer for the Lower House (Continental Congress delegate and Articles of Confederation signer) and George Wyllys for the Upper House (Connecticut Secretary of State). See DOC013."},{"war":"French and Indian Wars","war_id":"WAR003","rank":"Major","rank_year_start":1757,"rank_year_end":1757,"unit":"Troop of horses, CT militia (Glastonbury)","service_years":"August 1757","battles":["BTL048"],"notes":"Commanded a Troop of horses raised at Glastonbury for service in the alarm for the relief of Fort William Henry and parts adjacent, August 1757. His unit included Hooker descendant Samuel Hooker Jr (H00228) for 14 days of service. Source: Berlin-Peck Memorial Library — Berlin in the French and Indian War 1753-1763."}],"bio":{"display_name":"Col. Elizur Talcott","first_name":"Elizur","last_name":"Talcott","title":"Colonel","married_names":[]},"residence":{},"slug":"elizur-talcott-1709"},"U00049":{"id":"U00049","has_descendants_documented":false,"in_talcott_book":false,"visible_default":false,"classification":{"is_talcott_descendant":false,"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"Talcott Pedigree 1876"}],"gender":"female","number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"T01029","date_year":1779,"date_month":11,"date_day":17,"location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1779,"children_ids":["T01042","T01043","T01044","T01045","T01046","T01047","T01048"]},{"marriage_number":2,"spouse_id":"T00459","date_year":1730,"date_month":12,"date_day":31,"children_ids":["T01018","T01010","TD0306","TD0307","TD0308","TD0309","TD0310","TD0311","T01012","T01016","T01017","T01019"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1756,"month":11,"day":22,"state":"Connecticut","country":"United States"},"death":{"year":1801,"month":5,"day":3,"city":"Bolton","county":"Tolland","state":"Connecticut","country":"United States"},"cross_connections":[],"baptism":{},"burial":{"cemetery_id":"CEM119","plot_notes":"Quarryville Cemetery, Bolton CT. FindAGrave Memorial ID 10706544."},"marriage_number":1,"narrative_blocks":[{"number":1,"category":"marriage","header":"She brought a fortune to her marriage","body":"Ruth Wright was an only child who inherited a large fortune from her wealthy father and brought it to her marriage with Elizur Talcott. Family memory described her as a remarkably handsome woman, tall and erect, with golden hair and black eyes."}],"artworks":[],"documents":[]