r 1916 by St. Anne's Society"},"narrative_blocks":[{"header":"Remembered at St. Anne's with a carved stone","body":"Carrie Jennings Willcox was the youngest child of Prof. William Henry Willcox — born three years before her father's death in 1870. She spent her adult life in Annapolis, working as a private teacher to children of prominent families and at the Naval Academy, and as assistant to the founder of the St. Anne's Society. When she died of bronchial pneumonia on August 2, 1910 at 43, the Evening Capital ran a front-page obituary: 'She was a woman of high culture and deep learning and rare intellectuality.' In 1916 the St. Anne's Society installed a carved stone sedilia set in her memory — ceremonial seats for officiating clergy, still in the chancel of St. Anne's Church, Annapolis.","number":1}],"cross_connections":[],"bio":{"display_name":"Carrie Jennings Willcox","first_name":"Carrie","last_name":"Willcox","maiden_name":"Willcox","married_names":["Willcox"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST114"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"carrie-willcox-1867"},"HD0731":{"id":"HD0731","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1825,"city":"Berlin/New Haven","state":"Connecticut"},"death":{"year":1901,"month":4,"day":5,"city":"Philadelphia","state":"Pennsylvania"},"parents":{"mother_id":"HD0726","father_research_notes":"Norris Willcox","father_id":"X02013"},"marriages":[{"children_ids":["HD0732","HD0733","HD0734","HD0735"],"spouse_id":"X01295","marriage_number":1,"date_year":1849,"date_month":5,"date_day":17,"location_city":"New Haven","location_state":"Connecticut"}],"tags":["banker"],