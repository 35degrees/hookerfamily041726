he Supreme Court.","number":1},{"category":"law","header":"He later carried out the captives' release","body":"When the courts ruled for the Africans, it fell to Willcox to free them from federal custody. President Polk afterward named him collector of customs for the port of New Haven.","number":2}],"cross_connections":[{"type":"legal_adversary_ally","related_id":"HD0867","display_label":"Both central figures in the Amistad case — Willcox as federal marshal holding the captives, Leavitt as the abolitionist organizing their legal defense.","link_text":"Rev. Joshua Leavitt"},{"type":"amistad_connection","related_id":"H00697","display_label":"Cowles housed a Mende girl in his Farmington home after the Supreme Court freed the captives; Willcox had administered their federal custody throughout the trial.","link_text":"Horace Cowles"},{"type":"amistad_connection","related_id":"H00698","display_label":"Held the Mende during trial — Cowles housed one after release","link_text":"Major Timothy Cowles","description":"Norris Willcox held the Mende captives in federal custody during their trial. After the Supreme Court freed them in March 1841, the Mende were brought to Farmington, where Major Timothy Cowles was among the families who sheltered one of the freed Mende girls."}],"bio":{"display_name":"Norris Willcox","first_name":"Norris","last_name":"Willcox","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"norris-willcox-1798"},"HD2965":{"id":"HD2965","is_placeholder":false,"gender":"male","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1823,"month":10,"day":19,"state":"Connecticut"},"d