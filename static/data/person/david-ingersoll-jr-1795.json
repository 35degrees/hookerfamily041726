year":1728,"month":8,"day":25,"city":"Northampton","state":"Massachusetts"},"death":{"year":1805,"month":5,"day":15,"city":"Goshen","state":"Massachusetts"},"parents":{"father_id":"X00128","mother_id":"HD0418"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 376"},{"label":"Salt of the Earth — David Brainerd and Jerusha Edwards: A Colonial Love Story","url":"https://salt-ofthe-earth.blogspot.com/2013/02/david-brainerd-and-jerusha-edwards.html"}],"marriages":[{"spouse_id":"X00536","children_ids":["H00901","H00902","H00903","H00904","H00905","H00906","H00907","H00908","H00909","H00910","H00911"],"marriage_number":1,"date_year":1750,"date_month":6,"date_day":11}],"cross_connections":[{"type":"family_connection","notes":"The coincidence of two daughters marrying two Ingersolls in the same period and region (Berkshire County MA) likely reflects the prominence of the Ingersoll family in that area. (DAR records; FindAGrave)","related_id":"H00905","display_label":"Daughter Lydia married Aaron Ingersoll of Berkshire","link_text":"Lydia Parsons Ingersoll"},{"type":"family_connection","notes":"The coincidence of two daughters marrying two Ingersolls in the same period and region (Berkshire County MA) likely reflects the prominence of the Ingersoll family in that area. (DAR records; FindAGrave)","related_id":"H00907","display_label":"Daughter Sarah married David Ingersoll of Berkshire","link_text":"Sarah Parsons"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Sarah Edwards","first_name":"Sarah","maiden_name":"Edwards","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777406086/sarahedwardsparsons_jcxgr0.png","photo_notes":"Sarah Edwards Parsons (1728-1805), eldest daughter of Jonathan Edwards."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Eldest Edwards child born Sabbath afternoon, 1728","body":"She was born August 25, 1728 in Northampton — 'on a Sabbath day, between 2 and 3 o'clock in the afternoon,' as her father Jonathan Edwards recorded. She was the eldest of his eleven children."},{"number":2,"category":"marriage","header":"Married her father's attorney — Stockbridge farmer","body":"In 1750 she married Elihu Parsons, a Northampton attorney who handled many of Jonathan Edwards's legal and personal affairs. Parsons later farmed in Stockbridge, where the family settled during the Mohican mission years."},{"number":3,"category":"character","header":"Father warned suitor of her temper","body":"When Elihu Parsons asked Jonathan Edwards for her hand, Edwards reportedly disclosed her difficult temper before quipping: 'I hope she has grace, but grace can live where you cannot.'"},{"number":4,"category":"family","header":"Two daughters married into the Berkshire Ingersolls","body":"Two of her eleven children — both daughters — married into the Ingersoll family of Berkshire County, Massachusetts. This is a separate Ingersoll line from the Loyalist New Haven Ingersolls who descended through the Newton-Miles line."}],"slug":"sarah-edwards-1728"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}