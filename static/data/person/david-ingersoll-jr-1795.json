"date_year":1781,"date_month":12,"date_day":18,"location_city":"Lee","location_state":"Massachusetts"}],"tags":[],"sources":[{"short":"Edward Hooker 1909","entry":"907"},{"short":"The Jonathan Edwards Collection (Yale)"},{"short":"Avery, Genealogy of the Ingersoll Family in America (1926)"},{"short":"Descendants of William Smith of Glastonbury CT (archive.org)","url":"https://archive.org/details/descendantsofwil00smit/page/38/mode/2up?q=Eunice+"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Genealogy of the Ingersoll Family in America 1926"},"cross_connections":[],"bio":{"display_name":"Sarah Parsons","first_name":"Sarah","last_name":"Parsons","married_names":["Ingersoll"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Thirteen children all reached adulthood and married","body":"Sarah Parsons married Deacon David Ingersoll II at Stockbridge MA on December 13, 1781. Their thirteen children all grew to adulthood, married, and mostly had large families — over 2,000 descendants are recorded. The Ingersoll-Yale lineage was one of the founding strata of Lee, Massachusetts; the marble from David's farm quarry helped build the U.S. Capitol."},{"number":2,"category":"family","header":"Two thousand descendants and counting","body":"The thirteen children she raised at Lee all married and “mostly had large families” — over two thousand descendants recorded by the 1926 Ingersoll genealogy, among them the founders of the Ingersoll Dollar Watch. Her widowed mother, a daughter of Jonathan Edwards, lived out years under her roof."}],"slug":"sarah-parsons-1760"},"X00536":{"id":"X00536","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_fro