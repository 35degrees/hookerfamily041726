elated_id":"X02782","display_label":"Co-founders of Austinburg church and Western Reserve College","link_text":"Judge Eliphalet Austin Sr."}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["religion","education"],"notable_blurb":"Pioneer minister, founded Austinburg Ohio 1811","primary_url":"https://ohiogenealogyexpress.com/ashtabula/ashtaco_1878_bios/ashtaco_1878_bios_cowlesGiles.html","primary_url_label":"Ohio Genealogy Express"},"burial":{"cemetery_id":"CEM035","plot_notes":"Buried beside his wife Sallie White Cowles and son Edward. Funeral held in the church he helped build."},"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1786-1789","institution_blurb":"Graduated Yale College 1789 with honors; D.D. awarded by Williams College 1823."},{"institution_id":"INST044","relationship":"founder","years":"1825-1826","institution_blurb":"One of the original founders of Western Reserve College (now Case Western Reserve University) in 1826; drove the founding stake on College Hill, Hudson Ohio."},{"institution_id":"INST003","relationship":"member","years":"1792-1810","institution_blurb":"Ordained minister at First Congregational Church, Bristol CT 1792-1810."},{"institution_id":"INST043","relationship":"alumnus"}],"narrative_blocks":[{"number":1,"category":"religion","header":"A thirty-day wagon journey from Bristol","body":"In 1811 Cowles loaded his family of nine children onto two wagons and traveled thirty to forty days over mud roads to Austinburg, Ohio — a journey so final that returning was considered nearly impossible. His congregation built the first church with a steeple in the state of Ohio, and he served it for nearly twenty-five years."},{"number":2,"category":"education","header":"Drove the founding stake of Ohio's first college","body":"In 1825 Cowles helped found Western Reserve College — called 'Yale of the West' for sharing Yale's motto, standards, and curriculum. He was among those who drove a stake on College Hill in Hudson, Ohio, and his name appears as an original incorporator. The college is now Case Western Reserve University."},{"number":3,"category":"religion","header":"Yale 1789, then theology with Edwards the Younger","body":"After Yale 1789 Cowles read theology with tutor William Robinson before continuing under Rev. Dr. Jonathan Edwards Jr. at New Haven, son of the Great Awakening preacher. Edwards Jr. ordained him at Bristol's First Church on October 17, 1792."},{"number":4,"category":"religion","header":"'A year never to be forgotten' — 1799","body":"A revival swept his Bristol parish in 1799 and added 218 members to the church, the harvest of his early ministry. Three years later he was preaching publicly against the Bristol Baptists in defense of infant baptism, sermons that drew fierce reply."},{"number":5,"category":"social_reform","header":"His Austinburg parsonage gathered the era's reformers","body":"His 320-acre Austinburg parsonage built in 1815 housed the Western Reserve's largest county library and a steady traffic of visitors — Bishop Philander Chase passing through on his Ohio diocese rounds, anti-slavery orators stopping for hospitality. The Cowles household became a way-station for the reform circuits of the Reserve."},{"number":6,"category":"death","header":"Resigned the pulpit 1830, died still preaching","body":"Cowles resigned his Austinburg pulpit in 1830 with a farewell sermon on 1 Samuel 12:23: 'God forbid that I should sin against the Lord in ceasing to pray for you.' Five years later, on Sunday July 5, 1835, he died at his parsonage and the Western Reserve's clergy gathered to bury him in his own churchyard."}],"career":[{"title":"Congregational Minister","start_year":1792,"end_year":1835,"location_city":"Bristol","location_state":"Connecticut","notes":"Ordained Oct 17, 1792. Bristol CT 1792-1810. Austinburg OH 1811-1835."},{"title":"Theological Student under Rev. Dr. Jonathan Edwards Jr.","location_city":"New Haven","location_state":"Connecticut","start_year":1789,"end_year":1791,"notes":"Read theology under Edwards the Younger after Yale graduation; tutored earlier under William Robinson."},{"title":"Licensed Candidate to Preach","organization":"Hartford North Association","location_state":"Connecticut","start_year":1791,"end_year":1792,"notes":"Licensed May 31, 1791."},{"title":"Pastor","organization":"First Congregational Church of Bristol (New Cambridge)","location_city":"Bristol","location_state":"Connecticut","start_year":1792,"end_year":1810,"notes":"Ordained October 17, 1792. Dismissed May 24, 1810 in preparation for Ohio migration."},{"title":"Pastor","organization":"United Church of Austinburg and Morgan","location_city":"Austinburg","location_state":"Ohio","start_year":1811,"end_year":1830,"notes":"Installed September 25, 1811. Built first steepled church in Ohio. Resigned pulpit 1830."},{"title":"Co-founder","organization":"Western Reserve College","location_city":"Hudson","location_state":"Ohio","start_year":1825,"end_year":1826,"notes":"Original incorporator; drove the founding stake on College Hill, Hudson Ohio. Now Case Western Reserve University."}],"education":[{"degree":"B.A. with honors; M.A.","notes":"Prepared under Rev. Wm. Robinson of Southington; entered Yale Jun 1, 1786; graduated Sep 9, 1789.","school_name":"Yale College","graduation_year":1789,"institution_id":"INST022"},{"degree":"D.D. (honorary)","school_name":"Williams College","graduation_year":1823,"institution_id":"INST043"}],"bio":{"display_name":"Rev. Giles Hooker Cowles","first_name":"Giles","last_name":"Cowles","middle_name":"Hooker","title":"Reverend","married_names":[],"photo_url":"https://ohiogenealogyexpress.com/ashtabula/graphics/1878_CowlesGHRev_Res_austinburgO.jpg","photo_notes":"Illustration of the Cowles family residence, Austinburg, Ohio (1878). No portrait survives."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"giles-cowles-1766"},"X00259":{"id":"X00259","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["ohio_migration"],"sources":[{"short":"Find a Grave Memorial 47260486 (Sally White Cowles)","url":"https://www.findagrave.com/memorial/47260486/sally-cowles","accessed":"2026-05"},{"short":"Williams Brothers 'History of Ashtabula County' (1878), biography of Rev. Giles Hooker Cowles","url":"https://ohiogenealogyexpress.com/ashtabula/ashtaco_1878_bios/ashtaco_1878_bios_cowlesGiles.html","accessed":"2026-05"}],"birth":{"year":1774,"month":1,"day":1,"city":"Stamford","state":"Connecticut","country":"United States"},"death":{"year":1830,"month":7,"day":31,"city":"Austinburg","county":"Ashtabula County","state":"Ohio","country":"United States"},"gender":"female","number_of_marriages":1,"marriages":[{"spouse_id":"H00443","children_ids":["H01141","H01142","H01143","H01144","H01145","H01146","H01147","H01148","H01149"],"marriage_number":1,"date_year":1793,"date_month":2,"date_day":5,"location_city":"Stamford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1830}],"parents":{"father_research_notes":"Lebbeus White, b. Stamford Jun 10, 1748; Revolutionary War private; drowned 1779 (NOT at Delaware crossing — family tradition incorrect; drowned event inscribed on Stamford tombstone). d. Jul 5, 1779.","mother_research_notes":"Abigail Weed White, b. Stamford Oct 24, 1750. Descended from Huguenot family De Grasse (name later changed to Weed)."},"notable":{"is_notable":false,"notable_category":[]},"burial":{"cemetery_id":"CEM035","plot_notes":"Buried beside her mother Abigail White, who died the year before."},"narrative_blocks":[{"number":1,"category":"character","header":"She convinced her husband to move to Ohio","body":"It was Sally who first embraced the idea of emigrating to the Western Reserve — seeing in the distant Ohio lands cheap land and opportunity for her boys. She persuaded her husband to make the scouting journey on horseback that led to the family's migration in 1811, loading nine children onto two wagons for a thirty-day journey from which return was considered nearly impossible."},{"number":2,"category":"legacy","header":"First child born to the Mayflower settlers","body":"Sally White was a direct descendant of Peregrine White, born aboard the Mayflower in Provincetown Harbor in 1620 — the first child born to the Mayflower settlers in the New World. She was also descended, on her mother's side, from the Huguenot family De Grasse, whose name was later anglicized to Weed."}],"cross_connections":[],"bio":{"display_name":"Sally White Cowles","first_name":"Sally","last_name":"Cowles","maiden_name":"White","married_names":["Cowles"],"photo_url":"https://ohiogenealogyexpress.com/ashtabula/graphics/1878_CowlesGHRev_Res_austinburgO.jpg","photo_notes":"Illustration of the Cowles family residence, Austinburg, Ohio (1878). No portrait survives."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sally-white-1774"},"I00156":{"id":"I00156","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1721,"month":11,"day":4,"city":"Farmington","state":"Connecticut"},"death":{"year":1806,"month":9,"day":23,"city":"Farmington","state":"Connecticut"},"parents":{"father_id":"X00261","mother_id":"X00262"},"marriages":[{"spouse_id":"H00232","children_ids":["H00436","H00437","H00438","H00439","H00440","H0044