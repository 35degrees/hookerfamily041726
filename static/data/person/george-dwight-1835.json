":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST018"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-fiske-1800"},"H00920":{"id":"H00920","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1764},"death":{"year":1846},"parents":{"father_id":"X00635","mother_id":"H00379"},"marriages":[{"spouse_id":"X00659","children_ids":["HD2050","HD2051","HD2052"],"marriage_number":1,"date_year":1792,"date_month":9,"date_day":9}],"tags":["author","journalist","abolitionist","congressman"],"sources":[{"short":"Edward Hooker 1909","entry":"920"}],"cross_connections":[{"type":"mentor_student","notes":"Admitted to bar 1787. The mentor-student relationship between these two Jonathan Edwards grandchildren is documented in Dwight's biography. (Wikipedia; DAB)","related_id":"H00920","display_label":"Theodore Dwight Sr. studied law under his cousin Pierpont Edwards.","link_text":"Theodore Dwight"},{"type":"mentor_student","notes":"Admitted to bar 1787. The mentor-student relationship between these two Jonathan Edwards grandchildren is documented in Dwight's biography. (Wikipedia; DAB)","related_id":"H00386","display_label":"Theodore Dwight Sr. studied law under his cousin Pierpont Edwards.","link_text":"Pierpont Edwards"},{"type":"civic_peer","notes":"Both were grandsons of Jonathan Edwards. Both had their careers ultimately shaped by political catastrophe — Burr's duel with Hamilton (1804) and Dwight's association with the Hartford Convention (1814). Their brief partnership is documented in Appletons' Cyclopaedia and DAB.","related_id":"H00920","display_label":"Theodore Dwight Sr. had a brief law partnership with his.","link_text":"Theodore Dwight"},{"type":"civic_peer","notes":"Both were grandsons of Jonathan Edwards. Both had their careers ultimately shaped by political catastrophe — Burr's duel with Hamilton (1804) and Dwight's association with the Hartford Convention (1814). Their brief partnership is documented in Appletons' Cyclopaedia and DAB.","related_id":"H00913","display_label":"Theodore Dwight Sr. had a brief law partnership with his.","link_text":"Aaron Burr Jr."}],"orbit_connections":[{"name":"Richard March Hoe (X00797) — grandson of rotary press inventor; married granddaughter of Theodore Dwight's line","person_id":"X00797","relationship":"Richard March Hoe Harper Sr. married Mabel Simpkins Bacon (HD2426), granddaughter of Dr. Gorham Bacon (HD2413), great-great-granddaughter of Amelia Dwight (HD2286), great-great-great-granddaughter of Rhoda Edwards Dwight, and a descendant of Theodore Dwight Sr. (H00920). His grandfather Richard March Hoe invented the rotary printing press (1843) and the web perfecting press (1871) that printed 18,000 newspapers/hour — the same generation as Theodore Dwight Sr.'s 1825 steam-press newspaper.","connection_type":"orbit_non_descendant"}],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"U.S. Congressman","primary_url":"https://en.wikipedia.org/wiki/Theodore_Dwight_(journalist)"},"narrative_blocks":[{"header":"Hartford Convention secretary","detail":"Dwight was at the center of Connecticut Federalism for two decades — as editor of the Connecticut Mirror (its primary organ), as a member of the Connecticut State Council 1809-15, and briefly as a US Congressman (Dec 1806-Mar 1807). His 1833 History of the Hartford Convention became the primary Federalist account of that controversy. The Convention's association with disloyalty during the war's victorious conclusion largely destroyed the Federalist Party, making Dwight and his cousin Aaron Burr Jr. (H00913) emblematic of two very different careers cut short by political miscalculation. (Wikipedia)","body":"Dwight served as secretary of the Hartford Convention in 1814-15, the gathering of New England Federalists whose opposition to the War of 1812 effectively ended the Federalist Party as a national force.","number":1},{"header":"New York Daily Advertiser","detail":"He built the Advertiser into a major New York paper over nearly two decades before the Great Fire of December 1835 destroyed its offices and presses. His father's Hartford Courant and Connecticut Mirror connections gave him a journalism apprenticeship; the Advertiser represented his mature achievement. His son William Richard Dwight later co-edited the paper with him. (Wikipedia; Dwight 1874)","body":"Dwight's New York Daily Advertiser (founded 1817) was the first American periodical printed by steam-powered cylinder press (1825), capable of 2,000 copies per hour.","number":2},{"header":"Abolitionist — argued for immediate emancipation and reparations","detail":"Using natural law philosophy, Dwight contended that Black Americans had every right to use force to defend their natural rights — a more radical position than most white abolitionists of his generation. This oration preceded his better-known journalism career and connects him, and through him his son Theodore Dwight Jr. (HD2050), to the organized abolitionist movement that would culminate in the Civil War. His son Theodore Jr. continued this tradition, working directly with the enslaved scholar Omar ibn Said. (Theodore Dwight, \"An Oration... Before the Connecticut Society,\" published pamphlet)","body":"In an oration before the Connecticut Society for the Promotion of Freedom, Dwight argued that enslaved people had never consented to a social contract and were therefore in a state of war with white Americans, entitled not only to freedom but to reparations.","number":3},{"header":"Jefferson and Sally Hemings","detail":"Published decades before the abolitionist press widely addressed the Hemings relationship, Dwight's 1839 work represents one of the earliest treatments of what would remain a contested historical question for more than 150 years. His anti-Jeffersonian Federalist politics gave him both motive and audience. His cousin Aaron Burr Jr. (H00913) — Jefferson's bitter political enemy — would have relished the publication had he lived to see it. (Wikipedia; The Character of Thomas Jefferson, Hartford, 1839)","body":"In The Character of Thomas Jefferson (1839), Dwight argued that Jefferson's character was duplicitous and explicitly referenced his relationship with Sally Hemings.","number":4}],"number_of_marriages":1,"bio":{"display_name":"Theodore Dwight","first_name":"Theodore","last_name":"Dwight","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/thumb/9/9e/Theodore_Dwight.jpg/440px-Theodore_Dwight.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"theodore-dwight-1764"},"X00659":{"id":"X00659","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1765,"month":11,"day":17,"city":"Middletown","state":"Connecticut"},"death":{"year":1846,"month":4,"day":2,"city":"New York City","state":"New York"},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00920","date_year":1792,"date_month":9,"date_day":9,"children_ids":["HD2050","HD2051","HD2052"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Abigail Alsop","first_name":"Abigail","maiden_name":"Alsop","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming