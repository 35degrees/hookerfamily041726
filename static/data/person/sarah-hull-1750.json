ildren_ids":["HD0280","HD3053","HD3054","HD3055","HD3056","HD3057"],"location_country":"United States"}],"tags":["argentina_migration","physician","politician","military"],"sources":[{"label":"Wikipedia — Amán Rawson","url":"https://en.wikipedia.org/wiki/Am%C3%A1n_Rawson"}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":true,"notable_category":["politics","medicine"],"notable_blurb":"4-day chairman San Juan","primary_url":"https://en.wikipedia.org/wiki/Am%C3%A1n_Rawson","primary_url_label":"Wikipedia"},"narrative_blocks":[{"header":"Arrived in Argentina at 26 — independence year","number":1,"body":"Amán Rawson received his medical degree in 1814 and served as a surgeon in the U.S. Navy. In 1818 — just two years after Argentina declared independence — he arrived in Buenos Aires. He spent a short time in Mendoza before settling in San Juan in early 1819."},{"header":"Smuggled Facundo in drawers labeled for disease","number":2,"body":"In his final years Amán Rawson smuggled copies of Sarmiento's Facundo — a devastating political attack on the Rosas dictatorship — by hiding them in drawers filled with a chemical stench, with a large sign warning they contained remedies for venereal diseases. The border guards never checked. He died in San Juan in January 1847, a year after the books arrived."},{"header":"Emergency chairman of San Juan — four days","number":3,"body":"In April 1831, news reached San Juan that Federalist forces under General Facundo Quiroga were marching on the province. Amán Rawson took emergency joint control of the government with priest José de Oro and Ignacio José Sánchez. He called an election, a moderate Federalist won, and Rawson stepped aside — four days after he'd stepped in."},{"header":"He arrived from Massachusetts and founded a city","number":4,"body":"In 1822, the former U.S. Navy surgeon planned to establish an American immigrant colony in San Juan Province. It ended as an Argentine settlement instead — but from that project grew the city of Caucete and the irrigation of the left bank of the San Juan River."}],"cross_connections":[{"type":"family_orbit","related_id":"X02061","display_label":"He smuggled Sarmiento's Facundo into San Juan hidden in medicine drawers —.","link_text":"Domingo Faustino Sarmiento"}],"bio":{"display_name":"Amán Rawson","first_name":"Haman","last_name":"Rawson","married_names":[],"nickname":"Haman","photo_url":"https://upload.wikimedia.org/wikipedia/commons/1/1e/Aman_rawson.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"haman-rawson-1792"},"X01120":{"id":"X01120","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0277","end_type":"death_of_spouse","end_year":1822,"children_ids":["HD3050","HD3051","HD0279","HD3052"],"date_year":1819,"date_month":3,"date_day":17,"location_city":"San Juan","location_country":"Argentina"}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1798,"month":1,"day":1,"city":"San Juan","country":"Argentina"},"death":{"year":1822,"month":1,"day":1,"city":"San Juan","country":"Argentina"},"narrative_blocks":[{"header":"She died in 1822","body":"María Justina Rojo married Amán Rawson on March 17, 1819 — he had converted to Catholicism to meet her family's requirements, though he never practiced the faith. She died in 1822, the same year as their son Justino, and the same year her husband attempted to establish an American immigrant colony that became the city of Caucete.","number":1}],"cross_connections":[],"bio":{"display_name":"María Justina Rojo Frías","fir