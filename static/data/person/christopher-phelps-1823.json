_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H00483","mother_id":"I00756"},"number_of_marriages":1,"marriages":[{"marriage_number":2,"spouse_id":"I00759","date_year":1814,"date_month":1,"date_day":7,"location_country":"United States","children_ids":["HD4445","HD4446","HD4447","H02368","HD4448","HD4449","H02370"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Married her late sister's husband; bore explorer-named twins","body":"Fourteen months after her sister Louisa's death — just twenty-four days into Louisa's marriage to Burnham Phelps — Mary Deming Hooker married Burnham herself on January 7, 1814, the practice of marrying a deceased wife's sister recognized in New England as a form of family continuity. Among their eight children were twins born July 7, 1823 named Christopher Columbus and Americus Vespusius — honoring both Atlantic explorers in a single act of naming, though Americus died at age three in 1826."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909), entries 483–2370","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"mary-phelps-1792"},"H00483":{"id":"H00483","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1747,"month":3,"day":4,"city":"Wethersfield","county":"Hartford County","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00254","mother_id":"I00162"},"tags":["revolutionary_war","vermont_migration"],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909), entries 483–2370","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave memorial records","url":"https://www.findagrave.com"}],"gender":"unknown","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00756","location_country":"United States","children_ids":["H01247","H01248","HD4432","HD4433","HD4434","HD4435","H01253"]}],"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1808,"month":10,"day":23,"city":"Middlebury","county":"Addison County","state":"Vermont","country":"United States"},"cross_connections":[{"type":"naming_pattern","related_id":"X02351","display_label":"Named for him — born same year Brainerd died, 1747","link_text":"Rev. David Brainerd"}],"bio":{"display_name":"Brainard Hooker","first_name":"Brainard","last_name":"Hooker","married_names":[],"gender":"male"},"residence":{},"baptism":{},"research_tags":["has_discrepancy"],"research_sources":[],"documents":[],"naming_inspiration":[{"name_element":"Brainard","inspired_by_id":"X02351","description":"Named for the Connecticut missionary David Brainerd (X02351, 1718-1747), who died October 9, 1747 — just seven months after Brainard Hooker's birth. Brainerd was Connecticut-born (Haddam) and celebrated for his missionary work when the Hooker baby was named."}],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"Revolutionary War","war_id":"WAR001","rank":"Soldier","notes":"Per EH entry 483."}],"narrative_blocks":[{"number":1,"category":"military","header":"Revolutionary War soldier; led family north to Vermont","body":"Brainard Hooker served in the Revolutionary War and moved his family from Wethersfield, Connecticut to Middlebury, Vermont, where he died in October 1808 at age sixty-one. He was survived by his wife Mary Deming Hooker, who outlived him by thirty-five years, dying in 1843 at age ninety."},{"number":2,"category":"birthname","header":"Born in 1747 when David Brainerd also died","body":"Brainard Hooker was born in Woodbury, Connecticut on March 4, 1747 — the same year that the renowned Presbyterian missionary David Brainerd died in Northampton, Massachusetts on October 9, 1747. The name 'Brainard' was rare in colonial Connecticut, but Brainerd was Connecticut-born (Haddam) and celebrated across New England for his missionary work among Delaware Indians; his parents almost certainly named the baby in honor of the dying missionary."}],"burial":{"cemetery_id":"CEM388","plot_notes":"Case Street Cemetery, Middlebury VT per FindAGrave"},"slug":"brainard-hooker-1747"},"I00756":{"id":"I00756","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Mary","last_name":"Hooker","maiden_name":"Deming","married_names":["Hooker"],"gender":"female","display_name":"Mary Deming Hooker"},"birth":{"year":1752,"month":1,"day":23,"city":"Wethersfield","county":"Hartford County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1843,"month":6,"day":4,"city":"Middlebury","county":"Addison County","state":"Vermont","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM388","plot_notes":"Case Street Cemetery, Middlebury VT (m.1771 per FindAGrave)"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00483","location_country":"United States","children_ids":["H01247","H01248","HD4432","HD4433","H