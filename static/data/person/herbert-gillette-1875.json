","landmark_blurb":"Co-founder (from 1853); Co-founded Nook Farm with brother-in-law John Hooker."}],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"artworks":[],"quotes":[],"military_service":[],"slug":"francis-gillette-1807"},"H01625":{"id":"H01625","is_placeholder":false,"gender":"female","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1813,"month":5,"day":1,"city":"Farmington","state":"Connecticut"},"death":{"year":1893,"month":12,"day":16,"city":"Hartford","state":"Connecticut"},"parents":{"father_id":"H00630","mother_id":"X02036"},"marriages":[{"marriage_number":1,"spouse_id":"I00173","children_ids":["H02974","H02975","H02976","H02977","H02978","H02979"],"date_year":1834,"date_month":9,"date_day":10,"location_city":"Farmington","location_state":"Connecticut"}],"number_of_marriages":1,"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 01625"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"She married a Yale-educated senator who co-founded Nook","body":"Elisabeth Daggett Hooker married Francis Gillette in 1834 — a Yale valedictorian who later became a U.S. Senator and co-founded Hartford's Nook Farm community with her brother John. Every one of their five children who survived infancy carried 'Hooker' as a middle name: Ashbell Frank, Elisabeth Hooker, Edward Hooker, Robert Hooker, and William Hooker.","number":1}],"cross_connections":[],"bio":{"display_name":"Elisabeth Daggett Hooker Gillette","first_name":"Elisabeth","last_name":"Gillette","maiden_name":"Hooker","married_names":["Gillette"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmar