 Stoddard of Guilford was betrothed to Robert Hooker Gillette when he was killed at Fort Fisher on January 16, 1865. Sixteen months later, on June 26, 1866, she married his brother Edward Hooker Gillette — who had been farming in Iowa since 1863. She became an Iowa farmer's wife; Edward later won election to Congress.","number":1}],"burial":{"cemetery_id":"CEM073","plot_notes":"Buried at her request near Robert Hooker Gillette (H02977), her original fiancé"},"cross_connections":[],"bio":{"display_name":"Sophia Theresa Stoddard Gillette","first_name":"Sophia","last_name":"Gillette","maiden_name":"Stoddard","married_names":["Gillette"],"middle_name":"Theresa","photo_url":"https://www.wikitree.com/photo.php/1/1a/Stoddard-810.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sophia-stoddard-1845"},"I00173":{"id":"I00173","is_placeholder":false,"gender":"male","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1807,"month":12,"day":14,"city":"Bloomfield","state":"Connecticut"},"death":{"year":1879,"month":9,"day":30,"city":"Hartford","state":"Connecticut"},"burial":{"cemetery_id":"CEM073"},"parents":{"father_research_notes":"Rev. Ashbel Gillette","mother_research_notes":"Achsah Francis"},"marriages":[{"marriage_number":1,"spouse_id":"H01625","children_ids":["H02974","H02975","H02976","H02977","H02978","H02979"],"date_year":1834,"date_month":9,"date_day":10,"location_city":"Farmington","location_state":"Connecticut"}],"number_of_marriages":1,"institutions":[{"institution_id":"INST022","institution_blurb":"Yale College 1829; valedictorian elected unanimously by classmates."}],"tags":["abolitionist","educator","politician",