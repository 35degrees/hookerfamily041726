ngineer","expatriate","inventor","yale_graduate"],"sources":[{"label":"Yale University Obituary Record — Edward Hubbard Russell (Ph.B. 1878)"},{"label":"Yale Library Manuscripts MS 1213 — Russell Process Company Records","url":"https://ead-pdfs.library.yale.edu/3224.pdf"}],"birth":{"year":1855,"month":12,"day":27,"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1928,"month":11,"day":21,"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States","cause":"Arteriosclerosis"},"gender":"male","marriages":[],"notable":{"is_notable":true,"notable_category":["business","science"],"notable_blurb":"Russell Process silver extraction inventor","primary_url":"https://ead-pdfs.library.yale.edu/3224.pdf","primary_url_label":"Yale Library MS 1213 Russell Process Company Records"},"cross_connections":[],"bio":{"display_name":"Edward Hubbard Russell","first_name":"Edward","last_name":"Russell","middle_name":"Hubbard","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST138","role":"General Manager + Inventor (Russell Process)","start_year":1884,"end_year":1895,"notes":"Russell Process for silver extraction from low-grade ores — basis of company."},{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"plot_notes":"Grove Street Cemetery, New Haven CT"},"education":[{"school_name":"Yale College","institution_id":"INST022","degree_or_field":"Entered Class of 1878","notes":"Member Kappa Sigma Epsilon."},{"school_name":"Sheffield Scientific School at Yale","degree_or_field":"Ph.B. (engineering)","class_year":1878,"notes":"Transferred 1879 from Yale College to Class of 1878 S. Member Sigma Delta Chi."},{"school_name":"Sheffield Scientific School (graduate)","degree_or_field":"Metallurgy graduate study","class_year":1879,"notes":"One year of post-bachelor's metallurgy study at Sheffield."}],"career":[{"role":"Mining Engineer","organization":"Ontario Mining Company","location":"Park City Utah","start_year":1879,"notes":"First mining engineer position post-Sheffield; western US silver-mining boom."},{"role":"Mining Engineer","organization":"Various US + Mexico mining concerns","location":"United States + Mexico","start_year":1879,"end_year":1895,"notes":"15-20 years as mining engineer + metallurgist."},{"role":"General Manager + Inventor","organization":"Russell Process Company (INST138)","location":"New York City HQ","start_year":1884,"end_year":1895,"notes":"Patents 1880, 1883, 1884, 1885, 1886, 1889 for silver extraction + ore leaching + hyposulphites + soda ash purification."},{"role":"Independent scholar + sociologist","organization":"Living abroad (London)","location":"London","start_year":1895,"end_year":1928,"notes":"Gave up mining 1895; lived abroad until May 1928. Studied sociology + worked with poorer classes."}],"narrative_blocks":[{"number":1,"category":"science","header":"Invented the Russell Process for silver extraction","body":"Around 1884 he invented the Russell Process — a hydro-metallurgical leaching method using sodium hyposulphite that allowed economic silver extraction from low-grade ores previously uneconomic. The process built on the older Austrian Patera method but achieved higher extraction rates and could handle ores with heavy base metals."},{"number":2,"category":"career","header":"Patents across nine years, 1880-1889","body":"He held US patents granted in 1880, 1883, 1884, 1885, 1886, and 1889 for separating metals from ores, leaching, purifying hyposulphites, and purifying soda ash. The process became highly lucrative for western US and Mexican silver-mining operations through the late 1880s."},{"number":3,"category":"career","header":"Mining engineer at Park City, then London sociologist","body":"After Yale Sheffield 1878 he worked 15-20 years as mining engineer in Park City Utah and across US + Mexico — including with the Ontario Mining Company. Gave up mining 1895 and lived in London until May 1928, devoting himself to the study of sociology + work among poorer classes."},{"number":4,"category":"family","header":"Unmarried; died New Haven 1928 age seventy-two","body":"He never married; on returning to New Haven May 1928 from his 33-year London period he died at the Parkhurst Sanitarium November 1928 of arteriosclerosis at age 72. Buried at Grove Street Cemetery in his birth city — alongside many of his Russell siblings."}],"slug":"edward-russell-1855"},"HD1411":{"id":"HD1411","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":true,"is_easter_egg":false,"generation_from_john_talcott":7},"parents":{"father_id":"HD1395","mother_id":"X00449"},"tags":[],"sources":[],"birth":{"year":1860},"death":{"year":1881},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Robert Gray Russell","first_name":"Robert","last_name":"Russell","middle_name":"Gray","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"robert-russell-1860"},"HD1396":{"id":"HD1396","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00856","mother_id":"X00448"},"tags":[],"sources":[],"birth":{"year":1810},"death":{"year":1865},"gender":"female","marriages":[],"notable":{"is_notable":false,"notable_category