vic_leadership","academic","yale_graduate"],"sources":[{"label":"Yale University Obituary Record — Talcott Huntington Russell (B.A. 1869)"},{"label":"Yale Library Manuscripts MS 1213 — Russell Process Company Records","url":"https://ead-pdfs.library.yale.edu/3224.pdf"},{"label":"Find a Grave — Talcott Huntington Russell"}],"birth":{"year":1847,"month":3,"day":14,"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1917,"month":10,"day":18,"city":"Westport","county":"Fairfield","state":"Connecticut","country":"United States","cause":"Illness (four-year duration)"},"cross_connections":[{"type":"naming_pattern","related_id":"H00856","display_label":"Carried the Talcott name third generation, after grandfather and aunt.","link_text":"Matthew Talcott Russell"}],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01120","date_year":1889,"date_month":12,"date_day":10,"location_city":"New Haven","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death_of_self","end_year":1917,"children_ids":["HD4827","HD4828"]}],"notable":{"is_notable":true,"notable_category":["law","social_reform"],"notable_blurb":"CT Workmen's Compensation founding chairman, 1913","primary_url":"https://ead-pdfs.library.yale.edu/3224.pdf","primary_url_label":"Yale Library MS 1213 Russell Process Company Records"},"bio":{"display_name":"Talcott Huntington Russell","first_name":"Talcott","last_name":"Russell","middle_name":"Huntington","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779222135/taclottrussell_jo3zxf.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST138","role":"Secretary-Treasurer","notes":"Brother Edward H. Russell the Russell Process inventor was general manager."},{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"legacy","header":"Donated his ancestor's 1638 sea chest to history","body":"In 1888 his family donated the William Russell sea chest, dating to 1638, to the New Haven Colony Historical Society. The provenance letter named him as the living end of a 250-year chain."},{"number":2,"category":"family","header":"Father co-founded Skull and Bones at Yale","body":"His father William Huntington Russell co-founded the secret society at Yale in 1832. The family's Yale connections ran through both the Russell and the Talcott lines for generations."},{"number":3,"category":"family","header":"Third generation to carry the Talcott name","body":"His grandfather Matthew Talcott Russell had been named for the childless Col. Matthew Talcott who funded his education. He was the third in his line to carry the Talcott name forward."},{"category":"civic","header":"First chairman of CT workmen's compensation 1913","body":"In 1911 he was retained by the CT legislative committee to draft workmen's compensation legislation; his draft 'formed the framework of much of the legislation finally adopted.' When Connecticut adopted the system in 1913 he was made first chairman of the commission — resigning 1.5 years later due to ill health.","number":4},{"category":"education","header":"Yale Law instructor on municipal corporations","body":"From 1892 until 1900 he served as instructor on municipal corporations at the Yale School of Law — an 8-year teaching tenure during his New Haven private-practice years. The position followed his New Haven Board of Councilmen presidency in the city's municipal-government era.","number":5},{"category":"business","header":"Secretary-treasurer of the Russell Process Company","body":"Together with his brother Edward — inventor of the Russell Process for silver extraction from low-grade ores — he ran the New York-headquartered Russell Process Company that licensed metallurgy patents through the 1880s-1890s western US silver mining boom. Much of the company's business was conducted out of his New Haven law office.","number":6},{"category":"scholarship","header":"Conference on Uniform State Laws founding treasurer","body":"He was one of the first members + treasurer of the Conference on Uniform State Laws (now the Uniform Law Commission) — the body that drafts model legislation for adoption by US states. He chaired the Commercial Law Committee, shaping early uniform commercial law jurisprudence.","number":7},{"category":"education","header":"Yale 1869, Columbia Law LL.B. 1872","body":"Prepared at his father's school (General Russell's Collegiate and Commercial Institute) and at Lawrence Academy in Groton MA. After Yale BA 1869 he studied 1 year at Yale Law before transferring to Columbia Law School, earning his LL.B. 1872 — that year was admitted to the Connecticut bar.","number":8}],"burial":{"plot_notes":"Grove Street Cemetery, New Haven CT"},"education":[{"school_name":"Lawrence Academy","degree_or_field":"Preparatory","notes":"Groton MA (Sam-Sr's school + his own preparatory)"},{"school_name":"Yale College","institution_id":"INST022","degree_or_field":"B.A.","class_year":1869},{"school_name":"Yale School of Law","degree_or_field":"Law (1 year)","class_year":1870,"notes":"Studied 1 year at Yale Law before transferring to Columbia."},{"school_name":"Columbia Law School","degree_or_field":"LL.B.","class_year":1872,"notes":"Admitted to Connecticut bar 1872."}],"career":[{"role":"Attorney","organization":"Private practice, New Haven CT","location":"New Haven CT","start_year":1872,"end_year":1914,"notes":"Retired 1914 due to illness."},{"role":"Receiver","organization":"American Mutual Life Insurance Company","location":"Connecticut","start_year":1878},{"role":"Secretary","organization":"Independent Republican Organization","location":"Connecticut","start_year":1884},{"role":"Instructor on Municipal Corporations","organization":"Yale School of Law","location":"New Haven CT","start_year":1892,"end_year":1900,"notes":"8-year teaching tenure."},{"role":"Treasurer + Commercial Law Committee Chair","organization":"Conference on Uniform State Laws","location":"United States","notes":"One of the first members."},{"role":"Secretary-Treasurer","organization":"Russell Process Company (INST138)","location":"New Haven CT office (NYC company HQ)","notes":"Brother Edward H. Russell was general manager + inventor; C.A. Stetefeldt was president."},{"role":"Chairman + Commissioner, 3rd Congressional District","organization":"Connecticut Workmen's Compensation Commission","location":"Connecticut","start_year":1913,"end_year":1914,"notes":"First chairman when CT adopted workmen's compensation 1913; resigned after 1.5 years due to ill health."}],"slug":"talcott-russell-1847"},"HD1407":{"id":"HD1407","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":true,"is_easter_egg":false,"generation_from_john_talcott":7},"parents":{"father_id":"HD1395","mother_id":"X00449"},"tags":["died_in_infancy"],"sources":[],"birth":{"year":1850},"death":{"year":1851},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"William H. Russell","first_name":"William","last_name":"Russell","middle_name":"H.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"william-russell-1850"},"HD1408":{"id":"HD1408","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":tr