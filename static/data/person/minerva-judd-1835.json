ce":[],"narrative_blocks":[{"number":1,"category":"career","header":"Pioneered collapse therapy for tuberculosis in Colorado","body":"Dr. George Burton Gilbert pioneered collapse therapy for tuberculosis as resident physician at Cragmor Sanatorium in Colorado Springs — the leading early-twentieth-century American TB sanatorium. He worked as associate of Dr. Gerald B. Webb, the era's most prominent American TB physician and a founder of the National Tuberculosis Association. Gilbert earned wide recognition for his TB treatment work across the western American medical community."},{"number":2,"category":"character","header":"Tuberculosis interrupted his Johns Hopkins training","body":"Gilbert was sent to Saranac Lake — the Adirondack TB-treatment village — during his Johns Hopkins Medical School years after contracting tuberculosis himself. He completed the medical degree despite the interruption and later turned his own patient experience into a career treating others with the disease. His Colorado Springs move from his Hartford internship was both for the dry climate and for the Cragmor opportunity."},{"number":3,"category":"character","header":"Attended Saturday morning conferences until the last","body":"Even after ill health forced his retirement from active practice, Gilbert continued unremitting reading of medicine and attended the weekly clinical-pathological staff conference every Saturday morning until the very last week of his life. He died of coronary thrombosis on April 6, 1951 at age sixty-nine. The lifelong-learning discipline reflected the unbroken professional commitment characteristic of early-twentieth-century American physicians."},{"number":4,"category":"family","header":"Yale 1903, Hopkins MD 1907, three marriages","body":"Gilbert graduated Yale College in 1903 — having planned to enter the ministry but received a legacy that enabled medical school at Johns Hopkins instead, where he graduated in 1907. He served as Regional Regent of the American College of Chest Physicians and held memberships in the American Board of Internal Medicine, American Trudeau Society, and American College of Physicians. He had three marriages across his life."}],"slug":"george-gilbert-1881"},"X00366":{"id":"X00366","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1807},"death":{"year":1896},"gender":"male","marriages":[{"spouse_id":"HD1179","children_ids":["HD1181"],"marriage_number":1}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sherman Prindle Woodward","first_name":"Sherman","last_name":"Woodward","middle_name":"Prindle","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"number_of_marriages":1,"slug":"sherman-woodward-1807-2"},"HD1179":{"id":"HD1179","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00825","mother_id":"I00369"},"tags":[],"sources":[{"short":"Find a Grave — Northfield Cemetery Northfield CT","url":"https://www.findagrave.com/cemetery/103525/northfield-cemetery"},{"short":"WikiTree (online genealogy)","url":"https://www.wikitree.com/"}],"birth":{"year":1809,"month":9,"day":4,"county":"Litchfield","state":"Connecticut","country":"United States"},"death":{"year":1837,"month":8,"day":22,"country":"United States"},"marriages":[{"marriage_number":1,"spouse_id":"I00370","location_country":"United States","end_type":"death","end_year":1837,"children_ids":["HD3653","HD3654","HD1181"]},{"spouse_id":"X00366","children_ids":["HD1181"],"marriage_number":2}],"gender":"female","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Minerva Pierpont Woodward","first_name":"Minerva","last_name":"Woodward","maiden_name":"Pierpont","married_names":["Woodward"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM259","plot_notes":"Find a Grave memorial 153095371"},"narrative_blocks":[{"number":1,"category":"family","header":"Lost mother at twenty-eight with two daughters","body":"Minerva died at twenty-eight, the year after her mother and the year after her father's drowning death — leaving two young daughters, four-year-old Rachael and two-year-old Minerva. Her widower Sherman Prindle Woodward remarried Hannah Eliza Russell the following year, and the two girls were raised by their stepmother in the Watertown household."}],"slug":"minerva-woodward-1809"},"H00825":{"id":"H00825","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1783,"month":6,"day":29,"city":"Plymouth","county":"Litchfield","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00353","mother_id":"X00355"},"tags":["westward_migration","drowned","ohio_migration"],"sources":[{"short":"Edward Hooker 1909","entry":"825"},{"short":"WikiTree (online genealogy)","url":"https://www.wikitree.com/"},{"short":"Rhoda Cowles Diary, vol. II"},{"short":"My Country, vol. 28 no. 1, winter 1994"},{"short":"Find a Grave — Cholera Cemetery Sandusky OH","url":"https://www.findagrave.com/cemetery/40290/cholera-cemetery"}],"death":{"year":1836,"month":5,"day":7,"city":"Sandusky","county":"Erie","state":"Ohio","country":"United States","cause":"Drowned in Lake Erie when sailboat capsized in a squall off Put-in-Bay (South Bass Island)"},"marriages":[{"spouse_id":"I00369","children_ids":["HD1179","HD1180"],"marriage_number":1,"date_year":1807,"date_month":12,"date_day":1,"location_city":"Litchfield","location_state":"Connecticut","location_country":"United States"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"place_overlap","related_id":"H01494","display_label":"War of 1812 soldier died at Sandusky, 1813","link_text":"Norman Hart","notes":"Both Hooker descendants died at Sandusky, Ohio, twenty-three years apart. Norman Hart (gen 7, Marietta Hart line) died there August 1813 as a soldier of the War of 1812 aged seventeen — likely at the August 1-2 defense of Fort Stephenson. Sherman drowned in Lake Erie there May 7, 1836 aged fifty-two. Different lines of Hooker descent ending at the same Ohio frontier town a generation apart."},{"type":"parallel_descent","related_id":"HD4969","display_label":"Drowned at Lake Garfield Massachusetts, 1915, age 38","link_text":"Albert Norton Butler","notes":"Both Hooker descendants drowned in lakes. Albert Norton Butler — Yale 1900, president of Butler & Klein Lumber Co. — drowned in Lake Garfield at Monterey, Berkshire County Massachusetts on September 28, 1915 when his rowboat capsized; aged thirty-eight. Seventy-nine years and two generations after Sherman's Lake Erie drowning at Sandusky in 1836."}],"bio":{"display_name":"Sherman Pierpont","first_name":"Sherman","last_name":"Pierpont","married_names":[]},"residence":{"city":"Sandusky","county":"Erie","state":"Ohio","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"title":"Wool merchant","organization":"Pierpont Family Wool Business","dates":"~1805-1830s","type":"commerce","notes":"Continued the Pierpont family wool business in Litchfield County. When Sherman and his wife Sidney moved to Sandusky Ohio (probably early 1830s), his younger brother James Morris Pierpont IV (H00832) took over the business. Per My Country (vol. 28 no. 1, winter 1994)."}],"burial":{"cemetery_id":"CEM258","plot_notes":"Buried May 27, 1836 after body washed ashore on Lake Erie. His name appears on a Find A Grave memorial with parents and siblings at Morris Burying Ground in Litchfield County CT, but this is in error — actual burial is at Cholera Cemetery in Sandusky OH per FG records."},"narrative_blocks":[{"number":1,"category":"death","header":"Drowned in Lake Erie squall, body washed ashore","body":"Sherman left Put-in-Bay on a sailboat heading for Sandusky Ohio May 7, 1836 with two other men, and all three drowned when the boat capsized in a squall. His body washed ashore on Lake Erie twenty days later. His brother Rev. John Pierpont, the Boston abolitionist, wrote in a poem of dreaming of his lost brother 'sleeping on Low Sandusky's shore.'"},{"number":2,"category":"death","header":"Body washed ashore three weeks after drowning","body":"His sailboat capsized in a squall off Put-in-Bay on South Bass Island in Lake Erie on 7 May 1836; all three men aboard drowned. His body was discovered 27 May 1836 on the shore of Lake Erie — three weeks after the squall — and brought to Sandusky for burial."},{"number":3,"category":"legacy","header":"Brother John's poem mourned him from Connecticut","body":"His older brother Rev John Pierpont wrote a posthumous poem preserved in the Rhoda Cowles Diary: 'I am awakened by my weeping / To know that thou art sleeping / on Low Sandusky's shore.' The grief crossed both the family wool business and the geographic separation of Connecticut from Ohio."}],"slug":"sherman-pierpont-1783"},"I00369":{"id":"I00369","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Sidney","last_name":"Pierpont","maiden_name":"Humiston","married_names":["Pierpont"],"gender":"female","display_name":"Sidney Humiston Pierpont"},"birth":{"year":1786,"city":"Plymouth","county":"Litchfield","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1841,"month":5,"day":16,"country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM259","plot_notes":"Find a Grave memorial 153077426"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Jesse Humiston","mother_name":"Abi Blakeslee Humiston","father_research_notes":"Jesse Humiston of Plymouth CT (not built per Jalapeño).","mother_research_notes":"Abi Blakeslee Humiston of Plymouth CT (not built per Jalapeño)."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00825","date_year":1807,"location_country":"United States","end_type":"death_of_spouse","end_year":1836,"children_ids":["HD1179","HD1180"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"short":"Humiston Genealogy","url":"https://archive.org/details/connecticutmagaz00hart/page/172/mode/2up","notes":"Connecticut Magazine — Humiston entry §188."},{"short":"Find a Grave — Northfield Cemetery Northfield CT","url":"https://www.findagrave.com/cemetery/103525/northfield-cemetery"},{"short":"WikiTree (online genealogy)","url":"https://www.wikitree.com/"}],"research_sources":[],"documents":[],"slug"