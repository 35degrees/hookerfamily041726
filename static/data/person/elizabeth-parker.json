areer":[{"role":"Physician","location":"East Cambridge, Middlesex County, Massachusetts","start_year":1822,"end_year":1869,"notes":"Per EH 1909: 'not only became noted as a physician but was also prominent in the public affairs of the place.'"},{"role":"Member of Common Council","organization":"City of East Cambridge","location":"East Cambridge, Massachusetts"},{"role":"Alderman","organization":"City of East Cambridge","location":"East Cambridge, Massachusetts"},{"role":"Representative","organization":"Massachusetts General Court","location":"Boston, Massachusetts","notes":"Representative of East Cambridge in the Massachusetts General Court per EH 1909."}],"military_service":[],"institutions":[{"institution_id":"INST043","relationship":"alumnus","years":"graduated 1819","institution_blurb":"Graduated Williams College 1819."},{"institution_id":"INST002","relationship":"alumnus","years":"graduated 1822","institution_blurb":"Graduated Harvard Medical School 1822."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["physician","harvard_graduate","politician"],"research_tags":[],"cross_connections":[{"type":"mentor_student","related_id":"H02763","display_label":"Studied medicine at East Cambridge; died of hospital disease, 1858","link_text":"Edward Hooker"},{"type":"mentor_student","related_id":"H02760","display_label":"Son who joined his practice; died New Year's Eve 1873","link_text":"Anson Parker Hooker"}],"narrative_blocks":[{"number":1,"category":"family","header":"Nephew died six weeks after son's birth, 1858","body":"His nephew Edward Hooker came to East Cambridge to study medicine after graduating Williams College in 1855, but died April 26, 1858 of disease contracted in hospital service — six weeks after Anson's youngest son Edward Dwight was born in the same East Cambridge household on March 17. The same spring brought both a birth and a death into the Hooker physician line."},{"number":2,"category":"politics","header":"Common Council to State House in one career","body":"Beyond his East Cambridge medical practice, Anson served successively on the Common Council, as Alderman, and as a Representative in the Massachusetts General Court — three ascending levels of civic office held while maintaining his practice from 1822 until his death in 1869. Harvard-trained physicians of his generation were expected to lead their communities as well as treat them."},{"number":3,"category":"legacy","header":"First of three consecutive Harvard physician generations, 1822","body":"Dr. Anson Hooker graduated Harvard Medical School in 1822 and built a Cambridge practice that his son Anson Parker inherited after Harvard M.D. 1855, and his grandson Edward Dwight carried on after Harvard M.D. 1884. Three consecutive Hooker physicians trained at Harvard across sixty-two years."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"anson-hooker-1799"},"H02760":{"id":"H02760","is_placeholder":false,"has_descendants_documented":true,"former_ids":[],"bio":{"display_name":"Anson Parker Hooker","first_name":"Anson","middle_name":"Parker","last_name":"Hooker","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779423301/1868_Anson_Parker_Hooker_Massachusetts_House_of_Representatives_r1wfpu.png","photo_notes":"Massachusetts House of Representatives photograph, 1868."},"gender":"male","birth":{"year":1829,"month":9,"day":2,"city":"East Cambridge","county":"Middlesex","state":"Massachusetts","country":"United States"},"death":{"year":1873,"month":12,"day":31,"city":"East Cambridge","county":"Middlesex","state":"Massachusetts","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"parents":{"father_id":"H01414","mother_id":"I01160"},"notable":{"is_notable":true,"notable_category":["military","politician"],"notable_blurb":"surgeon, 26th Massachusetts Infantry, Department of the Gulf","primary_url":"https://www.nejm.org/doi/abs/10.1056/NEJM187401080900210","primary_url_label":"Obituary, New England Journal of Medicine, January 8, 1874"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01166","date_year":1861,"date_month":9,"date_day":10,"location_state":"Massachusetts","location_country":"United States","end_type":"death","end_year":1873,"children_ids":["H04366","H04367","H04368"]}],"education":[{"institution_id":"INST002","dates":"graduated 1851","type":"undergraduate","notes":"Harvard College A.B. 1851 per EH 1909 #2760."},{"institution_id":"INST002","dates":"graduated 1855","type":"professional","notes":"Harvard Medical School M.D. 1855 per EH 1909 #2760."}],"career":[{"role":"Physician","location":"East Cambridge, Middlesex County, Massachusetts","start_year":1855,"end_year":1873,"notes":"Per EH: 'connected with his father in practice in East Cambridge, and after his father's death succeeded to a large practice.'"}],"military_service":[{"war":"American Civil War","war_id":"WAR006","rank":"Surgeon","unit":"26th Massachusetts Volunteers (Infantry)","notes":"Commissioned surgeon September 10, 1861. Served in Department of the Gulf (Ship Island, Mississippi, then New Orleans area following its capture April 1862). Resigned June 18, 1862 due to disability from exhausting tropical diseases. First of young surgeons to offer services to Governor John Andrew at the start of the war per NEJM obituary January 8, 1874. Returned to state service in charge of military camps, May 1863. Tribute from Surgeon General Dale at his passing."}],"institutions":[{"institution_id":"INST002","relationship":"alumnus","years":"A.B. 1851, M.D. 1855","institution_blurb":"Harvard College A.B. 1851 and Harvard Medical School M.D. 1855."}],"landmarks":[],"artworks":[],"tags":["physician","harvard_graduate","politician","civil_war"],"research_tags":[],"cross_connections":[{"type":"mentor_student","related_id":"H01414","display_label":"Father and East Cambridge physician partner before his death","link_text":"Dr. Anson Hooker"}],"narrative_blocks":[{"number":1,"category":"career","header":"Succeeded father's practice; died New Year's Eve 1873","body":"After Harvard College 1851 and Harvard Medical School 1855, Anson Parker joined his father Dr. Anson Hooker in practice at East Cambridge — the third consecutive Hooker physician in the Westhampton-to-Cambridge line. He died December 31, 1873 at forty-four, New Year's Eve, leaving a large practice he had held only since his father's 1869 death."},{"number":2,"category":"family","header":"One twin died; one outlived Cotton Mather's descendants","body":"On March 15, 1866, twin daughters Elizabeth Mather and Mary Marshall were born at East Cambridge; Mary Marshall died four days later. Elizabeth Mather survived and was identified by Edward Hooker in his 1909 genealogy as the last living descendant of Cotton Mather."},{"number":3,"category":"military","header":"First surgeon to volunteer; disability hastened death","body":"Anson Parker Hooker was the first of the young surgeons to offer his services to Governor John Andrew at the outbreak of the Civil War, receiving his commission to the 26th Massachusetts on September 10, 1861, and serving in the Department of the Gulf. Exhausting tropical diseases forced his resignation June 18, 1862 — and the resulting disability was cited in his New England Journal of Medicine obituary as having hastened his death at forty-four."}],"quotes":[],"documents":[],"naming_inspiration":[],"burial":{"cemetery_id":"CEM549"},"residence":{"city":"East Cambridge","county":"Middlesex","state":"Massachusetts","country":"United States"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 2760"}],"research_sources":[],"slug":"anson-hooker-1829"},"I01166":{"id":"I01166","is_placehold