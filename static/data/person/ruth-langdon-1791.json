rvoir","body":"Around 1870 Hoadley proposed damming a San Mateo County valley for a major reservoir, an idea later realized as Crystal Springs. His Bush Street house survives as a designated San Francisco landmark.","number":3},{"category":"family","header":"A clockmaker's son who surveyed the frontier","body":"Milo was the eldest son of the Connecticut clockmaker Silas Hoadley and left the family trade for engineering in Gold Rush California. He died in 1887 after being thrown from his buggy near Sonora.","number":4}],"sources":[],"institutions":[],"landmarks":[{"landmark_id":"LM127","landmark_blurb":"The Bush Street house he built in 1858, now a city landmark."}],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Milo","last_name":"Hoadley","display_name":"Milo Hoadley","gender":"male","bio_blurb":"First City Engineer of San Francisco"},"military_service":[],"career":[{"role":"City Engineer","organization":"City of San Francisco","start_year":1854,"end_year":1857},{"role":"Civil engineer and surveyor","organization":"Private practice, San Francisco","start_year":1849,"end_year":1887}],"birth":{"year":1809,"country":"United States","month":7,"day":25,"state":"Connecticut","city":"Plymouth"},"death":{"year":1887,"country":"United States","month":5,"day":19,"state":"California","city":"Sonora"},"burial":{"cemetery_id":"CEM267"},"education":[],"slug":"milo-hoadley-1809"},"HD5990":{"id":"HD5990","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":true,"is_easter_egg":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"generation_from_thomas":8},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I01618","mother_id":"HD5989"},"marriages":[],"tags":[],"narrative_blocks":[