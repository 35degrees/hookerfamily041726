ly","header":"Great-grandson of two Revolutionary patriots","body":"Tallmadge descended from the Declaration signer William Floyd and from Benjamin Tallmadge of the Culper Spy Ring. A New York lawyer, he belonged to the Union Club, the New-York Historical Society, and the Society of the Cincinnati.","number":2},{"category":"legacy","header":"He left the society his library and relics","body":"In his will Tallmadge gave the Sons of the Revolution his library and Revolutionary relics, among them Benjamin Tallmadge's handwritten memoir. A bronze tablet by Victor Brenner marks Fraunces Tavern as his memorial.","number":3}],"sources":[],"institutions":[],"landmarks":[{"landmark_id":"LM129","landmark_blurb":"The Revolutionary tavern his bequest rescued for the Sons of the Revolution."}],"artworks":[{"artwork_id":"ART080","role":"subject"}],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Frederick Samuel","last_name":"Tallmadge","display_name":"Frederick Samuel Tallmadge","gender":"male","bio_blurb":"Sons of the Revolution president; saved Fraunces Tavern","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780932054/Frederick-Samuel-Tallmadge-painting-McEntee_j610c8.webp"},"military_service":[],"career":[],"birth":{"year":1824,"country":"United States","month":1,"day":24,"city":"New York","state":"New York"},"death":{"year":1904,"country":"United States","month":6,"day":20,"city":"Litchfield","state":"Connecticut"},"burial":{"cemetery_id":"CEM749"},"education":[],"slug":"frederick-samuel-tallmadge-1824"},"I01626":{"id":"I01626","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"spouse