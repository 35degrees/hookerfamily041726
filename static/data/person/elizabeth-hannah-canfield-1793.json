e":false,"include_in_path_calculation":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["law"],"notable_blurb":"Eminent New York lawyer and legal codifier","primary_url":"https://en.wikipedia.org/wiki/William_Curtis_Noyes","primary_url_label":"Wikipedia"},"parents":{},"number_of_marriages":1,"marriages":[{"spouse_id":"HD6017","children_ids":["HD6027","HD6028","HD6029"],"marriage_number":1}],"tags":[],"narrative_blocks":[{"category":"law","header":"One of the New York bar's giants","body":"Noyes rose from district attorney of Oneida County to the front rank of the New York bar, prized for his cross-examination and equity practice. In 1857 he was named a commissioner to codify the laws of the state.","number":1},{"category":"legacy","header":"He left Hamilton College his law library","body":"Noyes assembled one of the finest law libraries in the country and bequeathed its five thousand volumes to Hamilton College, which had granted him an honorary LL.D. He had no college education himself.","number":2},{"category":"politics","header":"A Union man courted for the Senate","body":"A founder of the Union League and a peace-conference delegate in 1861, Noyes was a leading candidate that winter for a United States Senate seat. He declined politics for the law until his sudden death in 1864.","number":3}],"sources":[],"institutions":[],"landmarks":[{"landmark_id":"LM130","landmark_blurb":"The 1871 firehouse built on land he gave the village of Castleton-on-Hudson."}],"artworks":[{"artwork_id":"ART081","role":"subject"}],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"William Curtis","last_name":"Noyes","display_name":"William Curtis Noyes","gender":"male","bio_blurb":"Eminent New York lawyer and legal codifier","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780932586/W_Curtis_Noyes_bpobc8.jpg"},"military_service":[],"career":[],"birth":{"year":1805,"country":"United States","month":8,"day":19,"city":"Schodack","state":"New York"},"death":{"year":1864,"country":"United States","month":12,"day":25,"city":"New York","state":"New York"},"burial":{"cemetery_id":"CEM753"},"education":[],"slug":"william-curtis-noyes-1805"},"HD6027":{"id":"HD6027","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":true,"is_easter_egg":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"generation_from_thomas":9},"notable":{"is_notable":true,"notable_category":["arts"],"notable_blurb":"Painter, author, and Litchfield historian","primary_url":"https://en.wikipedia.org/wiki/Emily_Noyes_Vanderpoel","primary_url_label":"Wikipedia"},"parents":{"father_id":"I01625","mother_id":"HD6017"},"number_of_marriages":1,"marriages":[{"spouse_id":"I01627","children_ids":["HD6030"],"marriage_number":1}],"tags":["artist","author","extraordinary_longevity","painter"],"narrative_blocks":[{"category":"arts","header":"Artist and chronicler of a pioneer school","body":"Emily Noyes Vanderpoel was a painter and writer whose 1903 'Chronicles of a Pioneer School' preserved the history of Litchfield's Female Academy. She also published an influential study of color in design.","number":1},{"category":"arts","header":"Her Color Problems anticipated modern abstraction","body":"Vanderpoel's 1902 'Color Problems' translated color theory into hundred-square grids sampling everything from mummy cases to butterfly wings. Long overlooked, the book is now read as anticipating Klee, Albers, and Rothko by decades.","number":2},{"category":"social_reform","header":"She remade Litchfield in Colonial Revival","body":"As curator of the Litchfield Historical Society, Vanderpoel drove the town's Colonial Revival, behind the restorations of the Congregational Church and the Litchfield Law School. She also helped found the local DAR chapter named for her great-grandmother Mary Floyd Tallmadge.","number":3},{"category":"legacy","header":"She finished her son's gift to Litchfield","body":"When her son John Arent died with his library building unfinished, Emily completed the project and set a memorial tablet to him beneath its Palladian window. The building honored her mother, Julia Tallmadge Noyes.","number":4}],"sources":[],"institutions":[],"landmarks":[],"artworks":[{"artwork_id":"ART082","role":"creator"}],"research_tags":[],"cross_connections":[{"type":"family_orbit","related_id":"X03136","display_label":"her father-in-law, Congressman Aaron Vanderpoel"},{"type":"parallel_careers","related_id":"HD3004","display_label":"led Hartford's preservation as Vanderpoel did Litchfield's"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Emily Caroline","last_name":"Noyes","display_name":"Emily Caroline Noyes Vanderpoel","gender":"female","married_names":["Vanderpoel"],"maiden_name":"Noyes","bio_blurb":"Artist and author of \"Chronicles of a Pioneer School\"","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780940427/Photo_of_Emily_Noyes_Vanderpoel_excifx.jpg"},"military_service":[],"career":[],"birth":{"year":1842,"country":"United States","city":"New York","state":"New York"},"death":{"year":1939,"country":"United States","city":"New York","state":"New York"},"burial":{"cemetery_id":"CEM749"},"education":[],"slug":"emily-caroline-noyes-1842"},"HD6028":{"id":"HD6028","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":true,"is_easter_egg":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"generation_from_thomas":9},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I01625","mother_id":"HD6017"},"marr