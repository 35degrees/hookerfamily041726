ing_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"george-packard-jr-1904"},"H02745":{"id":"H02745","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1832,"month":8,"day":15,"city":"Philadelphia","state":"Pennsylvania"},"parents":{"mother_id":"H01403","father_research_notes":"Frederic Adolphus Packard","father_id":"X00161"},"tags":["physician","civil_war","author","pennsylvania_migration"],"sources":[],"death":{"year":1907,"month":5,"day":20,"city":"Atlantic City","state":"New Jersey","cause":"Cardiorenal failure (heart disease)"},"marriages":[{"spouse_id":"X00162","children_ids":["H04333","H04334","H04335","H04336","H04337","H04338"],"marriage_number":1,"date_year":1858,"date_month":6,"date_day":3}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["medicine"],"notable_blurb":"pioneer of modern American surgery","primary_url":"https://www.medicalantiques.com/civilwar/Medical_Authors_Faculty/Packard_John_H..htm","primary_url_label":"Dr. Echols & Dr. Arbittier — John H. Packard, M.D."},"cross_connections":[],"bio":{"display_name":"Dr. John Hooker Packard","first_name":"John","last_name":"Packard","middle_name":"Hooker","title":"Doctor","married_names":[],"gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779146282/johnhookerpackard_kbbw52.jpg","photo_notes":"Portrait photograph reproduced in Anesthesiology journal, Nov 2001 (Defalque, Panning, Wright)."},"residence":{"city":"Philadelphia","county":"Philadelphia","state":"Pennsylvania","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST143","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["HD0621"],"burial":{"cemetery_id":"CEM529","plot_notes":"Old Saint David's Church Cemetery, Wayne, Delaware County, PA"},"education":[{"school_name":"University of Pennsylvania","institution_id":"INST143","degree_or_field":"A.B. 1850; M.D. 1853","class_year":1853,"notes":"A.B. 1850, M.D. 1853. Resident physician at Philadelphia's University Hospital for 18 months after graduation; then 1.5 years visiting the great Paris hospitals before returning to Philadelphia practice."}],"career":[{"role":"Surgeon","organization":"Christian Street U.S. Army Hospital","location":"Philadelphia, PA","start_year":1862,"end_year":1865,"notes":"Acting assistant surgeon at Christian Street and Satterlee Union Army hospitals during the Civil War."},{"role":"Consulting surgeon","organization":"U.S. Army hospitals at Beverly NJ and Haddington PA","location":"PA / NJ","start_year":1862,"end_year":1865},{"role":"Surgeon","organization":"Episcopal Hospital","location":"Philadelphia, PA","start_year":1863,"end_year":1884},{"role":"Surgeon","organization":"Pennsylvania Hospital","location":"Philadelphia, PA","start_year":1884,"end_year":1896,"notes":"Surgeon to Pennsylvania Hospital from 1884 until his 1896 retirement following septicemia from a finger infection caught during surgery."},{"role":"Secretary then Vice President","organization":"College of Physicians of Philadelphia","location":"Philadelphia, PA","start_year":1862,"end_year":1896,"notes":"Secretary 1862-1877; Vice President from 1886."}],"narrative_blocks":[{"number":1,"category":"innovation","header":"Switched American surgeons from chloroform to ether","body":"In May 1865 he reported to the Philadelphia College of Physicians that after witnessing fatal chloroform accidents in his own and his colleagues' practices, he was switching to ether. Following his friend F. D."},{"number":2,"category":"publication","header":"Manual of Minor Surgery adopted by US Army","body":"His 1863 Manual of Minor Surgery — a working guide to bandaging, pain control, and field operations — was adopted by the United States Army and became one of the most reprinted surgical handbooks of the Civil War era. The Handbook of Operative Surgery followed in 1870."},{"number":3,"category":"war","header":"Civil War surgeon at Christian Street and Satterlee","body":"He served as acting assistant surgeon at Philadelphia's Christian Street and Satterlee U.S. Army hospitals throughout the Civil War. One soldier whose arm Packard rebuilt — Martin V.B. Keller — wrote afterward that the surgeon was 'very proud of the operation' and had photographs taken of the recovered arm."},{"number":4,"category":"death","header":"Septic finger ended career, 1896 retirement","body":"A finger infection caught during surgery in 1896 led to septicemia and forced his retirement at sixty-four after forty-three years of practice. He died of cardiorenal failure at the Hotel Chalfont in Atlantic City on 21 May 1907 and was buried at Old Saint David's Church Cemetery in Wayne, PA."},{"number":5,"category":"publication","header":"Sea-Air therapy book established resort medicine","body":"His 1880 book Sea-Air and Sea-Bathing was among the first American medical works to argue systematically that coastal air and bathing could benefit specific patient categories. The treatise helped establish the Atlantic City and Cape May resort culture that would shape East Coast medicine for a generation."}],"slug":"john-packard-1832"},"X00162":{"id":"X00162","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1835,"month":5,"day":2,"city":"Philadelphia","county":"Philadelphia","state":"Pennsylvania","country":"United States"},"death":{"year":1897,"month":3,"day":11,"city":"Devon","county":"Chester","state":"Pennsylvania","country":"United States"},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H02745","date_year":1858,"date_month":6,"date_day":3,"end_type":"death_of_self","end_year":1897,"children_ids":["H04333","H04334","H04335","H04336","H04337","H04338"]}],"parents":{"father_name":"Charles Stuart Wood of Philadelphia (Quaker)","mother_name":"Juliana Fitz Randolph Wood (Quaker)"},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Wood Packard","first_name":"Elizabeth","maiden_name":"Wood","married_names":["Packard"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elizabeth-wood-1835"},"X00161":{"id":"X00161","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"tags":["lawyer","author","harvard_graduate","massachusetts_migration","pennsylvania_migration"],"sources":[],"birth":{"year":1794,"month":9,"day":25,"city":"Marlborough","county":"Middlesex","state":"Massachusetts","country":"United States"},"death":{"year":1867,"month":11,"day":11,"city":"Philadelphia","county":"Philadelphia","state":"Pennsylvania","country":"United States"},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01403","date_year":1822,"date_month":5,"date_day":15,"location_city":"Springfield","location_county":"Hampden","location_state":"Massachusetts","location_country":"United States","end_type":"death_of_spouse","end_year":1862,"children_ids":["H02742","H02743","H02744","H02745","H02746"]}],"parents":{"father_name":"Rev. Asa Packard, pastor of Congregational church in Marlborough MA; descendant of Samuel Packard, founder of Bridgewater","mother_name":"Ann (Quincy) Packard"},"notable":{"is_notable":true,"notable_category":["education","religion"],"notable_blurb":"American Sunday School Union editor of 2,000 publications"},"cross_connections":[],"bio":{"display_name":"Rev. Frederic Adolphus Packard","first_name":"Frederic","last_name":"Packard","middle_name":"Adolphus","title":"Reverend","married_names":[],"gender":"male"},"residence":{"city":"Philadelphia","county":"Philadelphia","state":"Pennsylvania","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","institution_blurb":"Harvard College, A.B. 1814. Studied law at Northampton after graduation.","relationship":"alumnus","years":"1814"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM413","plot_notes":"Springfield Cemetery, with wife Elizabeth Dwight Hooker Packard"},"education":[{"school_name":"Harvard College","institution_id":"INST002","degree_or_field":"A.B.","class_year":1814,"notes":"Harvard 1814. Studied law at Northampton after graduation; practiced at Springfield 1817-1829."}],"career":[{"role":"Lawyer","location":"Springfield, MA","start_year":1817,"end_year":1829,"notes":"Practiced law at Springfield, Massachusetts."},{"role":"Editor","organization":"Hampden Federalist (newspaper)","location":"Springfield, MA","start_year":1817,"end_year":1827,"notes":"Edited the Federalist newspaper for approximately 10 years."},{"role":"Member of legislature","organization":"Massachusetts General Court","location":"Boston, MA","start_year":1828,"end_year":1829},{"role":"Editor","organization":"American Sunday School Union","location":"Philadelphia, PA","start_year":1829,"end_year":1867,"notes":"Edited all 2,000 publications of the ASS Union; wrote or compiled 40+ himself. Edited the Sunday-School Magazine, Sunday-School Journal, and Youth's Penny Gazette (renamed the Child's World). Edited 11 volumes of the Philadelphia Journal of Prison Discipline."}],"narrative_blocks":[{"number":1,"category":"career","header":"Edited Hampden Federalist in Springfield, 1817-1827","body":"After Harvard 1814 he studied law at Northampton and practiced at Springfield, MA from 1817 to 1829. For ten of those years he edited the Hampden Federalist newspaper alongside his law practice."},{"number":2,"category":"career","header":"Edited 2,000 Sunday School Union publications","body":"From 1829 until his death in 1867 he edited the publications of the American Sunday School Union — 2,000 titles in all, more than forty of which he wrote or compiled himself. He prepared the Society's annual reports and contributed regularly to its Magazine, Journal, and Penny Gazette."},{"number":3,"category":"innovation","header":"Projected the first child's newspaper in America","body":"He projected the Youth's Penny Gazette (later renamed the Child's World), by his own description the first newspaper in the United States designed specifically for children. The paper ran weekly through the American Sunday School Union network."},{"number":4,"category":"career","header":"Declined Girard College presidency, July 1849","body":"In July 1849 he was elected president of Girard College in Philadelphia — a then-new and well-endowed institution founded for poor white orphan boys — and declined. He preferred to continue his publishing work and education advocacy from his Philadelphia perch."},{"number":5,"category":"civic","header":"Mass. legislature 1828-29 between Springfield careers","body":"He served as a member of the Massachusetts legislature in 1828-29, his last public role in the state before removing to Philadelphia. The legislative session preceded his elevation to American Sunday School Union editorship by a single year."}],"slug":"frederic-packard-1794"},"H01403":{"id":"H01403","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1798,"month":2,"day":16,"city":"Springfield","state":"Massachusetts"},"parents":{"father_id":"H00527","mother_id":"X00227"},"tags":[],"sources":[],"death":{"year":1862,"month":7,"day":5,"city":"Philadelphia","county":"Philadelphia","state":"Pennsylvania","country":"United States"},"marriages":[{"children_ids":["H02742","H02743","H02744","H02745","H02746"],"spouse_id":"X00161","marriage_number":1,"date_year":1822,"date_month":5,"date_day":15,"location_city":"Springfield","location_state":"Massachusetts","end_type":"death_of_self","end_year":1862}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Dwight Hooker Packard","first_name":"Elizabeth","middle_name":"Dwight","maiden_name":"Hooker","married_names":["Packard"],"gender":"female"},"residence":{"city":"Philadelphia","county":"Philadelphia","state":"Pennsylvania","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["HD0618"],"burial":{"cemetery_id":"CEM413","plot_notes":"Returned to Springfield Cemetery, beside her parents Judge John and Sarah Dwight Hooker"},"narrative_blocks":[{"number":1,"category":"marriage","header":"Married Frederic Packard in Springfield, 1822","body":"On 15 May 1822 she married Frederic Adolphus Packard, a Harvard 1814 graduate then editing the Hampden Federalist in Springfield. The couple moved to Philadelphia in 1829 when he became editor of American Sunday School Union publications, ultimately producing 2,000 titles including the first child's newspaper in the United States."},{"number":2,"category":"family","header":"Bore five Packard children; two died young","body":"Five children followed between 1827 and 1836: John Hooker Packard 1st (H02742, died on his second birthday); Frederick Jr. (H02743, lawyer Appleton WI); Mary Hooker (H02744, married Samuel Clarke Perkins of Skull and Bones); Dr. John Hooker Packard (H02745, the eminent Philadelphia surgeon); and Lewis Richard (H02746, Yale Hillhouse Professor of Greek). The eldest two were buried back in Springfield with the Hooker grandparents."},{"number":3,"category":"death","header":"Died Philadelphia 1862, returned to Springfield","body":"She died 5 July 1862 in Philadelphia at age 64, where she had lived since 1829. Her body was returned to Springfield Cemetery to lie beside her father Judge John and her Hooker grandparents — five years before her husband Frederic would join them in 1867."}],"slug":"elizabeth-packard-1798"}},"burialCemetery":{"id":"CEM529","former_ids":[],"primary_name":"Old Saint David's Church Cemetery","city":"Wayne","county":"Delaware","state":"Pennsylvania","country":"United States","primary_url":"https://www.findagrave.com/cemetery/805823/old-saint-davids-church-cemetery","primary_url_label":"FindAGrave — Old Saint David's Church Cemetery","hooker_connections":["H02745","H04337","I01095","H04335","I01091","H04336","I01092","H05233","I01097","HD04868","HD4804","H04338","I01093"],"notes":"Episcopal churchyard in Wayne, Delaware County PA — burial site of Dr. John Hooker Packard (H02745) and his son Dr. Francis Randolph Packard (H04337)."},"institutionsById":{},"crossConnections":[]}