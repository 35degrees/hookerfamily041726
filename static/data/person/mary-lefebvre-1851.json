research_sources":[],"documents":[],"slug":"lila-willingham-1874"},"I00718":{"id":"I00718","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"John","middle_name":"Skelton","last_name":"Williams","suffix":"Sr.","married_names":[],"gender":"male","display_name":"John Skelton Williams Sr.","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778795432/johnskeltonwillimas_xtodqs.png","photo_notes":"Portrait of John Skelton Williams Sr., US Comptroller of Currency"},"birth":{"year":1865,"month":7,"day":6,"city":"Paxton","county":"Powhatan County","state":"Virginia","country":"United States"},"baptism":{},"death":{"year":1926,"month":11,"day":4,"city":"Richmond","county":"City of Richmond","state":"Virginia","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM142","plot_notes":"FindAGrave #10866484."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["politics","business","banking"],"notable_blurb":"US Comptroller of Currency 1914-1921","primary_url":"https://en.wikipedia.org/wiki/John_Skelton_Williams","primary_url_label":"Wikipedia — John Skelton Williams"},"parents":{"father_name":"John Langbourne Williams","mother_name":"Maria Ward (Skelton) Williams"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4371","date_year":1895,"location_state":"Virginia","location_country":"United States","end_type":"death","end_year":1926,"children_ids":["HD4373","HD4374"]}],"education":[{"school_name":"University of Virginia","type":"undergraduate","notes":"Educated at Richmond VA and Univ. of Virginia."}],"career":[{"role":"President and organizer","organization":"Seaboard Air Line Railway","start_year":1900,"end_year":1903,"notes":"Organized railroad into single company; first president."},{"role":"First Assistant Secretary of the Treasury","organization":"U.S. Treasury","start_year":1913,"end_year":1914,"notes":"One of first acts: ordered segregation of Bureau of Engraving and Printing work areas."},{"role":"Comptroller of the Currency (13th)","organization":"U.S. Government","start_year":1914,"end_year":1921,"notes":"Ex officio member of original Federal Reserve Board. Appointed by Woodrow Wilson. Reappointed 1919 despite controversy. Resigned Mar 2, 1921."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["banker","federal_reserve","politician","moral_complexity"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Organized Seaboard Air Line; then became Comptroller","body":"Williams organized the Seaboard Air Line into a single railway company and served as its first president from 1900 to 1903, establishing his reputation as a leading Southern financier. President Woodrow Wilson appointed him Comptroller of the Currency in 1914, making him an ex officio member of the newly created Federal Reserve Board."},{"number":2,"category":"legacy","header":"Ordered Treasury segregation; later attacked the Federal Reserve","body":"Among his first acts as Assistant Secretary of the Treasury was ordering the segregation of work areas at the Bureau of Engraving and Printing and ending promotions for Black workers. After resigning as Comptroller in 1921, he became an outspoken critic of the Federal Reserve, charging deliberate deflation against farmers — prompting Congress to form a joint investigative committee."},{"number":3,"category":"career","header":"1920 report exposed insider manipulation of call-money rates","body":"On July 31, 1920, Williams released a detailed public report showing how call-money interest rates were manipulated by insider speculators to the disadvantage of ordinary borrowers nationwide. The statement was published verbatim in a subsequent book, and Williams's aggressive oversight as Comptroller kept him in repeated conflict with the Federal Reserve's leadership."}],"quotes":[],"sources":[{"label":"Wikipedia — John Skelton Williams","url":"https://en.wikipedia.org/wiki/John_Skelton_Williams"},{"label":"Federal Reserve History — John Skelton Williams","url":"https://www.federalreservehistory.org/people/john-skelton-williams"}],"research_sources":[],"documents":[],"slug":"john-williams-sr-1865"},"I00719":{"id":"I00719","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"William","middle_name":"Allen","last_name":"Willingham","married_names":[],"gender":"male","display_name":"William Allen Willingham"},"birth":{"year":1872},"baptism":{},"death":{"year":1945},"residence":{},"burial":{"cemetery_id":"CEM142","plot_notes":"FindAGrave #93685835."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4371","date_year":1938,"location_country":"United States","children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"william-willingham-1872"},"HD4373":{"id":"HD4373","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"John","middle_name":"Skelton","last_name":"Williams","suffix":"Jr.","married_names":[],"gender":"male","display_name":"John Skelton Williams Jr."},"birth":{"year":18