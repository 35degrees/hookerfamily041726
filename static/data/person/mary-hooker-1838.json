older":false,"has_descendants_documented":true,"bio":{"first_name":"Edward","last_name":"Hooker","married_names":[],"gender":"male","display_name":"Edward Hooker"},"gender":"male","birth":{"year":1802,"month":3,"day":20,"city":"Westhampton","county":"Hampshire","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1841,"month":8,"day":1,"city":"Cleveland","county":"Cuyahoga","state":"Ohio","country":"United States"},"residence":{"city":"Cleveland","county":"Cuyahoga","state":"Ohio","country":"United States"},"burial":{"cemetery_id":"CEM550"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H00529","mother_id":"I01155"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01162","date_year":1834,"date_month":5,"date_day":8,"location_city":"South Hadley","location_county":"Hampshire","location_state":"Massachusetts","location_country":"United States","end_type":"death","end_year":1841,"children_ids":["H02763","H02764"]}],"education":[{"institution_id":"INST043","dates":"graduated 1820","type":"undergraduate","notes":"A.B. Williams College 1820 per EH 1909 #1415."}],"career":[{"role":"Lawyer","location":"Ravenna, Portage County, Ohio","notes":"First law practice after Williams College 1820."},{"role":"Lawyer","location":"South Hadley, Hampshire County, Massachusetts","end_year":1835,"notes":"Returned to Massachusetts; practiced law at South Hadley. Met and married Mary Ann Dwight here 1834."},{"role":"Lawyer / Commercial Partner","organization":"D.H. Lamb & Co.","location":"Cleveland, Cuyahoga County, Ohio","start_year":1835,"end_year":1841,"notes":"Per obituary: 'lawyery at D.H. Lamb & Co.' EH 1909 says 'engaged in soda manufacture' — D.H. Lamb & Co. may have been the soda manufacturing enterprise for which Edward served as legal counsel and commercial partner. Removed from Rochester NY to Cleveland 1835; remained until his death August 1, 1841 at thirty-nine."}],"military_service":[],"institutions":[{"institution_id":"INST043","relationship":"alumnus","years":"graduated 1820","institution_blurb":"Graduated Williams College 1820."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["lawyer","ohio_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died at thirty-nine; wife outlived him fifty years","body":"Edward left West Hampton MA as a Williams College graduate, practiced law in Ohio and Massachusetts, then pivoted to soda manufacturing in Cleveland — dying there August 1, 1841 at only thirty-nine, leaving two children under age seven. His wife Mary Ann Dwight survived him until June 4, 1891, outliving him by exactly fifty years."},{"number":2,"category":"character","header":"Became, late in life, a man of prayer","body":"The obituary that marked Edward's death at thirty-nine focused less on his law practice at D.H. Lamb & Co. than on the man he had become: late in life he united with the Congregational Church in Ohio City and was remembered by those who knew him simply as 'a man of prayer.' For a direct descendant of Rev. Thomas Hooker — who helped establish the Congregational tradition in Connecticut two centuries earlier — the phrase carried the full weight of inheritance."},{"number":3,"category":"career","header":"Williams 1820; youngest son of a man who","body":"Edward Hooker graduated Williams College in 1820 and practiced law at Ravenna Ohio, then South Hadley Massachusetts, before settling in Cleveland with D.H. Lamb & Co. He was the youngest son of Dr. William Hooker of Westhampton, who lived to ninety-four — Edward died at thirty-nine."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"edward-hooker-1802"},"I01162":{"id":"I01162","is_placeholder":false,"former_ids":[],"bio":{"display_name":"Mary Ann Dwight Hooker","first_name":"Mary Ann","last_name":"Hooker","maiden_name":"Dwight","married_names":["Hooker"]},"gender":"female","birth":{"year":1810,"month":9,"day":12,"city":"South Hadley","county":"Hampshire","state":"Massachusetts","country":"United States"},"death":{"year":1891,"month":6,"day":4,"city":"South Hadley","county":"Hampshire","state":"Massachusetts","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"is_easter_egg":false},"parents":{"father_research_notes":"Elihu Dwight MD of South Hadley MA per EH 1909 #1415.","mother_research_notes":"Lydia (White) Dwight per EH 1909 #1415."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01415","date_year":1834,"location_state":"Massachusetts","location_country":"United States","end_type":"death","children_ids":["H02763","H02764"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"documents":[],"naming_inspiration":[],"burial":{},"residence":{"state":"Massachusetts","country":"United States"},"notable":{"is_notable":false,"notable_category":[]},"sources":[{"short":"Edward Hooker 1909","page":"Entry 1415"}],"research_sources":[],"slug":"mary-ann-dwight-1810"},"H00529":{"id":"H00529","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1766,"month":11,"day":26,"city":"Northampton","state":"Massachusetts","county":"Hampshire","country":"United States"},"death":{"year":1861,"month":2,"day":27,"city":"Westhampton","county":"Hampshire","state":"Massachusetts","country":"United States"},"parents":{"father_id":"H00264","mother_id":"I00043"},"tags":["extraordinary_longevity","physician"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 529"}],"gender":"male","number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"I01155","date_year":1788,"location_country":"United States","end_type":"death_of_spouse","end_year":1810,"children_ids":["H01409","H01410","H01411","H01412","H01413","H01414","H01415"]},{"marriage_number":2,"spouse_id":"I01156","date_year":1812,"location_country":"United States","end_type":"death_of_spouse","end_year":1847,"children_ids":[]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Dr. William Hooker","first_name":"William","last_name":"Hooker","title":"Dr.","married_names":[]},"residence":{"city":"Westhampton","county":"Hampshire","state":"Massachusetts","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"is_placeholder":false,"burial":{"cemetery_id":"CEM544"},"education":[],"career":[{"role":"Physician","location":"Westhampton, Hampshire County, Massachusetts","notes":"Practiced medicine at Westhampton MA per EH 1909 #529. Established the Hooker physician tradition in Westhampton continued by son Dr. Anson Hooker (H01414, 1799-1869) and through several Westhampton descendants."},{"role":"Trader / Merchant","location":"Westhampton, Hampshire County, Massachusetts","notes":"Per EH 1909 #529: 'He was a physician and also a trader at West Hampton, Mass.' — supplementing physician income with a trading operation, common pattern for rural New England doctors of the period."}],"narrative_blocks":[{"number":1,"category":"career","header":"Lived to ninety-four as Westhampton physician","body":"Born Northampton MA 1766; died Westhampton MA February 27, 1861 at age ninety-four — extraordinary longevity spanning the early Republic through the Civil War's outbreak. Practiced medicine in Westhampton MA and also operated as a trader; both occupations supported a large family of seven children with first wife Anna Thompson before her 1810 death."},{"number":2,"category":"family","header":"Lost wife at forty-two, remarried after two years","body":"First wife Anna Thompson died Westhampton April 2, 1810 at age forty-two — leaving him with seven children ranging from twenty-four-year-old Henry down to eight-year-old Edward. William remarried 1812 to Rhoda Phelps, widow of Ensign Hartland of Hartland Connecticut. No documented children from the second marriage; Rhoda predeceased William by fourteen years."}],"former_ids":[],"slug":"william-hooker-1766"},"I01155":{"id":"I01155","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Anna","last_name":"Hooker","maiden_name":"Thompson","married_names":["Hooker"],"gender":"female","display_name":"Anna Thompson Hooker"},"gender":"female","birth":{"year":1768,"month":2,"day":25,"county":"Hartford","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1810,"month":4,"day":2,"city":"Westhampton","county":"Hampshire","state":"Massachusetts","country":"United States"},"residence":{"city":"Westhampton","county":"Hampshire","state":"Massachusetts","country":"United States"},"burial":{"cemetery_id":"CEM544"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Hugh Thompson of East Windsor CT (per EH 1909 #529)","father_research_notes":"Per Edward Hooker 1909 #529: 'm. 1798 [sic — likely 1788], Anna Thompson, daughter of Hugh Thompson of East Windsor, Conn.' EH date '1798' may be transcription error; her 1786 first child suggests marriage 1785-86. Hugh Thompson East Windsor specific parentage not yet built."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00529","date_year":1788,"location_country":"United States","end_type":"death","end_year":1810,"children_ids":["H01409","H01410","H01411","H01412","H01413","H01414","H01415"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"tragedy","header":"Died age forty-two leaving seven children","body":"Died Westhampton MA April 2, 1810 at age forty-two — leaving seven children ranging from twenty-four-year-old Henry down to eight-year-old Edward. Her son middle-named for her father Hugh Thompson (Hugh Thompson Hooker, born 1789) carries the East Windsor Connecticut Thompson family name forward."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"anna-thompson-1768"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}