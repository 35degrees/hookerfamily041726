,"state":"Connecticut","country":"United States"},"death":{"year":1776,"month":6,"day":18,"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM014"},"parents":{"father_id":"X00126","mother_id":"H00034"},"marriages":[{"spouse_id":"I00142","children_ids":[],"marriage_number":1,"end_type":"death_of_spouse","end_year":1753,"date_year":1727,"date_month":11,"date_day":1,"location_country":"United States","location_city":"Boston","location_state":"Massachusetts"},{"spouse_id":"I00143","children_ids":["H00351","H00352","H00353","H00354","H00355"],"marriage_number":2,"date_year":1754,"date_month":3,"date_day":28,"location_country":"United States"}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 116"},{"short":"Dexter, Biographical Sketches Yale 1885","page":"Vol.1 p.189"},{"short":"Moffat, Pierrepont Genealogies 1913","page":"38"},{"short":"Yale Archives","url":"https://archives.yale.edu/agents/people/22447"}],"cross_connections":[],"gender":"male","tags":["yale_tutor","yale_graduate"],"number_of_marriages":2,"notable":{"is_notable":true,"notable_category":["education"],"notable_blurb":"Son of Yale's founding trustee; Yale tutor 1722-24","primary_url":"https://archives.yale.edu/agents/people/22447","primary_url_label":"Yale Archives"},"narrative_blocks":[{"number":1,"category":"career","header":"Yale tutor 1722-24 — then apothecary","body":"He graduated from Yale in 1718 and served as a tutor there 1722-24. He then established himself as an apothecary in Boston, continuing the business until his second marriage in 1754, when he moved to New Haven and carried on the same trade there until his death in 1776."},{"number":2,"category":"family","header":"His three eldest sons all married sisters","body":"The eldest three sons — Evelyn, Robert, and James — all married sisters, daughters of Charles Collins of Litchfield. The Collins sisters were daughters of Charles Collins of Litchfield."},{"number":3,"category":"character","header":"Whitefield preached under his elm tree — twice","body":"Rev. George Whitefield was twice the guest of James Pierpont — in October 1740 and again in 1745. On the latter occasion \"he preached to an immense audience from a platform under the Elm tree, in front of Mr. Pierpont's house.\" (Pierpont occupied his father's residence at Elm and Temple Streets, New"},{"number":4,"category":"character","header":"Spent his last years chasing an English inheritance","body":"The last years of his life were clouded by vain efforts to obtain recognition as the rightful heir to the titles and estates of the Pierrepont family in England. (His son Evelyn carried this further — His son Evelyn pursued this claim further."},{"number":5,"category":"family","header":"Sister married Edwards — the Aaron Burr legacy","body":"His sister Sarah Pierpont Edwards married Jonathan Edwards, the Great Awakening theologian. Their daughter Esther married Rev. Aaron Burr Sr., and their son Aaron Burr became the 3rd Vice President of the United States and killed Alexander Hamilton in a duel in 1804. The Pierpont siblings split into two of the most consequential American lineages."}],"education":[{"notes":"Tutor at Yale 1722-1724","school_name":"Yale College","graduation_year":1718,"institution_id":"INST022"}],"bio":{"display_name":"James Pierpont","first_name":"James","last_name":"Pierpont","married_names":[],"bio_blurb":"Yale tutor, then apothecary in Boston and New Haven"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1718"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Tutor","organization":"Yale College","start_year":1722,"end_year":1724},{"role":"Apothecary","location":"Boston","start_year":1727,"end_year":1754},{"role":"Apothecary","location":"New Haven","start_year":1754,"end_year":1776,"notes":"Occupied his father’s residence at Elm and Temple Streets."}],"slug":"james-pierpont-1699"},"I00143":{"id":"I00143","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1728,"month":1,"day":1,"city":"New Haven","state":"Connecticut"},"death":{"year":1803,"city":"New Haven","state":"Connecticut"},"parents":{"mother_research_notes":"Unknown Callone Sherman","father_research_notes":"Jabez Sherman of New Haven"},"marriages":[{"spouse_id":"H00116","children_ids":["H00351","H00352","H00353","H00354","H00355"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 116"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Anna Sherman Pierpont","notes":"Also given as Ann Sherman Davenport — widow of a Davenport at time of marriage","first_name":"Anna","last_name":"Pierpont","married_names":["Pierpont"],"maiden_name":"Sherman"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"anna-sherman-1728"},"X00126":{"id":"X00126","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1659,"month":1,"day":4,"city":"Roxbury","county":"Suffolk","state":"Massachusetts","country":"United States"},"death":{"year":1714,"month":11,"day":22,"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States"},"marriages":[{"children_ids":[],"spouse_id":"X01868","marriage_number":1,"date_year":1691,"date_month":10,"date_day":27,"location_city":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1692},{"children_ids":["X03177"],"spouse_id":"X01869","marriage_number":2},{"spouse_id":"H00034","children_ids":["H00116","HD0414","H00118","HD0416","HD1322","HD0417","HD0418","HD0419"],"marriage_number":3,"date_year":1698,"date_month":7,"date_day":26,"location_city":"Farmington","location_state":"Connecticut","location_country":"United States"}],"sources":[{"short":"Edward Hooker 1909"}],"gender":"male","parents":{"father_id":"X03175","mother_id":"X03176"},"tags":["yale_connection","minister","great_migration","yale_founder","yale_trustee","harvard_graduate"],"number_of_marriages":3,"notable":{"is_notable":true,"notable_category":["religion","education"],"notable_blurb":"Co-founder of Yale University, 1701","primary_url":"https://en.wikipedia.org/wiki/James_Pierpont_(minister)","primary_url_label":"Wikipedia"},"cross_connections":[{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X01001","link_text":"Rev. Thomas Buckingham"},{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"I00137","link_text":"Rev. John Hart"},{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X01929","link_text":"Rev. Thomas Ruggles"},{"type":"civic_connection","related_id":"X02127","display_label":"Both founding trustees of Yale 1701; Pierson was first rector.","link_text":"Rev. Abraham Pierson Jr."},{"type":"civic_peer","related_id":"X02123","display_label":"Pierpont built the institution Davenport had envisioned.","link_text":"Rev. John Davenport"},{"type":"parallel_careers","related_id":"HD1395","display_label":"Descendant co-founded Skull and Bones at his Yale 130 years later.","link_text":"William Huntington Russell"},{"type":"historical_connection","related_id":"HD5928","display_label":"coined the Ivy League name for colleges like Yale"},{"type":"parallel_careers","related_id":"X01015","link_text":"Rev. Stephen Buckingham","display_label":"his brother-in-law, a fellow Yale founder married to a Hooker sister"}],"institutions":[{"institution_id":"INST022","institution_blurb":"Founding trustee Oct 16, 1701 — until death 1714.","relationship":"founder"},{"institution_id":"INST002","institution_blurb":"Harvard College class of 1681."},{"institution_id":"INST073","institution_blurb":"Attended Roxbury Latin School before Harvard."}],"artworks":[{"artwork_id":"ART039","artwork_blurb":"Portrait 1711 by Pierpont Limner; Yale University Art Gallery."}],"narrative_blocks":[{"number":1,"category":"career","header":"Ten ministers, forty books, one college","body":"In 1700 Pierpont gathered ten ministers at Branford, each laying down volumes with the words “I give these books for the founding of a College in this Colony” — tradition credits James with six of the original forty. The charter he secured the next year became Yale."},{"number":2,"category":"family","header":"Two elms planted at the minister’s door","body":"A poor farmer with nothing else to give carried two young elms on his shoulder and planted them before the new parsonage in 1686. Under their shade Jonathan Edwards courted Sarah Pierpont forty years on, and Whitefield preached at sixty. When the last elm finally came down, its sound trunk was sawed into blocks and scattered among the family."},{"number":3,"category":"family","header":"Three brides in seven years","body":"James buried two young wives in five years — Abigail, dead of a cold caught attending church in her wedding garments per the custom of the day, and Sarah, lost after childbirth. In 1698 he married Mary Hooker of Farmington, who bore eight children and outlived him by twenty-six years."},{"number":4,"category":"religion","header":"He drafted Connecticut’s church constitution","body":"A leader of the 1708 Saybrook Synod, Pierpont is said to have drawn up the Articles of the Saybrook Platform — the system of discipline and fellowship that governed Connecticut’s churches for more than a century."},{"number":5,"category":"religion","header":"1706 ordination — five ministers, all Hooker-tree","body":"On November 25, 1706 he was among five ministers who ordained Rev. John Hart at East Guilford — alongside Buckingham of Saybrook, Noadiah Russell of Middletown, Samuel Russell of Branford, and Thomas Ruggles of Guilford. All five names run through the Hooker tree."},{"number":6,"category":"legacy","header":"The household that seeded three centuries","body":"The New Haven parsonage became one of America’s great seedbeds: daughter Sarah married Jonathan Edwards, and the lines that followed carried two Timothy Dwights and Theodore Dwight Woolsey to Yale’s presidency, a vice president named Burr — and, further on, a financier named John Pierpont Morgan."}],"bio":{"title":"Reverend","display_name":"Rev. James Pierpont","first_name":"James","last_name":"Pierpont","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/a/ad/Reverend_James_Pierpont_1711.jpeg","photo_notes":"Portrait image, Wikipedia Commons."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM014"},"education":[{"school_name":"The Roxbury Latin School","type":"preparatory","notes":"Oldest boys’ school in the colonies, founded 1645."},{"school_name":"Harvard College","dates":"1681","type":"college"}],"career":[{"role":"Pastor","organization":"First Church of New Haven","start_year":1685,"end_year":1714,"notes":"Ordained July 2 1685, ending an eleven-year pulpit vacancy; served until death."},{"role":"Founding trustee","organization":"Collegiate School of Connecticut","start_year":1701,"end_year":1714,"notes":"The school became Yale College in 1718."}],"slug":"james-pierpont-1659"},"H00034":{"id":"H00034","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":3,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1673,"month":7,"day":3,"city":"Farmington","state":"Connecticut","country":"United States"},"death":{"year":1740,"month":11,"day":1,"city":"New Haven","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00007","mother_id":"I00006"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 34"}],"marriages":[{"spouse_id":"X00126","children_ids":["H00116","HD0414","H00118","HD0416","HD1322","HD0417","HD0418","HD0419"],"marriage_number":1,"date_year":1698,"date_month":7,"date_day":26,"location_country":"United States"}],"cross_connections":[{"type":"in_law","related_id":"X03175","display_label":"fathered the New Haven minister she married in 1698"},{"type":"in_law","related_id":"X03176","display_label":"was mother to the New Haven minister she married in 1698"},{"type":"artifact","related_id":"H00356","link_text":"Mary Russell Talcott","display_label":"her granddaughter, last of the line the heirloom apron passed through"}],"gender":"female","tags":["yale_connection","extraordinary_story"],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Wife of Yale co-founder Rev. James Pierpont","primary_url":"https://artgallery.yale.edu/collections/objects/9147","primary_url_label":"Yale Art Gallery"},"artworks":[{"artwork_id":"ART040","artwork_blurb":"Companion portrait to husband Rev. James Pierpont, 1711; Yale Art Gallery."}],"narrative_blocks":[{"number":1,"category":"family","header":"Eight children in the house under the elms","body":"Mary ran the New Haven parsonage through sixteen years of marriage and eight children, then presided over it as a widow for twenty-six more. The congregation had raised the house by voluntary subscription, and it stood for over a century."},{"number":2,"category":"family","header":"Married James Pierpont the year her father died","body":"Her father, the Farmington minister Samuel Hooker, died in November 1697; she married James Pierpont of New Haven the following year. The match carried her from one parsonage to the center of Connecticut’s emerging intellectual capital."},{"number":3,"category":"family","header":"Her daughter’s courtship under the elms","body":"It was Mary’s daughter Sarah whom Jonathan Edwards courted beneath the parsonage elms in 1726 — a match made in her widowed household that joined the Pierpont and Edwards lines and led on to college presidents and a vice president."},{"number":4,"category":"family","header":"A son lost crossing the Connecticut","body":"Her son Samuel — Yale 1718, newly ordained at Lyme — drowned in March 1723 crossing the Connecticut River in a canoe with an Indian guide. His body came ashore on Fishers Island six weeks later and was buried where it was found."},{"number":5,"category":"character","header":"The family that named an artist","body":"The unidentified colonial painter who took her portrait around 1711 is known to art history only as the Pierpont Limner — christened for this family, whose likenesses anchor his surviving work. Her husband’s companion portrait hangs at the Yale University Art Gallery."},{"number":6,"category":"legacy","header":"A silk apron may trace to her line","body":"A rare 1730s embroidered silk apron at the Connecticut Historical Society descends through three generations of Marys beginning with her. Though scholars doubt she stitched it herself, her advantageous marriage made such a luxury possible for the daughters who followed."}],"bio":{"display_name":"Mary Hooker Pierpont","first_name":"Mary","last_name":"Pierpont","married_names":["Pierpont"],"maiden_name":"Hooker","photo_url":"https://upload.wikimedia.org/wikipedia/commons/0/02/Mrs._James_Pierpont_née_Mary_Hooker_1711.jpeg","photo_notes":"Portrait of Mrs. James Pierpont (née Mary Hooker), 1711. Wikipedia Commons."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST013"},{"institution_id":"INST022"}],"landmarks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM014"},"videos":[{"video_id":"VID009"}],"slug":"mary-pierpont-1673"}},"burialCemetery":{"id":"CEM033","name":"Dellwood Cemetery","city":"Manchester","county":"Bennington County","state":"Vermont","country":"United States","gps":{"latitude":43.1525,"longitude":-73.0753},"visitable":true,"hooker_connections":["H00352","H00820","H00821","H00823","HD1142","HD1148","HD1149","HD1150","HD1154","HD1158","HD1159","HD3061","HD3062","HD3063","HD3064","X00342","X00348","X00349","X00351","X02064","X02065"]},"institutionsById":{},"crossConnections":[]}