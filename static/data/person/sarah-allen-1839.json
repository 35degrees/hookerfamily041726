connections":[{"type":"family_connection","related_id":"T01459","display_label":"His uncle Allen Butler Talcott was a founding Old Lyme painter.","link_text":"Allen Butler Talcott"}],"narrative_blocks":[{"number":1,"category":"career","header":"New Yorker said America had found its sculptor","body":"At Dudley Talcott's 1927 debut at Valentine Dudensing Galleries, The New Yorker wrote: \"We heard recently that if America ever produced a sculptor it was in the person of Dudley Talcott... Talcott has departed and has still clung to the thing that gives power and beauty.\" Three years later five of his pieces were shown at MoMA alongside Alexander Calder and Isamu Noguchi."},{"number":2,"category":"career","header":"Six years in Norwegian fjords","body":"From 1925 to 1931 Talcott spent six years in Norway, canoeing fjords and working on North Sea fishing boats, then co-owned the vessel Norkap II for four pack-ice voyages to Greenland with scientists and sportsmen. The expeditions produced three illustrated books and directly shaped his figurative sculptures of fishermen and Nordic figures."},{"number":3,"category":"legacy","header":"Olympic art entrant — honorable mention, 1932","body":"In 1932, sculpture was still an Olympic competition. Talcott entered The Wrestler in the Los Angeles Games art category and received an honorable mention — among the few American sculptors to compete in the Olympic arts."},{"number":4,"category":"legacy","header":"Kopernik still stands on the Ben Franklin Parkway","body":"His final major commission, Kopernik (1972-73), is a 16-foot stainless steel orbital circle on Philadelphia's Benjamin Franklin Parkway, donated to the city to mark the 500th anniversary of Copernicus's birth. It remains in place today."}],"quotes":[],"sources":[{"label":"Wikipedia — Dudley Talcott","url":"https://en.wikipedia.org/wiki/Dudley_Talcott"},{"label":"Cedar Hill Foundation — Dudley Vaill Talcott","url":"https://cedarhillfoundation.org/wp-content/uploads/2024/11/Dudley-Talcott-239x300.jpg"}],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Dudley","middle_name":"Vaill","last_name":"Talcott","married_names":[],"display_name":"Dudley Vaill Talcott","photo_url":"https://cedarhillfoundation.org/wp-content/uploads/2024/11/Dudley-Talcott-239x300.jpg","photo_notes":"Portrait. Cedar Hill Foundation."},"military_service":[],"slug":"dudley-talcott-1899"},"TD0063":{"id":"TD0063","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","birth":{"year":1901,"month":11,"day":15,"city":"Hartford","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1989,"month":4,"day":26,"city":"Greenwich","county":"Fairfield","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM025","plot_notes":"Cedar Hill Cemetery Hartford CT. FindAGrave confirms."},"residence":{"city":"Greenwich","county":"Fairfield","state":"Connecticut","country":"United States"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"generation_from_john_talcott":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"T01460","mother_id":"I00180"},"number_of_marriages":3,"marriages":[{"marriage_number":1,"spouse_id":"I00188","date_year":1929,"date_month":1,"date_day":1,"location_state":"Connecticut","location_country":"United States","end_type":"divorce","children_ids":["TD0071","TD0072"]},{"marriage_number":2,"spouse_id":"I00189","date_year":1940,"date_month":1,"date_day":1,"location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1940,"children_ids":[]},{"marriage_number":3,"spouse_id":"I00190","date_year":1942,"date_month":1,"date_day