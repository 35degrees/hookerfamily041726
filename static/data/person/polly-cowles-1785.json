emetery_id":"CEM022","plot_notes":"Ledge Cemetery, Berlin, Connecticut"},"parents":{"father_id":"I00155","mother_id":"H00230"},"marriages":[{"children_ids":["HD0508","HD3785","HD0509"],"spouse_id":"X01214","marriage_number":1,"date_year":1776,"end_type":"death","end_year":1834}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 434"},{"short":"Cowles Family Genealogy","page":"Entry 468"}],"gender":"male","tags":["revolutionary_war"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Samuel Cowles","first_name":"Samuel","last_name":"Cowles","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[{"bib_id":"BIB003"}],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[{"text":"I was born in that part of Farmington which is now Berlin, in Dec. 1752, and have lived in same place to this time.","attribution":"Samuel Cowles, sworn pension affidavit, Berlin Connecticut, September 19, 1832 (U.S. Pension Office)","category":"character"},{"text":"Samuel Cowles is well known to the Court as a worthy, honest man, a man of truth and a wealthy farmer of Berlin.","attribution":"Probate Judge Thomas Lee of Berlin Connecticut, certifying Samuel's 1832 Revolutionary War pension application","category":"character"}],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","rank":"Soldier","unit":"Capt. Sloper's cavalry company, Col. Bull's Connecticut regiment, Danbury","notes":"Four wartime call-ups documented in his 1832 pension affidavit: (1) July 1776, marched to New York City, ~3 weeks; (2) September 1776, Peekskill and White Plains, ~3 weeks, present during the campaign that lost Fort Washington; (3) October 1777, Peekskill and Red Hook NY, ~2 months under Capt. Sloper or his Lt. Seth Deming; (4) October 1779, New Haven Alarm under Capt. Sloper, ~1 week. Pension rejected under Act of 1832 because total service fell short of the six-month minimum. Served alongside brother Jabez Cowles (H00435)."}],"narrative_blocks":[{"number":1,"category":"military","header":"Cavalry service through four Connecticut call-ups","body":"Samuel rode in Capt. Sloper's cavalry company under Col. Bull of Danbury through four wartime call-ups: New York City in summer 1776, Peekskill and White Plains that fall, Red Hook in 1777, and the New Haven Alarm in 1779. His regiment was at White Plains during the campaign that ended with the loss of Fort Washington and 2,800 Continentals captured."},{"number":2,"category":"family","header":"Served the Revolution with his younger brother Jabez","body":"Samuel served his four wartime call-ups alongside his younger brother Jabez Cowles, both riding under Col. Bull of Danbury. Sixty years later the brothers signed each other's pension paperwork — vouching for a war the federal government had nearly forgotten."},{"number":3,"category":"family","header":"Born and died on the same Kensington parcel","body":"'I was born in that part of Farmington which is now Berlin, in Dec. 1752,' Samuel testified in his pension affidavit, 'and have lived in same place to this time.' He died there at eighty-one without ever moving."},{"number":4,"category":"character","header":"Held the second-row pew, served as fence viewer","body":"When the Kensington meetinghouse was reseated in 1815, Samuel was assigned the second row — a precise marker of village standing in a colonial congregation. He served the parish as grand juror in 1802 and as fence viewer over several years."},{"number":5,"category":"military","header":"His pension claim fell short of six months","body":"Samuel filed a Revolutionary War pension affidavit in 1832 detailing each call-up by date and commanding officer. The Pension Office rejected it because his total service fell short of the six months required under the Act of 1832 — though Probate Judge Thomas Lee certified him to the court as 'a worthy, honest man, a man of truth, and a wealthy farmer of Berlin.'"}],"slug":"samuel-cowles-1752"},"X01214":{"id":"X01214","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00434","date_year":1776,"location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1834,"children_ids":["HD0508","HD3785","HD0509"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1751,"city":"Kensington","state":"Connecticut","country":"United States"},"death":{"year":1841,"month":3,"day":18,"city":"Kensington","state":"Connecticut","country":"United States"},"cross_connections":[],"bio":{"display_name":"Mary Lawrence","first_name":"Mary","maiden_name":"Lawrence","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[{"bib_id":"BIB003"}],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-lawrence-1751"},"I00155":{"id":"I00155","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1728,"month":7,"day":18,"city":"Kensington","state":"Connecticut"},"death":{"year":1807,"month":4,"day":7,"city":"Berlin","state":"Connecticut"},"burial":{"cemetery_id":"CEM022","plot_notes":"Ledge Cemetery, Berlin, Connecticut"},"parents":{"mother_research_notes":"Sarah Wadsworth Cowles","father_research_notes":"Samuel Cowles Jr. of Kensington"},"marriages":[{"spouse_id":"H00230","children_ids":["H00434","H00435"],"marriage_number":1,"end_type":"death_o