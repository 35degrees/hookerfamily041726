arch_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"I01302","date_year":1839,"end_type":"death","end_year":1860,"children_ids":["HD5129","HD5130","HD5131"]}],"number_of_marriages":1,"notable":{"is_notable":true,"notable_blurb":"Judge, US District Court for the District of Connecticut","notable_category":["law"],"primary_url":"https://en.wikipedia.org/wiki/Charles_A._Ingersoll","primary_url_label":"Wikipedia"},"birth":{"year":1798,"month":10,"day":19,"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1860,"month":1,"day":12,"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States","age":61},"residence":{},"burial":{"plot_notes":"Grove Street Cemetery, New Haven CT"},"baptism":{},"cross_connections":[],"narrative_blocks":[{"number":1,"category":"law","header":"US federal judge nominated by President Pierce","body":"Charles Anthony Ingersoll served as a United States federal judge, nominated to the bench by President Franklin Pierce in the 1850s. The appointment placed him on the Connecticut federal bench during the politically charged decade leading into the Civil War. He continued the Ingersoll family's principal role in Connecticut legal and judicial life — his father Jonathan Jr. having served as Superior Court Judge and Lieutenant Governor, his elder brother Ralph in Congress and as US Minister to Russia."},{"number":2,"category":"family","header":"Father of two sons who continued legal tradition","body":"Charles Anthony's two sons Charles Dennis Ingersoll (1843-1905, New York City lawyer) and Thomas Chester Ingersoll (1845-1884) continued the family legal tradition. The Ingersoll name extended across three generations of the New York and Philadelphia bars in addition to the original Connecticut branch. His brother Charles Jared Ingersoll (the Philadelphia cousin) had been the family progenitor of the Pennsylvania legal line."},{"number":3,"category":"family","header":"Born 1798, died 1860 age sixty-two","body":"Charles Anthony Ingersoll was born in 1798 — likely a twin to his sister Harriet Ingersoll Voorhees who shares the same birth year. He died in 1860 at age sixty-two on the eve of the Civil War. His father Jonathan Ingersoll Jr. had been Lieutenant Governor of Connecticut at the time of his birth and continued in that role until his death in 1823."}],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","role":"student","notes":"Yale University AM 1827"}],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Charles Anthony Ingersoll","first_name":"Charles","last_name":"Ingersoll","middle_name":"Anthony","married_names":[],"gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779824780/judgecharlesingersoll_ydejnz.jpg"},"slug":"charles-ingersoll-1798"},"I01302":{"id":"I01302","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker_bool":false},"parents":{},"tags":[],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"HD5112","date_year":1839,"end_type":"death","end_year":1860,"children_ids":["HD5129","HD5130","HD5131"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1806,"month":6,"day":20,"city":"New York","county":"New York","state":"New York","country":"United States"},"death":{"year":1877,"month":4,"day":9,"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States","age":70},"residence":{},"burial":{"plot_notes":"Grove Street Cemetery, New Ha