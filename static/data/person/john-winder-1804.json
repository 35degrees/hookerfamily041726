ive.org/details/descendantsofrev00hook"},{"label":"History of Descendants of Elder John Strong, Vol. 1 (1871)","url":"https://dn720908.ca.archive.org/0/items/historyofdescend0001dwig/historyofdescend0001dwig.pdf"}],"research_sources":[],"documents":[],"slug":"martha-strong-1818"},"HD4618":{"id":"HD4618","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Catherine","middle_name":"Granger","last_name":"Chase","maiden_name":"Winder","married_names":["Chase"],"gender":"female","display_name":"Catherine Granger Winder Chase"},"birth":{"year":1838,"month":1,"day":1,"county":"Michigan","state":"Michigan","country":"United States"},"baptism":{},"death":{"year":1860,"month":2,"day":11,"county":"Wayne County","state":"Michigan","country":"United States","cause":"complications of childbirth","age":22},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM437","plot_notes":"Elmwood Cemetery Detroit per FA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"generation_from_john_talcott":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00912","mother_id":"H02016"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00913","date_year":1857,"location_country":"United States","end_type":"death","end_year":1864,"children_ids":["HD4621"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died at twenty-two, months after first childbirth","body":"Catherine 'Kittie' Granger Winder Chase died February 11, 1860 in Wayne County Michigan at age twenty-two — approximately two and a half months after the birth of her only son John Winder Chase on November 26, 1859. The compressed birth-then-death timeline strongly suggests childbirth complications or postpartum illness. Her son John grew up motherless from infancy."},{"number":2,"category":"family","header":"Married Marcus Chase 1857, son John born 1859","body":"Kittie married Marcus A. Chase in 1857 in Wayne County Michigan. Their only documented child John Winder Chase was born November 26, 1859 in Detroit — the boy carried his mother's maiden name Winder forward as his middle name, preserving the Winder family line into the next generation. Marcus survived her by thirty years, dying in 1890."},{"number":3,"category":"family","header":"Michigan 1838-1860; buried Elmwood Cemetery Detroit","body":"Catherine Granger Winder was born January 1, 1838 in Michigan and died February 11, 1860 in Wayne County Michigan at age twenty-two. She is buried at Elmwood Cemetery in Detroit — the major nineteenth-century Detroit garden cemetery. Her father Colonel John Winder and mother Martha Cornelia Strong Winder placed her among the prominent Detroit-Michigan Winder-Strong-Hooker family network of the mid-nineteenth century."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave","url":"https://www.findagrave.com"},{"label":"History of Descendants of Elder John Strong, Vol. 1 (1871)","url":"https://dn720908.ca.archive.org/0/items/historyofdescend0001dwig/historyofdescend0001dwig.pdf"}],"research_sources":[],"documents":[],"slug":"catherine-chase-1838"},"I00913":{"id":"I00913","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Marcus","middle_name":"A","last_name":"Chase","married_names":[],"gender":"male","display_name":"Marcus A Chase"},"birth":{"year":1832,"month":5,"day":24,"county":"Ontario County","state":"New York","country"