,"notes":"Studied in Germany at University of Berlin."}],"military_service":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"},{"institution_id":"INST041"}],"landmarks":[],"artworks":[],"tags":["minister","clergy","author","yale_graduate","missionary"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Pastor of Roxbury's Eliot Church for fifty-nine years","body":"Rev. Augustus Thompson began his pastorate at Eliot Congregational Church, Roxbury, Massachusetts in 1842 and remained senior pastor until his death on September 26, 1901 — fifty-nine unbroken years. In that time he published more than fifteen devotional books, outlived two wives and three children, and became one of the most prolific Congregationalist authors of the mid-Victorian era."},{"number":2,"category":"career","header":"Led ABCFM deputation to India in 1854","body":"In 1854-5, Thompson accompanied Rev. Dr. Rufus Anderson as the ABCFM's deputation to its missions in India and Sri Lanka — visiting stations to resolve disputes over educational policy at a time when British colonial grants were pressuring missionaries toward English-language instruction. The same visit brought him to the Madura mission in South India where William Banfield Capron — husband of Hooker descendant Sarah Brown Hooker Capron — was then serving."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM098"},"residence":{"city":"Roxbury","county":"Suffolk","state":"Massachusetts","country":"United States"},"sources":[{"short":"FindAGrave","page":"FGA #97317843"}],"research_sources":[],"slug":"augustus-thompson-sr-1812"},"H04223":{"id":"H04223","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Rear Adm. Theodore Strong Thompson","first_name":"Theodore","middle_name":"Strong","last_name":"Thompson","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779551900/strongthompson_fidiey.jpg","photo_notes":"Portrait. FGA/Cloudinary."},"gender":"male","birth":{"year":1842,"month":4,"day":23,"city":"Northampton","state":"Massachusetts","country":"United States"},"death":{"year":1915,"month":7,"day":27,"city":"Plattsburgh","county":"Clinton","state":"New York"},"baptism":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"parents":{"father_id":"H02673","mother_id":"I01218"},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":0,"marriages":[],"career":[{"role":"Assistant Paymaster → Pay Director → Rear Admiral","organization":"U.S. Navy","location":"Various","start_year":1863,"end_year":1903,"notes":"Appointed Assistant Paymaster Oct 1863. Paymaster 1878. Pay Inspector July 1898. Pay Director Sept 1901. Retired Dec 26, 1903 as Rear Admiral. 40+ years service."}],"education":[],"military_service":[{"war":"American Civil War","war_id":"WAR006","rank":"Volunteer","unit":"45th Massachusetts Regiment, U.S. Volunteers","notes":"9 months service."},{"war":"Spanish-American War","war_id":"WAR012","rank":"Pay Director (Captain)","unit":"U.S. Navy, USS Massachusetts","notes":"Served on USS Massachusetts to close of Spanish-American War."}],"institutions":[{"institution_id":"INST043","relationship":"alumnus","years":"class of 1862","institution_blurb":"Williams College class of 1862. Civil War service followed graduation."}],"landmarks":[],"artworks":[],"tags":["civil_war","navy"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"military","header":"Retired Rear Admiral from the U.S. Navy","body":"Theodore Strong Thompson served in the Civil War with the 45th Massachusetts Regiment, then spent forty years in the United States Navy's Pay Corps — rising from Assistant Paymaster in 1863 to Pay Director in 1901, retiring December 26, 1903 as a Rear Admiral. His official accounts across four decades are recorded as among the most complete and accurate ever received by the Naval Department."},{"number":2,"category":"military","header":"Served on the Polaris expedition to the Arctic","body":"Thompson sailed on the Polaris Search Expedition to the Arctic and later brought survivors of the Virginius massacre from Santiago de Cuba to New York aboard a Navy vessel. He also served on the battleship Massachusetts to the close of the Spanish-American War."},{"number":3,"category":"family","header":"Son of a minister; grandson of the Governor","body":"Theodore Strong Thompson was the son of Rev. Augustus Thompson, fifty-nine-year pastor of Eliot Congregational Church in Roxbury, and the grandson of Governor Caleb Strong of Massachusetts — one of the most prominent Federalist politicians of the early republic. The Rear Admiral thus carried both pastoral and gubernatorial lineage."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM098"},"residence":{"country":"United States"},"sources":[{"short":"EH 1909","page":"EH 1909"}],"research_sources":[],"slug":"theodore-thompson-1842"},"H04224":{"id":"H04224","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Martha Allen Thompson","first_name":"Martha","middle_name":"Allen","last_name":"Thompson","married_names":[]},"gender":"female","birth":{"year":1843,"month":12,"day":24,"city":"Roxbury","state":"Massachusetts","country":"United States"},"death":{"year":1910},"baptism":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"parents":{"father_id":"H02