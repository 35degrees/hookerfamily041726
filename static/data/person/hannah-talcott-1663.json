arch_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Deputy Governor","organization":"Colony of Connecticut","start_year":1708,"end_year":1723},{"role":"Chief Justice","organization":"Connecticut Superior Court","start_year":1712}],"narrative_blocks":[{"number":1,"category":"politics","header":"He died in office; a Talcott succeeded","body":"Gold held the deputy governorship from 1708 until his death in 1723, doubling as chief justice of the Superior Court from 1712. The man who succeeded him was Joseph Talcott — kin of Gold’s own first wife, Hannah Talcott of Hartford."},{"number":2,"category":"family","header":"Jay Gould and a duchess descend from him","body":"His grandson Lt. Col. Abraham Gould fell at the head of the 4th Connecticut Militia at Ridgefield in 1777; Abraham’s great-grandson was the financier Jay Gould, whose daughter Anna became Duchess of Talleyrand. His father’s troop, Gold’s Dragoons of 1660, still parades in Fairfield."}],"slug":"nathaniel-gold-1663"},"T00058":{"id":"T00058","has_descendants_documented":false,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":false,"generation_from_john_talcott":3,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1687,"month":2},"death":{},"parents":{"father_id":"U00020","mother_id":"T00043"},"tags":[],"sources":[{"short":"Talcott 1876","page":"Entry 58"}],"marriages":[{"children_ids":[],"spouse_id":"X01753","marriage_number":1}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Abigail Gold","first_name":"Abigail","maiden_name":"Gold","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[