rin Kingsley adopted a Boston-born child, Louisa W. Kingsley, who came to Westhampton sometime before November 1847. She died there three years after her 1844 birth; her original family surname appears as Somerby on FindAGrave records."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"emily-kingsley-1804"},"H01409":{"id":"H01409","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"title":"Capt.","first_name":"Henry","last_name":"Hooker","married_names":[],"extra_names":"Findagrave 'VETERAN' marker","gender":"male","display_name":"Capt. Henry Hooker"},"gender":"male","birth":{"year":1786,"month":5,"day":18,"city":"Westhampton","county":"Hampshire","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1853,"month":6,"day":30,"city":"Westhampton","county":"Hampshire","state":"Massachusetts","country":"United States"},"residence":{"city":"Westhampton","county":"Hampshire","state":"Massachusetts","country":"United States"},"burial":{"cemetery_id":"CEM544"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H00529","mother_id":"I01155"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01157","date_year":1803,"location_city":"Westhampton","location_county":"Hampshire","location_state":"Massachusetts","location_country":"United States","end_type":"death","end_year":1853,"children_ids":["H02748","H02749","H02750","H02751","H02752"]}],"education":[],"career":[],"military_service":[{"branch":"Militia (likely Massachusetts state militia)","rank":"Captain","war":"Likely War of 1812 (age 26 at outbreak; rank Capt confirmed)","notes":"Findagrave Memorial #122605184 