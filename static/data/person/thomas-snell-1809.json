:["HD2563","HD2577","HD2564"],"marriage_number":1,"date_year":1906,"date_month":5,"date_day":16,"location_city":"Washington","location_state":"District of Columbia"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Charles Livingston Snell","first_name":"Charles","last_name":"Snell","middle_name":"Livingston","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"Spanish-American War (1898) and continued service","side":"United States","branch":"U.S. Army","service_years":"1898-1911","rank":"U.S. Army officer; entered as junior officer","role":"Served as United States Army officer during the 1898 Spanish-American War and stayed in service until 1911. Likely served at multiple campaigns of the era given the length of service."},{"war":"World War I","side":"United States","branch":"U.S. Army Infantry","service_years":"1917-1919","rank":"Major Infantry","role":"Returned to U.S. Army for World War I 1917-1918; attained the rank of Major (Infantry) before his 1919 discharge. Whether he accompanied the American Expeditionary Force to France is unknown."}],"narrative_blocks":[{"number":1,"category":"military","header":"Spanish-American War to WWI Major Infantry","body":"Charles Livingston Snell served as a United States Army officer during the 1898 Spanish-American War and remained in service until 1911 — a thirteen-year active-duty span across the short campaigns of that era. He then returned to the Army for World War I from 1917 to 1918, attaining the rank of Major (Infantry) before his 1919 discharge. Whether he accompanied the American Expeditionary Force to France during the war is unknown."},{"number":2,"category":"career","header":"Navy fingerprint expert, USMC and federal clerk","body":"Charles Livingston Snell's postwar federal career — per census records — included service as a United States Navy fingerprint expert, then as a United States Marine Corps clerk, then as a United States Government chief clerk. The career arc combined three different federal agencies and reflected the kind of long-term Civil Service work that flourished in early-twentieth-century Washington."},{"number":3,"category":"family","header":"Wife Sarah died 1918, possibly Spanish Flu","body":"Charles Livingston Snell married Sarah Elizabeth Rittenhouse (1880-1918) on May 16, 1906 in Washington D.C., and they had three children — including Elizabeth Rittenhouse Snell Hayes who married Lieutenant General Charles Harold Hayes. Sarah died at age thirty-seven on October 17, 1918, possibly a victim of the Spanish flu pandemic of 1918-1920 (unsourced). Charles never remarried and died at age eighty-three on April 19, 1961 at the Fort Ward Convalescent Home in Alexandria Virginia, buried at Arlington National Cemetery with Sarah."}],"slug":"charles-snell-1877"},"HD2562":{"id":"HD2562","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2559","mother_id":"X00853"},"tags":[],"sources":[],"birth":{"year":1875,"month":9},"death":{"year":1960},"marriages":[{"spouse_id":"X00856","children_ids":["HD2578","HD2565"],"marriage_number":1,"date_year":1905}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Theodore Thomas Snell","first_name":"Theodore","last_name":"Snell","middle_name":"Thomas","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug"