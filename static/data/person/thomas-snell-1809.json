":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Unknown Snell","first_name":"Unknown","last_name":"Snell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"unknown-snell-hd2584"},"HD2559":{"id":"HD2559","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00852","mother_id":"HD2530"},"tags":["army","civil_war","clergy","minister"],"sources":[],"birth":{"year":1839,"month":5},"death":{"year":1909,"month":12},"marriages":[{"spouse_id":"X00853","children_ids":["HD2560","HD2571","HD2572","HD2573","HD2574","HD2561","HD2562","HD2575","HD2576"],"marriage_number":1,"date_year":1862,"date_month":8,"date_day":31}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Moses Porter Snell","first_name":"Moses","last_name":"Snell","middle_name":"Porter","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779738163/mosesportersnell_y4aodg.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[{"name_element":"Moses Porter","inspired_by_id":"HD2434","description":"Named 'Moses Porter' for grandfather Col. Moses Porter (HD2434)."}],"institutions":[{"institution_id":"INST091","relationship":"licensee/preacher","years":"1868","institution_blurb":"Licensed to preach in 1868 at Talcott Street Congregational Church (now Faith Congregational Church) — historic Black Congregational congregation founded 1826 in Hartford."},{"institution_id":"INST018"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Civil War","war_id":"WAR002","side":"Union","rank":"Private (1862-64) → First Lieutenant and Brevet Captain (1864)","service_years":"1862-1865","units":["36th Massachusetts Volunteer Infantry (1862-1864)","39th United States Colored Troops (1864) — Black Union Army regiment","Aide-de-Camp to General Duncan, New Bern North Carolina (1865)"],"role":"Enlisted Massachusetts state regiment 1862; transitioned to officer commission with one of the U.S. Colored Troops Black Union regiments in 1864. Served as aide-de-camp to General Duncan in New Bern North Carolina through war's end."}],"burial":{"cemetery_id":"CEM027","plot_notes":"Congressional Cemetery, Washington, District of Columbia. Cemetery linkage repair: existing person was listed in cemetery hooker_connections in prior pilots but burial.cemetery_id was null. Pilot104 closure of bidirectional reference."},"narrative_blocks":[{"number":1,"category":"military","header":"USCT officer, Freedmen's Bureau Superintendent","body":"Moses Porter Snell rose from Private in the 36th Massachusetts Volunteers (1862-1864) to First Lieutenant and Brevet Captain in the 39th United States Colored Troops in 1864 — one of the Black Union Army regiments. He served as Aide-de-Camp to General Duncan in New Bern North Carolina in 1865. Immediately postwar he became Superintendent of the Freedmen's Bureau in Washington D.C., a significant Reconstruction-era role coordinating federal support for newly emancipated African Americans."},{"number":2,"category":"religion","header":"Licensed to preach at Talcott Street Church, 1868","body":"After ordination on May 8, 1867 from Hartford Theological Seminary, Moses Porter Snell was licensed to preach in 1868 at Talcott Street Congregational Church in Hartford — the historic Black Congregational congregation that had been founded in 1826. The Talcott Street licensing parallel between his Reconstruction-era career and his ministerial commissioning at one of New England's most prominent Black churches is striking. He spent the next forty years as missionary and pastor in Washington D.C. and Maryland-Virginia churches."},{"number":3,"category":"family","header":"Grandson of Amherst College founder Thomas Snell","body":"Moses Porter Snell was grandson of Dr. Thomas Snell, founder of Amherst College, and nephew of Ebenezer S. Snell (Amherst class of 1822). He himself graduated Amherst in 1868 and attended Hartford Theological Seminary 1866-1868. The two-generation Amherst College connection — founder grandfather, alumnus uncle, alumnus himself — was characteristic of the New England Congregational scholarly families that dominated late-nineteenth-century mainline Protestant institutional leadership."},{"number":4,"category":"family","header":"Born North Brookfield MA, buried Congressional Cemetery DC","body":"Moses Porter Snell was born May 3, 1839 in North Brookfield Massachusetts and died December 31, 1909 in Newton New Jersey at age seventy. He was buried at Congressional Cemetery in Washington D.C. He married Mary Cordelia Hallock on August 31, 1862 — the same year he enlisted in the 36th Massachusetts. They had nine children."}],"slug":"moses-snell-1839"},"X00853":{"id":"X00853","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1843},"death":{"year":1924},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2559","date_year":1862,"date_month":8,"date_day":31,"children_ids":["HD2560","HD2571","HD2572","HD2573","HD2574","HD2561","HD2562","HD2575","HD2576"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Cordelia Hallock","first_name":"Mary","middle_name":"Cordelia","maiden_name":"Hal