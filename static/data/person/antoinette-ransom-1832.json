t":"EH 1909; FamilySearch"}],"birth":{"year":1798},"death":{"year":1859,"month":11,"day":11,"city":"Fort Scott","state":"Kansas"},"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"7th Governor of Michigan; Michigan Supreme Court justice","primary_url":"https://en.wikipedia.org/wiki/Epaphroditus_Ransom","primary_url_label":"Wikipedia"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2682","children_ids":["HD2683","HD2684","HD2824","HD2825"],"date_year":1827,"date_month":2,"date_day":21,"location_city":"Montpelier","location_state":"Vermont"}],"parents":{},"narrative_blocks":[{"header":"Shielded Potawatomi from removal, 1840","detail":"During his governorship the first telegraph line from New York to Detroit was completed (March 1, 1849). Two significant immigrations occurred: Dutch settlers under Rev. Van Raalte founded Holland, Michigan and established Hope College; and James Jesse Strang led a faction of Mormon followers to Beaver Island, where Strang founded a short-lived kingdom before his assassination. Ransom's strong anti-slavery position cost him renomination by the state Democratic Party in 1850. He was elected again to the state legislature in 1853 and 1854. (Wikipedia)","body":"Epaphroditus Ransom served as Michigan Supreme Court justice from 1837, including as chief justice 1843-1848. In 1840 he issued a ruling preventing the removal of the Catholic Potawatomi from their lands in southwestern Michigan. Elected governor in 1848, he was the first inaugurated in Lansing after the capital moved from Detroit.","number":1},{"header":"Died in Kansas, private fortune ruined","detail":"The Panic of 1855 destroyed his private business ventures. In 1857 President Buchanan appointed him receiver of public monies for the Osage Land Office in Fort Scott, Kansas. He died there in 1859 at 61, buried at Mountain Home Cemetery in Kalamazoo. His wife Almira Cadwell (HD2682) was a 7th-generation descendant of Rev. Thomas Hooker through the Cadwell family. His father Major Ezekiel Ransom was present at the execution of Major John André during the Revolutionary War — the spy whose capture unraveled Benedict Arnold's treason. (Wikipedia; research notes)","body":"Ransom was the first president of the Michigan Agricultural Society, directly instrumental in establishing both the Michigan State Fair and Michigan State University. He served as regent of the University of Michigan 1850-1852 and co-founded the village of Augusta, Michigan.","number":2}],"cross_connections":[{"type":"civic_connection","display_label":"oversaw the André execution Ransom's father witnessed","related_id":"H00757","link_text":"Maj. Benjamin Tallmadge Jr."}],"bio":{"display_name":"Epaphroditus Ransom","first_name":"Epaphroditus","last_name":"Ransom","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/f/ff/Epaphroditus_Ransom_1.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"epaphroditus-ransom-1798"},"HD2682":{"id":"HD2682","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2675","mother_id":"X00911"},"tags":[],"sources":[{"short":"EH 1909; FamilySearch"}],"birth":{"year":1805,"month":2,"day":10},"death":{"year":1877,"month":3,"day":17,"city":"Fort Scott","state":"Kansas"},"marriages":[{"spouse_id":"X00912","children_ids":["HD2683","HD2684","HD2824","HD2825"],"marriage_number":1,"date_year":1827,"date_month":2,"date_day":21}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"7th-generation Hooker descendant who married Michigan's governor","detail":"Two of her four children died in infancy. Her son Wyllys Cadwell Ransom (HD2683) became a prominent figure in Kalamazoo; her daughter Antoinette Eugenia Ransom (HD2684) lived to 1909. The Cadwell family name she carried appears in her son's full name — Wyllys Cadwell Ransom — and again in her grandsons' generation. She is buried at Mountain Home Cemetery, Kalamazoo, in the same lot as her husband. (FamilySearch; EH 1909)","body":"Almira Cadwell was born in Montpelier, Vermont in 1805, a 7th-generation descendant of Rev. Thomas Hooker through the Cadwell family line. She married Epaphroditus Ransom in 1827, followed him to Michigan Territory in 1834, and outlived him by 18 years — dying in Fort Scott, Kansas in 1877, the same town where her husband had died.","number":1}],"cross_connections":[],"bio":{"display_name":"Almira Cadwell Ransom","first_name":"Almira","last_name":"Ransom","maiden_name":"Cadwell","married_names":["Ransom"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"almira-ransom-1805"},"HD2675":{"id":"HD2675","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00910","mother_id":"H00986"},"tags":[],"sources":[{"short":"EH 1909; FamilySearch"}],"birth":{"year":1778,"month":8},"death":{"year":1823,"month":12,"day":8,"city":"Montpelier","state":"Vermont"},"marriages":[{"spouse_id":"X00911","children_ids":["HD2682","HD2707"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Wyllys Jay Cadwell","first_name":"Wyllys","last_name":"Cadwell","middl