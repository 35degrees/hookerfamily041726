itary_service":[],"narrative_blocks":[{"number":1,"category":"character","header":"Anticipated turbine engines used later in ocean liners","body":"Frederick Howard Pierpont built a working turbine model that his friends laughed at, so he got rid of it — and the turbine engine was later put into practical use on ocean liners. He always wished he had not given up the model. The independent prescience of a Connecticut toolmaker about marine propulsion captured the kind of unrecognized invention that small communities of his era frequently failed to encourage."},{"number":2,"category":"character","header":"Old-time fiddler at kitchen dances since age fourteen","body":"Frederick played the fiddle from age fourteen onward — an 'old time fiddler' playing jigs and reels, who 'spent many hours making other people happy playing his fiddle at kitchen dances.' He also played mandolin. The kitchen-dance circuit was the late-nineteenth-century Connecticut working-class equivalent of community concerts; Frederick's name was on the local register of regular musicians."},{"number":3,"category":"family","header":"Wife arrived alone from Ireland at seventeen","body":"Frederick's wife Mary Eleanor Elliott was born November 16, 1868 in County Cavan Ireland and arrived in America in 1885 at age seventeen, alone, on the steamship SS Circassia. She lived to age eighty-eight, dying May 9, 1957 in Waterbury Connecticut. The age-17 solo transatlantic Irish-immigrant arrival was a striking single-event biographical fact."},{"number":4,"category":"character","header":"Roamed woods with sister testing medicinal herbs","body":"As a youth Frederick roamed the woods with his sister hunting for medicinal herbs — testing each plant to ensure it was not poisonous. The herbalist apprenticeship was part of his lifelong love of nature, hunting, and fishing. He was a member of First Methodist Church Waterbury where he lived his last forty-four years working as a toolmaker for John Draber Machine Co., Hendey Machine Plant, and Torrington Manufacturing Co."},{"number":5,"category":"family","header":"Litchfield 1862 birth to Waterbury 1934 death","body":"Frederick Howard Pierpont was born June 14, 1862 at the old Pierpont homestead in Litchfield Connecticut and died January 27, 1934 in Waterbury Connecticut at age seventy-one. Five sons: Edward Beach (1890-1958), Douglas Montgomery (1894-1973), Albert Howard (1896-1952), Ralph Andrew (1898-1971), and Frederick Elliott (1902-1972)."}],"slug":"frederick-pierpont-1862"},"X00403":{"id":"X00403","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1868},"death":{"year":1957},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1296","date_year":1887,"date_month":5,"date_day":25,"children_ids":["HD1298","HD1299","HD1300","HD1301","HD1302"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Eleanor Elliott","first_name":"Mary","middle_name":"Eleanor","maiden_name":"Elliott","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-elliott-1868"},"HD1298":{"id":"HD1298","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1296","mother_id":"X00403"},"tags":[],"sources":[],"birth":{"year":1890},"death":{"year":1958},"gender":"male","marriages":[{"spouse_id":"X01472","children_ids":[],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Edward Beach Pierpont","first_name":"Edward","last_name":"Pierpont","middle_name":"Beach","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"edward-pierpont-1890"},"HD1299":{"id":"HD1299","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1296","mother_id":"X00403"},"tags":["army","engineer","wwi"],"sources":[],"birth":{"year":1894},"death":{"year":1973,"cause":"Died at Veterans Administration Hospital, West Haven CT"},"marriages":[{"spouse_id":"X00404","children_ids":["HD1303","HD1304","HD1305","HD1306","HD1307"],"marriage_number":1}],"cross_connections":[{"type":"parallel_descent","related_id":"HD1265","display_label":"Douglas Montgomery Pierpont was Vice President of Snow-Nabstedt Gear Corp.","link_text":"Ruth Canfield Snow Nabstedt"},{"type":"parallel_descent","related_id":"HD1261","display_label":"Douglas Montgomery Pierpont was Vice President of Snow-Nabstedt Gear Corp.","link_text":"Frank Hinman Pierpont"}],"gender":"unknown","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Douglas Montgomery Pierpont","first_name":"Douglas","last_name":"Pierpont","middle_name":"Montgomery","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"World War I","war_id":"WAR007","side":"United States","rank":"U.S. Army","service_years":"1918-1919","enlisted_date":"1918-08-26","discharged_date":"1919-01-17","notes":"Enlisted August 26, 1918; discharged January 17, 1919. Five-month service window — enlisted in the final months of the war and was discharged shortly after the Armistice."}],"narrative_blocks":[{"number":1,"category":"military","header":"Enlisted as Armistice loomed, served five months","body":"Douglas Montgomery Pierpont enlisted in the U.S. Army on August 26, 1918 — eleven weeks before the November 11 Armistice ended World War I. He was discharged on January 17, 1919, having served roughly five months total, including the war's final phase and the immediate aftermath. He died fifty-five years later at the Veterans Administration Hospital in West Haven Connecticut, age seventy-nine."},{"number":2,"category":"career","header":"Vice president of cousin-named gear company","body":"Pierpont was Vice President of the Snow-Nabstedt Gear Corporation in Connecticut — a corporate name built from two cousin-family surnames he knew intimately. 'Snow' was Levi Tracy Snow, husband of his distant cousin Sila Harrison Pierpont (daughter of his grand-uncle Cornelius). 'Nabstedt' was Arthur Theodore Nabstedt, who married Sila's daughter Ruth Canfield Snow. He held the role through the WWII industrial-machinery boom."}],"slug":"douglas-pierpont-1894"},"HD1300":{"id":"HD1300","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1296","mother_id":"X00403"},"tags":[],"sources":[],"birth":{"year":1896},"death":{"year":1952},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Albert Howard Pierpont","first_name":"Albert","last_name":"Pierpont","middle_name":"Howard","married_names":[]},"residence":{},"baptism":{},"researc