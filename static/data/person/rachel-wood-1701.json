v. John Wilson Sr., first minister First Church Boston","father_id":"X02132","mother_id":"X02972","father_name":"Rev. John Wilson Sr."},"marriages":[{"spouse_id":"H00006","children_ids":["H00019","H00020","H00021","H00022","H00023","H00024","H00025","H00026"],"marriage_number":1,"date_year":1647}],"tags":["minister","physician","harvard_graduate"],"sources":[{"short":"Edward Hooker 1909"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"is_placeholder":false,"baptism":{},"residence":{"city":"Medfield","county":"Norfolk","state":"Massachusetts","country":"United States"},"institutions":[{"institution_id":"INST002","institution_blurb":"Harvard College 1642."}],"landmarks":[],"naming_inspiration":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"narrative_blocks":[{"number":1,"category":"legacy","header":"Founded Medfield church — served forty years","body":"He became the first minister of Medfield, Massachusetts in 1651 and served the congregation for forty years until his death in 1691. He had previously served as a colleague of Rev. Richard Mather at Dorchester, and received his education at Harvard College in 1642."},{"number":2,"category":"legacy","header":"Harvard 1642 — the first graduating class","body":"He attended Harvard College in 1642, effectively the first graduating class of the institution. His father Rev. John Wilson Sr. was a close ally of Rev. Thomas Hooker, and John Jr. married Hooker's daughter Sarah — bringing together two of the founding families of Puritan New England."},{"number":3,"category":"family","header":"Son of Boston's founding minister","body":"His father, Rev. John Wilson Sr., was the first minister of the First Church of Boston from its founding in 1630 until his death in 1667 — the man who formally excommunicated Anne Hutchinson in 1638 and who supervised the execution of Mary Dyer in 1660."},{"number":4,"category":"character","header":"Fell four stories — taken up for dead","body":"Cotton Mather records that as a child, Wilson \"fell upon his head from a loft four stories high into the street; from whence he was taken up for dead, and so battered and bruised and bloody with his fall, that it struck horror into the beholders.\" His father's prayers were credited with his recovery. He went on to serve Medfield forty years as minister, physician, and schoolmaster."}],"burial":{"cemetery_id":"CEM650"},"career":[{"role":"Schoolmaster","organization":"Nathaniel Eaton's school, Cambridge MA","end_year":1642,"notes":"Studied at Eaton's school (introductory to Harvard). Testified to ill-treatment of scholars by Eaton."},{"role":"Coadjutor / Colleague","organization":"Dorchester Church, Massachusetts","start_year":1649,"end_year":1651,"notes":"Colleague of Rev. Richard Mather at Dorchester. Known as \"the gracious and godly Mr. Wilson.\""},{"role":"First Minister","organization":"Medfield, Massachusetts","start_year":1651,"end_year":1691,"notes":"Settled 1651. Ordained pastor Oct 12, 1652. Also served as physician and schoolmaster. Served 40 years until his death."}],"education":[{"institution_id":"INST002","degree":"graduate","year":1642,"notes":"First class"}],"bio":{"title":"Reverend","display_name":"Rev. John Wilson","first_name":"John","last_name":"Wilson","married_names":[]},"documents":[],"artworks":[],"military_service":[],"slug":"john-wilson-1621"},"H00006":{"id":"H00006","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":2,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1630,"month":2,"day":21,"city":"Little Baddow","county":"Essex","country":"England"},"death":{"year":1725,"month":8,"day":20,"city":"Braintree","county":"Suffolk","state":"Massachusetts","country":"United States"},"parents":{"father_id":"H00001","mother_id":"I00001"},"marriages":[{"spouse_id":"I00004","children_ids":["H00019","H00020","H00021","H00022","H00023","H00024","H00025","H00026"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1691,"date_year":1647,"location_country":"United States"}],"tags":["replacement_naming","extraordinary_longevity"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 6"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"legacy","header":"Lived to age 95","body":"Lived to age 95","migrated_from":"historical_significance"},{"number":2,"category":"legacy","header":"Outlived husband by 34 years","body":"Outlived husband by 34 years","migrated_from":"historical_significance"},{"number":3,"category":"legacy","header":"Her son married her sister Mary's daughter","body":"Her son John Wilson married Sarah Newton — the daughter of Mary Hooker Newton, Sarah's own sister. Both of Thomas Hooker's daughters had children of the same generation who married each other, making their grandchildren the first documented double-descent in the Hooker tree."}],"baptism":{"year":1630,"month":2,"day":21,"city":"Broomfield","county":"Essex","country":"England"},"residence":{"city":"Braintree","county":"Suffolk","state":"Massachusetts","country":"United States"},"cross_connections":[{"type":"cousin_marriage","related_id":"H00024","display_label":"Her son John Wilson married his first cousin Sarah Newton.","link_text":"John Wilson"},{"type":"in_law","related_id":"X02132","display_label":"was her father-in-law and Boston’s first minister","link_text":"Rev. John Wilson Sr."}],"bio":{"display_name":"Sarah Hooker Wilson","first_name":"Sarah","last_name":"Wilson","married_names":["Wilson"],"maiden_name":"Hooker"},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-wilson-1630"}},"burialCemetery":null,"institutionsBy