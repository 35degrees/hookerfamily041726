n_type":"orbit_non_descendant"}],"gender":"male","number_of_marriages":1,"parents":{},"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Minister who founded a New Haven girls' school","primary_url":"https://en.wikipedia.org/wiki/Claudius_Herrick","primary_url_label":"Wikipedia"},"cross_connections":[],"bio":{"display_name":"Rev. Claudius Herrick","title":"Reverend","first_name":"Claudius","last_name":"Herrick","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST016"},{"institution_id":"INST022","relationship":"alumnus","years":"1798"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"education":[{"institution_id":"INST022","dates":"1798"}],"narrative_blocks":[{"category":"education","header":"He founded a New Haven school for women","body":"After ill health ended his Woodbridge pastorate, Claudius Herrick opened a school for young women in New Haven that ran from 1808 until his death. He charged daughters of clergymen half the usual tuition.","number":1},{"category":"legacy","header":"His pupils married bishops and a governor","body":"Three Episcopal bishops and Governor Roger Sherman Baldwin all married former students of his school. Herrick himself had earlier served as head of Deerfield Academy.","number":2}],"slug":"claudius-herrick-1775"},"H00979":{"id":"H00979","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1776,"city":"New Haven","state":"Connecticut"},"death":{"year":1859,"city":"New Haven","state":"Connecticut"},"parents":{"father_id":"H00388","mother_id":"X00494"},"marriages":[{"spouse_id":"X00500","children_ids":["HD1551","HD1552","HD1553","HD1554"],"marriage_number":1,"date_year":1