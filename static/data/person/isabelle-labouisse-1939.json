ategory":"family","header":"Named for signer John Witherspoon, his ancestor","body":"John Witherspoon Labouisse carried the name of his ancestor John Witherspoon — the Princeton president and only ordained minister to sign the Declaration of Independence in 1776. Through his maternal Huger line he also descended from Arthur Middleton, a fellow Declaration signer from South Carolina. The double-signer ancestry was a frequent talking point in family records."},{"number":2,"category":"marriage","header":"Married Cameron daughter; settled at Fairntosh Farm","body":"In 1926 John Witherspoon Labouisse married Sarah Taliaferro 'Sally' Cameron of Powhatan, Virginia, daughter of Bennehan Cameron of the prominent North Carolina Cameron family. They settled at Fairntosh Farm in Durham County, North Carolina — historic Cameron family land. Four children were born; their only son died in infancy in 1935."}],"slug":"john-labouisse-1899"},"X00881":{"id":"X00881","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1903,"month":7,"day":25,"city":"Powhatan","state":"Virginia","county":"Powhatan County","country":"USA"},"death":{"year":1985,"month":3,"day":23,"city":"Richmond","state":"Virginia","age":81},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2605","children_ids":["HD2615","HD2616","HD2617"],"date_year":1926}],"parents":{"father_research_notes":"Bennehan Cameron","mother_research_notes":"Sallie Taliaferro Mayo"},"notable":{"is_notable":false,"notable_category":[]},"burial":{"place":"Saint Matthew's Episcopal Church Cemetery","city":"Hillsborough","state":"North Carolina"},"cross_connections":[],"bio":{"display_name":"Sarah Taliaferro Cameron Labouisse","first_name":"Sarah","last_name":"Labouisse","maiden_name"