ion_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"achievement","header":"Bicknell's Thrush bears his name","body":"Bicknell collected a thrush specimen which the ornithologist Robert Ridgway described as a new species and named Catharus bicknellii in his honor. The bird breeds in the high-elevation balsam fir forests of the northeastern United States and eastern Canada. Plants in five genera were also named for him, including Carex bicknellii and Geranium bicknellii (Bicknell's cranesbill)."},{"number":2,"category":"career","header":"Self-taught naturalist; founding AOU secretary","body":"Eugene Bicknell worked at the banking firm John Munroe & Co. and its Paris affiliate, then turned to natural history as a self-taught naturalist. His first publication on the birds of the Hudson Valley appeared in 1878, followed by surveys of the Catskills and Nantucket. He was Secretary of the American Ornithologists' Union at its founding."}],"slug":"eugene-bicknell-1859"},"X00978":{"id":"X00978","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1604","date_year":1901,"children_ids":["HD2750","HD2751"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Edith Babcock","first_name":"Edith","last_name":"Babcock","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"edith-babcock"},"HD2750":{"id":"HD2750","has_descendants_documented":false,"classification":{"include_in