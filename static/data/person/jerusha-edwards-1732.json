was named in his honor","body":"A fluent orator said to charm any room or legislature he entered, Welles became one of the foremost makers of Athens, Pennsylvania. Wells Township was named for him."},{"number":3,"category":"marriage","header":"His first wife died weeks after the wedding","body":"Henry married Phoebe Patrick in February 1809, but she died only weeks later, leaving him a young widower. Three years on he married Sarah 'Sally' Spalding, who would outlive him by forty-four years."}],"sources":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Henry","last_name":"Welles","married_names":[],"display_name":"Henry Welles","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780698889/henrywelles_rtjwnk.png","photo_notes":"Gen. Henry Welles (1781–1833), Pennsylvania state senator."},"military_service":[],"career":[{"role":"State Representative","organization":"Pennsylvania House","start_year":1809,"end_year":1813,"notes":"Wrote the 1813 Academy Bill."},{"role":"State Senator","organization":"Pennsylvania Senate","start_year":1815,"end_year":1819,"notes":"10th district."},{"role":"General (aide-de-camp)","organization":"Gov. Simon Snyder","notes":"Honorary rank."}],"slug":"henry-welles-1781"},"T01809":{"id":"T01809","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"female","birth":{"year":1783,"month":1,"day":10,"city":"Glastonbury","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1865,"month":2,"day":7,"city":"Owego","state":"New York","country":"United States"},"burial":{},"residence":{"city":"Owego","state":"New York","country":"United States"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":5,"include_in_path_calc