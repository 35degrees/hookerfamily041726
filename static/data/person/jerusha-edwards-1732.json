":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"His will sent three sons to three futures","body":"Richard Edwards, the only child of one of Hartford's first settlers, became the progenitor of the celebrated Edwards family of Connecticut. His will charted divergent courses for his sons — one to care for their mother, one to be educated at college and become a judge, one to be put to a trade — and through his son Timothy came his grandson Jonathan Edwards, the Great Awakening theologian."},{"number":2,"category":"family","header":"Only child of two of Hartford’s first families","body":"Richard was the only child of William Edwards and Agnes Spencer, each tied to Hartford's earliest settlers, and his grandmother Ann had crossed from England with his father when the boy was young. He inherited that founding stock as an only child and passed it to a large family of his own."}],"slug":"richard-edwards-1647"},"T00042":{"id":"T00042","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":2,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1661,"month":8,"day":26},"death":{"year":1723},"parents":{"father_id":"T00035","mother_id":"U00012"},"tags":[],"sources":[{"short":"Talcott 1876","page":"Entry 42"}],"marriages":[{"spouse_id":"U00016","children_ids":["T00052","T00053","T00054","T00055","I00053","T00057"],"marriage_number":1,"date_year":1692}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"family_connection","related_id":"H00033","display_label":"Her son married his daughter, first Hooker-Talcott merger.","link_text":"Nathaniel Willett Hooker"}],"bio":{"display_name":"Mary Talcott","first_name":"Mary","maiden_name":"Talcott","married_names":[]},"residence":{},"baptism":