table":{"is_notable":true,"notable_category":["politics","medicine"],"notable_blurb":"4-day chairman San Juan","primary_url":"https://en.wikipedia.org/wiki/Am%C3%A1n_Rawson","primary_url_label":"Wikipedia"},"narrative_blocks":[{"header":"Arrived in Argentina at 26 — independence year","number":1,"body":"Amán Rawson received his medical degree in 1814 and served as a surgeon in the U.S. Navy. In 1818 — just two years after Argentina declared independence — he arrived in Buenos Aires. He spent a short time in Mendoza before settling in San Juan in early 1819."},{"header":"Smuggled Facundo in drawers labeled for disease","number":2,"body":"In his final years Amán Rawson smuggled copies of Sarmiento's Facundo — a devastating political attack on the Rosas dictatorship — by hiding them in drawers filled with a chemical stench, with a large sign warning they contained remedies for venereal diseases. The border guards never checked. He died in San Juan in January 1847, a year after the books arrived."},{"header":"Emergency chairman of San Juan — four days","number":3,"body":"In April 1831, news reached San Juan that Federalist forces under General Facundo Quiroga were marching on the province. Amán Rawson took emergency joint control of the government with priest José de Oro and Ignacio José Sánchez. He called an election, a moderate Federalist won, and Rawson stepped aside — four days after he'd stepped in."},{"header":"He arrived from Massachusetts and founded a city","number":4,"body":"In 1822, the former U.S. Navy surgeon planned to establish an American immigrant colony in San Juan Province. It ended as an Argentine settlement instead — but from that project grew the city of Caucete and the irrigation of the left bank of the San Juan River."}],"cross_connections":[{"type":"family_orbit","related_id":"X02061","display_label":"He smuggled Sarmiento's Facundo into San Juan hidden in medicine drawers —.","link_text":"Domingo Faustino Sarmiento"}],"bio":{"display_name":"Amán Rawson","first_name":"Haman","last_name":"Rawson","married_names":[],"nickname":"Haman","photo_url":"https://upload.wikimedia.org/wikipedia/commons/1/1e/Aman_rawson.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"haman-rawson-1792"},"X02060":{"id":"X02060","is_placeholder":false,"gender":"female","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{},"death":{},"parents":{},"marriages":[{"marriage_number":1,"spouse_id":"HD0277","children_ids":["HD0280","HD3053","HD3054","HD3055","HD3056","HD3057"]}],"number_of_marriages":1,"tags":[],"sources":[{"short":"FindAGrave"}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mercedes Martínez Doncel","first_name":"Mercedes","last_name":"Martínez","maiden_name":"Martínez","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mercedes-martinez"},"HD0275":{"id":"HD0275","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1751,"month":6,"day":2,"city":"Uxbridge","county":"Worcester","state":"Massachusetts","country":"United States"},"death":{"year":1823,"month":5,"day":1,"city":"Wilna","county":"Jefferson","state":"New York","country":"United States"},"parents":{"father_id":"H00201","mother_id":"X01116"},"marriages":[{"marriage_number":1,"spouse_id":"X01118","date_year":1770,"date_month":7,"date_day":10,"location_city":"Uxbridge","location_county":"Worcester","location_state":"Massachusetts","location_country":"United States","end_type":"death_of_spouse","children_ids":["HD0276","HD0277","HD0278"]}],"tags":["revolutionary_war"],"sources":[],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"military","header":"Private in the Massachusetts forces during the Revolution","body":"He enlisted as a private in the Massachusetts militia during the American Revolution — one of the Rawson family's generation who answered the first call. His uncle Abner Rawson served in the same conflict."},{"number":2,"category":"migration","header":"Moved west — died in Wilna NY, 1823","body":"After the Revolution he joined the wave of New Englanders settling upstate New York. He died in Wilna, Jefferson County on May 1, 1823, having migrated far from his birthplace in Uxbridge, Massachusetts."},{"number":3,"category":"family","header":"His son Aman governed Argentina — smuggled pamphlets","body":"His son Haman Rawson (born 1792, known in Argentina as Amán) trained as a doctor, served as a U.S. Navy surgeon, then settled in San Juan, Argentina. He governed San Juan Province for four days during a political emergency in 1831, founded the city of Caucete, and smuggled copies of Sarmiento's anti-Rosas pamphlet Facundo hidden in medicine drawers. He died in San Juan on January 12, 1847."}],"cross_connections":[],"bio":{"display_name":"Edmund Rawson","first_name":"Edmund","last_name":"Rawson","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"edmund-rawson-1751"},"X01118":{"id":"X01118","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0275","date_year":1770,"date_month":7,"date_day":10,"location_city":"Uxbridge","location_county":"Worcester","location_state":"Massachusetts","location_country":"United States","children_ids":["HD0276","HD0277","HD0278"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1750,"city":"Sutton","county":"Worcester","state":"Massachusetts","country":"United States"},"death":{},"narrative_blocks":[{"number":1,"category":"family","header":"Her son Amán became an Argentine provincial governor","body":"Her son Haman Rawson — born 1792 in Massachusetts, known as Amán in Argentina — became a doctor, a U.S. Navy surgeon, and eventually a pivotal figure in San Juan, Argentina. He founded a city, governed a province for four days during a political crisis, and smuggled anti-dictator pamphlets hidden in medicine drawers. He died in San Juan on January 12, 1847."}],"cross_connections":[],"bio":{"display_name":"Sarah Hull Rawson","first_name":"Sarah","last_name":"Rawson","maiden_name":"Hull","married_names":["Rawson"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-hull-1750"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}