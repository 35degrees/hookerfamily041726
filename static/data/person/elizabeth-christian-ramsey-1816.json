ial":{"cemetery_id":"CEM898"},"slug":"elizabeth-christian-ramsey-1816"},"X02122":{"id":"X02122","is_placeholder":false,"has_descendants_documented":false,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":true},"bio":{"first_name":"Ainsworth","middle_name":"Emery","last_name":"Blunt","married_names":[],"gender":"male","display_name":"Ainsworth Blunt","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781543666/41814476_0df9f6af-c96e-4c2e-89de-3d382ee61d93_b9srwg.jpg","bio_blurb":"Cherokee missionary; first mayor of Dalton, Georgia"},"birth":{"year":1800,"month":2,"day":22,"city":"Amherst","state":"New Hampshire","country":"United States","date_precision":"exact"},"baptism":{},"death":{"year":1865,"month":12,"day":21,"city":"Dalton","state":"Georgia","country":"United States","date_precision":"exact"},"burial":{"cemetery_id":"CEM898"},"parents":{"father_name":"John Isaac Blunt","mother_name":"Sarah (Eames) Blunt"},"number_of_marriages":1,"marriages":[{"spouse_id":"X02121","marriage_number":1,"date_year":1822,"date_month":11,"date_day":17,"children_ids":["HD6503","HD6504","HD6505","HD6506","HD6507"]},{"spouse_id":"X03372","marriage_number":2,"date_year":1849,"children_ids":[]}],"institutions":[{"institution_id":"INST041","institution_blurb":"Missionary at Brainerd Mission 1822-1837."}],"landmarks":[{"landmark_id":"LM154","relationship":"builder"}],"naming_inspiration":[],"tags":["cherokee_mission","mayor","minister","missionary"],"research_tags":[],"cross_connections":[{"type":"civic_connection","related_id":"HD6470","link_text":"Rev. Samuel Newton","display_label":"a fellow Cherokee missionary who later pioneered San Antonio"}],"quotes":[],"narrative_blocks":[{"number":1,"category":"religion","header":"He sailed south to teach the Cherokee","body":"In 1822 the American Board of Commissioners for Foreign Missions sent Ainsworth Blunt from Boston to the Brainerd Mission in the Cherokee Nation, where he taught literacy, Christianity, carpentry, and farming. He ran a ferry across Chickamauga Creek and oversaw the mission’s wild oxen, reporting that “much good” was being done."},{"number":2,"category":"religion","header":"A mission wedding among the Cherokee","body":"On November 17, 1822, Blunt married fellow teacher Harriet Ellsworth at Brainerd Mission Church — one of the earliest recorded white weddings in Cherokee territory south of the Tennessee River. The couple raised their family at the mission station until illness forced a move in 1837."},{"number":3,"category":"migration","header":"He walked part of the Trail of Tears","body":"When the Cherokee were forced west in 1838, Blunt accompanied them on the Trail of Tears as far as the Mississippi before illness turned him back. He afterward bought part of the former mission property to protect the cemetery where converts and missionaries lay buried."},{"number":4,"category":"politics","header":"From mission farmer to a town’s first mayor","body":"Resettling at Cross Plains, Georgia, Blunt became its first postmaster and, when the town was incorporated as Dalton in 1847, its first mayor. He helped found the First Presbyterian Church there and built, in 1848, the town’s first two-story house."},{"number":5,"category":"character","header":"His house became a Union hospital","body":"The 1848 Blunt House sheltered Confederate General Joseph E. Johnston and his staff in 1863–64, then served as a Union field hospital after the army pushed toward Atlanta. The family refugeed to Illinois in 1864 and returned after the war; Blunt died the following December."}],"sources":[{"short":"Wikipedia","notes":"Ainsworth Blunt article"}],"research_sources":[],"notable":{"is_notable":true,"notable_category":["religion","politics"],"notable_blurb":"Brainerd Mission teacher; fi