w Jersey","body":"His wife Rhoda Ogden was sister of Aaron Ogden (Governor of New Jersey 1812-1813) and Matthias Ogden, a lieutenant colonel who marched to Quebec with Benedict Arnold in 1775. Through her, the Edwards-Hooker line connected to early New Jersey political and military leadership."},{"number":3,"category":"family","header":"Daughter Phebe married a Hooker — double convergence","body":"His daughter Phebe Edwards married Rev. Asahel Hooker — both descended from Thomas Hooker, creating a double Hooker convergence in their children. Phebe's path back went through her mother Sarah Pierpont Edwards; Asahel's through the main Hartford Hooker line."}],"slug":"timothy-edwards-1738"},"X00709":{"id":"X00709","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1741,"month":9,"day":28,"city":"Elizabethtown","state":"New Jersey"},"death":{"year":1822,"month":11,"day":2,"city":"Litchfield","state":"Connecticut"},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00381","children_ids":["H00936","H00937","H00938","H00939","H00940","H00941","H00942","H00943","H00944","H00945","H00946","H00947","H00948","H00949"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Rhoda Ogden","first_name":"Rhoda","maiden_name":"Ogden","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"rhoda-ogden-1741"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}