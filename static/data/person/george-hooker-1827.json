","first_name":"Henrietta","middle_name":"Edgecomb","last_name":"Hooker","married_names":[],"gender":"female","display_name":"Prof. Henrietta Edgecomb Hooker","photo_url":"https://www.wikitree.com/photo.php/7/72/Hooker-4321.png","photo_notes":"WikiTree photo."},"birth":{"year":1851,"month":12,"day":12,"city":"Gardiner","county":"Kennebec County","state":"Maine","country":"United States"},"death":{"year":1929,"month":5,"day":13,"city":"Holyoke","county":"Hampden County","state":"Massachusetts","country":"United States"},"parents":{"father_id":"H03671","mother_id":"X02171"},"number_of_marriages":0,"marriages":[],"education":[{"institution_id":"INST092","degree":"PhB / BA","start_year":1871,"end_year":1873,"notes":"Entered 1871; graduated 1873."},{"institution_name":"Massachusetts Institute of Technology","degree":"graduate study"},{"institution_name":"Syracuse University","degree":"PhM"},{"institution_name":"Syracuse University","degree":"Ph.D. botany","end_year":1889,"notes":"Dissertation on the parasitic vine Cuscuta gronovii. Among the first women to earn a Ph.D. in botany at any U.S. university; second female doctoral graduate in botany at Syracuse."},{"institution_name":"University of Berlin","degree":"graduate study"},{"institution_name":"University of Chicago","degree":"graduate study"},{"institution_id":"INST092","degree":"Sc.D. (honorary)","end_year":1923,"notes":"Honorary Doctor of Science from Mount Holyoke College, 1923."}],"career":[{"role":"Public school teacher","organization":"Vermont public schools","start_year":1869,"end_year":1870},{"role":"Teacher","organization":"Academy of West Charleston","start_year":1870,"end_year":1871},{"role":"Faculty / Teacher of botany","organization":"Mount Holyoke Seminary and College","start_year":1873,"end_year":1904,"notes":"Joined Mount Holyoke as a faculty member after her 1873 graduation. Worked alongside her former teacher Lydia Shattuck and zoologist Cornelia Clapp."},{"role":"Professor of botany / Department chair","organization":"Mount Holyoke College","start_year":1904,"end_year":1908,"notes":"As chair, advocated for expansion of the curriculum and improvements to laboratory space and equipment. Research focused on the morphology and embryology of Cuscuta, a genus of parasitic plants."},{"role":"Professor emeritus","organization":"Mount Holyoke College","start_year":1908,"end_year":1929,"notes":"Continued involvement after retirement. Bred prize-winning Buff Orpington chickens and donated the winnings to the school."}],"tags":["educator","academic","botanist","phd","mount_holyoke","mt_holyoke_faculty","women_in_stem"],"sources":[{"short":"Edward Hooker 1909, entry 4934"},{"short":"Wikipedia — Henrietta Hooker"},{"short":"NYT obituary May 14, 1929"},{"short":"Mount Holyoke College records"}],"notable":{"is_notable":true,"notable_blurb":"Mount Holyoke botany professor with Syracuse PhD","notable_category":["academic","science"],"primary_url":"https://en.wikipedia.org/wiki/Henrietta_Hooker","primary_url_label":"Wikipedia"},"narrative_blocks":[{"number":1,"category":"education","header":"Orphaned at seven, factory worker by sixteen","body":"Henrietta was orphaned at age seven when both parents died (her father George Washington Hooker died Feb 1853 when she was 14 months old; her mother Eliza Ballentine died before 1858). At age 16 in 1867 she began work at a New England cotton factory; after a single week she sought help finding different work. She taught Vermont public schools 1869-1870 before entering Mount Holyoke Female Seminary in 1871, graduating in 1873."},{"number":2,"category":"education","header":"Among earliest American women botany PhDs","body":"Henrietta earned her Ph.D. in botany from Syracuse University in 1889 with a dissertation on the parasitic vine Cuscuta gronovii. She was the second female doctoral graduate in botany at Syracuse — among the first women in the United States to earn a Ph.D. in botany at any university. She also did graduate work at MIT, the University of Berlin, and the University of Chicago."},{"number":3,"category":"career","header":"Thirty-five years teaching botany at Mount Holyoke","body":"Henrietta joined the Mount Holyoke faculty after her 1873 graduation and taught there for thirty-five years. She worked alongside her former teacher Lydia Shattuck and zoologist Cornelia Clapp. By 1899 she was one of only two Mount Holyoke teachers with a Ph.D. (the other being Clapp)."},{"number":4,"category":"legacy","header":"Hooker Auditorium at Mount Holyoke bears her name","body":"Mount Holyoke awarded Henrietta an honorary Sc.D. in 1923, fifteen years after her 1908 retirement. The college's Hooker Auditorium — a theater building near the Mount Holyoke College Art Museum — was named in her honor. Even in retirement she remained committed to the school: she bred prize-winning Buff Orpington chickens and donated the winnings to Mount Holyoke."}],"cross_connections":[],"cross_reference":{"edward_hooker_1909":"4934"},"landmarks":[{"landmark_id":"LM053","landmark_blurb":"Mount Holyoke auditorium named in her honor."}],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST092","relationship":"alumnus"}],"artworks":[],"quotes":[],"military_service":[],"slug":"henrietta-hooker-1851"},"H02133":{"id":"H02133","former_ids":[],"is_placeholder":false,"gender":"male","has_descendants_documented":true,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"is_easter_egg":false,"include_in_path_calculation":true,"descent_from_thomas_hooker":true},"bio":{"first_name":"Samuel","last_name":"Hooker","married_names":[],"gender":"male","display_name":"Samuel Hooker"},"birth":{"year":1800,"month":10,"day":30,"city":"Litchfield","county":"Kennebec County","state":"Maine","country":"United States"},"death":{"year":1873,"month":7,"day":15