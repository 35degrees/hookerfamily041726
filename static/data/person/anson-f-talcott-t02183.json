oss_connections":[],"bio":{"display_name":"Abigail Huntington","first_name":"Abigail","last_name":"Huntington","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"abigail-huntington"}},"burialCemetery":null,"institutionsById":{"INST080":{"id":"INST080","primary_name":"Granite Mills","name":"Granite Mills","short_name":"Granite Mills","alt_names":[],"type":"mill","founding_year":1838,"location":{"city":"Vernon","county":"Tolland County","state":"Connecticut","country":"United States","address":"Just above Kelly Road, on the Hockanum River, Talcottville"},"primary_url":"https://www.tankerhoosen.info/history/mill_granite.htm","primary_persons":["T01052"],"hooker_connected_people":["T01052","T01935","T02183"],"person_ids":[],"related_institutions":[],"related_landmarks":[],"tags":[],"sources":[],"notes":"Paper mill on the Hockanum River just above Kelly Road, Talcottville (Vernon) CT. GPS: 41.83210° N, 72.49648° W. Founded by T01052 Samuel Smith Talcott (1793-1882) as a linseed oil mill c.1838; converted to paper manufacturing after an 1863 fire. Manufactured albums, binders, boards, manilla and press papers — recycling old paper purchased in bales from New York, Boston, and Philadelphia. Destroyed by fire four times (1863, 1870, 1881, 1912) and rebuilt each time until the final 1912 fire. The 1881 fire article names owners as \"Smith S. and Anson F. Talcott.\" Smith Stephen Talcott (1834-1888) — likely a son of T01052 Samuel — served as active agent from c.1864; he and T01052 ran the mill in parallel (\"particularly confusing are the roles of the two S. S. Talcotts\"). The Talcott Brothers (Charles Denison and Horace Wells) purchased the mill site in December 1912 primarily to acquire the water privilege. Despite the Talcott name, the Granite Mills Talcotts were from a different branch than the Talcottville mill owners. Site today: land between Tri-City Plaza and Hockanum River near Kelly Road; race exit from foundation preserved. Royal Talcott Journal, Nov 26, 1877: \"young Nickols... got his foot caught in the belt\" — earliest direct eyewitness account in the Royal Talcott Journal. SOURCE: Tankerhoosen Valley History, \"Granite Mills (Circa 1850-1912).\"\n[former/alt detail] Also known as: Granite Paper Mills, Talcottville Paper Mill"}},"crossConnections":[{"type":"business_connection","related_id":"T01052","link_text":"Samuel Smith Talcott","display_label":"Co-owned the Granite Mills in Talcottville at the time of the 1881 fire.","slug":"samuel-talcott-1793"}]}