ale","display_name":"George Hooker Strong"},"birth":{"year":1871,"state":"Kansas","country":"United States"},"baptism":{},"death":{"year":1938,"month":10,"day":31,"city":"Altoona","county":"Blair County","state":"Pennsylvania","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM477","plot_notes":"Green Mount Cemetery West Goshen Township Chester County per FA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"generation_from_john_talcott":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H02020","mother_id":"I00958"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00959","date_year":1898,"date_month":5,"date_day":12,"location_city":"Sedalia","location_state":"Missouri","location_country":"United States","children_ids":["HD4707","HD4706","HD4708"]}],"education":[],"career":[{"role":"Expert Accountant","organization":"Connected with Lukens Steel, Coatesville, Pennsylvania","end_year":1938,"notes":"Active member of Presbyterian Church; board of deacons. Per FA memorial."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Hooker","inspired_by_id":"H00001","description":"Middle name 'Hooker' honors the family's Hooker ancestry — his grandmother Dolly Goodwin Hooker Strong brought the Hooker name into the Strong family when she married Elisha Beebe Strong in 1813."}],"artworks":[],"tags":["named_for_hooker","accountant"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Named Hooker; his daughter married her Hooker cousin","body":"George Hooker Strong was named for his grandmother Dolly Goodwin Hooker Strong, who had brought the Hooker name into the Strong family through her 1813 marriage to Elisha Beebe Strong — and he carried that name west from Kansas, where he was born in 1871, to Pennsylvania, where he worked as an accountant connected to Lukens Steel in Coatesville and served on the board of deacons of the Presbyterian Church. He died in Altoona, Pennsylvania in 1938, outlived by a daughter and a grandson who carried the Hooker name into the Vietnam War."},{"number":2,"category":"career","header":"An accountant connected with Lukens Steel in Pennsylvania","body":"George Hooker Strong settled in Chester County, Pennsylvania, where he worked as an expert accountant connected with Lukens Steel — the Coatesville ironworks that had been rolling armor plate since the Civil War and would become one of the nation's most storied steel producers, known for the plates that built American warships and later for pioneering stainless steel production. He was an active member of the Presbyterian Church and served on the board of deacons, maintaining the denominational tradition of his grandfather George Parish Strong and the broader Hooker family's Congregationalist and Presbyterian roots."},{"number":3,"category":"family","header":"His son Henry also bore the name Hooker","body":"George Hooker Strong named his son Henry Hooker Strong (born 1901), carrying the name into yet another generation of the Strong family, four generations removed from Dolly Goodwin Hooker Strong who first brought it into the Strongs through her 1813 marriage to Elisha Beebe Strong. Henry Hooker Strong's own son, Captain Henry Hooker Strong Jr., also bore the name — making it five consecutive generations of Hooker-named Strongs, ending with a Navy Skyhawk pilot shot down over North Vietnam in 1972."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"FindAGrave","url":"https://www.findagrave.com"},{"label":"FamilySearch","url":"https://www.familysearch.org"}],"research_sources":[],"documents":[],"slug":"george-strong-1871"},"I00959":{"id":"I00959","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Nettie","middle_name":"Fern","last_name":"Strong","maiden_name":"Mertz","married_names":["Strong"],"gender":"female","display_name":"Nettie Fern Mertz Strong"},"birth":{"year":1874,"month":7,"day":10,"city":"Sedalia","county":"Pettis County","state":"Missouri","country":"United States"},"baptism":{},"death":{"year":1935,"month":8,"day":4,"city":"West Chester","county":"Chester County","state":"Pennsylvania","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM477","plot_notes":"Green Mount Cemetery West Goshen Township Chester County per FA"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4697","date_year":1898,"date_month":5,"date_day":12,"location_city":"Sedalia","location_state":"Missouri","location_country":"United States","children_ids":["HD4707","HD4706","HD4708"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"FamilySearch","url":"https://www.familysearch.org"}],"research_sources":[],"documents":[],"slug":"nettie-mertz-1874"},"H02020":{"id":"H02020","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"George","middle_name":"Parish","last_name":"Strong","married_names":[],"gender":"male","display_name":"George Parish Strong"},"b