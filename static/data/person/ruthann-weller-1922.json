ce":{"country":"United States"},"burial":{"cemetery_id":"CEM469","plot_notes":"Crown Hill Cemetery Indianapolis per FA; died Kansas City MO Nov 1924"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H02020","date_year":1847,"date_month":9,"date_day":5,"location_city":"Washtenaw","location_state":"Michigan","location_country":"United States","children_ids":["HD4697","HD4698","HD4699"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["extraordinary_longevity"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"character","header":"Born in 1830; outlived all her children","body":"Henrietta Theresa Parsons Strong was born in Michigan in 1830 and died in Kansas City, Missouri in November 1924 at age ninety-three — surviving her husband George Parish Strong by thirty-seven years, the Civil War, two children who predeceased her, and the first World War, her life spanning virtually the entire arc of American expansion from the frontier Michigan of Andrew Jackson's presidency to the Model T era. She was buried at Crown Hill Cemetery in Indianapolis — the same cemetery that holds the tomb of President Benjamin Harrison — a woman who had watched three American generations unfold from a Michigan farm to a Missouri city, buried in a cemetery more famous for a president she had outlived."}],"quotes":[],"sources":[{"label":"FamilySearch","url":"https://www.familysearch.org"}],"research_sources":[],"documents":[],"slug":"henrietta-parsons-1830"}},"burialCemetery":{"id":"CEM477","name":"Green Mount Cemetery","locat