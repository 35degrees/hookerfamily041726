ward Cole"}],"narrative_blocks":[{"number":1,"category":"career","header":"Served Berlin schools twenty years and legislature twice","body":"Justus Newton Perrin served as Berlin Vermont's superintendent of schools for more than twenty years and represented the town twice in the Vermont state legislature. He balanced public service with running the family dairy farm, where his fifteen-year-old son Porter Elisha documented the operation in an 1874 diary now held by the Vermont Historical Society."},{"number":2,"category":"family","header":"Outlived two wives and reached ninety-one","body":"Justus's first wife Arethusa Hosford died in 1855 at age thirty, leaving him with two young daughters. He remarried in 1858 to Mary Wild and had five more children. He lived to ninety-one and is buried at Berlin Corner Cemetery alongside generations of his Perrin and Talcott ancestors."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"justus-perrin-1822"},"X02410":{"id":"X02410","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Mary","last_name":"Perrin","maiden_name":"Wild","married_names":["Perrin"],"gender":"female","display_name":"Mary Wild Perrin"},"birth":{"year":1827,"month":4,"day":22,"city":"West Fairlee","county":"Orange","state":"Vermont","country":"United States"},"baptism":{},"death":{"year":1909,"month":3,"day":19,"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"residence":{"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[