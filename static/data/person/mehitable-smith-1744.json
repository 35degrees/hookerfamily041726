0","H00331"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 109"},{"short":"Smith-Hooker Genealogy by Della Bishop, 1936"},{"short":"Yale Biographical Sketches 1701-1745 (1885)","page":"359"}],"gender":"male","tags":["yale_graduate","physician","minister"],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["physician","minister"],"notable_blurb":"Physician-minister at White Plains for thirty years","primary_url":"https://www.findagrave.com/memorial/62188479/john-smith","primary_url_label":"FindAGrave"},"cross_connections":[{"type":"historical_connection","related_id":"X00128","display_label":"Young friend in New York who drew him toward the ministry","link_text":"Jonathan Edwards"}],"education":[{"school_name":"Yale College","graduation_year":1727,"institution_id":"INST022"}],"bio":{"title":"Rev. Dr.","display_name":"Rev. Dr. John Smith","first_name":"John","last_name":"Smith","married_names":[],"gender":"male"},"residence":{"city":"White Plains","county":"Westchester","state":"New York","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1727"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Physician","organization":"Rye and White Plains, NY","end_year":1771,"notes":"Practiced medicine alongside ministry for nearly 30 years. 'Said to have been a very successful physician... remarkably successful in cases of insanity.'"},{"role":"Presbyterian Minister","organization":"White Plains Presbyterian Church","end_year":1771,"notes":"Served the White Plains church which was destroyed in the Battle of White Plains October 1776, seven years after his death."}],"narrative_blocks":[{"number":1,"category":"relationships","header":"Walked the Hudson with Jonathan Edwards as friend","body":"He was a personal friend of Jonathan Edwards, the most important American theologian of the eighteenth century. On one occasion, walking together along the banks of the Hudson, Smith confided to Edwards: 'To be separated from my endeared friends and companions are the most bitter trials of my life.' The friendship spanned Smith's quarter-century at White Plains and Edwards's career through Northampton, Stockbridge, and Princeton."},{"number":2,"category":"career","header":"Physician and Presbyterian minister for thirty years","body":"He practiced medicine and ministry simultaneously at Rye and White Plains for nearly thirty years — a rare dual vocation in colonial America. Contemporaries described him as 'remarkably successful in cases of insanity.' His Yale class of 1727 trained him for ministry; the medicine he taught himself."},{"number":3,"category":"historical","header":"His church destroyed at Battle of White Plains","body":"Seven years after his death in 1771, the Battle of White Plains was fought in front of his Presbyterian church on Oct 28, 1776 — and the building was destroyed. A second church on the same ground was later destroyed by fire. The third — built of gray stone — was eventually extended over his grave, and the original upright slab was moved further back."},{"number":4,"category":"clergy","header":"A church was later built over his grave","body":"Rev. Dr. John Smith served nearly thirty years as Presbyterian minister at Rye and White Plains. After his death the White Plains meetinghouse was rebuilt over his burial spot, and his gravestone was moved back to accommodate it."}],"slug":"john-smith-1702"},"H00109":{"id":"H00109","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1704,"month":5,"day":10,"city":"Guilford","state":"Connecticut"},"parents":{"father_id":"H00031","mother_id":"I00061"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 109"},{"short":"Smith-Hooker Genealogy by Della Bishop, 1936, Ithaca NY"}],"death":{"year":1775,"month":9,"day":5,"city":"White Plains","state":"New York"},"marriages":[{"spouse_id":"I00140","children_ids":["H00320","H00321","H00322","H00323","H00324","H00325","H00326","H00327","H00328","H00329","H00330","H00331"],"marriage_number":1,"date_year":1724,"date_month":5,"date_day":6,"location_city":"Guilford","location_state":"Connecticut"}],"cross_connections":[{"type":"family_connection","related_id":"H00757","display_label":"Mehitable Hooker Smith is the great-grandmother of Maj. Benjamin Tallmadge.","link_text":"Maj. Benjamin Tallmadge Jr."}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Mehitable Hooker Smith","notes":"Also called \"Mabel\" per EH","first_name":"Mehitable","last_name":"Smith","married_names":["Smith"],"maiden_name":"Hooker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Twelve children with Rev. John Smith of Rye","body":"She married Rev. John Smith of Rye, New York, and had twelve children between 1727 and 1750. The family lived in Westchester County during the years just before the Revolution turned that border country into a no-man's land."},{"number":2,"category":"family","header":"Great-grandmother of Washington's spymaster","body":"Her great-grandson Major Benjamin Tallmadge ran the Culper Ring for George Washington — the network that exposed Benedict Arnold's 1780 treason. Tallmadge was a classmate of Nathan Hale and a fellow Hooker descendant."},{"number":3,"category":"family","header":"Daughter Abigail at Washington's White Plains headquarters","body":"Her daughter Abigail Smith married Jacob Purdy, whose Purchase, NY house served as Washington's headquarters during the Battle of White Plains in 1776 and again in 1778. The Purdy descendants would carry the line through several Patriot–Loyalist conflicts."},{"number":4,"category":"family","header":"She and her sister married two Smith brothers","body":"Mehitable Hooker married Rev. Dr. John Smith of Rye. Her elder sister Hannah had married his brother Thomas, so two Hooker sisters wed two Smith brothers."}],"burial":{"cemetery_id":"CEM579","plot_notes":"First Presbyterian Church Cemetery, White Plains NY. SOURCE: FindAGrave."},"slug":"mehitable-smith-1704"},"H00031":{"id":"H00031","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":3,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1666,"month":10,"day":27,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1740,"month":3,"day":12,"city":"Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00007","mother_id":"I00006"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 31"}],"marriages":[{"marriage_number":1,"spouse_id":"I00061","date_year":1691,"date_month":8,"date_day":1,"location_city":"Guilford","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1740,"children_ids":["H00105","H00106","H00107","H00108","H00109"]}],"burial":{"cemetery_id":"CEM012"},"cross_connections":[{"type":"family_connection","related_id":"X00067","display_label":"Governor of New Haven and Connecticut colonies","link_text":"Gov. William Leete"},{"type":"in_law","related_id":"X00065","display_label":"was his father-in-law; son of Governor William Leete"}],"gender":"male","tags":["politician","judge"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"marriage","header":"He married the granddaughter of Governor William Leete","body":"Mary Leete was the daughter of William Leete Jr. and the granddaughter of Governor William Leete — the only man to govern both New Haven Colony and the Colony of Connecticut. James Hooker, born a Farmington pastor's son, married into one of the most distinguished families in colonial Connecticut."},{"number":2,"category":"politics","header":"First Probate Judge — presided over the Assembly","body":"He became the first Probate Judge of the Guilford district and repeatedly represented Guilford in the Colonial Assembly, serving for a number of sessions as its presiding officer. EH notes he \"became a very prominent man at Guilford.\""},{"number":3,"category":"family","header":"His only son died at 21, name extinct","body":"EH notes he \"had but one son who died unmarried, leaving no one to perpetuate his name.\" That son was William, Yale class of 1722, who died at 21."}],"career":[{"role":"Probate Judge","organization":"Guilford District","notes":"First judge of the Guilford probate district; also a town magistrate."},{"role":"Representative","organization":"Connecticut Assembly","notes":"Repeatedly represented Guilford; presiding officer for several sessions."}],"bio":{"display_name":"Hon. James Hooker","title":"Honorable","first_name":"James","last_name":"Hooker","married_names":[],"bio_blurb":"First probate judge of the Guilford district"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"james-hooker-1666"},"I00061":{"id":"I00061","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1672,"month":1,"day":11,"city":"Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1752,"month":10,"day":5,"city":"Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"parents":{"father_id":"X00065","mother_id":"X00066"},"marriages":[{"spouse_id":"H00031","children_ids":["H00105","H00106","H00107","H00108","H00109"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 31"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Granddaughter of Gov. William Leete","primary_url":"https://en.wikipedia.org/wiki/William_Leete","primary_url_label":"Wikipedia (grandfather)"},"cross_connections":[{"type":"parallel_marriage","related_id":"I00119","display_label":"First cousins — both Leete granddaughters who married Hooker men.","link_text":"Mercy Leete Hooker"}],"narrative_blocks":[{"number":1,"category":"family","header":"Granddaughter of Governor William Leete","body":"Her father was William Leete Jr., son of Governor William Leete — the only man to govern both New Haven Colony and Colony of Connecticut. Her first cousin Mercy Leete (daughter of her uncle Andrew) also married a Hooker man. Two of the Governor's granddaughters, through different sons, both married into the Hooker family."},{"number":2,"category":"family","header":"Granddaughter of a Connecticut governor","body":"Mary Leete was a granddaughter of Gov. William Leete, who governed both the New Haven and Connecticut colonies. She married Judge James Hooker in 1691 and they settled at Guilford."}],"bio":{"display_name":"Mary Leete Hooker","first_name":"Mary","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Leete"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"buria