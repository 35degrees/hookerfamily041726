:[],"slug":"jacqueline-parsons-1929"},"H03720":{"id":"H03720","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Edward","middle_name":"Kirtland","last_name":"Fowler","married_names":[],"gender":"male","display_name":"Edward Kirtland Fowler"},"birth":{"year":1832,"month":8,"day":11,"city":"Churchville","state":"New York","country":"United States"},"baptism":{},"death":{"year":1898,"month":6,"day":27,"city":"Coe Township","state":"Michigan","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM208","plot_notes":"Oak Grove Cemetery, St. Louis Gratiot County MI. Per Abel Fowler genealogy."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"X02653","mother_id":"H02242"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02661","date_year":1861,"date_month":6,"date_day":30,"location_country":"United States","end_type":"death","end_year":1898,"children_ids":["HD3509","HD3510","HD3511","HD3512"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Kirtland","inspired_by_id":"X02649","description":"Carries his maternal grandmother Lucilla Kirtland Gridley's maiden surname as middle name."}],"artworks":[],"tags":["michigan_migration","new_york_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Carries his grandmother's maiden surname","body":"Edward's middle name 'Kirtland' came from his maternal grandmother Lucilla Kirtland Gridley — the same surname his uncle John Kirtland Gridley had inherited as a middle name