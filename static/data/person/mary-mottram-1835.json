ation":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"danger","header":"Survived nine bullets through hat and clothing","body":"Two weeks after he repelled a Confederate band attempting to free prisoners at Independence MO, five mounted armed rebels attacked him on Kansas City streets. In the hand-to-hand fight 'nine balls' went 'through his hat and clothing that did not strike his person'; he shot one attacker before falling seriously wounded himself."},{"number":2,"category":"military","header":"Pursued Quantrill after the Lawrence massacre","body":"He was present in the aftermath of Quantrill's August 1863 raid on Lawrence Kansas — where 150 unarmed men and boys were murdered — and participated in the pursuit of the Confederate guerrillas across the Kansas-Missouri border."},{"number":3,"category":"military","header":"Daily skirmishes with Quantrill in 1862 Missouri","body":"Commanding the 6th Kansas Cavalry as senior Major, he held Confederate guerrillas in western Missouri at bay through 1862 — daily skirmishes with William Quantrill, George Todd, Dick Yeager, and Parker. The summer was 'almost daily fights' per his 1903 family memoir."},{"number":4,"category":"family","header":"Secretary to his Michigan-governor father, 1849","body":"His father Epaphroditus Ransom served as Governor of Michigan; the son served as his personal secretary 1849. The family had emigrated from Vermont to Michigan in October 1834 when Wyllys was six."}],"slug":"wyllys-ransom-1828"},"HD2690":{"id":"HD2690","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":10,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2683","mother_id":"X00913"},"tags":["railroad","unusual_death"],"sources":[],"birth":{"year":1857,"month":10},"death":{"year":1894,"month":1},"marriages":[{"spouse_id":"X00919","children_ids":["HD2691","HD2692","HD2694"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"William Epaphroditus Ransom","first_name":"William","last_name":"Ransom","middle_name":"Epaphroditus","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"death","header":"Railroad detective killed after train-robber scuffle","body":"William Epaphroditus Ransom was a Union Pacific Railroad detective. While investigating train robberies near Wahoo Nebraska in January 1894, he confronted a thief breaking into a box car; in the resulting scuffle the burglar was shot dead and Ransom was 'thrown or slipped upon the end of a tie' and injured his head. He seemed not badly hurt at first."},{"number":2,"category":"death","header":"Brain fever onset; out of mind until death","body":"Alarming symptoms of brain fever soon developed after his head injury. Ransom was admitted to Saint Joseph's Hospital in Omaha and was 'continually out of his mind' until his death on January 29, 1894 at age thirty-six. The head-injury-to-brain-fever sequence reflected the era's limited understanding of post-traumatic intracranial complications."},{"number":3,"category":"death","header":"Brother Arthur also died in same year","body":"William's brother Arthur Ransom also died in April 1894 — both Ransom sons dead within three months. The compressed double family loss across two siblings in one year captured the kind of unrelated tragedy that occasionally swept through American families of the Gilded Age. William was survived by his wife Josephine E. Pierce and three children."},{"number":4,"category":"career","header":"Ten years with Union Pacific Railroad","body":"Ransom was connected with the Union Pacific Railroad for ten years before his death — first as chief clerk to the superintendent, then in the law and claims departments. He was 'well liked' and described as 'one of the best known young railroad men in town.' Born October 27, 1857 in Lecompton Douglas County Kansas, he is buried at Mountain Home Cemetery in Kalamazoo Michigan."}],"slug":"william-ransom-1857"},"X00919":{"id":"X00919","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1859,"month":11,"day":19,"state":"Michigan","country":"United States"},"death":{"year":1925,"month":8,"day":16,"city":"Climax","county":"Kalamazoo County","state":"Michigan","country":"United States"},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2690","children_ids":["HD2691","HD2692","HD2694"]}],"parents":{"father_research_notes":"Isaac Pierce","mother_research_notes":"Emeline E. Bates"},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Josephine E. Pierce Ransom","first_name":"Josephine","last_name":"Ransom","maiden_name":"Pierce","middle_name":"E.","married_names":["Ransom"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"josephine-pierce-1859"},"HD2691":{"id":"HD2691","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":11,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2690","mother_id":"X00919"},"tags":[],"sourc