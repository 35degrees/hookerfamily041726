:[{"marriage_number":1,"spouse_id":"I00051","date_year":1698,"date_month":12,"date_day":28,"location_city":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1711,"children_ids":["H00110","H00111","H00112","H00113","H00114","H00115"]}],"burial":{"cemetery_id":"CEM003"},"cross_connections":[{"type":"family_connection","related_id":"T00042","display_label":"His daughter married her son, founding lines merged.","link_text":"Mary Talcott"}],"gender":"male","tags":["politician"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"marriage","header":"His bride had been promised to his brother","body":"Mary Standley had been betrothed to Nathaniel's brother Roger Hooker, who died April 29, 1698. Seven months later — December 28, 1698 — Nathaniel married her instead."},{"number":2,"category":"career","header":"His wedding gift was half of Main Street","body":"When Nathaniel married, his father-in-law Hon. Nathaniel Stanley gave him half his Hartford lot — extending from the Second Burial Ground to the little river. This became his place of business on the main street, just below the present Centre Church."},{"number":3,"category":"marriage","header":"Two different Stanley families both married Hooker brothers","body":"His brother John had married Abigail Standley of one Stanley family; Nathaniel married Mary Standley of a completely separate Stanley branch — Hon. Nathaniel Stanley of Hartford's line. Two unrelated families sharing the same name both converged on the Hooker brothers in the same generation."},{"number":4,"category":"politics","header":"Hartford's Colonial Assembly representative, dead at 40","body":"He represented Hartford in the Connecticut Colonial Assembly for several years. He died November 21, 1711, at age 40, still in office."},{"number":5,"category":"family","header":"His daughter married into the Talcott-Edwards line","body":"Hi