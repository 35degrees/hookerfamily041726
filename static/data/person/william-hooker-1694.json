_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1633,"month":11,"day":14,"city":"Cambridge (Newtowne)","state":"Massachusetts","country":"United States"},"death":{"year":1697,"month":11,"day":6,"city":"Farmington","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM004","plot_notes":"No stone survives. Well-attested tradition places the grave at the south side of Rev. Samuel Whitman's marked grave. \"Mr. Whitman like Mr. Hooker, died while the minister of the town, and tradition says he was buried by the side of Mr. Hooker.\""},"parents":{"father_id":"H00001","mother_id":"I00001"},"marriages":[{"spouse_id":"I00006","children_ids":["H00027","H00028","H00029","H00030","H00031","H00032","H00033","H00034","H00035","H00036","H00037"],"marriage_number":1,"date_year":1658,"date_month":9,"date_day":22}],"tags":["minister","harvard_graduate","clergy","compiler_ancestor"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 7"},{"short":"Flagg 1926","page":"p. 377"},{"short":"Sibley's Harvard Graduates","volume":"I","pages":"348-52"},{"short":"Woodward, W. \"New England's Other Witch-Hunt\"","notes":"Magazine of History 17:4 (July 2003): 16-19"},{"short":"Woodward, W. Prospero's America","notes":"John Winthrop Jr., Alchemy and the Creation of New England Culture, 1606-1676 (Homer Babbidge Prize)"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["religion"],"notable_blurb":"Eloquent second minister of Farmington","primary_url":"https://www.nativenortheastportal.com/bio/bibliography/hooker-samuel","primary_url_label":"Native Northeast Portal"},"narrative_blocks":[{"number":1,"category":"family","header":"He inherited his father's library — and his calling","body":"Thomas Hooker's will gave his library to John on condition that John pursue ministry; if John faltered, the entire library and manuscripts went to Samuel. John did not become a minister. Samuel received his father's books — and then dedicated his own life to the ministry his father had hoped for."},{"number":2,"category":"religion","header":"Prosecutor in the Hartford witch trials","body":"In the 1660s he formed a prosecutorial tribunal with Rev. Samuel Stone of Hartford and Rev. Joseph Haynes of Wethersfield. Connecticut tried witches more aggressively than Massachusetts in this decade — three decades before the Salem trials."},{"number":3,"category":"military","header":"Ordered to King Philip's War, then quietly replaced","body":"On March 9, 1675-6, the Council ordered Hooker to prepare to march into King Philip's War with Major Treat's army toward Hadley and Northampton. Two days later, the Council quietly replaced him with Rev. Israel Chauncy. No reason was recorded — only the substitution."},{"number":4,"category":"legacy","header":"He persuaded Farmington to found a free school","body":"In December 1685, the town of Farmington voted to give £30 for a schoolmaster for one year — and declared it a free school for the town, almost certainly at Hooker's instigation. It was among the earliest free public schools in colonial Connecticut."},{"number":5,"category":"character","header":"The 'Fervent Hooker,' who preached from the heart","body":"Rev. Pitkin described him as 'an excellent preacher, his composition good, his address pathetic, warm and engaging.' Hooker told a friend he had three things to do with his sermons before delivering them: write them, commit them to memory, and get them into his heart."}],"cross_connections":[{"type":"parallel_descent","related_id":"H00702","display_label":"Five Hooker generations on the same Farmington ground.","link_text":"Solomon Cowles"},{"type":"civic_peer","related_id":"I00003","display_label":"Farmington's first pastor, whom Hooker succeeded","link_text":"Rev. Roger Newton Sr."},{"type":"parallel_descent","related_id":"T00011","display_label":"His grandfather Tobie Willet sailed with John Talcott on the Lion.","link_text":"John Talcott"},{"type":"family_connection","related_id":"H00153","display_label":"Her husband's Prudden line connects to his wife Mary Willet's family","link_text":"Hannah Newton Prudden"},{"type":"in_law","related_id":"X00007","display_label":"was his father-in-law; First Mayor of New York City, 1665"}],"residence":{"city":"Farmington","state":"Connecticut","country":"United States"},"quotes":[{"text":"Thus we have to this day among us our dead Hooker, yet living in his worthy son Samuel Hooker, an able, faithful, useful minister at Farmington, in the Colony of Connecticut.","attribution":"Cotton Mather, Magnalia Christi Americana","category":"legacy"}],"career":[{"role":"Minister","organization":"Plymouth","start_year":1657,"end_year":1661},{"role":"Second Pastor","organization":"Farmington, Connecticut — INST005","start_year":1661,"end_year":1697,"notes":"Succeeded brother-in-law Roger Newton"}],"education":[{"institution_id":"INST002","dates":"1653","type":"graduation","notes":"B.A. 1653. Entered Harvard 1651. Chosen Fellow of the College November 27, 1654."}],"bio":{"title":"Reverend","display_name":"Rev. Samuel Hooker","nickname":"The Fervent Hooker","first_name":"Samuel","last_name":"Hooker","married_names":[]},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"}],"landmarks":[],"artworks":[],"military_service":[],"slug":"samuel-hooker-1633"},"I00006":{"id":"I00006","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1637,"month":11,"day":10,"city":"Plymouth","state":"Massachusetts","country":"United States"},"death":{"year":1712,"month":6,"day":24,"city":"Norwalk","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM002","plot_notes":"Near center of burying ground, near East Norwalk railway station"},"parents":{"father_id":"X00007","mother_id":"X00008"},"marriages":[{"spouse_id":"H00007","children_ids":["H00027","H00028","H00029","H00030","H00031","H00032","H00033","H00034","H00035","H00036","H00037"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1697,"date_year":1658,"date_month":9,"date_day":22},{"children_ids":[],"spouse_id":"X01001","marriage_number":2,"end_type":"death_of_spouse","end_year":1709,"date_year":1703,"date_month":8,"date_day":10,"location_city":"Saybrook","location_state":"Connecticut","location_country":"United States"}],"tags":[],"sources":[{"short":"Edward Hooker 1909"},{"short":"Flagg 1926","page":"p. 377"}],"gender":"female","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Daughter of New York City's first mayor","body":"Her father Capt. Thomas Willet was appointed the first Mayor of New York City in 1665, when the English renamed the Dutch colony. He had previously succeeded Capt. Miles Standish as commander of Plymouth's militia — one of the most storied military commands in early New England. Mary carried this distinguished lineage to Farmington when she married Rev. Samuel Hooker."},{"number":2,"category":"legacy","header":"Three generations of Willet women known for beauty","body":"Mary's mother was described as possessing 'beauty and majesty almost divine.' A portrait of Mary's daughter Mary Hooker Pierpont survives, and from it contemporaries formed 'the opinion that she was a woman of uncommon beauty.' Her daughter Sarah was 'accounted the most accomplished lady that had ever come to Norwalk.'"},{"number":3,"category":"marriage","header":"Remarried at 66 — outlived two minister husbands","body":"After Samuel Hooker's death in 1697, Mary married Reverend Thomas Buckingham of Saybrook at age 66. When he died in 1709 she moved to Norwalk to live with her son-in-law Reverend Stephen Buckingham, where she remained until her death in 1712 at age 74."},{"number":4,"category":"family","header":"She and her daughter married father and son","body":"After Rev. Samuel Hooker died, Mary Willet married Rev. Thomas Buckingham of Saybrook in 1703. Her daughter Sarah was the wife of his son, Rev. Stephen Buckingham, so a mother and daughter had married a father and his son."}],"cross_connections":[{"type":"parallel_descent","related_id":"T00011","display_label":"Her grandfather Tobie Willet sailed to New England with John Talcott.","link_text":"John Talcott"},{"type":"family_connection","related_id":"H00153","display_label":"Her father Thomas Willet's widow's first husband was ancestor of H00153's husband","link_text":"Hannah Newton Prudden"}],"bio":{"display_name":"Mary Willet Buckingham","first_name":"Mary","last_name":"Buckingham","married_names":["Hooker","Buckingham"],"maiden_name":"Willet"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-willet-1637"},"X00060":{"id":"X00060","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"city":"Middletown","state":"Connecticut"},"marriages":[{"spouse_id":"X00061","children_ids":["I00056"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 28"}],"gender":"male","tags":[],"number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"death":{},"cross_connections":[],"bio":{"title":"Captain","display_name":"Captain Giles Hamlin","first_name":"Giles","last_name":"Hamlin","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artwo