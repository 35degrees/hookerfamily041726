locks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"william-betts-1859"},"X01911":{"id":"X01911","has_descendants_documented":false,"is_placeholder":false,"gender":"male","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"birth":{"year":1752,"month":7,"day":7,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"death":{"year":1805,"month":1,"day":1,"city":"Bridgeport","county":"Fairfield County","state":"Connecticut","country":"United States"},"parents":{"father_research_notes":"Capt. John Cannon","mother_research_notes":"Esther Perry Cannon"},"marriages":[{"marriage_number":1,"spouse_id":"H01237","children_ids":["HD2793","HD2794","HD2795","HD2796","HD2797","HD2798","HD2799","HD2800"],"date_year":1777,"date_month":7,"location_city":"Norwalk","location_state":"Connecticut"}],"number_of_marriages":1,"tags":["bridgeport_founder","physician","slaveholder"],"sources":[{"short":"St. John Genealogy"}],"notable":{"is_notable":true,"notable_category":["civic_service"],"notable_blurb":"Bridgeport founder, physician, turnpike company founder"},"narrative_blocks":[{"header":"Co-founder of the Borough of Bridgeport","detail":"His estate was distributed in 1805 to his widow Sarah and their children. A note in the research suggests a John Cannon (possibly his son) founded the Bridgeport Bank in 1806 and served as its president from 1823 until 1827 — the probate timeline makes it likely this was the son John Jr. (HD2793) rather than the physician himself. In the 1790 US Census, one enslaved person was enumerated in his household. His daughter Antoinette married U.S. Senator Thaddeus Betts; his daughter Sarah married back into the St. John family. (St. John Genealogy; Bridgeport historical records)","body":"John Cannon Jr. moved from Norwalk to Bridgeport (then called Newfield) around 1790. He was involved in founding the Newfield Fire Company (1796), helped incorporate the Borough of Bridgeport (1800), and founded the Bridgeport & Newtown Turnpike Company (1801). With William Peet he ran a saddlery business as Cannon & Peet.","number":1,"category":"character"},{"number":2,"category":"business","header":"A saddler among Bridgeport’s founders","body":"With the tanner William Peet he ran the saddlery firm Cannon & Peet on Broad Street, then helped raise the subscription that bought Newfield its first fire engine in 1796 — fifteen dollars of his own among the names. He died in office as president of the Bridgeport Bank."},{"number":3,"category":"social_reform","header":"One enslaved person in his household","body":"The 1790 census enumerated one enslaved person in his Norwalk household; later Bridgeport records name a man, Cato Cannon, among those he held. The turnpike-builder and bank president was, like many Connecticut founders of his day, a slaveholder."}],"cross_connections":[{"type":"family_connection","related_id":"X02364","display_label":"shares a Peet family tie worth tracing","link_text":"William Creighton Peet Jr."}],"bio":{"display_name":"Doctor John Cannon Jr.","first_name":"John","last_name":"Cannon","title":"Doctor","married_names":[],"suffix":"Jr.","bio_blurb":"Physician and co-founder of Bridgeport"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Physician","location":"Norwalk, then Bridgeport"},{"role":"Saddler","organization":"Cannon & Peet","notes":"tannery on Broad Street, Bridgeport"},{"role":"President","organization":"Bridgeport Bank","start_year":1823,"end_year":1827},{"role":"Co-founder","organization":"Borough of Bridgeport","start_year":1800},{"role":"Founder","organization":"Bridgeport & Newtown Turnpike Co.","start_year":1801}],"slug":"john-cannon-jr-1752"},"H01237":{"id":"H01237","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00479","mother_id":"X00216"},"tags":[],"sources":[],"birth":{"year":1758,"month":1,"day":1},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X01911","children_ids":["HD2793","HD2794","HD2795","HD2796","HD2797","HD2798","HD2799","HD2800"],"date_year":1777,"date_month":7,"location_city":"Norwalk","location_state":"Connecticut"}],"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1825,"month":12,"day":22,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"cross_connections":[],"bio":{"display_name":"Sarah St. John Cannon","first_name":"Sarah","last_name":"Cannon","maiden_name":"St. John","middle_name":"St. John","married_names":["Cannon"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["HD0967"],"slug":"sarah-cannon-1758"},"H00479":{"id":"H00479","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1736,"city":"Norwalk","state":"Connecticut"},"parents":{"mother_id":"H00253","father_research_notes":"Capt. Joseph St. John of Norwalk","father_id":"X00215"},"tags":["revolutionary_war","slaveholder","moral_complexity"],"sources":[{"short":"Edward Hooker 1909","page":"H00253 branch"},{"label":"St. John Genealogy — entry 141","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"}],"death":{"year":1785,"month":5,"day":9,"city":"Norwalk","state":"Connecticut"},"political_offices":[{"title":"Selectman Norwalk","notes":"1763-64, 1766, 1772-73, 1775-78, 1782-84"},{"title":"Member CT House of Representatives","dates":"1778-1785"},{"title":"Major, 9th CT Regiment","dates":"May 1775"},{"title":"Lt. Colonel, 9th CT Militia","dates":"May 1777"},{"title":"Justice of the Peace","dates":"May 1777"}],"enslaved_persons":[{"name":"Peter","description":"Enslaved man. Listed in 1786 estate inventory."},{"name":"Phyllis","description":"Enslaved woman. Listed in 1786 estate inventory."}],"marriages":[{"spouse_id":"X00216","children_ids":["H01238","H01239","H01237","H01240","H01236"],"marriage_number":1,"date_year":1757,"date_month":12,"date_day":9}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"military_service":[{"war":"American Revolutionary War","rank":"Lt. Col.","unit":"9th Regiment, Connecticut Militia","notes":"Capt. 1st Co. Norwalk May 1761; Major 9th Regt. May 1775; Major 1st Batt. Col. Whiting Nov 1776; Lt. Col. 9th Regt. May 1777. On committee of Articles of Confederation 1777.","war_id":"WAR004"}],"bio":{"display_name":"Lt. Col. Stephen Saint John","first_name":"Stephen","last_name":"St. John","title":"Lieutenant Colonel","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778792414/stephenstjohnesq-resized_cvqbdg.png","photo_notes":"Portrait of Lt. Col. Stephen Saint John Esq.","bio_blurb":"Norwalk officer of the Connecticut 9th"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"former_ids":["HD0365"],"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave #44152495. Stone: 'Lt Col command of the 9th Reg of Foot Guard of the State of Connecticut who departed this life May the 9th 1785, in the 50th year of his age.'"},"narrative_blocks":[{"number":1,"category":"military","header":"Led Connecticut's 9th Regiment of Foot as Lt.","body":"Stephen Saint John rose to Lieutenant Colonel in command of the 9th Regiment of Foot, Guard of the State of Connecticut — a rank inscribed on his tombstone in East Norwalk Historical Cemetery. His family's marriage alliances connected two of Norwalk's most prominent dynasties: the Saint Johns married into the Fitches across two consecutive generations."},{"number":2,"category":"military","header":"He sent no substitute; his brother did","body":"A Connecticut selectman and Revolutionary officer, he led the colony’s 9th Regiment of Foot. When the war came, an enslaved man named Dover was sent to fight in the Continental Army in place of his brother — while his own household still held two people, Peter and Phyllis, at his death."}],"career":[{"role":"Selectman","organization":"Norwalk, Connecticut","notes":"1763-1784"},{"role":"Representative","organization":"Connecticut House","notes":"1778-1785"},{"role":"Lt. Colonel","organization":"9th Connecticut Regiment"}],"slug":"stephen-st-john-1736"},"X00216":{"id":"X00216","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"label":"St. John Genealogy (Alexander, 1907)","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"}],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00479","date_year":1757,"date_month":12,"date_day":9,"children_ids":["H01238","H01239","H01237","H01240","H01236"]}],"parents":{"father_name":"Hon. Samuel Fitch","mother_name":"Susannah Fitch","father_research_notes":"Per St. John Genealogy (Alexander 1907), entry 141: 'the dau. of Hon. Samuel and Susanna