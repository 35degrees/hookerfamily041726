in_path_calculation":true,"descent_from_thomas_hooker":true},"bio":{"first_name":"Coris","middle_name":"Ann","last_name":"Hodges","maiden_name":"Bartlett","married_names":["Hare","Hodges"],"extra_names":"Findagrave: 'Coris Ann Bartlett Hodges'; WikiTree: 'Corris A (Bartlett) Hare'","gender":"female","display_name":"Coris Ann Bartlett Hodges"},"birth":{"year":1843,"month":7,"day":21,"city":"Moriah","county":"Essex County","state":"New York","country":"United States"},"death":{"year":1927,"month":4,"day":6,"city":"Elkhorn","county":"Walworth County","state":"Wisconsin","country":"United States"},"parents":{"father_id":"HD0949","mother_id":"X02228"},"burial":{"plot_notes":"Mount Pleasant Cemetery, Tibbets, Walworth County WI (per Findagrave). Same as parents."},"number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"X02229","location_country":"United States","end_type":"death_of_spouse","children_ids":["HD3196","HD3197","HD3193","HD3198"]},{"marriage_number":2,"spouse_id":"X02230","location_country":"United States","children_ids":[]}],"tags":["wisconsin_migration"],"sources":[{"short":"Findagrave (Mount Pleasant Cemetery, Tibbets WI)"},{"short":"WikiTree (Corris A Bartlett Hare)"},{"short":"Walworth County 1882 history"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Second husband made superior-quality sorghum molasses","body":"After her first husband Levi Hare died, Coris Ann married William Hodges — a Wisconsin manufacturer known locally for his 'superior quality sorghum molasses,' the cane-syrup product that became a mid-nineteenth-century Northern alternative to slavery-produced Southern sugar. The Walworth County Wisconsin sorghum trade reached its peak during the 1860s-1880s as a documented anti-slavery agricultural economy. William Hodges's specific reputation for quality placed him among the regional leaders."},{"number":2,"category":"family","header":"Two marriages; four children with Levi Hare","body":"Coris Ann's first marriage to Levi Hare (born May 26, 1837 New York) produced four documented children. After Levi's death she married William Hodges without further documented children. The two-marriage household was typical of nineteenth-century American widows who remarried for economic and social support; her second marriage placed her in the sorghum-molasses trade economy of Walworth County Wisconsin."},{"number":3,"category":"family","header":"Moriah NY 1843 to Elkhorn Wisconsin 1927","body":"Coris Ann Bartlett was born July 21, 1843 in Moriah, Essex County New York — during her father Truman Bartlett's New York years before the family's 1844 migration to Wisconsin. She died April 6, 1927 in Elkhorn, Walworth County Wisconsin at age eighty-three. She is buried at Mount Pleasant Cemetery, Tibbets Wisconsin alongside her parents — a three-generation Wisconsin family cemetery cluster."}],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"coris-hodges-1843"},"HD0950":{"id":"HD0950","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD0436","mother_id":"X00206"},"tags":["wisconsin_migration"],"sources":[],"birth":{"year":1817},"death":{"year":1914},"gender":"female","marriages":[{"marriage_number":1,"spouse_id":"X01615","date_year":1838,"date_month":4,"date_day":28,"location_city":"Rutland","location_county":"Rutland County","location_state":"Vermont","location_country":"United States","end_type":"death_of_spouse","end_year":1868,"children_ids":["HD3200","HD3201","HD3195","HD3202","HD3203","HD3204","HD3206","HD3205","HD3207"]}],"number_of