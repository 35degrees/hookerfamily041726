,"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"“The Great Red Dragon” of the Revolution","primary_url":"https://boston1775.blogspot.com/2010/02/capt-william-coit-describes-his-ship.html","primary_url_label":"Boston 1775"},"education":[{"school_name":"Yale College","dates":"1761","type":"undergraduate"}],"military_service":[{"war":"American Revolutionary War","branch":"Continental Army then naval service","rank":"Captain","unit":"4th Company, 6th Connecticut Regiment; schooner Harrison; ship Oliver Cromwell","notes":"Covered the retreat at Bunker Hill; commanded the Harrison from Oct 1775 under Washington’s written instructions; later the privateer America; captured when Arnold burned New London, Sept 6, 1781"}],"bio":{"title":"Captain","display_name":"Captain William Coit","nickname":"The Great Red Dragon","notes":"Known for wearing a scarlet cloak","first_name":"William","last_name":"Coit","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1761"}],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"military","header":"Captain of one of America's first warships","body":"In late 1775 he commanded the schooner Harrison — one of the first vessels commissioned by Congress under General Washington. He intercepted two British supply ships and brought them into Plymouth harbor."},{"number":2,"category":"military","header":"Made British prisoners stand on Plymouth Rock","body":"He landed the captured British prisoners on Plymouth Rock, where they 'gave three cheers, and wished success to American arms,' per the Pennsylvania Journal of 1775. The act inverted Plymouth's founding myth: now British prisoners stood on the rock."},{"number":3,"category":"character","header":"The Great Red Dragon — scarlet cloak","body":"He was tall, portly, soldierly in bearing, frank, jovial, somewhat eccentric, and very liberal. He wore a scarlet cloak that earned him the nickname 'The Great Red Dragon.'"},{"number":4,"category":"military","header":"First American to invert the British flag","body":"He claimed to be 'the first man in the States who turned his majesty's bunting upside down' when he captured British vessels in late 1775. The symbolic act came early in the naval war."},{"number":5,"category":"military","header":"“Cohorns that Noah had in the Ark”","body":"His November 1775 letter savaged his own schooner: cannon “brought by the Lords Say and Seal” in 1635, swivels “never fired since” 1620, a deck that broke through over the magazine, smoke that “serves for bedding, victuals, drink and choking.” Firing both guns of a side, he wrote, would split her “from gunwale to her keelson.”"}],"slug":"william-coit-1742"},"X00114":{"id":"X00114","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1741,"month":1,"day":27,"city":"New London","state":"Connecticut"},"death":{"year":1813,"month":5,"day":18,"city":"New York","state":"New York"},"parents":{"mother_research_notes":"Sarah Christophers","father_research_notes":"Capt. John Prentiss of New London — commander of armed sloop \"Defence\" which convoyed 500 CT troops to Cape Breton 1745; died London Feb 1747"},"marriages":[{"spouse_id":"H00248","children_ids":["HD0347","HD0353","HD0348","HD0349","HD0351","HD0352","HD0354","HD0350"],"marriage_number":1}],"sources":[],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sarah Prentiss Coit","first_name":"Sarah","last_name":"Coit","married_names":["Coit"],"maiden_name":"Prentiss"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM866"},"narrative_blocks":[{"number":1,"category":"family","header":"Five daughters celebrated for their beauty","body":"The painter Samuel Waldo said her Esther had the handsomest face he ever painted; Ann died on the very day fixed for her wedding to Bishop Seabury’s eldest son. Widowed, Sarah moved to New York to live beside Esther, and lies near her in Trinity churchyard."}],"slug":"sarah-prentiss-1741"},"I00127":{"id":"I00127","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1698,"month":10,"day":25,"city":"New London","state":"Connecticut"},"death":{"year":1773,"month":7,"day":19,"city":"New London","state":"Connecticut"},"parents":{"mother_research_notes":"Sarah Chandler","father_research_notes":"William Coit of New London"},"political_offices":[{"title":"Town Clerk","jurisdiction":"New London, Connecticut","dates":"1736-1773","notes":"Re-elected every year except 1757 until his death — 36 years of service"}],"marriages":[{"children_ids":[],"spouse_id":"X01158","marriage_number":1,"end_type":"death_of_spouse","date_year":1721},{"spouse_id":"H00093","children_ids":["H00248","H00249","H00250","H00251","H00252"],"marriage_number":2,"end_type":"death_of_spouse","end_year":1763,"date_year":1742,"date_month":1,"date_day":21},{"children_ids":[],"spouse_id":"X01159","marriage_number":3,"date_year":1764}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 93"}],"gender":"male","tags":[],"number_of_marriages":3,"notable":{"is_notable":false,"notable_category":[],"notable_blurb":"Esquire, Hooker descendant"},"cross_connections":[],"bio":{"title":"Esquire","display_name":"Esq. Daniel Coit","first_name":"Daniel","last_name"