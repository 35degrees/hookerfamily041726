utions":[{"institution_id":"INST022","institution_blurb":"Yale College 1829; valedictorian elected unanimously by classmates."}],"tags":["abolitionist","educator","politician","senator","underground_railroad","yale_graduate"],"sources":[{"label":"Wikipedia — Francis Gillette","url":"https://en.wikipedia.org/wiki/Francis_Gillette"}],"notable":{"is_notable":true,"notable_category":["politics","social_reform"],"notable_blurb":"U.S. Senator Connecticut 1854-1855","primary_url":"https://en.wikipedia.org/wiki/Francis_Gillette","primary_url_label":"Wikipedia"},"narrative_blocks":[{"category":"politics","header":"He went from valedictorian to the Senate","body":"Gillette was elected valedictorian of Yale's class of 1829, then served in the Connecticut legislature before reaching Washington. He filled a United States Senate vacancy as a Free Soil man in 1854, in the thick of the slavery fight.","number":1},{"category":"social_reform","header":"His farmhouse sheltered the Underground Railroad","body":"Gillette ran an Underground Railroad station at his Bloomfield farm and helped found Connecticut's Republican Party. He was a silent partner in the Evening Press, the state's first Republican newspaper.","number":2},{"category":"family","header":"He built Nook Farm with John Hooker","body":"In 1853 Gillette and his brother-in-law John Hooker founded Nook Farm, the Hartford enclave that would draw Mark Twain and Harriet Beecher Stowe. His wife was Elisabeth Daggett Hooker.","number":3},{"category":"legacy","header":"His son became Sherlock Holmes on stage","body":"Gillette's son William Hooker Gillette grew into the celebrated actor who defined Sherlock Holmes for American audiences. Another son, Edward, went to Congress.","number":4}],"cross_connections":[{"type":"civic_peer","related_id":"H01626","display_label":"co-founded Nook Farm, drawing Twain and Stowe there","link_text":"John Hooker"}],"bio":{"display_name":"Sen. Francis Gillette","first_name":"Francis","last_name":"Gillette","married_names":[],"title":"Senator","photo_url":"https://upload.wikimedia.org/wikipedia/commons/6/69/Francis_Gillette%2C_Senator.jpg"},"landmarks":[{"landmark_id":"LM052","landmark_blurb":"Co-founder (from 1853); Co-founded Nook Farm with brother-in-law John Hooker."}],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"artworks":[],"quotes":[],"military_service":[],"slug":"francis-gillette-1807"},"H01625":{"id":"H01625","is_placeholder":false,"gender":"female","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1813,"month":5,"day":1,"city":"Farmington","state":"Connecticut"},"death":{"year":1893,"month":12,"day":16,"city":"Hartford","state":"Connecticut"},"parents":{"father_id":"H00630","mother_id":"X02036"},"marriages":[{"marriage_number":1,"spouse_id":"I00173","children_ids":["H02974","H02975","H02976","H02977","H02978","H02979"],"date_year":1834,"date_month":9,"date_day":10,"location_city":"Farmington","location_state":"Connecticut"}],"number_of_marriages":1,"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 01625"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"She married a Yale-educated senator who co-founded Nook","body":"Elisabeth Daggett Hooker married Francis Gillette in 1834 — a Yale valedictorian who later became a U.S. Senator and co-founded Hartford's Nook Farm community with her brother John. Every one of their five children who survived infancy carried 'Hooker' as a middle name: Ashbell Frank, Elisabeth Hooker, Edward Hooker, Robert Hooker, and William Hooker.","number":1}],"cross_connections":[],"bio":{"display_name":"Elisabeth Daggett Hooker Gillette","first_name":"Elisabeth","last_name":"Gillette","maiden_nam