y":"Scotch Plains","location_state":"New Jersey","location_country":"United States","end_type":"divorce","children_ids":[]},{"spouse_id":"X00887","children_ids":["HD2642","HD2643"],"marriage_number":2,"date_year":1800,"location_city":"Savannah","location_state":"Georgia"}],"gender":"female","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"family_orbit","related_id":"H00913","display_label":"Cousin raised together; Burr lodged at her Savannah home","link_text":"Aaron Burr Jr."}],"bio":{"display_name":"Maria Edwards","first_name":"Maria","maiden_name":"Edwards","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Aaron Burr negotiated her children's return from England","body":"Her first marriage at about fifteen to Sir Charles Rupert Dennis of England was disastrous; he treated her cruelly and they divorced. He abducted their children to England (13 Harley Street London) — her first cousin Aaron Burr Jr, with whom she had been raised, assisted in negotiating the children's return."},{"number":2,"category":"legacy","header":"Son organized illegal slave ship Wanderer, 1858","body":"Her son John Samuel de Montmollin II organized the illegal slave ship Wanderer in 1858 — a Charleston yacht refitted to smuggle 409 enslaved Africans into Georgia after the international slave trade had been banned for fifty years. Her own father Jonathan Edwards Jr had been among America's first abolitionists."},{"number":3,"category":"family","header":"Aaron Burr lodged at her Savannah home, 1802","body":"Vice President Aaron Burr — her first cousin and childhood housemate — lodged at the DeMontmollin house at 120 Oglethorpe Street Savannah in 1802 and again in 1807. The visits came during Burr's national political prominence and his subsequent flight from Eastern political circles after the Hamilton duel."},{"number":4,"category":"death","header":"Buried under maiden name Edwards to honor parents","body":"She died 1 September 1859 at Savannah Georgia and was buried at Laurel Grove Cemetery under the surname 'EDWARDS' — her birth name — chosen at death to honor her parents' memory. Her father Jonathan Edwards Jr and mother Mary Porter had both died when she was a young girl."}],"slug":"maria-edwards-1778"},"H00384":{"id":"H00384","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1745,"month":5,"day":26,"city":"Northampton","state":"Massachusetts"},"death":{"year":1801,"month":8,"day":1},"parents":{"father_id":"X00128","mother_id":"HD0418"},"tags":["abolitionist","minister","theologian","author","educator","indigenous_rights"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 384"}],"marriages":[{"spouse_id":"X00882","children_ids":["HD2623","HD2619","HD2620","HD2621","HD2622","HD2624","HD2625"],"marriage_number":1,"date_year":1770,"date_month":10,"date_day":4,"marriage_year":1770},{"spouse_id":"X00883","children_ids":[],"marriage_number":2,"date_year":1783,"date_month":12,"date_day":18}],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Abolitionist reformer","primary_url":"https://en.wikipedia.org/wiki/Jonathan_Edwards_(the_younger)"},"number_of_marriages":2,"artworks":["ART020"],"cross_connections":[],"bio":{"display_name":"Jonathan Edwards","first_name":"Jonathan","last_name":"Edwards","married_names":[],"photo_url":"https://tree-portraits-pgp.familysearchcdn.org/eyowi/thumb200s.jpg","bio_blurb":"Abolitionist minister; Mohican linguist"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"social_reform","header":"Among Princeton's only true abolitionists","body":"In 1773 he published antislavery articles in the Connecticut Journal under the pseudonym 'Antidoulios' — Greek for 'against slavery.' His 1791 sermon 'The Injustice and Impolicy of the Slave Trade' delivered antislavery from his New Haven pulpit."},{"number":2,"category":"legacy","header":"Mohican linguist — Washington thanked him personally","body":"He grew up in Stockbridge speaking Mohican before English, writing that 'it became more familiar to me than my mother tongue.' His 1788 'Observations on the Language of the Muhhekaneew Indians' was acknowledged by George Washington and circulated through Madison to Jefferson."},{"number":3,"category":"family","header":"His first wife drowned at New Haven 1782","body":"His first wife Mary Porter died June 10, 1782 in New Haven by drowning, leaving four children. He remarried in December 1783 to Mary Sabins, with whom he had no further children."},{"number":4,"category":"death","header":"Died as president of Union College, 1801","body":"In May 1799 he was chosen President of Union College in Schenectady, New York. He served less than two years, dying in office August 1, 1801, age 56 — leaving the abolitionist Edwards line for his sons to carry."},{"number":5,"category":"social_reform","header":"He wrote against slavery as “Antidoulios”","body":"Ordained only four years, the twenty-eight-year-old pastor took a pen name for his 1773 newspaper attack on slavery: Antidoulios, Greek for “against slavery.” He applied the golden rule directly — why are slaveholders exempt from “whatsoever ye would that men should do to you”?"}],"education":[{"school_name":"Princeton (College of New Jersey)","dates":"1765","type":"undergraduate","notes":"ranked first in a class of thirty-one"},{"school_name":"Theology under Joseph Bellamy","location":"Bethlehem, Connecticut","type":"professional"}],"career":[{"role":"Tutor","organization":"Princeton","start_year":1767,"end_year":1769},{"role":"Pastor","organization":"White Haven (2nd Congregational) Church, New Haven","start_year":1769,"end_year":1795},{"role":"Pastor","organization":"Colebrook, Connecticut","start_year":1795,"end_year":1799},{"role":"President","organization":"Union College, Schenectady","start_year":1799,"end_year":1801}],"slug":"jonathan-edwards-1745"},"X00882":{"id":"X00882","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"EH 1909; Online vital records"}],"death":{"year":1782,"cause":"drowned","month":6,"day":24,"city":"New Haven","state":"Connecticut","country":"United States"},"gender":"female","parents":{"father_name":"Eleazer Porter","mother_name":"Sarah Pitkin Porter"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00384","date_year":1770,"date_month":10,"date_day":4,"children_ids":["HD2623","HD2619","HD2620","HD2621","HD2622","HD2624","HD2625"],"marriage_year":1770}],"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1748,"country":"United States"},"cross_connections":[],"bio":{"display_name":"Mary Porter","first_name":"Mary","maiden_name":"Porter","married_names":[],"bio_blurb":"First wife of Jonathan Edwards Jr.; drowned 1782"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM014"},"narrative_blocks":[{"number":1,"category":"death","header":"Drowned watering her horse","body":"Riding into the country, she stopped at a New Haven mill-pond to let her horse drink; it waded beyond its depth and both went under. Her stone in the Center Church crypt is the only one there to name a cause of death — “accidentally drowned.”"}],"slug":"mary-porter-1748"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}