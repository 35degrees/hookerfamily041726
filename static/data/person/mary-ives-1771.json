:[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Hotel Operator","location":"Morristown, St. Lawrence County, New York","start_year":1815,"end_year":1823,"notes":"Bought Arnold Smith hotel fall 1815. Sold to Alfred Hooker Aug 23, 1823."},{"role":"Merchant","location":"Morristown NY","end_year":1829,"notes":"General mercantile, principally Canadian trade."},{"role":"Collector of the Port","organization":"Port of Morristown","location":"Morristown NY","start_year":1821,"notes":"First collector of port. Overseer of the poor when town organized March 27, 1821."}],"narrative_blocks":[{"number":1,"category":"career","header":"St. Lawrence River hotel owner; first port collector","body":"John Hooker moved his family from Turin to Morristown in the fall of 1815 — a village of only a few houses on the St. Lawrence River — where he bought Arnold Smith's hotel and ran it until 1823. When the town was organized on March 27, 1821, he was appointed overseer of the poor and became its first collector of the port."},{"number":2,"category":"legacy","header":"From Connecticut to Turin to the St. Lawrence","body":"John Hooker left Kensington, Connecticut after his first wife Abigail Goodrich died in 1794, remarried Mary Ives in 1795, and removed the family to Turin, New York in 1802 — then in 1814 to Morristown, beautifully situated on the St. Lawrence River, where he died April 12, 1829."}],"number_of_marriages":2,"slug":"john-hooker-1768"},"H01437":{"id":"H01437","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Henry Hooker","first_name":"Henry","last_name":"Hooker","married_names":[]},"gender":"male","birth":{"year":1797,"month":7,"day":7,"state":"Connecticut","country":"United States"},"death":{"year":1882,"month":12,"day":6,"city":"Morristown","state":"New York","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"parents":{"father_id":"H00535","mother_id":"I01233"},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":1,"marriages":[{"children_ids":["H02814","H02815","H02816","H02818","H02817"],"marriage_number":1}],"career":[{"role":"Collector of Customs","organization":"Port of Morristown","location":"Morristown NY","notes":"Appointed Tyler; reappointed Lincoln and Grant."}],"education":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":["politician","merchant"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Customs collector appointed by Tyler, Lincoln, and Grant","body":"Henry Hooker served as Collector of Customs at the Port of Morristown, appointed by President Tyler and reappointed by Presidents Lincoln and Grant — spanning decades across the Civil War era. He was also Justice of the Peace, town Supervisor, Episcopal Church Warden, and partner in the mercantile firm Miller, Hooker & Co."},{"number":2,"category":"legacy","header":"Son Alfred killed at Monocacy, 1864","body":"Henry Hooker's son Alfred Ives became Captain of Company B, 106th New York Infantry, and was killed at the Battle of Monocacy on July 9, 1864 — the engagement that slowed Jubal Early's Confederate march on Washington. Alfred died three years before his mother Melinda and eighteen years before his father."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{},"residence":{},"sources":[{"short":"EH 1909"}],"research_sources":[],"slug":"henry-hooker-1797"},"H02814":{"id":"H02814","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Mary Hooker Chapman","first_name":"Mary","last_name":"Hooker","married_nam