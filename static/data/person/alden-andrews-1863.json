al_reform","header":"His book on slavery drew abolitionist fire","body":"In 1836 Andrews published a study of slavery and the domestic slave trade that The Liberator attacked as a pro-slavery apologia. The work set the scholar awkwardly against the rising antislavery tide of his native Connecticut.","number":4}],"cross_connections":[],"education":[{"institution_id":"INST022","school_name":"Yale College","type":"university","degree":"B.A.","graduation_year":1810,"notable":true,"institution_blurb":"Graduated Yale 1810; Yale conferred LL.D. 1848 for Latin scholarship."},{"institution_id":"INST022","school_name":"Yale University","type":"university","degree":"LL.D.","graduation_year":1848,"notable":true,"institution_blurb":"Yale conferred LL.D. 1848 for eminence as Latin author."}],"bio":{"display_name":"Prof. Ethan Allen Andrews","first_name":"Ethan","middle_name":"Allen","last_name":"Andrews","title":"Prof.","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780773321/Ethan_Allen_Andrews__page_333_crop_vj8csf.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ethan-andrews-1787"},"H00699":{"id":"H00699","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1789,"month":1,"day":20},"parents":{"father_id":"X00270","mother_id":"H00309"},"tags":["named_for_hooker"],"sources":[{"short":"Edward Hooker 1909","entry":"699"},{"short":"Cowles Family Genealogy"},{"bib_id":"BIB003"}],"death":{"year":1875,"month":11,"day":16,"city":"Farmington","state":"Connecticut"},"gender":"female","burial":{"cemetery_id":"CEM031"},"number_