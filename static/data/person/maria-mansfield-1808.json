the Croton Aqueduct. He also built mills, ran a bank, and helped build the Michigan Southern and Northern Indiana Railroad."},{"number":3,"category":"legacy","header":"Townsfolk saved his mansion from the wreckers","body":"Hugh White's 1830 Waterford homestead, built of brick and timber shipped down the Erie Canal, was marked for demolition in 1964. Within weeks a group of residents raised the money to buy it and moved it to a new site, where it became the Waterford Historical Museum."}],"sources":[],"institutions":[],"landmarks":[{"landmark_id":"LM117","landmark_blurb":"Built and lived in this 1830 Waterford homestead"}],"naming_inspiration":[],"artworks":[],"research_tags":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Hugh","last_name":"White","married_names":[],"display_name":"Hugh White","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780691468/7640745_116001079154_zfcxil.jpg","photo_notes":"Congressman Hugh White (1798–1870)."},"military_service":[],"education":[{"school_name":"Hamilton College","dates":"1823","type":"undergraduate","notes":"Graduated 1823."}],"career":[{"role":"U.S. Representative","organization":"New York 16th District","start_year":1845,"end_year":1851,"notes":"Whig; chaired House Agriculture."},{"role":"Proprietor","organization":"Rosendale Cement Works","notes":"First U.S. waterproof cement."},{"role":"President","organization":"Saratoga County National Bank"}],"cross_connections":[{"type":"in_law","related_id":"HD1608","display_label":"married his son William in 1863"}],"slug":"hugh-white-1798"},"X00514":{"id":"X00514","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1833},"death":{"year":1896},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1608","children_id