education":[],"career":[{"role":"Member","organization":"Connecticut State Legislature","start_year":1845,"end_year":1845},{"role":"State Senator","organization":"Connecticut","start_year":1846,"end_year":1846},{"role":"Selectman","organization":"Town of North Haven, Connecticut"},{"role":"Town Treasurer","organization":"Town of North Haven, Connecticut"},{"role":"Town Clerk","organization":"Town of North Haven, Connecticut"},{"role":"Justice of the Peace","organization":"Town of North Haven, Connecticut"},{"role":"Judge of Probate","organization":"Town of North Haven, Connecticut"},{"role":"Warden and Clerk","organization":"St. John's Protestant Episcopal Parish, North Haven","notes":"Served in this role for over thirty years."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["cousin_marriage"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Three wives, three children buried by 1841","body":"Ezra outlived his first two wives — Esther in 1836 and Mary in 1853 — and buried three of his five children before they reached age seven. Only Ezra Leander, born 1844 to his third wife, reached adulthood, and he never married."}],"quotes":[],"sources":[{"label":"FindAGrave memorial 127199478","url":"https://www.findagrave.com/memorial/127199478/ezra-stiles"}],"research_sources":[],"documents":[],"slug":"ezra-stiles-1804"},"HD1446":{"id":"HD1446","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00877","mother_id":"X00468"},"tags":["cousin_marriage"],"sources":[{"short":"Online vital records / Pierpont genealogy"}],"birth":{"year":1805},"death":{"year":1836,"month":9,"day":26,"country":"United States"},"gender":"female","marriages":[{"marriage_number":1,"spouse_id":"H01186","date_year":1829,"date_month":4,"date_day":30,"location_city":"North Haven","location_county":"New Haven County","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1836,"children_ids":["HD4087","HD4088"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"parallel_marriage","related_id":"HD1460","display_label":"Married Stiles brothers; second cousins themselves","link_text":"Lois Pierpont Stiles"}],"bio":{"display_name":"Esther Pierpont Stiles","first_name":"Esther","last_name":"Stiles","maiden_name":"Pierpont","married_names":["Stiles"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"death","header":"Mother and infant buried in same casket, 1836","body":"Esther Pierpont Stiles died September 26, 1836 in North Haven Connecticut at age thirty-one. Her six-month-old daughter Esther Josephine died the following day, September 27 — and per family tradition mother and infant were buried in the same casket. Her only surviving child, son Charles William Stiles born February 1833, died August 7, 1840 at age seven, ending her direct line within four years of her own death."},{"number":2,"category":"family","header":"Cousin marriage; sisters wed Stiles brothers","body":"Esther's 1829 marriage to Ezra Stiles was a documented Pierpont-Stiles cousin marriage — her father Daniel Pierpont and Lois Pierpont Stiles's father Benjamin Pierpont Jr. were first cousins, both grandsons of Joseph Pierpont. That made Esther and her second cousin Lois Pierpont Stiles both Hooker descendants, and the two women married brothers — Ezra and Horace Stiles. Two Hooker-Pierpont cousin marriages between siblings of two intermarried families."},{"number":3,"category":"family","header":"Husband's later marriages also ended in early death","body":"Ezra Stiles outlived Esther by half a century but his second marriage in 1837 also ended in his second wife's death at age forty-two in 1853. His third marriage in 1854 to Frances Elizabeth Johnson produced a third Charles, who likewise died at age six. The repeated pattern across three marriages — early-widowed wives, sons named Charles dying young — marks one of the more striking grief sequences in the Stiles branch records."}],"slug":"esther-stiles-1805"},"H00454":{"id":"H00454","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1767,"month":4,"day":30,"city":"North Haven","state":"Connecticut"},"parents":{"father_id":"H00238","mother_id":"I00158","father_name":"Isaac Stiles Jr.","mother_name":"Mabel Clark"},"tags":["not_yet_fully_entered"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 454"},{"label":"FindAGrave Capt. Isaac C. Stiles","url":"https://www.findagrave.com/cemetery/103538/old-cemetery"}],"gender":"male","marriages":[{"spouse_id":"X01370","children_ids":["H01180","H01182","H01181","H01183","H01184","H01185","H01186","H01187"],"marriage_number":1,"date_year":1787,"date_month":2,"date_day":3}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1834,"month":6,"day":16,"city":"North Haven","county":"New Haven County","state":"Connecticut","country":"United States"},"cross_connections":[],"bio":{"display_name":"Captain Isaac Clark Stiles","first_name":"Isaac","last_name":"Stiles","middle_name":"Clark","title":"Captain","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM307"},"career":[{"role":"Selectman","organization":"Town of North Haven, Connecticut","start_year":1828,"end_year":1829},{"role":"Member","organization":"Connecticut General Assembly","start_year":1831,"end_year":1831}],"narrative_blocks":[{"number":1,"category":"politics","header":"Late-life politics: Selectman, Assemblyman, then died","body":"Isaac Clark Stiles served as Selectman of North Haven in 1828 and 1829 and was elected to the Connecticut General Assembly in 1831. He died three years later in June 1834 at age sixty-seven."}],"slug":"isaac-stiles-1767"},"X01370":{"id":"X01370","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"label":"FindAGrave Eunice Blakeslee Stiles","url":"https://www.findagrave.com/cemetery/103538/old-cemetery"}],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00454","date_year":1787,"date_month":2,"date_day":3,"location_state":"Connecticut","location_country":"United States","children_ids":["H01180","H01182","H01181","H01183","H01184","H01185","H01186","H01187"]}],"parents":{"father_id":"X02811","mother_id":"X02812","father_name":"Zophar Blakeslee","mother_name":"Eunice Ives Blakeslee"},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1767,"month":4,"day":25,"city":"North Haven","county":"New Haven County","state":"Connecticut","country":"United States"},"death":{"year":1853,"month":11,"day":4,"state":"Connecticut","country":"United States"},"cross_connections":[],"bio":{"display_name":"Eunice Blakeslee","first_name":"Eunice","maiden_name":"Blakeslee","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM307"},"slug":"eunice-blakeslee-1767"},"H00877":{"id":"H00877","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00366","mother_id":"X00456"},"tags":["politician"],"sources":[{"short":"Edward Hooker 1909","entry":"877"},{"short":"Pierpont genealogy (Moffat)"}],"birth":{"year":1775,"month":5,"day":16},"death":{"year":1851,"month":11,"day":16,"city":"North Haven","state":"Connecticut"},"marriages":[{"spouse_id":"X00468","children_ids":["HD1444","HD1445","HD1446","HD1447","HD1448","HD1449","HD1450"],"marriage_number":1,"date_year":1799,"date_month":9,"date_day":26}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Daniel Pierpont Esq.","first_name":"Daniel","last_name":"Pierpont","suffix":"Esq.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Forty-four years as North Haven Town Clerk","body":"Daniel Pierpont succeeded his father as Town Clerk of North Haven Connecticut and served in the role for forty-four years — from about 1807 until his death in 1851. The continuous-tenure record was one of the longer documented town-clerkships in early-Republic Connecticut, and combined with his cabinetmaking work, it positioned him as 'one of North Haven's leading citizens.'"},{"number":2,"category":"politics","header":"Five legislative terms, Constitutional Convention delegate","body":"Daniel Pierpont represented North Haven in the Connecticut General Assembly for five terms (1813, 1815, 1818, 1824, and one other), served as a Justice of the Peace for many years, and was a delegate to the Connecticut Constitutional Convention in Hartford. The combined civic portfolio — Town Clerk, JP, state representative, constitutional delegate — built one of the more complete antebellum local-leadership Connecticut careers."},{"number":3,"category":"family","header":"Pierpont Homestead 1809, now local historic district","body":"Around 1809 Daniel Pierpont purchased the Pierpont Homestead at 29 State Street North Haven — a Georgian Colonial built 1785 by Stephen Jacobs to which he added a rear addition in 1846. The homestead and the adjacent store run by son Rufus for over a hundred years became 'the center of life at the Pines Bridge in North Haven' and is today a local historic district. The house does not face State Street because the road originally curved to a ford across the river."},{"number":4,"category":"family","header":"Born and died North Haven, age seventy-six","body":"Daniel Pierpont was born May 16, 1775 in North Haven Connecticut and died there November 16, 1851 at age seventy-six, buried at Old Cemetery North Haven. He had married Esther Humiston on September 26, 1799 — she outlived him by thirteen years, dying August 17, 1864 in New Haven at age ninety. Their seven children were Bede, Elias, Esther/Stiles, Harriet, Sally, Jared, and Rufus."}],"slug":"daniel-pierpont-1775"},"X00468":{"id":"X00468","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1774},"death":{"year":1864},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00877","date_year":1799,"date_month":9,"date_day":26,"children_ids":["HD1444","HD1445","HD1446","HD1447","HD1448","HD1449"