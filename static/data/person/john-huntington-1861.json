career","header":"Assistant Postmistress at Luther Oklahoma forty-one years","body":"Worked as Assistant Postmistress at the Luther Oklahoma post office for forty-one years until her 1974 retirement — her mother Belle had been the appointed Postmistress. After retirement Roberta became Belle's full-time caregiver until her mother's 1977 stroke and death."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"roberta-cox-1909"},"I01154":{"id":"I01154","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Luther","middle_name":"E.","last_name":"Cox","married_names":[],"nickname":"Luke","gender":"male","display_name":"Luther E. \"Luke\" Cox"},"gender":"male","birth":{"year":1909,"month":6,"day":30,"country":"United States"},"baptism":{},"death":{"year":2000,"month":11,"day":1,"country":"United States"},"residence":{"city":"Luther","county":"Oklahoma","state":"Oklahoma","country":"United States"},"burial":{"plot_notes":"Memorial Park Cemetery, Oklahoma City — alongside wife Roberta."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_research_notes":"Cox family. Parents not identified."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"TD0289","date_year":1933,"date_month":5,"location_state":"Oklahoma","location_country":"United States","end_type":"death","end_year":2000,"children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["extraordinary_longevity"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"luther-cox-1909"},"TD0290":{"