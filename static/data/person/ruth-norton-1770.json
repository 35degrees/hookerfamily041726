:[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ichabod-norton"},"H00297":{"id":"H00297","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1739,"month":9,"day":3,"city":"Farmington","state":"Connecticut"},"death":{"year":1823,"month":7,"day":16,"city":"West Hartford","state":"Connecticut"},"parents":{"father_id":"I00055","mother_id":"H00103"},"tags":["replacement_naming"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 297"},{"short":"Orderly Book of Capt. Ichabod Norton","notes":"Original MS owned by Charles Mulford Robinson, Rochester NY, 1909."}],"marriages":[{"children_ids":["H00660","H00661","H00662","H00663","H00664","H00665","H00666","H00667","H00668"],"spouse_id":"X01068","marriage_number":1,"date_year":1760,"date_month":2,"date_day":21,"location_city":"Hartford","location_state":"Connecticut"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"military_service":[{"war":"American Revolutionary War","rank":"Spouse of officer","notes":"Ruth Strong Norton — wife of Col. Ichabod Norton.","war_id":"WAR004"}],"bio":{"display_name":"Ruth Strong","first_name":"Ruth","maiden_name":"Strong","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"military","header":"Husband served under her Hooker cousin in 1777","body":"Her husband Major Ichabod Norton entered the Revolutionary army as a lieutenant in 1776, fighting at Skeensborough, Fort Ann, and Ticonderoga. In 1777 at Peekskill he served under Colonel Noadiah Hooker — Ruth's first cousin once removed in the Hooker line — and was eventually promoted to Major."},{"number":2,"category":"family","header":"Two Ruths — only one survived past four","body":"Her parents' first daughter Ruth had died at age four on September 6, 1736; she was born three years later in 1739 and given the same name. Replacement naming was a common Puritan practice when an infant died young, but it left the second Ruth carrying her dead sister's identity for life."}],"slug":"ruth-strong-1739"},"I00055":{"id":"I00055","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1702,"month":10,"day":8,"city":"Farmington","state":"Connecticut"},"death":{"year":1751,"month":3,"day":30,"city":"Farmington","state":"Connecticut"},"parents":{"mother_research_notes":"Margaret Hart — daughter of Capt. Thomas Hart (X00031), son of Stephen Hart (X00034)","father_research_notes":"Asahel Strong Sr. (b. Nov 14, 1668 Northampton MA) — married Margaret Hart, daughter of Capt. Thomas Hart (X00031)"},"marriages":[{"spouse_id":"H00103","children_ids":["H00293","H00294","H00295","H00296","H00297","H00298","H00299","H00300"],"marriage_number":1,"date_year":1729,"date_month":1,"date_day":8}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 103"}],"gender":"male","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[],"notable_blurb":null,"primary_url":null,"primary_url_label":null},"cross_connections":[{"type":"parallel_descent","related_id":"I00900","display_label":"Both Strong men who married Hooker descendants, 84 years apart","link_text":"Judge Elisha Beebe Strong"}],"bio":{"title":"Captain","display_name":"Captain Asahel Strong Jr.","first_name":"Asahel","last_name":"Strong","suffix":"Jr.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"His Hooker marriage echoed down two more generations","body":"When Captain Asahel Strong Jr. married Sarah Hooker in 1729 at Farmington, Connecticut — a great-great-granddaughter of Rev. Thomas Hooker — he began a pattern that would echo through generations: their great-great-grandson Asahel Hooker Strong was born in 1776 with 'Hooker' preserved as his middle name, and 84 years after the first marriage, Judge Elisha Beebe Strong married another Thomas Hooker descendant, Dolly Goodwin Hooker, at Canandaigua, New York in 1813. By 1866, that second union had produced Beebe Hooker Strong of Milwaukee, the fourth person in the Strong family to carry the Hooker name — connecting the original Farmington parsonage to the Wisconsin frontier across 137 years."}],"slug":"asahel-strong-jr-1702"},"H00103":{"id":"H00103","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1708,"month":4,"day":16,"city":"Farmington","state":"Connecticut"},"death":{"year":1777,"month":9,"day":18,"city":"Farmington","state":"Connecticut"},"parents":{"father_id":"H00030","mother_id":"I00031"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 103"},{"short":"Native Northeast Portal","url":"https://www.nativenortheastportal.com/bio/bibliography/hooker-ruth-1708-1777"}],"marriages":[{"spouse_id":"I00055","children_ids":["H00293","H00294","H00295","H00296","H00297","H00298","H00299","H00300"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1751,"date_year":1729,"date_month":1,"date_day":8},{"children_ids":[],"spouse_id":"I00134","marriage_number":2,"date_year":1772,"date_month":11,"date_day":19}],"cross_connections":[{"type":"parallel_descent","related_id":"H00795","display_label":"Hooker women who married Strongs in 1729 and 1813","link_text":"Dolly Goodwin Hooker"}],"gender":"female","narrative_blocks":[{"number":1,"category":"family","header":"Eight children with Capt. Asahel Strong Jr.","body":"She married Capt. Asahel Strong Jr. on January 8, 1729 and bore him eight children — including Rev. Cyprian Strong of Chatham. Asahel was a grandson of Stephen Hart through his mother Margaret Hart, closing another loop in the Hart-Hooker network."},{"number":2,"category":"death","header":"Lost three children in September 1736","body":"In a single ten-day span — September 6 to 15, 1736 — three of her young children died: Lois and Ruth on the same day, then Elnathan nine days later. The cluster strongly suggests an epidemic moving through Farmington."},{"number":3,"category":"marriage","header":"Second husband Solomon Whitman lived to 93","body":"After Capt. Asahel Strong's death she married Solomon Whitman, who was Town Clerk at 92 and made a pair of shoes on his 90th birthday. He died at 93 from over-fatigue settling a fence dispute between two brothers."}],"number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Ruth Hooker Whitman","first_name":"Ruth","last_name":"Whitman","maiden_name":"Hooker","married_names":["Strong","Whitman"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ruth-whitman-1708"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}