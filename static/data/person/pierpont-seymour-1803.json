lse,"is_easter_egg":false},"birth":{"year":1766,"month":6,"day":1,"city":"Stockbridge","state":"Massachusetts"},"death":{"year":1861,"month":1,"day":8,"city":"Victor","state":"New York"},"parents":{"father_id":"X00536","mother_id":"H00376"},"marriages":[{"spouse_id":"X00544","children_ids":["HD1900","HD1901","HD1902","HD1903","HD1904"],"marriage_number":1,"date_year":1795,"date_month":12,"date_day":24,"location_city":"Hampshire","location_state":"Massachusetts"}],"tags":["extraordinary_longevity"],"sources":[{"short":"Edward Hooker 1909","entry":"911"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Jerusha Parsons","first_name":"Jerusha","last_name":"Parsons","married_names":["Seymour"],"suffix":"No. 2"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Colonial-era birth, Civil War year death, age ninety-four","body":"Jerusha Parsons was born June 1, 1766 in Stockbridge Massachusetts, when the colonies still answered to George III. She died January 8, 1861 in Victor, Ontario County New York at age ninety-four — three months before Fort Sumter opened the Civil War. Her ninety-four-year life span covered the Revolution, the early Republic, Jacksonian democracy, abolitionism, and the war's first months."},{"number":2,"category":"family","header":"Husband named in Bellamy's Shays' Rebellion novel","body":"Jerusha's husband Ira Seymour Sr. served as deputy sheriff during Shays' Rebellion (1786-1787), siding with the 'aristocrats' Judge Timothy Edwards and Judge Jahleel Woodbridge against the Shays' insurgents — and as deputy sheriff he 'liberated many debtors from the county jail.' Edward Bellamy named him by name in the 1879 historical novel 'The Duke of Stockbridge,' the most-read fictional treatment of the rebellion. Jerusha's marriage thus placed her at the center of the Stockbridge gentry's response to the agrarian revolt."},{"number":3,"category":"family","header":"Husband descended from Hartford co-founder Richard Seymour","body":"Ira Seymour Sr. was the great-great-grandson of Richard Seymour (1596 England - 1655 Norwalk Connecticut) — one of the original founders of Hartford with Thomas Hooker in 1636. Jerusha's marriage thus united two completely independent Hartford-founding family lines through a Berkshire County Massachusetts match, two centuries after the original 1636 settlement. The Seymour-Parsons union is one of the cleaner cases in the tree of Hartford-founder lines reconverging."}],"slug":"jerusha-parsons-1766"},"X00544":{"id":"X00544","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1748,"month":8,"day":31,"city":"Norwalk","state":"Connecticut"},"death":{"year":1837,"month":10,"day":4,"city":"Victor","state":"New York"},"tags":[],"sources":[],"marriages":[{"spouse_id":"H00911","children_ids":["HD1900","HD1901","HD1902","HD1903","HD1904"],"marriage_number":1,"date_year":1795,"date_month":12,"date_day":24,"location_city":"Hampshire","location_state":"Massachusetts"}],"gender":"female","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Ira Seymour Sr.","first_name":"Ira","suffix":"Sr.","maiden_name":"Seymour","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ira-seymour-sr-1748"},"X00536":{"id":"X00536","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":true},"birth":{"year":1719},"death":{"year":1785},"tags":["revolutionary_war"],"sources":[],"marriages":[{"spouse_id":"H00376","children_ids":["H00901","H00902","H00903","H00904","H00905","H00906","H00907","H00908","H00909","H00910","H00911"],"marriage_number":1,"date_year":1750,"date_month":6,"date_day":11}],"gender":"male","parents":{},"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Revolutionary militia private; son-in-law of Jonathan Edwards","primary_url":"https://en.wikipedia.org/wiki/Elihu_Parsons_(politician)","primary_url_label":"Wikipedia"},"cross_connections":[],"bio":{"display_name":"Elihu Parsons","first_name":"Elihu","last_name":"Parsons","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"category":"military","header":"He marched in the Berkshire County militia","body":"Elihu Parsons served as a private in the Berkshire County militia during the Revolution, under Captain Ezra Whittlesey and Colonel John Brown. He is recognized as a patriot ancestor by the Daughters of the American Revolution.","number":1},{"category":"marriage","header":"He married a daughter of Jonathan Edwards","body":"In 1750 Parsons wed Sarah Edwards, a daughter of the theologian Jonathan Edwards, and the couple raised eleven children at Stockbridge. He lived as an esquire in the western Massachusetts hills.","number":2}],"slug":"elihu-parsons-1719"},"H00376":{"id":"H00376","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1728,"month":8,"day":25,"city":"Northampton","state":"Massachusetts"},"death":{"year":1805,"month":5,"day":15,"city":"Goshen","state":"Massachusetts"},"parents":{"father_id":"X00128","mother_id":"HD0418"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 376"},{"label":"Salt of the Earth — David Brainerd and Jerusha Edwards: A Colonial Love Story","url":"https://salt-ofthe-earth.blogspot.com/2013/02/david-brainerd-and-jerusha-edwards.html"}],"marriages":[{"spouse_id":"X00536","children_ids":["H00901","H00902","H00903","H00904","H00905","H00906","H00907","H00908","H00909","H00910","H00911"],"marriage_number":1,"date_year":1750,"date_month":6,"date_day":11}],"cross_connections":[{"type":"family_connection","notes":"The coincidence of two daughters marrying two Ingersolls in the same period and region (Berkshire County MA) likely reflects the prominence of the Ingersoll family in that area. (DAR records; FindAGrave)","related_id":"H00905","display_label":"Daughter Lydia married Aaron Ingersoll of Berkshire","link_text":"Lydia Parsons Ingersoll"},{"type":"family_connection","notes":"The coincidence of two daughters marrying two Ingersolls in the same period and region (Berkshire County MA) likely reflects the prominence of the Ingersoll family in that area. (DAR records; FindAGrave)","related_id":"H00907","display_label":"Daughter Sarah married David Ingersoll of Berkshire","link_text":"Sarah Parsons"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Sarah Edwards","first_name":"Sarah","maiden_name":"Edwards","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777406086/sarahedwardsparsons_jcxgr0.png","photo_notes":"Sarah Edwards Parsons (1728-1805), eldest daughter of Jonathan Edwards."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Eldest Edwards child born Sabbath afternoon, 1728","body":"She was born August 25, 1728 in Northampton — 'on a Sabbath day, between 2 and 3 o'clock in the afternoon,' as her father Jonathan Edwards recorded. She was the eldest of his eleven children."},{"number":2,"category":"marriage","header":"Married her father's attorney — Stockbridge farmer","body":"In 1750 she married Elihu Parsons, a Northampton attorney who handled many of Jonathan Edwards's legal and personal affairs. Parsons later farmed in Stockbridge, where the family settled during the Mohican mission years."},{"number":3,"category":"character","header":"Father warned suitor of her temper","body":"When Elihu Parsons asked Jonathan Edwards for her hand, Edwards reportedly disclosed her difficult temper before quipping: 'I hope she has grace, but grace can live where you cannot.'"},{"number":4,"category":"family","header":"Two daughters married into the Berkshire Ingersolls","body":"Two of her eleven children — both daughters — married into the Ingersoll family of Berkshire County, Massachusetts. This is a separate Ingersoll line from the Loyalist New Haven Ingersolls who descended through the Newton-Miles line."}],"slug":"sarah-edwards-1728"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}