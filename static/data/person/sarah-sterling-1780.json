cks":[{"number":1,"category":"migration","header":"A creek in the Wyoming Valley bears his name","body":"A merchant at North Castle, New York, James Sutton sold out at the Revolution's onset and removed to Exeter in the Wyoming Valley, building a saw and grist mill on a stream named for him, Sutton's Creek."},{"number":2,"category":"military","header":"He guarded the women and children at Forty Fort","body":"A Quaker scrupulous about bearing arms, Sutton was nonetheless stationed inside Forty Fort on the day of the 1778 Wyoming Massacre, charged with protecting the women, children, and aged who sheltered there."}],"slug":"james-sutton-1744"},"H00746":{"id":"H00746","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1747,"month":6,"day":17},"parents":{"father_id":"H00320","mother_id":"X00284"},"tags":["named_for_hooker","pennsylvania_migration"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 746"}],"gender":"female","marriages":[{"spouse_id":"X01577","children_ids":["H01927","H05316","HD5210","HD5211","HD5212","HD5213","HD5214","HD5215","HD5290","HD5361","HD5362","HD5363","HD5376"],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1834,"month":8,"day":20,"city":"Exeter","county":"Luzerne","state":"Pennsylvania","country":"United States"},"cross_connections":[],"bio":{"display_name":"Sarah Smith","first_name":"Sarah","maiden_name":"Smith","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM578","plot_notes":"Hollenback Cemetery, Wilkes-Barre PA. SOURCE: FindAGrave."},"narrative_blocks":[{"number":1,"category":"migration","header":"She followed her father to the Wyoming Valley","body":"Sarah Smith married James Sutton and removed with him and her father, Dr. William Hooker Smith, to the Wyoming Valley of Pennsylvania, settling at Exeter where Sutton's mills stood."}],"slug":"sarah-smith-1747"},"H00320":{"id":"H00320","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1725,"month":3,"day":23,"city":"White Plains","state":"New York"},"death":{"year":1815,"month":7,"day":17,"city":"Tunkhannock","state":"Pennsylvania"},"burial":{"cemetery_id":"CEM576","plot_notes":"Jackson Cemetery, Tunkhannock, Wyoming County PA. SOURCE: FindAGrave; Miner's History of Wyoming."},"parents":{"father_id":"I00140","mother_id":"H00109"},"tags":["named_for_hooker","revolutionary_war","physician","pennsylvania_migration","minister"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 320"}],"marriages":[{"children_ids":["H00745","H00746","H00747","H00748","H00749","H00750","H00751","H00752","H00753","H00754"],"spouse_id":"X00284","marriage_number":1,"end_type":"death_of_spouse","end_year":1778,"date_year":1743,"date_month":6},{"children_ids":["H00755"],"spouse_id":"X00285","marriage_number":2,"date_year":1779,"date_month":11,"date_day":22}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Continental Army surgeon; Old Forge, PA namesake","primary_url":"https://ca.forceswarrecords.com/memorial/630047138/william-hooker-smith","primary_url_label":"Forces War Records"},"cross_connections":[{"type":"parallel_event","related_id":"H01927","display_label":"survived the same Wyoming Massacre as a child","link_text":"Deborah Sutton Bedford"},{"type":"civic_peer","display_label":"fought at the Battle of Wyoming with judge Matthias Hollenback","related_id":"X03090","link_text":"Matthias Hollenback"},{"type":"civic_peer","display_label":"Wyoming Valley physician who soldiered with Colonel John Spalding","related_id":"X03095","link_text":"Col. John Spalding"},{"type":"civic_peer","display_label":"Wyoming Valley patriot who soldiered with General Simon Spalding","related_id":"X03106","link_text":"Gen. Simon Spalding"}],"military_service":[{"war":"American Revolutionary War","active_in_war":true,"rank":"Captain then Surgeon","notes":"3rd Co., 1st Regt CT, May 1775, Wyoming Valley PA; marched under Gen. Schuyler to NY. 1776: 10th Continental Regt CT under Col. Parsons. 1777: commissioned Captain, 24th Regt CT (Westmoreland Regt). May 27, 1778: commissioned Surgeon. Surgeon to militia under Col. Dennison, Forty Fort 1778-1779. Participated in Battle of Wyoming. Congress 1836 special act: $2,400 to heirs for war services.","war_id":"WAR004"}],"bio":{"display_name":"William Hooker Smith","notes":"Middle name \"Hooker\" explicit tribute to ancestor Thomas Hooker","first_name":"William","last_name":"Smith","middle_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"military","header":"Continental Army surgeon at Wyoming Massacre 1778","body":"He served as Surgeon in the Continental Army — 3rd Company, 1st Regiment Connecticut — and was living in the Wyoming Valley when the July 3, 1778 massacre killed approximately 300 Patriots. His first wife Sarah had died three weeks earlier."},{"number":2,"category":"death","header":"Family Bible recorded wife's death before the massacre","body":"His Oxford-printed Bible (1772) preserves the record of her death at 'about nine o'clock at night' on Friday, June 12, 1778. She was buried on his own land at Jacob's Plains two days later, three weeks before the Wyoming Massacre."},{"number":3,"category":"legacy","header":"Old Forge, Pennsylvania was named for him","body":"He and his son-in-law James Sutton founded an iron works in the Lackawanna Valley. Those who knew him called him 'old forge' — and the town of Old Forge, Pennsylvania was named for him."},{"number":4,"category":"family","header":"Lived to ninety in Tunkhannock, Pennsylvania","body":"He died July 17, 1815 in Tunkhannock, Wyoming County, Pennsylvania, age 90. He had outlived his first wife by 37 years and his second wife as well."},{"number":5,"category":"military","header":"Congress paid his heirs for his war service","body":"Decades after his death, Congress passed a special act in the 1830s granting his heirs $2,400 in commutation for his Revolutionary service as the sole surgeon at the Wilkes-Barre garrison in the Wyoming Valley."}],"slug":"william-smith-1725"},"X00284":{"id":"X00284","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1725},"death":{"year":1778},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00320","date_year":1743,"date_month":6,"end_type":"death_of_spouse","end_year":1778,"children_ids":["H00745","H00746","H00747","H00748","H00749","H00750","H00751","H00752","H00753","H00754"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sarah Brown","first_name":"Sarah","maiden_name":"Brown","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-brown-1725"}},"burialCemetery":{"id":"CEM643","name":"Black Walnut Cemetery","city":"Meshoppen","state