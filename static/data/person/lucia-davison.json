d across Little Bellas chapters nationwide, with Jeff as its de facto manager."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"jeffrey-davison"},"HD4028":{"id":"HD4028","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Lea","last_name":"Davison","married_names":[],"gender":"female","display_name":"Lea Davison","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778545156/lea-davison-portrait-3-544x720_ove5hb.jpg"},"birth":{"year":1983,"city":"Sunderland","state":"Vermont","country":"United States"},"baptism":{},"death":{},"residence":{"city":"Jericho","state":"Vermont","country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":13,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["social_reform"],"notable_blurb":"Olympic mountain biker, 2012 + 2016 Games","primary_url":"https://en.wikipedia.org/wiki/Lea_Davison","primary_url_label":"Wikipedia: Lea Davison"},"parents":{"father_id":"I00555","mother_id":"HD4026"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00557","date_year":2018,"date_month":9,"date_day":22,"children_ids":["HD4032"]}],"education":[{"institution":"Mount Mansfield Union High School","degree":"High school","end_year":2001,"location_city":"Jericho","location_state":"Vermont","notes":"Class of 2001."},{"institution":"Middlebury College","institution_id":"INST054","degree":"Bachelor of Arts","field":"Environmental Studies","start_year":2001,"end_year":2005,"location_city":"Middlebury","location_state":"Vermont","notes":"Focus in conservation biology. Competed on Middlebury alpine ski team during undergraduate. Tore ACL end of first year (repaired 2002)."}],"career":[{"employer":"Team Allied/SRAM","role":"Professional mountain biker","start_year":2001,"location_state":"Vermont","notes":"Began racing 2001 at NORBA Nationals Mount Snow VT (7th place). Cross-country specialty. 2x Olympic appearances (2012, 2016) + 2 UCI World Championship medals (silver 2016, bronze 2014) + 3rd overall 2015 World Cup series. Previously with Specialized + Orbea teams. Hip labra repairs 2010 + 2014."},{"employer":"Little Bellas","role":"Co-founder / Pro Ambassador","start_year":2007,"location_state":"Vermont","notes":"Co-founded 2007 in northern Vermont with sister Sabra Davison + friend Angela Irvine. Nonprofit girls' mountain biking mentoring program. Continues involvement through Pro Ambassador Program. By 2023 had grown to chapters across the country with 142 loaner bikes available via the Gear Up financial-assistance program."}],"military_service":[],"institutions":[{"institution_id":"INST054","role":"Alpine ski team athlete + student","start_year":2001,"end_year":2005,"notes":"Middlebury College alpine ski racer + Environmental Studies major."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["olympian"],"research_tags":[],"cross_connections":[{"related_id":"HD4010","display_label":"Both notable Mansfields via Isaac Mansfield common ancestor","type":"family_connection","link_text":"Archibald Romaine Mansfield"}],"narrative_blocks":[{"number":1,"category":"career","header":"Tore ACL freshman year, then Olympic medalist","body":"After tearing her ACL at the end of her first year at Middlebury College, Lea Davison rehabbed back to the highest level of competitive cycling — twice racing the Olympics. She competed at London 2012 (11th) and Rio 2016 (7th) in cross-country mountain biking, winning silver at the 2016 UCI World Championships and bronze at 2014."},{"number":2,"category":"social_reform","header":"After seeing no female cycling community, built one","body":"After seeing a lack of women's community in competitive cycling, Lea Davison co-founde