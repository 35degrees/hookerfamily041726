 grave."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["business"],"notable_blurb":"Redpath Sugar dynasty partner, Canada Sugar Refining","primary_url":"https://www.findagrave.com/memorial/108233535/john_james-redpath","primary_url_label":"FindAGrave memorial #108233535"},"parents":{"father_id":"X02825","mother_name":"Janet McPhee Redpath","mother_research_notes":"Janet McPhee (1791 Stormont Glengarry Upper Canada - Jul 26, 1834 Montreal age 43). John Redpath Sr.'s first wife. Died the year John James was born — likely childbirth-related complications. Not built as separate entry per Jalapeño Rule."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0585","date_year":1867,"location_city":"Putney","location_country":"England","end_type":"death","end_year":1884,"children_ids":["HD4187","HD4188","HD4189","HD4190","HD4191"]}],"education":[],"career":[{"role":"Partner","organization":"John Redpath and Son (later Canada Sugar Refining Company)","location":"Montréal","start_year":1862,"end_year":1867,"notes":"Made partner alongside brother George Drummond Redpath by contract registered July 4, 1862 when their father John withdrew from the business. Partnership ended December 31, 1867; Peter Redpath + Drummond continued alone, joined by Francis Robert Redpath in 1872."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"John","inspired_by_id":"X02825","description":"First name John honors his father John Redpath Sr., the Scottish-born founder of Canada Sugar Refining Company."}],"artworks":[],"tags":["canada_migration","merchant"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"business","header":"Redpath Sugar partner, died at fifty","body":"John James Redpath was made a partner in John Redpath and Son alongside his brother George Drummond in 1862 when their father withdrew from the business. The partnership lasted five years before being dissolved December 31, 1867 — months after John James's 1867 marriage to Ada Maria Mills at Putney England. He died June 4, 1884 at Montreal at age fifty, seventeen years before his wife and son would die in the Redpath Mansion shooting."},{"category":"family","header":"His family built Canada's first sugar refinery","body":"John James was a son of John Redpath, founder of the Canada Sugar Refining Company, whose Montreal works gave the country its first sugar refinery. The Redpath name still appears on Canadian sugar today.","number":2},{"category":"death","header":"His widow died in the Redpath Mansion shooting","body":"After his death at fifty, his wife Ada was widowed for seventeen years. She and their son Clifford died together in the unexplained 1901 Redpath Mansion shooting.","number":3}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"john-redpath-1834"},"HD0585":{"id":"HD0585","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1842,"month":4,"day":26,"city":"Montréal","state":"Quebec","country":"Canada"},"death":{"year":1901,"month":6,"day":13,"city":"Montréal","state":"Quebec","country":"Canada","cause":"gunshot wound (Redpath Mansion shooting)"},"parents":{"mother_id":"HD0581","father_research_notes":"Mayor John Easton Mills","father_id":"X01251"},"tags":["unsolved_crime_victim","unusual_death","canada_migration"],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00630","date_year":1867,"location_city":"Putney","location_country":"England","end_type":"death_of_spouse","end_year":1884,"children_ids":["HD4187","HD4188","HD4189","HD4190","HD4191"]}],"notable":{"is_notable":true,"notable_category":["history"],"notable_blurb":"Died with son in famous Redpath Mansion shooting","primary_url":"https://www.findagrave.com/memorial/108233525/ada_maria-redpath","primary_url_label":"FindAGrave memorial #108233525"},"cross_connections":[{"type":"in_law","related_id":"X02825","display_label":"was her father-in-law; Founded Canada's first sugar refinery 1854"}],"bio":{"display_name":"Ada Maria Mills Redpath","first_name":"Ada","last_name":"Redpath","middle_name":"Maria","maiden_name":"Mills","married_names":["Redpath"],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778701223/adaredpath_edh8gb.png","photo_notes":"Portrait of Ada Maria Mills Redpath (1842-1901)."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM328","plot_notes":"Cimetière Mont-Royal Montreal — Redpath family grave; buried Jun 15, 1901 with her son Jocelyn Clifford who died alongside her."},"narrative_blocks":[{"number":1,"category":"family","header":"Marriage contract gave her control of her assets","body":"Ada married John James Redpath in 1867 at Putney, England — an unusual cross-Atlantic ceremony for the Mills and Redpath families. Her marriage contract stipulated she would control her own assets as if no marriage had taken place — a striking provision for 1867. In November 1870 she purchased the family villa at 1065 Sherbrooke Street Montreal, which would become the site of her death thirty-one years later."},{"number":2,"category":"death","header":"Died with son in famous Redpath Mansion shooting","body":"On June 13, 1901 at six in the evening at the Redpath Mansion 1065 Sherbrooke Street Montreal, two revolver shots were heard from Ada's bedroom. Servants found her dead and her twenty-four-year-old son Jocelyn Clifford fatally wounded. The case attracted wide publicity given the Redpaths' Canadian Sugar Refining fortune, but the coroner's inquest was perfunctory; the prevailing theory held Ada had suicidal intent and Clifford was accidentally shot trying to take the revolver from her."}],"slug":"ada-redpath-1842"}},"burialCemetery":{"id":"CEM328","name":"Cimetière Mont-Royal","city":"Outremont","state":"Montréal Region","country":"Canada","founded":1852,"wikipedia_url":"https://en.wikipedia.org/wiki/Mount_Royal_Cemetery","primary_url":"https://www.findagrave.com/cemetery/639448/cimeti%C3%A8re-mont-royal","hooker_connections":["HD0580","HD0583","HD0584","HD0585","HD0586","HD0587","HD0588","HD4178","HD4182","HD4183","HD4187","HD4188","HD4189","HD4190","HD4191","HD4192","HD4194","HD4196","HD4198","HD4199","HD4210","HD4211","HD4213","HD4214","HD4219","HD4220","HD4221","HD4228","HD4229","I00630","I00631","I00632","I00634","I00640","I00641","I00643","I00645","I00646","I00647","X01250","X01251","X01252","X01253","X01591","X02825","I01230"],"notes":"Cimetière Mont-Royal (Mount Royal Cemetery), Outremont, Montreal QC. Major Protestant cemetery founded 1852 on the slopes of Mount Royal. Burial site of multiple members of the Lyman family — Hannah Stiles Lyman's descendants who became prominent Montreal druggists, lawyers, and civic figures: Elisha Lyman Jr. (with his three wives memorialized together), Henry Lyman, Mary Corse Lyman, Henry Herbert Lyman (later commemorated here after death on the Empress of Ireland 1914), Albert Clarence Lyman, Frederick Stiles Lyman, Edith Mary Louise Lyman, and others."},"institutionsById":{},"crossConnections":[]}