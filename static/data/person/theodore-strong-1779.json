ed August 17, 1831 at twenty years old — the third child of Theodore and Martha Allen Strong. No marriage is recorded in the Hooker genealogy."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM023"},"residence":{"country":"United States"},"sources":[{"short":"EH 1909","page":"EH 1909 #2674"}],"research_sources":[],"slug":"martha-strong-1811"},"H02675":{"id":"H02675","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Sarah Hooker Strong","first_name":"Sarah","middle_name":"Hooker","last_name":"Strong","married_names":[]},"gender":"female","birth":{"year":1817,"month":9,"day":13,"city":"Northampton","state":"Massachusetts","country":"United States"},"death":{"year":1840,"month":8,"day":26,"city":"Northampton","state":"Massachusetts","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"parents":{"father_id":"HD0369","mother_id":"I01211"},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":0,"marriages":[],"career":[],"education":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":["named_for_hooker"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Named Sarah Hooker; died young in Ohio","body":"Sarah Hooker Strong carried the exact name of her grandmother — born September 13, 1817 at Northampton, she moved west to Ohio and died August 26, 1840 at twenty-two. She was the third generation to carry the Hooker name forward."}],"naming_inspiration":[{"name_element":"Hooker","inspired_by_id":"H00525","description":"Named Sarah Hooker after grandmother Sarah Hooker Strong (H00525), continuing the name into the third generation."}],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM023"},"residence":{"country":"United States"},"sources":[{"short":"EH 1909","page":"EH 1909 #2675"}],"research_sources":[],"slug":"sarah-strong-1817"},"H02676":{"id":"H02676","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Julia Augusta Strong","first_name":"Julia","middle_name":"Augusta","last_name":"Strong","married_names":[]},"gender":"female","birth":{"year":1822,"month":3,"day":30,"city":"Northampton","state":"Massachusetts","country":"United States"},"death":{"year":1827,"month":11,"day":10,"state":"Ohio","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"parents":{"father_id":"HD0369","mother_id":"I01211"},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":0,"marriages":[],"career":[],"education":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died at five years old in Ohio","body":"Julia Augusta Strong was born March 30, 1822 and died November 10, 1827 at five years old — the youngest of Theodore Strong's five children, and the last to die young in a family that saw three children die before thirty."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{},"residence":{"country":"United States"},"sources":[{"short":"EH 1909","page":"EH 1909 #2676"}],"research_sources":[],"slug":"julia-strong-1822"},"X00117":{"id":"X00117","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1745,"month":1,"day":9,"city":"Northampton","state":"Massachusetts"},"death":{"year":1819,"month":11,"day":7,"city":"Northampton","state":"Massachusetts","cause":"angina pectoris"},"burial":{"cemetery_id":"CEM023","plot_notes":"Bridge Street Cemetery, Northampton, Massachusetts"},"parents":{"mother_research_notes":"Phebe Lyman Strong","father_research_notes":"Lt. Caleb Strong of Northampton"},"marriages":[{"spouse_id":"H00525","children_ids":["HD0369","HD0370","HD0371","HD0372","HD0373","HD0374","HD0375","HD0376","HD0377"],"marriage_number":1}],"political_offices":[{"title":"6th Governor of Massachusetts","dates":"1800-1807"},{"title":"10th Governor of Massachusetts","dates":"1812-1816"},{"title":"U.S. Senator (Class 2), Massachusetts","dates":"1789-1796","notes":"Member of the inaugural U.S. Senate"},{"title":"Delegate, Philadelphia Convention","dates":"1787","notes":"Helped draft the U.S. Constitution"},{"title":"Massachusetts Constitutional Convention","dates":"1779","notes":"Member of committee that drafted the Massachusetts State Constitution"},{"title":"County Attorney, Hampshire County","dates":"1776-1800","notes":"24 years"}],"prominent_name_reason":"Gov. Caleb Strong — Founding Father; delegate to 1787 Philadelphia Convention; helped draft Massachusetts State Constitution (1779); U.S. Senator in inaugural Senate; 6th and 10th Governor of Massachusetts; instrumental in drafting Judiciary Act of 1789 and 11th Amendment; worked on Quock Walker cases establishing slavery incompatible with Massachusetts constitution. Married Sarah Hooker (H00525), daughter of Rev. John Hooker of Northampton.","sources":[{"short":"Wikipedia","notes":"Caleb Strong article"},{"label":"Wikipedia — Caleb Strong","url":"https://en.wikipedia.org/wiki/Caleb_Strong"}],"gender":"male","tags":[],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["politics"],"notable_blurb":"Governor of Massachusetts 1800-1807 (Federalist) and U.S. Senator","primary_url":"https://en.wikipedia.org/wiki/Caleb_Strong","primary_url_label":"Wikipedia"},"cross_connections":[],"education":[{"notes":"Temporarily blinded by smallpox shortly after graduation — prevented him from military service during the Revolution","school_name":"Harvard College","graduation_year":1764,"institution_id":"INST002"}],"bio":{"title":"Governor","display_name":"Gov. Caleb Strong","first_name":"Caleb","last_name":"Strong","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married his pastor's daughter, 1777","body":"He joined Rev. John Hooker's Northampton congregation in 1772 at age 27. Five years later, when Rev. Hooker died of smallpox in February 1777, the newly-licensed lawyer married his late pastor's daughter Sarah Hooker in November 1777. The Hooker name thus passed directly into the family of a future Founding Father."},{"number":2,"category":"politics","header":"U.S. Senator from Massachusetts, 1789-1796","body":"In 1788 he was elected as one of the first two U.S. Senators from Massachusetts and served 1789-1796 in the Federalist majority of the early Senate. He had previously served at the 1787 Constitutional Convention as a Massachusetts delegate, though he left Philadelphia before the document was signed because of family illness."},{"number":3,"category":"politics","header":"Federalist Governor of Massachusetts, 1800-1807","body":"He served seven consecutive one-year terms as Federalist Governor of Massachusetts 1800-1807, then a four-term return 1812-1816. During the War of 1812 his Federalist stance against the war and against New England troop mobilization drew Madison administration ire but was popular in Massachusetts."},{"number":4,"category":"family","header":"Father of nine, source of the Strong-Hooker line","body":"With his wife Sarah Hooker Strong he had nine children: 5 sons and 4 daughters including Clarissa Strong Dwight, the matriarch of the New Haven Dwight-Lyman branch. The family thereby connected the Massachusetts political elite to the Hooker founding line of Hartford CT."}],"slug":"caleb-strong-1745"},"H00525":{"id":"H00525","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1758,"month":1,"day":30,"city":"Northampton","state":"Massachusetts"},"death":{"year":1817,"month":2,"day":12,"city":"Northampton","state":"Massachusetts"},"parents":{"father_id":"H00264","mother_id":"I00043"},"tags":[],"sources":[{"short":"Edward Hooker 1909"},{"short":"Wikipedia","notes":"Caleb Strong article"}],"burial":{"cemetery_id":"CEM023","plot_notes":"Bridge Street Cemetery, Northampton, Massachusetts"},"prominent_name_reason":"Wife of Gov. Caleb Strong — 6th and 10th Governor of Massachusetts (1800-1807, 1812-1816), U.S. Senator, Founding Father, delegate to the Philadelphia Convention of 1787. Daughter of Rev. John Hooker of Northampton (H00264). 5th-generation descendant of Thomas Hooker.","marriages":[{"spouse_id":"X00117","children_ids":["HD0369","HD0370","HD0371","HD0372","HD0373","HD0374","HD0375","HD0376","HD0377"],"marriage_number":1,"date_year":1777,"date_month":11,"date_day":29,"location_city":"Northampton","location_state":"Massachusetts"}],"gravestone_inscription":"In Memory of Mrs. Sarah Strong, the wife of Caleb Strong and daughter of the Rev John Hooker who having early devoted herself to the service of her Redeemer and through life exemplified the virtues & graces of his religion gently breathed out her spirit in humble reliance upon his power and love on the 12th day of February AD 1817 in the 60th year of her age.","gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[],"notable_blurb":null,"primary_url":null,"primary_url_label":null},"cross_connections":[],"bio":{"display_name":"Sarah Hooker Strong","first_name":"Sarah","last_name":"Strong","married_names":["Strong"],"maiden_name":"Hooker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Father died of smallpox before her wedding","body":"Her father Rev. John Hooker pastor of Northampton MA died of smallpox in February 1777 when she was 19. Caleb Strong, a lawyer who had joined her father's congregation five years earlier, married her in November 1777 — nine months after the funeral."},{"number":2,"category":"family","header":"Matriarch of the Strong-Hooker-Dwight branch","body":"Mother of nine children with Gov. Caleb Strong including Clarissa Strong Dwight, who married Timothy Dwight Jr. in 1809 and produced the New Haven Dwight-Lyman cluster — three sons of whom were Yale-educated and one of whom Sam's tree records as ancestor of two generations of Yale presidents."}],"slug":"sarah-strong-1758"},"H00264":{"id":"H00264","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"compiler_ancestor":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1729,"month":3,"day":19,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1777,"month":2,"day":6,"city":"Northampton","county":"Hampshire","state":"Massachusetts","country":"United States","cause":"smallpox"},"parents":{"father_id":"H00098","mother_id":"I00041"},"tags":["compiler_ancestor","yale_graduate","clergy","minister","epidemic_death"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 264"}],"marriages":[{"spouse_id":"I00043","children_ids":["H00524","H00525","H00526","H00527","H00528","H00529","H00530","H00531","H00532"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1777,"date_year":1755,"date_month":12,"date_day":10,"location_country":"United States"}],"compiler_ancestor":true,"ministry_positions":[{"role":"Minister","location":"Northampton, Massachusetts","dates":"1753-1777","duration_years":24,"notes":"Ordained Dec 5, 1753; settled there 24 years until death by smallpox"}],"ordination":{"date":{"year":1753,"month":12,"day":5},"location":"Northampton, Massachusetts"},"primary_residence":{"city":"Northampton","state":"Massachusetts","notes":"Minister here 24 years 1753-1777. Yale 1751, ordained Dec 5, 1753."},"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"religion","header":"Took Jonathan Edwards' Northampton pulpit, died of smallpox","body":"Ordained in 1753, he became pastor at Northampton, Massachusetts — the church where Jonathan Edwards had preached until his dismissal in 1750. He held that pulpit for nearly 25 years, dying of smallpox on February 6, 1777, in his 48th year. His was the most prominent pastoral appointment held by any Hooker descendant of his generation."},{"number":2,"category":"family","header":"His wife's father, Colonel Worthington, named Worthington Parish","body":"He married Sarah Worthington, daughter of Colonel Worthington of Springfield, Massachusetts — the man who gave his name to Worthington Parish in Berlin, Connecticut, the parish where the Hart and Hooker families had long been prominent. The marriage connected the Hooker line to one of western Massachusetts's most distinguished families."},{"number":1,"category":"death","header":"Smallpox took the Northampton pastor at forty-seven","body":"He served as pastor of the Northampton MA Congregational Church from 1753 until smallpox killed him in February 1777 at forty-seven. His daughter Sarah Hooker married the Northampton lawyer Caleb Strong nine months later — passing the Hooker name into the family of a future Massachusetts Governor and U.S. Senator."}],"cross_connections":[{"type":"civic_connection","related_id":"H00379","display_label":"Edwards's daughter refused his pulpit and her chair sat in the vestibule.","link_text":"Mary Edwards Dwight"}],"education":[{"degrees":[{"degree":"B.A.","year":1751}],"notes":"Yale College class of 1751","degree":"B.A.","school_name":"Yale College","graduation_year":1751,"institution_id":"INST022"}],"bio":{"display_name":"Rev. John Hooker","title":"Reverend","first_name":"John","last_name":"Hooker","married_names":[]},"landmarks":[],"residence":{"city":"Northampton","state":"Massachusetts","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1751"}],"artworks":[],"quotes":[],"military_service":[],"slug":"john-hooker-1729"},"I00043":{"id":"I00043","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1732,"month":1,"day":27,"city":"Springfield","state":"Massachusetts"},"death":{"year":1817,"month":4,"day":5,"city":"Northampton","state":"Massachusetts"},"marriages":[{"spouse_id":"H00264","children_ids":["H00524","H00525","H00526","H00527","H00528","H00529","H00530","H00531","H00532"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1777,"date_year":1755,"date_month":12,"date_day":10}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 526"}],"parents":{"father_id":"X00053","mother_id":"X00054"},"gender":"female","tags":[],"number_of_marriages"