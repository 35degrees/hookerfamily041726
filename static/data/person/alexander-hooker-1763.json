ry":"legacy","header":"His Windsor house is on the National Register","body":"He built the James Hooker House ca. 1772 at 118 Palisado Avenue, Windsor — now part of the Palisado Avenue Historic District on the National Register of Historic Places. The interior was later gutted for Chaffee School classrooms but the Federal-period exterior survives under Greek Revival additions."}],"institutions":[{"institution_id":"INST070","institution_blurb":"Silent partner; one of New England's great Revolutionary-era trading houses."}],"landmarks":[{"landmark_id":"LM015","landmark_blurb":"He built this house c.1772; it survives on Palisado Avenue's National Register district."}],"bio":{"display_name":"Captain James Hooker","first_name":"James","maiden_name":"Hooker","title":"Captain","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778904974/captjameshooker_rjjclc.jpg","photo_notes":"Portrait of Captain James Hooker (1742-1805), Windsor CT merchant."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Merchant and Silent Partner","organization":"Hartford and Windsor, Connecticut","end_year":1805,"notes":"Principal of INST070 Hooker and Chaffee. Succeeded to father's Hartford business with brothers; established Windsor branch. See INST070 for full firm history."}],"slug":"james-hooker-1742"},"X00317":{"id":"X00317","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1743},"death":{"year":1765},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00348","children_ids":["H00793"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[