nt"],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"I01313","date_year":1937,"date_month":6,"date_day":19,"location_city":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1996,"children_ids":["HD5146"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1916,"country":"United States"},"death":{"year":2000,"age":84,"country":"United States"},"residence":{},"burial":{},"baptism":{},"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Mayflower Elder Brewster descent on father's side","body":"Justine Arnold was a documented descendant of Elder William Brewster — the senior elder of the Plymouth Colony Pilgrims who arrived on the Mayflower in 1620. The Brewster line came through her father Dr. Harold Sears Arnold's family. The Mayflower connection placed her in two of the most documented founding-era American ancestral lines: Brewster (Mayflower 1620) and Hooker (Hartford 1636) through her mother."},{"number":2,"category":"family","header":"Yale Fine Arts student married fellow student","body":"Justine attended Mrs. Day's School in New Haven and the Yale School of Fine Arts. On June 19, 1937 at Christ Church New Haven, she married Edward Mortimer Linforth — also a Yale School of Fine Arts student and son of Professor Ivan M. Linforth of Berkeley California. Her cousin Leeanne Gwynne (the Portland piano teacher) was a flower girl at the wedding and her brother Ingersoll 'Ingy' Arnold served as an usher."}],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Justine Ingersoll Linforth","first_name":"Justine","last_name":"Linforth","maiden_name":"Arnold","middle_name":"Ingersoll","married_names":["Linforth"],"gender":"female"},"slug":"justine-linforth-1916"},"I01313":{"id"