cation_state":"Connecticut"},{"children_ids":["HD0690","HD0691","HD0692","HD0693","HD0694"],"spouse_id":"X00232","marriage_number":2,"date_year":1777}],"death":{"year":1822,"month":6,"day":16,"city":"Springfield","state":"Ohio"},"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR001","side":"United States","rank":"Captain (called)","service_years":"~1775-1782 (approximately 7 years)","units":["Continental Army teamster / transportation trains"],"role":"Served approximately seven years, mostly as a teamster in transportation trains. Called 'Captain.' His first wife Sarah Hubbard died in Wallingford CT while Raphael was away with the army — their son Agathus was about 2 months old at the time."}],"bio":{"display_name":"Raphael Hurlbut","notes":"Hurlbut Family Genealogy 1888 entry #320","first_name":"Raphael","last_name":"Hurlbut","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"family","header":"Wife died with infant while he served","body":"Raphael Hurlbut's first wife Sarah Hubbard died in Wallingford Connecticut in 1776 while Raphael was away with the Continental Army. Their son Agathus was about two months old at the time. The single-event combination — wife's home death, infant son, husband absent on extended military service — captured the personal cost of the Revolutionary War to families left behind on the Connecticut homefront."},{"number":2,"category":"military","header":"Seven years Continental Army teamster, called Captain","body":"Raphael Hurlbut served approximately seven years in the Continental Army — one of the longer single-soldier tours among Connecticut-line Hooker descendants. He served mostly as a teamster in the transportation trains, the supply-line logistics work that was distinct from frontline combat but was just as essential to the army's operations. He was called 'Captain' by his contemporaries."},{"number":3,"category":"family","header":"Connecticut to Ohio migration 1812, died Springfield","body":"Raphael lived first at Wallingford Connecticut, then at Salisbury Connecticut, and in 1812 removed to Springfield Ohio where he died June 16, 1822 around age seventy-eight. His second wife Abigail Riley Knott (widow of Giles Nott) later married John Hamilton in Ohio after Raphael's death. His father Dr. James Hurlbut, one of the founders of Connecticut medicine, had lived with him in Wallingford in his final years before returning to die in Wethersfield Connecticut."}],"slug":"raphael-hurlbut-1744"},"X00232":{"id":"X00232","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1759},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD0676","date_year":1777,"children_ids":["HD0690","HD0691","HD0692","HD0693","HD0694"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"death":{},"cross_connections":[],"bio":{"display_name":"Abigail Nott","first_name":"Abigail","nickname":"Riley","maiden_name":"Nott","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"abigail-nott-1759"},"I00153":{"id":"I00153","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1717,"city":"Kensington (Farmington)","state":"Connecticut"},"death":{"year":1794,"month":4,"day":11,"city":"Wethersfield","state":"Connecticut","cause":"Cancer of the leg"},"parents":{"father_research_notes":"Jonathan Hurlbut (Hurlbut genealogy entry 118)"},"marriages":[{"spouse_id":"H00269","children_ids":["HD0676","HD0677","HD0678","HD0679","HD0680","HD0681","HD0682","HD0683","HD0684"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1789},{"children_ids":[],"spouse_id":"X00237","marriage_number":2,"date_year":1790}],"sources":[{"short":"Hurlbut family genealogy","notes":"Entry 118"},{"short":"Thacher's Medical Biography","notes":"Memoir of Dr. Hurlbut (contains some errors per Hurlbut genealogy)"}],"gender":"male","tags":["physician"],"number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"title":"Doctor","display_name":"Doctor James Hurlbut","first_name":"James","last_name":"Hurlbut","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Called a father of medicine in Connecticut","body":"He practiced widely in Kensington, Berlin, and Wethersfield from the 1740s through the 1790s. Hinman's Early Connecticut Settlers ranked him high in his profession."},{"number":2,"category":"character","header":"Drink erased his name from the church","body":"He fell into intemperance in middle age and the church removed him from membership. He had been careless in money matters his whole life, often not billing for his services."},{"number":3,"category":"legacy","header":"Emma Willard remembered him from her childhood","body":"Decades after his death she wrote that 'Dr. Hurlbut must have been a remarkable man, since he impressed himself so vividly upon the generation who came after him.' He had been her mother's physician."},{"number":4,"category":"marriage","header":"Days into marriage, high words and parting","body":"After his first wife Abigail Hart died, he married the widow of Robert Booth of Glastonbury late in life. Within days the union dissolved into 'high words' and a brief unhappy alliance."},{"number":5,"category":"death","header":"Died in rags, buried with no marker","body":"Cancer of the leg killed him in April 1794 at a friend's house in Wethersfield. He was buried near the north wall of Wethersfield churchyard with no monument."}],"slug":"james-hurlbut-1717"},"H00269":{"id":"H00269","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1723,"month":7,"day":21,"city":"Kensington","state":"Connecticut"},"death":{"year":1789,"month":11,"city":"Kensington/Wethersfield","state":"Connecticut"},"parents":{"father_id":"I00028","mother_id":"H00099"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 269"},{"short":"Hurlbut Family Genealogy 1888","notes":"Entry 118"}],"marriages":[{"spouse_id":"I00153","children_ids":["HD0676","HD0677","HD0678","HD0679","HD0680","HD0681","HD0682","HD0683","HD0684"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1789,"date_year":1742,"location_city":"Kensington","location_state":"Connecticut"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Abigail Hart","first_name":"Abigail","maiden_name":"Hart","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"abigail-hart-1723"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}