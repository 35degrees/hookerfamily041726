emetery_id":"CEM293"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"include_in_path_calculation":true,"descent_paths_to_thomas":2,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD3938","mother_id":"I00527"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00530","date_year":1899,"location_city":"West Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Body shipped from Tucson to New Haven, 1925","body":"Mabel Stiles Warner died at her Tucson Arizona home on January 6, 1925 age 46, having moved there only eleven months earlier. Her body was shipped back to New Haven Connecticut by the Reilly Undertaking Company, where she joined her parents at the family plot in New Center Cemetery, North Haven."},{"category":"death","header":"Tucson home eleven months before her death","body":"She died 6 January 1925 at her South Scott Street home in Tucson Arizona — her residence of only the past eleven months. The move had likely been a health-driven relocation to desert air, common among consumptive patients of the early twentieth century.","number":2},{"category":"marriage","header":"1899 home wedding with palms and Fichtl's orchestra","body":"She married Charles Bennet Warner in 1899 at her father's West Haven home at 6 PM — described as a 'pretty home wedding' with rich white satin gown, tulle veil fastened with lilies of the valley, an improvised altar of palms and spring blossoms, and Fichtl's orchestra playing bridal music. Rev R H Gessner of Christ Episcopal Church officiated; the couple took a two-week wedding trip after a wedding supper.","number":3},{"category":"death","header":"Sister escorted body two thousand miles home","body":"Her sister Mrs Edward Stiles of Hartford was with Mabel at her Tucson death and accompanied the body home. The Reilly Undertaking Company shipped Mabel's body back to New Haven by rail — a journey of roughly two thousand miles under solo sisterly escort, for burial at New Center Cemetery.","number":4}],"quotes":[],"sources":[{"label":"FindAGrave 126757591","url":"https://www.findagrave.com/memorial/126757591/mabel-warner"}],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"slug":"mabel-warner-1878"}},"burialCemetery":{"id":"CEM292","name":"Oak Grove Cemetery","city":"West Haven","county":"New Haven","state":"Connecticut","country":"United States","findagrave_id":"103532","primary_url":"https://www.findagrave.com/cemetery/103532/oak-grove-cemetery","hooker_connections":["I00516","I00528","I00530"],"notes":"Cemetery in West Haven, New Haven County CT. Burial site of Frances 'Fannie' Kimberly Goodyear (I00516)."},"institutionsById":{},"crossConnections":[]}