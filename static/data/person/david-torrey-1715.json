rks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"He came of Salisbury’s tanner-grantee family","body":"Paul Batt was born a twin at Salisbury in 1643, into the family of Christopher Batt — a tanner and one of the town’s twelve original grantees, who had crossed from Wiltshire on the ship Bevis in 1638, slipping out just ahead of the King’s ban on sailings."},{"number":2,"category":"family","header":"His father died in a freak shooting","body":"When Paul was a young man his father was accidentally shot and killed by another of his sons, who had been firing at a target in the family orchard at Boston."},{"number":3,"category":"family","header":"He left his shop to his daughter","body":"Paul married Sarah Wilson in 1674 and died in 1678 at about thirty-five; his will left his Boston tenement and shop to his infant daughter Sarah, charged with the support of his widowed mother."}],"slug":"paul-batt-1643"},"H00020":{"id":"H00020","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":3,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1650,"month":1,"day":1,"city":"Dorchester","state":"Massachusetts","country":"United States"},"death":{"year":1725,"city":"Mansfield","state":"Connecticut","country":"United States"},"parents":{"father_id":"I00004","mother_id":"H00006"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 20"}],"marriages":[{"spouse_id":"I00058","children_ids":["HD0067","HD5453"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1678,"date_year":1674,"date_month":1,"date_day":1,"location_city":"Boston","location_state":"Massachusetts"},{"spouse_id":"I00059","children_ids":["H00067","H00068","H00069","HD5398","X00072"],"marriage_number":2,"end_type":"death_of_survivor","end_year":1725,"date_year":1680,"date_month":5,"date_d