eer","header":"Naval Academy Commandant of Midshipmen 1875-1878","body":"He served as Commandant of Midshipmen at the United States Naval Academy from 1875 to 1878 — the chief discipline and training officer for the entire midshipman corps. He had previously commanded the screw steamship USS Saco with the Asiatic Fleet from 1870 to 1872."},{"number":3,"category":"legacy","header":"Two USS Terry destroyers were named for him","body":"Two United States Navy ships have been named USS Terry in his honor — the destroyer DD-25 (commissioned 1910, served WWI) and a later destroyer DD-513. He died of tuberculosis at Manitou Springs in 1882 and is buried at the U.S. Naval Academy Cemetery."}],"marriages":[{"marriage_number":1,"spouse_id":"I00300","children_ids":[],"date_year":1867,"date_month":12,"date_day":25,"location_city":"Detroit","location_state":"Michigan","end_year":1882,"end_type":"death"}],"number_of_marriages":1,"cross_connections":[{"related_id":"HD1364","type":"family_connection","display_label":"First cousin; both Civil War officers leading the charge","link_text":"Gen. Alfred Howe Terry"},{"type":"military","related_id":"H02014","display_label":"Both fought at Mobile Bay under Admiral Farragut, 1864","link_text":"Rear Admiral James Hooker Strong"},{"type":"in_law","related_id":"X02358","display_label":"was his father-in-law"}],"institutions":[{"institution_id":"INST114"}],"landmarks":[],"artworks":[],"quotes":[],"documents":[],"naming_inspiration":[],"research_tags":[],"research_sources":[],"military_service":[{"war":"American Civil War","war_id":"WAR006","active_in_war":true,"rank":"Lieutenant Commander","final_rank":"Commander","dates":"1861-1865","unit":"USS Richmond, Western Gulf Blockading Squadron","battles":["Battle of the Head of Passes (1861)","Forts Jackson and St. Philip (1862)","Capture of New Orleans (1862)","Siege of Vicksburg (1863)","Siege of Port Hudson (1863)","Battle of Mobile Bay (1864)"],"wounded":false,"notes":"Career US Navy officer 1853