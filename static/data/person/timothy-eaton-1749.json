1778 and 1791, all baptized at St. John's Church in North Haven. She died in 1792 at age thirty-seven, less than a year after the seventh baptism. Her husband Timothy Eaton remarried twice — his second wife Catherine Walter died in 1797 after producing one child, and a presumed unnamed third wife produced a son baptized in 1800; the family network shows the high cost of post-Revolutionary childbearing in colonial Connecticut."}],"slug":"elizabeth-eaton-1755"},"H01165":{"id":"H01165","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Hannah","last_name":"Eaton","married_names":[],"extra_names":["Heaton (FamilySearch variant; corruption of Eaton)"],"gender":"female","display_name":"Hannah Eaton"},"birth":{"year":1778,"city":"North Haven","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{"year":1778,"city":"North Haven","county":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1851},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00505","mother_id":"H00449"},"number_of_marriages":0,"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry #1165"},{"short":"FamilySearch (L7YM-XXT)"}],"research_sources":[],"documents":[],"slug":"hannah-eaton-1778"},"H01166":{"id":"H01166","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Betsey","last_name":"Eaton","married_names":[