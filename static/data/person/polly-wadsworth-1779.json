"Music director","organization":"St. John's Church","location":"North Haven Connecticut","start_year":1783,"notes":"Per Frost Family genealogy (BIB007): had 'full charge of the music in St. John's Church at No. Haven, Conn.' from 1783; called 'the father of music' in 1775."},{"role":"Chairmaker, coffin maker","location":"Muddy River, North Haven Connecticut","notes":"Per Frost Family genealogy: chairmaker at Muddy River; church membership records from 1763 note he made coffins for ten shillings each."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["musician"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"arts","header":"'Father of music' at North Haven, 1775","body":"Church records as early as 1763 note he made coffins for ten shillings each. From 1783 he directed the music at St. John's Church North Haven while working as a chairmaker at Muddy River."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry #448 (named as Mabel's husband)"},{"short":"Frost Family genealogy","page":"BIB007"},{"short":"FindAGrave","page":"Memorial at Montowese Cemetery, North Haven CT"},{"short":"WikiTree (Frost-8489)"}],"research_sources":[],"documents":[],"slug":"titus-frost-1748"},"H00448":{"id":"H00448","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1753,"month":2,"day":12,"city":"North Haven","county":"New Haven","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00238","mother_id":"I00158"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry #448"},{"short":"Frost Family genealogy","page":"BIB007"},{"short":"FamilySearch (KLJY-XQC)"}],"gender":"female","marriages":[{"marriage_number":1,"spouse_id":"I00504","date_year":1773,"date_month":7,"date_day":29,"location_city":"North Haven","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","children_ids":["H01159","H01160","H01161","H01162","H01163","H01164","HD3902"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1834,"month":5,"day":1,"city":"North Haven","county":"New Haven","state":"Connecticut","country":"United States"},"cross_connections":[],"bio":{"display_name":"Mabel Stiles Frost","first_name":"Mabel","maiden_name":"Stiles","married_names":["Frost"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Husband Titus Frost called father of music","body":"Mabel's husband Titus Frost was known locally as 'the father of music at North Haven' — the recognized musical leader of the small Connecticut town that had emerged from the colonial Quinnipiac settlement. He also worked as a chairmaker at Muddy River in New Haven, combining the musical reputation with the craftsman trade of an established North Haven householder. The dual identity of musician and chairmaker placed him among the multi-trade artisans typical of post-Revolutionary Connecticut village economies."},{"number":2,"category":"family","header":"Seven children documented from 1773 marriage","body":"Mabel and Titus Frost married July 29, 1773 in North Haven Connecticut and had seven documented children — Samuel, Willard 'William,' Polly, Julia, John, Leverett, and Titus Jr. The substantial completed family size was typical of the post-Revolutionary North Haven Stiles-Frost generation, with most of the children remaining in or near the town through their adult lives."},{"number":3,"category":"family","header":"Born North Haven 1753, died there 1834","body":"Mabel Stiles Frost was born February 12, 1753 in North Haven Connecticut — the village then still called Quinnipiac — and died there May 1, 1834 at age eighty-one. Her father Isaac Stiles Jr. and her grandmother Esther Hooker connected her to the Stiles-Hooker line that ran continuously through the eighteenth-century North Haven community."}],"slug":"mabel-frost-1753"},"H00238":{"id":"H00238","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1729,"month":9,"day":5,"city":"Windsor","state":"Connecticut"},"parents":{"father_id":"I00126","mother_id":"H00092"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 238"}],"marriages":[{"spouse_id":"I00158","children_ids":["H00447","H00448","H00449","H00450","H00451","H00452","H00453a","H00453","H00454"],"marriage_number":1,"date_year":1750,"date_month":5,"date_day":31,"location_city":"New Haven","location_state":"Connecticut"}],"death":{"year":1783,"month":3,"day":13,"city":"North Haven","state":"Connecticut"},"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Isaac Stiles Jr.","first_name":"Isaac","last_name":"Stiles","suffix":"Jr.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"isaac-stiles-jr-1729"},"I00158":{"id":"I00158","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1730,"mon