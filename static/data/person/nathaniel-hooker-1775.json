ffee, which grew very successful during the Revolutionary War era. The firm continued the family's Hartford commercial standing into the next generation."}],"baptism":{"year":1710,"month":10,"day":8,"city":"Hartford","state":"Connecticut","country":"United States"},"institutions":[{"institution_id":"INST022","institution_blurb":"Yale College 1729.","relationship":"alumnus","years":"1729"}],"education":[{"school_name":"Yale College","graduation_year":1729,"institution_id":"INST022"}],"bio":{"display_name":"Captain Nathaniel Hooker","first_name":"Nathaniel","last_name":"Hooker","title":"Captain","married_names":[]},"residence":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"nathaniel-hooker-1710"},"I00054":{"id":"I00054","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"generation_from_john_talcott":3,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1709,"month":1,"day":26,"city":"Hartford","county":"Hartford County","state":"Connecticut","country":"United States"},"death":{"year":1795,"month":7,"day":12,"city":"Windsor","county":"Hartford County","state":"Connecticut","country":"United States"},"parents":{"father_id":"T00045","mother_id":"U00017"},"marriages":[{"marriage_number":1,"spouse_id":"H00115","location_city":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1763,"children_ids":["H00346","H00347","H00348","H00349","H00350"]}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 115"}],"talcott_book_id":"69","burial":{"cemetery_id":"CEM107"},"cross_connections":[{"type":"founding_family_nexus","related_id":"H00356","display_label":"Sister-in-law — Mary Russell married her brother Matthew Talcott.","link_text":"Mary Russell Talcott"}],"gender":"female","tags":["hooker_talcott_convergence"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"She and brother Matthew both married Hooker descendants","body":"She married Captain Nathaniel Hooker — a direct Hooker-surname descendant. Her brother Matthew Talcott simultaneously married Mary Russell, herself a Hooker descendant through the Pierpont line. Two of Governor Joseph Talcott's children marrying into the Hooker family in the same generation is why \"Talcott\" became a permanent name in the Hooker tree."}],"bio":{"display_name":"Eunice Talcott Hooker","first_name":"Eunice","last_name":"Hooker","maiden_name":"Talcott","married_names":["Hooker"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"eunice-talcott-1709"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}