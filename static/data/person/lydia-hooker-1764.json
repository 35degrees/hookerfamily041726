ale","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"military","related_id":"T00459","display_label":"Served in his Troop of horses, Fort William Henry alarm 1757.","link_text":"Col. Elizur Talcott"},{"type":"military","related_id":"H00410","display_label":"Nephew killed June 1757; uncle enlisted that August.","link_text":"Martin Hooker"},{"type":"military","related_id":"H00583","display_label":"Fellow Hooker descendant in same 1757 Fort William Henry alarm.","link_text":"Samuel Hart"},{"type":"cousin_marriage","related_id":"H00420","display_label":"Sister Elizabeth's son who married his daughter Sarah 1807.","link_text":"Hooker Gilbert"},{"type":"family_connection","related_id":"I00150","display_label":"His son Hooker Gilbert married my daughter Sarah in 1807.","link_text":"Moses Gilbert"}],"bio":{"display_name":"Samuel Hooker","first_name":"Samuel","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"French and Indian Wars","war_id":"WAR003","rank":"Private","rank_start":"Private","rank_end":"Private","rank_year_start":1757,"rank_year_end":1757,"unit":"Maj. Elizur Talcott of Glastonbury — Troop of horses","service_years":"August 1757 — 14 days","battles":["BTL048"],"notes":"At age 31 enlisted in Maj. Elizur Talcott of Glastonbury's Troop of horses for service in the alarm for the relief of Fort William Henry and parts adjacent, August 1757 — 14 days of service. Enlisted approximately two months after his nephew Martin Hooker (H00410) was killed June 10, 1757 in the same war. The connection to Maj. Elizur Talcott (T00459, gen 3 from John Talcott) is a Hooker↔Talcott cross-tree military link."},{"war":"American Revolutionary War","war_id":"WAR004","rank":"Private","rank_year_start":1777,"rank_year_end":1778,"unit":"Capt. Nathaniel Chapman's Company, Lt-Col Joseph Baldwin's Regiment, Col. Mead's drafted men","service_years":"December 28, 1777 – March 1, 1778","notes":"Served under Capt. Nathaniel Chapman in Lt-Col Joseph Baldwin's Regiment at Fishkill, NY. DAR Ancestor #A057686 (Connecticut, Private). Source: Record of Service of Connecticut Men in the War of the Revolution (1889), p. 522."}],"narrative_blocks":[{"number":1,"category":"military","header":"Veteran of two colonial wars","body":"Samuel served as Private in two of the colonial era's military campaigns twenty years apart. In August 1757 at age 31 he joined Maj. Elizur Talcott's Troop of horses for fourteen days during the Fort William Henry alarm. Twenty years later at age 51 he served again from December 1777 to March 1778 in Capt. Nathaniel Chapman's Company at Fishkill NY — earning DAR ancestor recognition #A057686."},{"number":2,"category":"military","header":"Enlisted weeks after his nephew Martin's death","body":"Samuel's nephew Martin Hooker — son of Samuel's brother Andrew — was killed in the same war on June 10, 1757 at the deadly sentry post documented in Edward Hooker's 1909 genealogy. About two months later in August 1757, Samuel Hooker Jr enlisted at age 31 in Maj. Elizur Talcott's Troop of horses for the Fort William Henry alarm. Whether the enlistment was motivated by news of Martin's death is undocumented but the timing is suggestive."}],"slug":"samuel-hooker-1726"},"I00157":{"id":"I00157","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1732,"month":1,"day":28,"city":"Southington","state":"Connecticut"},"death":{"year":1809,"month":5,"day":7,"city":"Kensington","state":"Connecticut"},"burial":{"cemetery_id":"CEM008","plot_notes":"Christian Lane Cemetery, Kensington, Connecticut"},"parents":{"mother_research_notes":"Sarah Savage Norton","father_research_notes":"Ebenezer Norton of Bristol CT"},"marriages":[{"spouse_id":"H00228","children_ids":["H00429","H00430","H00431","H00432","H00433"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 228"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"family_connection","related_id":"H00224","display_label":"Her son Hooker Gilbert married my daughter Sarah in 1807.","link_text":"Elizabeth Hooker Gilbert"}],"bio":{"display_name":"Sarah Norton Hooker","first_name":"Sarah","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Norton"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-norton-1732"},"H00086":{"id":"H00086","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1688,"month":4,"day":6,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00028","mother_id":"I00056"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 86"}],"death":{"year":1787,"month":3,"day":1,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"marriages":[{"marriage_number":1,"spouse_id":"I00119","date_year":1711,"date_month":1,"date_day":9,"location_city":"Guilford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1751,"children_ids":["H00223","H00224","H00225","H00226","H00227","H00228","H00229","H00230","H00231"]},{"marriage_number":2,"spouse_id":"I00120","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1771,"children_ids":[]}],"tags":["extraordinary_longevity"],"cross_connections":[],"burial":{"cemetery_id":"CEM008","plot_notes":"Gravestone gives age 98. EH gives age 99."},"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"landmarks":[{"landmark_id":"LM043","landmark_blurb":"His father lived here, directly opposite the Giles Hooker house on Main Street."}],"narrative_blocks":[{"number":1,"category":"death","header":"He heard his brother died","body":"On hearing that his younger brother Giles had died at age 96, Samuel Hooker \"fell back in his chair and expired\" in Kensington on March 1, 1787, age 98. Their sister later wrote: \"her brother Samuel died in 1787, ae. 99 — a long lived race.\" Two brothers, together accounting for nearly 195 years of life, died within ten days."},{"number":2,"category":"marriage","header":"His wife was a granddaughter of the Governor","body":"Mercy Leete, whom he married in 1711, was the granddaughter of Governor William Leete of Connecticut Colony. His uncle James Hooker had also married a Leete granddaughter — Mary Leete, Mercy's first cousin through the same Governor. Two generations of the Hooker family married into the Leete gubernatorial line."}],"bio":{"display_name":"Samuel Hooker","first_name":"Samuel","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"artworks":[],"quotes":[],"military_service":[],"slug":"samuel-hooker-1688"},"I00119":{"id":"I00119","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1688,"city":"Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1751,"month":2,"day":4,"city":"Kensington","state":"Connecticut","country":"United States"},"parents":{"father_id":"X00108","mother_id":"X00109"},"marriages":[{"spouse_id":"H00086","children_ids":["H00223","H00224","H00225","H00226","H00227","H00228","H00229","H00230","H00231"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 86"}],"cross_connections":[{"type":"parallel_marriage","related_id":"I00061","display_label":"First cousins — both Leete granddaughters who married Hooker men.","link_text":"Mary Leete Hooker"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Granddaughter of Governor William Leete","body":"Her father Andrew Leete was the son of Governor William Leete, who governed both New Haven Colony and the Colony of Connecticut — the only person ever to hold both offices. Her first cousin Mary Leete (through the Governor's son William Jr.) also married a Hooker man in the same generation."}],"bio":{"display_name":"Mercy Leete Hooker","notes":"Also given as \"Mary\" — EH gives \"Mercy (Mary) Leete\"","first_name":"Mercy","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Leete"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mercy-leete-1688"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}