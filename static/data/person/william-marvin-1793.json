riages":[{"spouse_id":"X00216","children_ids":["H01238","H01239","H01237","H01240","H01236"],"marriage_number":1,"date_year":1757,"date_month":12,"date_day":9}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"military_service":[{"war":"American Revolutionary War","rank":"Lt. Col.","unit":"9th Regiment, Connecticut Militia","notes":"Capt. 1st Co. Norwalk May 1761; Major 9th Regt. May 1775; Major 1st Batt. Col. Whiting Nov 1776; Lt. Col. 9th Regt. May 1777. On committee of Articles of Confederation 1777.","war_id":"WAR004"}],"bio":{"display_name":"Lt. Col. Stephen Saint John","first_name":"Stephen","last_name":"St. John","title":"Lieutenant Colonel","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778792414/stephenstjohnesq-resized_cvqbdg.png","photo_notes":"Portrait of Lt. Col. Stephen Saint John Esq.","bio_blurb":"Norwalk officer of the Connecticut 9th"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"former_ids":["HD0365"],"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave #44152495. Stone: 'Lt Col command of the 9th Reg of Foot Guard of the State of Connecticut who departed this life May the 9th 1785, in the 50th year of his age.'"},"narrative_blocks":[{"number":1,"category":"military","header":"Led Connecticut's 9th Regiment of Foot as Lt.","body":"Stephen Saint John rose to Lieutenant Colonel in command of the 9th Regiment of Foot, Guard of the State of Connecticut — a rank inscribed on his tombstone in East Norwalk Historical Cemetery. His family's marriage alliances connected two of Norwalk's most prominent dynasties: the Saint Johns married into the Fitches across two consecutive generations."},{"number":2,"category":"military","header":"He sent no substitute; his brother did","body":"A Connecticut selectman and Revolutionary office