:{"display_name":"Sr. William Woodworth Bogel","first_name":"William Woodworth","last_name":"Bogel","married_names":[],"title":"Sr.","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781542099/75989926_31f34d39-b13a-477b-82f5-2d693f955f0d_ansnro.jpg","bio_blurb":"West Texas sheep rancher and judge"},"birth":{"year":1855,"date_precision":"exact","month":7,"day":23,"city":"Goshen Township","state":"Ohio","country":"United States"},"death":{"year":1946,"date_precision":"exact","month":6,"day":23,"city":"Marfa","state":"Texas","country":"United States"},"parents":{"father_id":null,"mother_id":null},"marriages":[{"spouse_id":"HD6484","marriage_number":1,"date_year":1882,"children_ids":["HD6490","HD6491","HD6492","HD6493","HD6494","HD6495","HD6496"]}],"tags":["westward_migration"],"burial":{"cemetery_id":"CEM893"},"narrative_blocks":[{"number":1,"category":"character","header":"He practiced speeches naked on a table","body":"At Louisiana State’s military school, young William Bogel and his fellow cadets rid themselves of stage fright by practicing speeches stripped bare atop a barracks table, delivering their oratory above the taunts of the others. The university president once followed the noise and caught him “bare as a new born babe.”"},{"number":2,"category":"politics","header":"His class refused carpetbagger diplomas","body":"Bogel graduated from LSU in 1874 during Reconstruction, when diplomas required the signature of Governor William P. Kellogg — a Republican the class regarded as a carpetbagger. The entire class of 1874 refused their diplomas in protest; his was later lost when the capitol burned."},{"number":3,"category":"character","header":"Free wool ended his sheep empire","body":"Bogel built up a 10,000-head sheep operation south of Marfa until wool was placed on the “free list” under President Cleveland and prices collapsed from forty cents a pound to four. Badly bent but not broken, he switched to cattle and swore he would never look a sheep in the face again."}],"slug":"william-woodworth-bogel-1855"},"HD6490":{"id":"HD6490","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":11},"bio":{"display_name":"Jessie Bogel Kirk","first_name":"Jessie","last_name":"Kirk","married_names":[],"maiden_name":"Bogel"},"birth":{"year":1882,"date_precision":"exact"},"death":{"year":1956,"date_precision":"exact"},"parents":{"father_id":"I01800","mother_id":"HD6484"},"marriages":[],"tags":[],"slug":"jessie-kirk-1882"},"HD6491":{"id":"HD6491","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":11},"bio":{"display_name":"Augustus Julius Bogel","first_name":"Augustus Julius","last_name":"Bogel","married_names":[]},"birth":{"year":1884,"date_precision":"exact"},"death":{"year":1934,"date_precision":"exact"},"parents":{"father_id":"I01800","mother_id":"HD6484"},"marriages":[],"tags":[],"slug":"augustus-julius-bogel-1884"},"HD6492":{"id":"HD6492","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":11},"bio":{"display_name":"Jr. William Woodworth Bogel","first_name":"William Woodworth","last_name":"Bogel","married_names":[],"title":"Jr."},"birth":{"year":1885,"date_precision":"exact"},"death":{"year":1919,"date_precision":"exact"},"parents":{"father_id":"I01800","mother_id":"HD6484"},"marriages":[],"tags":[],"slug":"william-woodworth-bogel-1885"},"HD6493":{"id":"HD6493","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":11},"bio":{"display_name":"Galitzin Newton Bogel Sr.","first_name":"Galitzin Newton","last_name":"Bogel","married_names":[],"title":"Sr.","suffix":"Sr."},"birth":{"year":1886,"date_precision":"exact"},"death":{"year":1973,"date_precision":"exact"},"parents":{"father_id":"I01800","mother_id":"HD6484"},"marriages":[],"tags":[],"narrati