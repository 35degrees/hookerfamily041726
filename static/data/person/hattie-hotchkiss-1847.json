scendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1781,"month":12,"day":28,"city":"Hamden","county":"New Haven County","state":"Connecticut","country":"United States"},"death":{"year":1844,"month":4,"day":21,"city":"Hamden","county":"New Haven County","state":"Connecticut","country":"United States"},"parents":{"father_id":"I00177","mother_id":"H00459"},"marriages":[{"marriage_number":1,"spouse_id":"I00603","location_state":"Connecticut","location_country":"United States","children_ids":["HD4125","HD4126","HD4127","HD4128","HD4129","HD4136"]}],"number_of_marriages":1,"tags":[],"sources":[{"short":"FindAGrave"}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Eli Tuttle","first_name":"Eli","last_name":"Tuttle","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Seven documented children with Thankful Asenath Perkins","body":"Eli Tuttle and his wife Thankful Asenath Perkins Tuttle had seven documented children between 1807 and the late 1820s. Five of the seven were Lucius (1807-1885 who stayed in Hamden), Leonard (1810-1875 Ohio migration), Lauren (1815-1860 two wives), Mehitable Tuttle Cooper (1819-1868 two husbands), and Lucy (died 1827). Two more — Louisa and Asahel — died young."},{"number":2,"category":"death","header":"Daughter Louisa died as an infant in 1822","body":"Eli and Thankful's daughter Louisa Tuttle was born in 1821 and died in 1822 — an infant death within her first year. The early death was one of three children Eli outlived: Louisa as infant; Lucy who died in 1827 as a young child; and Asahel by 1850 in his adulthood. The cumulative loss across both childhood and adult-child mortality was typical of nineteenth-century rural Connecticut family experience."},{"number":3,"category":"family","header":"Born and died in Hamden, Connecticut","body":"Eli Tuttle was born December 28, 1781 in Hamden, New Haven County Connecticut, son of Jotham Tuttle and Kezia Munson Tuttle. He died April 21, 1844 in Hamden at age sixty-two and is buried at Mount Carmel Burying Ground, Hamden. The lifelong-Hamden residence pattern was common among the Tuttle-Munson cluster of north New Haven County families."}],"burial":{"cemetery_id":"CEM312","plot_notes":"Mount Carmel Burying Ground, Hamden CT — alongside his mother Kezia Munson Tuttle"},"slug":"eli-tuttle-1781"},"I00603":{"id":"I00603","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Thankful","middle_name":"Asenath","last_name":"Tuttle","maiden_name":"Perkins","married_names":[],"gender":"female","display_name":"Thankful Asenath Perkins Tuttle"},"birth":{"year":1783,"month":1,"day":16,"city":"Woodbridge","county":"New Haven County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1861,"country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3142","location_state":"Connecticut","location_country":"United States","children_ids":["HD4125","HD4126","HD4127","HD4128","HD4129","HD4136"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"thankful-perkins-1783"}},"burialCemetery":{"id":"CEM320","name":"In Memo