e":"Rhode Island","country":"United States"},"burial":{},"residence":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":6,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["science","exploration"],"notable_blurb":"Geologist and explorer of Asia's interior","primary_url":"https://en.wikipedia.org/wiki/Raphael_Pumpelly","primary_url_label":"Wikipedia"},"parents":{"father_id":"I01523","father_name":"William Pumpelly","mother_id":"T01812","mother_name":"Mary H. Welles"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_name":"Eliza F. Shepard","date_year":1869,"spouse_id":"I01540","children_ids":["TD0335","TD0336","TD0337"]}],"tags":[],"narrative_blocks":[{"number":1,"category":"science","header":"He mapped Asia's deserts for American science","body":"Trained as a mining engineer, Raphael Pumpelly surveyed mineral country across Japan, China, and Mongolia in the 1860s and crossed the Gobi Desert. His later expeditions into Russian Central Asia searched for the origins of agriculture and early civilization."},{"number":2,"category":"science","header":"He tied windblown dust to climate history","body":"Pumpelly's studies of loess, the fine wind-laid soil of northern China, helped show how such deposits record ancient climate. At home he directed the northern transcontinental railroad survey and led major government geological surveys."},{"category":"career","header":"He held Harvard's first chair in mining","body":"From 1866 to 1875 Pumpelly served as Harvard's first professor of mining, between expeditions that carried him around the world. He later organized the economic-geology division of the new U.S. Geological Survey and directed its New England branch.","number":3},{"category":"science","header":"His Anau dig pushed Central Asian history back","body":"In 1903 Pumpelly led a Carnegie-funded expedition to the Anau mounds in Turkmenistan, uncovering a settlement he dated to about 4500 BCE. The mineral pumpellyite, found in Michigan's copper country, was later named in his honor.","number":4},{"category":"legacy","header":"He blazed the Pumpelly Trail up Monadnock","body":"From his summer place at Dublin, New Hampshire, Pumpelly cut a ridge trail to the summit of Mount Monadnock that still carries his name. He spent his last decades at Newport and presided over the Geological Society of America in 1905.","number":5}],"sources":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"family_connection","display_label":"descends from Springfield's founder William Pynchon","related_id":"Y00004","link_text":"Hon. William Pynchon"},{"type":"family_connection","display_label":"descends from Connecticut governor Thomas Welles","related_id":"X02354","link_text":"Gov. Thomas Welles"},{"type":"parallel_careers","display_label":"the mineralogist in whose system pumpellyite is classed","related_id":"X00898","link_text":"Edward Salisbury Dana"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Raphael","last_name":"Pumpelly","married_names":[],"display_name":"Raphael Pumpelly","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780757921/18514323_ba588cd9-8d5f-46cb-89d2-794a87890734_j2tjyt.jpg"},"military_service":[],"education":[{"school_name":"Bergakademie Freiberg","dates":"1856-1859","type":"graduate","notes":"Mining engineering."}],"career":[{"role":"Geologist & explorer","organization":"Surveys of Japan, China, Mongolia","start_year":1861,"notes":"Mining & geological surveys."},{"role":"Director","organization":"Northern Transcontinental Survey","notes":"Railroad route survey."}],"slug":"raphael-pumpelly-1837"},"I0