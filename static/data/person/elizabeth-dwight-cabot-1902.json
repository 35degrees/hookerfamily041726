:["I01542"]}],"tags":["author","harvard_graduate","architect"],"narrative_blocks":[{"category":"literature","header":"He wrote the first life of Emerson","body":"A close friend of Ralph Waldo Emerson, James Elliot Cabot served as his literary executor and wrote the first authorized biography, A Memoir of Ralph Waldo Emerson (1887). He had earlier helped found the Atlantic Monthly.","number":1},{"category":"arts","header":"A reluctant lawyer who turned to architecture","body":"Harvard College and Harvard Law trained, Cabot found trial work daunting and left the bar. He joined his brother Edward's architectural practice, designing buildings and helping run the office.","number":2},{"category":"arts","header":"He gave Boston's museum its plaster casts","body":"An early trustee of the Museum of Fine Arts, Cabot championed acquiring plaster casts of famous Greek and Roman statues. He believed the young museum would never afford originals, and also served the Boston Athenaeum.","number":3},{"category":"literature","header":"His first essay graced the final Dial","body":"Cabot's essay on Immanuel Kant opened the last issue of The Dial in April 1844, his first appearance in print. He later helped edit the short-lived Massachusetts Quarterly Review alongside Emerson and Theodore Parker.","number":4}],"sources":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus and overseer","years":"1840"}],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"in_law","related_id":"TD0336","display_label":"married his son Thomas"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"James Elliot","last_name":"Cabot","married_names":[],"display_name":"James Elliot Cabot","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780763461/59686021_134437993477_xntkj2.jpg"},"military_service":[],"education":[{"institution_id":"INST002","dates":"1840","type":"college","degree":"A.B."},{"institution_