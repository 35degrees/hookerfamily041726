onth":10,"date_day":30}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Phebe Edwards","first_name":"Phebe","last_name":"Edwards","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"phebe-edwards-1768"},"H00514":{"id":"H00514","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1762,"month":8,"day":29,"city":"Woodbury","state":"Connecticut"},"parents":{"father_id":"H00262","mother_id":"I00166"},"tags":["clergy","yale_connection"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 514"}],"marriages":[{"spouse_id":"H00940","children_ids":["H01353","H01354","H01355","H01356"],"marriage_number":1,"date_year":1792,"date_month":6,"date_day":11,"location_city":"Stockbridge","location_state":"Massachusetts"}],"orbit_connections":[{"name":"Joseph Harvey (Yale 1809) — succeeded Asahel at Goshen","relationship":"Harvey succeeded Asahel Hooker as pastor at Goshen CT in 1810","notes":"Yale Biographical Sketches (Dexter): \"The Rev. Asahel Hooker (Yale 1789) was dismissed from his pastorate over the Congregational Church of Goshen, in Litchfield County, on June 12, 1810; and Mr. Harvey thereafter supplied the pulpit with such favor that he was unanimously called to the vacant place.\" Also: Joseph Edwards (Yale, graduated c.1806) \"began the study of theology upon graduation with the Rev. Asahel Hooker (Yale 1789), of Goshen, at the same time conducting an academy there.\" Asahel Hooker's Goshen pastorate was evidently a center of theological training in Litchfield County during the early 19th century. (Yale Biographical Sketches of Grads 1805-1815, Dexter 1912; URL: https://www.cga.ct.gov/hco/books/Biographical_Sketches_of_Grads_of_Yale_1805-1815_1912.pdf)","connection_type":"orbit_non_descendant"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"pastor of the church in Goshen until dismissed","primary_url":"https://www.cga.ct.gov/hco/books/Biographical_Sketches_of_Grads_of_Yale_1805-1815_1912.pdf","primary_url_label":"Source"},"death":{},"cross_connections":[],"bio":{"display_name":"Asahel Hooker","first_name":"Asahel","maiden_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1789"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Eighteen years at Goshen, dismissed for ill health","body":"Asahel Hooker was ordained at Goshen, Connecticut on September 7, 1791, and served the congregation as beloved pastor for eighteen years. He was dismissed June 12, 1810 — not over doctrine or congregational conflict, but because his health had broken. Throughout his Goshen tenure he was a published voice in the Connecticut Evangelical Magazine."},{"number":2,"category":"marriage","header":"Married Jonathan Edwards's granddaughter Phebe Edwards","body":"On June 11, 1792 he married Phebe Edwards (H00940), daughter of Hon. Timothy Edwards and granddaughter of Rev. Jonathan Edwards. Like Asahel, Phebe descended from Thomas Hooker — but through Mary Hooker Pierpont's line rather than the surname line. Their son Edward William Hooker would later write the 1849 biography of Thomas Hooker cited as the foundational source by Edward Hooker's 1909 Descendants."},{"number":3,"category":"family","header":"His son wrote the 1849 Thomas Hooker biography","body":"His son Rev. Edward William Hooker (H01354) wrote The Life of Rev. Thomas Hooker in 1849. The biography became the foundational source for nineteenth-century Hooker scholarship and was cited as a primary reference in Edward Hooker's 1909 Descendants of Rev. Thomas Hooker. Edward William inherited the double Hooker descent — surname line through Asahel, Edwards line through his mother Phebe."}],"education":[{"institution_id":"INST022","dates":"1789","notes":" — Yale College 1789. Son of Asahel Hooker (H00262). Congregational pastor at Goshen CT 1791-1810, Norwich CT 1812-1813. Yale Biographical Sketches mention him as the pastor at Goshen when Joseph Harvey (Yale 1809) succeeded him and when Joseph Edwards (Yale student) studied theology with him."}],"slug":"asahel-hooker-1762"},"H00381":{"id":"H00381","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1738,"month":7,"day":25,"city":"Northampton","state":"Massachusetts"},"death":{"year":1813},"parents":{"father_id":"X00128","mother_id":"HD0418"},"tags":["lawyer","judge"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 381"}],"prominent_name_reason":"Hon. Timothy Edwards (1738-1813) — Princeton 1757; merchant and judge of Stockbridge MA. His son \"Edward Hooker Edwards\" (b.1763) carried the Hooker name explicitly — a deliberate tribute to the founding ancestor in the 5th generation of Edwards descendants.","marriages":[{"spouse_id":"X00709","children_ids":["H00936","H00937","H00938","H00939","H00940","H00941","H00942","H00943","H00944","H00945","H00946","H00947","H00948","H00949"],"marriage_number":1,"date_year":1760,"date_month":9,"date_day":25,"location_city":"Elizabethtown","location_state":"New Jersey"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Governor of NJ 1812"},"cross_connections":[],"bio":{"display_name":"Timothy Edwards","first_name":"Timothy","last_name":"Edwards","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"education","header":"Princeton 1757 — son of Jonathan Edwards","body":"He graduated Princeton in 1757 and went to Elizabethtown, New Jersey to practice law. He moved to Stockbridge, Massachusetts around 1770, where he served as a judge — earning the 'Hon.' style on his name."},{"number":2,"category":"family","header":"Married into the Ogden family of New Jersey","body":"His wife Rhoda Ogden was sister of Aaron Ogden (Governor of New Jersey 1812-1813) and Matthias Ogden, a lieutenant colonel who marched to Quebec with Benedict Arnold in 1775. Through her, the Edwards-Hooker line connected to early New Jersey political and military leadership."},{"number":3,"category":"family","header":"Daughter Phebe married a Hooker — double convergence","body":"His daughter Phebe Edwards married Rev. Asahel Hooker — both descended from Thomas Hooker, creating a double Hooker convergence in their children. Phebe's path back went through her mother Sarah Pierpont Edwards; Asahel's through the main Hartford Hooker line."}],"slug":"timothy-edwards-1738"},"X00709":{"id":"X00709","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1741,"month":9,"day":28,"city":"Elizabethtown","state":"New Jersey"},"death":{"year":1822,"month":11,"day":2,"city":"Litchfield","state":"Connecticut"},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00381","childre