 farm near the Bristol-Plainville line from about 1760, and with his sons took up manufacturing beside it — the seed of three generations of Hooker mills. He was buried in the old ground near the line he farmed."}],"slug":"asahel-hooker-1736"},"I00166":{"id":"I00166","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1737,"month":2},"death":{"year":1811,"month":10,"day":27,"city":"Bristol","state":"Connecticut"},"parents":{"mother_research_notes":"Sarah Taylor Parmalee","father_research_notes":"Jonathan Parmalee of Branford/Litchfield/Chatham CT"},"marriages":[{"spouse_id":"H00262","children_ids":["H00513","H00514","H00515","H00516","H00517","H00518","H00519","H00520"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 262"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Anne Parmalee Hooker","first_name":"Anne","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Parmalee"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"anne-parmalee-1737"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}