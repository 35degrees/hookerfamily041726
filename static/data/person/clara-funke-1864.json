_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00567","end_type":"divorce","children_ids":[]}],"education":[{"institution":"University of California, Berkeley","degree":"Bachelor's","field":"English and Journalism","location_city":"Berkeley","location_state":"California","notes":"Began college at age 16. Studied English and journalism."},{"institution":"University of Illinois at Chicago Circle (UIC)","degree":"Master of Arts","location_city":"Chicago","location_state":"Illinois","notes":"Earned Master of Arts later in life after divorce from Hal Monsor and the death of daughter Ellen to lymphoma."}],"career":[{"employer":"Redwood Journal","role":"Journalist","location_city":"Ukiah","location_state":"California","notes":"Early career journalism."},{"employer":"Women's Day magazine","role":"Journalist","location_city":"New York","location_state":"New York","notes":"Continued journalism work in NYC."},{"employer":"Youth Guidance","role":"Social services staff","location_city":"Chicago","location_state":"Illinois","notes":"Worked 20 years with Youth Guidance, an organization providing social workers to underserved Chicago-area schools, after earning Master's at UIC."},{"employer":"Mothers Trust Foundation","role":"Founder and President","start_year":1998,"end_year":2016,"location_city":"Lake Forest","location_state":"Illinois","notes":"Founded the Mothers Trust Foundation at age 75 in Lake County IL after retiring from Youth Guidance. Inspired by exposure to childhood poverty through Youth Guidance social workers' field stories. Served as President for approximately 18 years (from ~1998 to ~2016, into her nineties). Foundation supports needs unmet by existing social services. Built with volunteers from Church of the Holy Spirit and Lake County Democratic infrastructure."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"cate