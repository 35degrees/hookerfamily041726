es":[{"short":"Findagrave"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"death","header":"Husband and wife died two months apart 1949","body":"Joseph Warren Hooker and his wife Annie Wilson Hooker died within two months of each other in 1949 — Joseph on February 4 and Annie in April. The compressed deaths suggested either coincidental simultaneous decline of a long-married couple, or perhaps Annie's grief-and-illness following Joseph's death. They are buried together at Olivet Gardens of Cypress Lawn Memorial Park in Colma California."},{"number":2,"category":"family","header":"California migration with Illinois-born wife Annie","body":"Joseph Warren Hooker migrated from the Maine-Connecticut family base westward to San Francisco California, where he and his wife Annie Wilson (born Illinois 1870) settled and raised their two daughters. Daughter Esther Hooker Dirking (1893-1965) and granddaughter Dorothy Beatrice Dirking Hanley (1916-1993) are also buried at the same Cypress Lawn cemetery in Colma — a four-generation California family cluster."},{"number":3,"category":"family","header":"Born 1869, died San Francisco 1949 age seventy-nine","body":"Joseph Warren Hooker was born December 13, 1869 and died February 4, 1949 in San Francisco California at age seventy-nine. He was the eldest documented son of his father Warren Hooker by Warren's first wife Elizabeth. The family's California migration was the western expression of the broader nineteenth-and-early-twentieth-century westward movement that drew Northeast-born Hookers across the continent."}],"cross_connections":[],"cross_reference":{"edward_hooker_1909":"4957"},"burial":{"plot_notes":"Olivet Gardens of Cypress Lawn Memorial Park, Colma, San Mateo County CA (per Findagrave)."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":