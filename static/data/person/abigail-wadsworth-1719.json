":["TD0006","TD0007","TD0008","TD0009","TD0010","TD0011"],"marriage_number":1,"date_year":1711,"date_month":11,"date_day":29}],"sources":[{"short":"Wadsworth Descendants","full":"Descendants of Joseph and Elizabeth (Talcott) Wadsworth — later publication"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Hepzibah Marsh Wadsworth","first_name":"Hepzibah","last_name":"Wadsworth","married_names":["Wadsworth"],"maiden_name":"Marsh"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"hepzibah-marsh-1686"},"U00018":{"id":"U00018","visible_default":false,"in_talcott_book":true,"classification":{"is_spouse_of_talcott_descendant":true,"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1648,"city":"Hartford","state":"Connecticut"},"death":{"year":1729},"parents":{"father_id":"Y00001","mother_id":"X01736"},"marriages":[{"children_ids":[],"spouse_id":"X01734","marriage_number":1},{"spouse_id":"T00040","children_ids":["TD0001","TD0002","TD0003","TD0004","TD0005"],"marriage_number":2},{"children_ids":[],"spouse_id":"X01735","marriage_number":3}],"sources":[{"short":"Talcott 1876","page":"Entry 40"},{"short":"Wadsworth Descendants","full":"Descendants of Joseph and Elizabeth (Talcott) Wadsworth — later publication"}],"gender":"male","tags":["king_philips_war"],"number_of_marriages":3,"notable":{"is_notable":true,"notable_category":["military"],"notable_blurb":"Captain of the Charter Oak legend","primary_url":"https://connecticuthistory.org/hiding-the-charter-images-of-joseph-wadsworths-legendary-action/","primary_url_label":"Connecticut History (CTHumanities)"},"narrative_blocks":[{"category":"politics","header":"He vanished into the dark with the charter","body":"By tradition, when the candles went out in the Hartford meeting-house on the night of 31 October 1687, Wadsworth carried the colony's charter into the dark and hid it in a great oak on the Wyllys grounds. Historians note the evidence is thin and the duplicate may have gone to his own cellar, but the legend made his name.","number":1},{"category":"military","header":"Lieutenant in King Philip's War, captain after","body":"Wadsworth served as a lieutenant during King Philip's War in the 1670s and had risen to captain by 1690. The colony long remembered him as a soldier as much as the charter's keeper.","number":2},{"category":"family","header":"Three marriages, but a single line of children","body":"Wadsworth married three times: first to Elizabeth Barnard, who left no children, and last to the widow Mary Blackleach, who outlived him. All his children came through his second wife, Elizabeth Talcott, daughter of Lieutenant-Colonel John Talcott.","number":3},{"category":"legacy","header":"The colony quietly paid him for the deed","body":"In 1715, nearly thirty years after the event, Connecticut voted Wadsworth twenty shillings for securing the duplicate charter in a very troublesome season. That grant is the closest thing to a contemporary record of his famous act.","number":4},{"category":"family","header":"His father crossed on the Lyon with Talcotts","body":"Wadsworth's father William came from England aboard the ship Lyon in 1632, in the same migration as the Talcott family whose daughter Joseph would later marry. The two Hartford founding houses were thus bound twice over, by voyage and by marriage.","number":5}],"cross_connections":[{"type":"artifact","display_label":"painted the oak where tradition hid the charter","related_id":"X03123","link_text":"Charles DeWolf Brownell"}],"military_service":[{"war":"King Philip's War","active_in_war":true,"rank":"Lieutenant","dates":"1676","war_id":