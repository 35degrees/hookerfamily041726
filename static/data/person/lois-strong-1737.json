":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sally Pomeroy","first_name":"Sally","maiden_name":"Pomeroy","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Husband organized first Episcopal parish in Ohio","body":"Sally's husband Rev. Roger Searle organized the first Episcopal parish in Ohio — St. Peter's at Ashtabula on February 19, 1817 — and preached the first religious service in Medina County Ohio on March 11, 1817. He went on to organize Trinity Cleveland, St. Mark's Columbia, St. James' Boardman, and St. Luke's Ravenna. Sally lived alongside this Ohio Episcopal circuit-rider mission through its founding decade."},{"number":2,"category":"family","header":"Widowed at Ohio frontier age fifty-four","body":"Sally was widowed at age fifty-four when Rev. Searle died September 6, 1826 in Ashtabula Ohio. She lived another twenty-three years and ultimately died in 1849 at Ogdensburg, Saint Lawrence County New York — having migrated from her Ohio widowhood home northeast to the Saint Lawrence River frontier. The Connecticut-to-Ohio-to-Ogdensburg migration arc spanned three frontier regions across her seventy-six years."},{"number":3,"category":"family","header":"Two children: son Lucian and daughter Nancy","body":"Sally and Rev. Searle had two documented children. Their son Lucian Theodoscius Searle (1808-1895) lived to age eighty-seven; their daughter Nancy Sarah Marie Searle Johnston (1817-1906) lived to age eighty-eight or eighty-nine. Both children outlived the parents by half a century and represent the surviving Searle line through Sally Pomeroy's marriage."},{"number":4,"category":"family","header":"Middletown CT 1772 to Ogdensburg NY 1849","body":"Sally Pomeroy was born April 21, 1772 in Middletown Connecticut, daughter of Adino Pomeroy and Lois Strong Pomeroy. She married Rev. Roger Searle on August 7, 1800 and died January 17, 1849 at Ogdensburg, Saint Lawrence County New York at age seventy-six. She is buried at Ogdensburg Cemetery."}],"slug":"sally-pomeroy-1772"},"X01330":{"id":"X01330","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["minister","clergy","ohio_migration","episcopal"],"sources":[{"label":"St. Paul's Episcopal Church Medina OH","url":"https://stpaulsmedina.org"},{"short":"Church Life magazine, Diocese of Ohio, Summer 2018"}],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00655","children_ids":["HD0833","HD0834"],"date_year":1800,"date_month":8,"date_day":7}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1775,"month":7,"day":8,"state":"Connecticut"},"death":{"year":1826,"month":9,"day":6,"city":"Ashtabula","county":"Ashtabula County","state":"Ohio"},"cross_connections":[],"bio":{"display_name":"Rev. Roger Searle","first_name":"Roger","last_name":"Searle","title":"Reverend","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"roger-searle-1775"},"HD0833":{"id":"HD0833","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1808,"month":3,"day":4,"city":"Harwinton","state":"Connecticut"},"death":{"year":1895,"month":8,"day":16,"city":"Tiskilwa","state":"Illinois"},"burial":{"cemetery_id":"CEM081"},"parents":{"