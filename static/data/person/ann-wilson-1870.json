ied February 4, 1949 in San Francisco California at age seventy-nine. He was the eldest documented son of his father Warren Hooker by Warren's first wife Elizabeth. The family's California migration was the western expression of the broader nineteenth-and-early-twentieth-century westward movement that drew Northeast-born Hookers across the continent."}],"cross_connections":[],"cross_reference":{"edward_hooker_1909":"4957"},"burial":{"plot_notes":"Olivet Gardens of Cypress Lawn Memorial Park, Colma, San Mateo County CA (per Findagrave)."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"joseph-hooker-1869"},"HD3170":{"id":"HD3170","former_ids":[],"is_placeholder":false,"gender":"female","has_descendants_documented":true,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"is_easter_egg":false,"include_in_path_calculation":true,"descent_from_thomas_hooker":true},"bio":{"first_name":"Esther","last_name":"Dirking","maiden_name":"Hooker","married_names":["Dirking"],"gender":"female","display_name":"Esther Hooker Dirking","photo_url":"https://images.findagrave.com/photos/2021/30/131019330_3fc4dd53-b53c-4ad1-875a-bf32a669e742.jpeg","photo_notes":"Findagrave portrait."},"birth":{"year":1893,"month":11,"day":1,"state":"California","country":"United States"},"death":{"year":1965,"month":2,"day":13,"county":"San Mateo County","state":"California","country":"United States"},"parents":{"father_id":"H04957","mother_id":"X02168"},"burial":{"plot_notes":"Olivet Gardens of Cypress Lawn Memorial Park, Colma, San Mateo County CA (per Findagrave)."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02169","location_state":"California","location_country":"United States","end_type":"death","end_year":1965,"children_ids"