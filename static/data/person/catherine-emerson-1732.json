_service":[],"slug":"hawley-emerson"},"I00111":{"id":"I00111","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1690,"month":6,"day":22,"city":"Roxbury","state":"Massachusetts"},"death":{"year":1768,"month":3,"day":9,"city":"Mendon","state":"Massachusetts"},"parents":{"mother_research_notes":"Elizabeth Hawley","father_research_notes":"Edward Dorr"},"church_roles":[{"role":"Pastor","church":"Congregational Church of Mendon","dates":"1715-1768","duration_years":52,"notes":"Successor to Rev. Grindal Rawson (I00005), his future father-in-law. Settled 1715. \"Highly respected and very much beloved and esteemed by his people.\""}],"marriages":[{"spouse_id":"H00081","children_ids":["H00218","H00219","H00220","H00221"],"marriage_number":1}],"cross_connections":[{"type":"founding_connections","related_id":"I00005","display_label":"Succeeded Rev. Grindal Rawson as pastor of Mendon — his.","link_text":"Rev. Grindal Rawson"}],"sources":[],"gender":"male","tags":["harvard_graduate"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[],"notable_blurb":"Pastor of Mendon for fifty-two years"},"education":[{"school_name":"Harvard College","dates":"1711","type":"undergraduate"}],"bio":{"title":"Reverend","display_name":"Rev. Joseph Dorr","first_name":"Joseph","last_name":"Dorr","married_names":[],"bio_blurb":"Pastor of Mendon for fifty-two years"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Minister","organization":"First Church, Mendon","start_year":1716,"end_year":1768},{"role":"Moderator","organization":"Mendon Association","start_year":1751,"end_year":1768}],"narrative_blocks":[{"number":1,"category":"religion","header":"Fifty-two years in his father-in-law’s pulpit","body":"Settled at Mendon in 1715 as successor to Rev. Grindal Rawson, Dorr then married Rawson’s daughter — keeping the pulpit in one extended family for the better part of a century. He died “in his 79th year and the 52nd of his ministry”; his epitaph reads, “His temper was mild and placid.”"},{"number":2,"category":"religion","header":"He succeeded the father, married the daughter","body":"Ordained at Mendon in 1716 to succeed the late Grindal Rawson, Dorr married Rawson’s daughter Mary eight years later — and held the pulpit fifty-two years, until his death. The son of Edward and Elizabeth Hawley Dorr of Roxbury, he was Harvard, class of 1711."},{"number":3,"category":"religion","header":"The Association met at his house","body":"First Moderator of the Mendon Association from its 1751 founding — which gathered at his home for its first five years — he remained its standing Moderator until death, favored Jonathan Edwards’s views, and signed the ministers’ testimonial for the revival of 1740."}],"burial":{"cemetery_id":"CEM001"},"slug":"joseph-dorr-1690"},"H00081":{"id":"H00081","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1699,"month":6,"day":22,"city":"Mendon","state":"Massachusetts"},"death":{"year":1776,"month":4,"day":9,"city":"Mendon","state":"Massachusetts"},"parents":{"father_id":"I00005","mother_id":"H00026"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 81"}],"burial":{"cemetery_id":"CEM001"},"marriages":[{"spouse_id":"I00111","children_ids":["H00218","H00219","H00220","H00221"],"marriage_number":1,"date_year":1724,"date_month":4,"date_day":9,"location_city":"Mendon","location_state":"Massachusetts"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Rawson Dorr","first_name":"Mary","last_name":"Dorr","married_names":["Dorr"],"maiden_name":"Rawson"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"She shared his birthday, died on her anniversary","body":"Born June 22 like her husband, nine years apart, Mary Rawson Dorr died on April 9, 1776 — fifty-two years to the day after her wedding. Her stone reads “Dust thou art and unto dust shalt thou return.”"}],"slug":"mary-dorr-1699"},"I00005":{"id":"I00005","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1659,"month":1,"day":23,"city":"Boston","county":"Suffolk","state":"Massachusetts","country":"United States"},"death":{"year":1715,"month":2,"day":6,"city":"Mendon","county":"Worcester","state":"Massachusetts","country":"United States"},"burial":{"cemetery_id":"CEM001","marker_type":"crypt","shared_with":["H00026"]},"parents":{"father_id":"X00009","mother_id":"X00059"},"marriages":[{"spouse_id":"H00026","children_ids":["H00074","H00075","H00076","H00077","H00078","H00079","H00080","H00081","H00082","H00083","H00084","H00085"],"marriage_number":1,"date_year":1682,"date_month":8,"date_day":30,"location_city":"Mendon","location_state":"Massachusetts","location_country":"United States"}],"tags":["minister","missionary","author","king_williams_war","harvard_graduate"],"sources":[{"short":"Edward Hooker 1909"},{"short":"Rawson Family Memorial 1875"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["religion","literature"],"notable_blurb":"Mendon minister; Algonquian translator; Cotton Mather classmate","primary_url":"https://americanantiquarian.org/EnglishtoAlgonquian/grindalrawson","primary_url_label":"American Antiquarian Society"},"quotes":[{"text":"To my Beloved Wife Mrs Susanna Rawson who tho last in mention yet deserveth the first in my best and sincere affections","attribution":"Rev. Grindal Rawson, Will dated Jan 24, 1714","category":"family"}],"narrative_blocks":[{"number":1,"category":"family","header":"Named for Elizabeth I's Archbishop of Canterbury","body":"He was named \"Grindal\" after Edmund Grindal, Archbishop of Canterbury under Elizabeth I — his great-great-grandmother's brother, per the Harvard commencement of 1678. At that ceremony President Urian Oakes called him \"sprung from a most illustrious stock\" and prayed that Rawson might \"in learning, holiness and excellence of character, resemble both Wilson and Grindal.\""},{"number":2,"category":"religion","header":"Mastered Algonquian; preached and translated for natives","body":"He learned the Algonquian language and preached sermons in it to local Nipmuc parishioners — translating Thomas Shepard's Sincere Convert, John Cotton's Spiritual Milk, and a Confession of Faith. Cotton Mather called him 'a Master that had scarce an Equal' in the language."},{"number":3,"category":"religion","header":"Ordered to sail with the Canada invasion","body":"In July 1692 the General Court ordered four ministers, Rawson among them, to accompany the forces in the expedition against Canada, “to carry on the worshipping of God.” Whether he sailed with Sir William Phipps is unknown."}],"cross_connections":[{"type":"family_connection","related_id":"I01735","display_label":"carried the Mendon pastor’s name into the Talcott line"}],"bio":{"title":"Reverend","display_name":"Rev. Grindal Rawson","first_name":"Grindal","last_name":"Rawson","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780372151/grindalrawson_qlr0rc.png","photo_notes":"Gravestone portrait, Mendon burying ground — primary for authenticity."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002"}],"landmarks":[],"artworks":[],"military_service":[],"alternate_photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781148118/Rawson-99-resized_lzrdre.png","slug":"grindal-rawson-1659"},"H00026":{"id":"H00026","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":3,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1664,"month":12,"day":1,"country":"United States"},"death":{"year":1748,"month":7,"day":8,"country":"United States"},"burial":{"cemetery_id":"CEM001","marker_type":"crypt","marker_original":true,"shared_with":["I00005"],"inscription":"Here lies Inter'd ye Remains of Mrs. Susanna Rawson Relict of ye late Rev'd Mr. Grindall Rawson, Pastor of a Church of Christ in Mendon & Daughter of ye Rev'd Mr. John Wilson 1st Minister of ye Gospel in Medfield who changed mortality for life Aug. 23, 1691. She was born Dec. 1, 1664, & died July 8, 1748, in ye 84th year of her age."},"parents":{"father_id":"I00004","mother_id":"H00006"},"marriages":[{"spouse_id":"I00005","children_ids":["H00074","H00075","H00076","H00077","H00078","H00079","H00080","H00081","H00082","H00083","H00084","H00085"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1715,"date_year":1682,"date_month":8,"date_day":30,"location_city":"Mendon","location_state":"Massachusetts","location_country":"United States"}],"tags":["letter_writer"],"sources":[{"page":"Entry 26","label":"Edward Hooker 1909"},{"label":"Rawson Family Memorial 1875"},{"full":"Gary Boyd Roberts, Ancestors of American Presidents","label":"Roberts 2009"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"legacy","header":"Wrote Cotton Mather a eulogy for her husband","body":"After Rev. Grindal Rawson died on February 6, 1715, Susanna wrote a long letter to Cotton Mather — a detailed portrait of her husband's forty-year ministry at Mendon, his Indian mission work, his character, and his final hours. His last words were \"Come Lord Jesus, come quickly!\" The letter was published in the Rawson Family Memorial. Cotton Mather quoted it in the sermon he preached at Rawson's funeral."},{"number":2,"category":"family","header":"Her gravestone names her father, not husband","body":"Her gravestone in Mendon reads: \"Here lies inter'd ye Remains of Mrs. Susanna Rawson, Relict of ye late Rev. Mr. Grindal Rawson... and daughter to ye Rev. Mr. John Wilson 1st Minister of ye Gospel in Medfield.\" She outlived her husband by 33 years, dying July 8, 1748, age 83."},{"number":3,"category":"legacy","header":"Ancestor of President Taft through both Taft brothers","body":"Her granddaughter Mary Dorr Taft married Moses Taft, and her great-granddaughter Rhoda Rawson Taft married Aaron Taft — Moses's and Aaron's fathers were brothers. President William Howard Taft descends through the Aaron Taft line."}],"cross_connections":[{"type":"in_law","related_id":"X00009","display_label":"was her father-in-law, the Bay Colony’s secretary","link_text":"Edward Rawson"}],"bio":{"display_name":"Susanna Wilson Rawson","first_name":"Susanna","last_name":"Rawson","married_names":["Rawson"],"maiden_name":"Wilson"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":[],"education":[],"career":[],"is_placeholder":false,"slug":"susanna-rawson-1664"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}