n decorated by France, Trevor ran the Army's New York military-intelligence branch during the postwar Red Scare. He served as counsel to the New York legislature's Lusk Committee investigating radical activity.","number":3}],"sources":[],"institutions":[],"landmarks":[{"landmark_id":"LM135","landmark_blurb":"His Carnegie Hill townhouse, opposite the Carnegie mansion."}],"artworks":[],"research_tags":[],"cross_connections":[{"type":"family_orbit","related_id":"X03140","display_label":"his father-in-law, Union Club president Lucius Wilmerding"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"John B.","last_name":"Trevor","display_name":"John B. Trevor Sr.","gender":"male","bio_blurb":"Lawyer and architect of the 1924 immigration quotas","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780943450/77887183_a5ed9ffa-fcc3-4105-8b30-a4485adb2537_zhlw0c.jpg","suffix":"Sr."},"military_service":[],"career":[],"birth":{"year":1878,"country":"United States","city":"Yonkers","state":"New York"},"death":{"year":1956,"country":"United States","city":"New York","state":"New York"},"burial":{"cemetery_id":"CEM112"},"education":[],"number_of_marriages":1,"slug":"john-b-trevor-sr-1878"},"HD1032":{"id":"HD1032","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00757","mother_id":"X00297"},"tags":[],"sources":[],"birth":{"year":1787},"death":{"year":1854},"gender":"male","marriages":[{"spouse_id":"I01632","children_ids":["HD6035","HD6036","HD6037","HD6038","HD6039","HD6040"],"marriage_number":1}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Henry Floyd Tallmadge","first_name":"Henry","last_name":"Tallmadge","middle_name":"Floyd","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780945852/Screenshot_2026-06-08_at_12.10.08_PM_cokf54.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[{"artwork_id":"ART079","role":"subject"}],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM754"},"number_of_marriages":1,"slug":"henry-tallmadge-1787"},"I01632":{"id":"I01632","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"spouse_id":"HD1032","children_ids":["HD6035","HD6036","HD6037","HD6038","HD6039","HD6040"],"marriage_number":1}],"tags":[],"narrative_blocks":[],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Maria Canfield","last_name":"Adams","display_name":"Maria Canfield Adams Tallmadge","gender":"female","married_names":["Tallmadge"],"maiden_name":"Adams"},"military_service":[],"career":[],"birth":{"year":1787,"country":"United States","city":"Litchfield","state":"Connecticut"},"death":{"year":1858,"country":"United States","city":"New York","state":"New York"},"burial":{"cemetery_id":"CEM754"},"education":[],"slug":"maria-canfield-adams-1787"},"H00757":{"id":"H00757","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1754,"month":2,"day":25,"city":"Setauket, Long Island","state":"New York"},"death":{"year":1835,"month":3,"day":7,"city":"Litchfield","state":"Connecticut"},"parents":{"father_id":"X00122","mother_id":"H00323"},"prominent_name_reason":"Major Benjamin Tallmadge Jr. (1754-1835) — spymaster of the Culper Ring, Washington's director of military intelligence, classmate of Nathan Hale (Yale 1773), custodian of Major André before his execution, hero of Battle of Fort St. George, U.S. Congressman (Federalist) 1801-1817, Society of the Cincinnati founding member. Grandson of Mehitable Hooker (H00109) and great-great-great-grandchild of Thomas Hooker. His wife Mary Floyd was the daughter of William Floyd, Signer of the Declaration of Independence.","tags":["spy","society_of_cincinnati","revolutionary_war","yale_graduate","banker"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 757"}],"burial":{"plot_notes":"East Cemetery, Litchfield, Connecticut.","cemetery_id":"CEM749"},"marriages":[{"spouse_id":"X00297","children_ids":["HD1031","HD1032","HD1033","HD1034","HD1035","HD1036","HD6015"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1805,"date_year":1784,"date_month":3,"date_day":18},{"spouse_id":"X00298","children_ids":[],"marriage_number":2,"date_year":1808}],"political_offices":[{"title":"U.S. Representative","jurisdiction":"Connecticut at-large","party":"Federalist","dates":"1801-1817","duration_years":16,"notes":"Succeeded William Edmond. Succeeded by Thomas Scott Williams."}],"orbit_connections":[{"name":"Gen. William Floyd","relationship":"Father-in-law — Benjamin Tallmadge married his daughter Mary Floyd Mar 18, 1784","notes":"William Floyd (Dec 17, 1734 – Aug 4, 1821). Continental Congressman; signer of the Declaration of Independence. Major General, New York Militia. His Setauket, Long Island estate was occupied by British forces during the Revolution — the same neighborhood where Tallmadge's Culper Spy Ring operated. Floyd was a neighbor, a comrade-in-arms, and became Tallmadge's father-in-law. (Wikipedia)","primary_url":"https://en.wikipedia.org/wiki/William_Floyd","connection_type":"orbit_non_descendant"}],"gender":"male","notable":{"is_notable":true,"notable_category":["military","politics"],"notable_blurb":"Continental Army spymaster and Connecticut Congressman","primary_url":"https://en.wikipedia.org/wiki/Benjamin_Tallmadge"},"narrative_blocks":[{"header":"Director of Washington's Culper Spy Ring","detail":"Appointed director of military intelligence by Washington, Tallmadge recruited Abraham Woodhull and Robert Townsend as key agents, operating under the alias \"John Bolton.\" When Major John André was captured carrying Arnold's secret correspondence, Arnold fled to the British before he could be arrested. André was placed in Tallmadge's personal custody and executed Oct 2, 1780. Washington personally wrote of Tallmadge's intelligence operation: the Culper Ring has been called the most effective intelligence network of the American Revolution. His Yale classmate and close friend was Nathan Hale — executed as a spy by the British in 1776. Tallmadge was fighting the same war Hale died in. (Wikipedia; DAB; Society of the Cincinnati records)","body":"Major Benjamin Tallmadge ran Washington's military intelligence network during the Revolutionary War, assembling the Culper Ring and playing the central role in exposing Benedict Arnold's plot to surrender West Point.","number":1},{"header":"Raid on Fort St. George (1780)","detail":"Washington personally wrote: \"I have received with much pleasure the report of your successful enterprise upon Fort St. George.\" The raid was a textbook special operations mission — night crossing, surprise assault, clean withdrawal — conducted by the same man who was simultaneously running Washington's spy network. Tallmadge Hall at Fort Huachuca, Arizona (home of Army Intelligence) is named for him. The town of Tallmadge, Ohio bears his name. (Wikipedia; DAB)","body":"Tallmadge led 80 men in whaleboats across Long Island Sound on November 21-22, 1780, captured and burned Fort St. George, and destroyed 300 tons of British hay — with no American casualties.","number":2},{"header":"Married a Declaration signer's daughter","detail":"His father Rev. Benjamin Tallmadge officiated at the wedding. William Floyd, whose daughter he married, had been a member of the Continental Congress and signed the Declaration; Floyd also served alongside Tallmadge in the Revolutionary War as a major general of New York militia. In Congress, Tallmadge was a committed Federalist. He was a founding member of the Society of the Cincinnati (Connecticut chapter, July 1783), an organization restricted to officers who served in the Revolution. \"Continues to be represented by a living descendant in the society today.\" (Wikipedia; DAB; Society of the Cincinnati)","body":"Tallmadge married Mary Floyd in 1784 — daughter of General William Floyd, signer of the Declaration of Independence — and served as a Connecticut Federalist Congressman from 1801 to 1817.","number":3},{"category":"business","header":"A Litchfield merchant and bank president","body":"Settling in Litchfield after the war, Tallmadge grew wealthy in trade and land and led the local branch of the Phoenix Bank. He was among the town's first citizens for half a century.","number":4}],"number_of_marriages":2,"cross_connections":[{"type":"civic_connection","display_label":"had a father present at the André execution Tallmadge oversaw","related_id":"X00912","link_text":"Epaphroditus Ransom"},{"type":"civic_connection","related_id":"HD2925","display_label":"Newton settled the Richfield land he had purchased.","link_text":"John Newton"},{"type":"historical_connection","related_id":"HD2934","display_label":"Her husband bought his Richfield land in 1811 — both Hooker descendants","link_text":"Eunice Newton Oviatt"},{"type":"civic_peer","related_id":"X01997","display_label":"Both Connecticut men shaped the Western Reserve — land and law","link_text":"Elisha Whittlesey"},{"type":"civic_peer","related_id":"TD0059","display_label":"He commanded this officer in Sheldon's Horse — both became Western Reserve pioneers","link_text":"Gen. Elijah Wadsworth"},{"type":"family_connection","related_id":"H00109","display_label":"His great-grandmother through the Smith line","link_text":"Mehitable Hooker Smith"},{"type":"family_orbit","related_id":"X03133","display_label":"his father-in-law, the Declaration signer William Floyd"},{"type":"historical_connection","related_id":"X02860","display_label":"his Yale classmate of 1773, later hanged as a spy"},{"type":"parallel_careers","related_id":"HD6101","display_label":"a descendant who ran the CIA's 1953 Iran coup"},{"type":"parallel_careers","related_id":"HD6093","display_label":"a descendant who led CIA technical services"}],"education":[{"school_name":"Yale College","graduation_year":1773,"institution_id":"INST022"}],"military_service":[{"war":"American Revolutionary War","rank":"Major","unit":"Continental Army","notes":"Maj. Benjamin Tallmadge Jr. Yale 1773. Washington's chief intelligence officer. Organized Culper Spy Ring. Managed custody of John André.","war_id":"WAR004"}],"bio":{"title":"Major","display_name":"Maj. Benjamin Tallmadge Jr.","first_name":"Benjamin","last_name":"Tallmadge","suffix":"Jr.","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780931045/Benjamin_Tallmadge_by_Ezra_Ames_cqwcnl.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1773"},{"institution_id":"INST0045"},{"institution_id":"INST163","relationship":"founder"}],"landmarks":[],"artworks":[],"quotes":[],"slug":"benjamin-tallmadge-jr-1754"},"X00297":{"id":"X00297","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_