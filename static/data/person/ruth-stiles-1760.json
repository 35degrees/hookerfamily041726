":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Great-grandfather of J.P. Morgan","body":"His great-grandson was John Pierpont Morgan (1837-1913), the financier whose name 'J.P. Morgan' carries forward this Pierpont line. Through his son James Pierpont and grandson John Pierpont the poet, the name traveled four generations to one of America's most consequential bankers."},{"number":2,"category":"family","header":"Lived in old Pierpont mansion, New Haven","body":"Timothy Dwight described him as 'a large landholder who lived in the old family-mansion at New Haven.' He had ten children, of whom only four reached adulthood and only three married."},{"number":3,"category":"family","header":"Family later restored 'Pierrepont' French spelling","body":"He was born 'Pierpont' but late in his life, around 1802, Hezekiah Beers Pierpont requested the family restore the original French 'Pierrepont' spelling. Hezekiah did not adopt it himself for business reasons; descendants split between the two spellings thereafter."}],"slug":"john-pierpont-1740"},"HD0558":{"id":"HD0558","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"mother_id":"H00451","father_research_notes":"John Pierpont","father_id":"H00388"},"tags":[],"sources":[],"gender":"male","marriages":[{"spouse_id":"X01371","children_ids":[],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Leonard Pierpont","first_name":"Leonard","last_name":"Pierpont","married_names":[]},"residence":{},"baptism":{},"research_tags"