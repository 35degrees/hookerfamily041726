nt":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00886","mother_id":"X00484"},"tags":[],"sources":[{"short":"Online vital records / primary documents"}],"birth":{"year":1793},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"death":{},"cross_connections":[],"bio":{"display_name":"Justus T. Brockett","first_name":"Justus","last_name":"Brockett","middle_name":"T.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"justus-brockett-1793"},"H00886":{"id":"H00886","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00479","mother_id":"H00370"},"tags":["army","merchant","war_of_1812"],"sources":[{"short":"Edward Hooker 1909","entry":"886"},{"short":"Brockett genealogy (Descendants of John Brockett)"}],"birth":{"year":1769},"death":{"year":1849},"marriages":[{"spouse_id":"X00484","children_ids":["HD1503","HD1504","HD1505","HD1506","HD1507","HD1508"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Hezekiah Brockett","first_name":"Hezekiah","last_name":"Brockett","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"War of 1812","war_id":"WAR003","side":"United States","rank":"enlisted private","units":["2nd Regiment, 7th Company under Captain Ambrose Tuttle (Connecticut militia)"],"source_citation":"Muster roll, 2nd Regiment 7th Company","role":"Connecticut militia enlistee under Captain Ambrose Tuttle's company."}],"narrative_blocks":[{"number":1,"category":"character","header":"Dreamed his vessel sank that night","body":"Hezekiah Brockett was a sea captain engaged in the New Haven-West Indies trade. On one voyage when he did not accompany his vessel, he had a dream that the vessel had gone down — the impression so vivid that he awoke his wife and told her his dream; the vessel was never heard from, and he always believed it had gone down that night. He never went to sea again after the premonition was confirmed."},{"number":2,"category":"career","header":"Sea captain became Mount Carmel cooperage owner","body":"After abandoning sea travel following his premonition dream, Hezekiah engaged in the cooperage business at Mount Carmel Connecticut — barrel-making for the New Haven-West Indies trade he had previously sailed in. Cooperage at the time was 'one of the leading industries of the country and an important factor in the trade between New Haven and the West Indies.' The career pivot from sea to shore kept him in the same trade network without exposing him to maritime risk."},{"number":3,"category":"military","header":"War of 1812 muster roll, Captain Tuttle's company","body":"Hezekiah Brockett's name appears on the War of 1812 muster roll, Second Regiment, Seventh Company, under Captain Ambrose Tuttle of the Connecticut militia. His brothers Pierpont and Jesse Brockett had both also served — Pierpont as ensign-then-lieutenant under Commander Abraham Hubbard at Groton and New London, and Jesse as Lieutenant 1812 / Captain 1815 in the Connecticut militia."},{"number":4,"category":"family","header":"Six children with Mehitabel Candee, Hamden CT","body":"Hezekiah Brockett married Mehitabel Candee about 1791 (born ca.1775, daughter of Zaccheus Candee and Rebecca Smith). They resided in Hamden Connecticut and had six children: Ephraim, Justus T. (later moved Chenango County NY), Hezekiah Jr., Cynthia (married Arba Dickerman), Charles (manufacturer, married Amelia Bristol), and Julia (born and died October-November 1800 age 21 days). Mehitabel died November 21, 1840 Hamden; Hezekiah died September 22, 1849 age eighty, buried Old Graveyard, Mount Carmel, Hamden."}],"slug":"hezekiah-brockett-1769"},"X00484":{"id":"X00484","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1775},"death":{"year":1840},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00886","children_ids":["HD1503","HD1504","HD1505","HD1506","HD1507","HD1508"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mehitabel Candee","first_name":"Mehitabel","maiden_name":"Candee","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mehitabel-candee-1775"},"X00479":{"id":"X00479","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["french_indian_war","revolutionary_war"],"sources":[],"birth":{"year":1725},"death":{"year":1815},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00370","date_year":1755,"date_month":7,"date_day":24,"children_ids":["HD1482","HD1483","HD1484","H00884","HD1485","H00885","H00886","H00887","H00888","H00889","H00890","HD1509","HD1510"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Abel Brockett","first_na