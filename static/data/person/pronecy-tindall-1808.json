,"research_sources":[],"documents":[],"slug":"mrs-sarah-bullard-x02551"},"TD0174":{"id":"TD0174","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"display_name":"Louise Matilda 'Lula' Perrin Frizzell","first_name":"Louise","middle_name":"Matilda","last_name":"Frizzell","maiden_name":"Perrin","married_names":["Frizzell"],"nickname":"Lula","gender":"female","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777675169/louisefrizzel_wvqpeh.jpg","photo_notes":"Portrait. Cloudinary."},"birth":{"year":1862,"month":4,"day":19,"city":"Amite","county":"Tangipahoa","state":"Louisiana","country":"United States"},"baptism":{},"death":{"year":1925,"month":12,"day":24,"city":"Banks","county":"Bradley","state":"Arkansas","country":"United States","cause":"pneumonia"},"residence":{"city":"Banks","county":"Bradley","state":"Arkansas","country":"United States","note":"Banks AR final home; lived earlier Princeton, Bucksnort (Dallas Co), Kingsland (Cleveland Co), Banks (Bradley Co)."},"burial":{"cemetery_id":"CEM188","plot_notes":"Williams Cemetery, Warren AR."},"gender":"female","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":9,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_id":"TD0172","mother_id":"X02390"},"marriages":[{"marriage_number":1,"spouse_id":"X02391","date_year":1889,"date_month":10,"date_day":8,"location_city":"Camden","location_county":"Ouachita","location_state":"Arkansas","location_country":"United States","end_type":"death_of_self","end_year":1925,"children_ids":["TD0179","TD0180","TD0181","TD0182","TD0183"]}],"number_of_marriages":1,"tags":["educator","arkansas_migration"],"research_tags":[],"sources":[{"label":"FindAGrave — Louise Matilda 'Lula' Perrin Frizzell","url":"https://www.findagrave.com/memorial/126875942/louise_matilda-frizzell"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Father remarried nine days after her wedding","body":"Louise married Dr. Daniel Harrison Frizzell on October 8, 1889 at Camden Arkansas. Just nine days later, her widowed father William Alexander Perrin remarried — to Sarah Bullard at Thornton Arkansas. The compressed nine-day father-and-daughter wedding sequence in October 1889 marked the end of their three-year shared widowhood-and-grief after the mother's 1886 Waxahachie Texas death."},{"number":2,"category":"death","header":"Christmas Eve 1925 pneumonia death at sixty-three","body":"Louise died of pneumonia on Christmas Eve, December 24, 1925 at Banks Arkansas at age sixty-three. She is buried at Williams Cemetery in Warren Arkansas. She was survived by her husband, three sons, and two daughters per the Arkansas Gazette obituary published December 27, 1925."},{"number":3,"category":"career","header":"Arkansas schoolteacher across multiple county towns","body":"Louise was a schoolteacher in addition to mothering five children. The Frizzell family moved across Arkansas towns — Princeton and Bucksnort in Dallas County, then Kingsland in Cleveland County, then finally Banks in Bradley County. Five children all named with Hooker-Talcott family-tradition names: Clara Amanda, Francis Niven, Lillie Irene, Garland, and James Austin."},{"number":4,"category":"family","header":"Born Amite LA 1862, eldest of Perrin daughters","body":"Louise Matilda 'Lula' Perrin was born April 19, 1862 in Amite, Tangipahoa Parish Louisiana — eldest daughter of William Alexander Perrin and Clarentine 'Clara' Niven Perrin. After her mother's 1886 death in Waxahachie Texas, Louise and her widowed father moved east to Thornton in Calhoun County Arkansas, where she met her future husband Dr. Daniel Harrison Frizzell."}],"cross_connections":[],"naming_inspiratio