ategory":[]},"narrative_blocks":[],"cross_connections":[],"naming_inspiration":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"pronecy-tindall-1808"},"TD0170":{"id":"TD0170","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"display_name":"Rev. Truman 'Freeman' Perrin","first_name":"Truman","last_name":"Perrin","title":"Reverend","married_names":[],"nickname":"Freeman","gender":"male"},"birth":{"year":1796,"month":4,"day":24,"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"baptism":{},"death":{"year":1869,"month":11,"day":19,"city":"Washington","county":"Berkshire","state":"Massachusetts","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM191","plot_notes":"East Road Cemetery, Berlin VT — solo Hooker-tree connection, no CEM entry built per §0.4 threshold. Note: Cemetery sits adjacent to historic Perrin family land at East Road / Scott Hill intersection in Berlin VT."},"gender":"male","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":7,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_id":"X01832","mother_id":"T01387"},"marriages":[{"marriage_number":1,"spouse_id":"X02389","date_year":1835,"location_country":"United States","end_type":"death_of_self","end_year":1869,"children_ids":["TD0171","TD0172","TD0173"]}],"number_of_marriages":1,"tags":["minister","clergy","vermont_migration","mississippi_migration"],"research_tags":[],"sources":[{"label":"FindAGrave — Rev Truman 'Freeman' Perrin","url":"https://www.findagrave.com/memorial/81459782/truman-perrin"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"religion","header":"Berlin Vermont son who took the gospel south","body":"Truman was born in Berlin Vermont in 1796 to the Perrin family's newly-cleared 1300-acre Scott Hill farm. He took the Presbyterian ministry as his calling and migrated south through Alabama and Mississippi where his three children grew up — but he died in Massachusetts in 1869, and was returned to Vermont for burial near the family land where he had been born."},{"category":"career","header":"Southern bank failures ruined him by 1850","body":"After years preaching and accumulating merchant property in Alabama and Georgia, the failure of several Southern banks around 1850 wiped out most of his fortune. He returned to Vermont and spent his remaining nineteen years 'preaching in various places, and in the employ of the American Tract Society.'","number":2},{"category":"marriage","header":"Wife stayed in Aberdeen Mississippi when he returned","body":"His wife Pronecy Tindall remained in Aberdeen Mississippi when he moved back north around 1850. He died at Washington Massachusetts in November 1869; she lived another fifteen years in Aberdeen, dying there in 1884.","number":3},{"category":"legacy","header":"Buried Vermont family land though died Massachusetts","body":"Despite dying at Washington Berkshire County Massachusetts in November 1869, he was buried at East Road Cemetery in Berlin Vermont — adjacent to the 1300-acre Perrin family land his father Zachariah had established in 1789. His parents had chosen a different Berlin cemetery; Truman's plot lay closer to the farm.","number":4}],"cross_connections":[],"naming_inspiration":[],"education":[],"career":[{"role":"Presbyterian minister","organization":"Various Presbyterian churches","location":"Mississippi and Massachusetts","end_year":1869,"notes":"Per Pronecy's 1884 obituary 'the late Presbyterian minister.' Migration history: Berlin VT (b.1796) → Alabama (children born early 1830s) → Mississippi (raised William in Aberdeen) → Massachusetts (d.1869 Washington Berkshire County)."}],"military_service":[],"institutions":[{"institution_id":"INST058"}],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"truman-perrin-1796"},"TD0171":{"id":"TD0171","former_ids":[],"is_placeholder":true,"has_descendants_documented":false,"bio":{"display_name":"Mary Caroline Perrin Pollard","first_name":"Mary","middle_name":"Caroline","last_name":"Pollard","maiden_name":"Perrin","married_names":["Pollard"],"gender":"female"},"birth":{"year":1837,"country":"United States"},"baptism":{},"death":{"year":1866,"country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM189","plot_notes":"Odd Fellows Rest Cemetery, Aberdeen MS — Perrin family plot, predeceased mother Pronecy by 18 years."},"gender":"female","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":8,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_id":"TD0170","mother_id":"X02389"},"marriages":[{"marriage_number":1,"spouse_id":"X02550","end_type":"death_of_self","end_year":1866,"children_ids":[]}],"number_of_marriages":1,"tags":["mississippi_migration"],"research_tags":[],"sources":[],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"naming_inspiration":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"mary-caroline-perrin-pollard-td0171"},"X02550":{"id":"X02550","former_ids":[],"is_placeholder":true,"has_descendants_documented":false,"bio":{"title":"Mr.","last_name":"Pollard","married_names":[],"gender":"male","display_name":"Mr. Pollard"},"birth":{},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descend