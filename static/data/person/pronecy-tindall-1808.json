ate_year":1861,"date_month":7,"date_day":18,"location_city":"Osyka","location_county":"Pike","location_state":"Mississippi","location_country":"United States","officiant":"Rev. Dr. Spencer (likely Capt. John Thomas Spencer of Floridian Academy, Greensburg LA)","end_type":"death_of_spouse","end_year":1886,"children_ids":["TD0174","TD0175","TD0176","TD0177","TD0178"]},{"marriage_number":2,"spouse_id":"X02551","date_year":1889,"date_month":10,"date_day":17,"location_city":"Thornton","location_county":"Calhoun","location_state":"Arkansas","location_country":"United States","officiant":"Rev. David Edwin Gambrell (Baptist)","end_type":"death_of_self","end_year":1903,"children_ids":[]}],"number_of_marriages":2,"tags":["confederate","civil_war","lawyer","educator","freemason","mississippi_migration","texas_migration","louisiana_migration","arkansas_migration"],"research_tags":[],"sources":[{"label":"FindAGrave — William Alexander Perrin","url":"https://www.findagrave.com/memorial/237207103/william_alexander-perrin"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"law","header":"LL.B. four months before the Civil War","body":"William graduated with his Bachelor of Laws from the Law Department of the University of Louisiana — what is now Tulane University — on Saturday March 30, 1861. Four months later he married Clara Niven on the eve of his 28th birthday at Osyka Mississippi; less than a year after that he enlisted in the Confederate Washington Artillery Battalion at New Orleans."},{"number":2,"category":"marriage","header":"Married his daughter's wedding host nine days later","body":"After his first wife Clara died Waxahachie Texas in January 1886, William moved east to Thornton Calhoun County Arkansas. His daughter Louise married Dr. Daniel Frizzell at Camden Arkansas on October 8, 1889 — nine days later October 17, 1889 William himself married Mrs. Sarah Bullard at Thornton."},{"number":3,"category":"family","header":"First cousin to Admiral Dewey and Speaker Evans","body":"Through his grandmother Mary Talcott Perrin and grandfather Zachariah Perrin, William was first cousin to Admiral George Dewey of Manila Bay (whose mother Mary Polly was William's aunt) and a cousin twice removed of Civil War Medal of Honor recipient Ira Hobart Evans of Texas and of Pampa Texas's Timothy Dwight Hobart. The Vermont Perrin matriarch's grandchildren scattered across Confederate Mississippi, Union Vermont, Texas frontiers, and the Spanish-American War Pacific."}],"cross_connections":[],"naming_inspiration":[],"education":[{"school_name":"Law Department, University of Louisiana (now Tulane University)","dates":"graduated March 30, 1861","type":"law","notes":"LL.B. (Bachelor of Laws) — graduated just before Civil War."}],"career":[{"role":"Attorney at Law","organization":"Self / private practice","location":"Greensburg, Amite, and New Orleans, Louisiana","start_year":1861},{"role":"Schoolteacher (Principal)","organization":"Smithville Male and Female Normal Institute","location":"Smithville, Monroe County, Mississippi","notes":"Principal of the Institute; taught alongside wife Clara, Mrs. Clay Elliott, Professor William Saville, and Dr. John T. M. Gregory. NOT BUILT as INST per Sam directive."},{"role":"Cotton Broker","organization":"Self","location":"Amite, Tangipahoa Parish, Louisiana"},{"role":"Fire Insurance Agent","organization":"Self","location":"Texas","notes":"Later in life."},{"role":"Census Enumerator","organization":"United States Census Bureau","location":"Midland County, Texas","start_year":1900,"end_year":1900,"notes":"1900 U.S. Census enumerator for Midland County TX."}],"military_service":[{"war":"American Civil War","rank":"Private","rank_start":"Private","rank_end":"Private","rank_year_start":1862,"rank_year_end":1865,"unit":"2nd Company, Washington Artillery Battalion of Louisiana","notes":"Enlisted Private March 7, 1862 New Orleans LA. Service record shows present on all rolls through October 1863; absent with leave late 1863; absent without leave early 1864; returned active duty March 1864; served until February 1865. Occupation recorded as 'lawyer'; residence Osyka MS. Confederate service during the Civil War."}],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"william-perrin-1838"},"X02390":{"id":"X02390","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"display_name":"Clarentine 'Clara' Cowling Niven Perrin","first_name":"Clarentine","middle_name":"Cowling","last_name":"Perrin","maiden_name":"Niven","married_names":["Perrin"],"nickname":"Clara","gender":"female"},"birth":{"year":1839,"state":"Louisiana","country":"United States"},"baptism":{},"death":{"year":1886,"month":1,"day":28,"city":"Waxahachie","county":"Ellis","state":"Texas","country":"United States"},"residence":{},"burial":{"plot_notes":"Burial details unknown per FindAGrave."},"gender":"female","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_research_notes":"Father James Neil Niven, well-known New Orleans businessman. Maternal grandparents John Granberry Cowling and Louisa Marie Anne Martha Georgette of Savannah GA. Not built — non-tree.","mother_research_notes":"Mother Maria Sophia Clarentina 'Clara' Cowling. Not built."},"marriages":[{"marriage_number":1,"spouse_id":"TD0172","date_year":1861,"date_month":7,"date_day":18,"location_city":"Osyka","location_state":"Mississippi","location_country":"United States","end_type":"death_of_self","end_year":1886,"children_ids":["TD0174","TD0175","TD0176","TD0177","TD0178"]}],"number_of_marriages":1,"tags":["educator","texas_migration"],"research_tags":[],"sources":[{"label":"FindAGrave — Cl