ar":1885,"month":4,"day":21,"city":"Dover Furnace","state":"New York","county":"Dutchess","country":"United States"},"marriages":[{"children_ids":["H02791","H02792"],"spouse_id":"H01429","marriage_number":1,"date_year":1814,"date_month":1,"date_day":9,"location_city":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1853}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Amelia Stanley Hooker","first_name":"Amelia","last_name":"Stanley","married_names":["Hooker"],"maiden_name":"Stanley"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM240"},"narrative_blocks":[{"number":1,"category":"family","header":"Cousin marriage united two Hooker branches","body":"Amelia carried Hooker blood from both parents — her mother Ann Hooker Stanley descended from Samuel Hooker Jr., her father Seth Stanley descended through his mother Hannah Hart from Abigail Hooker. When she married her cousin Dr. William Hooker in Hartford on January 9, 1814, three Hooker branches converged in their two children — a triple descent that closed a century-and-a-half family loop."}],"former_ids":["HD0539"],"slug":"amelia-stanley-1790"},"H00533":{"id":"H00533","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"compiler_ancestor":true,"lineage_note":"H00533 William (gen 5) → H00265 Seth (gen 4) → H00098 John No.2 (gen 3) → H00030 John (gen 2) → H00007 Samuel (gen 1) → H00001 Thomas","descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1756,"month":9,"day":15,"city":"Kensington","state":"Connecticut"},"death":{"year":1826,"month":2,"day":4,"city":"Kensington","state":"Connecticut"},"parents":{"father_id":"H00265","mother_id":"I00042"},"compiler_ancestor":true,"compiler_connection":{"notes":"William Hooker is the compiler's direct paternal ancestor through the Hooker surname line. His father Seth (H00265) died when William was 2 years old. William is the link between the confirmed paternal line and the compiler's grandfather Michael Gay Hooker. Research needed to trace descendants.","path_to_compiler":"H00533 William → [descendants to trace] → Michael Gay Hooker → Samuel Talcott Hooker (compiler)"},"open_questions":[{"question":"Full descent from William Hooker (H00533) to Michael Gay Hooker","status":"research_needed","notes":"William born 1756 Kensington CT; died 1826. His starred children H01427-H01433 are the next research step. The compiler's grandfather Michael Gay Hooker's connection runs through one of these children.","action":"Research EH entries 1427-1433; check CT vital records and census records for William's children"}],"tags":["compiler_ancestor","musician","revolutionary_war"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 533"}],"marriages":[{"spouse_id":"I00046","children_ids":["H01426","H01427","H01428","H01429","H01430","H01431","H01432","H01433","H01434"],"marriage_number":1,"date_year":1779}],"primary_residence":{"city":"Kensington (Berlin)","state":"Connecticut","notes":"Born and died Kensington CT. Also had family connection to Hinsdale NH through wife."},"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[],"notable_blurb":null,"primary_url":null,"primary_url_label":null},"cross_connections":[{"type":"cousin_marriage","related_id":"H00429","display_label":"Her daughter Amelia married my son Dr. William in 1814.","link_text":"Ann Hooker Stanley"},{"type":"cousin_marriage","related_id":"H00553","display_label":"His daughter Amelia married my son Dr. William in 1814.","link_text":"Seth Stanley"},{"type":"family_orbit","related_id":"X00049","display_label":"was the father of his wife Hannah Jones"}],"military_service":[{"war":"American Revolutionary War","war_id":"WAR001","side":"American","rank_start":"Private","rank_end":"Sergeant","rank_year_start":1777,"rank_year_end":1780,"unit":"Capt. Caleb Bull's Company in Webb's Regiment, Continental Army","service_years":"1777-1780","notes":"Enlisted Apr 21, 1777 as Private for 3 years in Capt. Caleb Bull's Company, Webb's Regiment. Promoted Sergeant May 16, 1780 for an additional 8 months. Member of the Hartford 'band of music' (eight musicians) raised 1777 and attached to the Connecticut line. Pensioned Nov 4, 1818. DAR Ancestor #A057709."}],"bio":{"display_name":"William Hooker","first_name":"William","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"military","header":"Hartford band of music attached to Connecticut line","body":"William Hooker was a member of the eight-man 'band of music' raised in Hartford in 1777 and attached to the Connecticut line of the Continental Army — one of the rare documented Revolutionary War regimental musical ensembles. The band provided drums, fifes, and field music during the war's middle years. The arrangement was unusual: most Revolutionary regiments had ad hoc field musicians rather than a formally organized eight-piece band."},{"number":2,"category":"military","header":"Three years Private, eight months Sergeant 1777-1780","body":"William enlisted April 21, 1777 as a Private in Captain Caleb Bull's Company of Webb's Regiment for a three-year term. On May 16, 1780 he was promoted to Sergeant for an additional eight months of service. He was pensioned November 4, 1818 (DAR Ancestor #A057709) — the federal pension secured nearly four decades after his service ended."},{"number":3,"category":"family","header":"Nine children with Sarah Wilcox of Berlin","body":"William married Sarah Wilcox of Berlin Connecticut and they had nine documented children together. The family remained in Kensington, the original Berlin Connecticut parish where William had been born in 1756 and where he would die in 1826. The nine-child household was characteristic of the post-Revolutionary Connecticut farming generation."},{"number":4,"category":"family","header":"Kensington Berlin CT 1756 to 1826 age sixty-nine","body":"William Hooker was born September 15, 1756 in Kensington (now Berlin) Connecticut and died February 4, 1826 in Kensington at age sixty-nine. He is buried at West Lane Cemetery in Berlin Connecticut. His Revolutionary War service spanned the war's middle period from the bleakest 1777 Valley Forge winter through the war's final 1780-1781 phase."}],"slug":"william-hooker-1756"},"I00046":{"id":"I00046","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1758,"month":12,"day":5,"city":"Hartford","state":"Connecticut"},"death":{"year":1854,"month":4,"day":12},"parents":{"father_id":"X00049","mother_id":"X00050"},"marriages":[{"spouse_id":"H00533","children_ids":["H01426","H01427","H01428","H01429","H01430","H01431","H01432","H01433","H01434"],"marriage_number":1,"date_year":1779}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 533"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Hannah Jones Hooker","first_name":"Hannah","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Jones"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"hannah-jones-1758"},"H00553":{"id":"H00553","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1755,"month":5,"day":6,"city":"Kensington","state":"Connecticut"},"death":{"year":1827,"month":6,"day":22,"city":"Berlin","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"mother_id":"H00272","father_research_notes":"Thomas Stanley","father_name":"Thomas Stanley","mother_name":"Hannah (Hart) Stanley","father_id":"X01026"},"marriages":[{"marriage_number":1,"spouse_id":"H00429","date_year":1781,"date_month":11,"location_country":"United States","children_ids":["H01468","H01469","H01471","H01472","H01470","H01473"]}],"tags":["revolutionary_war"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 553"},{"short":"Stanley Families of America (Warren, 1887?)","page":"entries 444-449"},{"short":"Record of Service of Connecticut Men in the War of the Revolution, 1889","page":"381, 392, 475"},{"short":"Berlin-Peck: Revolutionary War Soldiers of the Town of Berlin"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"cousin_marriage","related_id":"H00533","display_label":"His son Dr. William married my daughter Amelia in 1814.","link_text":"William Hooker Sr."},{"type":"military","related_id":"H00273","link_text":"Gen. Selah Hart","display_label":"commanded the company he guarded Boston with in early 1776"}],"bio":{"display_name":"Seth Stanley","first_name":"Seth","last_name":"Stanley","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","rank":"Corporal","rank_start":"Private","rank_end":"Corporal","rank_year_start":1776,"rank_year_end":1776,"unit":"Col. Erastus Wolcott's Regt. (Capt. Selah Hart's 3rd Co.); Gen. Wadsworth's Brigade; Maj. Sheldon's Light Horse (Capt. Daniel Sloper's Co.)","service_years":"January–December 1776","battles":["BTL013","BTL007"],"notes":"1776 campaign across three commands. Winter 1776: guarded besieged Boston about six weeks in Capt. Selah Hart's 3rd Company, Col. Erastus Wolcott's Regiment. Summer 1776: present at the Battle of Long Island (Aug 27) with Gen. James Wadsworth's Brigade and the retreat from New York. Nov 4–Dec 24, 1776: Corporal in Capt. Daniel Sloper's Company, Maj. Sheldon's Regiment of Light Horse, on Washington's retreat through New Jersey. Source: Record of Service of Connecticut Men in the War of the Revolution (1889), pp. 381, 392, 475; Berlin-Peck, Revolutionary War Soldiers of the Town of Berlin."}],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married three times, his last two wives widows","body":"After Ann Hooker died in 1808 he married twice more, both times to widows: Sabra Winchell Stanley, and in 1822 Abigail Hart Smith, herself already twice-widowed. His will, presented in court July 1827, left the farm and stock to his son Seth and the remainder to his daughters Lydia, Nancy, and Amelia."},{"number":2,"category":"military","header":"His whole war fit in one brutal year","body":"Seth's Revolutionary service was crowded into 1776. That year he helped guard besieged Boston through the winter, stood with the army in its rout at the Battle of Long Island, and rode in the light horse covering Washington's retreat across New Jersey."}],"slug":"seth-stanley-1755"},"H00429":{"id":"H00429","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1756,"month":9,"day":23,"city":"Kensington","state":"Connecticut"},"death":{"year":1808,"month":9,"day":5},"parents":{"father_id":"H00228","mother_id":"I00157"},"marriages":[{"children_ids":["H01468","H01469","H01471","H01472","H01470","H01473"],"spouse_id":"H00553","marriage_number":1,"date_year":1781,"date_month":11}],"tags":["not_yet_fully_entered"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 429"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"cousin_marriage","related_id":"H00533","display_label":"His son Dr. William married my daughter Amelia in 1814.","link_text":"William Hooker Sr."}],"bio":{"display_name":"Ann Hooker Stanley","first_name":"Ann","last_name":"Stanley","married_names":["Stanley"],"maiden_name":"Hooker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ann-stanley-1756"}},"burialCemetery":{"id":"CEM240","primary_name":"South Dover Rural Cemetery","location":{"city":"Wingdale","county":"Dutchess","state":"New York","country":"United States"},"find_a_grave_url":"https://www.findagrave.com/cemetery/1976581/south-dover-rural-cemetery","hooker_connections":["H01429","H01473","H02791","H02792","H04401","H04403","H04405","HD3588","HD3589","HD3590","HD3591","HD3592","HD3593","X01229","X02738","X02739","X02740"],"notes":"Resting place of the South Dover Hooker family across multiple generations: Dr. William Hooker (H01429, 1788-1853) and his cousin Amelia Stanley Hooker (HD0539, 1790-1885), their two children William Jr. (H02791) and Ann Hooker Vincent (H02792), William Jr.'s wife Sarah Varney Cutler Hooker (X01229) and four of their five children, plus Ann's husband Edwin Vincent (X02738) and her three Vincent children — Ella, Amelia H., Charles William — and onward through the Vincent line via Charles Kenneth and his wife Edith Akin Vincent down to Walter Akin Vincent (HD3593, WWII Navy). The 1814 cousin marriage united two Hooker branches via Amelia's TRIPLE Hooker descent.","gps":{"lat":41.65263,"lng":-73.5559}},"institutionsById":{},"crossConnections":[]}