 1909 #2767."}],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":["vermont_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Twin children born 1869","body":"Josiah Goodhue and Sarah Chipman had twins — Ralph Josiah and Anna Eliza — born together September 24, 1869. Anna died June 27, 1884 at about fifteen; Ralph survived. A third child, Robert Shields, was also born on September 24 — seven years later."},{"number":2,"category":"family","header":"Son John Hooker died at twenty-one","body":"Josiah's son John Hooker Goodhue — named for the family lineage — died August 20, 1883 at Whitewater at twenty-one years old. The name Hooker had been carried through three generations of this branch and continued in the children who survived."},{"number":3,"category":"legacy","header":"Lived to eighty-nine in Whitewater; wife also eighty-eight","body":"Josiah Goodhue died August 10, 1919 at eighty-nine years old in Wisconsin, having outlived his father Rev. Josiah Fletcher Goodhue by fifty-six years. His wife Sarah Bennett Chipman Goodhue also reached eighty-eight — both achieving remarkable longevity for the Wisconsin farming community they had settled."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM560"},"residence":{"country":"United States"},"sources":[{"short":"EH 1909 #2767"}],"research_sources":[],"slug":"josiah-goodhue-1830"},"I01194":{"id":"I01194","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Sarah B. Chipman Goodhue","first_name":"Sarah","middle_name":"B.","last_name":"Chipman","married_names":["Goodhue"]},"gender":"female","birth":{"year":1837,"month":7,"day":11,"city":"Pontiac","state":"Michigan","country":"United States"},"death":{"year":1926,"month":1,"day":13},"baptism":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spou