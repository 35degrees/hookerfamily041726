ey"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM240"},"narrative_blocks":[{"number":1,"category":"family","header":"Cousin marriage united two Hooker branches","body":"Amelia carried Hooker blood from both parents — her mother Ann Hooker Stanley descended from Samuel Hooker Jr., her father Seth Stanley descended through his mother Hannah Hart from Abigail Hooker. When she married her cousin Dr. William Hooker in Hartford on January 9, 1814, three Hooker branches converged in their two children — a triple descent that closed a century-and-a-half family loop."}],"former_ids":["HD0539"],"slug":"amelia-stanley-1790"}},"burialCemetery":{"id":"CEM243","primary_name":"Pawling Cemetery","location":{"city":"Pawling","county":"Dutchess","state":"New York","country":"United States"},"find_a_grave_url":"https://www.findagrave.com/cemetery/641185/pawling-cemetery","hooker_connections":["H04404","HD0550","H05309","H05310","H05311","H05312","HD3603","HD3604","X00958","X00959","H05308","I01716","I01717","I01718","HD6204","HD6206"],"notes":"Primary Dykeman family burial ground in Pawling Dutchess County NY. Resting place of Peter Dykeman (X00958, 1858-1930, farmer and Pawling Baptist Church benefactor) and his wife Effie Keziah Hooker Dykeman (H04404, 1867-1936, triple Hooker descendant), and five of their seven children — William John, Peter Augustus, Calvin (infant), Alice C., and George Raymond — plus their youngest Henry Dykeman (HD0550, 1900-1984, roadside market co-founder and volunteer firefighter), his wife Velma Ellis (X00959), and Henry's son 'Farmer Hank' (HD3604, 1928-2017) with his wife Jean Wright.","gps":{"lat":41.56798,"lng":-73.59384}},"institutionsById":{},"crossConnections":[]}