ader":"Lost his first wife after thirteen years","body":"His first wife Abigail Andrews of Milford died June 13, 1765 after thirteen years of marriage. He remarried Abigail Newberry of Wintonbury in 1770, five years before his own death."}],"slug":"william-russell-1725"},"X00411":{"id":"X00411","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1723},"death":{"year":1765},"gender":"female","parents":{"father_id":"H00358","mother_id":"X00412"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00358","date_year":1752,"end_type":"death_of_spouse","end_year":1765,"children_ids":["H00843","H00844","H00845","H00846"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Abigail Andrews","first_name":"Abigail","maiden_name":"Andrews","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"abigail-andrews-1723"},"I00144":{"id":"I00144","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1690,"month":11,"day":30,"city":"Middletown","state":"Connecticut","country":"United States"},"death":{"year":1761,"month":6,"day":1,"city":"Middletown","state":"Connecticut","country":"United States"},"parents":{"mother_research_notes":"Mary Hamlin Russell — her sister Mehitable Hamlin married Samuel Hooker Jr., making Rev. William Russell's aunt the wife of Mary Pierpont's maternal uncle. EH notes this double family connection explicitly.","father_research_notes":"Rev. Noadiah Russell of Middletown — founding trustee of Yale College"},"church_roles":[{"role":"Pastor","location":"Middletown, Connecticut","dates":"1715-1761","notes":"Successor to his father Rev. Noadiah Russell"}],"marriages":[{"spouse_id":"H00118","children_ids":["H00356","H00357","H00358","H00359","H00360","H00360a","H00361","H00362","H00363"],"marriage_number":1,"date_year":1719,"date_month":8,"date_day":19,"location_country":"United States"}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 118"}],"gender":"male","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"cousin_marriage","related_id":"HD0416","display_label":"Married the sister of his own sister's husband, both Pierpont-Russell siblings.","link_text":"Joseph Pierpont"}],"education":[{"school_name":"Yale College","dates":"1709","type":"college"}],"bio":{"title":"Reverend","display_name":"Rev. William Russell","first_name":"William","last_name":"Russell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"founder","years":"1709"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"lineage","header":"Son of Yale's founding trustee Noadiah Russell","body":"His father Rev. Noadiah Russell was one of the ten founding trustees of Yale College in 1701 — the same founding cohort as Rev. James Pierpont Sr (his future father-in-law). Two Yale founding-trustee families thus merged through his marriage to Mary Pierpont in 1718."},{"number":2,"category":"lineage","header":"Double Hamlin family connection to Hooker line","body":"His mother Mary Hamlin's sister Mehitable Hamlin had married Samuel Hooker Jr. - brother of Mary Pierpont's mother Mary Hooker. Edward Hooker's 1909 genealogy notes this double family connection explicitly: two Hamlin sisters married into the Hooker-Pierpont line one generation apart."},{"number":3,"category":"career","header":"Pastor of Middletown First Church for decades","body":"Served as pastor of Middletown First Church through the mid-18th century until his death 1 June 1761 at age 70. Father of nine surviving children — five sons + four daughters — through whom the Russell name carried into the Wadsworth, Talcott, Anthony, and Dwight branches of the Hooker tree."},{"number":4,"category":"career","header":"Forty-six years in the pulpit, to the day","body":"Settled as Middletown’s pastor on June 1, 1715, William Russell died on June 1, 1761 — forty-six years in the same pulpit to the day."}],"career":[{"role":"Pastor","organization":"First Church of Middletown","start_year":1715,"end_year":1761}],"slug":"william-russell-1690"},"H00118":{"id":"H00118","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1703,"month":11,"day":23,"city":"New Haven","county":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1740,"month":6,"day":24,"city":"Middletown","county":"Middlesex","state":"Connecticut","country":"United States"},"parents":{"father_id":"X00126","mother_id":"H00034"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 118"}],"marriages":[{"marriage_number":1,"spouse_id":"I00144","date_year":1719,"date_month":8,"date_day":19,"location_city":"New Haven","location_county":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1740,"children_ids":["H00356","H00357","H00358","H00359","H00360","H00360a","H00361","H00362","H00363"]}],"cross_connections":[{"type":"founding_family_nexus","related_id":"H00115","display_label":"Both families joined through Talcott siblings a generation later.","link_text":"Capt. Nathaniel Hooker"},{"type":"family_connection","related_id":"T00070","display_label":"Her daughter's marriage to Talcott converged founding lines.","link_text":"Col. Matthew Talcott"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"institutions":[{"institution_id":"INST022","institution_blurb":"Father Rev. James Pierpont Sr. and father-in-law Rev. Noadiah Russell were both founding trustees of Yale in the same 1701 charter."},{"institution_id":"INST013"}],"narrative_blocks":[{"number":1,"category":"legacy","header":"Her father and father-in-law both founded Yale","body":"She was the daughter of Rev. James Pierpont Sr., one of the ten founding trustees who chartered Yale College on October 16, 1701. She married Rev. William Russell, son of Rev. Noadiah Russell of Middletown — who was also one of those ten founding trustees."},{"number":2,"category":"legacy","header":"Four founding families converge in her children's generation","body":"Through her parents she carried the Hooker line and the Pierpont-Yale line. Through marriage she joined the Russell-Yale line. Her daughter Mary Russell married Matthew Talcott — adding the Talcott founding line to the convergence her children embodied."},{"number":3,"category":"family","header":"A hidden Hooker-Hamlin connection in her husband's family","body":"Rev. William Russell's mother Mary Hamlin was the sister of Mehitable Hamlin, who married Samuel Hooker Jr. — a brother of Mary Pierpont's own mother. This made William Russell's aunt the wife of Mary's uncle, drawing a second bond between the families before their own marriage."},{"number":4,"category":"family","header":"Granddaughter of Hartford's founder — nine children","body":"Her grandfather was Rev. Thomas Hooker, who led the 1636 migration from Cambridge that founded Hartford. She settled in Middletown with her husband and bore nine children: Mary, Esther, William, Samuel, Noadiah, James, Sarah, Mehitable, and Hannah."},{"number":5,"category":"family","header":"Her daughter Mary married Matthew Talcott","body":"Her daughter Mary Russell married Matthew Talcott of Hartford — the marriage that created the Russell-Talcott convergence. Their children were both Hooker and Talcott descendants, connecting two of colonial Connecticut's founding families."},{"number":6,"category":"legacy","header":"She may have stitched the family apron","body":"Of the three Marys linked to a surviving 1730s silk apron, she is one of two likeliest embroiderers, depending on which attended a Boston finishing school and when. The apron’s Chinese silk and French metallic thread mark the family’s reach into global trade."}],"bio":{"display_name":"Mary Pierpont Russell","first_name":"Mary","last_name":"Russell","married_names":["Russell"],"maiden_name":"Pierpont","bio_blurb":"Mother of the Russell nine at Middletown"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"videos":[{"video_id":"VID009"}],"slug":"mary-russell-1703"},"X00412":{"id":"X00412","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00358","date_year":1770,"date_month":1,"date_day":18,"children_ids":["H00847","X00411"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Abigail Newberry","first_name":"Abigail","maiden_name":"Newberry","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"abigail-newberry"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}