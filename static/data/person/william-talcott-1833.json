ming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM198","plot_notes":"Talcott Cemetery, Lanesborough, Berkshire County MA."},"narrative_blocks":[{"number":1,"category":"migration","header":"Migrated to Lanesborough at twenty-four","body":"Capt. Nehemiah Talcott was born in Glastonbury Connecticut in 1766 and migrated to Lanesborough Massachusetts by 1790 — the year of the first US Census, which shows him already living there. He married Tirzah Platt that August in her hometown and they raised ten children in Lanesborough. He died there in 1848 at eighty-two."},{"number":2,"category":"death","header":"Died three months after his wife","body":"Tirzah Platt Talcott died in Lanesborough on July 14, 1848 at seventy-seven. Capt. Nehemiah followed her exactly three months later on October 13, 1848 at eighty-two. They were buried together in Talcott Cemetery — the Lanesborough burying ground that bore the family name."}],"slug":"nehemiah-talcott-1766"},"X01834":{"id":"X01834","has_descendants_documented":false,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"EH 1909"}],"gender":"unknown","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"T01390","date_year":1790,"date_month":8,"date_day":10,"location_city":"Lanesborough","location_county":"Berkshire","location_state":"Massachusetts","location_country":"United States","end_type":"death","end_year":1848,"children_ids":["T01469","T01470","T01471","T01472","T01474","T01475","T01473","T01476","T01477","T01478"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1771,"month":3,"day":30,"city":"Lanesborough","county":"B