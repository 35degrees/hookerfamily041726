e carried the names of two New England clerical lines west to Youngstown; he rose from first sergeant to major in the 19th Ohio before Shiloh killed him at twenty-four."}],"slug":"timothy-edwards-1838"},"HD2185":{"id":"HD2185","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2182","mother_id":"HD2170"},"tags":[],"sources":[],"birth":{"year":1844,"month":2,"day":22,"city":"Youngstown","state":"Ohio"},"death":{"year":1902,"month":7,"day":7,"city":"Gretna","state":"Nebraska"},"gender":"female","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Rhoda B Edwards","first_name":"Rhoda","middle_name":"B","maiden_name":"Edwards","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"rhoda-edwards-1844"},"HD2171":{"id":"HD2171","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00933","mother_id":"X00693"},"tags":["died_in_childhood"],"sources":[],"birth":{"year":1808},"death":{"year":1817,"cause":"drowned"},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"John Woodbridge","first_name":"John","last_name":"Woodbridge","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-woodbridge-1808"},"HD2172":{"id":"HD2172","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00933","mother_id":"X00693"},"tags":["military","physician","civil_war"],"sources":[],"birth":{"year":1810,"month":2,"day":19,"city":"Youngstown","state":"Ohio"},"death":{"year":1892,"month":1,"day":4,"city":"Youngstown","state":"Ohio"},"institution_affiliations":[{"institution_id":"INST036","role":"graduate","year":1833,"notes":"Graduated Jefferson Medical College Philadelphia 1833. Returned to Youngstown; served as Civil War surgeon at Johnson's Island; appointed by President Hayes to Fort Peck Montana 1879."}],"gender":"male","marriages":[{"spouse_id":"X01546","children_ids":[],"marriage_number":1}],"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Physician, Civil War"},"narrative_blocks":[{"header":"First doctor born in Youngstown","detail":"He barely survived the Mahoning River drowning that killed his brother John. Jefferson Medical College 1833 — the leading medical school in the US at that time. In 1847-48, David Tod (later Ohio Governor) personally chose him as family physician for his diplomatic posting in Brazil. In 1861, he was appointed surgeon at Johnson's Island on Lake Erie — the Union's prisoner-of-war camp for Confederate officers. In 1879, President Hayes appointed him surgeon at Fort Peck, Montana, where he was the medical officer for both soldiers and Native Americans. He co-founded the Mahoning County Medical Society (1872) and served as its first president for seven years. His billing eccentricities — listing \"the fat woman in Brier Hill\" in his day books and accepting half-fees from the poor — were celebrated in the 1882 History of Trumbull and Mahoning Counties. (Rose Melnick Medical Museum; Growing Up in Working Class Youngstown; US Army records)","body":"Timothy Woodbridge was Youngstown's first native-born physician, whose career spanned from private practice in a log cabin to two separate US Army appointments — one by Lincoln's government during the Civil War, one by President Hayes in 1879.","number":1},{"number":2,"category":"medicine","header":"“The fat woman in Brier Hill”","body":"His ledgers listed patients by description rather than name — “the fat woman in Brier Hill” — and he routinely accepted half to three-quarters of what the poor owed him. The 1816 log cabin he moved across Youngstown in 1862 still stands."}],"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Timothy Woodbridge","first_name":"Timothy","last_name":"Woodbridge","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST036"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Civil War","branch":"US Army","rank":"Surgeon","notes":"Johnson’s Island"}],"career":[{"role":"Surgeon","organization":"US Army, Johnson’s Island POW camp","start_year":1861,"end_year":1865},{"role":"First president","organization":"Mahoning County Medical Society","start_year":1872},{"role":"Post surgeon","organization":"Fort Peck, Montana","start_year":1879}],"slug":"timothy-woodbridge-1810"},"X01546":{"id":"X01546","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2172","children_ids":[]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"I