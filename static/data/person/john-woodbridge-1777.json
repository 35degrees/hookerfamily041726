ent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00694","mother_id":"HD2178"},"tags":["legal"],"sources":[],"birth":{"year":1852,"month":11,"day":26,"city":"Youngstown","state":"Ohio"},"death":{"year":1910,"month":11,"day":26,"city":"Cleveland","state":"Ohio"},"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Lawyer"},"narrative_blocks":[{"header":"Theodore Roosevelt made him a judge","detail":"His father was Lincoln's Comptroller of the Treasury; he himself was a close friend of other Ohio political figures of the era. He died the day before his 58th birthday, still serving on the federal bench. His mother Louisa Maria Woodbridge was a direct descendant of Thomas Hooker through Lucy Edwards Woodbridge (H00380), daughter of Jonathan Edwards. (Wikipedia; FindAGrave)","body":"After four terms in Congress chairing the elections committee, Tayler was appointed to the Northern District of Ohio bench by President Roosevelt in January 1905 and served until his death — one day short of his fifty-eighth birthday.","number":1,"category":"character"},{"number":2,"category":"law","header":"He died the day before his birthday","body":"Still on the federal bench Roosevelt had named him to in 1905, Tayler died in Cleveland on November 25, 1910 — one day short of fifty-eight. Four terms in Congress, and the chairmanship of its elections committee, preceded the judgeship."}],"marriages":[],"cross_connections":[],"bio":{"display_name":"Robert Walker Tayler","first_name":"Robert","last_name":"Tayler","middle_name":"Walker","married_names":[],"bio_blurb":"Ohio congressman, then federal judge"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"education":[{"school_name":"Western Reserve College","dates":"1872","type":"undergraduate"}],"career":[{"role":"US Congressman","organization":"Ohio 18th District","start_year":1895,"end_year":1903},{"role":"US District Judge","organization":"Northern District of Ohio","start_year":1905,"end_year":1910}],"slug":"robert-tayler-1852"},"HD2179":{"id":"HD2179","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00933","mother_id":"X00693"},"tags":["died_in_childhood"],"sources":[],"birth":{"year":1823},"death":{"year":1832},"gender":"male","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Stark Edward Woodbridge","first_name":"Stark","last_name":"Woodbridge","middle_name":"Edward","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"stark-woodbridge-1823"},"X00690":{"id":"X00690","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["revolutionary_war","french_indian_war"],"sources":[],"birth":{"year":1738},"death":{"year":1796},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00380","date_year":1764,"date_month":6,"date_day":7,"location_city":"Stockbridge","location_state":"Massachusetts","children_ids":["H00927","H00928","H00929","H00930","H00931","H00932","H00933","H00934","H00935"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Jahleel Woodbridge","first_name":"Jahleel","last_name":"Woodbridge","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST023"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"politics","header":"Kidnapped from home at midnight by Shays men","body":"When Shays' Rebellion reached Stockbridge in 1787, the insurrectionists targeted Judge Woodbridge — symbol of the 'silk stocking aristocracy.' They broke into his home at midnight, pillaged it, and carried him off as a prisoner to Great Barrington; he negotiated his own release and met the rescue party halfway home. Edward Bellamy's 1879 novel 'The Duke of Stockbridge' drew on these events."},{"number":2,"category":"education","header":"Learned the Mahican language at Mission School","body":"Growing up in Stockbridge from age one, he attended the Indian Mission School and was tutored by his uncle Timothy Woodbridge and Jonathan Edwards — learning the Mahican language in the process. Princeton followed in 1761, and Berkshire County militia service by 1764."},{"number":3,"category":"politics","header":"Paid Stockbridge Indian soldiers to prevent strong drink","body":"On 5 July 1775 the Third Provincial Congress of Massachusetts resolved that wages of Stockbridge Indians serving in the war be paid directly to Woodbridge and Timothy Edwards. The Indians had requested the arrangement themselves — 'being sensible of their want of prudence in disposing of their money, [they were] desirous that this Congress, in their wisdom, would devise some method to prevent their getting too much strong drink.'"}],"slug":"jahleel-woodbridge-1738"},"H00380":{"id":"H00380","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1736,"month":8,"day":31,"city":"Northampton","state":"Massachusetts"},"death":{"year":1786,"month":9,"day":17,"city":"Stockbridge","state":"Massachusetts"},"parents":{"father_id":"X00128","mother_id":"HD0418"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 380"}],"marriages":[{"spouse_id":"X00690","children_ids":["H00927","H00928","H00929","H00930","H00931","H00932","H00933","H00934","H00935"],"marriage_number":1,"date_year":1764,"date_month":6,"date_day":7,"location_city":"Stockbridge","location_state":"Massachusetts"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Lucy Edwards","first_name":"Lucy","maiden_name":"Edwards","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Edwards recorded the exact hour of her birth","body":"She was born August 31, 1736 in Northampton — 'between 2 and 3 o'clock in the morning,' as her father Jonathan Edwards recorded in the family Bible. She was a Northampton child of the Great Awakening years."},{"number":2,"category":"marriage","header":"Married Jahleel Woodbridge of Stockbridge in 1764","body":"In 1764 she married Jahleel Woodbridge — Princeton 1761, judge of Probate Court, Connecticut state senator, captain of Minute Men. He served in the Provincial Congress with her brother Timothy Edwards."},{"number":3,"category":"family","header":"Stockbridge home base for the Edwards-Woodbridge line","body":"She moved to Stockbridge with Jahleel Woodbridge — the same Mohican mission town where her father had ministered after Northampton. She died in Stockbridge in 1786, age fifty."}],"slug":"lucy-edwards-1736"},"X00128":{"id":"X00128","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1703,"month":10,"day":5,"city":"East Windsor","state":"Connecticut"},"death":{"year":1758,"month":3,"day":22,"city":"Princeton","state":"New Jersey","cause":"Complications from smallpox inoculation"},"burial":{"cemetery_id":"CEM026","plot_notes":"Princeton Cemetery, Princeton, New Jersey"},"parents":{"mother_research_notes":"Esther Stoddard — daughter of Rev. Solomon Stoddard of Northampton","father_research_notes":"Rev. Timothy Edwards of East Windsor CT — minister 60 years until death 1758 age 89"},"church_roles":[{"role":"Assistant Pastor then Senior Pastor","location":"Northampton, Massachusetts","dates":"1727-1750","notes":"Succeeded grandfather Solomon Stoddard. Led Great Awakening revivals. Dismissed 1750 over communion controversy."},{"role":"Missionary to Housatonic Indians","location":"Stockbridge, Massachusetts","dates":"1751-1757"},{"role":"President","location":"College of New Jersey (Princeton)","dates":"1757-1758","notes":"Died 34 days after installation."}],"prominent_name_reason":"Rev. Jonathan Edwards (1703-1758) — Yale 1720; greatest American theologian; leader of the Great Awakening; delivered \"Sinners in the Hands of an Angry God\" (1741); President of Princeton; grandfather of Aaron Burr Jr. (3rd U.S. Vice President). Father's father-in-law was Rev. Timothy Edwards who held one enslaved person named Ansars. Edwards himself enslaved at least six people: Venus (purchased 1731), Joab, Rose Binney, Titus (son of Joab and Rose), Joseph, Sue, and possibly Leah.","enslaved_persons":[{"name":"Venus","description":"Purchased June 1731 as a young teenager. Likely later baptized and given name Leah."},{"name":"Joab Binney","description":"Enslaved man. Married Rose 1751."},{"name":"Rose Binney","description":"Enslaved woman. Married Joab 1751."},{"name":"Titus","description":"Enslaved man. Son of Joab and Rose."},{"name":"Joseph","description":"Enslaved man. Married couple with Sue."},{"name":"Sue","description":"Enslaved woman. Married Joseph."}],"marriages":[{"spouse_id":"HD0418","children_ids":["H00376","H00377","H00378","H00379","H00380","H00381","H00382","H00383","H00384","H00385","H00386"],"marriage_number":1}],"sources":[{"short":"Wikipedia","notes":"Jonathan Edwards (theologian) article"}],"gender":"male","tags":["yale_graduate"],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["religion"],"notable_blurb":"Theologian, Great Awakening leader","primary_url":"https://en.wikipedia.org/wiki/Jonathan_Edwards_(theologian)","primary_url_label":"Wikipedia"},"cross_connections":[{"type":"mentor_student","related_id":"H00443","display_label":"Giles Hooker Cowles studied theology under him after graduating Yale in 1789.","link_text":"Rev. Giles Hooker Cowles"},{"type":"family_connection","related_id":"X00613","display_label":"Succeeded his son-in-law as Princeton president after his sudden death.","link_text":"Rev. Aaron Burr Sr."},{"type":"family_orbit","related_id":"X02351","display_label":"Hosted him in final illness; published his Life as bestseller","link_text":"Rev. David Brainerd"},{"type":"historical_connection","related_id":"I00140","display_label":"Physician-minister and intimate friend in his New York years","link_text":"Rev. Dr. John Smith"}],"artworks":["ART019"],"education":[{"notes":"Entered 1716 at age 13. Graduated with highest honors.","school_name":"Yale College","graduation_year":1720,"institution_id":"INST022"},{"degree":"M.A.","school_name":"Yale College","graduation_year":1722,"institution_id":"INST022"}],"bio":{"title":"Reverend","display_name":"Rev. Jonathan Edwards","first_name":"Jonathan","last_name":"Edwards","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/thumb/e/e7/Jonathan_Edwards_%28detail%29.jpg/440px-Jonathan_Edwards_%28detail%29.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1720"},{"institution_id":"INST023"}],"landmarks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"religion","header":"His 1741 sermon shocked New England","body":"On July 8, 1741, he delivered 'Sinners in the Hands of an Angry God' to a Connecticut congregation. The Great Awakening had been spreading from his Northampton parish for six years."},{"number":2,"category":"legacy","header":"Wrote his greatest works in frontier exile","body":"After Northampton he took the Stockbridge mission preaching to Housatonnuck families through an interpreter. There he composed Freedom of the Will, The Nature of True Virtue, and The Doctrine of Original Sin."},{"number":3,"category":"religion","header":"Town turned on him over a midwifery book","body":"In 1748 he disciplined young people in his Northampton parish for circulating what he called 'immoral books,' later identified as a midwifery manual. His own Williams and Hawley relatives led the council that dismissed him in 1750."},{"number":4,"category":"death","header":"Died thirty-five days into the Princeton presidency","body":"He accepted the College of New Jersey presidency in early 1758 after his son-in-law Aaron Burr Sr. died suddenly in office. A smallpox inoculation administered February 23 turned fatal on March 22."},{"number":5,"category":"education","header":"Yale valedictorian at sixteen, in Latin","body":"He entered Yale at twelve and graduated four years later as the youngest member of his class. He delivered the commencement valedictory address in Latin."}],"slug":"jonathan-edwards-1703"},"HD0418":{"id":"HD0418","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1710,"month":1,"day":9,"city":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1758,"month":10,"day":2,"city":"Philadelphia","state":"Pennsylvania","country":"United States"},"parents":{"father_id":"X00126","mother_id":"H00034"},"tags":[],"sources":[{"short":"Pierpont genealogy, entry 30"},{"short":"Life of Rev. Jonathan Edwards by Sereno Dwight"},{"short":"Wikipedia: Jonathan Edwards; Sarah Pierpont"}],"burial":{"cemetery_id":"CEM026","plot_notes":"Princeton Cemetery, Princeton, New Jersey — buried next to Jonathan Edwards"},"marriages":[{"spouse_id":"X00128","children_ids":["H00376","H00377","H00378","H00379","H00380","H00381","H00382","H00383","H00384","H00385","H00386"],"marriage_number":1,"date_year":1727,"date_month":7,"date_day":28,"location_country":"United States"}],"cross_connections":[{"type":"family_connection","related_id":"H00913","display_label":"Died trying to bring him home from Princeton at age two.","link_text":"Aaron Burr Jr."},{"type":"family_connection","related_id":"H00912","display_label":"Died trying to bring her home from Princeton at age four.","link_text":"Sarah Burr Reeve"},{"type":"family_connection","related_id":"H00372","display_label":"Her North Haven nephew — wealthiest man in town in 1786","link_text":"Giles Pierpont"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["religion"],"notable_blurb":"Wife of Jonathan Edwards, theologian","primary_url":"https://en.wikipedia.org/wiki/Sarah_Pierpont_Edwards","primary_url_label":"Wikipedia"},"bio":{"display_name":"Sarah Pierpont Edwards","first_name":"Sarah","last_name":"Edwards","married_names":["Edwards"],"maiden_name":"Pierpont","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777405945/sarahedwardsb1710_txo277.png","photo_notes":"Sarah Pierpont Edwards (1710-1758), wife of Jonathan Edwards.","bio_blurb":"Subject of Edwards’s famous meditation at thirteen"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"},{"institution_id":"INST023"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Edwards wrote about her when she was twelve","body":"Jonathan Edwards composed a private spiritual meditation about a 'young lady in New Haven who is beloved of that Great Being who made and rules the world.' She married him five years later, at seventeen."},{"number":2,"category":"family","header":"Brought home her orphaned Burr grandchildren","body":"After Jonathan's death she traveled south in autumn 1758 to retrieve four-year-old Sarah Burr and two-year-old Aaron Burr Jr. She fell sick with dysentery in Philadelphia before she could complete the journey."},{"number":3,"category":"death","header":"Died exactly six months after her husband","body":"Jonathan died of smallpox-inoculation complications on March 22, 1758, weeks into the Princeton presidency. Sarah died of dysentery on October 2, 1758, at forty-eight."},{"number":4,"category":"death","header":"Made her will the day she died","body":"On October 2, 1758, in Philadelphia, she dictated her last instructions hours before dysentery took her. The two Burr grandchildren she had been escorting were placed with Dr. William Shippen."},{"number":5,"category":"legacy","header":"Her portrait hangs in a Yale dining hall","body":"She and her husband were both painted in oils, traditionally attributed to John Smybert. The portraits were bequeathed to Yale in 1939 and now hang in Jonathan Edwards College."}],"slug":"sarah-edwards-1710"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}