er the Huntington Family in America 1915 record: 'He had spent some portion of his life on the sea' before settling in Indiana as a respected citizen. Honored by fellow citizens with frequent testimonials of their confidence in his character."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"septimus-huntington-1778"},"I01146":{"id":"I01146","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Mary","middle_name":"Tyler","last_name":"Huntington","maiden_name":"Morse","married_names":["Huntington"],"gender":"female","display_name":"Mary Tyler Morse Huntington"},"gender":"female","birth":{"year":1787,"month":4,"day":29,"county":"Worcester","state":"Massachusetts","country":"United States"},"baptism":{},"death":{},"residence":{"county":"Shelby","state":"Indiana","country":"United States"},"burial":{"plot_notes":"Center Cemetery, Shelby County Indiana — alongside husband Septimus."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_research_notes":"Morse family of Wrentham (Norfolk County) MA. Wrentham was the same town as the Morses (Samuel F.B. Morse the telegraph inventor's family). Specific parents not yet identified."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"TD0260","date_year":1810,"date_month":2,"location_city":"Wrentham","location_county":"Norfolk","location_state":"Massachusetts","location_country":"United States","end_type":"death_of_spouse","end_year":1844,"children_ids":["TD0261","TD0262","TD0263","TD0264","TD0265","TD0266"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"mary-morse-1787"},"Y00008":{"id":"Y00008","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"bio":{"display_name":"Rev. Joseph Huntington","first_name":"Joseph","last_name":"Huntington","title":"Rev.","married_names":[]},"gender":"male","birth":{"year":1735,"month":5,"day":5,"city":"Windham","county":"Windham","state":"Connecticut","country":"United States"},"death":{"year":1794,"month":12,"day":25,"city":"Coventry","county":"Tolland","state":"Connecticut","country":"United States","cause":"Complication of diseases per contemporary account"},"burial":{"cemetery_name":"Nathan Hale Cemetery","city":"Coventry","state":"Connecticut","country":"United States"},"parents":{"father_name":"Nathaniel Huntington","mother_name":"Mehitabel Thurston Huntington","father_research_notes":"Nathaniel Huntington of Windham CT.","mother_research_notes":"Mehitabel Thurston Huntington."},"number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"Y00009","date_year":1764,"date_month":11,"date_day":7,"location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1771,"children_ids":["Y00010"]},{"marriage_number":2,"spouse_id":"TD0237","date_year":1772,"date_month":8,"date_day":26,"location_city":"Glastonbury","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1794,"children_ids":["TD0238","TD0260","TD0298","TD0299","TD0300","TD0301","TD0302","TD0303","TD0304"]}],"education":[{"institution_id":"INST022","dates":"1758-1762","type":"undergraduate","notes":"Yale College B.A. 1762. Entered at age 23 after his father had destined him for the clothier trade against his own wishes; his pastor Rev. Ebenezer Devotion encouraged the late preparation. Graduated honorably."}],"career":[{"role":"Pastor","organization":"First Church of Coventry","location":"Coventry, Connecticut","start_year":1763,"end_year":1794,"notes":"Installed June 29, 1763 — within one year of his Yale graduation. Continued as pastor until his death thirty-one years later. Under his ministry the parish built the best meeting house in the region for $5,000 — services at his ordination were held in the open air either because the existing meeting house was too small or too dilapidated."}],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1758-1762","institution_blurb":"Yale College 1762; D.D. honoris causa 1780; Trustee 1780-1788."}],"landmarks":[],"artworks":[],"tags":["minister","clergy","author","yale_graduate","educator"],"research_tags":[],"notable":{"is_notable":false,"notable_category":["minister","literature"],"notable_blurb":"Coventry minister who posthumously published Universalism","primary_url":"https://en.wikipedia.org/wiki/Joseph_Huntington","primary_url_label":"Wikipedia"},"cross_connections":[{"type":"mentor_student","related_id":"X02860","display_label":"Tutored Nathan Hale at Coventry for Yale entrance","link_text":"Nathan Hale"}],"quotes":[],"documents":[],"sources":[],"narrative_blocks":[{"number":1,"category":"literature","header":"Daughter burned most copies of his Universalist treatise","body":"'Calvinism Improved' — his posthumous 1796 treatise defending universal salvation and denying eternal punishment — was doomed to limited circulation because one of his daughters consigned the greater part of the edition to the flames. Sprague's Annals of the American Pulpit notes 'so effectual was the suppression of the work that it is now almost impossible to find a copy.'"},{"number":2,"category":"family","header":"Son from first marriage became Ohio Governor","body":"His eldest son with Hannah Devotion — Samuel H. Huntington — was orphaned at age six when Hannah died in 1771 and was adopted by his uncle Samuel Huntington, the Connecticut Governor and Declaration signer. The boy grew up to attend Dartmouth and Yale, settled Cleveland in 1801, and became the third Governor of Ohio 1808-1810 — half-brother to the nine children Joseph would later have with second wife Elizabeth Hale."},{"number":3,"category":"education","header":"Tutored Nathan Hale of Coventry for Yale","body":"He prepared Nathan Hale (1755-1776) of Coventry for Yale before Hale entered the college in 1769 and graduated 1773. Hale was hanged at New York September 22, 1776 — 'I only regret that I have but one life to lose for my country.' Both Huntington and Hale are buried at the Nathan Hale Cemetery in Coventry."},{"number":4,"category":"career","header":"Almost succeeded Wheelock as Dartmouth president, 1780","body":"After the death of Rev Eleazar Wheelock — Dartmouth's first president — communications were made to Huntington that gave him reason to expect election as Wheelock's successor. He actually made the journey to Hanover NH before declining. Yale conferred a D.D. honoris causa on him that same year, and he was elected a Yale Trustee 1780-1788."},{"number":5,"category":"religion","header":"Preached Universalism quietly for two decades","body":"Old parishioners later claimed 'Dr Huntington preached good Universalism for twenty years, but in such a way that he was not suspected, except by those who relished it.' His preface to Calvinism Improved acknowledged the work 'contained a small part of a system of divinity which the author has been meditating more than twenty years' — his Coventry parish never knew their pastor's actual theology."},{"number":6,"category":"career","header":"Open-air ordination at decayed Coventry meeting house","body":"Installed June 29, 1763 as pastor of the First Church of Coventry, where the previous meeting house had been suffered to go to decay. The ordination services were held in the open air, whether because the building was too small or too dilapidated to be safe never made clear. Within a few years he led the parish to build the best house of public worship in the region at a cost of five thousand dollars."}],"slug":"joseph-huntington-1735"},"TD0237":{"id":"TD0237","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"generation_from_john_talcott":5,"is_easter_egg":false},"bio":{"display_name":"Elizabeth Hale Huntington","first_name":"Elizabeth","last_name":"Huntington","maiden_name":"Hale","married_names":["Huntington"]},"gender":"female","birth":{"year":1747,"month":8,"day":16,"city":"Glastonbury","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1806,"month":2,"day":17,"city":"Coventry","county":"Tolland","state":"Connecticut","country":"United States"},"burial":{"cemetery_name":"Nathan Hale Cemetery","city":"Coventry","state":"Connecticut","country":"United States"},"parents":{"father_id":"TD0236","mother_id":"U00056"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"Y00008","date_year":1772,"date_month":8,"date_day":26,"location_city":"Glastonbury","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1794,"children_ids":["TD0238","TD0260","TD0298","TD0299","TD0300","TD0301","TD0302","TD0303","TD0304"],"notes":" Stage 6Y-202: eldest surviving child TD0238 built (Elizabeth Hale Huntington Jones, m. Amasa Jones 1794, → Wilkes-Barre PA 1816). 8 other M2 children deferred (Talcott gen 6 cohort, mostly died young): Septimus 1773-1776, George Washington Huntington 1776-1777, Septimus George 1778-1844, Hannah 1779-1794, Henry 1781-1806, Lucretia Norton 1783-1876, Mercy Penelope 1788-1794, James 1790-1793."}],"education":[],"career":[],"institutions":[],"landmarks":[],"artworks":[],"tags":[],"research_tags":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"quotes":[],"documents":[],"sources":[],"narrative_blocks":[{"number":1,"category":"family","header":"Father died of typhus at Siege of Boston","body":"Her father Capt Jonathan Hale Jr died of camp fever at Roxbury MA on March 7, 1776 — less than four years after her August 1772 marriage to Joseph Huntington. Her older brother Jonathan died unmarried that October and her younger sister Jerusha died that September, leaving her mother widowed with three children buried in one Revolutionary year."},{"number":2,"category":"family","header":"Six of nine children predeceased her","body":"Of the nine children she bore Rev Joseph Huntington between 1773 and 1790, six died before she did — Septimus (age 3), George Washington (age 1), Hannah (age 15), Penelope (age 6), James (age 3), and Henry (age 25 same year as her own death). Only Elizabeth, Septimus George, and Lucretia outlived their mother to maturity."}],"slug":"elizabeth-huntington-1747"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}