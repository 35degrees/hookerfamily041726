:[{"number":1,"category":"birthplace","header":"Born San Francisco 1828 — before the Gold Rush","body":"Mary Etta Isaacs was born on March 20, 1828 in San Francisco — then a tiny settlement called Yerba Buena in Mexican Alta California — placing her family among the very earliest documented New England visitors to what would become California, more than twenty years before the 1849 Gold Rush. Her father John Isaacs, a Hooker descendant through the Norwalk Saint John and Isaacs families, was likely engaged in the Pacific hide-and-tallow trade that drew New England merchant ships around Cape Horn to California ports throughout the 1820s."}],"quotes":[],"sources":[{"label":"St. John Genealogy (Alexander, 1907)","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"}],"research_sources":[],"documents":[],"slug":"mary-stow-1828"},"HD4398":{"id":"HD4398","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Elizabeth","last_name":"Belden","maiden_name":"Isaacs","married_names":["Belden"],"gender":"female","display_name":"Elizabeth Isaacs Belden"},"birth":{},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"X01910","mother_id":"H01239"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00741","location_country":"United States","children_ids":["HD4399"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"St. John Genealogy (Al