98"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01246","date_year":1816,"date_month":3,"date_day":13,"location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1817,"children_ids":["HD4400"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["cousin_marriage"],"research_tags":[],"cross_connections":[{"type":"cousin_marriage","related_id":"H01246","display_label":"Married Hooker Saint John — her mother's first cousin, both Hooker descendants","link_text":"Hooker Saint John"}],"narrative_blocks":[{"number":1,"category":"death","header":"Died at twenty-six within months of her son's","body":"Julia Belden married Hooker Saint John in March 1816 — her mother's first cousin, as their families had intermarried across generations in Norwalk — and their son Frederick Augustus was born in January 1817. Julia died in September 1817, aged twenty-six, within months of the birth; the boy himself would die without children in 1839 at twenty-two."}],"quotes":[],"sources":[{"label":"St. John Genealogy (Alexander, 1907)","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"}],"research_sources":[],"documents":[],"slug":"julia-saint-john-1791"},"H00479":{"id":"H00479","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1736,"city":"Norwalk","state":"Connecticut"},"parents":{"mother_id":"H00253","father_research_notes":"Capt. Joseph St. John of Norwalk","father_id":"X00215"},"tags":["revolutionary_war","slaveholder","moral_complexity"],"sources":[{"short":"Edward Hooker 1909","page":"H00253 branch"},{"label":"St. John Genealogy — entry 141","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"}],"death":{"year":1785,"month":5,"day":9,"city":"Norwalk","state":"Connecticut"},"political_offices":[{"title":"Selectman Norwalk","notes":"1763-64, 1766, 1772-73, 1775-78, 1782-84"},{"title":"Member CT House of Representatives","dates":"1778-1785"},{"title":"Major, 9th CT Regiment","dates":"May 1775"},{"title":"Lt. Colonel, 9th CT Militia","dates":"May 1777"},{"title":"Justice of the Peace","dates":"May 1777"}],"enslaved_persons":[{"name":"Peter","description":"Enslaved man. Listed in 1786 estate inventory."},{"name":"Phyllis","description":"Enslaved woman. Listed in 1786 estate inventory."}],"marriages":[{"spouse_id":"X00216","children_ids":["H01238","H01239","H01237","H01240","H01236"],"marriage_number":1,"date_year":1757,"date_month":12,"date_day":9}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"military_service":[{"war":"American Revolutionary War","rank":"Lt. Col.","unit":"9th Regiment, Connecticut Militia","notes":"Capt. 1st Co. Norwalk May 1761; Major 9th Regt. May 1775; Major 1st Batt. Col. Whiting Nov 1776; Lt. Col. 9th Regt. May 1777. On committee of Articles of Confederation 1777.","war_id":"WAR004"}],"bio":{"display_name":"Lt. Col. Stephen Saint John","first_name":"Stephen","last_name":"St. John","title":"Lieutenant Colonel","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778792414/stephenstjohnesq-resized_cvqbdg.png","photo_notes":"Portrait of Lt. Col. Stephen Saint John Esq.","bio_blurb":"Norwalk officer of the Connecticut 9th"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"former_ids":["HD0365"],"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave #44152495. Stone: 'Lt Col command of the 9th Reg of Foot Guard of the State of Connecticut who departed this life May the 9th 1785, in the 50th year of his age.'"},"narrative_blocks":[{"number":1,"category":"military","header":"Led Connecticut's 9th Regiment of Foot as Lt.","body":"Stephen Saint John rose to Lieutenant Colonel in command of the 9th Regiment of Foot, Guard of the State of Connecticut — a rank inscribed on his tombstone in East Norwalk Historical Cemetery. His family's marriage alliances connected two of Norwalk's most prominent dynasties: the Saint Johns married into the Fitches across two consecutive generations."},{"number":2,"category":"military","header":"He sent no substitute; his brother did","body":"A Connecticut selectman and Revolutionary officer, he led the colony’s 9th Regiment of Foot. When the war came, an enslaved man named Dover was sent to fight in the Continental Army in place of his brother — while his own household still held two people, Peter and Phyllis, at his death."}],"career":[{"role":"Selectman","organization":"Norwalk, Connecticut","notes":"1763-1784"},{"role":"Representative","organization":"Connecticut House","notes":"1778-1785"},{"role":"Lt. Colonel","organization":"9th Connecticut Regiment"}],"slug":"stephen-st-john-1736"},"X00216":{"id":"X00216","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"label":"St. John Genealogy (Alexander, 1907)","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"}],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00479","date_year":1757,"date_month":12,"date_day":9,"children_ids":["H01238","H01239","H01237","H01240","H01236"]}],"parents":{"father_name":"Hon. Samuel Fitch","mother_name":"Susannah Fitch","father_research_notes":"Per St. John Genealogy (Alexander 1907), entry 141: 'the dau. of Hon. S