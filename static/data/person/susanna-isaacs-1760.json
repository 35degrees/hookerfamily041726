ce":[],"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave."},"narrative_blocks":[{"number":1,"category":"family","header":"Had a daughter born in Mexican California, 1828","body":"John Isaacs was born in Norwalk, Connecticut, son of Isaac Scudder Isaacs and Susannah Saint John Isaacs (H01239, a Hooker descendant), and married Elizabeth Ann Saint John on October 7-8, 1821. His daughter Mary Etta was born in San Francisco on March 20, 1828 — when it was still called Yerba Buena under Mexican rule — placing his family among the very earliest documented New England visitors to Alta California, more than twenty years before the 1849 Gold Rush."}],"slug":"john-isaacs-1799"},"I00742":{"id":"I00742","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Elizabeth","middle_name":"Ann","last_name":"Isaacs","maiden_name":"Saint John","married_names":[],"gender":"female","display_name":"Elizabeth Ann Saint John Isaacs"},"birth":{"year":1801,"month":9,"day":24},"baptism":{},"death":{"year":1884,"month":1,"day":11},"residence":{},"burial":{"cemetery_id":"CEM002","plot_notes":"Died Jan 11, 1884 Norwalk CT. Per St. John source 'No. 804b'."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2792","date_year":1821,"date_month":10,"date_day":7,"location_country":"United States","children_ids":["HD4456","HD4457","HD4458"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"el