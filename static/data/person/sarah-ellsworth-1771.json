id":"X03372","marriage_number":2,"date_year":1849,"children_ids":[]}],"institutions":[{"institution_id":"INST041","institution_blurb":"Missionary at Brainerd Mission 1822-1837."}],"landmarks":[{"landmark_id":"LM154","relationship":"builder"}],"naming_inspiration":[],"tags":["cherokee_mission","mayor","minister","missionary"],"research_tags":[],"cross_connections":[{"type":"civic_connection","related_id":"HD6470","link_text":"Rev. Samuel Newton","display_label":"a fellow Cherokee missionary who later pioneered San Antonio"}],"quotes":[],"narrative_blocks":[{"number":1,"category":"religion","header":"He sailed south to teach the Cherokee","body":"In 1822 the American Board of Commissioners for Foreign Missions sent Ainsworth Blunt from Boston to the Brainerd Mission in the Cherokee Nation, where he taught literacy, Christianity, carpentry, and farming. He ran a ferry across Chickamauga Creek and oversaw the mission’s wild oxen, reporting that “much good” was being done."},{"number":2,"category":"religion","header":"A mission wedding among the Cherokee","body":"On November 17, 1822, Blunt married fellow teacher Harriet Ellsworth at Brainerd Mission Church — one of the earliest recorded white weddings in Cherokee territory south of the Tennessee River. The couple raised their family at the mission station until illness forced a move in 1837."},{"number":3,"category":"migration","header":"He walked part of the Trail of Tears","body":"When the Cherokee were forced west in 1838, Blunt accompanied them on the Trail of Tears as far as the Mississippi before illness turned him back. He afterward bought part of the former mission property to protect the cemetery where converts and missionaries lay buried."},{"number":4,"category":"politics","header":"From mission farmer to a town’s first mayor","body":"Resettling at Cross Plains, Georgia, Blunt became its first postmaster and, when the town was incorporated as Dalton in 1847, its first mayor. He helped found the First Presbyterian Church there and built, in 1848, the town’s first two-story house."},{"number":5,"category":"character","header":"His house became a Union hospital","body":"The 1848 Blunt House sheltered Confederate General Joseph E. Johnston and his staff in 1863–64, then served as a Union field hospital after the army pushed toward Atlanta. The family refugeed to Illinois in 1864 and returned after the war; Blunt died the following December."}],"sources":[{"short":"Wikipedia","notes":"Ainsworth Blunt article"}],"research_sources":[],"notable":{"is_notable":true,"notable_category":["religion","politics"],"notable_blurb":"Brainerd Mission teacher; first mayor of Dalton","primary_url":"https://en.wikipedia.org/wiki/Ainsworth_Blunt","primary_url_label":"Wikipedia"},"residence":{},"documents":[],"artworks":[],"military_service":[],"career":[{"role":"Missionary, farmer & mechanic","organization":"Brainerd Mission (ABCFM), Cherokee Nation","start_year":1822,"end_year":1838},{"role":"First Postmaster","organization":"Cross Plains / Dalton, Georgia","start_year":1845,"end_year":null},{"role":"First Mayor","organization":"Dalton, Georgia","start_year":1847,"end_year":null},{"role":"Ruling Elder","organization":"First Presbyterian Church, Dalton","start_year":1847,"end_year":1865}],"videos":[{"video_id":"VID003"}],"slug":"ainsworth-blunt-1800"},"HD6503":{"id":"HD6503","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":8},"bio":{"display_name":"Harriet Eliza Blunt","first_name":"Harriet Eliza","last_name":"Blunt","married_names":[]},"birth":{"year":1823,"date_precision":"exact","month":10,"day":12},"death":{"year":1825,"date_precision":"exact","month":12,"day":3},"parents":{"father_id":"X02122","mother_id":"X02121"},"marriages":[],"tags":["died_in_childhood"],"slug":"harriet-eliza-blunt-1823"},"HD6504":{"id":"HD6504","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"g