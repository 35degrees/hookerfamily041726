lege","dates":"graduated 1821","type":"undergraduate","notes":"Per EH 1909 #1416."},{"school_name":"Andover Theological Seminary","type":"professional","notes":"Per EH 1909 #1416."}],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":["author","clergy","minister"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Middlebury 1821, Andover Seminary","body":"Josiah Goodhue graduated Middlebury College in 1821 and Andover Theological Seminary thereafter, serving as Congregational pastor at Williston and Shoreham Vermont for twenty-four years. In 1857 he and Elizabeth removed to Whitewater Wisconsin, where he died May 3, 1863."},{"number":2,"category":"career","header":"Published history of Shoreham, Vermont, 1861","body":"Rev. Goodhue published 'History of the Town of Shoreham, Vermont, from the date of its charter, October 8th, 1761, to the present time' in 1861, printed by A.H. Copeland of Middlebury — a local history completed while he was still pastor at Shoreham. His middle name Fletcher derived from his mother's family: his mother was Elisabeth Fletcher Goodhue."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM559"},"residence":{"country":"United States"},"sources":[{"short":"EH 1909 #1416"}],"research_sources":[],"slug":"josiah-goodhue-1791"},"H02765":{"id":"H02765","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Thomas Hooker Goodhue","first_name":"Thomas","middle_name":"Hooker","last_name":"Goodhue","married_names":[]},"gender":"male","birth":{"year":1825,"month":8,"day":21,"city":"Williston","county":"Chittenden","state":"Vermont","country":"United States"},"death":{"year":1905,"month":9,"day":26,"city":"Whitewater","county":"Walworth","state":"Wisconsin"},"baptism":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generat