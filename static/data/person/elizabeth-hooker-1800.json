Ette","middle_name":"Mary","last_name":"Burrows","married_names":["Goodhue"]},"gender":"female","birth":{"year":1842,"month":2,"day":20,"city":"Perryville","state":"New York","country":"United States"},"death":{"year":1923,"month":6,"day":2},"baptism":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"parents":{},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H02765","date_year":1876,"date_month":6,"date_day":15,"children_ids":["H04371"]}],"career":[],"education":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Born in New York","body":"Mary Deette Burrows was the daughter of Stephen and Mary Elvira (Root) Burrows of Whitewater, Wisconsin, born February 20, 1842 at Perryville, New York. She married Thomas Hooker Goodhue on June 15, 1876."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM560"},"residence":{"country":"United States"},"sources":[{"short":"EH 1909 #2765"}],"research_sources":[],"slug":"deette-burrows-1842"},"H04371":{"id":"H04371","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Thomas Hooker Goodhue","first_name":"Thomas","middle_name":"Hooker","last_name":"Goodhue"},"gender":"male","birth":{"year":1879,"month":1,"day":1,"city":"Whitewater","state":"Wisconsin","country":"United States"},"death":{"year":1937,"month":1,"day":3},"baptism":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"parents":{"father_id":"H02765","mother_id":"I01193"},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01209","end_type":"death","end_year":1937,"children_ids":[]}],"career":[],"education":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":["named_for_hooker"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Third generation named Thomas Hooker in this family","body":"Thomas Hooker Goodhue was born January 1, 1879 at Whitewater, Wisconsin — the third consecutive generation to carry the names Thomas Hooker: his grandfather Thomas Hooker Goodhue, his great-grandmother Elizabeth White Hooker, and the family lineage back to Rev. Thomas Hooker of Hartford. The naming was an explicit act of genealogical memory, continued in Wisconsin four generations from Connecticut."},{"number":2,"category":"death","header":"Died January 3, 1937","body":"Thomas Hooker Goodhue Jr. was born January 1, 1879 and died January 3, 1937 in Whitewater — two days after what would have been his fifty-eighth birthday. He was the third consecutive generation to carry the name Thomas Hooker Goodhue."}],"naming_inspiration":[{"name_element":"Hooker","description":"Named Thomas Hooker — third consecutive generation in the Goodhue family, honoring the Hooker lineage through great-grandmother Elizabeth White Hooker."}],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM560"},"residence":{"country":"United States"},"sources":[{"short":"EH 1909 #4371"}],"research_sources":[],"slug":"thomas-goodhue-1879"},"H02766":{"id":"H02766","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Sarah Strong Goodhue","first_name":"Sarah","middle_name":"Strong","last_name":"Goodhue","married_names":[]},"gender":"female","birth":{"year":1827,"month":10,"day":3,"c