:null}},"maternal":{}},"grandchildren":[],"siblings_count":1},"context":{"HD3355":{"id":"HD3355","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Ellen","middle_name":"Rebecca","last_name":"Adams","married_names":[],"nickname":"Becky","gender":"female","display_name":"Ellen Rebecca \"Becky\" Adams"},"birth":{},"baptism":{},"death":{},"residence":{"city":"Longlac","state":"Ontario","country":"Canada"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":12,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD3351","mother_id":"I00310"},"gender":"female","marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["living_or_recent","living_possible_contact","canada_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"ellen-adams"},"HD3351":{"id":"HD3351","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Faneuil","last_name":"Adams","suffix":"Jr.","married_names":[],"nickname":"Fan","gender":"male","display_name":"Faneuil \"Fan\" Adams Jr."},"birth":{"year":1923,"month":7,"day":20,"city":"Boston","county":"Suffolk","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1999,"month":3,"day":22,"city":"Manhattan","county":"New York","state":"New York","country":"United States"},"residence":{},"burial":{"plot_notes":"Mayflower Cemetery, Duxbury MA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":11,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD3350","mother_id":"I00306"},"gender":"male","number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"I00310","children_ids":["HD3354","HD3355"],"date_year":1947,"end_year":1975,"end_type":"divorce"},{"marriage_number":2,"spouse_id":"I00311","children_ids":[],"end_year":1999,"end_type":"death"}],"education":[],"career":[{"role":"Executive","organization":"Mobil Oil Corporation","location":"Germany; Switzerland; Italy; Japan","notes":"International career with Mobil Oil — postings in Germany, Switzerland, Italy, and Japan during 1947-1975 marriage to Joan."},{"role":"President","organization":"Chess in Schools","notes":"Brought chess programs to inner-city schools."},{"role":"Treasurer","organization":"Manhattan Chess Club","location":"Manhattan, New York"},{"role":"Delegate","organization":"United States Chess Federation","notes":"Delegate to FIDE (World Chess Federation). Led opposition to FIDE leadership at infamous 1994 Moscow Congress."}],"military_service":[{"war":"World War II","war_id":"WAR008","rank":"First Lieutenant","unit":"US Army Paratroops","notes":"First Lieutenant in US Army paratroops; awarded Bronze Star."},{"war":"Korean War","war_id":"WAR014","rank":"First Lieutenant","unit":"US Army","notes":"Also served in Korean War."}],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["wwii","korean_war"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Born the same day his mother died","body":"Faneuil 'Fan' Adams Jr. was born July 20, 1923 in Boston — the same day his mother Rose Bradley Adams died, almost certainly in childbirth. He was the only documented son of Benjamin Faneuil Dunkin Adams II by Rose, his first wife. The same-day birth-and-mother-death is one of the more piercing first-day biographies in the tree, alongside a sibling in another branch's brother who lived only one day."},{"number":2,"category":"military","header":"WWII paratroop Bronze Star, then Korean War service","body":"Fan Adams served as a U.S. Army First Lieutenant in paratroops during World War II, receiving the Bronze Star. He then served again in the Korean War — making him a two-conflict combat veteran. He spent his postwar career as a Mobil Oil executive from 1947 to 1975, with overseas postings in Germany, Switzerland, Italy, and Japan, before retiring to devote himself to chess advocacy."},{"number":3,"category":"character","header":"1994 FIDE Moscow Congress resignation, vindicated election","body":"As a U.S. Chess Federation Policy Board member and delegate to FIDE, Fan attended the 1994 FIDE Moscow Congress. Under USCF Board pressure to reverse position and support FIDE leadership's heavy-handed tactics, he resigned his Board seat on the spot rather than comply — and within a year was overwhelmingly re-elected to the same Board he had just resigned from. He had also served as President of Chess in Schools, the inner-city programs organization, and Treasurer of the Manhattan Chess Club."}],"quotes":[{"text":"Fan Adams was a man of integrity. When he was the delegate of the United States Chess Federation to the infamous 1994 FIDE Congress at Moscow his integrity shone through. At that Congress, Fan led the battle against the heavy handed and illegal tactics employed by the World Chess Federation's leadership in order for them to stay in power. Rather than go against his principles, Fan resigned on the spot from a job he cherished.","attribution":"Don Schultz, eulogy for Faneuil Adams Jr., NYC, April 1, 1999","category":"character"}],"sources":[],"research_sources":[],"documents":[],"slug":"faneuil-adams-jr-1923"},"I00310":{"id":"I00310","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Joan","last_name":"Bertaccini","maiden_name":"Purves","married_names":["Adams","Bertaccini"],"gender":"female","display_name":"Joan Purves Adams Bertaccini"},"birth":{"year":1928,"month":7,"day":27},"baptism":{},"death":{"year":2020,"month":7,"day":21,"city":"Morris","county":"Litchfield","state":"Connecticut","country":"United States"},"residence":{},"burial":{"plot_notes":"East Cemetery, Litchfield CT"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Austin Montgomery Purves Jr.","mother_name":"Ellen Tybout Wood Purves","father_research_notes":"20th-century artist and educator"},"gender":"female","number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"HD3351","children_ids":["HD3354","HD3355"],"date_year":1947,"end_year":1975,"end_type":"divorce"},{"marriage_number":2,"spouse_id":"X02540","children_ids":[]}],"education":[{"school_name":"Litchfield High School","type":"secondary"},{"school_name":"Barnard College","dates":"1942-1949","type":"undergraduate"},{"school_name":"Waterbury Hospital","type":"professional","notes":"LPN."},{"school_name":"Columbia-Presbyterian","type":"professional","notes":"RN — pursued after 1975 divorce."}],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"joan-purves-1928"},"HD3350":{"id":"HD3350","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Benjamin","middle_name":"Faneuil Dunkin","last_name":"Adams","suffix":"II","married_names":[],"gender":"male","display_name":"Benjamin Faneuil Dunkin Adams II","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777487231/benfanueiladams_y1eev1.jpg"},"birth":{"year":1898,"month":5,"day":11,"city":"Concord","county":"Middlesex","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1981,"month":4,"day":22,"city":"Duxbury","county":"Plymouth","state":"Massachusetts","country":"United States"},"residence":{},"burial":{"plot_notes":"Mayflower Cemetery, Duxbury MA"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD3347","mother_id":"I00304"},"gender":"male","number_of_marriages":4,"marriages":[{"marriage_number":1,"spouse_id":"I00306","children_ids":["HD3351"],"date_year":1922,"end_year":1923,"end_type":"death_of_spouse"},{"marriage_number":2,"spouse_id":"I00307","children_ids":[],"end_year":1965,"end_type":"death_of_spouse"},{"marriage_number":3,"spouse_id":"I00308","children_ids":[],"end_year":1978,"end_type":"death_of_spouse"},{"marriage_number":4,"spouse_id":"I00309","children_ids":[],"date_year":1980,"end_year":1981,"end_type":"death"}],"education":[{"school_name":"Middlesex School","type":"preparatory","notes":"Middlesex School, Concord MA — preparatory school."},{"institution_id":"INST002","type":"undergraduate","notes":"A.B. Harvard."},{"institution_id":"INST002","school_name":"Harvard Law School","type":"law","notes":"Harvard Law School."}],"career":[{"role":"Partner (retired)","organization":"Hill & Barlow","location":"Boston, Massachusetts","notes":"Boston law firm Hill & Barlow."},{"role":"President","organization":"Cambridge Center for Adult Education","location":"Cambridge, Massachusetts"}],"military_service":[{"war":"World War I","war_id":"WAR007","rank":"Unknown","notes":"Veteran (war service flagged on FindAGrave; war unspecified in source — WWI inferred from age 19-20 at US entry 1917-18)."}],"institutions":[{"institution_id":"INST002","relationship":"alumnus"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["harvard_graduate","lawyer","wwi"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"First wife died in childbirth same day","body":"Benjamin's first wife Rose Bradley died July 20, 1923 in childbirth at age twenty-three — the same day she bore their son Faneuil 'Fan' Adams Jr. Rose was twenty-four at the marriage in 1922 and was dead within a year. Benjamin was twenty-five at her death, and the simultaneous birth and death framed the start of his decades of subsequent widowhood and remarriage."},{"number":2,"category":"family","header":"Four marriages including final at age eighty-two","body":"Benjamin had four marriages across his eighty-three-year life — Rose Bradley in 1922 who died 1923, then Susanne Root, then Helen Weston Thompson, and finally Mary Manning in 1980 at age eighty-two — that final late-life marriage ending within a year by his own April 1981 death. Only the first marriage produced a documented child."},{"number":3,"category":"career","header":"Hill and Barlow partner; Cambridge adult education president","body":"Benjamin earned an A.B. from Harvard followed by Harvard Law School, and retired as a partner at the Boston law firm Hill and Barlow. In civic life he served as President of the Cambridge Center for Adult Education — the long-running Cambridge institution founded in 1938. The combined corporate-law and adult-education leadership tracked the typical second-career trajectory of established Boston-area lawyers."},{"number":4,"category":"family","header":"Born Concord MA 1898, died Duxbury MA 1981","body":"Benjamin Faneuil Dunkin Adams II was born May 11, 1898 in Concord, Middlesex County Massachusetts and died April 22, 1981 in Duxbury, Plymouth County Massachusetts at age eighty-two. He is buried at Mayflower Cemetery, Duxbury — the family ground where Rose Bradley, son Fan Adams Jr., and his mother Rebecca Ames are also interred."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"benjamin-adams-ii-1898"},"I00306":{"id":"I00306","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Rose","last_name":"Adams","maiden_name":"Bradley","married_names":["Adams"],"gender":"female","display_name":"Rose Bradley Adams"},"birth":{"year":1899,"month":8,"day":28},"baptism":{},"death":{"year":1923,"month":7,"day":20,"cause":"childbirth complications (presumed)"},"residence":{},"burial":{"plot_notes":"Mayflower Cemetery, Duxbury MA"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3350","children_ids":["HD3351"],"date_year":1922,"end_year":1923,"end_type":"death"}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_in_childbirth"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"rose-bradley-1899"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}