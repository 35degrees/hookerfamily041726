College 1947-1966"},"birth":{"year":1900,"city":"Rochester","county":"Monroe County","state":"New York","country":"United States"},"baptism":{},"death":{"year":1969,"city":"Gravenhurst","state":"Ontario","country":"Canada"},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"generation_from_john_talcott":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["education"],"notable_blurb":"Dean of Bowdoin College for twenty years, 1947-1966","primary_url":"https://archivesspace.bowdoin.edu/repositories/2/resources/251","primary_url_label":"Bowdoin College Special Collections — Kendrick Papers"},"parents":{"father_id":"HD4668","mother_id":"I00944"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00946","date_year":1927,"location_country":"United States","children_ids":["HD4672","HD4673"]}],"education":[{"school_name":"University of Rochester","dates":"B.A. 1921","type":"undergraduate"},{"institution_id":"INST002","school_name":"Harvard University","dates":"Ph.D. 1930","type":"doctorate","notes":"Studied at London and Vienna on traveling fellowship 1925-26."}],"career":[{"role":"Instructor/Professor of History","organization":"Bowdoin College, Brunswick, Maine","start_year":1926,"end_year":1966,"notes":"Joined as instructor 1926; assistant professor 1928; associate professor 1932; full professor 1946; acting dean 1946; Dean 1947-1966; Frank Munsey Professor of History Emeritus 1959. Honorary doctorate of humane letters 1966."}],"military_service":[],"institutions":[{"institution_id":"INST020","relationship":"alumnus","years":"B.A. 1921","institution_blurb":"Graduated University of Rochester 1921, the institution his grandfather Asahel Clark Kendrick had helped found in 1850."},{"institution_id":"INST130","relationship":"faculty","years":"1926-1966","institution_blurb":"Dean of Bowdoin College 1947-1966; Frank Munsey Professor of History Emeritus; papers held at Bowdoin Special Collections M101."},{"institution_id":"INST002","relationship":"alumnus"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["educator","academic"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Dean of Bowdoin College for twenty years","body":"Nathaniel Cooper Kendrick served as dean of Bowdoin College from 1947 to 1966 — twenty years — having joined the Bowdoin history faculty in 1926 after completing his PhD at Harvard and being named the Frank Munsey Professor of History Emeritus in 1959, making him one of the longest-serving academic administrators in Bowdoin's history. His grandfather Asahel Clark Kendrick had been among the founding faculty of the University of Rochester a century earlier, making this the third generation of the Hooker-Kendrick line to hold a distinguished academic chair."},{"number":2,"category":"education","header":"Took his doctorate at Harvard before leading Bowdoin","body":"Nathaniel Cooper Kendrick earned his doctorate at Harvard University in 1930 — having completed his bachelor's at the University of Rochester, where his grandfather had taught Greek for thirty-eight years — and spent his entire career at Bowdoin College, rising from instructor in 1926 to dean of the college in 1947, a position he held for twenty years. His papers, held at the Bowdoin College Special Collections (M101), document his tenure across the Depression, World War II, and the postwar reshaping of liberal arts education."}],"quotes":[],"sources":[{"label":"FindAGrave","url":"https://www.findagrave.com"},{"label":"Bowdoin College Special Collections — Nathaniel Cooper Kendrick Papers (M101)","url":"https://archivesspace.bowdoin.edu/repositories/2/resources/251"}],"research_sources":[],"documents":[],"slug":"nathaniel-kendrick-1900"},"HD4672":{"id":"HD4672","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Ann","middle_name":"Kendrick","last_name":"McNabb","maiden_name":"Kendrick","married_names":["McNabb"],"gender":"female","display_name":"Ann Kendrick McNabb","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778971847/annkendrick_vo5gqy.jpg","photo_notes":"Ann Kendrick McNabb (1929-2021)"},"birth":{"year":1929,"month":12,"day":6,"city":"Portland","county":"Cumberland County","state":"Maine","country":"United States"},"baptism":{},"death":{"year":2021,"month":3,"day":2,"county":"Monroe County","state":"New York","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM436","plot_notes":"Mount Hope Cemetery Rochester — returning to the family burial ground"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"generation_from_john_talcott":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD4670","mother_id":"I00946"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00947","location_country":"United States","children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[{"institution_id":"INST020","relationship":"alumnus","years":"B.A. History","institution_blurb":"Attended the University of Rochester, where her great-great-grandfather Asahel Clark Kendrick had been inaugural professor of Greek in 1850, completing the fourth generation of the Hooker-Kendrick family at the institution."}],"landmarks":[],"naming_inspiration":[{"name_element":"Kendrick","inspired_by_id":"HD4668","description":"Middle name 'Kendrick' preserves the family's scholarly identity — her grandfather Ryland Morris Kendrick had been a Rochester classics professor and her great-grandfather Asahel Clark Kendrick had founded the Greek program at the university she would herself attend."}],"artworks":[],"tags":["civil_rights"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"legacy","header":"Four generations taught at her alma mater","body":"Ann Kendrick McNabb attended the University of Rochester — where her great-great-grandfather Asahel Clark Kendrick had been its founding professor of Greek in 1850, her great-grandfather Ryland Morris Kendrick had taught Greek and Latin, and where the family had maintained a continuous scholarly presence across four generations — and named her own grandson Ryland to carry the family lineage forward. She spent her life in Rochester as a civil rights activist, tutor, early childhood advocate, and supporter of refugee families, sustaining the family's commitment to public service that had begun with a Baptist minister's son teaching Greek in 1831."}],"quotes":[],"sources":[{"label":"FindAGrave","url":"https://www.findagrave.com"},{"label":"Ann Kendrick McNabb obituary, Rochester, March 2021"}],"research_sources":[],"documents":[],"slug":"ann-mcnabb-1929"},"I00947":{"id":"I00947","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Neal","middle_name":"A","last_name":"McNabb","married_names":[],"gender":"male","display_name":"Neal A McNabb"},"birth":{},"baptism":{},"death":{},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,