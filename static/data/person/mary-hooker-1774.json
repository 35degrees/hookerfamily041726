found 'the confidence of the town was entirely withheld from him.'"},{"number":2,"category":"family","header":"Married into a Loyalist Hooker descendant family","body":"His wife Mary Ingersoll was the daughter of Rev. Jonathan Ingersoll — himself a Hooker descendant through a separate line. The Ingersoll family were committed Loyalists; this marriage united two Hooker-descendant branches across opposing political loyalties."},{"number":3,"category":"politics","header":"Rebuilt his reputation in Litchfield, New York","body":"He removed to Litchfield in Herkimer County, New York, where he became active and trusted in public affairs. His new neighbors honored his integrity and loyalty to the new nation, restoring the standing he had lost in Farmington."}],"burial":{"cemetery_id":"CEM833"},"slug":"joseph-hooker-1751"},"I01758":{"id":"I01758","bio":{"display_name":"Mary Ingersoll Hooker","gender":"female"},"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false},"has_descendants_documented":true,"number_of_marriages":1,"tags":[],"sources":[],"birth":{"year":1748,"month":12,"day":20,"city":"Ridgefield","county":"Fairfield","state":"Connecticut"},"death":{"year":1805,"month":11,"day":14,"city":"Litchfield","county":"Herkimer","state":"New York"},"burial":{"cemetery_id":"CEM833"},"marriages":[{"marriage_number":1,"spouse_id":"H00292","date_year":1771,"children_ids":["H00644","H00645","H00646","H00647","H00648","H00649"]}],"slug":"mary-ingersoll-hooker-i01758"},"H00102":{"id":"H00102","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1705,"month":2,"day":15,"city":"Farmington","st