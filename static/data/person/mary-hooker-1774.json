 of Hon. John Hooker — the Farmington judge whose famous Hooker Elm gave the town its hospitality tradition. His grandfather Rev. Samuel Hooker had ministered Farmington's church for thirty years; his great-great-grandfather Rev. Thomas Hooker founded Hartford."}],"slug":"joseph-hooker-1705"},"I00132":{"id":"I00132","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1712,"month":5,"day":8,"city":"Farmington","state":"Connecticut","country":"United States"},"death":{"year":1797,"month":12,"day":25,"city":"Farmington","state":"Connecticut","country":"United States"},"parents":{"father_id":"X00120","mother_research_notes":"Abigail Ashley of Westfield, Massachusetts","mother_id":"X01861"},"marriages":[{"spouse_id":"H00102","children_ids":["H00287","H00288","H00289","H00290","H00291","H00292"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 102"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Sarah Lewis Hooker","first_name":"Sarah","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Lewis"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"sarah-lewis-1712"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}