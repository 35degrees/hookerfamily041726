siness","header":"His brother’s death made him president","body":"When Luther Gordon Jr. died in 1921, Thomas took over the First National Bank of Brockport and replaced its 1873 building with a Neo-classical structure that still stands today as a Chase Manhattan branch. He was treasurer of St. Luke’s Episcopal — the same parish his brother had served as treasurer before him."}],"cross_connections":[],"burial":{"plot_notes":"Mount Hope Cemetery, Rochester NY (Gordon family plot Lot 61 Range 2)"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Trustee","organization":"Village of Brockport","start_year":1914,"end_year":1920},{"role":"Mayor","organization":"Brockport, NY","start_year":1920,"end_year":1922},{"role":"President","organization":"First National Bank of Brockport","start_year":1921}],"slug":"thomas-gordon-sr-1884"},"X02285":{"id":"X02285","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":false},"bio":{"first_name":"Ruth","middle_name":"Little","last_name":"Gordon","maiden_name":"Perry","married_names":["Gordon"],"gender":"female","display_name":"Ruth Little Perry Gordon"},"birth":{"year":1884,"month":4,"day":3},"death":{"year":1965,"month":2,"day":6},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3267","date_year":1908,"date_month":10,"date_day":7,"location_country":"United States","children_ids":["HD3278","HD3279"]}],"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 5052 (as Thomas Cullen Gordon spouse)"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"burial":{"plot_not