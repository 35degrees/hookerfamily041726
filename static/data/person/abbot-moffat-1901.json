ice":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married into the Seth Low family","body":"In 1869 Henry Pierrepont married Ellen Almira Low, daughter of merchant Abiel Abbot Low and sister of Seth Low. Seth would go on to serve as Mayor of Brooklyn (1881-1885), President of Columbia University (1890-1901), and Mayor of New York City (1902-1903). Ellen died in 1884, leaving six children — the match had woven the Pierrepont, Low, and Jay families together at the apex of Brooklyn Heights society."},{"number":2,"category":"career","header":"Pierrepont Brothers warehouse manager for 25 years","body":"Henry managed his family's import-export firm Pierrepont Brothers & Co. on the Brooklyn waterfront for twenty-five years. After his father's death the warehouse business was leased to Empire Warehouse Company in 1888 and sold to the Brooklyn Wharf and Warehouse Company in 1895. He held trusteeships at half a dozen Brooklyn institutions and served as warden of Grace Church on Brooklyn Heights."}],"slug":"henry-pierrepont-ii-1845"},"X00517":{"id":"X00517","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1846},"death":{"year":1884},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1537","children_ids":["HD1629","HD1630","HD1631","HD1632","HD1633","HD1634"],"marriage_number":1,"date_year":1869,"date_month":12,"date_day":9,"location_city":"Brooklyn","location_state":"New York"}],"gender":"female","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Ellen Almira Low","first_name":"Ellen","middle_name":"Almira","maiden_name":"Low","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":