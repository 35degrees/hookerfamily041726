":[{"header":"Founded The Nation in 1865","body":"Edwin Lawrence Godkin was born in County Wicklow, Ireland in 1831. After studying law in Belfast and covering the Crimean War for the London Daily News, he emigrated to the United States in 1856. In 1865 a group of abolitionists led by landscape architect Frederick Law Olmsted asked him to found a new weekly political magazine.","number":1},{"header":"Sued by Tammany Hall — and commemorated at Harvard","body":"Godkin's attacks on Tammany Hall were so frequent that in 1894 he was sued for libel over biographical sketches of its leaders — the cases never went to trial. He retired in December 1899 and died in Devon, England in 1902, buried at Saint Michael's Churchyard in Northamptonshire. The annual Edwin L.","number":2}],"burial":{"cemetery_id":"CEM068"},"cross_connections":[{"type":"civic_connection","related_id":"X02035","display_label":"Godkin was asked by Olmsted to found The Nation in 1865 and agreed, becoming its first editor.","link_text":"Frederick Law Olmsted"},{"type":"civic_collaborator","related_id":"HD2975","display_label":"Both were central figures in Frederick Law Olmsted's civic network — Elliott as Central Park commissioner from 1857, Godkin as founder of The Nation at Olmsted's urging in 1865.","link_text":"Charles Wyllys Elliott"}],"bio":{"display_name":"Edwin Lawrence Godkin","first_name":"Edwin","last_name":"Godkin","middle_name":"Lawrence","married_names":[],"photo_url":"https://upload.wikimedia.org/wikipedia/commons/f/f4/Edwin_Godkin.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"edwin-godkin-1831"},"HD0404":{"id":"HD0404","has_descendants_documented":true,"classification":{"include_in_path_calculation":false,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1835,"month":10,"day":6},"death":{"year":1875,"month":4,"day":11,"city":"New Haven","state":"Connecticut"},"parents":{"mother_id":"HD0403","father_research_notes":"Samuel Edmund Foote","father_id":"X01189"},"marriages":[{"children_ids":["HD2991","HD2992","HD2993"],"spouse_id":"X01190","marriage_number":1,"date_year":1859,"date_month":7,"date_day":29,"location_city":"New Haven","location_state":"Connecticut"}],"prominent_name_reason":"Wife of E.L. Godkin (1831-1902), founder and first editor of The Nation magazine (1865) — one of the most influential journals in American intellectual history. 8th-generation descendant of Rev. Thomas Hooker through: Thomas Hooker → Samuel Hooker → James Hooker → Mary Hooker Hart → Sarah Hart Hill → Henry Hill (Hon.) → Catherine Hill Elliott → Elizabeth Elliott Foote → Frances Foote Godkin.","tags":[],"sources":[],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"Her father's Cincinnati home hosted Harriet Beecher Stowe","body":"Frances 'Fanny' Foote was born in Guilford, Connecticut in 1835 — the same year her aunt Harriet Beecher was preparing to marry Professor Stowe at Cincinnati's Lane Theological Seminary, where her father's home was a center of antislavery discussion. After her father's death in 1858, Edwin Godkin courted her and they were married at Trinity Church, New Haven in 1859. A biography notes that acquaintances commented on her 'close resemblance to her mother, a tall woman of great beauty of countenance and an exceedingly clever brain.' She died April 11, 1875 at 39.","number":1}],"cross_connections":[],"bio":{"display_name":"Frances Elizabeth Foote Godkin","first_name":"Frances","last_name":"Godkin","married_names":["Godkin"],"middle_name":"Elizabeth","maiden_name":"Foote"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"insti