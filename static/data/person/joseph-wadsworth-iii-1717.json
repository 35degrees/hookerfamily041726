n":true,"generation_from_john_talcott":8,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"is_easter_egg":false},"birth":{"year":1786,"month":3,"day":7,"city":"Litchfield","county":"Litchfield","state":"Connecticut","country":"United States"},"death":{"year":1869,"month":3,"day":16,"city":"Yreka","county":"Siskiyou","state":"California","country":"United States"},"burial":{"cemetery_name":"Evergreen Cemetery","city":"Yreka","state":"California","country":"United States"},"parents":{"father_id":"TD0059","mother_id":"X01999","mother_research_notes":"Rhoda Hopkins Wadsworth"},"marriages":[],"number_of_marriages":1,"tags":["ohio_migration","politician","war_of_1812"],"sources":[{"short":"Wikipedia — Frederick Wadsworth","url":"https://en.wikipedia.org/wiki/Frederick_Wadsworth"}],"notable":{"is_notable":true,"notable_category":["politics","business"],"notable_blurb":"Mayor of Akron 1852-53","primary_url":"https://en.wikipedia.org/wiki/Frederick_Wadsworth","primary_url_label":"Wikipedia"},"cross_connections":[],"bio":{"display_name":"Frederick Wadsworth","first_name":"Frederick","last_name":"Wadsworth","married_names":[],"middle_name":"Elijah"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[{"landmark_id":"LM125"}],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"category":"politics","header":"He was an early mayor of Akron","body":"Frederick Wadsworth helped develop frontier Ohio through wool, canal, and iron ventures before serving as mayor of Akron in 1852. He had moved west from Litchfield, Connecticut, as a boy of thirteen.","number":1},{"category":"military","header":"His father commissioned him in 1812","body":"His father, General Elijah Wadsworth, appointed him a lieutenant in the Ohio militia at the outbreak of the War of 1812. The Wadsworth house he built in Edinburg Township still stands on the National Register.","number":2},{"category":"character","header":"He conquered a long battle with drink","body":"For some twenty-five years Frederick Wadsworth struggled with intemperance, then gave it up entirely and never drank again. He became a fervent advocate of abstinence, saying once that five hundred dollars could not tempt him to a single drink.","number":3},{"category":"business","header":"He helped finance the rise of Akron","body":"A canal commissioner and investor, Wadsworth joined Simon Perkins in the Portage Canal and Manufacturing Company that powered the new boomtown. He even lent money to the young John Brown for an Ohio farm before Brown's speculation collapsed in the Panic of 1837.","number":4}],"slug":"frederick-wadsworth-1786"},"TD0001":{"id":"TD0001","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":3,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1682},"death":{"year":1778,"month":8,"day":24},"parents":{"father_id":"U00018","mother_id":"T00040"},"marriages":[{"children_ids":["TD0058"],"spouse_id":"X01737","marriage_number":1}],"tags":[],"sources":[{"short":"Wadsworth Descendants","full":"Descendants of Joseph and Elizabeth (Talcott) Wadsworth — later publication"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Joseph Wadsworth","first_name":"Joseph","last_name":"Wadsworth","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"joseph-wadsworth-1682"},"X01737":{"id":"X01737","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"EH 1909"}],"gender":"unknown","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"TD0001","children_ids":["TD0058"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"cross_connections":[],"bio":{"display_name":"Joanna Hovey","first_name":"Joanna","last_name":"Hovey","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"joanna-hovey"},"U00018":{"id":"U00018","visible_default":false,"in_talcott_book":true,"classification":{"is_spouse_of_talcott_descendant":true,"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1648,"city":"Hartford","state":"Connecticut"},"death":{"year":1729},"parents":{"father_id":"Y00001","mother_id":"X01736"},"marriages":[{"children_ids":[],"spouse_id":"X01734","marriage_number":1},{"spouse_id":"T00040","children_ids":["TD0001","TD0002","TD0003","TD0004","TD0005"],"marriage_number":2},{"children_ids":[],"spouse_id":"X01735","marriage_number":3}],"sources":[{"short":"Talcott 1876","page":"Entry 40"},{"short":"Wadsworth Descendants","full":"Descendants of Joseph and Elizabeth (Talcott) Wadsworth — later publication"}],"gender":"male","tags":["king_philips_war"],"number_of_marriages":3,"notable":{"is_notable":true,"notable_category":["military"],"notable_blurb":"Captain of the Charter Oak legend","primary_url":"https://connecticuthistory.org/hiding-the-charter-images-of-joseph-wadsworths-legendary-action/","primary_url_label":"Connecticut History (CTHumanities)"},"narrative_blocks":[{"category":"politics","header":"He vanished into the dark with the charter","body":"By tradition, when the candles went out in the Hartford meeting-house on the night of 31 October 1687, Wadsworth carried the colony's charter into the dark and hid it in a great oak on the Wyllys grounds. Historians note the evidence is thin and the duplicate may have gone to his own cellar, but the legend made his name.","number":1},{"category":"military","header":"Lieutenant in King Philip's War, captain after","body":"Wadsworth served as a lieutenant during King Philip's War in the 1670s and had risen to captain by 1690. The colony long remembered him as a soldier as much as the charter's keeper.","number":2},{"category":"family","header":"Three marriages, but a single line of children","body":"Wadsworth married three times: first to Elizabeth Barnard, who left no children, and last to the widow Mary Blackleach, who outlived him. All his children came through his second wife, Elizabeth Talcott, daughter of Lieutenant-Colonel John Talcott.","number":3},{"category":"legacy","header":"The colony quietly paid him for the deed","body":"In 1715, nearly thirty years after the event, Connecticut voted Wadsworth twenty shillings for securing the duplicate charter in a very troublesome season. That grant is the closest thing to a contemporary record of his famous act.","number":4},{"category":"family","header":"His father crossed on the Lyon with Talcotts","body":"Wadsworth's father William came from England aboard the ship Lyon in 1632, in the same migration as the Talcott family whose daughter Joseph would later marry. The two Hartford founding houses were thus bound twice over, by voyage and by marriage.","number":5}],"cross_connections":[{"type":"artifact","display_label":"painted the oak where tradition hid the charter","related_id":"X03123","link_text":"Charles DeWolf Brownell"}],"military_service":[{"war":"King Philip's War","active_in_war":true,"rank":"Lieutenant","dates":"1676","war_id":"WAR002"}],"bio":{"title":"Captain","disp