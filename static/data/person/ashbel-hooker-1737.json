h","end_year":1766,"children_ids":["H00264","H00265","H00266","H00267"]}],"cross_connections":[{"type":"family_connection","related_id":"H00277","display_label":"His niece's son Abel Hollister came under his guardianship","link_text":"Anna Hart"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"family","header":"Named for a brother who died nine days","body":"His older brother John was born and died in December 1693 — living only nine days. When the next son arrived in 1695, his parents gave him the same name. He carried it through 71 years, Justice of the Peace and prominent Kensington businessman."},{"number":2,"category":"marriage","header":"He and his three sisters all married into","body":"His sisters Abigail, Mary, and Sarah married three sons of Capt. John Hart between 1719 and 1725. John himself had already married Mercy Hart in 1728 — from a different Hart branch, through Dea. Ebenezer Hart. Four Hooker siblings, two separate Hart lines, one generation."},{"number":3,"category":"politics","header":"Justice of the Peace","body":"EH describes him as \"a prominent and active man in the business of the town.\" He held the office of Justice of the Peace in Kensington, a parish of Berlin CT, and died there on August 3, 1766, age 71."}],"bio":{"display_name":"John Hooker","first_name":"John","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-hooker-1695"},"I00041":{"id":"I00041","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1703,"month":9,"day":29,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1782,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM008"},"parents":{"father_id":"X00119","father_name":"Dea. Ebenezer Hart","mother_name":"Mary Thompson","father_research_notes":"EH says father was Deacon Thomas Hart — WRONG. Barbour Collection Farmington VR confirms father was Dea. Ebenezer Hart (X00119). Primary source wins.","mother_id":"X00043"},"marriages":[{"marriage_number":1,"spouse_id":"H00098","date_year":1728,"date_month":7,"date_day":4,"location_city":"Kensington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1766,"children_ids":["H00264","H00265","H00266","H00267"]}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 98"},{"short":"Farmington Vital Records 1645-1850","notes":"Barbour Collection confirms: father = Dea. Ebenezer Hart"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[],"notable_blurb":null,"primary_url":null,"primary_url_label":null},"cross_connections":[],"bio":{"given_alt":"Mary","display_name":"Mercy Hart Hooker","notes":"EH gives 'Mercy (Mary) Hart' — both names used interchangeably","first_name":"Mercy","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Hart"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mercy-hart-1703"},"H00030":{"id":"H00030","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":3,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1664,"month":2,"day":20,"city":"Farmington","state":"Connecticut"},"death":{"year":1746,"month":2,"day":21,"city":"Farmington","state":"Connecticut"},"parents":{"father_id":"H00007","mother_id":"I00006"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 30"},{"short":"Native Northeast Portal","url":"https://www.nativenortheastportal.com/bio/bibliography/hooker-john-1664-1746"},{"short":"L.J. Hooker 1898","full":"L.J. Hooker, 'Edward Hooker, Commander, U.S. Navy,' The Old Northwest Genealogical Quarterly (Columbus, Ohio, 1898-), VII, 12"}],"marriages":[{"spouse_id":"I00031","children_ids":["H00095","H00096","H00097","H00098","H00099","H00100","H00101","H00102","H00103","H00104"],"marriage_number":1,"date_year":1687,"date_month":11,"date_day":24}],"cross_connections":[{"type":"family_connection","notes":"Col. Wadsworth's son Daniel Wadsworth founded the Wadsworth Atheneum in Hartford — a monument with Hooker family kinship interest. Research needed to confirm Mehitable Russell's Hooker descent line. Warren 1887 confirms: Elizabeth Standley married John Wadsworth — their son Daniel Wadsworth founded the Wadsworth Atheneum.","related_id":"X00035","display_label":"was his father-in-law, honored in the Indian wars","link_text":"Capt. John Standley"},{"type":"civic_peer","notes":"Capt. Thomas Hart b. ca. 1644, d. Aug 27, 1726 age 82. Son of Stephen Hart (X00034). Brother of John Hart who survived the 1666 fire (X00033). Not in this tree through marriage — noted as civic context only.","related_id":"X00034","display_label":"helped govern Farmington alongside him for decades","link_text":"Stephen Hart"},{"type":"parallel_descent","related_id":"T00387","display_label":"married a descendant of both Hooker and Standley","link_text":"Col. Jeremiah Wadsworth"},{"type":"civic_peer","related_id":"X00418","display_label":"served Hartford’s founding-family public life alongside him","link_text":"Rev. Daniel Wadsworth"},{"type":"family_connection","related_id":"X00453","display_label":"was his wife’s sister and Col. Jeremiah Wadsworth’s grandmother","link_text":"Elizabeth Standley"},{"type":"family_connection","related_id":"X00031","display_label":"fathered four children who married four of his own","link_text":"Capt. John Hart"},{"type":"civic_peer","related_id":"I00053","display_label":"Both served as Connecticut Colony Supreme Court judges.","link_text":"Hon. Daniel Edwards"},{"type":"family_connection","related_id":"H00089","display_label":"was the cousin whose Indian Neck deed he registered","link_text":"William Hooker"},{"type":"family_connection","related_id":"X00263","display_label":"signed a Tunxis dispossession deed as his descendant’s in-law","link_text":"Lt. John Mix"},{"type":"family_connection","related_id":"H00439","display_label":"shared his entanglement in Tunxis affairs, decades apart","link_text":"Ezekiel Cowles Jr."},{"type":"civic_peer","related_id":"X00045","display_label":"was called with him one of Farmington’s two prominent men","link_text":"Captain Thomas Hart"}],"burial":{"cemetery_id":"CEM004","plot_notes":"Memento Mori Cemetery, Farmington, Hartford County, Connecticut. Same cemetery as his father Rev. Samuel Hooker (H00007)."},"gender":"male","tags":["politician","judge","compiler_ancestor"],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Connecticut Superior Court judge, 1724-1732","primary_url":"https://www.nativenortheastportal.com/bio/bibliography/hooker-john-1664-1746","primary_url_label":"Native Northeast Portal — John Hooker biography"},"documents":["DOC004"],"residence":{"city":"Farmington","state":"Connecticut","country":"United States"},"narrative_blocks":[{"number":1,"category":"law","header":"Judge of Connecticut Colony's Supreme Court","body":"He served as Judge of the Supreme Court of Connecticut Colony from 1724 to 1732 and as Speaker of the Lower House. He also served as witness, certifying Assistant, and Registrar in the 1733 Sue Squa land deed — three official roles in a single transaction."},{"number":2,"category":"legacy","header":"He defended Tunxis land rights in court","body":"In 1738, John Hooker provided a formal statement to the Connecticut General Court that ninety acres at Indian Neck had 'always belonged' to the Tunxis tribe — an unusual act of testimony on behalf of the indigenous people whose land his own ancestors had settled near."},{"number":3,"category":"legacy","header":"The elm fell so someone could walk straight","body":"His father gave him a site on the west side of Farmington's main street, where he built under the branches of a great elm. The tree became famous through all the region for the company that gathered beneath it — three generations of Hookers lived in its shade before a later owner cut it down to straighten the sidewalk."},{"number":4,"category":"character","header":"The bell tolled — Hooker stepped out first","body":"A chronicler recorded that every Sunday the bell rang, then began tolling; at the first stroke, Hooker issued from his house and proceeded to the Meeting House. The minister walked from his house. Whoever arrived first waited at the door; together they entered — at which the bell stopped and all the congregation arose."},{"number":5,"category":"character","header":"The Sabbath ended when Hooker touched his gate","body":"The holiness of Sunday was supposed to end at sunset — but no child in the town dared stir until John Hooker gave the signal. When the sun sank, he walked to his gate and leaned on it; open flew the doors and out came the children with a wild rush and shout."},{"number":6,"category":"character","header":"Dark hair, dark eyes — dignity commanding respect","body":"His grandson described him: \"Dark hair and dark eyes, and a dignity in his air and expression that procured profound respect.\" A fine looking man, tall, very erect, and had a prominent large nose. He lived his entire life in Farmington, dying there in 1746 at age 81."}],"career":[{"role":"Justice and Register","organization":"Farmington, Connecticut","notes":"Served as justice and register of Farmington"},{"role":"Representative","organization":"Connecticut General Court","notes":"From Farmington. Served as Clerk two sessions; Speaker six sessions."},{"role":"Speaker","organization":"Connecticut General Court Lower House"},{"role":"Assistant","organization":"Colony of Connecticut"},{"role":"Judge, Superior Court","organization":"Colony of Connecticut","notes":"Served as judge of Superior Court concurrent with assistant role"},{"role":"Commissioner, Mohegan Sequestered Land","organization":"New London, Connecticut","notes":"Commissioner of the Mohegan's sequestered land at New London"}],"bio":{"display_name":"Hon. John Hooker","title":"Honorable","first_name":"John","last_name":"Hooker","married_names":[]},"baptism":{},"research_tags":[],"research_sources":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-hooker-1664"},"I00031":{"id":"I00031","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1669,"month":7,"day":25,"city":"Farmington","state":"Connecticut","country":"United States"},"death":{"year":1743,"month":2,"day":21,"city":"Farmington","state":"Connecticut","country":"United States"},"marriages":[{"spouse_id":"H00030","children_ids":["H00095","H00096","H00097","H00098","H00099","H00100","H00101","H00102","H00103","H00104"],"marriage_number":1,"date_year":1687,"date_month":11,"date_day":24,"location_country":"United States"}],"sources":[{"short":"Edward Hooker 1909","page":"Entries 99-101"}],"parents":{"father_id":"X00035","mother_id":"X00036"},"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"parallel_marriage","related_id":"I00051","display_label":"Both married Hooker brothers — from two separate Stanley families.","link_text":"Mary Standley"},{"type":"founding_family_nexus","related_id":"X00032","display_label":"Their families united — three daughters married Hart brothers.","link_text":"Mary Moore Hart"},{"type":"parallel_descent","related_id":"X00453","display_label":"Her sister Elizabeth Standley married into the Wadsworth line.","link_text":"Elizabeth Standley"}],"narrative_blocks":[{"number":1,"category":"family","header":"Her father won distinction in the Indian wars","body":"Capt. John Standley was a man of wealth and high social position who had served as lieutenant and captain in the Indian wars. Her sister Elizabeth Standley's granddaughter married Col. Jeremiah Wadsworth, Commissary General of the Continental Army — Wadsworth's wife also descended from Rev. Thomas Hooker, making Wadsworth's children doubly connected to the Hooker line."}],"bio":{"display_name":"Abigail Standley Hooker","notes":"Also spelled 'Stanley' in EH entry 30; 'Standley' in entries 99-101","first_name":"Abigail","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Standley"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM004","plot_notes":"Memento Mori Cemetery, Farmington CT. SOURCE: FindAGrave."},"slug":"abigail-standley-1669"},"X00119":{"id":"X00119","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"city":"Kensington","state":"Connecticut"},"children_noted":["I00041 Mercy/Mary Hart — married John Hooker Jr. (H00098) July 4, 1728"],"sources":[{"short":"Farmington Vital Records 1645-1850","notes":"Barbour Collection: \"Mary, d. Dea. Ebenezer, m. John HOOKER, Jr., July 4, 1728\""}],"gender":"unknown","tags":[],"number_of_marriages":1,"marriages":[{"children_ids":["I00041","X00