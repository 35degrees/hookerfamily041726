2372","location_country":"United States","end_type":"death_of_self","end_year":1994,"children_ids":[]}],"number_of_marriages":1,"tags":["extraordinary_longevity","kansas_migration"],"research_tags":[],"sources":[{"label":"FindAGrave — Mary Reed Hobart Hutchinson","url":"https://www.findagrave.com/memorial/41561937/mary_reed-hutchinson"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"naming_inspiration":[{"name_element":"Reed","inspired_by_id":"X02370","description":"Middle name carries her paternal grandmother Caroline Reed Hobart's maiden surname forward — the Maine line that married into the Berlin VT Hobart family in 1853."}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"mary-hutchinson-1902"},"X02368":{"id":"X02368","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"display_name":"Rev. James Hobart","first_name":"James","last_name":"Hobart","title":"Reverend","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777668484/revjameshobart_drsmyx.png","photo_notes":"Portrait. Cloudinary."},"birth":{"year":1766,"month":8,"day":2,"city":"Plymouth","county":"Grafton","state":"New Hampshire","country":"United States"},"baptism":{},"death":{"year":1862,"month":7,"day":16,"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"residence":{"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"burial":{"cemetery_id":"CEM176","plot_notes":"Berlin Corner Cemetery, Berlin Corners VT — alongside Betsey."},"gender":"male","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{},"marriages":[{"marriage_number":1,"spouse_id":"TD0120","date_year":1804,"date_month":8,"date_day":30,"location_city":"Berlin","location_state":"Vermont","location_country":"United States","end_type":"death_of_self","end_year":1862,"children_ids":["TD0121","TD0122","TD0123","TD0124","TD0125","TD0126","TD0127","TD0128","TD0129","TD0130","TD0131","TD0132"]}],"number_of_marriages":1,"tags":["minister","clergy","extraordinary_longevity"],"research_tags":[],"sources":[{"label":"Vermont Genealogy — Biography of Rev. James Hobart","url":"https://vermontgenealogy.com/washington/biography-of-rev-james-hobart.htm"},{"label":"FindAGrave — Rev James Hobart","url":"https://www.findagrave.com/memorial/641556/james-hobart"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"religion","header":"Berlin Vermont's first settled minister thirty-one years","body":"Ordained November 7, 1798 as Berlin Congregational's first settled minister, James drafted the church's confession of faith, covenant, and articles of discipline himself. His 31-year pastorate ran to May 1829, when a mutual council dismissed him. He then spent twelve years preaching in New Hampshire and twenty more itinerating around Worcester, Berlin, and West Berlin Vermont."},{"number":2,"category":"character","header":"Walked six miles and preached at ninety-five","body":"Per his obituary, 'in the very last year of his life, his 96th, he was able to preach a pretty well connected discourse, and could walk 6 or 8 miles in a day.' Below ordinary height with erect carriage, great memory, and a strong distinct voice, James was described as 'self-denying, laborious and persevering, having quite a missionary spirit.'"},{"number":3,"category":"family","header":"Three daughters married Congregational ministers","body":"Three of James and Betsey's daughters married Congregational ministers across New England: Pamelia married Rev. Rufus Child (Gilmanton NH then Berlin), Julia married Rev. Pliny Fisk Barnard (Richmond ME then Williamstown VT then Westminster VT), and Hannah married Rev. George Craven (Methodist, Danville VT). The Berlin pulpit's reach extended through the next generation."},{"number":4,"category":"religion","header":"Walked six miles a day preaching at ninety-six","body":"In the ninety-sixth year of his life Rev. Hobart preached well-connected discourses and was able to walk six or eight miles in a day. Below average height, he stood erect and was blessed with a retentive memory, strong voice, and good delivery."}],"cross_connections":[],"naming_inspiration":[],"education":[{"institution_id":"INST058","school_name":"Dartmouth College","dates":"1794","type":"undergraduate","notes":"A.B. 1794."},{"school_name":"Studies with Rev. Asa Burton","dates":"1794-1795","type":"theological","notes":"Apprentice studies with Asa Burton of Thetford VT before preaching license 1795."}],"career":[{"role":"Minister (candidate)","organization":"Chelsea VT","start_year":1795,"end_year":1796},{"role":"Minister (candidate)","organization":"Plymouth NH and Nottingham NH","start_year":1796,"end_year":1798,"notes":"Settlement call from Nottingham."},{"role":"First settled minister","organization":"Berlin Congregational Church (Berlin VT)","start_year":1798,"end_year":1829,"notes":"Ordained November 7, 1798. Drew up church confession of faith, covenant, and articles of discipline. 31-year pastorate dismissed by mutual council May 1829."},{"role":"Itinerant preacher","organization":"New Hampshire and Vermont congregations","start_year":1829,"end_year":1862,"notes":"Plymouth, Wentworth, Enfield, Alexandria, Bridgewater NH and near Portsmouth (12 years); then Worcester, Berlin, West Berlin VT (last 20 years)."}],"military_service":[],"institutions":[{"institution_id":"INST058","relationship":"alumnus"}],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"james-hobart-1766"},"TD0120":{"id":"TD0120","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"display_name":"Betsey Perrin Hobart","first_name":"Betsey","last_name":"Hobart","maiden_name":"Perrin","married_names":["Hobart"],"nickname":"Betsy"},"birth":{"year":1783,"month":3,"day":7,"city":"Hebron","county":"Tolland","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1876,"month":3,"day":28,"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"residence":{"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"burial":{"cemetery_id":"CEM176","plot_notes":"Berlin Corner Cemetery, Berlin Corners VT — FindAGrave 90950772."},"gender":"female","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":7,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_id":"X01832","mother_id":"T01387"},"marriages":[{"marriage_number":1,"spouse_id":"X02368","date_year":1804,"date_month":8,"date_day":30,"location_city":"Berlin","location_state":"Vermont","location_country":"United States","end_type":"death_of_spouse","end_year":1862,"children_ids":["TD0121","TD0122","TD0123","TD0124","TD0125","TD0126","TD0127","TD0128","TD0129","TD0130","TD0131","TD0132"]}],"number_of_marriages":1,"tags":["extraordinary_longevity","vermont_migration"],"research_tags":[],"sources":[{"label":"FindAGrave — Betsy Perrin Hobart","url":"https://www.findagrave.com/memorial/90950772/betsy-hobart"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"naming_inspiration":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"betsey-hobart-1783"},"X01832":{"id":"X01832","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"is_talcott_spouse":true},"tags":["revolutionary_war","vermont_migration","town_founder"],"sources":[{"label":"WikiTree — Zachariah Perrin Esq.","url":"https://www.wikitree.com/wiki/Perrin-2144"},{"label":"Vermont Genealogy — Biography of Rev. James Hobart","url":"https://vermontgenealogy.com/washington/biography-of-rev-james-hobart.htm"}],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"T01387","date_year":1779,"location_city":"Hebron","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1828,"children_ids":["T01391","TD0120","T01393","T01394","T01395","T01396","TD0170","TD0138","T01399"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1748,"month":3,"day":18,"city":"Hebron","county":"Tolland","state":"Connecticut","country":"United States"},"death":{"year":1838,"month":5,"day":25,"city":"Berlin Corners","county":"Washington","state":"Vermont","country":"United States"},"cross_connections":[],"bio":{"display_name":"Zachariah Perrin Esq.","first_name":"Zachariah","last_name":"Perrin","married_names":[],"suffix":"Esq.","gender":"male"},"residence":{"city":"Berlin Corners","county":"Washington","state":"Vermont","country":"United States","note":"Settled May 1789 from Hebron CT; farmed 1300 acres at Scott Hill/East Road intersection in East Road School District."},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[{"landmark_id":"LM066","landmark_blurb":"Established the 1300-acre East Road farmstead and built permanent buildings here after settling Berlin VT in 1789."}],"artworks":[],"quotes":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","unit":"8th Company, 12th Regiment Connecticut Militia","notes":"Documented Revolutionary War service."}],"burial":{"cemetery_id":"CEM176","plot_notes":"Berlin Corner Cemetery, Berlin Corners VT."},"narrative_blocks":[{"number":1,"category":"character","header":"Settled Berlin Vermont with collapsed-roof cabin","body":"Zachariah served in the Revolutionary War with the 8th company of the 12th Connecticut militia, then in February-March 1789 led his family from Hebron Connecticut to Berlin Vermont — up the Connecticut River with two teams of oxen, switching from wheels to runners in Brookfield. They found the log cabin he had built the previous summer crushed under three or four feet of snow."},{"number":2,"category":"legacy","header":"Founded a 1300-acre farm still in family","body":"Zachariah's 1300 acres in the East Road School District of Berlin VT — at what became the southeast corner of East Road and Scott Hill Road — passed down through generations of Perrins. His son Porter, the first boy born in Berlin, built the house at Scott Hill and Airport Road in 1815 (still standing). A descendant Henry Perrin still lived in 'Perrin territory' along Scott Hill Road into the modern era."}],"slug":"zachariah-perrin-1748"},"T01387":{"id":"T01387","has_descendants_documented":true,"classification":{"is_talcott_descendant":true,"include_in_path_calculation":true,"generation_from_john_talcott":6,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_easter_egg":false},"birth":{"year":1758,"month":6,"day":17,"city":"Glastonbury","state":"Connecticut"},"death":{"year":1828,"month":9,"day":11,"city":"Berlin Corners","county":"Washington","state":"Vermont"},"parents":{"father_id":"T01001","mother_id":"U00042"},"marriages":[{"children_ids":["T01391","TD0120","T01393","T01394","T01395","T01396","TD0170","TD0138","T01399"],"spouse_id":"X01832","marriage_number":1,"date_year":1779,"location_city":"Hebron","location_county":"Tolland","location_state":"Connecticut","location_country":"United States","end_type":"death_of_self","end_year":1828}],"sources":[{"label":"WikiTree — Mary (Talcott) Perrin","url":"https://www.wikitree.com/wiki/Talcott-49"},{"label":"Clark Univ — Mary Talcott rr23/rr23_395","url":"http://aleph0.clarku.edu/~djoyce/gen/report/rr23/rr23_395.html"}],"gender":"female","tags":["vermont_migration"],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"parallel_migration","related_id":"HD0233","display_label":"Settled Vermont 1789 after cousin David Newton's 1777 migration","link_text":"David Newton"}],"bio":{"display_name":"Mary Talcott Perrin","first_name":"Mary","last_name":"Perrin","maiden_name":"Talcott","married_names":["Perrin"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[{"landmark_id":"LM066","landmark_blurb":"Lived on the Perrin family farmstead from her arrival in Berlin in 1789 until her death in 1828."}],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM176","plot_notes":"Berlin Corner Cemetery, Berlin Corners VT — alongside Zachariah."},"narrative_blocks":[{"number":1,"category":"family","header":"Walked to Vermont with two oxen teams","body":"In February or March 1789 Mary and Zachariah moved their family from Hebron Connecticut to Berlin Vermont — traveling up the Connecticut River with two teams of oxen, then up the White River, switching from wheels to runners at Brookfield, then over a blazed trail. They arrived to find their log cabin's roof had collapsed under three to four feet of snow."},{"number":2,"category":"family","header":"Lost firstborn daughter Mary in 1798","body":"Mary's eldest child — also named Mary, born in Hebron — died in 1798. Four months later another daughter was born and named Mary in her sister's memory. The second Mary later married Julius Yemans Dewey and was the mother of Admiral George Dewey, hero of Manila Bay 1898."}],"slug":"mary-perrin-1758"}},"burialCemetery":{"id":"CEM176","name":"Berlin Corner Cemetery","city":"Berlin Corners","county":"Washington","state":"Vermont","country":"United States","primary_url":"https://www.findagrave.com/cemetery/641556/berlin-corner-cemetery","hooker_connections":["T01387","TD0120","TD0124","TD0129","TD0158","TD0159","TD0160","TD0161","TD0162","TD0163","TD0164","TD0200","X01832","X02368","X02370","X02383","X02384","X02409"],"notes":"Berlin Corner Cemetery, Berlin Corners Vermont. Burial site of the Perrin-Hobart founding family of Berlin VT — Zachariah Perrin Esq. (X01832, Berlin VT 1789 founder, Rev War vet, d.1838 age 90), his wife Mary Talcott Perrin (T01387, d.1828), their daughter Betsey Perrin Hobart (TD0120, d.1876), her husband Rev. James Hobart (X02368, Berlin VT first settled minister, d.1862 age 95), their son David Hobart (TD0129, d.1901), and his wife Caroline Reed Hobart (X02370, d.1898). Three Perrin-Hobart generations. [pilot100] Backfilled with Evans/Yale Berlin VT generation: Dr. Ira Evans Sr. (X02383) and Emeline Hobart Evans (TD0124, daughter of Rev. James + Betsey Hobart); their seven children including 4 died young/childhood/infancy (Mary E., Ira Jr., J. Annette, William Dwight) and 3 adult-lifespan (Mary Emeline Evans Yale + her Civil War vet husband Capt. Thomas Blossom Yale 108th NY Inf, Edward P. Evans 10th VT Inf wounded Cold Harbor, and Civil War Medal of Honor recipient Ira Hobart Evans TD0163 who died San Diego CA 1922 and was returned to Berlin Corner per his wishes). Cemetery now spans four generations of Hobart-Evans-Yale family across ~150 years."},"institutionsById":{},"crossConnections":[]}