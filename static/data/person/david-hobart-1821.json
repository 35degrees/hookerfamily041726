],"research_tags":[],"sources":[{"label":"FindAGrave — Caroline Elizabeth Reed Hobart","url":"https://www.findagrave.com/memorial/90952791/caroline_elizabeth-hobart"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"naming_inspiration":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"caroline-reed-1821"},"TD0133":{"id":"TD0133","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"display_name":"Timothy Dwight Hobart","first_name":"Timothy","middle_name":"Dwight","last_name":"Hobart","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777668714/timothyhobart_htssny.jpg","photo_notes":"Portrait. Cloudinary."},"birth":{"year":1855,"month":10,"day":6,"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"baptism":{},"death":{"year":1935,"month":5,"day":19,"city":"Pampa","county":"Gray","state":"Texas","country":"United States","cause":"pneumonia"},"residence":{"city":"Pampa","county":"Gray","state":"Texas","country":"United States","note":"Established Pampa headquarters 1903 from Mobeetie."},"burial":{"cemetery_id":"CEM179","plot_notes":"Fairview Cemetery, Pampa TX."},"gender":"male","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":9,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_id":"TD0129","mother_id":"X02370"},"marriages":[{"marriage_number":1,"spouse_id":"X02371","date_year":1888,"location_state":"Vermont","location_country":"United States","end_type":"death_of_self","end_year":1935,"children_ids":["TD0134","TD0135","TD0136","TD0137"]}],"number_of_marriages":1,"tags":["texas_migration"],"research_tags":[],"sources":[{"label":"Texas State Historical Association — Hobart, Timothy Dwight","url":"https://www.tshaonline.org/handbook/entries/hobart-timothy-dwight"},{"label":"FindAGrave — Timothy Dwight Hobart","url":"https://www.findagrave.com/memorial/27109842/timothy_dwight-hobart"},{"label":"Lester Fields Sheffy biography (1950)","note":"The Life and Times of Timothy Dwight Hobart, Panhandle-Plains Historical Society, Canyon TX 1950."}],"research_sources":[],"notable":{"is_notable":true,"notable_category":["business","public_service","history"],"notable_blurb":"Texas Panhandle rancher; founded Pampa Texas","primary_url":"https://www.tshaonline.org/handbook/entries/hobart-timothy-dwight","primary_url_label":"Texas State Historical Association"},"narrative_blocks":[{"number":1,"category":"career","header":"Surveyed a million Texas Panhandle acres","body":"Timothy moved from Vermont to Texas in 1882 at age 26 for the New York and Texas Land Company. After four years apprenticing under surveyor E. A."},{"number":2,"category":"public_service","header":"Founded Pampa Texas; elected mayor at seventy-one","body":"Pampa was founded in 1902 with Timothy as a leading figure. Twenty-five years later, in 1927, the town elected him mayor. He had also presided over the Panhandle-Plains Historical Society in the late 1920s and helped secure funding for the Panhandle-Plains Historical Museum, whose first unit was dedicated April 14, 1933 in Canyon Texas."},{"number":3,"category":"career","header":"Administered the JA Ranch — Goodnight's cattle empire","body":"From 1932 Timothy served as sole administrator of the JA Ranch — Charles Goodnight's pioneering 1876 cattle enterprise. He had served as executor of the Cornelia Adair estate since 1921. Twice president of the Texas and Southwestern Cattle Raisers Association, his Vermont schoolteacher beginnings ended in stewardship of one of the most storied ranches in the American West."},{"number":4,"category":"legacy","header":"Vermont son inscribed in Texas prairie","body":"His Pampa gravestone reads 'A PIONEER, LOVED AND RESPECTED BY ALL WHO KNEW HIM; WITH A CHARACTER STRONG AND RUGGED AS THE HILLS OF VERMONT FROM WHENCE HE CAME, AND A VISION AS BROAD AS THE TEXAS PRAIRIES.' He was the third Timothy Dwight Hobart in the family line — named for Yale's Timothy Dwight, the Hooker descendant, by way of his deceased uncle of the same name."}],"cross_connections":[{"type":"family_connection","related_id":"TD0163","display_label":"First cousins; Civil War Medal of Honor and Texas Speaker","link_text":"Ira Hobart Evans"},{"related_id":"H00914","relationship_type":"naming_pattern","description":"Likely named after the Pope Dwight Yale presidential lineage — given middle name 'Dwight' in 1855.","type":"family_connection","link_text":"Timothy Dwight"}],"naming_inspiration":[{"name_element":"Timothy Dwight","inspired_by_id":"H00914","description":"Carries forward through three generations the name of Yale's Timothy Dwight, the Yale president and Hooker descendant — the same name his uncle Timothy Dwight Hobart had carried (b.1826) before dying age twenty-seven, Dartmouth-bound for Andover."}],"education":[{"school_name":"Berlin VT public schools","type":"secondary","notes":"Local Berlin VT education before teaching career."}],"career":[{"role":"Superintendent of Schools","organization":"Berlin Vermont School District","end_year":1882,"notes":"Several years as Berlin VT schools superintendent before Texas migration."},{"role":"Surveyor (apprentice)","organization":"New York and Texas Land Company","location":"Texas","start_year":1882,"end_year":1886,"notes":"Four-year apprenticeship under E. A. Giraud surveying in Southwest Texas. Company owned 5 million acres scattered Brazoria to Panhandle."},{"role":"Land manager","organization":"New York and Texas Land Company","location":"Mobeetie, Texas","start_year":1886,"end_year":1903,"notes":"In charge of 1 million acres in Texas Panhandle (then open range). Headquarters Mobeetie. Surveyed, fenced, improved lands for leasing and subdividing among cattle companies."},{"role":"Land manager","organization":"White Deer Lands Trust Company","location":"Pampa (Gray County), Texas","start_year":1903,"end_year":1924,"notes":"After disposing of NY&T Land Co. lands. White Deer Trust bought 1,000 square miles from him in Carson, Gray, Roberts, and Hutchinson counties. Surveyed, fenced, and sold the White Deer lands until 1924 retirement."},{"role":"Executor / Administrator","organization":"Cornelia Adair estate / JA Ranch","location":"Texas Panhandle","start_year":1921,"end_year":1935,"notes":"Executor 1921; sole administrator JA Ranch from 1932. The JA Ranch was Charles Goodnight's pioneering 1876 enterprise."},{"role":"Mayor","organization":"City of Pampa","location":"Pampa, Texas","start_year":1927,"notes":"Elected mayor of city he had helped found in 1902."},{"role":"President","organization":"Panhandle-Plains Historical Society","location":"Canyon, Texas","notes":"Six years as president late 1920s and early 1930s. Helped secure funds for first unit of Panhandle-Plains Historical Museum dedicated April 14, 1933."},{"role":"President (twice)","organization":"Texas and Southwestern Cattle Raisers Association"}],"military_service":[],"institutions":[{"institution_id":"INST117"}],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"timothy-hobart-1855"},"X02371":{"id":"X02371","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"display_name":"Minnie Wood Warren Hobart","first_name":"Minnie","middle_name":"Wood","last_name":"Hobart","maiden_name":"Warren","married_names":["Hobart"],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777668758/minnehobart_cgluj8.jpg","photo_notes":"Portrait. Cloudinary."},"birth":{"year":1859,"month":12,"day":28,"city":"Berlin","county":"Washington","state":"Vermont","country":"United States"},"baptism":{},"death":{"yea