al Seminary thereafter, serving as Congregational pastor at Williston and Shoreham Vermont for twenty-four years. In 1857 he and Elizabeth removed to Whitewater Wisconsin, where he died May 3, 1863."},{"number":2,"category":"career","header":"Published history of Shoreham, Vermont, 1861","body":"Rev. Goodhue published 'History of the Town of Shoreham, Vermont, from the date of its charter, October 8th, 1761, to the present time' in 1861, printed by A.H. Copeland of Middlebury — a local history completed while he was still pastor at Shoreham. His middle name Fletcher derived from his mother's family: his mother was Elisabeth Fletcher Goodhue."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM559"},"residence":{"country":"United States"},"sources":[{"short":"EH 1909 #1416"}],"research_sources":[],"slug":"josiah-goodhue-1791"},"H01416":{"id":"H01416","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Elizabeth White Hooker","first_name":"Elizabeth","middle_name":"White","last_name":"Hooker","married_names":["Goodhue"]},"gender":"female","birth":{"year":1800,"month":7,"day":13,"city":"Rutland","county":"Rutland","state":"Vermont","country":"United States"},"death":{"year":1889,"month":1,"day":8,"city":"Whitewater","county":"Walworth","state":"Wisconsin","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"parents":{"father_id":"H00530","mother_id":"I01188"},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01189","date_year":1824,"date_month":6,"date_day":3,"end_type":"death","end_year":1889,"children_ids":["H02765","H02766","H02767","H02768","H02769"]}],"career":[],"education":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":["vermont_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Married a Congregational minister; moved Vermont to Wisconsin","body":"Elizabeth White Hooker married Rev. Josiah F. Goodhue in 1824 — a Middlebury College and Andover Theological Seminary graduate who served Congregational churches at Williston and Shoreham, Vermont, for twenty-four years. In 1857 they removed to Whitewater, Wisconsin, where he died in 1863 and she in January 1889 at eighty-eight."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM559"},"residence":{"country":"United States"},"sources":[{"short":"EH 1909 #1416"}],"research_sources":[],"slug":"elizabeth-hooker-1800"},"H00530":{"id":"H00530","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1770,"month":5,"day":20,"city":"Northampton","state":"Massachusetts","county":"Hampshire"},"death":{"year":1836,"month":4,"day":14,"city":"Rutland","county":"Rutland","state":"Vermont"},"parents":{"father_id":"H00264","mother_id":"I00043"},"tags":["merchant","vermont_migration"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 530"}],"gender":"male","marriages":[{"marriage_number":1,"spouse_id":"I01188","date_year":1796,"end_type":"death_of_spouse","end_year":1832,"children_ids":["H01416","H01417","H01418","H01419","H01420"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Thomas Hooker","first_name":"Thomas","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM553"},"career":[{"role":"Apothecary and Grocer","location":"Rutland, Rutland County, Vermont","end_year":1836,"notes":"Per EH 1909 #530: 'an apothecary and grocer at Rutland, Vt.'"}],"narrative_blocks":[{"number":1,"category":"career","header":"Apothecary and grocer at Rutland; wife predeceased him","body":"Thomas Hooker was an apothecary and grocer at Rutland, Vermont, where he spent his adult life and died in 1836 at sixty-five. His wife Sarah Brown died four years before him in 1832, predeceasing him despite being nine years younger."},{"number":2,"category":"marriage","header":"Married daughter of Col. John Brown of Pittsfield","body":"Sarah Brown's father, Colonel John Brown of Pittsfield, Massachusetts, is almost certainly the Revolutionary War officer killed at the Battle of Stone Arabia, New York, on October 19, 1780 — when Sarah was barely a year old. If confirmed, Thomas Hooker married the daughter of a Revolutionary War martyr."},{"number":3,"category":"family","header":"Twin sons: one to Boston missions","body":"John Worthington and Henry Brown Hooker were born the same day — August 31, 1802 — and their lives diverged completely: John moved to Chicago in 1836 among the city's earliest New England settlers, while Henry graduated Middlebury College, entered the ministry, and became Secretary of Missions at Boston."},{"number":4,"category":"family","header":"Two of five children died in Chicago","body":"John Worthington Hooker moved to Chicago in 1836 and died there in 1866; his sister Julia Ann married a Rutland lawyer and also died in Chicago in 1842. Two of Thomas Hooker's five children ended their days in the city that barely existed when they were born."}],"number_of_marriages":1,"slug":"thomas-hooker-1770"},"I01188":{"id":"I01188","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Sarah Brown Hooker","first_name":"Sarah","middle_name":"Brown","last_name":"Hooker","married_names":[]},"gender":"female","birth":{"year":1779,"city":"Pittsfield","county":"Berkshire","state":"Massachusetts","country":"United States"},"death":{"year":1832,"month":1,"day":11,"city":"Rutland","county":"Rutland","state":"Vermont","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"parents":{},"notable":{"is_notable":false,"notable_category":[]},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00530","date_year":1796,"end_type":"death","end_year":1832,"children_ids":["H01416","H01417","H01418","H01419","H01420"]}],"career":[],"education":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Probably daughter of a Revolutionary War martyr","body":"Sarah Brown's father, Colonel John Brown of Pittsfield Massachusetts named in the Hooker genealogy, is almost certainly the Revolutionary War officer killed at the Battle of Stone Arabia, New York, on October 19, 1780 — when Sarah was barely a year old. She married Thomas Hooker in 1796 and died at Rutland, Vermont, in 1832, four years before her husband."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM553"},"residence":{"country":"United States"},"sources":[{"short":"FindAGrave #43726558 + EH 1909 #530"}],"research_sources":[],"slug":"sarah-hooker-1779"}},"burialCemetery":{"id":"CEM559","name":"Oak Grove Cemetery","city":"Whitewater","county":"Walworth","state":"Wisconsin","country":"United States","primary_url":"https://www.findagrave.com/cemetery/88582/oak-grove-cemetery","hooker_connections":["H01416","I01189","H02766","H02768","H02769"