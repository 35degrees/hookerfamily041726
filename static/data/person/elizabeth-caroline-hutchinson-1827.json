ue,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["journalist","politician","abolitionist","author"],"notable_blurb":"Cleveland Leader editor 1854-1890; influential abolitionist Republican publisher","primary_url":"https://en.wikipedia.org/wiki/Edwin_Cowles","primary_url_label":"Wikipedia"},"parents":{"father_id":"H01141","mother_id":"I00396"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00413","date_year":1849,"date_month":5,"date_day":15,"location_country":"United States","children_ids":["HD3732","HD3733","HD3734","HD3735","HD3736","HD3737"]}],"education":[{"institution":"Grand River Institute","year":"1843","notes":"Brief period at Grand River Institute Austinburg 1843."}],"career":[{"title":"Printing apprentice","organization":"Cleveland Herald","dates":"1839-?","type":"journalism","notes":"Began trade at age 14 in 1839, mostly with Cleveland Herald."},{"title":"Co-founder, Smead & Cowles","organization":"Smead & Cowles printing","dates":"1845-1853","type":"business","notes":"Age 19 in 1845 began printing business as Smead & Cowles."},{"title":"Co-founder, Medill, Cowles & Co.","organization":"Forest City Democrat","dates":"1853-1854","type":"journalism","notes":"1853 partnership dissolved; new firm Medill, Cowles & Co., publishers of daily Forest City Democrat."},{"title":"Editor and proprietor, Cleveland Leader","organization":"Cleveland Leader","dates":"1854-1890","type":"journalism","notes":"1854 paper renamed Cleveland Leader. 1855 Vaugh + Joseph Medill sold their interests to Cowles and moved to Chicago to buy Tribune (Edwin's brother Alfred became Tribune business manager). Edwin sole proprietor + editor of Cleveland Leader to his death. 'A fearless and able journalist.'"},{"title":"Postmaster of Cleveland","organization":"U.S. Post Office","dates":"1861-1866","type":"government","notes":"Lincoln-appointed Postmaster of Cleveland 1861-66. Lincoln declined to remove him after his July 1861 anti-slavery editorial — saying 'he knew of no law which forbade postmasters a free expression of opinion.'"}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["journalist","abolitionist","politician","newspaper"],"research_tags":[],"cross_connections":[{"type":"civic_connection","related_id":"HD0337","display_label":"Ohio Republican Party founding-era figures — newspaper editor and lawyer-jurist.","link_text":"Alphonso Taft"},{"type":"naming_pattern","related_id":"HD3753","display_label":"Iwo Jima Major great-grandnephew named Edwin","link_text":"Rev. Edwin Hunt Badger Jr."},{"type":"naming_pattern","related_id":"HD3759","display_label":"Great-grandnephew carrying Cowles middle name","link_text":"Samuel Cowles Badger"}],"narrative_blocks":[{"number":1,"category":"politics","header":"Cleveland Leader as Republican Party origin claim","body":"In the winter of 1854-1855, Cowles, John C. Vaugh, and Joseph Medill drafted the call for the first national Republican convention from the editorial rooms of the Cleveland Leader. When Vaugh and Medill sold out and moved to Chicago later in 1855 to buy the Tribune, Edwin became sole proprietor of the Leader and made it one of the ablest advocates of Republican principles in Ohio."},{"number":2,"category":"politics","header":"Lincoln refused to remove him from postmastership","body":"Directly after the First Battle of Bull Run, Cowles wrote a Leader editorial titled 'Now's the time to abolish slavery as a war, as well as a moral measure.' Friends of the Administration urged President Lincoln to remove him from his Cleveland postmastership to placate the south, but Lincoln refused — saying he knew of no law which forbade postmasters a free expression of opinion."},{"number":3,"category":"family","header":"Inherited from his abolitionist great-uncle Samuel Cowles","body":"When Edwin's father Dr. Edwin Weed Cowles' older half-brother Samuel Cowles (1775-1837) — the Cleveland Court of Common Pleas judge and 1827 president of the Cuyahoga County Colonization Society — died childless in 1837, he left his estate to Edwin Weed's children. Edwin Cowles was four years old at the time and would build his own Cleveland legacy four decades later as Cleveland Leader founder."}],"quotes":[],"sources":[{"short":"Cowles Families in America #1719"},{"short":"History of Ashtabula Co., Ohio (biographical sketch + portrait)"},{"short":"National Cyclopedia"},{"short":"International Cyclopedia"},{"short":"Cleveland Weekly Leader and Herald, March 8, 1890"},{"short":"Wikipedia: Edwin Cowles","url":"https://en.wikipedia.org/wiki/Edwin_Cowles","accessed":"2026-05"}],"research_sources":[],"documents":[],"slug":"edwin-cowles-1825"},"HD3732":{"id":"HD3732","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Almira Foote","last_name":"Cowles","married_names":[],"gender":"female","display_name":"Almira Foote Cowles"},"birth":{"year":1850,"city":"Cleveland","county":"Cuyahoga County","state":"Ohio","country":"United States"},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD3711","father_name":"Edwin Cowles","mother_id":"I00413","mother_name":"Elizabeth Caroline Hutchinson Cowles"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming