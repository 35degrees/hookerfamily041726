ions":[],"narrative_blocks":[{"number":1,"category":"family","header":"Mother of Henry Merwin Blakeslee and Sophronia Stiles","body":"Julia Frost Blakeslee was daughter of Mabel Stiles Frost and Titus Frost of North Haven; she married Anson Blakeslee in 1810 and bore six children. Two of those children's marriages knit the Hooker descendants of the Isaac Stiles sister-branches back together: Sophronia wed Isaac Lorenzo Stiles, and Lavinia's son Anson later married Mary Cyrilla Stiles."}],"quotes":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry #1162"},{"short":"Frost Family genealogy","page":"BIB007"},{"short":"FamilySearch (LHX3-5BC)"}],"research_sources":[],"documents":[],"slug":"julia-blakeslee-1788"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}