y":[]},"parents":{"father_id":"I00531","mother_id":"H01162"},"number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"I00533","date_year":1837,"date_month":9,"date_day":17,"location_city":"North Haven","location_state":"Connecticut","location_country":"United States","officiant":"Rev. Mr. Griggs","end_type":"death_of_spouse","end_year":1876,"children_ids":["HD3950","HD3951","HD3952","HD3953"]},{"marriage_number":2,"spouse_id":"I00534","date_year":1878,"date_month":12,"date_day":7,"location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1909,"children_ids":[]}],"education":[],"career":[{"role":"Colonel","organization":"Connecticut Militia","location":"North Haven, Connecticut","notes":"Per Goodyear book #6852-1: 'Colonel Blakeslee was for many years an active and enthusiastic member of the Connecticut Militia.' Title 'Colonel' used throughout."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["extraordinary_longevity"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Polly died of grief weeks after daughter Harriet","body":"His daughter Harriet — 'an attractive and lovable girl' per the Goodyear book — died at age eighteen on 12 September 1876. His wife Polly Goodyear Blakeslee died less than two weeks later on 25 September 1876, attributed by the family record to grief."},{"number":2,"category":"death","header":"Polly's last words: dying bed soft as pillows","body":"The Goodyear book preserves Polly's last words: 'Jesus can make a dying bed feel soft as downy pillows are, while on his breast I'll lean my head, and breathe my life out sweetly there.' The lines come from an Isaac Watts hymn circulating widely in nineteenth-century New England."},{"number":3,"category":"marriage","header":"Second wife Cornelia was Polly's Bradley cousin","body":"Two years after Polly's death he married Cornelia Bronson Andrews on 7 December 1878. Cornelia and Polly were Bradley cousins — both great-granddaughters of Titus and Lydia Todd Bradley — making the second wife a documented blood relation of the first."},{"number":4,"category":"character","header":"Lived ninety-four years, Connecticut Militia Colonel","body":"Henry Merwin Blakeslee was born in Plymouth Connecticut on August 17, 1814 and died in North Haven on February 11, 1909, age ninety-four. He served many years in the Connecticut Militia and was widely known by the title Colonel; the Goodyear book noted he still led 'an energetic life in North Haven' in his eighties."}],"quotes":[],"sources":[{"label":"FindAGrave (Memorial 126682645)","url":"https://www.findagrave.com/memorial/126682645/henry_merwin-blakeslee"},{"label":"Goodyear book chapter #6852-1"}],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"slug":"henry-blakeslee-1814"},"I00533":{"id":"I00533","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Polly","last_name":"Blakeslee","maiden_name":"Goodyear","married_names":["Blakeslee"],"gender":"female","display_name":"Polly Goodyear Blakeslee","bio_blurb":"New Haven mother who died of grief"},"birth":{"year":1815,"month":11,"day":20,"city":"Hamden","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1876,"month":9,"day":25,"state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM293"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_research_notes":"Daughter of Andrew Goodyear (1784-1819) and Patty Bradley (1782-1821), both of Hamden CT (Goodyear book #6852). Andrew d. when Polly was age 4; Patty d. when Polly was age 6. After parents' deaths, Polly lived with her grandmother Bradley in North Haven. Mother Patty's line traces through Titus + Lydia (Todd) Bradley of N. Haven; same Bradley line as HMB's second wife Cornelia Bronson Andrews (I00534), so Polly and Cornelia are Bradley cousins. Goodyear line also produced significant Hooker connections elsewhere — Polly's brother William Bradley Goodyear m. Charlotte Frost (Hooker descendant via H00448 Mabel Stiles Frost). NOTE: This Goodyear line does NOT directly descend from Thomas Hooker; Polly is non-Hooker spouse to HMB."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3944","date_year":1837,"date_month":9,"date_day":17,"location_city":"North Haven","location_state":"Connecticut","location_country":"United States","officiant":"Rev. Mr. Griggs","end_type":"death","end_year":1876,"children_ids":["HD3950","HD3951","HD3952","HD3953"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"She died of grief days after her daughter","body":"When her eighteen-year-old daughter Harriet died in September 1876, she followed less than two weeks later; her family laid her death to grief. They lie together in the New Haven cemetery."},{"number":2,"category":"family","header":"Orphaned at six, raised by her grandmother","body":"Both her parents were dead before she turned six, and her Bradley grandmother in New Haven raised her. A family chronicle remembered her as firm and gentle at once, with an unshakable faith."},{"number":3,"category":"family","header":"Her brother founded Ogden, Utah","body":"One of her brothers, Miles Goodyear, became a Western trapper who founded what is now Ogden, Utah, and married a daughter of a Ute chief — a far cry from the New Haven world she kept to all her life."}],"quotes":[{"text":"Jesus can make a dying bed feel soft as downy pillows are, while on His breast I'll lean my head, and breathe my life out sweetly there.","source":"Reported as Polly Goodyear Blakeslee's last words in the Goodyear book #6852-1, drawn from Isaac Watts hymn 'Why should we start, and fear to die?'","context":"Deathbed September 1876"}],"sources":[{"label":"Goodyear book #6852-1 (Polly Goodyear Blakeslee chapter)"}],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"slug":"polly-goodyear-1815"},"I00531":{"id":"I00531","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Anson","last_name":"Blakeslee","married_names":[],"gender":"male","display_name":"Anson Blakeslee"},"birth":{"year":1783,"month":8,"day":28,"city":"North Haven","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1845,"month":10,"day":15,"city":"North Haven","county":"New Haven","state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM293"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_research_notes":"Son of Amos Blakeslee (1759-1827) and Eunice (Cooper) Blakeslee per Goodyear book. Both non-Hooker, not built. NOTE: Eunice Cooper — possibly related to Lois Cooper (I00524, HD3922 Isaac Stiles's wife, dau of Justus + Lois Cooper of N. Haven). Both Cooper families in N. Haven same era; relationship not documented in available source."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01162","date_year":1810,"location_city":"North Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1845,"children_ids":["HD3943","HD3944","HD394