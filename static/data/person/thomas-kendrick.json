"Ontario","country":"Canada"},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"generation_from_john_talcott":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["education"],"notable_blurb":"Dean of Bowdoin College for twenty years, 1947-1966","primary_url":"https://archivesspace.bowdoin.edu/repositories/2/resources/251","primary_url_label":"Bowdoin College Special Collections — Kendrick Papers"},"parents":{"father_id":"HD4668","mother_id":"I00944"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00946","date_year":1927,"location_country":"United States","children_ids":["HD4672","HD4673"]}],"education":[{"school_name":"University of Rochester","dates":"B.A. 1921","type":"undergraduate"},{"institution_id":"INST002","school_name":"Harvard University","dates":"Ph.D. 1930","type":"doctorate","notes":"Studied at London and Vienna on traveling fellowship 1925-26."}],"career":[{"role":"Instructor/Professor of History","organization":"Bowdoin College, Brunswick, Maine","start_year":1926,"end_year":1966,"notes":"Joined as instructor 1926; assistant professor 1928; associate professor 1932; full professor 1946; acting dean 1946; Dean 1947-1966; Frank Munsey Professor of History Emeritus 1959. Honorary doctorate of humane letters 1966."}],"military_service":[],"institutions":[{"institution_id":"INST020","relationship":"alumnus","years":"B.A. 1921","institution_blurb":"Graduated University of Rochester 1921, the institution his grandfather Asahel Clark Kendrick had helped found in 1850."},{"institution_id":"INST130","relationship":"faculty","years":"1926-1966","institution_blurb":"Dean of Bowdoin College 1947-1966; Frank Munsey Professor of History Emeritus; papers held at Bowdoin Special Collections M101."},{"institution_id":"INST002","relationship":"alumnus"}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["educator","academic"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Dean of Bowdoin College for twenty years","body":"Nathaniel Cooper Kendrick served as dean of Bowdoin College from 1947 to 1966 — twenty years — having joined the Bowdoin history faculty in 1926 after completing his PhD at Harvard and being named the Frank Munsey Professor of History Emeritus in 1959, making him one of the longest-serving academic administrators in Bowdoin's history. His grandfather Asahel Clark Kendrick had been among the founding faculty of the University of Rochester a century earlier, making this the third generation of the Hooker-Kendrick line to hold a distinguished academic chair."},{"number":2,"category":"education","header":"Took his doctorate at Harvard before leading Bowdoin","body":"Nathaniel Cooper Kendrick earned his doctorate at Harvard University in 1930 — having completed his bachelor's at the University of Rochester, where his grandfather had taught Greek for thirty-eight years — and spent his entire career at Bowdoin College, rising from instructor in 1926 to dean of the college in 1947, a position he held for twenty years. His papers, held at the Bowdoin College Special Collections (M101), document his tenure across the Depression, World War II, and the postwar reshaping of liberal arts education."}],"quotes":[],"sources":[{"label":"FindAGrave","url":"https://www.findagrave.com"},{"label":"Bowdoin College Special Collections — Nathaniel Cooper Kendrick Papers (M101)","url":"https://archivesspace.bowdoin.edu/repositories/2/resources/251"}],"research_sources":[],"documents":[],"slug":"nathaniel-kendrick-1900"},"I00946":{"id":"I00946","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Lucy","middle_name"