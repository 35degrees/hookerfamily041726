rch_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"I01303","date_year":1885,"date_month":6,"date_day":2,"location_city":"Manhattan","location_state":"New York","location_country":"United States","end_type":"death","end_year":1905,"children_ids":["HD5132","HD5133","HD5134"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1843,"month":1,"day":15,"city":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1905,"month":1,"day":8,"city":"Manhattan","state":"New York","country":"United States","age":61},"residence":{},"burial":{"plot_notes":"Green-Wood Cemetery, Greenwood Heights Brooklyn NY"},"baptism":{},"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"NYC judge continuing Ingersoll legal tradition","body":"Charles Dennis Ingersoll continued the Ingersoll family legal tradition across the New York and Connecticut bars — making him the fourth consecutive generation of Ingersoll lawyers and judges descending from Rev. Jonathan Ingersoll. His grandfather Jonathan Ingersoll Jr. was Lieutenant Governor of Connecticut; his father Charles Anthony Ingersoll was a US federal judge; his uncle Ralph Isaacs Ingersoll was a US Congressman and Minister to Russia; his cousin Charles Roberts Ingersoll became Governor of Connecticut. The Ingersoll legal dynasty spanned 1747-1905 (Rev. Jonathan to Charles Dennis) across five generations."},{"number":2,"category":"family","header":"Married widow Katharine Sanders Varnum, 1885","body":"Charles Dennis married Katharine Corse Sanders Varnum on June 2, 1885 in Manhattan New York — she had previously been married to Robert Taylor Varnum. The couple had three children together: Hamilton Ingersoll (1888-1940), Anita Ingersoll Gwynne (1891-1970), and Justine Ingersoll Arnold (1893-1984). His grandchildren through these three children form the documented twentieth-century Ingersoll-Arnold-Gwynne descendants of the original Connecticut bar family."},{"number":3,"category":"family","header":"New Haven 1843 to Manhattan 1905, Green-Wood Cemetery","body":"Charles Dennis Ingersoll was born January 15, 1843 in New Haven Connecticut and died January 8, 1905 in Manhattan New York at age sixty-one. He is buried at Green-Wood Cemetery in Greenwood Heights Brooklyn New York — breaking the Ingersoll family Grove Street Cemetery tradition through his NYC career. His wife Katharine died in Menton France in 1922."}],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Judge Charles Dennis Ingersoll","first_name":"Charles","last_name":"Ingersoll","middle_name":"Dennis","married_names":[],"title":"Judge","gender":"male"},"slug":"charles-ingersoll-1843"},"I01303":{"id":"I01303","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker_bool":false},"parents":{},"tags":[],"research_tags":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"HD5129","date_year":1885,"date_month":6,"date_day":2,"location_city":"Manhattan","location_state":"New York","location_country":"United States","end_type":"death","end_year":1905,"children_ids":["HD5132","HD5133","HD5134"]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1861,"month":10,"day":29,"city":"Long Island","state":"New York","country":"United States"},"death":{"year":1922,"month":2,"day":13,"city":"Menton","country":"France","age":60},"residence":{},"burial":{},"baptism":{},"cross_connections":[],"narrative_blocks":[],"quotes":[],"do