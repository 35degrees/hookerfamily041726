is_notable":true,"notable_category":["civic_service"],"notable_blurb":"Bridgeport founder, physician, turnpike company founder"},"narrative_blocks":[{"header":"Co-founder of the Borough of Bridgeport","detail":"His estate was distributed in 1805 to his widow Sarah and their children. A note in the research suggests a John Cannon (possibly his son) founded the Bridgeport Bank in 1806 and served as its president from 1823 until 1827 — the probate timeline makes it likely this was the son John Jr. (HD2793) rather than the physician himself. In the 1790 US Census, one enslaved person was enumerated in his household. His daughter Antoinette married U.S. Senator Thaddeus Betts; his daughter Sarah married back into the St. John family. (St. John Genealogy; Bridgeport historical records)","body":"John Cannon Jr. moved from Norwalk to Bridgeport (then called Newfield) around 1790. He was involved in founding the Newfield Fire Company (1796), helped incorporate the Borough of Bridgeport (1800), and founded the Bridgeport & Newtown Turnpike Company (1801). With William Peet he ran a saddlery business as Cannon & Peet.","number":1,"category":"character"},{"number":2,"category":"business","header":"A saddler among Bridgeport’s founders","body":"With the tanner William Peet he ran the saddlery firm Cannon & Peet on Broad Street, then helped raise the subscription that bought Newfield its first fire engine in 1796 — fifteen dollars of his own among the names. He died in office as president of the Bridgeport Bank."},{"number":3,"category":"social_reform","header":"One enslaved person in his household","body":"The 1790 census enumerated one enslaved person in his Norwalk household; later Bridgeport records name a man, Cato Cannon, among those he held. The turnpike-builder and bank president was, like many Connecticut founders of his day, a slaveholder."}],"cross_connections":[{"type":"family_connection","related_id":"X02364","display_label":"shares a Peet family tie worth tracing","link_text":"William Creighton Peet Jr."}],"bio":{"display_name":"Doctor John Cannon Jr.","first_name":"John","last_name":"Cannon","title":"Doctor","married_names":[],"suffix":"Jr.","bio_blurb":"Physician and co-founder of Bridgeport"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Physician","location":"Norwalk, then Bridgeport"},{"role":"Saddler","organization":"Cannon & Peet","notes":"tannery on Broad Street, Bridgeport"},{"role":"President","organization":"Bridgeport Bank","start_year":1823,"end_year":1827},{"role":"Co-founder","organization":"Borough of Bridgeport","start_year":1800},{"role":"Founder","organization":"Bridgeport & Newtown Turnpike Co.","start_year":1801}],"slug":"john-cannon-jr-1752"},"HD2793":{"id":"HD2793","has_descendants_documented":false,"is_placeholder":false,"gender":"male","classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1778,"month":5,"day":16},"death":{},"parents":{"father_id":"X01911","mother_id":"H01237"},"marriages":[],"tags":[],"sources":[{"short":"St. John Genealogy"}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"John Cannon","first_name":"John","last_name":"Cannon","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-cannon-1778"},"HD2794":{"id":"HD2794","has_descendants_documented":false,"is_placeholder":false,"gender":"female","classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_