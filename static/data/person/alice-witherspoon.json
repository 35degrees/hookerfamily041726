":[],"sources":[],"research_sources":[],"marriages":[{"marriage_number":1,"spouse_id":"I01312","date_year":1891,"date_month":11,"date_day":3,"location_city":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1927,"children_ids":["HD5143","HD5144"]}],"number_of_marriages":1,"notable":{"is_notable":true,"notable_blurb":"US Minister to Siam under Wilson; Trinity College + Yale Law","notable_category":["politics","law"],"primary_url":"https://en.wikipedia.org/wiki/George_Pratt_Ingersoll","primary_url_label":"Wikipedia"},"birth":{"year":1861,"month":4,"day":24,"city":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1927,"month":2,"day":24,"city":"Stamford","state":"Connecticut","country":"United States","age":65,"cause":"illness (two months)"},"residence":{},"burial":{"plot_notes":"Fairlawn Cemetery, Ridgefield CT (one of four incorporators of the cemetery 1908)"},"baptism":{},"cross_connections":[{"type":"civic_peer","related_id":"HD2659","display_label":"New Haven law firm founder, lifelong family friend","link_text":"Louis H. Bristol","notes":"Both at New Haven bar 1885-1910. Louis was Charles R. Ingersoll's lifelong friend; George Pratt was Charles R.'s nephew (son of Colin M.). Family-anchored bar peers across two generations."}],"narrative_blocks":[{"number":1,"category":"politics","header":"US Minister to Siam under Wilson, 1917-1918","body":"In August 1917 President Woodrow Wilson selected George Pratt Ingersoll as US Envoy Extraordinary and Minister Plenipotentiary to Siam (now Thailand) — serving August 8, 1917 to June 23, 1918 during WWI. He had retired from law practice earlier in 1917 to focus on public service. Three generations of Ingersolls held principal US diplomatic posts: grandfather Ralph (Minister to Russia 1846-48), father Colin M. (Secretary of legation St Petersburg 1847-48), George Pratt (Minister to Siam 1917-18)."},{"number":2,"category":"politics","header":"Vice Chair National Democratic Committee, 1914","body":"George Pratt Ingersoll served as Vice Chair of the National Democratic Committee in 1914 — the party leadership role during President Wilson's first term. The same year he was appointed prosecuting attorney for Fairfield County Connecticut. In 1910 he had been an unsuccessful Democratic candidate for the US House of Representatives from Connecticut, and later declined to run for the United States Senate."},{"number":3,"category":"family","header":"Married Alice Witherspoon, John Witherspoon descendant","body":"On November 3, 1891 at Trinity Church New Haven, George married Alice Witherspoon — daughter of Rev. Orlando Witherspoon of Buffalo NY and a documented descendant of founding father JOHN WITHERSPOON (signer of the Declaration of Independence). The marriage connected the Ingersoll family directly to one of the principal American founding lineages. The couple had two children: Collin M. and Gertrude M."},{"number":4,"category":"career","header":"Yale Law 1885, three-state practice, trust estates specialty","body":"George earned his Trinity College BA in 1883, Yale Law School LLB in 1885, and Trinity MA in 1885 — admitted to the Connecticut and New York bars the same year, with a legal specialty in trust estates. He practiced across three CT/NY firms: Murray Ingersoll Hodge & Humphrey (22 William Street NYC), Tyler Ingersoll & Morgan (New Haven), and Cummings & Lockwood (Stamford from October 1914). He served as US Commissioner for Connecticut from 1889."},{"number":5,"category":"family","header":"Born 1861 New Haven, buried Fairlawn Ridgefield","body":"George Pratt Ingersoll was born April 24, 1861 in New Haven Connecticut and died February 24, 1927 at Stamford Hospital after two months of illness at age sixty-five. He is buried at Fairlawn Cemetery Ridgefield Connecticut — one of the four original incorporators of the cemetery on October 30, 1908. His residence was 67 Glenbrook Road Stamford, with a summer home in Ridgefield called Ingleside."}],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST001","role":"student","notes":"Hopkins Grammar School preparatory training"},{"institution_id":"INST022","role":"student","notes":"Yale Law LLB 1885"},{"institution_id":"INST076","role":"student","notes":"Trinity College BA 1883 + MA 1885; Delta Psi fraternity"},{"institution_id":"INST155","role":"student","notes":"Yale Law LLB 1885"}],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"George Pratt Ingersoll","first_name":"George","last_name":"Ingersoll","middle_name":"Pratt","married_names":[],"gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779825755/George_Pratt_Ingersoll_rj2hkp.jpg"},"slug":"george-ingersoll-1861"},"HD5143":{"id":"HD5143","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"is_progenitor":false,"is_easter_egg":false,"descent_paths_to_thomas":1,"descent_from_thomas_hooker_bool":true},"parents":{"father_id":"HD5141","mother_id":"I01312"},"tags":[],"research_tags":[],"sources":[],"research_sources":[],"marriages":[],"number_of_marriages":0,"notable":{"is_notable":false,"notable_category":[]},"birth":{},"death":{},"residence":{},"burial":{},"baptism":{},"cross_connections":[],"narrative_blocks":[],"quotes":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"military_service":[],"education":[],"career":[],"bio":{"display_name":"Collin Macrae Ingersoll","first_name":"Collin","last_name":"Ingersoll","middle_name":"Macrae","married_names":[],"gender":"male"},"slug":"collin-ingersoll"},"HD5144":{"id":"HD5144","former_ids":[],"is_place