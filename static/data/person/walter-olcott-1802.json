uto-qualify under Jalapeño Rule. Per EH 1909 entry 310 narrative."},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Rev. Allen Olcott","first_name":"Allen","last_name":"Olcott","title":"Reverend","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"allen-olcott-1746"},"H00310":{"id":"H00310","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1760,"city":"Farmington","state":"Connecticut"},"parents":{"father_id":"H00104","mother_id":"I00136"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 310"}],"death":{"year":1827,"month":6,"day":27,"city":"Bolton","state":"Connecticut"},"burial":{"plot_notes":"Bolton Center Cemetery, Bolton, Tolland County, Connecticut. Cenotaphic inscription also on Olcott family monument in West Cemetery, Manchester CT."},"marriages":[{"spouse_id":"X00271","children_ids":["H00704","H00705","H00706","H00707","H00708"],"marriage_number":1,"end_type":"death_of_spouse","end_year":1811,"date_year":1792,"date_month":6,"date_day":11,"location_city":"East Hartford","location_state":"Connecticut"},{"spouse_id":"X00272","marriage_number":2,"children_ids":[],"end_type":"death_of_self","end_year":1827,"date_year":1813,"date_month":1,"date_day":14,"location_city":"East Hartford","location_state":"Connecticut"}],"gender":"female","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Cynthia Hooker","first_name":"Cynthia","maiden_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married a Yale-educated 'quaint and erratic' preacher","body":"Cynthia married Rev. Allen Olcott in 1792 — a Yale College 1768 graduate settled at the Farmington Presbyterian Church in 1787. After four years his preaching was deemed 'quaint and erratic' enough that he was dismissed and never settled at any other church."},{"number":2,"category":"family","header":"Settled with Allen on a South Manchester farm","body":"After his Farmington dismissal Allen returned to his native East Hartford and then settled with Cynthia on a farm at South Manchester, Connecticut. Family stories suggest his farming methods were as unique as his preaching had been. He died there in April 1811, leaving Cynthia a widow with five children ranging from eight to eighteen."},{"number":3,"category":"family","header":"Remarried Capt. Samuel Alvord at fifty-three","body":"Two years after Allen's death Cynthia remarried — Capt. Samuel Alvord of East Hartford, on 14 January 1813. The couple lived at East Hartford until her own death in June 1827. Through her first marriage's daughter Cynthia, her line married back into the Talcott-Hooker convergence."}],"slug":"cynthia-hooker-1760"},"H00104":{"id":"H00104","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1710,"month":9,"day":17,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1774,"month":5,"day":25,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00030","mother_id":"I00031"},"tags":["compiler_ancestor"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 104"}],"cross_connections":[],"burial":{"cemetery_id":"CEM004"},"marriages":[{"marriage_number":1,"spouse_id":"I00135","date_year":1740,"date_month":1,"date_day":29,"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1745,"children_ids":["H00301","H00302","H00303"]},{"marriage_number":2,"spouse_id":"I00136","date_year":1747,"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1774,"children_ids":["H00304","H00305","H00306","H00307","H00308","H00309","H00310"]}],"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"character","header":"He kept the Hooker Elm's famous hospitality alive","body":"He inherited the Farmington estate and the famous Hooker Elm from his father John. EH described him as 'a thorough gentleman of the old school' who continued the famed hospitality of the elm gatherings."},{"number":2,"category":"family","header":"Favorite son and keeper of family history","body":"He accompanied his father John on official journeys around the Colony and brought his first wife to live in the family house. EH wrote that he received from his father full information about the family's English origins — and that his father was the best informed of all Thomas Hooker's grandsons on the subject."},{"number":3,"category":"family","header":"Three sisters married Hart brothers — knot tied","body":"His sisters Abigail, Mary, and Sarah each married a son of Capt. John Hart between 1719 and 1725. Through those three marriages, Roger found himself simultaneously brother-in-law to Nathaniel, Samuel, and Matthew Hart — the Hart and Hooker families fully intertwined."},{"number":4,"category":"family","header":"His granddaughter Abigail married Samuel Talcott","body":"His son Thomas Hooker fathered Abigail Hooker, who married Samuel Talcott of Hartford. The marriage merged the Hooker surname into the Talcott line — a transition that defines several gen 6+ branches."}],"bio":{"display_name":"Roger Hooker","first_name":"Roger","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"roger-hooker-1710"},"I00136":{"id":"I00136","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1720,"month":2,"day":19,"city":"Newington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1797,"month":2,"day":17,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"mother_research_notes":"Dorothy Chester","father_research_notes":"Capt. Martin Kellogg of Newington, Connecticut"},"marriages":[{"marriage_number":1,"spouse_id":"H00104","date_year":1747,"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1774,"children_ids":["H00304","H00305","H00306","H00307","H00308","H00309","H00310"]}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 104"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Anna Kellogg Hooker","first_name":"Anna","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Kellogg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"