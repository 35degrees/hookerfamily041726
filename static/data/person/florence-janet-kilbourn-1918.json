es.cloudinary.com/dc5clrqtw/image/upload/v1781539535/jkil_deykkz.png","bio_blurb":"Connecticut banker turned Pueblo, Colorado financier"},"birth":{"year":1843,"date_precision":"exact","month":8,"day":22,"city":"Middletown","state":"Connecticut","country":"United States"},"death":{"year":1915,"date_precision":"exact","month":5,"day":21,"city":"Pueblo","state":"Colorado","country":"United States"},"parents":{"father_id":"I01791","mother_id":"HD6423"},"marriages":[{"spouse_id":"I01792","marriage_number":1,"date_year":1873,"date_month":9,"date_day":4,"children_ids":["HD6463","HD6464","HD6465"]}],"tags":[],"narrative_blocks":[{"number":1,"category":"career","header":"A presidential appointment in the West","body":"After two decades in Middletown banking, Jonathan Burwell Kilbourn followed his health to Colorado in 1880 and rose through Pueblo’s First National Bank. In 1885 President Grover Cleveland appointed him receiver of public moneys at the Pueblo Land Office, a post he held until 1890."},{"number":2,"category":"family","header":"He married a famous inventor’s granddaughter","body":"In 1873 Kilbourn married Mary Adeline Douglas, granddaughter of the noted inventor William Douglas of Middletown, whose “Douglas Pump” was sold worldwide. Ironically, it was as a traveling salesman for the Douglas Pump company that Kilbourn first came west."},{"number":3,"category":"career","header":"He saw a savings bank swell by millions","body":"Before going west, Kilbourn rose from teller to treasurer of the Middletown Savings Bank across the 1870s, a period in which its deposits increased by several millions. He had begun his working life as purser aboard the steamship Liberty, running between New York and Havana."},{"number":4,"category":"character","header":"A churchman who built a mansion out West","body":"An elder and former treasurer of Pueblo’s First Presbyterian Church, Kilbourn built a prominent 1896 mansion where the family lived with domestic staff. His business reach extended to mining ventures across Nevada, California, and Colorado and a real-estate and loan agency."}],"career":[{"role":"Purser","organization":"Steamship Liberty (New York–Havana)","start_year":1864,"end_year":1865},{"role":"Clerk","organization":"Russell Manufacturing Co., Middletown","start_year":1865,"end_year":1870},{"role":"Teller, asst. secretary, treasurer","organization":"Middletown Savings Bank","start_year":1870,"end_year":1879},{"role":"Teller, assistant cashier","organization":"First National Bank, Pueblo","start_year":1881,"end_year":1884},{"role":"Receiver of Public Moneys","organization":"U.S. Land Office, Pueblo (appt. Pres. Cleveland)","start_year":1885,"end_year":1890},{"role":"Treasurer","organization":"Pueblo City Schools","start_year":1884,"end_year":null}],"education":[{"institution_name":"Daniel H. Chase’s Private School","relationship":"student","degree":"Preparatory"},{"institution_name":"Wesleyan University","relationship":"student","years":"to junior year","degree":"Left during junior year"}],"slug":"jonathan-burwell-kilbourn-1843"},"I01792":{"id":"I01792","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":null},"bio":{"display_name":"Mary Adeline Douglas Kilbourn","first_name":"Mary Adeline","last_name":"Kilbourn","married_names":[],"maiden_name":"Douglas","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781539407/copy_of_screenshot_2026-06-15_at_90241_am_yjh1g1.png"},"birth":{"year":1850,"date_precision":"year_only"},"death":{"year":1933,"date_precision":"exact"},"parents":{"father_id":null,"mother_id":null},"marriages":[{"spouse_id":"HD6462","marriage_number":1,"date_year":1873,"children_ids":["HD6463","HD6464","HD6465"]}],"tags":[],"slug":"mary-adeline-douglas-1850"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}