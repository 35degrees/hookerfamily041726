15","date_year":1864,"end_type":"death_of_spouse","end_year":1877,"children_ids":["HD3975","HD3917"]}],"education":[],"career":[],"military_service":[{"war":"American Civil War","war_id":"WAR006","unit":"Second Regiment, Connecticut Volunteers ('the Grays'), company of Maj. C. E. Walter Osborn","notes":"Served with the Grays in General Terry's Second Regiment. Later attempted Navy enlistment but rejected (lost portion of one finger). Sutler at Grapevine Point conscript camp."}],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["civil_war"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"military","header":"Rode horse Atlantic-to-Pacific to the gold rush, 1852","body":"Twenty-one years old, he started overland for California in 1852 and made the entire trip from Atlantic to Pacific on horseback, staying eight years through the gold rush. He later surveyed the California-Mexico boundary for the federal government before returning to Connecticut to serve in General Terry's Second Regiment during the Civil War."},{"category":"military","header":"Lost finger barred him from Navy enlistment","body":"After returning from California he served in the Civil War with General Terry's Second Regiment 'Grays' under Major C E Walter Osborn. Later he tried to enlist in the Navy but was rejected — he had lost part of one finger somewhere along the way.","number":2},{"category":"religion","header":"Sang choir thirty years, retired weeks before death","body":"He sang in the choir of Second Congregational Church in Fair Haven Connecticut for nearly thirty years. He retired from the choir only weeks before his death from Bright's disease in June 1881 at age fifty.","number":3},{"category":"career","header":"Surveyed California-Mexico boundary for federal government","body":"During his eight California years he studied engineering and surveyed the California-Mexico boundary for the federal government. The skills he acquired in the gold-rush camps later carried into his Connecticut civic and political work in East Haven.","number":4}],"quotes":[],"sources":[{"label":"FindAGrave (Memorial 16981280, Central Burying Grounds)","url":"https://www.findagrave.com/memorial/16981280/william_eliot-goodyear"},{"label":"New Haven obituary, June 18, 1881"}],"research_sources":[],"documents":[],"slug":"william-goodyear-1831"},"HD3915":{"id":"HD3915","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Miles","middle_name":"Herschel","last_name":"Goodyear","married_names":[],"gender":"male","display_name":"Miles Herschel Goodyear"},"birth":{"year":1839,"month":6,"day":17,"state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1910,"month":7,"day":25,"state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM289"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00514","mother_id":"HD3913"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00516","end_type":"death_of_spouse","end_year":1883,"children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"FindAGrave (Memorial 16981293, Central Burying Grounds)","url":"https://www.findagrave.com/memorial/16981293/miles_herschel-goodyear"}],"research_sources":[],"documents":[],"slug":"miles-goodyear-1839"},"HD3916":{"id":"HD3916","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Lizzie","middle_