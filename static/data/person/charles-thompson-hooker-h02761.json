treat them."},{"number":3,"category":"legacy","header":"First of three consecutive Harvard physician generations, 1822","body":"Dr. Anson Hooker graduated Harvard Medical School in 1822 and built a Cambridge practice that his son Anson Parker inherited after Harvard M.D. 1855, and his grandson Edward Dwight carried on after Harvard M.D. 1884. Three consecutive Hooker physicians trained at Harvard across sixty-two years."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"anson-hooker-1799"},"I01161":{"id":"I01161","is_placeholder":false,"former_ids":[],"bio":{"display_name":"Anna Wright Parker Hooker","first_name":"Anna","middle_name":"Wright","last_name":"Hooker","maiden_name":"Parker","married_names":["Hooker"]},"gender":"female","birth":{"year":1813,"month":4,"day":6,"city":"Westford","county":"Middlesex","state":"Massachusetts","country":"United States"},"death":{"year":1891,"month":5,"day":2,"city":"Arlington","county":"Middlesex","state":"Massachusetts","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"is_easter_egg":false},"parents":{"father_research_notes":"Per EH 1909 #1414: 'Anna Wright of Cambridge, Mass.'"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01414","location_state":"Massachusetts","location_country":"United States","end_type":"death","children_ids":["H02761","H02762"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"documents":[],"naming_inspiration":[],"burial":{"cemetery_id":"CEM549"},"residence":{"state":"Massachusetts","country":"United States"},"notable":{"is_notable":false,"notable_category":[]},"sources":[{"short":"Edward Hooker 1909","page":"Entry 1414"}],"research_sources":[],"slug":"anna-parker-1813"},"