table":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3951","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1902,"children_ids":["HD3958"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"FindAGrave (Memorial 126898281, New Center Cemetery)","url":"https://www.findagrave.com/memorial/126898281/julian_w-tuttle"}],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"slug":"julian-tuttle-1836"},"HD3951":{"id":"HD3951","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Charlotte","middle_name":"E.","last_name":"Tuttle","maiden_name":"Blakeslee","married_names":["Tuttle"],"nickname":"Lottie","gender":"female","display_name":"Charlotte E. Blakeslee Tuttle"},"birth":{"year":1844,"month":4,"day":17,"state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1902,"month":3,"day":19,"city":"North Haven","county":"New Haven","state":"Connecticut","country":"United States"},"residence":{"city":"North Haven","state":"Connecticut","country":"United States"},"burial":{"cemetery_id":"CEM293"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD3944","mother_id":"I00533"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00536","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1902,"children_ids":["HD3958"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Only daughter Stella died at age thirty-one","body":"Lottie's only documented daughter Stella Tuttle (born August 17, 1863) died November 1, 1894 at age thirty-one — predeceasing her mother by seven and a half years. Stella had married Fred A. Warner on January 27, 1887 and they had one son, Leonard B. Warner (born May 14, 1889). The single-generation maternal-line continuation through Leonard was all that survived from Lottie's marriage to Julian Tuttle."},{"number":2,"category":"family","header":"Lottie was the nickname used in family records","body":"Charlotte E. Blakeslee was known throughout family records as 'Lottie' — the standard nineteenth-century diminutive of Charlotte. She married Julian W. Tuttle of North Haven Connecticut, who was born April 16, 1836 and died April 10, 1907 — slightly outliving Lottie."},{"number":3,"category":"family","header":"Born Connecticut 1844, died North Haven 1902","body":"Charlotte E. Blakeslee was born April 17, 1844 in Connecticut and died March 19, 1902 in North Haven Connecticut at age fifty-seven. She is buried at New Center Cemetery. Daughter of Colonel Henry Merwin Blakeslee and Polly Goodyear Blakeslee."}],"quotes":[],"sources":[{"label":"FindAGrave (Memorial 126898312)","url":"https://www.findagrave.com/memorial/126898312/charlotte_e-tuttle"},{"label":"Goodyear book #6852-1"}],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"slug":"charlotte-tuttle-1844"},"HD3944":{"id":"HD3944","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"title":"Colonel","first_name":"Henry","middle_name":"Merwin","last_name":"Blakeslee","married_names":[],"gender":"male","display_name":"Colonel Henry Merwin Blakeslee","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778521891/henryblakeslee-resized_mpoaav.png"},"birth":{"year":1814,"month":8,"day":17,"city":"Plymouth","county":"Litchfield","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1909,"month":2,"day":11},"residence":{},"burial":{"cemetery_id":"CEM293"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":8,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00531","mother_id":"H01162"},"number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"I00533","date_year":1837,"date_month":9,"date_day":17,"location_city":"North Haven","location_state":"Connecticut","location_country":"United States","officiant":"Rev. Mr. Griggs","end_type":"death_of_spouse","end_year":1876,"children_ids":["HD3950","HD3951","HD3952","HD3953"]},{"marriage_number":2,"spouse_id":"I00534","date_year":1878,"date_month":12,"date_day":7,"location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1909,"children_ids":[]}],"education":[],"career":[{"role":"Colonel","organization":"Connecticut Militia","location":"North Haven, Connecticut","notes":"Per Goodyear book #6852-1: 'Colonel Blakeslee was for many years an active and enthusiastic member of the Connecticut Militia.' Title 'Colonel' used throughout."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["extraordinary_longevity"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Polly died of grief weeks after daughter Harriet","body":"His daughter Harriet — 'an attractive and lovable girl' per the Goodyear book — died at age eighteen on 12 September 1876. His wife Polly Goodyear Blakeslee died less than two weeks later on 25 September 1876, attributed by the family record to grief."},{"number":2,"category":"death","header":"Polly's last words: dying bed soft as pillows","body":"The Goodyear book preserves Polly's last words: 'Jesus can make a dying bed feel soft as downy pillows are, while on his breast I'll lean my head, and breathe my life out sweetly there.' The lines come from an Isaac Watts hymn circulating widely in nineteenth-century New England."},{"number":3,"category":"marriage","header":"Second wife Cornelia was Polly's Bradley cousin","body":"Two years after Polly's death he married Cornelia Bronson Andrews on 7 December 1878. Cornelia and Polly were Bradley cousins — both great-granddaughters of Titus and Lydia Todd Bradley — making the second wife a documented blood relation of the first."},{"number":4,"category":"character","header":"Lived ninety-four years, Connecticut Militia Colonel","body":"Henry Merwin Blakeslee was born in Plymouth Connecticut on August 17, 1814 and died in North Haven on February 11, 1909, age ninety-four. He served many years in the Connecticut Militia and was widely known by the title Colonel; the Goodyear book noted he still led 'an energetic life in North Haven' in his eighties."}],"quotes":[],"sources":[{"label":"FindAGrave (Memorial 126682645)","url":"https://www.findagrave.com/memorial/126682645/henry_merwin-blakeslee"},{"label":"Goodyear book chapter #6852-1"}],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"slug":"henry-blakeslee-1814"},"I00533":{"id":"I00533","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Polly","last_name":"Blakeslee","maiden_name":"Goodyear","married_names":["Blakeslee"],"gender":"female","display_name":"Polly Goodyear Blakeslee","bio_blurb":"New Haven mother who died of grief"},"birth":{"year":1815,"month":11,"day":20,"city":"Hamden","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1876,"month":9,"day":25,"state":"Connecticut","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM293"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_research_notes":"Daughter of Andrew Goodyear (1784-1819) and Patty Bradley (1782-1821), both of Hamden CT (Goodyear book #6852). Andrew d. when Polly was age 4; Patty d. when Polly was age 6. After parents' deaths, Polly lived with her grandmother Bradley in North Haven. Mother Patty's line traces through Titus + Lydia (Todd) Bradley of N. Haven; same Bradley line as HMB's second wife Cornelia Bronson Andrews (I00534), so Polly and Cornelia are Bradley cousins. Goodyear line also produced significant Hooker connections elsewhere — Polly's brother William Bradley Goodyear m. Charlotte Frost (Hooker descendant via H00448 Mabel Stiles Frost). NOTE: This Goodyear line does NOT directly descend from Thomas Hooker; Polly is non-Hooker spouse to HMB."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD3944","date_year":1837,"date_month":9,"date_day":17,"location_city":"North Haven","location_state":"Connecticut","location_country":"United States","officiant":"Rev. Mr. Griggs","end_type":"death","end_year":1876,"children_ids":["HD3950","HD3951","HD3952","HD3953"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"She died of grief days after her daughter","body":"When her eighteen-year-old daughter Harriet died in September 1876, she followed less than two weeks later; her family laid her death to grief. They lie together in the New Haven cemetery."},{"number":2,"category":"family","header":"Orphaned at six, raised by her grandmother","body":"Both her parents were dead before she turned six, and her Bradley grandmother in New Haven raised her. A family chronicle remembered her as firm and gentle at once, with an unshakable faith."},{"number":3,"category":"family","header":"Her brother founded Ogden, Utah","body":"One of her brothers, Miles Goodyear, became a Western trapper who founded what is now Ogden, Utah, and married a daughter of a Ute chief — a far cry from the New Haven world she kept to all her life."}],"quotes":[{"text":"Jesus can make a dying bed feel soft as downy pillows are, while on His breast I'll lean my head, and breathe my life out sweetly there.","source":"Reported as Polly Goodyear Blakeslee's last words in the Goodyear book #6852-1, drawn from Isaac Watts hymn 'Why should we start, and fear to die?'","context":"Deathbed September 1876"}],"sources":[{"label":"Goodyear book #6852-1 (Polly Goodyear Blakeslee chapter)"}],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"slug":"polly-goodyear-1815"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}