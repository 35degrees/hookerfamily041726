raduate","educator"],"number_of_marriages":3,"notable":{"is_notable":true,"notable_category":["academia","religion"],"notable_blurb":"Yale's first B.A. graduate, 1703","primary_url":"https://yale60.org/wp-content/uploads/2025/05/OurLegacyOfJohnHart.pdf","primary_url_label":"yale60.org"},"narrative_blocks":[{"number":1,"category":"education","header":"Yale's first B.A. graduate — alone in 1703","body":"He was the first student in Yale College to be advanced to a Bachelor's Degree. He graduated alone at Saybrook on September 15, 1703 — his diploma signed by Rector Abraham Pierson, Moses Noyes, Thomas Buckingham, and Noadiah Russell."},{"number":2,"category":"career","header":"Second Yale tutor — succeeded Daniel Hooker","body":"He was appointed Yale's second tutor on the very day of his graduation, succeeding his Farmington townsman Daniel Hooker. He served from 1703 to 1705, with charge of the two lower classes."},{"number":3,"category":"religion","header":"Ordained East Guilford's first minister, 1707","body":"In April 1707 he accepted the call to East Guilford (now Madison), and on November 25, 1707 he was ordained over the new thirteen-member church. Five ministers including James Pierpont and Thomas Buckingham officiated."},{"number":4,"category":"religion","header":"Signed the 1722 Yale Episcopal declaration","body":"In September 1722 he joined Rector Cutler and five others in signing the famous declaration before Yale trustees questioning the validity of Presbyterian ordination. After conference at Yale Library on October 16, his doubts were resolved and he remained Congregational."},{"number":5,"category":"character","header":"Greatest ingenuity and learning of all seven","body":"President Ezra Stiles called him a man of 'the greatest ingenuity and learning' among the seven who signed the 1722 declaration. His estate at death included £35 in books — a substantial scholarly library."}],"cross_connections":[{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X00126","link_text":"Rev. James Pierpont"},{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X01001","link_text":"Rev. Thomas Buckingham"},{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X01929","link_text":"Rev. Thomas Ruggles"},{"type":"civic_peer","related_id":"H00036","display_label":"Succeeded him as Yale's second tutor in 1703","link_text":"Doctor Daniel Hooker"}],"education":[{"dates":"1700-1702","notes":"Two years at Harvard; transferred 1702","school_name":"Harvard College","institution_id":"INST002"},{"degree":"B.A.","notes":"FIRST student at Yale to receive a Bachelor's degree — graduated alone at Saybrook, September 15, 1703. His original diploma is preserved in Yale Library. The 1702 class received M.A. degrees only (honorary, for Harvard graduates); Hart's 1703 B.A. was Yale's first bachelor's degree.","school_name":"Yale College (Collegiate School of Connecticut)","graduation_year":1703,"institution_id":"INST022"}],"bio":{"title":"Reverend","display_name":"Rev. John Hart","first_name":"John","last_name":"Hart","married_names":[],"bio_blurb":"Yale's first graduate; second tutor of the college"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"},{"institution_id":"INST022","relationship":"alumnus","years":"1703"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-hart-1682"},"H00105":{"id":"H00105","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1693,"month":11,"day":5,"city":"Guilford","state":"Connecticut"},"parents":{"father_id":"H00031",