 plantation's agriculture and weather.","number":3},{"category":"military","header":"Sherman's army camped around his house","body":"During Sherman's March to the Sea, Barrowville was made the headquarters of a Federal encampment, with thousands of soldiers camped around it. The house narrowly escaped burning when the last troops marched away.","number":4}],"slug":"william-mckinley-1809"},"H01842":{"id":"H01842","is_placeholder":false,"gender":"female","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1815,"month":4,"day":27,"city":"New Britain","state":"Connecticut"},"death":{"year":1888,"month":6,"day":1},"parents":{"father_id":"X01972","mother_id":"H00699"},"marriages":[{"marriage_number":1,"spouse_id":"X01988","date_year":1842,"date_month":8,"date_day":24,"location_city":"Berlin","location_state":"Connecticut","end_type":"death_of_spouse","end_year":1845,"children_ids":["HD2905"]},{"marriage_number":2,"spouse_id":"X01989","date_year":1848,"date_month":10,"date_day":26,"location_city":"Berlin","location_state":"Connecticut","children_ids":["HD5910","HD5911","HD5912"]}],"number_of_marriages":2,"tags":[],"sources":[{"short":"Cowles Genealogy"},{"bib_id":"BIB003"}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"former_ids":["HD2884"],"bio":{"display_name":"Lucy Anne Andrews McKinley","first_name":"Lucy Anne","last_name":"McKinley","maiden_name":"Andrews","married_names":["Sims","McKinley"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"lucy-anne-mckinley-1815"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}