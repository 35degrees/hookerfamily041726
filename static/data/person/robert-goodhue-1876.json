[],"tags":["author","clergy","minister"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Middlebury 1821, Andover Seminary","body":"Josiah Goodhue graduated Middlebury College in 1821 and Andover Theological Seminary thereafter, serving as Congregational pastor at Williston and Shoreham Vermont for twenty-four years. In 1857 he and Elizabeth removed to Whitewater Wisconsin, where he died May 3, 1863."},{"number":2,"category":"career","header":"Published history of Shoreham, Vermont, 1861","body":"Rev. Goodhue published 'History of the Town of Shoreham, Vermont, from the date of its charter, October 8th, 1761, to the present time' in 1861, printed by A.H. Copeland of Middlebury — a local history completed while he was still pastor at Shoreham. His middle name Fletcher derived from his mother's family: his mother was Elisabeth Fletcher Goodhue."}],"naming_inspiration":[],"quotes":[],"documents":[],"burial":{"cemetery_id":"CEM559"},"residence":{"country":"United States"},"sources":[{"short":"EH 1909 #1416"}],"research_sources":[],"slug":"josiah-goodhue-1791"},"H01416":{"id":"H01416","is_placeholder":false,"has_descendants_documented":false,"former_ids":[],"bio":{"display_name":"Elizabeth White Hooker","first_name":"Elizabeth","middle_name":"White","last_name":"Hooker","married_names":["Goodhue"]},"gender":"female","birth":{"year":1800,"month":7,"day":13,"city":"Rutland","county":"Rutland","state":"Vermont","country":"United States"},"death":{"year":1889,"month":1,"day":8,"city":"Whitewater","county":"Walworth","state":"Wisconsin","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"parents":{"father_id":"H00530","mother_id":"I01188"},"