:[],"gender":"male"},"residence":{},"baptism":{},"research_tags":["has_discrepancy"],"research_sources":[],"documents":[],"naming_inspiration":[{"name_element":"Brainard","inspired_by_id":"X02351","description":"Named for the Connecticut missionary David Brainerd (X02351, 1718-1747), who died October 9, 1747 — just seven months after Brainard Hooker's birth. Brainerd was Connecticut-born (Haddam) and celebrated for his missionary work when the Hooker baby was named."}],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"Revolutionary War","war_id":"WAR001","rank":"Soldier","notes":"Per EH entry 483."}],"narrative_blocks":[{"number":1,"category":"military","header":"Revolutionary War soldier; led family north to Vermont","body":"Brainard Hooker served in the Revolutionary War and moved his family from Wethersfield, Connecticut to Middlebury, Vermont, where he died in October 1808 at age sixty-one. He was survived by his wife Mary Deming Hooker, who outlived him by thirty-five years, dying in 1843 at age ninety."},{"number":2,"category":"birthname","header":"Born in 1747 when David Brainerd also died","body":"Brainard Hooker was born in Woodbury, Connecticut on March 4, 1747 — the same year that the renowned Presbyterian missionary David Brainerd died in Northampton, Massachusetts on October 9, 1747. The name 'Brainard' was rare in colonial Connecticut, but Brainerd was Connecticut-born (Haddam) and celebrated across New England for his missionary work among Delaware Indians; his parents almost certainly named the baby in honor of the dying missionary."}],"burial":{"cemetery_id":"CEM388","plot_notes":"Case Street Cemetery, Middlebury VT per FindAGrave"},"slug":"brainard-hooker-1747"},"I00756":{"id":"I00756","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Mary","last_name":"Hooker","maiden_name":"Deming","married_names":["Hooker"],"gender":"female","display_name":"Mary Deming Hooker"},"bi