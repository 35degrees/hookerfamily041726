:[{"role":"Teacher","organization":"Groton School","start_year":1897,"end_year":1899},{"role":"Professor of Mathematics","organization":"Harvard University","start_year":1899,"end_year":1940},{"role":"First Master","organization":"Lowell House, Harvard","start_year":1930,"end_year":1940},{"role":"Department Chairman","organization":"Harvard Mathematics","start_year":1927,"end_year":1940}],"narrative_blocks":[{"number":1,"category":"education","header":"He taught a future president at Groton","body":"Before joining Harvard, Coolidge taught at Groton, where one of his pupils was Franklin Delano Roosevelt; the two remained friends for life. He went on to spend his whole career at Harvard, chairing its mathematics department."},{"number":2,"category":"science","header":"He held Oxford’s first science degree","body":"After Harvard, Coolidge took the very first Bachelor of Science ever awarded by Oxford, in 1897, then a doctorate at Bonn under Eduard Study. His treatises on the circle, the sphere, and non-Euclidean geometry became standards."},{"number":3,"category":"education","header":"He built Lowell House from raw brick","body":"Named the first master of Lowell House in 1930, Coolidge had to invent the residential culture of a building “new and raw from the builders’ hands.” His vision shaped Harvard’s house system for generations."},{"number":4,"category":"military","header":"A geometer who commanded two thousand men","body":"During the First World War, Coolidge served as a major and liaison officer to the French General Staff, with two thousand American men under his command in Paris. France made him a chevalier of the Legion of Honor in 1919."},{"number":5,"category":"literature","header":"In retirement he wrote mathematics’ history","body":"After retiring in 1940, Coolidge turned to the history of his field, publishing studies of geometrical methods and \"The Mathematics of Great Amateurs.\" He was a record-setting miler in his Oxford days and a lifelong oarsman."}],"marriages":[{"spouse_id":"HD6569","marriage_number":1,"date_year":1901,"children_ids":["HD6604","HD6605","HD6606","HD6607","HD6608"]}],"cross_connections":[{"type":"parallel_careers","related_id":"HD1263","link_text":"Prof. James Pelham Pierpont","display_label":"a fellow eminent American mathematics professor of the era"}],"slug":"julian-lowell-coolidge-1873"},"HD6569":{"id":"HD6569","classification":{"is_thomas_descendant":true,"is_easter_egg":false,"is_talcott_descendant":false,"generation_from_thomas":9},"bio":{"display_name":"Theresa Reynolds Coolidge","first_name":"Theresa","last_name":"Coolidge","married_names":[],"maiden_name":"Reynolds","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781565647/143260808_6036c123-e16b-4f3d-85ee-b4990006f259-resized_xubcab.png","bio_blurb":"Linguist; matriarch of a Harvard academic dynasty"},"parents":{"father_id":"HD6557","mother_id":"I01832"},"tags":["extraordinary_longevity"],"marriages":[{"spouse_id":"I01849","marriage_number":1,"date_year":1901,"children_ids":["HD6604","HD6605","HD6606","HD6607","HD6608"]}],"birth":{"year":1874,"month":9,"day":26,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"exact"},"death":{"year":1972,"month":1,"day":17,"city":"Cambridge","state":"Massachusetts","country":"United States","date_precision":"exact"},"burial":{"cemetery_id":"CEM549"},"narrative_blocks":[{"number":1,"category":"family","header":"Her marriage seeded a Harvard dynasty","body":"A linguist by training, Theresa Reynolds married the mathematician Julian Lowell Coolidge in 1901 and bore seven children. Among them were a Fogg Museum director and a daughter who married Boston’s leading cultural historian."}],"slug":"theresa-coolidge-1874"},"HD6557":{"id":"HD6557","classification":{"is_thomas_descendant":true,"is_easter_egg":false,"is_talcott_descendant":false,"generation_from_thomas":8},"bio":{"display_name":"Dr. John Phillips Reynolds","first_name":"John Phillips","last_name":"Reynolds","title":"Dr.","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781557537/drjon_p946kz.png","bio_blurb":"Harvard professor of obstetrics for over twenty years"},"birth":{"year":1825,"month":11,"day":20,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"exact"},"death":{"year":1909,"month":10,"day":10,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"exact"},"parents":{"father_id":"HD6556","mother_id":"I01831"},"tags":["physician","harvard_graduate"],"burial":{"cemetery_id":"CEM110"},"notable":{"is_notable":true,"notable_category":["medicine"],"notable_blurb":"Harvard professor of obstetrics; physician in Boston","primary_url":"https://collections.countway.harvard.edu/onview/items/show/3686","primary_url_label":"Harvard Countway Library"},"education":[{"institution_id":"INST133","school_name":null,"dates":null,"type":"student"},{"institution_id":"INST002","school_name":null,"dates":"1845","type":"undergraduate","notes":"A.B."},{"institution_id":"INST171","school_name":null,"dates":"1852","type":"medical","notes":"M.D."}],"career":[{"role":"Assistant master","organization":"Boston Latin School","start_year":null,"end_year":null},{"role":"Professor of Obstetrics","organization":"Harvard Medical School","start_year":null,"end_year":1885}],"narrative_blocks":[{"number":1,"category":"science","header":"A classicist pressed into the family trade","body":"Reynolds excelled in the classics at Boston Latin and taught there two years before his father pressed him into Harvard Medical School. He took to obstetrics, and held the Harvard chair in the subject for more than two decades until 1885."},{"number":2,"category":"family","header":"He married a granddaughter of Paul Revere","body":"In 1859 Reynolds married Jane Minot Revere, granddaughter of the Revolutionary silversmith. The match folded the Revere line into a family already two generations deep in Boston medicine, with his father the founding surgeon of the eye-and-ear infirmary."},{"number":3,"category":"character","header":"His own grandson couldn’t name his colleagues","body":"A book of his medical correspondence passed to a grandson who, in 1913, wrote the hospital librarian that he could not vouch for the handwritten list of names inside or recognize the hand. The doctor’s working world had grown unreadable within two generations."}],"marriages":[{"spouse_id":"I01832","marriage_number":1,"date_year":1859,"children_ids":["HD6563","HD6564","HD6558","HD6565","HD6566","HD6567","HD6568","HD6569"]}],"cross_connections":[{"type":"family_orbit","related_id":"X03377","link_text":"Joseph Warren Revere","display_label":"his father-in-law, who ran the Revere copper works"}],"slug":"john-phillips-reynolds-1825"},"I01832":{"id":"I01832","classification":{"is_thomas_descendant":false,"is_easter_egg":false,"is_talcott_descendant":false,"generation_from_thomas":null},"bio":{"display_name":"Jane Minot Revere Reynolds","first_name":"Jane Minot","maiden_name":"Revere","last_name":"Reynolds","married_names":["Reynolds"],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781557106/147349069_c33ad113-e089-4369-8b36-126d5d693a53_zb5k1j.jpg","bio_blurb":"Granddaughter of Paul Revere; Boston matriarch"},"birth":{"year":1835,"month":6,"day":20,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"exact"},"death":{"year":1910,"month":5,"day":21,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"exact"},"parents":{"father_id":"X03377","mother_id":"X03381"},"tags":[],"burial":{"cemetery_id":"CEM110"},"marriages":[{"spouse_id":"HD6557","marriage_number":1,"date_year":1859,"children_ids":["HD6563","HD6564","HD6558","HD6565","HD6566","HD6567","HD6568","HD6569"]}],"narrative_blocks":[{"number":1,"category":"family","header":"Through her, the Revere name entered Boston medicine","body":"Jane Minot Revere was a granddaughter of Paul Revere and daughter of the copper magnate Joseph Warren Revere. Her 1859 marriage to Dr. John Phillips Reynolds braided the Revere line into three generations of Boston physicians."},{"number":2,"category":"legacy","header":"Her son bought back the Revere house","body":"Among Jane’s eight children was John Phillips Reynolds Jr., who in 1902 purchased and preserved her grandfather’s house in Boston’s North End. The Revere ancestry she carried became the cause that defined his life."},{"number":3,"category":"family","header":"Her name carried two Boston dynasties","body":"Jane Minot Revere bore the names of two old Boston families, the Minots and the Reveres, at the moment they joined the medical Reynoldses. Her children’s names, Paul Revere Reynolds and Mary Robbins Reynolds among them, kept the ancestry deliberately visible."}],"slug":"jane-minot-revere-1835"}},"burialCemetery":{"id":"CEM919","name":"Monticello Graveyard","city":"Charlottesville","county":"Albemarle County","state":"Virginia","country":"United States"},"institutionsById":{},"crossConnections":[]}