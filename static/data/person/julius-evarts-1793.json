],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Three Evarts siblings married three Nortons","body":"Curtis Evarts married Lois Norton in 1792. His brother Ezra had married Lois's sister Lorain in 1783, and his sister Mabel had married Lois's uncle Eber Norton in 1788. Three Evarts siblings tied themselves to three Nortons across two generations of the same Guilford family."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"curtis-evarts-1769"},"H01048":{"id":"H01048","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Lois","last_name":"Evarts","maiden_name":"Norton","married_names":["Evarts"],"gender":"female","display_name":"Lois Norton Evarts"},"birth":{"year":1766,"month":1,"day":10,"city":"East Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1828,"month":3,"day":21,"city":"East Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":6,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H00401","mother_id":"X02569"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02571","date_year":1792,"date_month":1,"date_day":18,"location_city":"Guilford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1828,"children_ids":["H02161","H02162"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Three Evarts siblings married three Nortons","body":"Lois Norton married Curtis Evarts in 1792. Her sister Lorain had married Curtis's brother Ezra nine years before, and the Evartses' sister Mabel married Lois's uncle Eber Norton. Three Evarts siblings tied themselves to three Nortons — Guilford genealogy at its densest."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"lois-evarts-1766"},"H00401":{"id":"H00401","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1744,"month":1,"day":15,"city":"Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"parents":{"father_id":"I00148","mother_id":"H00126"},"tags":["replacement_naming"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 401"}],"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02569","date_year":1762,"location_city":"Guilford","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1806,"children_ids":["H01046","H01047","H01048","H01049","H01050","H01051","H01052","H01053","H01054","H01055","H01056"],"location_county":"New Haven"}],"notable":{"is_notable":false,"notable_category":[]},"death":{"year":1827,"month":7,"day":17,"city":"Madison","county":"New Haven","state":"Connecticut","country":"United States"},"cross_connections":[],"bio":{"display_name":"Hooker Norton","notes":"Replacement naming after first Hooker Norton (H00399) died Sep 29, 1742","first_name":"Hooker","last_name":"Norton","suffix":"No. 2","married_names":[],"gender":"male","extra_names":"Called 'No. 2' in EH 1909 because his elder brother Hooker Norton (H00399, b. 1741) had received the same name — the elder Hooker presumably died young and the parents reused the name in 1744."},"residence":{"city":"East Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Given his deceased elder brother's name","body":"Hooker Norton was the SECOND son of Reuben and Hannah Hooker Norton to be given the name Hooker. The first (, b. 1741) presumably died young. Three years later when this son was born in 1744 the parents reused the Hooker name — a common eighteenth-century replacement-naming pattern that EH itself notes by labeling him 'No. 2.'"},{"number":2,"category":"family","header":"Eleven children five died young","body":"Hooker and Sibyl Bradley Norton had eleven documented children. Five died in infancy or childhood: Daniel Hooker at nine months in 1764; Russell at age six in 1774; Hannah at age eight in 1787; a second Russell at age eleven in 1795; and Zenas at age nine that same year. The 1795 deaths of Russell and Zenas in the same year hint at an epidemic."},{"number":3,"category":"death","header":"Lived eighty-three years through three wars","body":"Hooker Norton was born in colonial Connecticut on January 15, 1744 — age eleven at the start of the French and Indian War, age thirty-two when Independence was declared. He outlived the Revolutionary War, the War of 1812, and his wife Sibyl by twenty-one years. He died July 17, 1827 in Madison CT at eighty-three."}],"slug":"hooker-norton-1744"},"X02569":{"id":"X02569","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Sibyl","last_name":"Norton","maiden_name":"Bradley","married_names":["Norton"],"gender":"female","display_name":"Sibyl Bradley Norton"},"birth":{"year":1745,"month":3,"day":29,"city":"Guilford","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1806,"month":5,"day":4,"city":"Sunderland","county":"Bennington","state":"Vermont","country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Joseph Bradley","mother_name":"Sibyl Meigs Bradley","father_research_notes":"Joseph Bradley of Vergennes VT. Per EH 1909 entry 401.","mother_research_notes":"Sibyl Meigs Bradley of Vergennes VT. Per EH 1909 entry 401."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00401","date_year":1762,"location_city":"Guilford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1806,"children_ids":["H01046","H01047","H01048","H01049","H01050","H01051","H01052","H01053","H01054","H01055","H01056"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"migration","header":"Family migrated to Vermont before her death","body":"Sibyl Bradley Norton was born in Guilford CT in 1745 and married Hooker Norton there in 1762 at seventeen. By her 1806 death the family had migrated to Sunderland, Bennington County, Vermont — establishing that the Hooker Norton household made the New England westward move sometime between 1786 (when her youngest son Zenas was born in CT) and 1806. Her husband Hooker returned to Madison CT to die in 1827."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"sibyl-bradley-1745"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}