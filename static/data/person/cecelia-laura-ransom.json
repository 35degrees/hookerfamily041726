y","header":"He died a grand master of Masons","body":"Clarke joined the Masons after moving to Michigan and was serving as grand master of the state's Grand Lodge when he died in 1913. His funeral was among the largest the city of Flint had ever seen."}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"parallel_careers","related_id":"HD0411","display_label":"founded the American School for the Deaf in 1817"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Francis Devereux","last_name":"Clarke","display_name":"Lt. Francis Devereux Clarke","gender":"male","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780855375/157925628_609ab74f-6906-460c-b985-61c353fa9497_a988xw.jpg"},"military_service":[],"career":[],"birth":{"year":1849,"month":1,"day":31,"city":"Raleigh","county":"Wake","state":"North Carolina","country":"United States"},"death":{"year":1913,"month":9,"day":7,"city":"Flint","county":"Genesee","state":"Michigan","country":"United States"},"burial":{"cemetery_name":"Glenwood Cemetery","city":"Flint","county":"Genesee","state":"Michigan","country":"United States"},"education":[{"school_name":"Columbia University","type":"graduate","dates":"1873-1875","notes":"M.A., C.E."},{"school_name":"Davidson College","type":"college","dates":"1861-1863"}],"slug":"francis-devereux-clarke-1849"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}