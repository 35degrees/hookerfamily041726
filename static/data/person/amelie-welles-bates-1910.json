:3},{"category":"religion","header":"A Bahá'í who taught the faith in Haiti","body":"Bates embraced the Bahá'í Faith and its teaching of the oneness of humankind. In 1947 he and his family moved to Port-au-Prince to support the Bahá'í community there.","number":4}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"John Henry","last_name":"Bates","married_names":[],"display_name":"John Henry Bates","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780758773/johnbates_vx7si2.png"},"military_service":[],"slug":"john-henry-bates-1909"},"TD0354":{"id":"TD0354","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"female","birth":{"year":1936,"month":5,"day":24,"city":"New York","state":"New York","country":"United States"},"death":{"year":1971,"month":6,"day":26,"city":"Buga","country":"Colombia"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":false,"generation_from_john_talcott":9},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I01549","father_name":"John Henry Bates","mother_id":"TD0345","mother_name":"Amelie Welles Pumpelly Bates"},"number_of_marriages":0,"marriages":[],"tags":[],"narrative_blocks":[{"category":"death","header":"She died in a Colombian bus crash","body":"Raised in the Bahá'í Faith, Joan Pumpelly Bates moved with her family to Haiti as a child. She was killed at thirty-five in a bus accident near Buga, Colombia, in 1971.","number":1}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"st