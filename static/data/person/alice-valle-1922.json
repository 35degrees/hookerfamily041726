,"day":28,"city":"Rye Brook","county":"Westchester","state":"New York","country":"United States","cause":"lung cancer and stomach perforation"},"gender":"male","notable":{"is_notable":true,"notable_category":["law","business","politics"],"notable_blurb":"Wall Street lawyer; advised Eisenhower and Kennedy","primary_url":"https://www.nytimes.com/2006/10/02/nyregion/02knight.html","primary_url_label":"NYT obituary 2006"},"number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"I00325","children_ids":["HD3376","HD3377","HD3378","HD3379","HD3380"],"date_year":1940,"date_month":12,"date_day":14,"location_city":"New Haven","location_state":"Connecticut","location_country":"United States","end_type":"divorce","officiant":"Rev. Arthur F. McKenney (St. Paul's Protestant Episcopal Church)"},{"marriage_number":2,"spouse_id":"X02474","children_ids":[],"end_year":2006,"end_type":"death"}],"cross_connections":[],"bio":{"display_name":"Robert Huntington Knight","first_name":"Robert","last_name":"Knight","middle_name":"Huntington","married_names":[],"gender":"male"},"residence":{"city":"Greenwich / Ocean Ridge","county":"Fairfield / Palm Beach","state":"Connecticut / Florida","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"undergraduate_alumnus","years":"1936-1940","institution_blurb":"Yale College B.A. 1940."}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"World War II","war_id":"WAR008","rank":"Second Lieutenant","rank_start":"Second Lieutenant","rank_end":"Second Lieutenant","rank_year_start":1940,"rank_year_end":1945,"unit":"United States Army Air Corps","notes":"Commissioned as a second lieutenant directly upon his Yale graduation in 1940. Service interrupted his law-school plans by six years."}],"burial":{"plot_notes":"University of Virginia Cemetery and Columbarium, Charlottesville VA"},"education":[{"institution_id":"INST022","school_name":"Yale University","dates":"1936-1940","type":"undergraduate","degree":"B.A."},{"school_name":"University of Virginia School of Law","dates":"1946-1949","type":"graduate","degree":"LL.B.","notes":"Attained the school's first 4.0 GPA. Editor-in-chief of the Law Journal. Invited to join faculty upon graduation; taught for two years."}],"career":[{"role":"Faculty member","organization":"University of Virginia School of Law","location":"Charlottesville, Virginia","start_year":1949,"end_year":1951,"notes":"Joined the faculty upon graduation; taught for two years."},{"role":"Associate / Partner / Head of Firm","organization":"Shearman & Sterling","location":"New York City","start_year":1951,"end_year":2000,"notes":"Joined as associate 1951; made partner 1956; antitrust expert with growing corporate-client list. Headed the firm 1982-1985, leading its international expansion that established Shearman & Sterling as a premier global law practice."},{"role":"Deputy Assistant Secretary of Defense for International Security Affairs","organization":"United States Department of Defense (Eisenhower Administration)","location":"Washington, D.C.","start_year":1958,"end_year":1960,"notes":"Recruited from Shearman & Sterling by John Irwin II. Among his assignments: Eisenhower personally asked him to drive the road from West Germany to West Berlin to gather firsthand intelligence on Soviet efforts to isolate the enclave."},{"role":"General Counsel","organization":"United States Department of the Treasury (Kennedy Administration)","location":"Washington, D.C.","start_year":1961,"end_year":1963},{"role":"Bay of Pigs prisoner exchange organizer","organization":"Department of Justice (informal assignment from RFK)","location":"Washington, D.C.","start_year":1962,"end_year":1962,"notes":"Robert F. Kennedy, then Attorney General, asked him in fall 1962 to organize private-sector donations of food and drugs to exchange for the return of more than 1,000 prisoners captured by Cuba in the failed April 1961 Bay of Pigs invasion."},{"role":"Chairman (two terms)","organization":"Federal Reserve Bank of New York","location":"New York City","start_year":1977,"end_year":1983},{"role":"Board Member","organization":"Council on Foreign Relations","location":"New York City"},{"role":"Board Member","organization":"Asia Foundation","location":"San Francisco, California"},{"role":"Founding Member, Board Member, Trustee","organization":"University of Virginia Law School Foundation","location":"Charlottesville, Virginia","notes":"Helped lead a fund drive to build the school's endowment."}],"narrative_blocks":[{"number":1,"category":"education","header":"First 4.0 GPA in UVa Law School history","body":"Returning from WWII Army Air Corps service as a second lieutenant, he enrolled at the University of Virginia School of Law and graduated in 1949 having attained the school's first-ever 4.0 grade point average. He was editor-in-chief of the Law Journal and was invited to join the faculty directly upon graduation, teaching for two years before moving to New York to practice."},{"number":2,"category":"politics","header":"Eisenhower sent him to drive into Berlin","body":"As Deputy Assistant Secretary of Defense for International Security Affairs 1958-1960, he was personally asked by President Eisenhower to drive the road from West Germany to West Berlin to gather firsthand intelligence on Soviet efforts to isolate the enclave. The assignment came during the second Berlin Crisis culminating in the August 1961 construction of the Berlin Wall."},{"number":3,"category":"politics","header":"Organized Bay of Pigs prisoner exchange for RFK","body":"Back at Shearman & Sterling in fall 1962, he received a call from Attorney General Robert F. Kennedy asking him to organize private-sector donations of food and drugs to exchange for the return of more than 1,000 prisoners captured by Cuba in the failed April 1961 Bay of Pigs invasion. The unconventional barter — cash being diplomatically impossible — succeeded in freeing the men."},{"number":4,"category":"business","header":"Chaired NY Federal Reserve Bank for two terms","body":"He served two terms as Chairman of the Federal Reserve Bank of New York from 1977 to 1983, the most senior regional Fed appointment. The role spanned the Volcker disinflation period that broke late-1970s stagflation and reshaped global monetary policy for a generation."},{"number":5,"category":"career","header":"Made Shearman & Sterling a premier global firm","body":"As head of the firm 1982-1985 he led the international expansion that established Shearman & Sterling as one of the world's leading global law practices. He was awarded the Secretary of Defense Medal and the Alexander Hamilton Medal in recognition of his government service across the Eisenhower and Kennedy administrations."}],"slug":"robert-knight-1919"},"HD3376":{"id":"HD3376","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Alice","middle_name":"Price","last_name":"Knight","married_names":[],"gender":"female","display_name":"Alice Price Knight"},"birth":{"year":1949},"baptism":{},"death":{"year":2005},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":11,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD2156","mother_id":"I00325"},"gender":"female","marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["living_or_recent"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"alice-knight-1949"},"HD3377":