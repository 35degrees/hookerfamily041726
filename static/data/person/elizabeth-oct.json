 and Lake City, Florida during Reconstruction.","number":1}],"cross_connections":[],"bio":{"display_name":"Benjamin Hall Hart","first_name":"Benjamin","last_name":"Hart","middle_name":"Hall","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"benjamin-hart-1811"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}