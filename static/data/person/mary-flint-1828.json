otes":[],"military_service":[],"education":[{"school_name":"Harvard College","dates":"1786","type":"undergraduate","notes":"A.B. 1786."}],"career":[{"role":"Merchant","location":"Stockbridge, Massachusetts","notes":"For a time in business with his brother-in-law William Edwards."},{"role":"Court clerk; State Treasurer","organization":"Hampshire County Court; Commonwealth of Massachusetts"}],"narrative_blocks":[{"category":"career","header":"Harvard man, merchant, and state treasurer","body":"Josiah Dwight graduated from Harvard in 1786 and set up as a merchant at Stockbridge, for a time partnered with his brother-in-law William Edwards. He later served as clerk of the Hampshire County court and as treasurer of the Commonwealth of Massachusetts.","number":1},{"category":"family","header":"Rhoda Edwards was his second wife","body":"Dwight first married Caroline Williams in 1789, but she died in 1796. Two years later he married Rhoda Edwards, the celebrated 'Madam Dwight,' with whom he raised fifteen children.","number":2}],"slug":"josiah-dwight-1767"},"H00945":{"id":"H00945","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00381","mother_id":"X00709"},"tags":[],"sources":[{"short":"EH 1909"}],"birth":{"year":1778,"month":5,"day":7,"city":"Stockbridge","state":"Massachusetts"},"death":{"year":1863,"month":11,"day":13,"city":"Northampton","county":"Hampshire County","state":"Massachusetts","country":"United States","age":85},"marriages":[{"spouse_id":"X00725","children_ids":["HD2281","HD2282","HD2283","HD2284","HD2285","HD2286","HD2287","HD2288","HD2289","HD2290","HD2291","HD2292","HD2293","HD2294","HD2295"],"marriage_number":1,"date_year":1798,"date_month":3,"date_day":3,"location_city":"Stockbridge","location_state":"Massachusetts"}],"alternate_photo_url":"https://americanaristocracy.com/storage/18324/Screenshot-2024-02-12-at-20.23.36.png","gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Rhoda Edwards","first_name":"Rhoda","maiden_name":"Edwards","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780756028/Screenshot-2024-02-12-at-20.23.36_qyat8x.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"character","header":"Madam Dwight a wonder and joy in Northampton","body":"Contemporary admirers described Rhoda as 'a wonder and a joy to all who knew her, for intellectual power and brightness, to the end of her very long life.' She was held in veneration by the admiring people of Northampton Massachusetts and by 'a multitude without that historic town.' The recognition extended well beyond local family circles into the wider regional culture of mid-nineteenth-century Massachusetts intellectual life."},{"number":2,"category":"family","header":"Mother of fifteen children with Josiah Dwight","body":"Rhoda married Josiah Dwight of Northampton on March 3, 1798 and they had fifteen documented children together. The very large family size placed the Dwight-Edwards household among the more substantial child-bearing marriages of late-eighteenth and early-nineteenth-century western Massachusetts. Josiah died about 1822, leaving Rhoda widowed with many children to raise alone over the next four decades."},{"number":3,"category":"family","header":"Widowed about 1822 with many children","body":"After Josiah's death about 1822, Rhoda raised her surviving children through her long widowhood — she lived another forty-one years until her 1863 death. The decades-long widowhood and intellectual reputation combined to make her one of Northampton's prominent older women of the mid-nineteenth century."},{"number":4,"category":"family","header":"Born Stockbridge MA 1778, died Northampton 1863","body":"Rhoda Edwards was born May 7, 1778 in Stockbridge, Berkshire County Massachusetts and died November 13, 1863 in Northampton, Hampshire County Massachusetts at age eighty-five. She is buried at Bridge Street Cemetery, Northampton. The Stockbridge-to-Northampton life arc tracked her marriage migration about thirty miles east into the Connecticut River valley."}],"slug":"rhoda-edwards-1778"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}