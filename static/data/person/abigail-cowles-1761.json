:[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"military","header":"Farmington militia captain his entire life","body":"He held the rank of Captain in the Connecticut militia and was known by that title for the rest of his life. He spent his entire life in Farmington — born there February 15, 1704/5 and dying there December 19, 1764, in his 60th year."},{"number":2,"category":"character","header":"The big chair — militia saluted him sitting","body":"In later years he became so corpulent he could not attend to business. On fine days a large chair was placed in the front yard near the door, where he sat smoking his pipe and visiting with passersby. When the local militia paraded, it was customary for them to march around by his house and salute him in the big chair."},{"number":3,"category":"family","header":"Heir to the famous Farmington Hooker Elm","body":"He was the son of Hon. John Hooker — the Farmington judge whose famous Hooker Elm gave the town its hospitality tradition. His grandfather Rev. Samuel Hooker had ministered Farmington's church for thirty years; his great-great-grandfather Rev. Thomas Hooker founded Hartford."}],"slug":"joseph-hooker-1705"},"I00132":{"id":"I00132","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1712,"month":5,"day":8,"city":"Farmington","state":"Connecticut","country":"United States"},"death":{"year":1797,"month":12,"day":25,"city":"Farmington","state":"Connecticut","country":"United States"},"parents":{"father_id":"X00120","mother_research_notes":"Abigail Ashley of Westfield, Massachusetts","mother_id":"X01861"},"marriages":[{"spouse_id":"H00102","children_ids":["H00287","H00288","H00289","H00290","H00291","H00292"],"marriage_number