ted States"},"death":{"year":1864,"date_precision":"exact","month":4,"day":24,"city":"Durham","state":"Connecticut","country":"United States"},"parents":{"father_id":"HD0164","mother_id":"I01776"},"marriages":[{"spouse_id":"I01777","marriage_number":1,"date_year":1827,"date_month":11,"date_day":27,"children_ids":["HD6424","HD6425","HD6426"]}],"tags":[],"burial":{"cemetery_id":"CEM569"},"narrative_blocks":[{"number":1,"category":"religion","header":"He prosecuted neighbors over the Sabbath","body":"Ordained deacon of Durham’s First Congregational Church in 1827, Samuel Newton was appointed the officer charged with prosecuting Seventh-day Baptists for not observing the Christian Sabbath. He led the Durham Sunday School Association until his death and sat in the General Assembly in 1856."},{"number":2,"category":"family","header":"His birthday verses warned of the grave","body":"A writer of verses, Samuel marked his daughter Eliza’s eighth birthday with a poem warning that before eight more years passed, her “head may lie low in the dust.” She lived instead to seventy, teaching school and remembering the church in her will."}],"slug":"samuel-newton-1796"},"I01777":{"id":"I01777","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":null},"bio":{"display_name":"Betsey Parmelee Newton","first_name":"Betsey","last_name":"Newton","married_names":[],"maiden_name":"Parmelee"},"birth":{"year":1804,"date_precision":"year_only"},"death":{"year":1879,"date_precision":"exact","month":5,"day":8,"city":"Durham","state":"Connecticut","country":"United States"},"parents":{"father_id":null,"mother_id":null},"marriages":[{"spouse_id":"HD6421","marriage_number":1,"children_ids":["HD6424","HD6425","HD6426"]}],"tags":[],"burial":{"cemetery_id":"CEM569"},"slug":"betsey-parmelee-1804"},"HD6424":{"id":"HD6424","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from