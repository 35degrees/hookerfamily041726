children_ids":["HD2010","HD2011"],"marriage_number":1,"date_year":1848}],"tags":["farmer","republican_party","politician"],"sources":[{"label":"Wikipedia — Edward W. Dwight","url":"https://en.wikipedia.org/wiki/Edward_W._Dwight"},{"label":"WikiTree — Edward Woolsey Dwight outreach","url":"https://www.wikitree.com/wiki/Bizony-2"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["politics","agriculture"],"notable_blurb":"American farmer, frontier pioneer, and politician","primary_url":"https://en.wikipedia.org/wiki/Edward_W._Dwight","primary_url_label":"Wikipedia"},"cross_connections":[],"bio":{"display_name":"Edward Woolsey Dwight","first_name":"Edward","last_name":"Dwight","middle_name":"Woolsey","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Wisconsin frontier farmer for fifty-six years","body":"At twenty-one he married Elizabeth Foote and moved to Spring Prairie WI in Walworth County to farm. He spent the rest of his life — 56 years — as a Wisconsin farmer, far from the Dwight family's Yale-Hamilton-Columbia intellectual axis his brothers Theodore William and Benjamin Woodbridge occupied."},{"number":2,"category":"family","header":"Outlived four siblings in the Wisconsin countryside","body":"By the time he died at 76 in 1904 he had outlived all four of his siblings — Sophia (1863), Mary (1864), Theodore William (1892), and Benjamin Woodbridge (1889). He was buried in Oregon, Dane County WI, far from the family plot at Grove Street and Sunset Hill Cemetery."},{"number":3,"category":"adventure","header":"Whaling schooner at fifteen, year on Atlantic","body":"At fifteen he left his father's home and went to Boston, where he signed up on the whaling schooner Council and spent a year sailing the Atlantic Ocean. He returned to Boston and went to Clinton NY to work on a farm — the start of a 60-year agricultural career across three states."},{"number":4,"category":"politics","header":"Wisconsin State Assembly Republican, 1860","body":"He was active in the Republican Party and held various offices, culminating in his election to a single one-year term in the Wisconsin State Assembly in 1860 — Lincoln's election year. Dane County lost a seat in the subsequent assembly and he did not return to elected office for two decades."},{"number":5,"category":"politics","header":"Greenback Party presidential elector, 1880","body":"After the Civil War he spent a great deal of time studying financial questions. The result was a political pivot: in 1880 he served as a United States Presidential elector for the Greenback Party — a populist third party advocating greenback paper currency and against the gold standard. His brothers Theodore William and Benjamin Woodbridge remained Republican."}],"slug":"edward-dwight-1827"},"X00644":{"id":"X00644","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1827},"death":{"year":1905},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1992","children_ids":["HD2010","HD2011"],"marriage_number":1,"date_year":1848}],"gender":"female","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Foote","first_name":"Elizabeth","maiden_name":"Foote","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elizabeth-foote-1827"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}