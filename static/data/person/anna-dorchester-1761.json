[{"marriage_number":1,"spouse_id":"X02764","date_year":1694,"date_month":1,"date_day":2,"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death_of_spouse","end_year":1708,"children_ids":["X02765","X02768","I00156","X00260"]},{"spouse_id":"X00262","children_ids":["I00156"],"marriage_number":2}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Captain Isaac Cowles","first_name":"Isaac","last_name":"Cowles","title":"Captain","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"category":"marriage","header":"Married two Andrews sisters in succession","body":"His first wife Mary Andrews died July 1705; four years later in November 1709 he married her sister Sarah Andrews. Sarah herself died June 1715 leaving only one infant who had died in 1714 — Isaac married for the third and last time in December 1716 to Elizabeth Smith, twenty-six years his junior.","number":1},{"category":"career","header":"Farmington tailor who became Captain by 1731","body":"A tailor by trade and extensive landholder at Farmington, he rose through the militia ranks — Ensign 1717, Lieutenant 1723, Captain by May 1731 of the 2nd Company Trainband. He also served as Company Clerk in 1714, collector of the minister's rate 1698-1700, constable for several years, and town representative in 1726.","number":2},{"category":"legacy","header":"Five surviving sons divided 2500 pounds, 1763","body":"His will was dated October 1740 and proved March 1756. Seven years later in 1763 his last five surviving sons divided his Farmington estate — approximately £2,500 among themselves as sole heirs, an unusually concentrated inheritance for the colonial period.","number":3}],"slug":"isaac-cowles-1675"},"X00262":{"id":"X00262","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"short":"Cowles Family Genealogy"},{"bib_id":"BIB003"}],"birth":{"year":1690},"death":{"year":1767},"gender":"female","parents":{"father_id":"I00156","mother_id":"H00232"},"marriages":[{"spouse_id":"X00261","children_ids":["I00156"],"marriage_number":1}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Smith","first_name":"Elizabeth","maiden_name":"Smith","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"number_of_marriages":1,"slug":"elizabeth-smith-1690"},"H00087":{"id":"H00087","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1690,"month":10,"day":4,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"H00028","mother_id":"I00056"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 87"}],"death":{"year":1787,"month":2,"day":19,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"tags":["extraordinary_longevity"],"cross_connections":[],"marriages":[{"marriage_number":1,"spouse_id":"I00121","date_year":1720,"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1760,"children_ids":["H00232"]}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"landmarks":[{"landmark_id":"LM043","landmark_blurb":"His father lived here, directly opposite the Giles Hooker house on Main Street."}],"narrative_blocks":[{"number":1,"category":"death","header":"His death at 96 killed his brother Samuel","body":"On February 19, 1787, Giles Hooker died in Farmington at age 96. When the news reached his older brother Samuel — then age 98 in Kensington — Samuel \"fell back in his chair and expired\" on March 1, 1787. Two brothers, together accounting for nearly 195 years of life, died within ten days of each other."},{"number":2,"category":"legacy","header":"The well stone on Main Street","body":"He and Martha lived on the George Cowles place on Main Street, Farmington. In Edward Hooker's time (1909), a flat stone in the sidewalk just below the brow of the hill still covered the old well of the Giles Hooker house. Directly opposite, his father Rev. Samuel Hooker had lived in the Mix House — just south of the old burying ground."}],"bio":{"display_name":"Lt. Giles Hooker","title":"Lieutenant","first_name":"Giles","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"artworks":[],"quotes":[],"military_service":[],"slug":"giles-hooker-1690"},"I00121":{"id":"I00121","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1693,"month":6,"day":2,"city":"Hartford","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1760,"month":5,"day":22,"city":"Farmington","county":"Hartford","state":"Connecticut","country":"United States"},"parents":{"father_id":"X00110","mother_id":"X00111"},"marriages":[{"marriage_number":1,"spouse_id":"H00087","date_year":1720,"location_city":"Farmi