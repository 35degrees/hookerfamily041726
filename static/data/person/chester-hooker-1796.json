irthname","header":"Born in 1747 when David Brainerd also died","body":"Brainard Hooker was born in Woodbury, Connecticut on March 4, 1747 — the same year that the renowned Presbyterian missionary David Brainerd died in Northampton, Massachusetts on October 9, 1747. The name 'Brainard' was rare in colonial Connecticut, but Brainerd was Connecticut-born (Haddam) and celebrated across New England for his missionary work among Delaware Indians; his parents almost certainly named the baby in honor of the dying missionary."}],"burial":{"cemetery_id":"CEM388","plot_notes":"Case Street Cemetery, Middlebury VT per FindAGrave"},"slug":"brainard-hooker-1747"},"I00756":{"id":"I00756","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Mary","last_name":"Hooker","maiden_name":"Deming","married_names":["Hooker"],"gender":"female","display_name":"Mary Deming Hooker"},"birth":{"year":1752,"month":1,"day":23,"city":"Wethersfield","county":"Hartford County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1843,"month":6,"day":4,"city":"Middlebury","county":"Addison County","state":"Vermont","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM388","plot_notes":"Case Street Cemetery, Middlebury VT (m.1771 per FindAGrave)"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00483","location_country":"United States","children_ids":["H01247","H01248","HD4432","HD4433","HD4434","HD4435","H01253"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":["has_