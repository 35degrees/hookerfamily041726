 — purchased by her father-in-law Luther Gordon Sr. Plot features a stunning monument with columns and an allegorical figure with drapery. George C. Gordon her husband paid $9,229.54 for perpetual care in 1883."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"ida-gordon-1855"},"H03893":{"id":"H03893","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":true,"generation_from_thomas":9},"bio":{"first_name":"Florence","middle_name":"Louise","last_name":"Hooker","married_names":[],"gender":"female","display_name":"Florence Louise Hooker"},"birth":{"year":1866,"month":10,"day":21,"city":"Hindsburg","county":"Orleans County","state":"New York","country":"United States","historical_notes":"Hindsburg / Hindsburgh is a hamlet in the Town of Murray, Orleans County NY. Born 11 years after sister Ida May."},"death":{},"parents":{"father_id":"H02437","mother_id":"X02279"},"number_of_marriages":0,"marriages":[],"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 3893"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"florence-hooker-1866"},"H02438":{"id":"H02438","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":true,"generation_from_thomas":8},"bio":{"first_name":"Myron","middle_nam