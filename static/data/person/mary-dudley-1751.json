e","end_year":1715,"date_year":1712,"date_month":3,"date_day":20},{"children_ids":[],"spouse_id":"X00134","marriage_number":2,"end_type":"death_of_spouse","end_year":1719,"date_year":1717,"date_month":8,"date_day":12},{"spouse_id":"H00105","children_ids":["H00311","H00312","H00313","H00314","H00315","H00316"],"marriage_number":3,"date_year":1720,"date_month":12,"date_day":6}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 105"},{"short":"Yale Biographical Sketches 1701-1745 (1885)","url":"https://www.cga.ct.gov/hco/books/Biographical_Sketches_of_Grads_of_Yale_1701-1745_1885.pdf"}],"gender":"male","tags":["minister","yale_graduate","educator"],"number_of_marriages":3,"notable":{"is_notable":true,"notable_category":["academia","religion"],"notable_blurb":"Yale's first B.A. graduate, 1703","primary_url":"https://yale60.org/wp-content/uploads/2025/05/OurLegacyOfJohnHart.pdf","primary_url_label":"yale60.org"},"narrative_blocks":[{"number":1,"category":"education","header":"Yale's first B.A. graduate — alone in 1703","body":"He was the first student in Yale College to be advanced to a Bachelor's Degree. He graduated alone at Saybrook on September 15, 1703 — his diploma signed by Rector Abraham Pierson, Moses Noyes, Thomas Buckingham, and Noadiah Russell."},{"number":2,"category":"career","header":"Second Yale tutor — succeeded Daniel Hooker","body":"He was appointed Yale's second tutor on the very day of his graduation, succeeding his Farmington townsman Daniel Hooker. He served from 1703 to 1705, with charge of the two lower classes."},{"number":3,"category":"religion","header":"Ordained East Guilford's first minister, 1707","body":"In April 1707 he accepted the call to East Guilford (now Madison), and on November 25, 1707 he was ordained over the new thirteen-member church. Five ministers including James Pierpont and Thomas Buckingham officiated."},{"number":4,"category":"religion","header":"Signed the 1722 Yale Episcopal declaration","body":"In September 1722 he joined Rector Cutler and five others in signing the famous declaration before Yale trustees questioning the validity of Presbyterian ordination. After conference at Yale Library on October 16, his doubts were resolved and he remained Congregational."},{"number":5,"category":"character","header":"Greatest ingenuity and learning of all seven","body":"President Ezra Stiles called him a man of 'the greatest ingenuity and learning' among the seven who signed the 1722 declaration. His estate at death included £35 in books — a substantial scholarly library."}],"cross_connections":[{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X00126","link_text":"Rev. James Pierpont"},{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X01001","link_text":"Rev. Thomas Buckingham"},{"type":"civic_peer","display_label":"East Guilford ordination, November 25, 1706","related_id":"X01929","link_text":"Rev. Thomas Ruggles"},{"type":"civic_peer","related_id":"H00036","display_label":"Succeeded him as Yale's second tutor in 1703","link_text":"Doctor Daniel Hooker"}],"education":[{"dates":"1700-1702","notes":"Two years at Harvard; transferred 1702","school_name":"Harvard College","institution_id":"INST002"},{"degree":"B.A.","notes":"FIRST student at Yale to receive a Bachelor's degree — graduated alone at Saybrook, September 15, 1703. His original diploma is preserved in Yale Library. The 1702 class received M.A. degrees only (honorary, for Harvard graduates); Hart's 1703 B.A. was Yale's first bachelor's degree.","school_name":"Yale College (Collegiate School of Connecticut)","graduation_year":1703,"institution_id":"INST022"}],"bio":{"title":"Reverend","display_name":"Rev. John Hart","first_name":"John","last_name":"Hart","married_names":[],"bio_blurb":"Yale's first graduate; second tutor of the college"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"},{"institution_id":"INST022","relationship":"alumnus","years":"1703"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"john-hart-1682"},"H00105":{"id":"H00105","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1693,"month":11,"day":5,"city":"Guilford","state":"Connecticut"},"parents":{"father_id":"H00031","mother_id":"I00061"},"sources":[{"short":"Edward Hooker 1909","page":"Entry 105"}],"death":{"year":1756,"month":9,"day":6,"city":"Guilford","state":"Connecticut"},"marriages":[{"spouse_id":"I00137","children_ids":["H00311","H00312","H00313","H00314","H00315","H00316"],"marriage_number":1,"date_year":1720,"date_month":12,"date_day":6,"location_city":"Guilford","location_state":"Connecticut"}],"cross_connections":[{"type":"family_connection","related_id":"H00036","display_label":"Her husband succeeded Daniel as Yale's second tutor","link_text":"Doctor Daniel Hooker"},{"type":"in_law","related_id":"X00045","display_label":"was her father-in-law"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Mary Hooker Hart","first_name":"Mary","last_name":"Hart","married_names":["Hart"],"maiden_name":"Hooker"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"marriage","header":"Married Yale's first B.A. graduate","body":"On December 6, 1720 she married Rev. John Hart of East Guilford as his third wife. Hart had been Yale's first B.A. graduate (1703) and second tutor — succeeding her uncle Daniel Hooker, who had been Yale's first tutor."},{"number":2,"category":"family","header":"Three of her six children survived to marry","body":"With John Hart she had six children — four sons and two daughters. Two sons died young and infant Mary lived only three months. Sons Thomas (1723-1813) and Benjamin (1725-1804) carried the line, while daughter Sarah married three times — twice to Yale graduates."}],"slug":"mary-hart-1693"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}