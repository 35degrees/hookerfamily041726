e, WWI","body":"During World War I he served as State Chairman of Insurance for Pennsylvania, coordinating wartime insurance arrangements across the Commonwealth. He died at Villa Nova 10 January 1936 and was buried beside his father Dr. John Hooker Packard at Old Saint David's, Wayne."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"george-packard-1872"},"I01093":{"id":"I01093","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Elizabeth","middle_name":"Waln","last_name":"Packard","maiden_name":"Brown","married_names":["Packard"],"gender":"female","display_name":"Elizabeth Waln Wistar Brown Packard"},"birth":{"year":1872,"month":3,"day":26,"city":"Philadelphia","county":"Philadelphia","state":"Pennsylvania","country":"United States"},"baptism":{},"death":{"year":1940,"month":12,"day":20,"country":"United States"},"burial":{"cemetery_id":"CEM529","plot_notes":"Old Saint David's Church Cemetery, Wayne PA"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"T. Wistar Brown of Philadelphia","mother_name":"Mary Farnum Brown"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H04338","date_year":1895,"date_month":10,"date_day":30,"location_city":"Philadelphia","location_county":"Philadelphia","location_state":"Pennsylvania","location_country":"United States","end_type":"death_of_spouse","end_year":1936,"children_ids":["H05234","H05235","H05236","HD04862"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"elizabeth-brown-1872"},"H02745":{"id":"H02745","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1832,"month":8,"day":15,"city":"Philadelphia","state":"Pennsylvania"},"parents":{"mother_id":"H01403","father_research_notes":"Frederic Adolphus Packard","father_id":"X00161"},"tags":["physician","civil_war","author","pennsylvania_migration"],"sources":[],"death":{"year":1907,"month":5,"day":20,"city":"Atlantic City","state":"New Jersey","cause":"Cardiorenal failure (heart disease)"},"marriages":[{"spouse_id":"X00162","children_ids":["H04333","H04334","H04335","H04336","H04337","H04338"],"marriage_number":1,"date_year":1858,"date_month":6,"date_day":3}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["medicine"],"notable_blurb":"pioneer of modern American surgery","primary_url":"https://www.medicalantiques.com/civilwar/Medical_Authors_Faculty/Packard_John_H..htm","primary_url_label":"Dr. Echols & Dr. Arbittier — John H. Packard, M.D."},"cross_connections":[],"bio":{"display_name":"Dr. John Hooker Packard","first_name":"John","last_name":"Packard","middle_name":"Hooker","title":"Doctor","married_names":[],"gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779146282/johnhookerpackard_kbbw52.jpg","photo_notes":"Portrait photograph reproduced in Anesthesiology journal, Nov 2001 (Defalque, Panning, Wright)."},"residence":{"city":"Philadelphia","county":"Philadelphia","state":"Pennsylvania","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST143","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["HD0621"],"burial":{"cemetery_id":"CEM529","plot_notes":"Old Saint David's Church Cemetery, Wayne, Delaware County, PA"},"education":[{"school_name":"University of Pennsylvania","institution_id":"INST143","degree_or_field":"A.B. 1850; M.D. 1853","class_year":1853,"notes":"A.B. 1850, M.D. 1853. Resident physician at Philadelphia's University Hospital for 18 months after graduation; then 1.5 years visiting the great Paris hospitals before returning to Philadelphia practice."}],"career":[{"role":"Surgeon","organization":"Christian Street U.S. Army Hospital","location":"Philadelphia, PA","start_year":1862,"end_year":1865,"notes":"Acting assistant surgeon at Christian Street and Satterlee Union Army hospitals during the Civil War."},{"role":"Consulting surgeon","organization":"U.S. Army hospitals at Beverly NJ and Haddington PA","location":"PA / NJ","start_year":1862,"end_year":1865},{"role":"Surgeon","organization":"Episcopal Hospital","location":"Philadelphia, PA","start_year":1863,"end_year":1884},{"role":"Surgeon","organization":"Pennsylvania Hospital","location":"Philadelphia, PA","start_year":1884,"end_year":1896,"notes":"Surgeon to Pennsylvania Hospital from 1884 until his 1896 retirement following septicemia from a finger infection caught during surgery."},{"role":"Secretary then Vice President","organization":"College of Physicians of Philadelphia","location":"Philadelphia, PA","start_year":1862,"end_year":1896,"notes":"Secretary 1862-1877; Vice President from 1886."}],"narrative_blocks":[{"number":1,"category":"innovation","header":"Switched American surgeons from chloroform to ether","body":"In May 1865 he reported to the Philadelphia College of Physicians that after witnessing fatal chloroform accidents in his own and his colleagues' practices, he was switching to ether. Following his friend F. D."},{"number":2,"category":"publication","header":"Manual of Minor Surgery adopted by US Army","body":"His 1863 Manual of Minor Surgery — a working guide to bandaging, pain control, and field operations — was adopted by the United States Army and became one of the most reprinted surgical handbooks of the Civil War era. The Handbook of Operative Surgery followed in 1870."},{"number":3,"category":"war","header":"Civil War surgeon at Christian Street and Satterlee","body":"He served as acting assistant surgeon at Philadelphia's Christian Street and Satterlee U.S. Army hospitals throughout the Civil War. One soldier whose arm Packard rebuilt — Martin V.B. Keller — wrote afterward that the surgeon was 'very proud of the operation' and had photographs taken of the recovered arm."},{"number":4,"category":"death","header":"Septic finger ended career, 1896 retirement","body":"A finger infection caught during surgery in 1896 led to septicemia and forced his retirement at sixty-four after forty-three years of practice. He died of cardiorenal failure at the Hotel Chalfont in Atlantic City on 21 May 1907 and was buried at Old Saint David's Church Cemetery in Wayne, PA."},{"number":5,"category":"publication","header":"Sea-Air therapy book established resort medicine","body":"His 1880 book Sea-Air and Sea-Bathing was among the first American medical works to argue systematically that coastal air and bathing could benefit specific patient categories. The treatise helped establish the Atlantic City and Cape May resort culture that would shape East Coast medicine for a generation."}],"slug":"john-packard-1832"},"X00162":{"id":"X00162","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1835,"month":5,"day":2,"city":"Philadelphia","county":"Philadelphia","state":"Pennsylvania","country":"United States"},"death":{"year":1897,"month":3,"day":11,"city":"Devon","county":"Chester","state":"Pennsylvania","country":"United States"},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H02745","date_year":1858,"date_month":6,"date_day":3,"end_type":"death_of_self","end_year":1897,"children_ids":["H04333","H04334","H04335","H04336","H04337","H04338"]}],"parents":{"father_name":"Charles Stuart Wood of Philadelphia (Quaker)","mother_name":"Juliana Fitz Randolph Wood (Quaker)"},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Wood Packard","first_name":"Elizabeth","maiden_name":"Wood","married_names":["Packard"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"elizabeth-wood-1835"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}