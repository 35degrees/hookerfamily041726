{"person":{"id":"HD0676","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"I00153","mother_id":"H00269"},"tags":["army","ohio_migration","revolutionary_war"],"sources":[{"short":"Hurlbut Family Genealogy 1888","notes":"Entry 320"}],"birth":{"year":1744,"city":"Kensington/Farmington","state":"Connecticut"},"marriages":[{"children_ids":["HD0685","HD0686","HD0687","HD0688","HD0689","HD0908"],"spouse_id":"X00231","marriage_number":1,"end_type":"death_of_spouse","end_year":1776,"date_year":1766,"date_month":11,"date_day":17,"location_city":"Kensington","location_state":"Connecticut"},{"children_ids":["HD0690","HD0691","HD0692","HD0693","HD0694"],"spouse_id":"X00232","marriage_number":2,"date_year":1777}],"death":{"year":1822,"month":6,"day":16,"city":"Springfield","state":"Ohio"},"gender":"male","number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR001","side":"United States","rank":"Captain (called)","service_years":"~1775-1782 (approximately 7 years)","units":["Continental Army teamster / transportation trains"],"role":"Served approximately seven years, mostly as a teamster in transportation trains. Called 'Captain.' His first wife Sarah Hubbard died in Wallingford CT while Raphael was away with the army — their son Agathus was about 2 months old at the time."}],"bio":{"display_name":"Raphael Hurlbut","notes":"Hurlbut Family Genealogy 1888 entry #320","first_name":"Raphael","last_name":"Hurlbut","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"family","header":"Wife died with infant while he served","body":"Raphael Hurlbut's first wife Sarah Hubbard died in Wallingford Connecticut in 1776 while Raphael was away with the Continental Army. Their son Agathus was about two months old at the time. The single-event combination — wife's home death, infant son, husband absent on extended military service — captured the personal cost of the Revolutionary War to families left behind on the Connecticut homefront."},{"number":2,"category":"military","header":"Seven years Continental Army teamster, called Captain","body":"Raphael Hurlbut served approximately seven years in the Continental Army — one of the longer single-soldier tours among Connecticut-line Hooker descendants. He served mostly as a teamster in the transportation trains, the supply-line logistics work that was distinct from frontline combat but was just as essential to the army's operations. He was called 'Captain' by his contemporaries."},{"number":3,"category":"family","header":"Connecticut to Ohio migration 1812, died Springfield","body":"Raphael lived first at Wallingford Connecticut, then at Salisbury Connecticut, and in 1812 removed to Springfield Ohio where he died June 16, 1822 around age seventy-eight. His second wife Abigail Riley Knott (widow of Giles Nott) later married John Hamilton in Ohio after Raphael's death. His father Dr. James Hurlbut, one of the founders of Connecticut medicine, had lived with him in Wallingford in his final years before returning to die in Wethersfield Connecticut."}],"slug":"raphael-hurlbut-1744"},"neighborhood":{"focus":{"id":"HD0676","slug":"raphael-hurlbut-1744","n":"Raphael Hurlbut","by":1744,"dy":1822,"sx":"m","hd":true,"td":false,"ee":false,"g":6},"spouses":[{"order":1,"spouse":{"id":"X00231","slug":"sarah-hubbard-1747","n":"Sarah Hubbard","by":1747,"dy":1776,"sx":"f","hd":false,"td":false,"ee":false,"g":null},"year":1766,"children":[{"id":"HD0685","slug":"eunice-hurlbut-1767","n":"Eunice Hurlbut","by":1767,"