sylvania","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM176","plot_notes":"Berlin Corner Cemetery, Berlin Corners VT."},"gender":"male","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":9,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_id":"X02383","mother_id":"TD0124"},"marriages":[],"tags":["civil_war"],"research_tags":[],"sources":[{"label":"FindAGrave — Edward P. Evans","url":"https://www.findagrave.com/memorial/75483197/edward_p-evans"}],"research_sources":[],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"number":1,"category":"military","header":"Severely wounded at Cold Harbor, June 1864","body":"Edward served with the 10th Vermont Volunteer Infantry — the same regiment his younger brother Ira Hobart Evans had enlisted in two years earlier. He was severely wounded at the Battle of Cold Harbor Virginia on June 1, 1864, and was transferred to the Veteran Reserve Corps for invalid duty."}],"cross_connections":[],"naming_inspiration":[],"education":[],"career":[],"military_service":[{"war":"American Civil War","rank":"Veteran Reserve Corps","unit":"10th Regiment Vermont Volunteer Infantry → Veteran Reserve Corps","notes":"Severely wounded at the Battle of Cold Harbor, Virginia, June 1, 1864; transferred to Veteran Reserve Corps for invalid duty."}],"institutions":[],"landmarks":[],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"edward-evans-1842"},"TD0163":{"id":"TD0163","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"display_name":"Ira Hobart Evans","first_name":"Ira","middle_name":"Hobart","last_name":"Evans","married_names":[],"gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1777674218/Ira_Hobart_Evans_2_anxkrz.jpg","photo_notes":"Portrait. Cloudinary."},"birth":{"year":1844,"month":4,"day":11,"city":"Piermont","county":"Grafton","state":"New Hampshire","country":"United States"},"baptism":{},"death":{"year":1922,"month":4,"day":19,"city":"San Diego","county":"San Diego","state":"California","country":"United States"},"residence":{"city":"Austin","county":"Travis","state":"Texas","country":"United States","note":"North-Evans Chateau (LM063), now Austin Woman's Club."},"burial":{"cemetery_id":"CEM176","plot_notes":"Berlin Corner Cemetery, Berlin Corners VT — Vermont burial after California death per his wishes."},"gender":"male","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_john_talcott":9,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_id":"X02383","mother_id":"TD0124"},"marriages":[{"marriage_number":1,"spouse_id":"X02385","date_year":1871,"date_month":7,"location_country":"United States","end_type":"divorce","end_year":1917,"children_ids":["TD0165","TD0166","TD0167"]},{"marriage_number":2,"spouse_id":"X02386","date_year":1920,"location_country":"United States","end_type":"death_of_self","end_year":1922,"children_ids":[]}],"number_of_marriages":2,"tags":["civil_war","medal_of_honor","texas_migration","politician","banker","educator"],"research_tags":[],"sources":[{"label":"Wikipedia — Ira Hobart Evans","url":"https://en.wikipedia.org/wiki/Ira_Hobart_Evans"},{"label":"Texas State Historical Association — Evans, Ira Hobart","url":"https://www.tshaonline.org/handbook/entries/evans-ira-hobart"},{"label":"FindAGrave — Ira Hobart Evans (memorial 22659)","url":"https://www.findagrave.com/memorial/22659/ira_hobart-evans"}],"research_sources":[],"notable":{"is_notable":true,"notable_category":["military","politics","business"],"notable_blurb":"Civil War Medal of Honor; Texas House Speaker","primary_url":"https://en.wikipedia.org/wiki/Ira_Hobart_Evans","primary_url_label":"Wikipedia"},"narrative_blocks":[{"number":1,"category":"military","header":"Walked alone into the no-man's-land at Hatcher's Run","body":"On April 2, 1865, when Gen. William Birney needed deserters questioned before a planned afternoon assault on Confederate works at Hatcher's Run, Captain Evans was the only staff officer to volunteer. He dismounted, passed alone over the ridge — the only Union soldier in view from Confederate lines — drew a sharp musketry fire, made the rifle pit, questioned the deserters, and returned through another shower of bullets to report."},{"number":2,"category":"military","header":"Honor guard at Lincoln's funeral","body":"Two weeks after his Hatcher's Run heroism, Evans was selected as one of the officers in President Abraham Lincoln's funeral cortège honor guard on April 17, 1865. He was twenty-one years old. He had risen from private to brevet major in three years."},{"number":3,"category":"politics","header":"Speaker of the Texas House at twenty-six","body":"Elected Speaker of the Texas House of Representatives in 1870 — the youngest person ever to hold the office. Months later he opposed an August 1870 election law that postponed the next election from 1871 to 1872 in violation of the 1869 Constitution; the Republican caucus denounced him and voted to remove him from the speakership the following morning."},{"number":4,"category":"legacy","header":"Funded a Black college's industrial-training building","body":"Trustee of Tillotson College (now Huston-Tillotson University) 1881-1920 and board president 1909-1920, Evans donated $10,000 to construct the 1912 Evans Industrial Building — which trained Black students in construction skills and bears his name. The building stands today as a Texas Historical Site. He bequeathed an additional $10,000 for the college president's residence."},{"number":5,"category":"family","header":"First cousin of Pampa Texas's Timothy Dwight Hobart","body":"Wikipedia confirms what the Berlin Vermont genealogy shows — Ira's mother Emeline Hobart Evans and Timothy Dwight Hobart's father David Hobart were full siblings, children of Rev. James Hobart of Berlin Vermont. Two Berlin Vermont-born first cousins, both Texas pioneers, both buried back home. Timothy at Pampa Fairview, Ira at Berlin Corner."}],"cross_connections":[{"type":"family_connection","related_id":"TD0133","display_label":"First cousins; both Berlin Vermont-born Texas pioneers","link_text":"Timothy Dwight Hobart"},{"type":"parallel_careers","related_id":"TD0184","display_label":"Cousin Porter Kendrick commanded Michigan infantry as Civil War Major","link_text":"Porter Kendrick Perrin"}],"naming_inspiration":[{"name_element":"Hobart","inspired_by_id":"TD0120","description":"Middle name 'Hobart' honors his maternal grandparents — Berlin VT's first settled minister Rev. James Hobart and Betsey Perrin Hobart — and was carried forward into the next generation as his son Hobart Yale Evans's first name."}],"education":[{"school_name":"Public schools, Barre Vermont","type":"primary"},{"school_name":"Barre Academy","type":"secondary","notes":"Completed his education at Barre Academy after his mother moved the family to Barre VT following his father's 1852 death."}],"career":[{"role":"Rancher (failed)","organization":"Self / Texas ranch near Corpus Christi","location":"near Corpus Christi, Texas","start_year":1867,"notes":"Lost investment through dishonesty of a partner."},{"role":"Agent","organization":"Freedmen's Bureau","location":"Wharton, Texas","start_year":1867,"end_year":1868,"notes":"Resigned January 31, 1868 angered by superiors he considered incompetent."},{"role":"Internal Revenue agent","organization":"United States Internal Revenue Service","location":"Eagle Pass and Corpus Christi, Texas","start_year":1868,"end_year":1869},{"role":"State Representative","organization":"Texas House of Representatives","location":"Austin, Texas","start_year":1870,"end_year":1871,"notes":"Representing Western District of Texas; ran at urging of Republican gubernatorial candidate Edmund Jackson Davis 1869."},{"role":"Speaker of the House","organization":"Texas House of Representatives","location":"Austin, Texas","start_year":1870,"end_year":1870,"notes":"Elected Speaker 1870 at age 26 — youngest in Texas history. Removed by Republican caucus over August 1870 election law dispute (he opposed postponing 1871 election to 1872 as violating Constitution of 1869)."},{"role":"General Manager","organization":"Texas Land Company of Houston","start_year":1872,"end_year":1873},{"role":"Secretary","organization":"Houston and Great Northern Railroad Company","start_year":1873,"end_year":1874},{"role":"Secretary, then Director","organization":"International-Great Northern Railroad Company","start_year":1874,"end_year":1908,"notes":"Secretary from 1874 merger of Houston & Great Northern with International Railroad. Director 1875-1908."},{"role":"President","organization":"New York and Texas Land Company, Limited","start_year":1880,"end_year":1906,"notes":"Same NY&T Land Company where his cousin Timothy Dwight Hobart of Pampa worked as surveyor under E.A. Giraud 1882-86 then managed 1 million Panhandle acres from Mobeetie 1886-1903."},{"role":"Cofounder and Director","organization":"Austin National Bank","start_year":1890,"end_year":1922,"notes":"Lifelong director."},{"role":"Receiver","organization":"Austin Rapid Transit Railway Company","start_year":1897,"end_year":1902},{"role":"President and Director","organization":"Austin Electric Railway Company","start_year":1902,"end_year":1903},{"role":"Founder and President","organization":"Texas Life Insurance Company"},{"role":"Trustee, Board President","organization":"Tillotson College (now Huston-Tillotson University)","location":"Austin, Texas","start_year":1881,"end_year":1920,"notes":"Trustee 1881-1920; board president 1909-1920. $10,000 donation to construct Evans Industrial Building (1912; Texas Historical Site, named for him); $10,000 bequest for college president's residence."},{"role":"President","organization":"American Home Missionary Society"},{"role":"Founder and Trustee","organization":"First Congregational Church (Palestine TX)","start_year":1881},{"role":"Trustee","organization":"First Presbyterian Church (Austin TX)","notes":"22 years on board."},{"role":"Board President","organization":"First Congregational Church (Austin TX)","notes":"5 years as president."},{"role":"Founder and First President","organization":"Texas Society of the Sons of the American Revolution (SAR)","start_year":1896,"notes":"Vermont SAR member from 1896 (Vermont Society #51, national #2751); founded TX Society and was first president."}],"military_service":[{"war":"American Civil War","rank":"Brevet Major","rank_start":"Private","rank_end":"Brevet Major","rank_year_start":1862,"rank_year_end":1865,"unit":"Co. B 10th VT Vol. Inf. → 9th US Colored Troops → 116th US Colored Troops → XXV Army Corps Adjutant","notes":"Enlisted Private Co. B 10th Vermont Volunteer Infantry July 28, 1862. Commissioned 1st Lieutenant 9th US Colored Troops December 18, 1863. Promoted Captain commanding Co. B 116th US Colored Troops January 27, 1865. Brevet Major March 13, 1865 'for gallant and meritorious service'; assigned acting assistant adjutant general of XXV Army Corps, Army of the James. April 17, 1865 — officer in honor guard of Lincoln's funeral cortège. Mustered out February 7, 1867 at Louisville KY; provost marshal of Brownsville TX during Sheridan's occupation force."}],"institutions":[{"institution_id":"INST116","relationship":"trustee","years":"1881-1920","institution_blurb":"Trustee 1881-1920 and board president 1909-1920 of the Black Austin college; donor of the Evans Industrial Building."},{"institution_id":"INST117","relationship":"president","years":"1880-1906","institution_blurb":"President of the New York and Texas Land Company 1880-1906 — same firm that employed his cousin Timothy Dwight Hobart of Pampa."}],"landmarks":[{"landmark_id":"LM063","landmark_blurb":"His Austin home, now the Austin Woman's Club; an Austin Historic Landmark."},{"landmark_id":"LM064","landmark_blurb":"1912 Tillotson College building constructed with his $10,000 donation and named for him; Texas Historical Site."}],"artworks":[],"documents":[],"quotes":[],"statues":[],"slug":"ira-evans-1844"},"X02385":{"id":"X02385","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"display_name":"Francese Abi 'Fannie' Hurlbut Evans","first_name":"Francese","middle_name":"Abi","last_name":"Evans","maiden_name":"Hurlbut","married_names":["Evans"],"nickname":"Fannie","gender":"female"},"birth":{"year":1838,"month":8,"day":8,"city":"Upper Alton","county":"Madison","state":"Illinois","country":"United States"},"baptism":{},"death":{"year":1924,"month":1,"day":30,"country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM186","plot_notes":"Alton Cemetery, Alton IL."},"gender":"female","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"is_easter_egg":false,"descent_paths_to_thomas":0},"parents":{"father_research_notes":"Hurlbut family of Upper Alton IL. Researched: this Hurlbut line appears unrelated to the New England Hurlbut cluster (HD0676-HD0694, I00153 Dr. James Hurlbut, X00422 Anne Wright Hurlbut etc.) already in the Hooker tree — Hooker-tree Hurlbuts are largely New England Connecticut and Vermont; Fannie's Hurlbuts are Illinois. Possible common surname-deep ancestor not investigated. Not built.","mother_research_notes":"Not preserved."},"marriages":[{"marriage_number":1,"spouse_id":"TD0163","date_year":1871,"date_month":7,"location_country":"United States","end_type":"divorce","end_year":1917