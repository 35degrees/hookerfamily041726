arch_sources":[],"artworks":[],"career":[{"role":"Representative","organization":"Connecticut General Court","start_year":1691,"end_year":1703,"notes":"Represented Milford in 15 sessions of the General Court, 1691-1703."}],"military_service":[{"war":"King Philip's War","war_id":"WAR002","rank_start":"Ensign","rank_end":"Captain","rank_year_start":1675,"rank_year_end":1698,"unit":"Milford Militia","notes":"Appointed ensign 1675 at outbreak of King Philip's War. Served in recurring skirmishes with Indians. Rose to captain of Milford militia 1698. Source: Newton Genealogy (Leonard 1915)."}],"bio":{"display_name":"Samuel Newton","first_name":"Samuel","last_name":"Newton","married_names":[]},"documents":[],"slug":"samuel-newton-1646"},"X00097":{"id":"X00097","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"descent_paths_to_thomas":0,"is_progenitor":false},"parents":{"father_research_notes":"Thomas Welch of Milford — one of the Seven Pillars of the Milford church"},"marriages":[{"spouse_id":"X00096","children_ids":["I00091"],"marriage_number":1,"location_country":"United States"},{"marriage_number":2,"spouse_id":"H00011","date_year":1697,"date_month":1,"date_day":1,"location_country":"United States","children_ids":["H00045","HD0007"]}],"cross_connections":[],"sources":[],"gender":"female","tags":[],"number_of_marriages":2,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1660,"month":12,"day":7,"city":"Milford","county":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1723,"month":8,"day":5,"city":"Milford","county":"New Haven","state":"Connecticut","country":"United States"},"burial":{},"is_placeholder":false,"former_ids":[],"baptism":{},"residence":{"country":"United States"},"institutions":[],"landmarks":[],"naming_insp