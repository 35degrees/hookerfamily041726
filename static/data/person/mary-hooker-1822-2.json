_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1762,"month":8,"day":29,"city":"Woodbury","state":"Connecticut"},"parents":{"father_id":"H00262","mother_id":"I00166"},"tags":["clergy","yale_connection"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 514"}],"marriages":[{"spouse_id":"H00940","children_ids":["H01353","H01354","H01355","H01356"],"marriage_number":1,"date_year":1792,"date_month":6,"date_day":11,"location_city":"Stockbridge","location_state":"Massachusetts"}],"orbit_connections":[{"name":"Joseph Harvey (Yale 1809) — succeeded Asahel at Goshen","relationship":"Harvey succeeded Asahel Hooker as pastor at Goshen CT in 1810","notes":"Yale Biographical Sketches (Dexter): \"The Rev. Asahel Hooker (Yale 1789) was dismissed from his pastorate over the Congregational Church of Goshen, in Litchfield County, on June 12, 1810; and Mr. Harvey thereafter supplied the pulpit with such favor that he was unanimously called to the vacant place.\" Also: Joseph Edwards (Yale, graduated c.1806) \"began the study of theology upon graduation with the Rev. Asahel Hooker (Yale 1789), of Goshen, at the same time conducting an academy there.\" Asahel Hooker's Goshen pastorate was evidently a center of theological training in Litchfield County during the early 19th century. (Yale Biographical Sketches of Grads 1805-1815, Dexter 1912; URL: https://www.cga.ct.gov/hco/books/Biographical_Sketches_of_Grads_of_Yale_1805-1815_1912.pdf)","connection_type":"orbit_non_descendant"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"pastor of the church in Goshen until dismissed","primary_url":"https://www.cga.ct.gov/hco/books/Biographical_Sketches_of_Grads_of_Yale_1805-1815_1912.pdf","primary_url_label":"Source"},"death":{},"cross_connections":[],"bio":{"display_name":"Asahel Hooker","first_name":"Asahel","maiden_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1789"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Eighteen years at Goshen, dismissed for ill health","body":"Asahel Hooker was ordained at Goshen, Connecticut on September 7, 1791, and served the congregation as beloved pastor for eighteen years. He was dismissed June 12, 1810 — not over doctrine or congregational conflict, but because his health had broken. Throughout his Goshen tenure he was a published voice in the Connecticut Evangelical Magazine."},{"number":2,"category":"marriage","header":"Married Jonathan Edwards's granddaughter Phebe Edwards","body":"On June 11, 1792 he married Phebe Edwards (H00940), daughter of Hon. Timothy Edwards and granddaughter of Rev. Jonathan Edwards. Like Asahel, Phebe descended from Thomas Hooker — but through Mary Hooker Pierpont's line rather than the surname line. Their son Edward William Hooker would later write the 1849 biography of Thomas Hooker cited as the foundational source by Edward Hooker's 1909 Descendants."},{"number":3,"category":"family","header":"His son wrote the 1849 Thomas Hooker biography","body":"His son Rev. Edward William Hooker (H01354) wrote The Life of Rev. Thomas Hooker in 1849. The biography became the foundational source for nineteenth-century Hooker scholarship and was cited as a primary reference in Edward Hooker's 1909 Descendants of Rev. Thomas Hooker. Edward William inherited the double Hooker descent — surname line through Asahel, Edwards line through his mother Phebe."}],"education":[{"institution_id":"INST022","dates":"1789","notes":" — Yale College 1789. Son of Asahel Hooker (H00262). Congregational pastor at Goshen CT 1791-1810, Norwich CT 1812-1813. Yale Biographical Sketches mention him as the pastor at Goshen when Joseph Harvey (Yale 1809) succeeded him and when Joseph Edwards (Yale student) studied theology with him."}],"slug":"asahel-hooker-1762"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}