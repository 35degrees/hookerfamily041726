lse,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00940","mother_id":"H00514"},"tags":["author","clergy","double_hooker_ancestry","middlebury_graduate","native_american_contact","temperance","educator","minister"],"sources":[{"short":"EH 1909"}],"birth":{"year":1794,"month":11,"day":24,"city":"Goshen","state":"Connecticut","country":"United States"},"death":{"year":1875,"month":3,"day":31,"city":"Fort Atkinson","state":"Wisconsin","country":"United States"},"marriages":[{"spouse_id":"X00711","children_ids":["HD2241","HD2242","HD2243","HD2244","HD2245","HD2246"],"marriage_number":1,"date_year":1821,"location_country":"United States"},{"spouse_id":"X00712","children_ids":[],"marriage_number":2,"date_year":1850,"date_month":11,"date_day":19,"location_city":"Norwich","location_state":"Connecticut","location_country":"United States"}],"gender":"male","notable":{"is_notable":false,"notable_category":[],"notable_blurb":"Double Hooker descendant; ABCFM corporate member","primary_url":"https://en.wikipedia.org/wiki/Edward_William_Hooker"},"narrative_blocks":[{"number":1,"category":"literature","header":"Wrote definitive 1849 biography of Thomas Hooker","body":"In 1849 he published 'The Life of Thomas Hooker' — the foundational biography of his Hartford-founding ancestor. Edward Hooker cited it as a primary authority sixty years later when compiling the 1909 Descendants of Rev Thomas Hooker — the genealogical spine of this entire project."},{"number":2,"category":"family","header":"Hooker descendant through both parents independently","body":"His father descended from Thomas Hooker through the Hooker surname line, while his mother Phebe Edwards descended from the same ancestor through the separate Pierpont-Edwards line — making him a Hooker descendant twice over, through two parallel five-generation paths."},{"number":3,"category":"career","header":"ABCFM corporate member and Middlebury College trustee","body":"He served as a corporate member of the American Board of Commissioners for Foreign Missions from 1840 and as a trustee of Middlebury College from 1834 to 1844. The ABCFM was the leading Protestant foreign-mission engine of the antebellum era; his presence on the corporate board placed him at its strategic center."},{"number":4,"category":"family","header":"Son Elias named for missionary brother-in-law","body":"He named one son Elias Cornelius Hooker for his brother-in-law Rev Elias Cornelius — the ABCFM missionary who had married his sister Mary Ann Hooker. The name kept the missionary calling visible in the next generation, even though Cornelius himself died young in 1832."}],"number_of_marriages":2,"institutions":[{"institution_id":"INST054","institution_blurb":"Middlebury College alumnus."},{"institution_id":"INST041","institution_blurb":"Corporate member of ABCFM from 1840."},{"institution_id":"INST137","relationship":"alumnus","years":"1817","institution_blurb":"Andover Theological Seminary 1817 — ordained Green's Farms CT 1821."}],"cross_connections":[],"bio":{"display_name":"Edward William Hooker","first_name":"Edward","last_name":"Hooker","middle_name":"William","married_names":[],"photo_url":"https://images.findagrave.com/photos/2013/307/96378384_138361708435.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"edward-hooker-1794"},"X00711":{"id":"X00711","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1796},"death":{"year":1850},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H01354","location_country":"United States","children_ids":["HD2241","HD2242",