s":[],"quotes":[],"military_service":[],"slug":"william-walter-1752"},"H00868":{"id":"H00868","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"H00365","mother_id":"X00455"},"tags":[],"sources":[{"short":"Edward Hooker 1909","entry":"868"},{"short":"Pierpont genealogy"}],"birth":{"year":1758,"month":2,"day":22,"city":"North Haven","state":"Connecticut"},"death":{"year":1806},"cross_connections":[],"gender":"female","marriages":[{"spouse_id":"X01651","children_ids":["HD5098","HD5099","HD5100","HD5101","HD5102"],"marriage_number":1}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Theodosia Pierpont Walter","first_name":"Theodosia","last_name":"Walter","maiden_name":"Pierpont","married_names":["Walter"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"death","header":"Daughter Louisa died thirty days after marriage","body":"Theodosia's daughter Louisa Walter married Timothy Bishop on April 3, 1800 — and died on May 3, 1800, just thirty days after the marriage. Louisa was twenty. The compressed marriage-and-death cycle within a single calendar month captured the period's vulnerability to acute disease across all socioeconomic groups, even within the Pierpont-Walter household at New Haven."},{"number":2,"category":"family","header":"Great-granddaughter named Theodocia Pierpont in her honor","body":"A generation after Theodosia's 1806 death, her son William Walter's daughter named her own daughter Theodocia Pierpont Walter Hayden (born August 20, 1817) — honoring the Pierpont great-grandmother through both first name and middle name. The naming carried the Theodosia-and-Pierpont identity forward across three generations of women in the family."},{"number":3,"category":"death","header":"Grandson William Walter Hayden drowned in childhood","body":"Theodosia's great-grandson William Walter Hayden — son of Theodocia Pierpont Walter Hayden — drowned on August 2, 1850 in Windsor Connecticut at age twelve. The cascading family losses — daughter at twenty in 1800, great-granddaughter at twenty in 1838, great-great-grandson at twelve in 1850 — touched four consecutive generations of the Walter-Hayden line."},{"number":4,"category":"family","header":"Born North Haven 1758, died New Haven 1806","body":"Theodosia Pierpont was born February 22, 1758 in North Haven Connecticut and died July 15, 1806 in New Haven Connecticut at age forty-eight. She married William Jay Walter on November 17, 1777 in North East Village, New Haven — he survived her by eighteen years, dying April 19, 1824. Her five documented children were Joel, Louisa, Lovina, Jerry, and William Jr."}],"slug":"theodosia-walter-1758"},"HD5098":{"id":"HD5098","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"generation_from_thomas":7,"is_easter_egg":false},"parents":{"father_id":"X01651","mother_id":"H00868"},"tags":[],"sources":[],"marriages":[],"number_of_marriages":0,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1778,"month":5,"day":28,"city":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1833,"month":1,"day":17,"age":54},"cross_connections":[],"bio":{"display_name":"Joel Walter","first_name":"Joel","last_name":"Walter","married_names":[],"gender":"male"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"joel-walter-1778"},"HD5099":{"id":"HD5099","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"generation_from_thomas":7,"is_easter_egg":false},"parents":{"father_id":"X01651","mother_id":"H00868"},"tags":[],"sources":[],"marriages":[{"marriage_number":1,"spouse_id":"I01294","date_year":1800,"date_month":4,"date_day":3,"children_ids":[]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1780,"month":5,"day":22},"death":{"year":1800,"month":5,"day":3,"age":19},"cross_connections":[],"bio":{"display_name":"Louisa Bishop","first_name":"Louisa","last_name":"Bishop","maiden_name":"Walter","married_names":["Bishop"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died thirty days after her April marriage","body":"Louisa Walter married Timothy Bishop on April 3, 1800 and died on May 3, 1800 at age nineteen — about thirty days after the marriage, with no children. The compressed marriage-and-death cycle within a single calendar month was striking even by the period's standards of vulnerability to acute disease. Her husband Timothy lived another seventy-three years and remarried twice."},{"number":2,"category":"family","header":"Buried Grove Street Cemetery, New Haven","body":"Louisa is buried at Grove Street Cemetery in New Haven, Plot 11 Cypress Avenue East. The cemetery — one of America's first planned burial grounds and a National Historic Landmark — became the family-burial cluster for the Walter-Pierpont line, with her parents William Jay Walter and Theodosia and several siblings later joining her there."}],"slug":"louisa-bishop-1780"},"I01294":{"id":"I01294","has_descendants_documented":false,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{},"tags":["merchant","extraordinary_longevity"],"sources":[],"marriages":[{"marriage_number":1,"spouse_id":"HD5099","date_year":1800,"date_month":4,"date_day":3,"children_ids":[]}],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1777,"month":10,"day":29,"city":"New Haven","state":"Connecticut","country":"United States"},"death":{"year":1873,"month":3,"day":6,"city":"New Haven","state":"Connecticut","country":"United States","age":95},"cross_connections":[],"bio":{"display_name":"Timothy Bishop","first_name":"Timothy","last_name":"Bishop","married_names":[],"gender":"male"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"First wife died thirty days after wedding","body":"Timothy Bishop's first wife Louisa Walter married him on April 3, 1800 and died on May 3, 1800 — about thirty days later, at age nineteen. Timothy was twenty-three at the time. He went on to remarry twice and live another seventy-three years, dying at age ninety-five."},{"number":2,"category":"career","header":"Bank director at age ninety-one","body":"Timothy Bishop was a successful New Haven merchant and member of the Congregational Church. He served as a bank director at age ninety-one — still active in business governance four years before his death. The late-life professional engagement was characteristic of a Connecticut merchant patriarch who outlived three wives."}],"slug":"timothy-bishop-1777"},"HD5100":{"id":"HD5100","has_descendants_documented":