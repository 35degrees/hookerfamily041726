1942,"notes":"Founded the journal as the leading American periodical in medical history; edited 25 years."},{"role":"Editor","organization":"American Journal of the Medical Sciences","location":"Philadelphia, PA","start_year":1901,"end_year":1906},{"role":"Professor of Otology","organization":"University of Pennsylvania","location":"Philadelphia, PA","start_year":1902,"end_year":1921},{"role":"President","organization":"College of Physicians of Philadelphia","location":"Philadelphia, PA","start_year":1931,"end_year":1933,"notes":"Elected Fellow 1897; held Secretary, Honorary Librarian, Vice President posts before presidency. Chaired the Section on Medical History."},{"role":"Otologist and Laryngologist","organization":"Base Hospital No. 10 (Pennsylvania Hospital Unit)","location":"France","start_year":1917,"end_year":1919,"notes":"WWI service. Worked as anesthetist for Charles F. Mitchell during the Passchendaele offensive; Chief Consultant in Otolaryngology for the District of Paris 1918-1919."}],"narrative_blocks":[{"number":1,"category":"career","header":"Founded Annals of Medical History, 1917","body":"He founded and edited the Annals of Medical History from 1917 to 1942 — the leading American periodical in its field. He had previously edited the American Journal of the Medical Sciences from 1901 to 1906 and contributed widely as an otolaryngologist before turning to medical history."},{"number":2,"category":"education","header":"Studied under Sir William Osler at Hopkins","body":"After his M.D. at the University of Pennsylvania in 1892 he went to Johns Hopkins for postgraduate work under Sir William Osler. Their correspondence about the American Journal of the Medical Sciences and Osler's son Revere ran for twenty-five years."},{"number":3,"category":"war","header":"WWI: Otolaryngologist, Base Hospital No. 10","body":"He served as otologist and laryngologist at Base Hospital No. 10 in France during World War I, deploying with the Pennsylvania Hospital Unit. During the Passchendaele offensive he worked as anesthetist for Charles F. Mitchell; later Chief Consultant in Otolaryngology for the District of Paris."},{"number":4,"category":"career","header":"President, College of Physicians 1931-33","body":"He was elected Fellow of the College of Physicians of Philadelphia in 1897 and served as its President from 1931 to 1933, after holding earlier offices including Secretary, Honorary Librarian, and Vice President. He chaired the College's Section on Medical History."}],"slug":"francis-packard-1870"},"HD04863":{"id":"HD04863","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Margaret","last_name":"Packard","maiden_name":"Packard","married_names":[],"gender":"female","display_name":"Margaret Packard"},"birth":{"year":1907,"county":"Philadelphia","state":"Pennsylvania","country":"United States"},"baptism":{},"death":{"year":1994,"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H04337","mother_id":"I01095"},"number_of_marriages":0,"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"margaret-packard-1907"},"HD04864":{"id":"HD04864","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Ann","last_name":"Packard","maiden_name":"Packard","married_names":[],"gender":"female","display_name":"Ann Packard"},"birth":{"year":1908,"county":"Philadelphia","state":"Pennsylvania","