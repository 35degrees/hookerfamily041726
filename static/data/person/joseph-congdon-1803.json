r":1834,"month":12,"day":17,"city":"Freedom","state":"New York","country":"United States"},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"generation_from_john_talcott":6,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H00487","mother_id":"I01023"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01025","date_year":1823,"date_month":10,"date_day":2,"location_country":"United States","children_ids":["HD4759","HD4760","HD4761","HD4762","HD4763","HD4764"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died at thirty; infant Joseph eight months old","body":"Ann Hooker Congdon married Joseph Congdon on October 2, 1823 and bore six children in eleven years; her youngest, Joseph, was born April 17, 1834, and she died December 17 that same year at Freedom, New York, at thirty years old — leaving an eight-month-old infant among her surviving children. Her husband Joseph Congdon outlived her by thirty-eight years, dying at Elmira in 1872; the eldest child she had named 'James Hooker' had himself died nine months before that, in May 1865, leaving her family's history as a study in how early death cascades through a generation."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"ann-congdon-1804"},"HD4759":{"id":"HD4759","bio":{"first_name":"James","middle_name":"Hooker","last_name":"Congdon","display_na