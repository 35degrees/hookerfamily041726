d"],"type":"missionary_society","founding_year":1810,"location":{"city":"Boston","state":"Massachusetts"},"primary_persons":["X00724"],"hooker_connected_people":["X00724","X02121","X02122","T01213","H00527","I01195"],"person_ids":[],"related_institutions":[],"related_landmarks":[],"tags":["native_american_contact","missionary"],"sources":[{"short":"Wikipedia","note":"Elias Cornelius (clergyman); ABCFM"}],"notes":"First American foreign-mission organization. Tree connections: Rev. Elias Cornelius (agent 1816, secretary 1831-32); Ainsworth and Harriet Ellsworth Blunt, missionaries to the Cherokee at Brainerd, Tennessee; Eliza Talcott, missionary to Japan; Rev. William Banfield Capron, Madura mission; Judge John Hooker, member."}},"crossConnections":[]}