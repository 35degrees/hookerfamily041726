:"New Haven County","state":"Connecticut","country":"United States"},"marriages":[{"marriage_number":1,"spouse_id":"X01087","children_ids":[],"date_year":1745,"date_month":9,"date_day":23},{"marriage_number":2,"spouse_id":"H00143","children_ids":["HD0101","HD3797","HD3798","HD3799","HD3800","HD3801","HD3802","HD3803","HD3804","HD3805","HD3806","HD3807"],"date_year":1753,"date_month":8,"date_day":13}],"sources":[{"page":"Entry 44","short":"Whittlesey Genealogy"},{"page":"Entry 143 (as spouse of H00143)","short":"Edward Hooker 1909"}],"gender":"male","tags":["minister","yale_alumni","great_awakening"],"number_of_marriages":2,"parents":{"father_id":"X03182","mother_id":"X03183"},"notable":{"is_notable":false,"notable_category":[],"notable_blurb":null,"primary_url":null,"primary_url_label":null},"death":{"year":1787,"month":7,"day":24,"city":"New Haven","county":"New Haven County","state":"Connecticut","country":"United States"},"cross_connections":[{"type":"civic_peer","display_label":"Ezra Stiles held his hand at death — received a final squeeze","related_id":"HD0346","link_text":"President Ezra Stiles"},{"to_person_id":"HD0346","type":"civic_peer","display_label":"Eulogized at his 1787 deathbed by Yale's Stiles","notes":"President Ezra Stiles (HD0346) attended Whittlesey's 1787 deathbed; per the diary record, Stiles took his hand and asked 'Do you feel now the assurance of hope?' and Chauncey rallied his dying strength to answer 'Yes.' Stiles published a eulogy describing him as 'oracular at college' for breadth of learning. Per Whittlesey Genealogy #88."}],"narrative_blocks":[{"header":"'No more grace than a chair' — Brainerd's verdict","detail":"Brainerd later repented of the comment. President Ezra Stiles had a different assessment of Whittlesey: 'In literature he was in his day oracular at college, for he taught with facility and success in every branch of knowledge.' Whittlesey had graduated Yale in 1738, continued as a resident graduate on Bishop Berkeley's foundation, and served as a tutor from 1739 to 1745 — the very years of the Awakening's height. His diary entry from this period reflects the opposite of Brainerd's caricature: 'Having repeatedly commended my case to God by prayer... I am as yet too little acquainted with God, the Scriptures, human nature in general, and my own heart in particular to venture to undertake the great and important work of the ministry.' (Whittlesey Genealogy)","body":"During the Great Awakening of the 1740s, Yale student David Brainerd declared that Chauncey Whittlesey had 'no more grace than a chair.' Yale expelled Brainerd for it. The Whittlesey genealogy records the remark as evidence of the 'rash, pharisaical, and censorious spirit' of the New Light evangelicals — not of Whittelsey's actual faith.","number":1,"category":"religion"},{"header":"Ezra Stiles at Whittlesey's deathbed, July 1787","detail":"Dr. Dana wrote of Whittlesey's death: 'His old age was amiably splendid as a clear setting sun. His past days looked back upon him with a smile of friendship, and the morning of immortal felicity dawning on his soul gloriously irradiated the valley of death.' Whittlesey had served as minister of First Church New Haven for nearly thirty years (1758–1787), after a decade as a New Haven merchant and colonial assemblyman. The handshake with Stiles — one Yale man to another — was his last act of communication. (Whittlesey Genealogy; EH 1909)","body":"As Whittlesey lay dying in July 1787, his close friend Ezra Stiles — Yale president and Hooker descendant — came to the room. Taking his hand, Stiles asked: 'Do you feel now the assurance of hope? If you would say yes, and cannot speak, answer me by the pressure of your hand.' Whittlesey rallied his dying strength and pressed back.","number":2,"category":"death"},{"number":3,"category":"religion","header":"He preached to the wartime Assembly","body":"On May 14, 1778, with the Revolution undecided, Whittelsey delivered the Election Sermon before Connecticut’s General Assembly on II Samuel 23:3-4 — “the importance of religion in the civil Ruler.” The Assembly ordered it printed and sent Samuel Bishop and Eneas Munson to deliver its formal thanks."}],"bio":{"display_name":"Chauncey Whittlesey","first_name":"Chauncey","last_name":"Whittlesey","married_names":[],"photo_url":"https://images.findagrave.com/photos/2001/156/5002098_991809061.jpg","bio_blurb":"New Haven pastor in the Awakening’s crossfire"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"education":[{"school_name":"Yale College","dates":"1738","type":"college"}],"career":[{"role":"Tutor","organization":"Yale College","start_year":1738},{"role":"Pastor","organization":"First Church of New Haven","end_year":1787}],"slug":"chauncey-whittlesey-1717"},"H00143":{"id":"H00143","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1729,"month":1,"day":27,"city":"Milford","county":"New Haven County","state":"Connecticut","country":"United States"},"death":{"year":1812,"month":10,"day":27,"city":"New Haven","county":"New Haven County","state":"Connecticut","country":"United States"},"marriages":[{"spouse_id":"I00074","children_ids":["HD0101","HD3797","HD3798","HD3799","HD3800","HD3801","HD3802","HD3803","HD3804","HD3805","HD3806","HD3807"],"marriage_number":1,"date_year":1753,"date_month":8,"date_day":13}],"parents":{"father_id":"H00044","mother_id":"I00013"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 143"}],"burial":{"cemetery_id":"CEM014"},"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Martha Newton Whittlesey","first_name":"Martha","last_name":"Whittlesey","married_names":["Whittlesey"],"maiden_name":"Newton"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Twelve documented children with Chauncey Whittlesey","body":"Martha Newton Whittlesey and her husband Chauncey Whittlesey had twelve documented children between 1754 and 1773 — a high birth count even for the colonial-era marriages of leading New England families. Of the twelve, five died before reaching adulthood: Elizabeth (born 1758, died 1758), Elizabeth (born 1760, died 1760), John Bryan (born 1761, died 1763), plus Newton (died 1785 at thirty-one) and Susannah (died 1797 at thirty-one)."},{"number":2,"category":"family","header":"Two consecutive daughters named Elizabeth died young","body":"Martha and Chauncey lost two consecutive daughters both named Elizabeth — one born 1758 died the same year, one born 1760 died the same year. The replacement-naming pattern (same first name given to a later child after an earlier one died young) was characteristic of colonial New England families seeking to preserve a chosen name through high infant mortality. A third Elizabeth, born 1773, finally survived to age ninety-three and never married."},{"number":3,"category":"family","header":"Daughter Susannah married Judge Dyer White","body":"Martha and Chauncey's daughter Susannah Whittlesey (1766-1797) married Judge Dyer White — connecting the Whittlesey line into the Connecticut bench. The Whittlesey family across this generation produced lawyers, judges, military officers, and merchants spreading across New England."},{"number":4,"category":"family","header":"Born Milford 1729, lived to age eighty-three","body":"Martha Newton was born January 27, 1729 in Milford Connecticut, daughter of Colonel Roger Newton, and died October 27, 1812 at age eighty-three. She married Chauncey Whittlesey on August 13, 1753 as his second wife — his first wife Elizabeth Whiting had died October 17, 1751. She survived her husband by many years."}],"slug":"martha-whittlesey-1729"},"X03182":{"id":"X03182","bio":{"display_name":"Rev. Samuel Whittelsey","gender":"male","bio_blurb":"Wallingford’s pastor for forty-two years"},"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"has_descendants_documented":true,"number_of_marriages":1,"tags":["minister","yale_graduate","slaveholder"],"sources":[],"birth":{"year":1686,"city":"Saybrook","state":"Connecticut"},"death":{"year":1752,"month":4,"day":15,"city":"Wallingford","state":"Connecticut"},"notable":{"is_notable":true,"primary_url":"https://books.google.com/books?id=A6vceOAal2oC&pg=PA40","primary_url_label":"Yale Biographical Sketches","notable_blurb":"Wallingford pastor, Yale trustee, Old Light leader","notable_category":["religion","education"]},"education":[{"school_name":"Yale College","dates":"1705","type":"college"}],"career":[{"role":"Pastor","organization":"Wallingford Church","start_year":1710,"end_year":1752},{"role":"Trustee","organization":"Yale College","start_year":1732,"end_year":1752}],"narrative_blocks":[{"number":1,"category":"religion","header":"He preached his own ordination sermon","body":"Ordained colleague pastor at Wallingford on May 17, 1710, Whittelsey preached the ordination sermon himself, from 2 Corinthians iv:7 — and stayed in that one pulpit until his death forty-two years later."},{"number":2,"category":"character","header":"“One of the greatest men in Connecticut”","body":"So Rev. Dr. Charles Chauncy of Boston remembered him in 1768, adding that no one he knew could express difficult thoughts with such clearness and ease. Ezra Stiles, later Yale’s president, drew up the printed character of him that ran in the Boston Postboy."},{"number":3,"category":"moral_complexity","header":"Fourteen times more in servants than books","body":"His probate inventory showed an estate of about £22,000 — a scant hundred pounds of it in books, and fourteen times that amount in enslaved and mulatto servants. The leading Old Light voice of Connecticut was also one of its larger slaveholders."}],"marriages":[{"marriage_number":1,"spouse_id":"X03183","date_year":1712,"date_month":7,"date_day":1,"children_ids":["I00020","I00074"]}],"slug":"rev-samuel-whittelsey-x03182"},"X03183":{"id":"X03183","bio":{"display_name":"Sarah Chauncy Whittelsey","gender":"female"},"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"has_descendants_documented":true,"number_of_marriages":1,"tags":[],"sources":[],"birth":{"year":1683},"death":{"year":1767,"month":10,"day":23,"city":"Wallingford","state":"Connecticut"},"marriages":[{"marriage_number":1,"spouse_id":"X03182","date_year":1712,"date_month":7,"date_day":1,"children_ids":["I00020","I00074"]}],"slug":"sarah-chauncy-whittelsey-x03183"},"H00044":{"id":"H00044","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1685,"city":"Milford","state":"Connecticut"},"death":{"year":1771,"month":1,"day":15,"city":"Milford","state":"Connecticut"},"parents":{"father_id":"H00011","mother_id":"I00008"},"marriages":[{"spouse_id":"I00013","children_ids":["H00141","H00142","H00143","HD0004","HD0005","HD0006"],"marriage_number":1,"end_type":"death_of_survivor","end_year":1776,"date_year":1712,"date_month":4,"date_day":10}],"children_summary":{"total":6,"in_edward_hooker":3,"caroline_newton_only":3,"starred_in_edward_hooker":0,"notes":"No stars in Edward Hooker despite distinguished career — likely incomplete records for this branch. Birth dates for Caroline Newton children all required correction as given dates predate parents' 1712 marriage."},"political_offices":[{"title":"Judge, County Court","dates":"from 1730","has_discrepancy":true,"discrepancy_note":"EH gives 34 years; Families of Early Milford gives 33 years. Unresolved."},{"title":"Chief Judge","dates":"1737 until death 1771","duration_years":34,"has_discrepancy":true,"discrepancy_note":"EH gives 34 years; Families of Early Milford gives 33 years. Unresolved."},{"title":"Assistant","jurisdiction":"Colony of Connecticut","dates":"1738 until death 1771","duration_years":33}],"tags":["military","harvard_graduate","judge","colonial_assistant","louisbourg","queen_annes_war","milford_resident","french_indian_war"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 44"},{"short":"Caroline Gaylord Newton 1914","notes":"Entry 13.5; birth dates for several children required correction"},{"short":"EH 1909","page":"Entry 44 (Roger Newton)"}],"burial":{"cemetery_id":"CEM005","plot_notes":"Buried next to wife Susannah. Tombstone inscription preserved below."},"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[],"notable_blurb":null,"primary_url":null,"primary_url_label":null},"narrative_blocks":[{"number":1,"category":"legacy","header":"He commanded Connecticut’s troops at Louisbourg","body":"Commander of Connecticut troops at the Siege of Louisbourg 1745 — capture of French fortress at Cape Breton Island, one of most significant colonial military victories","migrated_from":"historical_significance"},{"number":2,"category":"legacy","header":"Colonel of the Second Connecticut Regiment","body":"Colonel of the Second Connecticut Regiment","migrated_from":"historical_significance"},{"number":3,"category":"legacy","header":"Chief Judge of County Court 1737-1771 — 34 years","body":"Chief Judge of County Court 1737-1771 — 34 years","migrated_from":"historical_significance"},{"number":4,"category":"legacy","header":"Assistant of Colony of Connecticut 1738-1771 — 33 years","body":"Assistant of Colony of Connecticut 1738-1771 — 33 years","migrated_from":"historical_significance"},{"number":5,"category":"legacy","header":"Harvard graduate; Captain in Queen Anne's War 1709","body":"Harvard graduate; Captain in Queen Anne's War 1709","migrated_from":"historical_significance"},{"number":6,"category":"death","header":"“Newton as steel inflexible from right”","body":"His Milford epitaph closes in verse: “The part the Hero left beneath the skies / Newton as steel inflexible from right / In Faith, in Law, in Equity, in Fight.” He had been thirty-three years a judge and an Assistant of the colony when he died in his eighty-seventh year."}],"cross_connections":[],"education":[{"institution_id":"INST002","notes":"Harvard graduate; year not recorded in sources"}],"military_service":[{"war":"Queen Anne's War","active_in_war":true,"rank":"Captain","dates":"1709-1710","battles":["Expedition of 1709","Expedition of 1710"],"notes":"Distinguished service in both expeditions"},{"war":"King George's War","active_in_war":true,"rank":"Colonel","dates":"1745","role":"Commander of Connecticut troops at Siege of Louisbourg","battles":["Siege of Louisbourg 1745"],"notes":"New England forces captured the French fortress at Cape Breton Island without British regular army support. One of most significant colonial military victories. Many years Colonel of the Second Connecticut Regiment."}],"bio":{"title":"Colonel","display_name":"Col. Roger Newton","first_name":"Roger","last_name":"Newton","married_names":[],"bio_blurb":"Louisbourg commander, judge, Assistant thirty-three years"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions"