6","H00127","H00128"],"marriage_number":1,"date_year":1706,"date_month":6,"date_day":24,"location_country":"United States"}],"gender":"male","tags":["yale_graduate","physician","yale_connection","harvard_graduate"],"number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["education","medicine","law"],"notable_blurb":"Yale's first tutor and first B.A. graduate, 1703","primary_url":"https://historicbuildingsct.com/the-dr-daniel-hooker-house-1725/","primary_url_label":"Historic Buildings CT — Dr. Daniel Hooker House 1725"},"narrative_blocks":[{"number":1,"category":"career","header":"First Yale tutor, B.A. graduate in 1703","body":"He was the first tutor appointed at the Collegiate School (Yale) by first rector Abraham Pierson Jr. — Yale's earliest faculty member. He received his Yale B.A. in 1703, alongside Rev. John Hart who was the first student to graduate."},{"number":2,"category":"military","header":"Surgeon of the Canada expedition, 1711","body":"He served as surgeon of the Massachusetts expedition against Canada in 1711 — the final major military operation of Queen Anne's War. He then returned to Wethersfield to practice medicine and law."},{"number":3,"category":"character","header":"Declined his father's pulpit — chose medicine","body":"After Rev. Samuel Hooker died in 1697, Farmington invited Daniel to succeed his father. He declined the pulpit and chose medicine — studying law alongside it, not to practice but to help patients make their wills."},{"number":4,"category":"education","header":"First Farmington-born man with a college education","body":"He graduated Harvard in 1700, then enrolled at the new Collegiate School in Saybrook to receive its B.A. in 1703. He was the first Farmington-born man to obtain a college education."},{"number":5,"category":"family","header":"Inherited and divided Thomas Hooker's West Hartford farm","body":"He inherited Thomas Hooker's farm in West Hartford and in 1728 deeded it to his sons. The land had been part of the original Hooker grant — passing through three generations from founder to surgeon."}],"institutions":[{"institution_id":"INST022","institution_blurb":"First Yale tutor 1701-1704; first B.A. graduate 1703."},{"institution_id":"INST002","institution_blurb":"Harvard College graduate 1700.","relationship":"alumnus"}],"cross_connections":[{"type":"civic_peer","related_id":"X02127","display_label":"He tutored under Pierson — Yale's first rector.","link_text":"Rev. Abraham Pierson Jr."},{"type":"family_connection","related_id":"H00105","display_label":"His niece married John Hart, his Yale successor","link_text":"Mary Hooker Hart"},{"type":"civic_peer","related_id":"I00137","display_label":"His successor as Yale tutor — second graduate","link_text":"Rev. John Hart"},{"type":"in_law","related_id":"X00055","display_label":"was his father-in-law"}],"residence":{"city":"New Haven","state":"Connecticut","country":"United States"},"career":[{"role":"First Tutor","organization":"Yale College","start_year":1701,"end_year":1703,"notes":"First tutor of Yale Collegiate School. Hired by rector Abraham Pierson Jr. (X02127). Resigned in favor of Rev. John Hart (I00137).","institution_id":"INST022"},{"role":"Physician","organization":"Wethersfield, Connecticut","start_year":1703,"end_year":1742,"notes":"Settled Wethersfield after leaving Yale. Also studied law to help patients make wills — no evidence he practiced law professionally."}],"education":[{"institution_id":"INST002","dates":"1700","type":"graduation","notes":"B.A. Harvard 1700. First Farmington-born man to receive a college education."},{"school_name":"Yale Collegiate School","dates":"1703","type":"graduation","notes":"Received degree at Yale's first commencement 1703. EH says he was \"the first B.A. of Yale\" but also that Rev. John Hart (I00137) was \"nominally the second, but really the first actual student to graduate.\" Daniel was the tutor/faculty; Hart was the first student B.A. Conflict flagged — see research_notes."}],"bio":{"display_name":"Doctor Daniel Hooker","title":"Doctor","first_name":"Daniel","last_name":"Hooker","married_names":[],"bio_blurb":"Yale's first tutor and first B.A. graduate; later a Wethersfield physician"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"daniel-hooker-1679"},"I00050":{"id":"I00050","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1686,"month":7,"day":4,"city":"Waterbury","state":"Connecticut","country":"United States"},"death":{"year":1726,"month":6,"day":15,"city":"Wethersfield","state":"Connecticut","country":"United States"},"parents":{"father_id":"X00055","mother_id":"X00056"},"marriages":[{"spouse_id":"H00036","children_ids":["H00123","H00124","H00125","H00126","H00127","H00128"],"marriage_number":1,"date_year":1706,"date_month":6,"date_day":24,"location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1726}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 36"},{"short":"Warren 1887","full":"Israel P. Warren D.D., The Stanley Families of America (1887)"},{"short":"Gravestone inscription","notes":"Wethersfield Village Cemetery; carved by William Stanclift"}],"burial":{"cemetery_id":"CEM010","plot_notes":"Marker type: gravestone. Original marker survives. Carved by William Stanclift. One of the older surviving carved gravestones in the region."},"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"baptism":{"year":1686,"month":7,"day":4,"city":"Waterbury","state":"Connecticut"},"cross_connections":[],"bio":{"display_name":"Sarah Stanley Hooker","first_name":"Sarah","last_name":"Hooker","married_names":["Hooker"],"maiden_name":"Stanley"},"residence":{},"