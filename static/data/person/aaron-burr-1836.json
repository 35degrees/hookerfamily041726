ducation":[],"slug":"gladys-burr-1887"},"HD1924":{"id":"HD1924","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"generation_from_thomas":7,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1802},"death":{"year":1873},"parents":{"father_id":"H00913","mother_id":"X00619"},"marriages":[{"children_ids":["HD5986","HD5993","HD5994"],"marriage_number":1}],"tags":["parentage_unverified"],"sources":[{"short":"Wikipedia","note":"Aaron Burr; WikiTree"}],"gender":"male","notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"James Aaron Burr","first_name":"James","last_name":"Burr","middle_name":"Aaron","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"number_of_marriages":1,"burial":{"cemetery_id":"CEM678"},"slug":"james-burr-1802"},"H00913":{"id":"H00913","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1756},"death":{"year":1836},"parents":{"father_id":"X00613","mother_id":"H00378"},"marriages":[{"spouse_id":"X00615","children_ids":["HD1911","HD1916","HD1922","HD1923"],"marriage_number":1,"date_year":1782,"date_month":7,"date_day":2,"location_city":"Monmouth","location_state":"New Jersey"},{"spouse_id":"X00616","children_ids":[],"marriage_number":2,"date_year":1833,"date_month":7,"date_day":1},{"spouse_id":"X00619","children_ids":["HD1914","HD1915","HD1917","HD1918","HD1919","HD1920","HD1924"],"marriage_number":3}],"tags":["politician","vice_president","lawyer","senator","revolutionary_war"],"sources":[{"short":"Edward Hooker 1909","entry":"913"}],"additional_children":{"notes":"Children adopted or acknowledged outside of marriages:","children_ids":["HD1917","HD1918","HD1919","HD1920","HD1924"],"details":"Aaron Columbus Burr (HD1917) and Charles Burdett (HD1918) adopted during 1810s-1820s, both reputed biological sons. Frances Ann Burr (HD1919) and Elizabeth Burr (HD1920) acknowledged in Burr's 1835 will."},"cross_connections":[{"type":"family_connection","related_id":"HD0418","display_label":"His grandmother died of dysentery trying to bring him home from Princeton.","link_text":"Sarah Pierpont Edwards"},{"type":"mentor_student","related_id":"X00614","display_label":"His Princeton tutor and brother-in-law; first student at Litchfield Law.","link_text":"Judge Tapping Reeve"},{"type":"family_orbit","related_id":"HD2624","display_label":"Cousin raised together; lodged at her Savannah home twice","link_text":"Maria Edwards"},{"type":"family_orbit","related_id":"X00619","display_label":"mother of several of his children"}],"gender":"male","notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Vice President of the United States","primary_url":"https://en.wikipedia.org/wiki/Aaron_Burr"},"narrative_blocks":[{"number":1,"category":"legacy","header":"Killed Alexander Hamilton in 1804 duel","body":"Shot and mortally wounded Alexander Hamilton in a duel at Weehawken New Jersey on July 11, 1804. Indicted for murder in New York and New Jersey but never tried in either jurisdiction. The duel destroyed Burr's political future and elevated Hamilton to martyrdom in American memory."},{"number":2,"category":"politics","header":"Third Vice President of the United States","body":"Burr tied Thomas Jefferson with seventy-three electoral votes apiece in the 1800 presidential election; the House of Representatives decided the contest on the thirty-sixth ballot. He served as Jefferson's Vice President from 1801 to 1805 and presided over the Senate impeachment trial of Justice Samuel Chase. The 12th Amendment was passed in 1804 as a direct response to the deadlock he had caused."},{"number":3,"category":"law","header":"Tried for treason and acquitted by Marshall","body":"After his vice presidency, Burr was tried for treason in Richmond Virginia in 1807 before Chief Justice John Marshall. The prosecution was personally driven by Jefferson, who accused Burr of plotting to create an independent nation in the American southwest. Marshall's strict definition of treason led to acquittal, and Burr spent 1808 to 1812 in self-imposed European exile."},{"number":4,"category":"military","header":"Continental Army officer at Quebec and Monmouth","body":"Joined the Continental Army in 1775 at age nineteen, serving on Benedict Arnold's grueling expedition to Quebec. Briefly an aide-de-camp to General Washington in 1776, he commanded a regiment at the Battle of Monmouth in 1778. He resigned his commission in 1779 due to recurring ill health that would trouble him through his political career."},{"number":5,"category":"education","header":"First law student of his brother-in-law","body":"After his Princeton studies, Burr read law with Tapping Reeve in Litchfield Connecticut beginning around 1774 — making him the first student of what would become the Litchfield Law School in 1784, the first independent law school in the United States. His sister Sally had married Reeve two years earlier in 1772."},{"number":6,"category":"character","header":"Edward Hooker's 1909 question about his ancestry","body":"In 1909, Edward Hooker himself wrote: 'This query suggests itself: Aaron Burr had behind him Rev. Jonathan Edwards, Rev. James Pierpont, Rev. Samuel Hooker, Rev. Thomas Hooker, and perhaps other Reverends. How then shall we account for the very bad reputation which historians give to Aaron Burr? Has he been misrepresented in history, or is history true and he was simply a personification of this concentration of ultra religious ancestry?'"}],"number_of_marriages":3,"bio":{"display_name":"Aaron Burr Jr.","first_name":"Aaron","last_name":"Burr","suffix":"Jr.","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST115","relationship":"member","institution_blurb":"Member of the Society of the Cincinnati — Revolutionary War officers' hereditary society."},{"institution_id":"INST024","relationship":"alumnus","institution_blurb":"Studied law under brother-in-law Tapping Reeve before enlisting 1775."},{"institution_id":"INST022"},{"institution_id":"INST023"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"title":"Princeton M.A.","organization":"College of New Jersey (Princeton)","dates":"1772","type":"education","notes":"B.A. 1772 from the College of New Jersey, where his father Aaron Burr Sr. had served as president (d. 1757 before Aaron Jr. was two).","institution_id":"INST023"},{"title":"Continental Army officer","organization":"Continental Army","dates":"1775-1779","type":"military","notes":"Served under Benedict Arnold's expedition to Quebec 1775; aide-de-camp to Gen. George Washington briefly 1776; field officer at the Battle of Monmouth 1778. Resigned 1779 due to ill health."},{"title":"Lawyer","dates":"1782-1789","type":"law","notes":"Admitted to the bar in New York 1782 after studying with Tapping Reeve as the first student at the nascent Litchfield Law School. Practiced law in Albany and New York City."},{"title":"New York State Assembly","organization":"New York State Assembly","dates":"1784-1785, 1798-1799","type":"politics","notes":"Served two terms in the New York State Assembly."},{"title":"Attorney General of New York","organization":"State of New York","dates":"1789-1791","type":"law","notes":"Appointed Attorney General of New York by Governor George Clinton."},{"title":"U.S. Senator from New York","organization":"United States Senate","dates":"1791-1797","type":"politics","notes":"Defeated Philip Schuyler (Alexander Hamilton's father-in-law) for the seat — beginning the Burr-Hamilton rivalry that would culminate in the 1804 duel."},{"title":"Vice President of the United States","organization":"United States","dates":"1801-1805","type":"politics","notes":"Third Vice President of the United States under Thomas Jefferson. Originally tied with Jefferson in the 1800 electoral college vote — resolved by the House on the 36th ballot. The Twelfth Amendment (1804) restructured presidential elections in response. As VP he presided over the 1805 impeachment trial of Justice Samuel Chase."},{"title":"Killed Alexander Hamilton in duel","dates":"July 11, 1804","type":"unusual_event","notes":"Killed Alexander Hamilton in a duel at Weehawken, New Jersey on July 11, 1804. Hamilton died July 12. Burr was indicted in NJ and NY but never tried; the political career consequences were severe."},{"title":"Treason trial","organization":"U.S. Circuit Court for Virginia","dates":"1807","type":"law","notes":"Tried for treason 1807 in Richmond VA before Chief Justice John Marshall, accused of plotting to create an independent nation in the southwest. Acquitted. Spent 1808-1812 in self-imposed European exile."},{"title":"New York lawyer (return)","dates":"1812-1836","type":"law","notes":"Returned to New York 1812; resumed law practice quietly. Married wealthy widow Eliza Bowen Jumel in 1833 (separated within months; divorce finalized the day Burr died, 1836)."}],"slug":"aaron-burr-jr-1756"},"X00619":{"id":"X00619","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"birth":{},"death":{},"tags":["parent_non_descendant"],"sources":[{"short":"Wikipedia","note":"Aaron Burr"}],"marriages":[{"marriage_number":1,"spouse_id":"H00913","children_ids":["HD1914","HD1915","HD1917","HD1918","HD1919","HD1920","HD1924"]}],"gender":"male","number_of_marriages":1,"parents":{},"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Haitian-born governess; mother of Aaron Burr's children","primary_url":"https://en.wikipedia.org/wiki/Mary_Emmons","primary_url_label":"Wikipedia"},"cross_connections":[{"type":"family_orbit","related_id":"H00913","display_label":"the Hooker descendant who fathered her children"}],"bio":{"display_name":"Mary Emmons","first_name":"Mary","last_name":"Emmons","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"category":"character","header":"Aaron Burr's secret household companion","body":"Born in Calcutta and brought through Saint-Domingue to America as a servant in the Prevost household, Mary Emmons bore two children by Aaron Burr while he was married to Theodosia. He never publicly acknowledged them in his lifetime.","number":1},{"category":"legacy","header":"Her son became a leading abolitionist","body":"Emmons's son John Pierre Burr ran an Underground Railroad station and helped organize the Pennsylvania Anti-Slavery Society. Her grandson Frank J. Webb wrote one of the earliest novels published by an African American.","number":2}],"slug":"mary-emmons"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}