,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["social_reform"],"notable_blurb":"Maryland suffrage leader and social reformer","primary_url":"https://msa.maryland.gov/msa/educ/exhibits/womenshallfame/html/hooker.html","primary_url_label":"Maryland Women's Hall of Fame"},"parents":{"father_name":"Alfred Augustus Houghton","mother_name":"Caroline Garlinghouse"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H04422","date_year":1905,"date_month":6,"date_day":14,"location_city":"Baltimore","location_state":"Maryland","location_country":"United States","children_ids":["HD5619","HD5620","HD5621","HD5622","HD5623"]}],"education":[{"school_name":"Bryn Mawr College","dates":"1901","type":"undergraduate","notes":"A.B."},{"institution_id":"INST146","type":"medical","notes":"left before finishing"}],"career":[],"military_service":[],"institutions":[{"institution_id":"INST146","relationship":"alumnus","institution_blurb":"Among the first women at Johns Hopkins Medical School; left to marry and pursue reform."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["suffragist","womens_rights","womens_hall_of_fame"],"research_tags":[],"cross_connections":[{"type":"parallel_careers","related_id":"I00170","display_label":"was also a prominent suffrage leader who married a Hooker","link_text":"Isabella Beecher Hooker"}],"narrative_blocks":[{"number":1,"category":"social_reform","header":"Took suffrage to the streets by automobile","body":"She founded Maryland's Just Government League in 1909 and its weekly Maryland Suffrage News in 1912, then carried the cause across the state in open-air meetings held from an automobile. In 1917 she became editor of The Suffragist, the National Woman's Party paper."},{"number":2,"category":"family","header":"Her sister was Katharine Hepburn's mother","body":"Edith and her older sister Katharine Houghton Hepburn were both prominent leaders of the woman-suffrage movement; that sister's daughter was the actress Katharine Hepburn, making Edith the actress's aunt. The Houghton sisters were raised by freethinking parents who championed women's education."},{"number":3,"category":"character","header":"Left Johns Hopkins medicine for a reformer's life","body":"One of the first women admitted to the Johns Hopkins School of Medicine, she left without finishing to marry her classmate Donald Hooker. With him she founded the Guild of St. George, a Baltimore home for unwed mothers and their children."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"edith-houghton-1879"},"HD5619":{"id":"HD5619","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"title":"Doctor","first_name":"Donald","middle_name":"Houghton","last_name":"Hooker","married_names":[],"gender":"male","display_name":"Dr. Donald Houghton Hooker","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780502682/donaldhooker_hflnst.png"},"birth":{"year":1908,"month":9,"day":18,"city":"Baltimore","state":"Maryland","country":"United States"},"baptism":{},"death":{"year":1996,"month":3,"day":31,"city":"Boca Grande","state":"Florida","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM695"},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"H04422","mother_id":"I01359"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01361","date_year":1937,"location_country":"United States","children_ids":["HD5624","HD5625","HD5626","HD5627","HD5628"]}],"education":[{"institution_id":"INST023","dates":"1932","type":"undergraduate","notes":"A.B. chemistry"},{"institution_id":"INST146","dates":"1936","type":"me