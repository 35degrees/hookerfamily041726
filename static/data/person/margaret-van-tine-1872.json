ch_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"helen-kihn-1899"},"I01247":{"id":"I01247","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Wilfred","middle_name":"Langdon","last_name":"Kihn","married_names":[],"extra_names":"Wilfred or William Langdon Kihn; signed paintings 'W. Langdon Kihn'; Blackfeet name 'Zoi-och-ka-tsai-ya' (Chase Enemy in Water).","gender":"male","display_name":"W. Langdon Kihn","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1779590977/kihn_pjtglg.jpg","photo_notes":"Photo provided by Sam Hooker (project compiler)."},"gender":"male","birth":{"year":1898,"month":9,"day":5,"city":"Brooklyn","county":"Kings","state":"New York","country":"United States"},"baptism":{},"death":{"year":1957,"month":12,"day":12,"city":"New London","county":"New London","state":"Connecticut","country":"United States"},"residence":{"city":"Hadlyme","county":"New London","state":"Connecticut","country":"United States"},"burial":{"plot_notes":"Cove Cemetery, Hadlyme, New London County CT. FindAGrave Memorial #135411069."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":true,"notable_category":["artist","illustrator"],"notable_blurb":"Native American portrait painter, National Geographic illustrator","primary_url":"https://en.wikipedia.org/wiki/W._Langdon_Kihn","primary_url_label":"Wikipedia: W. Langdon Kihn"},"parents":{"father_name":"Alfred Charles Kihn","mother_name":"Carrie Lowe Peck"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4970","date_year":1920,"end_type":"death","end_year":1957,"children_ids":["HD4978"]}],"education":[{"school_name":"Boys' High School (Brooklyn)","type":"secondary","notes":"Recognized for artistic talent at Boys' High School in Brooklyn."},{"school_name":"Art Students League of New York","dates":"1916-1917","type":"art","notes":"Pupil of Homer Boss and Winold Reiss. Reiss's influence on Indian portraiture decisively shaped Kihn's career direction."}],"career":[{"role":"Portrait painter (Native American subjects) and illustrator","organization":"Independent / National Geographic Society","start_year":1920,"end_year":1957,"notes":"From 1935 onward, occupied with a pictorial survey in oils of the Indian tribes commissioned by the National Geographic Society — a project that took him from the Atlantic to the Pacific and from Mexico to the Arctic. Also illustrated books including Marius Barbeau's 'Indian Days in the Canadian Rockies' (1923), Frances Carpenter's 'Pocahontas and Her World' (1961), and the children's story 'Flat Tail' by Alice Gall and Fleming Crew (1935). Painted Nathan Hale murals at Hale-Ray High School in Moodus (East Haddam)."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["artist","painter","illustrator"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Brooklyn boy who painted the disappearing tribes","body":"Born in Brooklyn September 5, 1898, son of Alfred Charles Kihn and Carrie Lowe Peck. He attended Boys' High School in Brooklyn where his artistic talent was recognized, and studied 1916–17 at the Art Students League of New York under Homer Boss and Winold Reiss. Reiss's interest in Native American portraiture decisively shaped his career; from 1920 onward Kihn lived intermittently in the Western United States and Canada, documenting tribal cultures he believed were vanishing."},{"number":2,"category":"career","header":"Admitted to the Blackfeet — Chase Enemy in Water","body":"In 1920 the Blackfeet tribe in Montana adopted him as a member, giving him the name 'Zoi-och-ka-tsai-ya' — Chase Enemy in Water. Many of his portraits afterward bore a pictogram of that name alongside his signature. The New York Times in 1922 described his portraits as marvels of incisive characterization, recording the subtle differences of aspect difficult enough to discern in races other than our own."},{"number":3,"category":"career","header":"National Geographic's tribal survey, Atlantic to Arctic","body":"From 1935 on, his principal work was a pictorial survey in oils of the Indian tribes commissioned by the National Geographic Society. The project took him from the Atlantic to the Pacific and from Mexico to the Arctic, and produced many of the colored portraits that ran in the magazine through the late 1930s and 1940s. He also illustrated books for Marius Barbeau and Frances Carpenter."},{"number":4,"category":"family","header":"Tenniel-style Alice murals for his daughter, 1934","body":"He married Helen Van Tine Butler of Meriden in 1920 and settled in Hadlyme, Connecticut. In 1934 he painted Alice in Wonderland murals after the Tenniel style on the walls of his daughter Phyllis's dormered bedroom; the inscription above the bed reads 'A ma chere Phyllis, with fond affection these walls are respectfully inscribed. W."},{"number":5,"category":"politics","header":"1948 Democratic candidate for Connecticut House","body":"Along with writer Donald Barr Chidsey, he stood as a Democratic candidate for the Connecticut House of Representatives from the town of Lyme in the election of November 2, 1948. He continued painting and illustrating until his final illness; he died at Lawrence Memorial Hospital in New London on December 12, 1957, aged fifty-nine."}],"quotes":[],"sources":[{"label":"Wikipedia: W. Langdon Kihn","url":"https://en.wikipedia.org/wiki/W._Langdon_Kihn"},{"label":"FindAGrave Memorial #135411069","url":"https://www.findagrave.com/memorial/135411069/wilfred_langdon-kihn"},{"label":"New York Times — 'Portraits of Native Americans' Wesleyan University Davison Art Center exhibition"}],"research_sources":[],"documents":[],"slug":"wilfred-kihn-1898"},"HD4978":{"id":"HD4978","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Phyllis","last_name":"Kihn","married_names":[],"nickname":"Fifi","gender":"female","display_name":"Phyllis Kihn"},"gender":"female","birth":{"year":1924,"month":2,"day":3,"city":"New York","county":"New York","state":"New York","country":"United States"},"baptism":{},"death":{"year":2004,"month":2,"day":27,"city":"Middletown","county":"Middlesex","state":"Connecticut","country":"United States"},"residence":{"city":"East Haddam","county":"Middlesex","state":"Connecticut","country":"United States"},"burial":{"plot_notes":"Cove Cemetery, Hadlyme CT. FindAGrave Memorial #135411204."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":11,"include_in_path_calculation":true,"descent_paths_to_thomas":2,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I01247","mother_id":"HD4970"},"number_of_marriages":0,"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Slept under her father's Tenniel-style Alice murals","body":"Born February 3, 1924 in New York, only child of W. Langdon Kihn and Helen Van Tine Butler. The dormered bedroom of her Hadlyme childhood home was painted with Alice in Wonderland murals her father gave her in 1934, signed 'A ma chere Phyllis, with fond affection.' She lived at East Haddam through her father's career and devoted herself after his death to keeping his legacy alive — quoted at length in Wesleyan University's 1987 Davison Art Center exhibition of his Native American portraits."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"phyllis-kihn-1924"},"HD4971":{"id":"HD4971","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Margaret","middle_name":"J.","last_name":"Yando","maiden_name":"Butler","married_names":["Yando"],"gender":"female","display_name":"Margaret Butler Yando"},"gender":"female","birth":{"year":1900,"city":"Meriden","county":"New Haven","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1993,"month":8,"day":28,"city":"East Providence","county":"Providence","state":"Rhode Island","country":"United States"},"residence":{"city":"Pawtucket","county":"Providence","state":"Rhode Island","country":"United States"},"burial":{"plot_notes":"Swan Point Cemetery, Providence RI. FindAGrave Memorial #156013135."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"include_in_path_calculation":true,"descent_paths_to_thomas":2,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"HD4968","mother_id":"I01245"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01252","end_type":"death_of_spouse","end_year":1989,"children_ids":["HD4979"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["extraordinary_longevity"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"margaret-yando-1900"},"I01252":{"id":"I01252","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Wesley","middle_name":"William","last_name":"Yando","married_names":[],"gender":"male","display_name":"Wesley William Yando"},"gender":"male","birth":{"year"