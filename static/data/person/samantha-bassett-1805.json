 Democratic National Convention in St. Louis 1888; President of the Tennessee Bar Association; Vice President of the American Bar Association 1907-1912; Grand Master of Tennessee Freemasons. Author of The Handbook of the Law of Public Corporations — still referenced today.","body":"Yale 1863; Civil War private; appointed Tennessee Supreme Court 1879; Dean of UT Law 1891-1914; VP of the American Bar Association 1907-1912.","number":2}],"number_of_marriages":1,"cross_connections":[],"bio":{"display_name":"Judge Henry Hulbert Ingersoll","title":"Judge","first_name":"Henry","last_name":"Ingersoll","middle_name":"Hulbert","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"henry-ingersoll-1844"},"X00603":{"id":"X00603","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1847},"death":{"year":1915},"tags":[],"sources":[],"marriages":[{"spouse_id":"HD1867","children_ids":["HD1868"],"marriage_number":1,"date_year":1864}],"gender":"female","number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Emily Gertrude Rogers","first_name":"Emily","middle_name":"Gertrude","maiden_name":"Rogers","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"emily-rogers-1847"},"HD1868":{"id":"HD1868","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_ta