om_thomas":10},"bio":{"display_name":"Margaret Wendell \"Gretchen\" Strong","first_name":"Margaret Wendell","last_name":"Strong","married_names":[],"nickname":"Gretchen","bio_blurb":"Subject of a Frank Benson portrait, c.1909"},"parents":{"father_id":"I01845","mother_id":"HD6564"},"tags":[],"marriages":[],"birth":{"year":1894,"date_precision":"year_only"},"artworks":[{"artwork_id":"ART105"}],"slug":"margaret-wendell-strong-1894"},"HD6557":{"id":"HD6557","classification":{"is_thomas_descendant":true,"is_easter_egg":false,"is_talcott_descendant":false,"generation_from_thomas":8},"bio":{"display_name":"Dr. John Phillips Reynolds","first_name":"John Phillips","last_name":"Reynolds","title":"Dr.","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781557537/drjon_p946kz.png","bio_blurb":"Harvard professor of obstetrics for over twenty years"},"birth":{"year":1825,"month":11,"day":20,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"exact"},"death":{"year":1909,"month":10,"day":10,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"exact"},"parents":{"father_id":"HD6556","mother_id":"I01831"},"tags":["physician","harvard_graduate"],"burial":{"cemetery_id":"CEM110"},"notable":{"is_notable":true,"notable_category":["medicine"],"notable_blurb":"Harvard professor of obstetrics; physician in Boston","primary_url":"https://collections.countway.harvard.edu/onview/items/show/3686","primary_url_label":"Harvard Countway Library"},"education":[{"institution_id":"INST133","school_name":null,"dates":null,"type":"student"},{"institution_id":"INST002","school_name":null,"dates":"1845","type":"undergraduate","notes":"A.B."},{"institution_id":"INST171","school_name":null,"dates":"1852","type":"medical","notes":"M.D."}],"career":[{"role":"Assistant master","organization":"Boston Latin School","start_year":null,"end_year":null},{"role":"Professor of Obstetrics","organization":"Harvard Medical School","start_year":null,"end_year":1885}],"narrative_blocks":[{"number":1,"category":"science","header":"A classicist pressed into the family trade","body":"Reynolds excelled in the classics at Boston Latin and taught there two years before his father pressed him into Harvard Medical School. He took to obstetrics, and held the Harvard chair in the subject for more than two decades until 1885."},{"number":2,"category":"family","header":"He married a granddaughter of Paul Revere","body":"In 1859 Reynolds married Jane Minot Revere, granddaughter of the Revolutionary silversmith. The match folded the Revere line into a family already two generations deep in Boston medicine, with his father the founding surgeon of the eye-and-ear infirmary."},{"number":3,"category":"character","header":"His own grandson couldn’t name his colleagues","body":"A book of his medical correspondence passed to a grandson who, in 1913, wrote the hospital librarian that he could not vouch for the handwritten list of names inside or recognize the hand. The doctor’s working world had grown unreadable within two generations."}],"marriages":[{"spouse_id":"I01832","marriage_number":1,"date_year":1859,"children_ids":["HD6563","HD6564","HD6558","HD6565","HD6566","HD6567","HD6568","HD6569"]}],"cross_connections":[{"type":"family_orbit","related_id":"X03377","link_text":"Joseph Warren Revere","display_label":"his father-in-law, who ran the Revere copper works"}],"slug":"john-phillips-reynolds-1825"},"I01832":{"id":"I01832","classification":{"is_thomas_descendant":false,"is_easter_egg":false,"is_talcott_descendant":false,"generation_from_thomas":null},"bio":{"display_name":"Jane Minot Revere Reynolds","first_name":"Jane Minot","maiden_name":"Revere","last_name":"Reynolds","married_names":["Reynolds"],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781557106/147349069_c33ad113-e089-4369-8b36-126d5d693a53_zb5k1j.jpg","bio_blurb":"Granddaughter of Paul Revere; Boston matriarch"},"birth":{"year":1835,"month":6,"day":20,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"exact"},"death":{"year":1910,"month":5,"day":21,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"exact"},"parents":{"father_id":"X03377","mother_id":"X03381"},"tags":[],"burial":{"cemetery_id":"CEM110"},"marriages":[{"spouse_id":"HD6557","marriage_number":1,"date_year":1859,"children_ids":["HD6563","HD6564","HD6558","HD6565","HD6566","HD6567","HD6568","HD6569"]}],"narrative_blocks":[{"number":1,"category":"family","header":"Through her, the Revere name entered Boston medicine","body":"Jane Minot Revere was a granddaughter of Paul Revere and daughter of the copper magnate Joseph Warren Revere. Her 1859 marriage to Dr. John Phillips Reynolds braided the Revere line into three generations of Boston physicians."},{"number":2,"category":"legacy","header":"Her son bought back the Revere house","body":"Among Jane’s eight children was John Phillips Reynolds Jr., who in 1902 purchased and preserved her grandfather’s house in Boston’s North End. The Revere ancestry she carried became the cause that defined his life."},{"number":3,"category":"family","header":"Her name carried two Boston dynasties","body":"Jane Minot Revere bore the names of two old Boston families, the Minots and the Reveres, at the moment they joined the medical Reynoldses. Her children’s names, Paul Revere Reynolds and Mary Robbins Reynolds among them, kept the ancestry deliberately visible."}],"slug":"jane-minot-revere-1835"},"HD6556":{"id":"HD6556","classification":{"is_thomas_descendant":true,"is_easter_egg":false,"is_talcott_descendant":false,"generation_from_thomas":7},"bio":{"display_name":"Dr. Edward Reynolds","first_name":"Edward","last_name":"Reynolds","title":"Dr.","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781556836/124588344_70b6d0b8-906d-473c-9544-6cfc200cd5c2_d70asq.jpg","bio_blurb":"Co-founder of the Massachusetts Eye and Ear Infirmary"},"birth":{"year":1793,"month":2,"day":28,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"exact"},"death":{"year":1881,"month":12,"day":25,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"exact"},"parents":{"father_id":"HD0267","mother_id":"I01830"},"tags":["physician","harvard_graduate"],"burial":{"cemetery_id":"CEM110"},"notable":{"is_notable":true,"notable_category":["medicine"],"notable_blurb":"Founded the Massachusetts Eye and Ear Infirmary, 1824","primary_url":"https://masseyeandear.org/200","primary_url_label":"Mass. Eye and Ear"},"education":[{"institution_id":"INST002","school_name":null,"dates":"1811","type":"undergraduate","notes":"A.B."},{"institution_id":null,"school_name":"Studied under Dr. John Collins Warren","dates":null,"type":"student","notes":"Medicine"},{"institution_id":null,"school_name":"Brown / Bowdoin (honorary)","dates":"1825","type":"honorary","notes":"M.D. (hon.)"}],"career":[{"role":"Ophthalmic and general surgeon","organization":"Boston","start_year":null,"end_year":null},{"role":"Co-founder","organization":"Massachusetts Eye and Ear Infirmary","start_year":1824,"end_year":null}],"narrative_blocks":[{"number":1,"category":"science","header":"He brought European eye surgery home to Boston","body":"After training under John Collins Warren, Reynolds crossed to London to study the eye under William Lawrence and surgery under Astley Cooper and Abernethy, then to Paris under Bichat and Dupuytren. He returned among the first Americans equipped to practice the new ophthalmic surgery."},{"number":2,"category":"science","header":"His infirmary still runs two centuries on","body":"In 1824 Reynolds and John Jeffries opened a charity eye clinic that became the Massachusetts Eye and Ear Infirmary, the first of its kind in the country and now past its bicentennial. It made the diseases of the eye and ear a recognized American specialty."},{"number":3,"category":"science","header":"Seventy years of practice, one cased portrait","body":"Reynolds practiced for more than seventy years, long enough that the colleagues of his prime had nearly all died before him. He survives in a single daguerreotype of the Society for Medical Improvement, the twelve Boston physicians who met to dissect each other’s hardest cases."},{"number":4,"category":"family","header":"He married the first Boston mayor’s daughter","body":"In 1825 Reynolds wed Margaret Wendell Phillips, daughter of John Phillips, Boston’s first mayor. Her younger brother Wendell Phillips would become the era’s most famous abolitionist orator, a connection Reynolds married into at the height of his surgical fame."}],"marriages":[{"spouse_id":"I01831","marriage_number":1,"date_year":1825,"children_ids":[]}],"artworks":[{"artwork_id":"ART102"}],"cross_connections":[{"type":"parallel_careers","related_id":"X03099","link_text":"Dr. Edward Wigglesworth","display_label":"who likewise founded a Boston specialty clinic and a medical library"}],"videos":[{"video_id":"VID013"}],"slug":"edward-reynolds-1793"},"I01831":{"id":"I01831","classification":{"is_thomas_descendant":false,"is_easter_egg":false,"is_talcott_descendant":false,"generation_from_thomas":null},"bio":{"display_name":"Margaret Wendell Phillips Reynolds","first_name":"Margaret Wendell","maiden_name":"Phillips","last_name":"Reynolds","married_names":["Reynolds"],"bio_blurb":"Daughter of Boston’s first mayor; Reynolds matriarch"},"birth":{"year":1802,"month":11,"day":29,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"approximate"},"death":{"year":1867,"month":6,"day":18,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"exact"},"parents":{"father_id":"X03382","mother_id":null},"tags":[],"marriages":[{"spouse_id":"HD6556","marriage_number":1,"date_year":1825,"children_ids":[]}],"narrative_blocks":[{"number":1,"category":"family","header":"Her brother was abolition’s loudest voice","body":"Margaret married into the Reynolds medical family, but her younger brother Wendell Phillips became the most celebrated abolitionist orator in America. Their father, John Phillips, was the first mayor of Boston."},{"number":2,"category":"family","header":"She linked a mayor’s house to a surgeon’s","body":"Daughter of Boston’s first mayor, Margaret married the founding surgeon of the Massachusetts Eye and Ear Infirmary. Their son carried both legacies into a Harvard professorship in obstetrics."}],"cross_connections":[{"type":"family_orbit","related_id":"X03383","link_text":"Wendell Phillips","display_label":"her brother, the abolitionist orator"}],"slug":"margaret-wendell-phillips-1802"},"X03377":{"id":"X03377","classification":{"is_thomas_descendant":false,"is_easter_egg":true,"is_talcott_descendant":false,"generation_from_thomas":null},"bio":{"display_name":"Joseph Warren Revere","first_name":"Joseph Warren","last_name":"Revere","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781557920/89378812_f91d55b4-a188-4b0d-bf20-0285192eca3a_abibth.jpg","bio_blurb":"Son of Paul Revere; president of Revere Copper"},"birth":{"year":1777,"month":4,"day":30,"city":"Boston","state":"Massachusetts","country":"United States","date_precision":"exact"},"death":{"year":1868,"month":10,"day":11,"city":"Canton","state":"Massachusetts","country":"United States","date_precision":"exact"},"parents":{"father_id":"X03378","mother_id":"X03380"},"tags":["extraordinary_longevity"],"burial":{"cemetery_id":"CEM110"},"notable":{"is_notable":true,"notable_category":["business"],"notable_blurb":"Ran Revere Copper; pioneered rolled-copper sheets","primary_url":"https://en.wikipedia.org/wiki/Joseph_Warren_Revere_(businessman)","primary_url_label":"Wikipedia"},"narrative_blocks":[{"number":1,"category":"business","header":"He turned his father’s mill into an empire","body":"Named for the Bunker Hill martyr who sent his father on the midnight ride, Joseph Warren Revere took over the Canton copper works in 1811 and built Revere Copper into a major industrial concern. He perfected the rolling of copper into large sheets for sheathing ships."},{"number":2,"category":"family","header":"His sons fell at Antietam and Gettysburg","body":"Two of his children died in the Civil War — assistant surgeon Edward at Antietam and Colonel Paul Joseph Revere of wounds after Gettysburg. His daughter Jane married into the Boston Reynolds family of physicians."},{"number":3,"category":"arts","header":"He commissioned matching portraits of father and son","body":"In 1813 Joseph commissioned Gilbert Stuart to paint his 78-year-old father Paul Revere, and sat for a companion portrait in the same pose. The pair of paintings, now at the Museum of Fine Arts, attests to the bond between them."},{"number":4,"category":"family","header":"He married a lieutenant governor’s daughter","body":"In 1821 Joseph married Mary Robbins, daughter of Edward Hutchinson Robbins, a former lieutenant governor of Massachusetts. The match tied the self-made Revere copper fortune to one of the colony’s old governing families."}],"marriages":[{"spouse_id":"X03381","marriage_number":1,"date_year":1821,"children_ids":["I01832"]}],"cross_connections":[{"type":"family_orbit","related_id":"HD6557","link_text":"Dr. John Phillips Reynolds","display_label":"his son-in-law, the Harvard obstetrics professor"}],"artworks":[{"artwork_id":"ART099"}],"videos":[{"video_id":"VID016"}],"slug":"joseph-warren-revere-1777"},"X03381":{"id":"X03381","classification":{"is_thomas_descendant":false,"is_easter_egg":false,"is_talcott_descendant":false,"generation_from_thomas":null},"bio":{"display_name":"Mary Robbins Revere","first_name":"Mary","maiden_name":"Robbins","last_name":"Revere","married_names":["Revere"],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1781558132/89378908_bd73520e-2553-454c-b2c8-0b44c9e16714_ybhzvs.jpg","gender":"female"},