 the Hooker-line Connecticut center."},{"number":2,"category":"family","header":"Presumed daughter's line reconverged Hooker branches","body":"Through Laura E. Hooker Shader — Myron's presumed daughter by first wife Sally Brooks — the line runs forward to Caroline E. Shader who married Thomas Harvey Hooker, descendant of Myron's half-brother Thomas Gould Hooker. That third-cousin marriage between two branches of Captain Thomas Hooker's descendants reconverged a line that had split four generations earlier. Their child Charles Theodore Hooker qualifies as double Hooker ancestry."}],"cross_connections":[],"burial":{"plot_notes":"Greenwood Cemetery, Kendall, Orleans County NY (per WikiTree). Cemetery not yet built as separate CEM entry."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"myron-hooker-1788"},"H01273":{"id":"H01273","former_ids":[],"is_placeholder":false,"gender":"female","has_descendants_documented":false,"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"is_easter_egg":false,"include_in_path_calculation":true,"descent_from_thomas_hooker":true},"bio":{"first_name":"Philomela","last_name":"Snyder","maiden_name":"Hooker","married_names":["Snyder"],"gender":"female","display_name":"Philomela Hooker Snyder"},"birth":{"year":1789,"month":10,"day":14,"state":"Vermont","country":"United States"},"death":{"year":1869,"country":"United States"},"parents":{"father_id":"H00491","mother_id":"X01958"},"marriages":[],"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 1273"}],"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[],"cross_connections":[],"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":