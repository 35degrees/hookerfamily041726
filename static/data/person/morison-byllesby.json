n."},{"number":4,"category":"family","header":"Six children; only surviving child of father","body":"Elizabeth had six documented children with Rev. Byllesby: Ruth Ellis (1865), Lewis Smith, Edward Ellis (1868-1868 cholera), Ellis Buchanan (1872), Langton (1873), and Sarah Elizabeth (1875). At her father Dr. Edward Ellis's 1885 death his obituary noted 'He leaves but one child, Mrs. Byllesby' — confirming Elizabeth was his only surviving child despite his multiple marriages."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"elizabeth-byllesby-1843"},"HD4254":{"id":"HD4254","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Ruth","middle_name":"Ellis","last_name":"Byllesby","married_names":[],"gender":"female","display_name":"Ruth Ellis Byllesby"},"birth":{"year":1865,"month":3,"day":9,"state":"Pennsylvania","country":"United States"},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I01293","father_name":"Rev. Morison Byllesby","mother_id":"HD4243"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["pennsylvania_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"ruth-byllesby-1865"},"HD4255":{"id":"HD4255","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Lewis","middle_name":"Smith","last_name":"Byllesby","married_names":[],"gender":"male","display_name":"Lewis Smith Byllesby"},"birth":{},"baptism":{},"d