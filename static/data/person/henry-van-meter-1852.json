t_name":"Hooker","suffix":"No. 2","middle_name":"Allin","married_names":[],"gender":"male"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[{"name_element":"Alexander Allin","description":"Named for his dead half-brother Alexander Allin Hooker (b.1763; d.1781; FAG 22532503), son of Capt. James Hooker's second wife Hannah Allin — a memorial naming that also honors the Allin family name carried through Capt. James's second wife."}],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"War of 1812","war_id":"WAR009","rank":"Soldier","unit":"Unknown — service documented in son's obituary","years":"c.1812-1815","notes":"Fought at Battle of Lundy's Lane (July 25, 1814) and Battle of Queenston Heights (Oct 13, 1812). Documented in obituary of his son Capt. James Henry Hooker, Rochester newspaper, March 1907: 'His father, Alexander B. Hooker, served in the war of 1812, fighting in the battles of Lundy's Lane, Queenstown, and others.'"}],"career":[{"role":"Farmer","organization":"Rochester, New York"}],"burial":{"cemetery_id":"CEM454","plot_notes":"Hooker Cemetery — land he deeded to Irondequoit in 1840; family plot survived 1950s accidental destruction"},"narrative_blocks":[{"number":1,"category":"career","header":"Pioneer settler who gave Irondequoit its Hooker Cemetery","body":"Alexander Allin Hooker arrived in the Rochester area in 1816 — with his brother Horace — to visit their sister Dolly (Dolly Goodwin Hooker Strong, who had recently married and settled in Canandaigua) and stayed to open a general store that lasted three years; by 1828 he had purchased Jesse Tainter's farm and by 1839 he was Irondequoit's first Town Clerk, and in 1840 he deeded land that became Hooker Cemetery to the town. His family burial plot there is one of the few in the cemetery to survive intact when the town accidentally destroyed most of the grounds in the 1950s, leaving his stone among the more legible remnants of the family that gave Irondequoit its first civic institutions."},{"number":2,"category":"military","header":"Fought at Lundy's Lane before founding Irondequoit","body":"Before settling in the Rochester area, Alexander Allin Hooker served in the War of 1812, fighting at the battles of Lundy's Lane (July 25, 1814, one of the bloodiest engagements on the Canadian border) and Queenston Heights — service documented in his son's 1907 newspaper obituary, which called him 'a soldier' who 'served in the war of 1812, fighting in the battles of Lundy's Lane, Queenstown, and others.' He came to Rochester in 1816, the year after the war ended, and within two decades had deeded a cemetery and founded a town — a veteran who became a civic patriarch."},{"number":3,"category":"character","header":"An old Indian trail passed behind his cemetery","body":"The burying ground Alexander Hooker made public in 1840 sat on a sandy knoll traversed by an Old Indian Trail that ran from the Seneca Village on Boughton Hill (near Victor, New York) to the Indian Landing at the mouth of the Genesee River — meaning the Hooker Cemetery was not merely a settler burial ground but sat astride an ancient Seneca thoroughfare, and likely contains Seneca burials alongside those of the earliest European settlers. It is estimated that perhaps a thousand people are buried in the one-and-a-half acres, most without markers, interred by pioneers under pine and oak trees before the ground was formally enclosed."}],"slug":"alexander-hooker-1789"},"I00901":{"id":"I00901","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Lucy","middle_name":"Case","last_name":"Hooker","maiden_name":"Case","married_names":["Hooker"],"gender":"female","display_name":"Lucy Case Hooker"},"birth":{"year":1800,"country":"United States"},"baptism":{},"death":{"year":1885,"month":7,"day":26,"country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM454","plot_notes":"Hooker Cemetery Irondequoit — inscription: \"She acted well her part and sleeps in Jesus\""},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00796","date_year":1820,"date_month":3,"date_day":23,"location_country":"United States","children_ids":["H02022","H02023","H02024","H02025","H02026","H02027","H02028","H02029"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"lucy-case-1800"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}