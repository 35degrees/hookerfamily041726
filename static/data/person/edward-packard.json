rs","start_year":1976,"end_year":1992,"notes":"Retired 1992."}],"military_service":[{"war":"World War II","war_id":"WAR008","rank":"Unknown","notes":"Veteran per obituary. Specific WWII service not detailed."},{"war":"Korean War","war_id":"WAR014","rank":"Flight Surgeon","rank_end":"Flight Surgeon","rank_year_end":1954,"unit":"U.S. Navy","notes":"Naval flight surgeon. Completed military service 1954."}],"institutions":[{"institution_id":"INST022","relationship":"alumnus","institution_blurb":"Yale University graduate; went on to Harvard Medical School and a distinguished career in cardiology and public health."},{"institution_id":"INST002","relationship":"alumnus","institution_blurb":"Harvard Medical School graduate; interned Columbia-Presbyterian; resident Peter Bent Brigham Hospital."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["wwii","korean_war","navy","physician","yale_graduate","living_or_recent"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Yale, Harvard Medical, Korean flight surgeon","body":"John Mallory Packard graduated from Yale University and Harvard Medical School, interned at Columbia-Presbyterian, and completed military service as a naval flight surgeon in the Korean War before beginning private practice in cardiology and internal medicine in Pensacola in 1954. He went on to co-found the College of Community Health Services at the University of Alabama, served as president of the Alabama Heart Association and Birmingham Academy of Medicine, and was active in genealogical societies — a member of the New England Historic Genealogical Society and the Sons of the American Revolution."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"john-packard-1920"},"HD4422":{"id":"HD4422","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Ann","last_name":"Ladd","maiden_name":"Packard","married_names":["Ladd"],"gender":"femal