ndmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"category":"military","header":"He marched in the Berkshire County militia","body":"Elihu Parsons served as a private in the Berkshire County militia during the Revolution, under Captain Ezra Whittlesey and Colonel John Brown. He is recognized as a patriot ancestor by the Daughters of the American Revolution.","number":1},{"category":"marriage","header":"He married a daughter of Jonathan Edwards","body":"In 1750 Parsons wed Sarah Edwards, a daughter of the theologian Jonathan Edwards, and the couple raised eleven children at Stockbridge. He lived as an esquire in the western Massachusetts hills.","number":2}],"slug":"elihu-parsons-1719"},"H00376":{"id":"H00376","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1728,"month":8,"day":25,"city":"Northampton","state":"Massachusetts"},"death":{"year":1805,"month":5,"day":15,"city":"Goshen","state":"Massachusetts"},"parents":{"father_id":"X00128","mother_id":"HD0418"},"tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 376"},{"label":"Salt of the Earth — David Brainerd and Jerusha Edwards: A Colonial Love Story","url":"https://salt-ofthe-earth.blogspot.com/2013/02/david-brainerd-and-jerusha-edwards.html"}],"marriages":[{"spouse_id":"X00536","children_ids":["H00901","H00902","H00903","H00904","H00905","H00906","H00907","H00908","H00909","H00910","H00911"],"marriage_number":1,"date_year":1750,"date_month":6,"date_day":11}],"cross_connections":[{"type":"family_connection","notes":"The coincidence of two daughters marrying two Ingersolls in the same period and region (Berkshire County MA) likely reflects the prominence of the Ingersoll family in that area. (DAR records; FindAGrave)","related_id":"H00905","disp