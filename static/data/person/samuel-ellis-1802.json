riage both died young."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"luthena-lyman-1828"},"I00663":{"id":"I00663","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"John","middle_name":"Burt","last_name":"Lyman","suffix":"Jr.","married_names":[],"gender":"male","display_name":"John Burt Lyman Jr."},"birth":{"year":1825,"month":12,"day":29,"city":"Norwich (now Huntington)","county":"Hampshire County","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1864,"month":5,"day":22,"city":"Fredericksburg","county":"City of Fredericksburg","state":"Virginia","country":"United States","cause":"Killed in action / died of wounds during Grant's Overland Campaign"},"residence":{},"burial":{"cemetery_id":"CEM348","plot_notes":"Norwich Hill Cemetery Huntington MA — body returned home from Virginia after Civil War death."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_name":"Deacon John Burt Lyman Sr.","mother_name":"Ruth Strong Lyman","father_research_notes":"Deacon John Burt Lyman Sr. (1792-1876) — per FA #121993556. Not built per Jalapeño Rule.","mother_research_notes":"Ruth Strong Lyman (1783-1856) — per FA #121993530. POTENTIAL HOOKER DESCENDANT through the extensive Strong family Hooker connections at Northampton MA (43 Strong-surname Hooker descendants in tree). Sam flagged 'cousins through ruth maybe?' — if Ruth Strong descends from the Asahel Strong / Sarah Hooker Strong line, this marriage could be a within-tree cousin marriage. Lineage of this Ruth Strong (b.1783) not yet verified. Not built per Jalapeño Rule pending research."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4245","date_year":1850,"location_state":"Massachusetts","location_country":"United States","end_type":"death_of_spouse","end_year":1861,"children_ids":["HD4266","HD4267","HD4268"]}],"education":[],"career":[],"military_service":[{"war":"American Civil War","war_id":"WAR006","rank_year_end":1864,"unit":"Massachusetts regiment (specific unit undocumented; Hampshire County MA recruitment)","notes":"Civil War veteran (per FA 'Veteran' designation). Died of wounds May 22, 1864 at Fredericksburg Virginia field hospital depot — one day after the Battle of Spotsylvania Court House officially ended (May 8-21). Wounded at Spotsylvania during Grant's Overland Campaign and transported to the Fredericksburg hospital depot, where he died. The Overland Campaign timeline: Battle of the Wilderness May 5-7, Spotsylvania Court House May 8-21, North Anna May 23-26 — Fredericksburg was the major Union field hospital depot receiving wounded from all these battles."}],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["civil_war","massachusetts_migration","killed_in_action"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"military","header":"Civil War death at Fredericksburg, May 22 1864","body":"John Burt Lyman Jr was wounded at Spotsylvania Court House during Grant's Overland Campaign and died of his wounds at the Fredericksburg Virginia field hospital depot on May 22, 1864 — one day after the battle officially ended. He was thirty-eight years old. His body was returned to Massachusetts and buried at Norwich Hill Cemetery Huntington."},{"number":2,"category":"family","header":"Three young orphans left by his battlefield death","body":"His wife Luthena had died at Northampton three years earlier in August 1861. His Civil War death therefore left their three children fully orphaned — the eldest son Asahel Hubert only eleven, the youngest daughter Catherine 'Katie' just four. Their middle child Elbert had already died in infancy in 1851."}],"quotes":[],"sources":[{"label":"FindAGrave memorial #120362403","url":"https://www.findagrave.com/memorial/120362403/john_burt-lyman"}],"research_sources":[],"documents":[],"slug":"john-lyman-jr-1825"},"HD4266":{"id":"HD4266","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Elbert","last_name":"Lyman","married_names":[],"gender":"male","display_name":"Elbert Lyman"},"birth":{"year":1851,"city":"Norwich","county":"Hampshire County","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1851,"city":"Norwich","county":"Hampshire County","state":"Massachusetts","country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00663","mother_id":"HD4245"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_in_infancy","massachusetts_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"elbert-lyman-1851"},"HD4267":{"id":"HD4267","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Asahel","middle_name":"Hubert","last_name":"Lyman","married_names":[],"gender":"male","display_name":"Asahel Hubert Lyman"},"birth":{"year":1853,"month":4,"day":17,"city":"Norwich (now Huntington)","county":"Hampshire County","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1896,"city":"Manistee Township","county":"Manistee County","state":"Michigan","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM341","plot_notes":"Oak Grove Cemetery, Manistee Manistee Co MI — same cemetery where his uncle Dr. Lathrop Stiles Ellis (HD4244) is buried."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00663","mother_id":"HD4245"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"TD0233","location_country":"United States","end_type":"death","end_year":1896,"children_ids":[]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Asahel","description":"First name Asahel — common Strong family name (the Northampton MA Strong-Hooker-descent line has multiple Asahels, including Capt. Asahel Strong Jr. I00055 who married Sarah Hooker H00101). May honor a Strong family connection through paternal grandmother Ruth Strong Lyman."}],"artworks":[],"tags":["massachusetts_migration","michigan_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"First Hooker-Talcott cross-line marriage on record","body":"Asahel Hubert Lyman married Julia Elizabeth Barnard Lyman — a Talcott descendant through her mother Julia Hobart Barnard and grandmother Betsey Perrin Hobart. Their marriage represents the first documented union of the two great descendant lines that form the project's twin axes — Thomas Hooker's descendants meeting John Talcott's descendants in a single household. Asahel descended from Hooker through the Stiles-Ellis-Lyman line; Julia descended from Talcott through the Perrin-Hobart-Barnard line."},{"number":2,"category":"death","header":"Orphaned at eleven, died Manistee Michigan at 43","body":"Asahel Hubert Lyman was orphaned at age eleven — his mother Luthena Ellis Lyman died at Northampton when he was eight, and his father was killed at Fredericksburg Virginia during Grant's Overland Campaign three years later. He migrated west to Manistee Township Michigan and died there in 1896 at age forty-three, buried at Oak Grove Cemetery alongside where his maternal uncle Dr. Lathrop Stiles Ellis would be interred four years later."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"asahel-lyman-1853"},"HD4268":{"id":"HD4268","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Catherine","middle_name":"Elizabeth","last_name":"Lyman","married_names":[],"nickname":"Katie","gender":"female","display_name":"Catherine Elizabeth 'Katie' Lyman"},"birth":{"year":1859,"month":6,"day":3,"city":"Huntington","county":"Hampshire County","state":"Massachusetts","country":"United States"},"baptism":{},"death":{"year":1872,"month":9,"day":2,"city":"Huntington","county":"Hampshire County","state":"Massachusetts","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM348","plot_notes":"Norwich Hill Cemetery Huntington MA — with mother Luthena and father John Burt Jr."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":9,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00663","mother_id":"HD4245"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["died_young","massachusetts_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Catherine died young","body":"Catherine 