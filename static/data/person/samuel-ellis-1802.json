","last_name":"Ellis","maiden_name":"Stiles","married_names":["Ellis"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"is_placeholder":false,"burial":{"cemetery_id":"CEM338","plot_notes":"Ellis Cemetery, Huntington Hampshire County MA."},"slug":"ruth-ellis-1778"},"H00241":{"id":"H00241","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1735,"month":9,"day":11,"city":"North Haven","county":"New Haven County","state":"Connecticut","country":"United States"},"parents":{"father_id":"I00126","mother_id":"H00092"},"tags":["revolutionary_war","massachusetts_migration","connecticut_migration"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 241"}],"marriages":[{"spouse_id":"I00160","children_ids":["H00460","H00461","H00462","H00463","H00464","H00465"],"marriage_number":1,"date_year":1759,"date_month":2}],"death":{"year":1810,"month":10,"city":"Norwich (now Huntington)","county":"Hampshire County","state":"Massachusetts","country":"United States"},"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","active_in_war":true,"rank_year_start":1781,"rank_year_end":1782,"service_period":"May 1781 - March 1782","notes":"Per The Stiles Family in America (BIB008) entry #230: served in the Revolution and was at Horse Neck from May 1781 to March 1782. Horse Neck (Greenwich CT) was an active Revolutionary War outpost under occasional British raid throughout the war."},{"war":"American Revolutionary War","war_id":"WAR004","rank_year_start":1781,"rank_year_end":1782,"unit":"Connecticut militia, Horse Neck post","notes":"Served in the Revolution at Horse Neck (now Greenwich CT, on the western frontier facing British-held New York), from May 1781 to March 1782."}],"bio":{"display_name":"Ashbel Stiles","first_name":"Ashbel","maiden_name":"Stiles","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":99,"category":"career","header":"Inherited mansion, lost all endorsing for friend","body":"Ashbel Stiles inherited the family mansion and a very comfortable property from his father in North Haven Connecticut. But in an evil hour he endorsed for a friend and lost his all. Soon after he removed to Windsor Connecticut, and thence to Norwich Massachusetts — now Huntington — near his daughter Ruth Stiles Ellis."},{"category":"death","header":"Hannah died Norwich one month before Ashbel did","body":"After fifty-one years of marriage, Ashbel and his cousin-wife Hannah Stiles both died at Norwich (now Huntington) Massachusetts in autumn 1810 — both at age seventy-five. Hannah went first in September; Ashbel followed in October, approximately one month later.","number":100},{"category":"death","header":"Son thrown from a horse, killed in Jamaica","body":"His son Benjamin Stiles died at Jamaica in the West Indies from injuries sustained being thrown from a horse. The Stiles Family in America entry 230 records the death without further circumstance — a son lost an ocean from home to a single fall.","number":101},{"category":"military","header":"Horse Neck garrison 1781 after financial ruin","body":"Forty-six at enlistment, he came to Revolutionary militia service well after most of his cohort. Financial ruin from endorsing for a friend had already emptied the family mansion he had inherited from his father.","number":102}],"slug":"ashbel-stiles-1735"},"I00160":{"id":"I00160","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1735,"month":9,"day":11},"death":{"year":1810,"month":9,"city":"Norwich (Huntington)","state":"Massachusetts"},"parents":{"mother_research_notes":"Mary Phelps Stiles","father_research_notes":"Lt. Samuel Stiles of Windsor CT"},"marriages":[{"spouse_id":"H00241","children_ids":["H00460","H00461","H00462","H00463","H00464","H00465"],"marriage_number":1}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 241"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Hannah Stiles Stiles","notes":"Hannah Stiles married her cousin Ashbell Stiles. She was daughter of Lt. Samuel Stiles and Mary Phelps of Windsor CT. Same surname before and after marriage.","first_name":"Hannah","last_name":"Stiles","married_names":["Stiles"],"maiden_name":"Stiles","gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"hannah-stiles-1735"}},"burialCemetery":{"id":"CEM340","name":"Dawes Cemetery","city":"Cummington","state":"Massachusetts","country":"United States","primary_url":"https://www.findagrave.com/cemetery/90909/dawes-cemetery","hooker_connections":["HD4234","HD4247","I00656"],"notes":"Dawes Cemetery, Cummington Hampshire County MA. Burial site of Samuel Ellis (HD4234, Hooker descendant) and his second wife Sarah Moore Ellis."},"institutionsById":{},"crossConnections":[]}