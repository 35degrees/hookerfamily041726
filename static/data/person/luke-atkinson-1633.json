_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"slug":"zachariah-baldwin-1660"},"I00022":{"id":"I00022","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1678,"city":"Milford","state":"Connecticut"},"death":{"year":1744,"month":3,"day":29,"city":"Milford","state":"Connecticut"},"parents":{"father_id":"X00019","mother_id":"X00024"},"marriages":[{"spouse_id":"H00042","children_ids":["HD0034","H00135","H00136","H00137","H00138","H00139","H00140"],"marriage_number":1,"date_year":1704,"date_month":6,"date_day":20}],"sources":[{"short":"Edward Hooker 1909","page":"Entry 42"},{"short":"Families of Early Milford"}],"gender":"female","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Baldwin","first_name":"Mary","maiden_name":"Baldwin","married_names":[]},"baptism":{"year":1680,"month":5,"day":2},"residence":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-baldwin-1678"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}