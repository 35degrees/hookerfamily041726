john_talcott":8},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"TD0337","father_name":"Raphael Welles Pumpelly","mother_id":"I01543","mother_name":"Amelie Sybil Van Doren Ripley"},"number_of_marriages":1,"marriages":[{"spouse_id":"I01549","spouse_name":"John Henry Bates","children_ids":["TD0354","TD0355","TD0356","TD0357"],"marriage_year":1935,"marriage_place":"Manhattan, New York"}],"tags":[],"narrative_blocks":[{"category":"family","header":"She crossed the color line in 1935","body":"A New York socialite by birth, Amelie married the African-American boxer and cabinetmaker John Henry Bates in 1935, when such unions were illegal in many states. As Bahá'ís, the couple held to the faith's teaching of the oneness of humankind.","number":1},{"category":"character","header":"From socialite to labor-union poster artist","body":"Born to wealth, Amelie became a painter who made graphic designs and posters for a labor union. She and John moved among the Black artists and writers of the late Harlem Renaissance.","number":2},{"category":"character","header":"Her Vermont farm sparked 'Invisible Man'","body":"The family kept an ancestral farm at Fayston, Vermont, where their friend Ralph Ellison stayed during the war. Ellison later credited the visits as a direct spark for his novel Invisible Man.","number":3},{"category":"death","header":"She died on a Bahá'í mission abroad","body":"After teaching the Bahá'í Faith in Haiti, Amelie moved with her family toward Mexico City. She died there suddenly of a coronary embolism in 1951, at the age of forty-one.","number":4}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Amelie Welles","last_name":"Bates","married_names":[],"display_name":"Amelie Welles Pumpelly Bates","gender":"female","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780758616/178937192_1602251134_fk9xzz.jpg"},"military_service":[],"slug":"amelie-welles-bates-1910"},"I01549":{"id":"I01549","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","birth":{"year":1909,"month":11,"day":27,"city":"Jersey City","state":"New Jersey","country":"United States"},"death":{"year":1975,"city":"New York","state":"New York","country":"United States"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":true,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"spouse_id":"TD0345","spouse_name":"Amelie Welles Pumpelly Bates","children_ids":["TD0354","TD0355","TD0356","TD0357"],"marriage_year":1935,"marriage_place":"Manhattan, New York"}],"tags":[],"narrative_blocks":[{"category":"character","header":"Brooklyn Johnny Bates, boxer and cabinetmaker","body":"The son of a Virginia-born porter, John Henry Bates boxed as 'Brooklyn Johnny Bates' until a car wreck ended his ring career. He then built fine furniture with his brothers, one of them a figure of the Harlem Renaissance.","number":1},{"category":"legacy","header":"He modeled for Gordon Parks's 'Invisible Man'","body":"Bates and his wife counted Ralph Ellison among their friends, and their Vermont farm helped inspire his novel. For a 1952 Life magazine essay on Invisible Man, Gordon Parks photographed Bates as the model for the unnamed narrator.","number":2},{"category":"family","header":"His family had been enslaved in Virginia","body":"The Bates family had been enslaved at Dinwiddie, Virginia, before John's father came north to work as a porter. From that beginning John boxed professionally and married into an old New England family.","number":3},{"category":"religion","header":"A Bahá'í who taught the faith in Haiti","body":"Bates embraced the Bahá'í Faith and its teaching of the oneness of humankind. In 1947 he and his family moved to Port-au-Prince to support the Bahá'í community there.","number":4}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"John Henry","last_name":"Bates","married_names":[],"display_name":"John Henry Bates","gender":"male","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780758773/johnbates_vx7si2.png"},"military_service":[],"slug":"john-henry-bates-1909"},"TD0354":{"id":"TD0354","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"female","birth":{"year":1936,"month":5,"day":24,"city":"New York","state":"New York","country":"United States"},"death":{"year":1971,"month":6,"day":26,"city":"Buga","country":"Colombia"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":true,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":true,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"descent_from_john_talcott":true,"is_progenitor":false,"is_easter_egg":false,"generation_from_john_talcott":9},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I01549","father_name":"John Henry Bates","mother_id":"TD0345","mother_name":"Amelie Welles Pumpelly Bates"},"number_of_marriages":0,"marriages":[],"tags":[],"narrative_blocks":[{"category":"death","header":"She died in a Colombian bus crash","body":"Raised in the Bahá'í Faith, Joan Pumpelly Bates moved with her family to Haiti as a child. She was killed at thirty-five in a bus accident near Buga, Colombia, in 1971.","number":1}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Joan","last_na