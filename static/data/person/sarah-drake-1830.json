ources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"career":[{"role":"Deacon","organization":"Lee Congregational Church","start_year":1812,"end_year":1839},{"role":"Selectman","organization":"Lee, Massachusetts"}],"narrative_blocks":[{"number":1,"category":"character","header":"He cut down his own orchard","body":"Finding that too many neighbors were getting drunk on his cider, Deacon Ingersoll felled every apple tree on his farm except those that fed his own table. At seventy-five he traveled to Ohio and Michigan to visit his children — before the railroads, “in the days of rugged constitutions.”"},{"number":2,"category":"business","header":"His quarry is in the Capitol","body":"The marble quarry on his Lee farm, a mile and a half from the Congregational church he helped found, supplied “much of the marble in the Capitol in Washington.” The Ingersoll and Yale families, the genealogy says, “might well be called the founders of Lee.”"}],"slug":"david-ingersoll-1759"},"H00907":{"id":"H00907","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1760},"death":{"year":1837},"parents":{"father_id":"X00536","mother_id":"H00376"},"marriages":[{"spouse_id":"X00543","children_ids":["HD1690","HD1691","HD1692","HD1693","HD1694","HD1695","HD1696"],"marriage_number":1,"date_year":1781,"date_month":12,"date_day":18,"location_city":"Lee","location_state":"Massachusetts"}],"tags":[],"sources":[{"short":"Edward Hooker 1909","entry":"907"},{"short":"The Jonathan Edwards Collection (Yale)"},{"short":"Avery, Genealogy of the Ingersoll Family in America (1926)"},{"short":"Descendants of William Smith of Glastonbury CT (archive.org)","url":"https://archive.org/details/descendantsofwil00smit/page/38/mode/2up?q=Eunice+"}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":[],"notable_blurb":"Genealogy of the Ingersoll Family in America 1926"},"cross_connections":[],"bio":{"display_name":"Sarah Parsons","first_name":"Sarah","last_name":"Parsons","married_names":["Ingersoll"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Thirteen children all reached adulthood and married","body":"Sarah Parsons married Deacon David Ingersoll II at Stockbridge MA on December 13, 1781. Their thirteen children all grew to adulthood, married, and mostly had large families — over 2,000 descendants are recorded. The Ingersoll-Yale lineage was one of the founding strata of Lee, Massachusetts; the marble from David's farm quarry helped build the U.S. Capitol."},{"number":2,"category":"family","header":"Two thousand descendants and counting","body":"The thirteen children she raised at Lee all married and “mostly had large families” — over two thousand descendants recorded by the 1926 Ingersoll genealogy, among them the founders of the Ingersoll Dollar Watch. Her widowed mother, a daughter of Jonathan Edwards, lived out years under her roof."}],"slug":"sarah-parsons-1760"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}