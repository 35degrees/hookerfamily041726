"location_country":"United States","officiant":"Rev. Eben Raymond","children_ids":["HD4320","HD4321","HD4322"]}],"education":[{"institution_id":"INST022","dates":"1845-1849","type":"undergraduate","notes":"A.B. 1849. Classmate of Timothy Dwight (future 8th Yale president). Captain of the Augusta boat race crew — credited as founding vessel of the Yale Navy."}],"career":[{"role":"Staff Officer","organization":"Union Army — staffs of Maj.-Gen. King and Maj.-Gen. Russell","start_year":1861,"end_year":1865,"notes":"Civil War service details not fully documented."},{"role":"Bank Commissioner","organization":"State of Connecticut","start_year":1859,"end_year":1862},{"role":"Member","organization":"Connecticut General Assembly","start_year":1865,"end_year":1872,"notes":"Republican, representing Norwalk; served 1865, 1866, and 1872."},{"role":"President","organization":"Fairfield County National Bank","start_year":1868,"end_year":1917,"notes":"President since December 1868."},{"role":"President","organization":"Danbury and Norwalk Railroad Co.","start_year":1882,"end_year":1917}],"military_service":[{"war":"American Civil War","war_id":"WAR006","rank_year_start":1861,"rank_year_end":1865,"unit":"Staffs of Major-Generals King and Russell","notes":"Specific unit and rank not documented in Lockwood genealogy or Patch.com biography."}],"institutions":[{"institution_id":"INST022","relationship":"alumnus","years":"1849","institution_blurb":"Yale A.B. 1849; classmate of Timothy Dwight, future 8th Yale president."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["yale_graduate","civil_war","army","banker","railroad","politician","freemason"],"research_tags":[],"cross_connections":[{"type":"civic_peer","related_id":"HD04877","display_label":"Yale Class of 1849; Dwight became the eighth university president","link_text":"Timothy Dwight"}],"narrative_blocks":[{"number":1,"category":"education","header":"Captained Yale Navy's founding boat, 1845","body":"In August 1845, Lockwood captained the Augusta, an eight-oared cedar shell his classmates bought for $170, later identified as the vessel that launched what became the Yale Navy. He graduated with the class of 1849 alongside Timothy Dwight, who would become the university's eighth president."},{"number":2,"category":"career","header":"Staffed two Union generals; built Norwalk's banking empire","body":"After serving on the staffs of Major-Generals King and Russell in the Civil War, Lockwood became president of Fairfield County National Bank and the Danbury and Norwalk Railroad, and served three terms as a Republican representative in the Connecticut General Assembly."},{"number":3,"category":"legacy","header":"SAR member; great-grandfather burned out by British","body":"A century after British forces torched Norwalk and destroyed his great-grandfather's home, Lockwood joined the Connecticut Society of the Sons of the American Revolutionary War, a membership whose meaning ran close to home. He was also made a Knight Templar and remained active in the Norwalk Club until his final years."}],"quotes":[],"sources":[{"label":"Patch.com — biography of Frederick Lockwood","url":"https://patch.com/connecticut/norwalk/a-famous-norwalker"}],"research_sources":[],"documents":[],"slug":"frederick-lockwood-1825"},"HD4320":{"id":"HD4320","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Elizabeth","last_name":"Hubbard","maiden_name":"Lockwood","married_names":["Hubbard"],"gender":"female","display_name":"Elizabeth Lockwood Hubbard"},"birth":{"year":1868,"month":7,"day":30,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1953,"month":12,"day":26},"residence":{},"burial":{"cemetery_id":"CEM366","plot_notes":"FindAGrave #73358435. Hubbard Memorial Cemetery, Huron City MI."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_