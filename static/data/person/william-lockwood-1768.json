Fairfield County","state":"Connecticut","country":"United States"},"baptism":{"year":1741,"month":10,"day":17,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"American Revolutionary War","war_id":"WAR004","rank":"Captain","rank_start":"Private","rank_end":"Captain","rank_year_start":1775,"rank_year_end":1780,"unit":"First Company, Colonel Charles Webb's Seventh Connecticut Regiment","notes":"Enlisted Jul 12, 1775; discharged Dec 24, 1775. Assigned to Gen. Sullivan's Brigade on Winter Hill. Assistant Commissary of Issues 1778; captain of coast guards 1780."}],"former_ids":[],"is_placeholder":false,"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave #155694447. East Norwalk Historical Cemetery."},"education":[],"career":[{"role":"Assistant Commissary of Issues","organization":"Fifth Connecticut Regiment, Continental Army","start_year":1778,"end_year":1778,"notes":"Posted $5,000 bond to Henry Laurens, President of the Continental Congress, Jul 21, 1778."},{"role":"Captain, Coast Guard","organization":"Connecticut Militia","start_year":1780},{"role":"Member","organization":"Connecticut House of Representatives","start_year":1790,"end_year":1796,"notes":"Represented Norwalk nine sessions: May/Oct 1790, May/Oct 1791, Oct 1794, May/Oct 1795, May/Oct 1796."}],"narrative_blocks":[{"number":1,"category":"military","header":"Lost home when British torched Norwalk, 1779","body":"British forces burned Norwalk in July 1779, destroying Lockwood's home among hundreds of others along the shore. He had already served in the 7th Connecticut Regiment and organized a petition to the General Assembly for an armed sloop after British ships raided the harbor at night."},{"number":2,"category":"politics","header":"Organized Norwalk's first volunteer fire department","body":"After the war Lockwood organized the first voluntary fire department in Norwalk, building civic infrastructure in the town the British had burned. He went on to represent Norwalk nine terms in the Connecticut General Assembly between 1790 and 1796."},{"number":3,"category":"military","header":"Petitioned Assembly for armed sloop; British still came","body":"In October 1777, Lockwood joined neighbors in petitioning the Connecticut General Assembly for an armed sloop to patrol Long Island Sound after British vessels repeatedly raided Norwalk's harbor at night, firing on houses and stealing livestock. Two years later, the raids he had warned against culminated in the burning of the town that destroyed his home."}],"slug":"eliphalet-lockwood-1741"},"H00478":{"id":"H00478","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"descent_paths_to_thomas":1,"is_progenitor":false},"birth":{"year":1743,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"parents":{"father_name":"Capt. Joseph St. John of Norwalk","mother_id":"H00253","mother_name":"Susannah Selleck St. John","father_research_notes":"Capt. Joseph St. John of Norwalk CT; d. 1756. His estate included enslaved people.","father_id":"X00215"},"tags":[],"sources":[{"label":"FindAGrave — Susannah St. John Lockwood","url":"https://www.findagrave.com/memorial/155694447/eliphalet-lockwood"}],"death":{"year":1810,"city":"Norwalk","county":"Fairfield County","state":"Connecticut","country":"United States"},"marriages":[{"marriage_number":1,"spouse_id":"X00218","date_year":1776,"date_month":6,"date_day":8,"location_city":"Norwalk","location_county":"Fairfield County","location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1810,"children_ids":["H01229","H01230","H01231","H01232","H01233","H01234","H01235"]}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Susannah St. John Lockwood","first_name":"Susannah","last_name":"Lockwood","maiden_name":"St. John","married_names":["Lockwood"],"gender":"female"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"former_ids":["HD0366"],"is_placeholder":false,"burial":{"cemetery_id":"CEM002","plot_notes":"FindAGrave — East Norwalk Historical Cemetery"},"education":[],"career":[],"narrative_blocks":[{"number":1,"category":"family","header":"Orphaned at six; married the town's future captain","body":"Her mother Susannah Selleck died in December 1749 when Susannah was barely six, and her father Capt. Joseph St. John died in 1756 when she was thirteen, leaving her to grow up in Norwalk without either parent. She married Captain Eliphalet Lockwood at thirty-three — he would go on to lose his home to British torches and organize the city's first volunteer fire department."}],"slug":"susannah-lockwood-1743"},"X00215":{"id":"X00215","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[{"label":"St. John Genealogy (Alexander, 1907)","url":"https://ia601308.us.archive.org/2/items/stjohngenealogyd00lcalex/stjohngenealogyd00lcalex.pdf"}],"birth":{"year":1703},"death":{"year":1756},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00253","date_year":1733,"children_ids":["HD0364","H00479","H00478","HD0367","H00481","H00482"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Captain Joseph St. John","first_name":"Joseph","last_name":"St. John","title":"Captain","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"character","header":"Earned 'Blue Sheep' nickname by dyeing his flock","body":"Tradition holds that Capt. Joseph Saint John attempted to dye a sheep blue to create a matching flock — and the rains washed it out, leaving him with the lasting nickname 'The Blue Sheep.' He was a large landowner in Norwalk and among its founding civic leaders, serving as Selectman, Rate Constable, Fence Viewer, and Captain of the 1st Company of the Norwalk trainband (1748)."},{"number":2,"category":"legacy","header":"Wife Susanna's epitaph: Rachel's face, Leah's fruitful womb","body":"When Susanna Selleck Saint John died in December 1749 at forty, Capt. Joseph commissioned a tombstone epitaph comparing her to Rachel ('face'), Leah ('fruitful womb'), Abigail ('wisdom'), Lydia ('faithful heart'), and Martha ('care'). The epitaph — one of the most elaborate in the East Norwalk churchyard — captures how colonial Norwalk elites memorialized women through accumulated biblical virtues."}],"slug":"joseph-st-john-1703"},"H00253":{"id":"H00253","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1709,"month":9,"day":3,"city":"Stamford","state":"Connecticut"},"death":{"year":1749,"month":12,"day":4,"city":"Norwalk","state":"Connecticut"},"burial":{"cemetery_id":"CEM002","plot_notes":"East Norwalk Historical Cemetery, Norwalk, Fairfield, Connecticut"},"parents":{"father_id":"I00129","mother_id":"H00094"},"marriages":[{"children_ids":["HD0364","H00479","H00478","HD0367","H00481","H00482"],"spouse_id":"X00215","marriage_number":1,"date_year":1733}],"gravestone_inscription":"Susanna St. John, ye wife of Capt. Joseph St. John died December ye 4th, 1749 aged 40 years and 2 months. \"She that lies at rest within this tomb / Had Rachel's face and Leah's fruitful womb, / Abigail's wisdom, Lydia's faithful heart / With Martha's care — we hope Mary's better part.\"","tags":[],"sources":[{"short":"Edward Hooker 1909","page":"Entry 253"}],"enslaved_persons":[{"name":"Jenny","description":"Enslaved woman. Listed in estate inventory of Joseph St. John, Dec 7, 1756."},{"name":"London","description":"Enslaved man. Listed in estate inventory of Joseph St. John, Dec 7, 1756."},{"name":"Peter","description":"Enslaved boy. Listed in estate inventory of Joseph St. John, Dec 7, 1756."}],"cross_connections":[],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"bio":{"display_name":"Susannah Selleck St. John","first_name":"Susannah","last_name":"St. John","married_names":["St. John"],"maiden_name":"Selleck"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Her mother died one month after her birth","body":"She was born September 3, 1709 in Norwalk. Her mother Hannah Hooker died October 5, 1709 — barely one month later, age nineteen, of complications from childbirth."},{"number":2,"category":"marriage","header":"Married 'The Blue Sheep' captain in 1729","body":"She married Capt. Joseph St. John in 1729 — known as 'The Blue Sheep' for the local tradition that he once dyed a sheep blue, though the rains washed it out. He served as Norwalk selectman seven times across thirty years."},{"number":3,"category":"social_reform","header":"Three generations of slaveholding descendants","body":"After her death, her husband's 1756 estate inventory listed three enslaved people: Jenny, London, and Peter. Three consecutive generations of her descendants held enslaved people — including grandson William St. John, who sent his enslaved man Dover to the Continental Army in his own place."}],"slug":"susannah-st-john-1709"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}