ecords as 'Lottie' — the standard nineteenth-century diminutive of Charlotte. She married Julian W. Tuttle of North Haven Connecticut, who was born April 16, 1836 and died April 10, 1907 — slightly outliving Lottie."},{"number":3,"category":"family","header":"Born Connecticut 1844, died North Haven 1902","body":"Charlotte E. Blakeslee was born April 17, 1844 in Connecticut and died March 19, 1902 in North Haven Connecticut at age fifty-seven. She is buried at New Center Cemetery. Daughter of Colonel Henry Merwin Blakeslee and Polly Goodyear Blakeslee."}],"quotes":[],"sources":[{"label":"FindAGrave (Memorial 126898312)","url":"https://www.findagrave.com/memorial/126898312/charlotte_e-tuttle"},{"label":"Goodyear book #6852-1"}],"research_sources":[{"bib_id":"BIB008"}],"documents":[],"slug":"charlotte-tuttle-1844"},"HD3958":{"id":"HD3958","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Stella","last_name":"Warner","maiden_name":"Tuttle","married_names":["Warner"],"gender":"female","display_name":"Stella Tuttle Warner"},"birth":{"year":1863,"month":8,"day":17,"state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1894,"month":11,"day":1,"state":"Connecticut","country":"United States"},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00536","mother_id":"HD3951"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00538","date_year":1887,"date_month":1,"date_day":27,"location_state":"Connecticut","location_country":"United States","end_type":"death","end_year":1894,"children_ids":["HD3962"]}],"education":[],"career":[],"military_service":