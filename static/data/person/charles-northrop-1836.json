,"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":[],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"death","header":"Died at twenty-four, leaving three children under three","body":"Bertha Northrop Orr died on February 3, 1895 at age twenty-four in Detroit, leaving behind three children all under three years old: Margaret (born 1892), Edward (born November 1893), and Bertha Gertrude, born just the day before on February 2, 1895 — a mother who died before her youngest was two days old. She had been married only four years to Edward Kellogg Orr, who remarried within the year and went on to become president of an iron company in Chicago."}],"quotes":[],"sources":[{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"bertha-orr-1870"},"I00972":{"id":"I00972","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Edward","middle_name":"Kellogg","last_name":"Orr","married_names":[],"gender":"male","display_name":"Edward Kellogg Orr"},"birth":{"year":1870,"month":3,"day":30,"city":"Detroit","county":"Wayne County","state":"Michigan","country":"United States"},"baptism":{},"death":{"year":1923,"month":8,"day":14,"city":"Fernway","county":"Cook County","state":"Illinois","country":"United States"},"residence":{"country":"United States"},"burial":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4714","date_year":1891,"date_month":5,"date_day":16,"location_city":"Detroit","location_state":"Michigan","location_country":"United States","end_type":"death_of_spouse","end_year":1895,"ch