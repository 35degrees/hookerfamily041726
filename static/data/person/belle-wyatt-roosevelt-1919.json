ook his degree in 1912.","number":5}],"sources":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"},{"institution_id":"INST062","relationship":"alumnus"}],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"family_connection","related_id":"HD6126","display_label":"re-ran the River of Doubt eight decades later"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Kermit","last_name":"Roosevelt","display_name":"Kermit Roosevelt","gender":"male","bio_blurb":"Explorer, soldier, son of Theodore Roosevelt"},"military_service":[{"war":"World War I","branch":"British Army","rank":"Captain (honorary)","unit":"14th Light Armored Motor Battery, Machine Gun Corps","awards":"Military Cross","notes":"Served under General Maude in the Mesopotamian campaign, 1917-1918."},{"war":"World War I","branch":"United States Army","rank":"Captain","unit":"Battery C, 7th Field Artillery, 1st Division","notes":"Transferred to the American Expeditionary Force in France, 1918; Meuse-Argonne Offensive."},{"war":"World War II","branch":"United States Army","rank":"Major","unit":"Fort Richardson, Alaska","notes":"Intelligence officer; helped raise a territorial militia of Alaska Natives."}],"career":[{"role":"Explorer","organization":"Africa and South America"},{"role":"Assistant Manager","organization":"National City Bank, Buenos Aires","start_year":1914,"end_year":1916},{"role":"Founder","organization":"Roosevelt Steamship Company"},{"role":"Vice President","organization":"New York Zoological Society","start_year":1937,"end_year":1939},{"role":"Author","organization":"explorer-memoirist"}],"birth":{"year":1889,"country":"United States"},"death":{"year":1943,"country":"United States","city":"Anchorage","state":"Alaska"},"burial":{"cemetery_id":"CEM773"},"education":[{"institution_id":"INST062"},{"institution_id":"INST002","dates":"1912","type":"graduation","notes":"A.B."}],"number_of_marriages":1,"slug":"kermit-roosevel