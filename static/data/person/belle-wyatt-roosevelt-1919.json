ited States","city":"Baltimore","state":"Maryland"},"death":{"year":1968,"country":"United States","city":"New York","state":"New York"},"burial":{"cemetery_id":"CEM768"},"education":[],"slug":"belle-wyatt-willard-1892"},"X00744":{"id":"X00744","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":true},"tags":["author","nobel_prize","president"],"sources":[],"birth":{"year":1858},"death":{"year":1919},"gender":"male","parents":{"father_id":"X03151","mother_id":"X03152"},"notable":{"is_notable":true,"notable_category":["politics","military"],"notable_blurb":"26th US President; Rough Rider; Nobel Peace laureate","primary_url":"https://en.wikipedia.org/wiki/Theodore_Roosevelt","primary_url_label":"Wikipedia"},"marriages":[{"spouse_id":"X03147","children_ids":["X03145"],"marriage_number":1,"marriage_year":1880},{"spouse_id":"HD6083","children_ids":["HD6086","HD6087","HD6088","HD6089","HD6090"],"marriage_number":2,"marriage_year":1886}],"cross_connections":[{"type":"parallel_careers","related_id":"HD2335","display_label":"his Harvard ornithology partner on an 1877 bird list","link_text":"Henry Davis Minot"},{"type":"civic_connection","related_id":"HD1170","display_label":"Trust-busted Morgan's Northern Securities Company in 1904","link_text":"John Pierpont Morgan"},{"type":"professional","related_id":"I01429","link_text":"Thomas Hastings","display_label":"designed the townhouse his family used near the White House"},{"type":"professional","related_id":"HD5701","link_text":"Lucius Hart Beers","display_label":"drew up the guardianship papers for his children"},{"type":"historical_connection","related_id":"X00721","display_label":"the Columbia president and Nobel laureate he befriended"}],"bio":{"display_name":"Theodore Roosevelt","first_name":"Theodore","last_name":"Roosevelt","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780965933/535146190_1328320185969705_5247696981767004675_n_rjvlwf.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"},{"institution_id":"INST063","relationship":"alumnus"}],"artworks":[],"quotes":[],"military_service":[{"war":"Spanish-American War","branch":"United States Army","rank":"Colonel","unit":"1st U.S. Volunteer Cavalry (Rough Riders)","notes":"Led the assault on the San Juan Heights, 1898; Medal of Honor awarded in 2001."}],"narrative_blocks":[{"category":"marriage","header":"He married the childhood friend next door","body":"Roosevelt married Edith Kermit Carow in London in 1886, his second wife and a granddaughter of the Union general Daniel Tyler. Through her he entered the Tyler family, with its Edwards and Hooker roots in colonial Connecticut.","number":1},{"number":2,"category":"character","header":"Harvard ornithology friendship became his first publication","body":"He met Henry Davis Minot, a Boston-based naturalist, as a Harvard freshman in 1877. They spent vacations listing birds in the Adirondacks and co-authored 'The Summer Birds of the Adirondacks' that fall — his first published work."},{"number":3,"category":"politics","header":"Trust-busted J.P. Morgan's Northern Securities Company","body":"His administration brought the antitrust suit that dissolved Morgan's Northern Securities holding company in 1904, ending the merger of the Northern Pacific and Great Northern railroads. Morgan reportedly told him 'Send your man to my man and they can fix it up' — the President refused, and the Supreme Court sided with the government."},{"category":"character","header":"He befriended Columbia's president Nicholas Butler","body":"Roosevelt's circle included Nicholas Murray Butler, the long-serving Columbia president and 1931 Nobel peace laureate, whom he nicknamed Nicholas Miraculous. The two Republican allies stayed close from Roosevelt's rise through the White House years.","number":4},{"category":"family","header":"The Roosevelts borrowed a famous architect's townhouse","body":"When the White House was torn up for renovation in 1902, the family decamped to a townhouse belonging to the firm of Carrère and Hastings. Its partner Thomas Hastings would go on to design the New York Public Library and Arlington's Tomb of the Unknowns.","number":5}],"number_of_marriages":2,"education":[{"institution_id":"INST002","dates":"1880","type":"graduation","notes":"A.B."},{"institution_id":"INST063","notes":"law; left for politics"}],"career":[{"role":"Member","organization":"New York State Assembly","start_year":1882,"end_year":1884},{"role":"Commissioner","organization":"U.S. Civil Service Commission","start_year":1889,"end_year":1895},{"role":"President","organization":"New York City Police Board","start_year":1895,"end_year":1897},{"role":"Assistant Secretary of the Navy","organization":"United States Navy","start_year":1897,"end_year":1898},{"role":"Governor","organization":"New York","start_year":1899,"end_year":1900},{"role":"President","organization":"United States","start_year":1901,"end_year":1909}],"slug":"theodore-roosevelt-1858"},"HD6083":{"id":"HD6083","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"include_in_path_calculation":true,"is_easter_egg":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"generation_from_thomas":9},"notable":{"is_notable":true,"notable_category":["politics"],"notable_blurb":"First Lady; wife of Theodore Roosevelt","primary_url":"https://en.wikipedia.org/wiki/Edith_Roosevelt","primary_url_label":"Wikipedia"},"parents":{"father_id":"I01653","mother_id":"HD6076"},"number_of_marriages":1,"marriages":[{"spouse_id":"X00744","children_ids":["HD6086","HD6087","HD6088","HD6089","HD6090"],"marriage_number":1,"marriage_year":1886}],"tags":["author"],"narrative_blocks":[{"category":"politics","header":"She built the modern First Lady's office","body":"Edith hired the first salaried social secretary for a First Lady and directed the 1902 White House renovation that created the West Wing. Historians credit her with shaping the modern institution of the role.","number":1},{"category":"character","header":"She burned a lifetime of love letters","body":"After Theodore died, the intensely private Edith destroyed the letters he had written her across their courtship and marriage. It is part of why her inner life stayed, by her own design, almost unknowable.","number":2},{"category":"legacy","header":"She wrote her own Connecticut ancestors' history","body":"Late in life Edith researched her mother's Tyler family and co-wrote a history of their colonial Connecticut roots. She bought the family's ancestral home in Brooklyn, Connecticut, returning there each summer.","number":3},{"category":"politics","header":"She stumped for Hoover to disown Franklin","body":"Edith kept out of politics for decades, then made a rare appearance for Herbert Hoover in 1932. Part of her motive was to remind voters that the Democratic nominee, Franklin Roosevelt, was only a distant cousin and not her son.","number":4},{"category":"family","header":"Theodore regretted overruling her judgment","body":"A childhood neighbor whom Theodore Roosevelt married in 1886, Edith ran Sagamore Hill and raised six children while quietly advising him on people and politics. Roosevelt admitted he was worse off whenever he ignored her counsel.","number":5}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"family_orbit","related_id":"X03145","display_label":"was her stepdaughter, the capital’s sharpest wit"},{"type":"family_orbit","related_id":"X03151","display_label":"her husband President Roosevelt's father"},{"type":"family_orbit","related_id":"X03152","display_label":"her husband President Roosevelt's Hartford-born mother"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Edith Kermit","last_name":"Carow","display_name":"Edith Kermit Carow Roosevelt","gender":"female","married_names":["Roosevelt"],"maiden_name":"Carow","bio_blurb":"First Lady; wife of Theodore Roosevelt","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780959099/5995_f037e496-9f02-4873-ba91-aa14250a6238_czjevu.jpg"},"military_service":[],"career":[{"role":"First Lady of the United States","start_year":1901,"end_year":1909},{"role":"Author"}],"birth":{"country":"United States","year":1861,"city":"Norwich","state":"Connecticut"},"death":{"country":"United States","year":1948,"city":"Oyster Bay","state":"New York"},"burial":{"cemetery_id":"CEM768"},"education":[{"school_name":"Miss Comstock's School"}],"slug":"edith-kermit-carow-1861"}},"burialCemetery":{"id":"CEM768","name":"Youngs Memorial Cemetery","city":"Oyster Bay","state":"New York","country":"United States","county":"Nassau","gps":{"latitude":40.87,"longitude":-73.5065},"hooker_connections":["HD6083","HD6088","HD6089","I01654","HD6094","I01657","I01660","HD6102","HD6103","HD6104","HD6106","HD6108","HD6109","I01663","I01664","I1666","HD6115","HD6116","HD6117","HD6118","I1667","HD6119","I1676"]},"institutionsById":{},"crossConnections":[]}