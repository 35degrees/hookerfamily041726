egory":"charity","header":"And Julia built Grace Church's Gothic parish house","body":"She and her sister Julia Jay Pierrepont funded the $100,000 Gothic parish house of Grace Church on Brooklyn Heights in 1931. She served as president of the Grace Church Girls Friendly Society for fifty years and spent her summers at Northeast Harbor, Maine, as patron of the Seal Cove Mission."},{"number":3,"category":"character","header":"Last of her generation","body":"She never married and spent her final decades at the family mansion with her sister Julia, until Julia died in 1937 — three years before her. At her death, journalists described her as the last surviving member of her generation in one of New York's most prominent families."}],"cross_connections":[],"bio":{"display_name":"Anna Jay Pierrepont","first_name":"Anna","middle_name":"Jay","maiden_name":"Pierrepont","married_names":[],"photo_url":"https://images.findagrave.com/photos/2018/77/58486813_de529317-8e82-4fec-a795-8943d37c2587.png"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"anna-pierrepont-1861"},"X00907":{"id":"X00907","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["orbit_notable","abolitionist","lawyer","judge"],"sources":[],"birth":{"year":1776,"month":1,"day":24,"city":"Elizabethtown","county":"Union","state":"New Jersey","country":"United States"},"death":{"year":1843,"month":2,"day":20,"city":"New York","county":"New York","state":"New York","country":"United States"},"gender":"male","marriages":[{"children_ids":["X00496"],"marriage_number":1}],"notable":{"is_notable":true,"notable_category":["law","social_reform","politics"],"notable_blurb":"Argued Black suffrage at NY Convention, 1821","primary_url":"https://en.wikipedia.org/wiki/Peter_Augustus_Jay_(lawyer)"},"number_of_marriages":1,"parents":{"father_name":"John Jay (1745-1829), first Chief Justice of the United States","mother_name":"Sarah Van Brugh Livingston"},"cross_connections":[],"bio":{"display_name":"Peter Augustus Jay","first_name":"Peter","last_name":"Jay","middle_name":"Augustus","married_names":[],"gender":"male","photo_url":"https://upload.wikimedia.org/wikipedia/en/a/ac/Peter_Augustus_Jay%2C_lawyer_and_anti-slavery_advocate.jpg"},"residence":{"city":"Rye","county":"Westchester","state":"New York","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST002","relationship":"alumnus"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"education":[{"school_name":"Columbia College","graduation_year":1794},{"school_name":"Harvard College (LL.D. honorary)","graduation_year":1832,"institution_id":"INST002"},{"school_name":"Columbia College (LL.D. honorary)","graduation_year":1835}],"career":[{"role":"Private Secretary","organization":"Chief Justice John Jay's London Mission (Jay Treaty)","start_year":1794,"end_year":1795,"notes":"Served as private secretary to his father during negotiation of the Jay Treaty with Britain in London."},{"role":"Recorder","organization":"City of New York","start_year":1819,"end_year":1821},{"role":"Delegate","organization":"New York State Constitutional Convention","start_year":1821,"end_year":1821,"notes":"Argued for Black suffrage during the convention; motion was overruled."},{"role":"Judge","organization":"Westchester County"},{"role":"President","organization":"New-York Manumission Society","start_year":1816,"notes":"Society founded by his father John Jay and Alexander Hamilton in 1785."},{"role":"President","organization":"New York Hospital","start_year":1827,"end_year":1833},{"role":"President","organization":"New-York Historical Society","start_year":1840,"end_year":1842},{"role":"Founder","organization":"New York Bank for Savings","start_year":1816,"notes":"Co-founded with Thomas Eddy — earliest savings bank in New York."},{"role":"Founder","organization":"New York Law Institute","start_year":1828,"notes":"Oldest law library in New York City."}],"narrative_blocks":[{"number":1,"category":"reform","header":"Argued Black suffrage at 1821 NY Convention","body":"At the 1821 New York State Constitutional Convention he moved that Black men be granted the same suffrage as white men — arguing that 'the idea that black people were naturally inferior had long been completely refuted and universally exploded.' The motion was overruled, and New York imposed a $250 property requirement on Black voters that effectively disenfranchised most. He was forty-five and had just stepped down as Recorder of New York City."},{"number":2,"category":"reform","header":"Led the Manumission Society his father co-founded","body":"He became President of the New-York Manumission Society in 1816 — the abolitionist society founded by his father John Jay and Alexander Hamilton in 1785. The role made him the institutional successor to the founding-era anti-slavery movement in New York. He also served simultaneously as President of the New York Public School Society, which his Manumission Society had helped create."},{"number":3,"category":"founding","header":"Founded New York Bank for Savings, 1816","body":"Co-founded the New York Bank for Savings with Thomas Eddy in 1816 — the earliest savings bank in New York and one of the first in the United States. He later founded the New York Law Institute in 1828, today the oldest law library in New York City. Both institutions still operate."}],"slug":"peter-jay-1776"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}