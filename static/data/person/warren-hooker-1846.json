ader":"Born 1869, died San Francisco 1949 age seventy-nine","body":"Joseph Warren Hooker was born December 13, 1869 and died February 4, 1949 in San Francisco California at age seventy-nine. He was the eldest documented son of his father Warren Hooker by Warren's first wife Elizabeth. The family's California migration was the western expression of the broader nineteenth-and-early-twentieth-century westward movement that drew Northeast-born Hookers across the continent."}],"cross_connections":[],"cross_reference":{"edward_hooker_1909":"4957"},"burial":{"plot_notes":"Olivet Gardens of Cypress Lawn Memorial Park, Colma, San Mateo County CA (per Findagrave)."},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"joseph-hooker-1869"},"X02168":{"id":"X02168","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"is_easter_egg":false,"include_in_path_calculation":false},"bio":{"first_name":"Ann","last_name":"Hooker","maiden_name":"Wilson","married_names":["Hooker"],"nickname":"Annie","gender":"female","display_name":"Ann \"Annie\" Wilson Hooker"},"birth":{"year":1870,"month":2,"day":8,"state":"Illinois","country":"United States"},"death":{"year":1949,"month":4,"day":10,"city":"San Francisco","county":"San Francisco County","state":"California","country":"United States"},"parents":{},"burial":{"plot_notes":"Olivet Gardens of Cypress Lawn Memorial Park, Colma, San Mateo County CA (per Findagrave)."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H04957","location_country":"United States","end_type":"death_of_spouse","end_year":1949,"children_ids":["HD3170","HD3171"]}],"tags":[],"sources":[{"short":"Findagrave (Olivet Gardens, Colma CA)"}],"notable":{"is_notable":fals