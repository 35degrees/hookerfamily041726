 37 — outlived John by 48 years","body":"John Newton died in May 1699, leaving Lydia with five children — the youngest barely two years old. She lived as a widow in Milford until October 23, 1747, dying at roughly age eighty-five after forty-eight years on her own."}],"quotes":[],"research_sources":[],"artworks":[],"bio":{"display_name":"Lydia Ford Newton","first_name":"Lydia","last_name":"Newton","married_names":["Newton"],"maiden_name":"Ford"},"documents":[],"military_service":[],"slug":"lydia-ford-1661"},"X00025":{"id":"X00025","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{},"death":{},"marriages":[{"spouse_id":"X00026","children_ids":["I00023"],"marriage_number":1}],"sources":[{"short":"Families of Early Milford, Connecticut","platform":"Ancestry.com"}],"gender":"male","tags":[],"number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Nathaniel Briscoe","first_name":"Nathaniel","last_name":"Briscoe","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"nathaniel-briscoe"},"X00026":{"id":"X00026","classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{},"death":{},"marriages":[{"spouse_id":"X00025","children_ids":["I00023"],"marriage_number":1}],"sources":[{"short":"Families of Early Milford, Connecticut","platform":"Ancestry.com"}],"gender":"female","tags":[],"number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Camp Br