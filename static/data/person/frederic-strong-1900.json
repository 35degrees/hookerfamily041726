ch — a craft requiring command of typography, page layout, and production under deadline pressure, invisible to readers but essential to every edition. His career carried him from the Milwaukee frontier family of his father Robert Hunter Strong to the newspaper rooms of the Twin Cities, where the printed word had been his vocation since before Minnesota had achieved the scale of a major American press market."}],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"},{"label":"History of Descendants of Elder John Strong, Vol. 1 (1871)","url":"https://dn720908.ca.archive.org/0/items/historyofdescend0001dwig/historyofdescend0001dwig.pdf"},{"label":"FindAGrave","url":"https://www.findagrave.com"}],"research_sources":[],"documents":[],"slug":"robert-strong-1863"},"I00925":{"id":"I00925","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Mary","middle_name":"Dibb","last_name":"Strong","maiden_name":"Dibb","married_names":["Strong"],"gender":"female","display_name":"Mary Dibb Strong"},"birth":{"year":1863,"month":10,"day":12,"state":"Minnesota","country":"United States"},"baptism":{},"death":{"year":1938,"month":10,"day":29,"county":"Ramsey County","state":"Minnesota","country":"United States"},"residence":{"country":"United States"},"burial":{"cemetery_id":"CEM445","plot_notes":"St. Anthony Cemetery Minneapolis per FA"},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4627","date_year":1887,"location_country":"United States","children_ids":["HD4641","HD4642","HD4643","HD4644","HD4