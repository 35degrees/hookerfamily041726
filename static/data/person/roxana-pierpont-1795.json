e_blocks":[{"number":1,"category":"legacy","header":"His five-thousand-dollar bequest transformed North Haven church","body":"On Ebenezer Pierpont's death in 1854, North Haven Congregational Church 'came into a legacy of five thousand dollars on the death of one of its oldest members.' The bequest was 'a munificent gift and marked the turning point in the history of the church.' His widow Lydia Blakeslee Pierpont added another thousand dollars at her own 1863 death nine years later — six thousand total, a remarkable sum for a mid-century Connecticut parish congregation."},{"number":2,"category":"family","header":"Wife Lydia Blakeslee outlived him by nine years","body":"Ebenezer married Lydia Blakeslee (born July 2, 1768) — daughter of Joel and Elizabeth Sackett Blakeslee. Lydia outlived him by nine years, dying July 22, 1863 in North Haven at age ninety-five, her own thousand-dollar bequest to the church supplementing his earlier five-thousand. The couple's combined legacy effectively endowed the North Haven Congregational Church mid-century operations."},{"number":3,"category":"family","header":"Born and died North Haven, age eighty-three","body":"Ebenezer Pierpont was born in 1771 in North Haven Connecticut and died March 4, 1854 in North Haven at approximately age eighty-three. His entire life unfolded within his birthplace town — a stability characteristic of the eighteenth-and-early-nineteenth-century New Haven County Pierpont families. His wife Lydia would live to ninety-five, an extraordinarily long life for her generation."}],"slug":"ebenezer-pierpont-1771"},"X00490":{"id":"X00490","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1768,"month":7,"day":2},"death":{"year":1863,"month":7,"day":22},"parents":{"father_id":"X00478"},"tags":[],"sources":[{"short":"Online vital records / Pierpont genealogy"}],"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1429","children_ids":["HD1526"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Lydia Blakeslee","first_name":"Lydia","maiden_name":"Blakeslee","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"lydia-blakeslee-1768"},"H00365":{"id":"H00365","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD0416","mother_id":"I00145"},"tags":["revolutionary_war","episcopal","extraordinary_longevity"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 365"}],"birth":{"year":1729,"month":4,"day":16,"city":"North Haven","state":"Connecticut"},"death":{"year":1820,"month":12,"day":24,"city":"North Haven","state":"Connecticut"},"marriages":[{"spouse_id":"X00455","children_ids":["H00865","H00866","H00867","H00868","H00869","H00870","H00871","HD1427","HD1428","HD1429"],"marriage_number":1,"date_year":1751,"date_month":11,"date_day":5}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Samuel Pierpont","first_name":"Samuel","last_name":"Pierpont","married_names":[],"bio_blurb":"Brick maker, Episcopal founder, warden fifty years"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"religion","header":"Founded Royalist Episcopal church at North Haven","body":"He was a founder and the first senior warden of St. John's Church of England in North Haven, elected at age thirty-two in 1761. The rector and majority of members were Royalists during the Revolution but accepted the new government afterward."},{"number":2,"category":"religion","header":"Senior warden for fifty years until death","body":"He continued as senior warden of St. John's, with few exceptions, for fifty years — until his death in 1820 at age ninety-one. He outlived his wife Elizabeth Frost by sixteen years."},{"number":3,"category":"career","header":"Brick maker who served the Revolution","body":"His occupation was brick maker in North Haven. Despite his Episcopal church's Royalist majority, he served in the Revolution — a fact recorded on his gravestone in the Old Cemetery."}],"burial":{"cemetery_id":"CEM307"},"slug":"samuel-pierpont-1729"},"X00455":{"id":"X00455","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1728,"month":3,"day":3,"city":"New Haven","state":"Connecticut"},"death":{"year":1804,"month":9,"day":20,"city":"New Haven","state":"Connecticut"},"gender":"female","parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H00365","children_ids":["H00865","H00866","H00867","H00868","H00869","H00870","H00871","HD1427","HD1428","HD1429"]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Elizabeth Frost","first_name":"Elizabeth","maiden_name":"Frost","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_id":"CEM307"},"slug":"elizabeth-frost-1728"},"X00478":{