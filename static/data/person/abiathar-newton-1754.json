scendant":false,"is_easter_egg":false,"generation_from_thomas":9},"bio":{"display_name":"Augusta Clarinda Newton Bosworth","first_name":"Augusta Clarinda","last_name":"Bosworth","married_names":[],"maiden_name":"Newton"},"birth":{"year":1834,"date_precision":"exact"},"death":{"year":1889,"date_precision":"exact"},"parents":{"father_id":"HD6431","mother_id":"I01780"},"marriages":[],"tags":[],"slug":"augusta-clarinda-bosworth-1834"},"HD6432":{"id":"HD6432","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false,"generation_from_thomas":8},"bio":{"display_name":"Mary Newton","first_name":"Mary","last_name":"Newton","married_names":[]},"birth":{"year":1800,"date_precision":"exact"},"death":{"year":1829,"date_precision":"exact"},"parents":{"father_id":"HD0163","mother_id":"I01778"},"marriages":[],"tags":["died_unmarried"],"slug":"mary-newton-1800"},"H00149":{"id":"H00149","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":5,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1729,"month":7,"day":20,"city":"Durham","state":"Connecticut","country":"United States"},"death":{"year":1807,"month":4,"day":16,"city":"Durham","state":"Connecticut"},"parents":{"father_id":"HD0007","mother_id":"I00026"},"tags":["durham_newton","revolutionary_war"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 149"},{"short":"Caroline Gaylord Newton 1914"}],"marriages":[{"spouse_id":"I00083","children_ids":["HD0163","HD0164","HD0166","HD0169","HD0170","HD6418","HD6420","HD6419","HD0165","HD0167","HD0168"],"marriage_number":1}],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"narrative_blocks":[{"header":"Born without a roof to his mouth","detail":"His principal crop was rye; he spelled it 'ri.' His carefully kept account book, dated January 1, 1762, survived and was published in Caroline Newton's family history. The speech impediment was not only a social burden — it shaped his entire Revolutionary War service. Strangers could not understand him, and when he could not give the countersign intelligibly, he risked being shot by his own side. When Britain declared war with France and the colonial militia faced possible service in Canada, his Captain consulted a higher officer, who granted Burwell an exemption from duty. The document of exemption was preserved in the family. (Caroline Gaylord Newton 1914)","body":"When the children in the little schoolhouse on Phillida Hill laughed at his cleft-palate speech, Burwell refused to attend. He taught himself to read, write, and keep accounts, his spelling defiantly phonetic — if he chose to spell his principal crop “ri,” that was the best way to spell it.","number":1,"category":"character"},{"header":"Defended Kingston and the Continental Congress in 1777","detail":"His service in both deployments was brief — not from cowardice but from the practical impossibility of the countersign problem. His unit could not rely on him for sentry duty or night patrol, since any stranger who challenged him could not understand his response. He served with what he could offer and was released. He is on the DAR lineage rolls through his descendant Miss Sarah Newton Church (NSDAR No. 99934; DAR Lineage Book 100:291). (Caroline Gaylord Newton 1914; EH 1909)","body":"In 1777 Burwell was at Kingston, New York, when the Continental Congress was assembled there under threat from British troops. In 1779 he enlisted in Capt. Charles Norton's Company, Col. Thaddeus Cook's regiment, and was called to New Haven and Fairfield during the British coastal raids of July 1779.","number":2,"category":"military"},{"number":3,"category":"military","header":"His stammer nearly kept him from war","body":"Born without a roof to his mouth, Burwell Newton could not give a military countersign clearly enough for strangers to understand — a danger that could get a sentry shot. When Britain’s war with France threatened to send the militia to Canada, Col. Timothy Stone authorized his discharge, writing that officers had “full Power to Relieve any Soldier… unfit for service.”"}],"cross_connections":[{"type":"family_connection","related_id":"HD6448","link_text":"Henry Gleason Newton","display_label":"a great-great-grandson who overcame the same speech difficulty"}],"military_service":[{"war":"American Revolutionary War","active_in_war":true,"dates":"1777, 1779","unit":"Captain Charles Norton's Company","notes":"At the defence of Kingston, New York, 1777, when Continental Congress was assembled there and threatened by British troops. Called to New Haven and Fairfield in July 1779. Did not remain long in service — his speech impediment made it dangerous: strangers could not understand him and he risked being shot when unable to give the countersign intelligibly.","war_id":"WAR004"}],"bio":{"display_name":"Burwell Newton","first_name":"Burwell","last_name":"Newton","married_names":[],"bio_blurb":"Durham farmer who soldiered despite a cleft palate"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"slug":"burwell-newton-1729"},"I00083":{"id":"I00083","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"marriages":[{"spouse_id":"H00149","children_ids":["HD0163","HD0164","HD0166","HD0169","HD0170","HD6418","HD6420","HD6419","HD0165","HD0167","HD0168"],"marriage_number":1}],"sources":[{"short":"Caroline Gaylord Newton 1914"}],"gender":"female","tags":[],"number_of_marriages":1,"parents":{},"notable":{"is_notable":false,"notable_category":[]},"birth":{"year":1733,"month":9,"day":16,"date_precision":"exact"},"death":{"year":1771,"month":1,"day":21,"date_precision":"exact"},"cross_connections":[],"bio":{"display_name":"Eunice Johnson Newton","first_name":"Eunice","last_name":"Newton","married_names":["Newton"],"maiden_name":"Johnson","bio_blurb":"Descendant of two men burned by frontier raiders"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"She left seven children and a newborn","body":"Eunice Johnson married Burwell Newton at nineteen and bore eight children before dying at thirty-eight, weeks after her last son Isaac was born. With no mother and a father who never remarried, the children kept house themselves — the eldest seventeen, the youngest daughters eleven and eight."},{"number":2,"category":"ancestry","header":"Two of her forebears were burned by raiders","body":"Eunice descended from a family marked by frontier violence: her great-great-grandfather Capt. John Plympton was captured and burned at the stake near Deerfield in 1675 during King Philip’s War, and her great-grandfather Nathaniel Sutliff met the same fate the following year. The orphaned Sutliff children received a grant of land for their support."}],"slug":"eunice-johnson-1733"},"HD0007":{"id":"HD0007","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":4,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1699,"month":5,"day":14,"city":"Milford","state":"Connecticut"},"parents":{"father_id":"H00011","mother_research_notes":"Sarah Welch Fowler, second wife of Samuel Newton","mother_id":"X00097","mother_name":"Sarah Welch Fowler"},"sources":[{"short":"Caroline Gaylord Newton 1914"},{"short":"Families of Early Milford","platform":"Ancestry.com"}],"death":{"year":1769,"month":2,"day":24,"city":"Durham","state":"Connecticut"},"marriages":[{"spouse_id":"I00026","children_ids":["H00147","H00148","H00149","H00150","H00151","X00027"],"marriage_number":1,"date_year":1724}],"marriage_date":{"year":1724,"notes":"Married early 1724; deed dated June 18, 1724 gives \"Abner Newton of Milford and Mary his wife\""},"primary_residence":{"city":"Durham","state":"Connecticut","notes":"Removed from Milford to Durham, settling there in late 1724. Deed of July 1724 calls him \"Abner Newton of Milford\"; deed of December 1724 calls him \"Abner Newton, late of Milford, now of Durham.\""},"tags":["durham_newton"],"gender":"male","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Abner Newton","first_name":"Abner","last_name":"Newton","married_names":[]},"landmarks":[],"residence":{"city":"Durham","state":"Connecticut","country":"United States"},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST022"}],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Half-brother shared same first name, Abner","body":"This Abner Newton was born 1699 to Samuel Newton's second wife Sarah Welch Fowler — distinguishing him from his half-brother Abner Newton baptized May 1689, who had been born to Samuel's first wife Martha Fenn ten years earlier. The repeated Abner name across both marriages was uncommon. The 1699 Abner became the documented ancestor of the Durham Newton branch — earning the 'durham_newton' tag in this entry."},{"number":2,"category":"family","header":"1724 Milford-to-Durham move; wife sold inherited share","body":"In 1724 Abner Newton and Mary Burwell removed from Milford to Durham Connecticut — and on the move Mary sold her own inherited property, a quarter share of a dwelling house and home-lot in Milford, to Susannah Burwell (widow of John Burwell) for eighty pounds. Per the deed boundaries this was the homestead of the first John Burwell, occupied since 1639. Mary had kept a share in her family's original Milford homestead until the day she left for Durham."},{"number":3,"category":"character","header":"Son Roger received Alice Newton's Yale bequest","body":"Abner's son Roger Newton was the beneficiary of Alice Newton's ca.1740 conditional Yale bequest — establishing the family's Yale-funded ministerial track. Roger graduated Yale 1758 and served fifty-six years as minister at Greenfield Massachusetts until 1816 — one of the longest continuous American pastorates of the Revolutionary-Republican era."}],"burial":{"cemetery_id":"CEM569"},"slug":"abner-newton-1699"},"I00026":{"id":"I00026","classification":{"include_in_path_calculation":true,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1698,"month":8,"day":28},"death":{"year":1759,"month":4,"day":9},"parents":{"father_id":"X00027","mother_id":"X00028"},"marriages":[{"spouse_id":"HD0007","children_ids":["H00147","H00148","H00149","H00150","H00151","X00027"],"marriage_number":1,"date_year":1724}],"sources":[{"short":"Families of Early Milford, Connecticut","platform":"Ancestry.com"}],"gender":"male","tags":[],"number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Mary Burwell","first_name":"Mary","last_name":"Burwell","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"mary-burwell-1698"}},"burialCemetery":{"id":"CEM889","name":"West Hartland Cemetery","city":"Hartland","county":"Hartford County","state":"Connecticut","country":"United States","gps":{"lat":42.00709,"lng":-72.97209},"url":"https://www.findagrave.com/cemetery/2140640/west-hartland-cemetery"},"institutionsById":{},"crossConnections":[]}