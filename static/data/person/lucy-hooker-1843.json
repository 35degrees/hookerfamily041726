:"family","header":"Buried infant Worthington; named next son Worthington","body":"Festus named his fifth child Worthington in April 1846, but the infant died December 10 of that year at eight months. His sixth son, born November 1848, was named Worthington again — the replacement naming common in the era, and a pattern repeated in the same Hooker generation when his uncle Henry named a daughter Almira after a deceased sibling."},{"number":2,"category":"family","header":"He gave the lost son’s name again","body":"When his infant son Worthington died, the Westhampton farmer gave the name again to his next boy — a quiet act of remembrance carried in the family register."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"festus-hooker-1806"},"I01164":{"id":"I01164","is_placeholder":false,"former_ids":[],"bio":{"display_name":"Mary Strong Hooker","first_name":"Mary","last_name":"Hooker","maiden_name":"Strong","married_names":["Hooker"]},"gender":"female","birth":{"year":1812,"month":1,"day":20,"city":"Huntington","county":"Hampshire","state":"Massachusetts","country":"United States"},"death":{"year":1894,"month":10,"day":3,"city":"Westhampton","county":"Hampshire","state":"Massachusetts","country":"United States"},"baptism":{},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"is_talcott_spouse":false,"include_in_path_calculation":false,"is_easter_egg":false},"parents":{"father_research_notes":"Chester Strong of Huntington MA per EH 1909 #2749.","mother_research_notes":"Rachel (Bartlett) Strong per EH 1909 #2749."},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"H02749","date_year":1832,"date_month":8,"date_day":9,"location_state":"Massachusetts","location_country":"United States","end_type":"death","end_year":1881,"children_ids":["H04346","H04347","H04348","H04349","H04350","H04351","H04352"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[]