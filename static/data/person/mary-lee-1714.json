States","end_type":"death","end_year":1866,"children_ids":["H02228","H02229","H02230","H02231","H02232","H02233","H02234","H02235","H02236","H02237","H02238"],"location_city":"Farmington","location_county":"Hartford","location_state":"Connecticut"}],"education":[{"institution_id":"INST058","type":"undergraduate","notes":"Dartmouth College graduate."}],"career":[{"role":"Physician","location":"Boston MA, Albany/Durham/Pompey/Monticello NY, Liberty/Candor/Ulysses PA","notes":"Practiced medicine in multiple locations across Massachusetts, New York, and Pennsylvania."}],"military_service":[{"war":"War of 1812","war_id":"WAR009","rank":"Surgeon","rank_end":"Surgeon","unit":"21st Regiment, New York","notes":"Surgeon of the 21st Regiment New York during the War of 1812. Stationed at Sackets Harbor NY — a key American naval base on Lake Ontario."}],"institutions":[{"institution_id":"INST058","relationship":"alumnus","institution_blurb":"Dartmouth College graduate; subsequently practiced medicine."}],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["physician","war_of_1812","new_york_migration","extraordinary_longevity","academic"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"military","header":"Dartmouth surgeon stationed at Sackets Harbor","body":"Giles Gridley graduated Dartmouth and practiced medicine before serving as surgeon of the 21st New York during the War of 1812. He was stationed at Sackets Harbor, the American naval base on Lake Ontario where Commodore Chauncey's fleet faced repeated British attacks 1812-1814."},{"number":2,"category":"career","header":"Practiced medicine across three states","body":"Giles practiced in Boston Massachusetts, then across upstate New York (Albany, Durham, Pompey, Monticello), and finally settled in northern Pennsylvania (Liberty, Candor, Ulysses). Few physicians of his era moved that many times — possibly tied to the receding frontier of medical practice as settlements matured."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"giles-gridley-1769"},"H01093":{"id":"H01093","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"Thomas","middle_name":"Hooker","last_name":"Gridley","married_names":[],"gender":"male","display_name":"Thomas Hooker Gridley"},"birth":{"year":1775,"month":1,"day":31,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"baptism":{},"death":{"year":1857,"month":8,"day":4,"city":"North Chili","county":"Monroe","state":"New York","country":"United States"},"residence":{"city":"North Chili","county":"Monroe","state":"New York","country":"United States"},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":7,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"X02647","mother_id":"H00409"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"X02649","date_year":1800,"date_month":2,"date_day":23,"location_country":"United States","end_type":"death_of_spouse","end_year":1826,"children_ids":["H02239","H02240","H02241","H02242","H02243","H02244"]}],"education":[],"career":[{"role":"Farmer","location":"Kensington CT, Durham NY, Pompey NY, North Chili NY","notes":"Farmed across multiple Connecticut and New York locations through his lifetime."}],"military_service":[{"war":"War of 1812","war_id":"WAR009","rank":"Soldier","notes":"Soldier of the War of 1812, stationed at Oswego NY — Lake Ontario port and frontline against British attack 1814."}],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Hooker","inspired_by_id":"H00001","description":"Middle name honors his great-great-great-grandfather Rev. Thomas Hooker, founder of Hartford CT."}],"artworks":[],"tags":["named_for_hooker","war_of_1812","new_york_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Named for his ancestor Reverend Thomas Hooker","body":"Thomas Hooker Gridley was given the full name of his great-great-great-grandfather Rev. Thomas Hooker, founder of Hartford. The naming honored a preacher five generations removed who had died in 1647 — a 1775 echo of the Puritan founding."},{"number":2,"category":"military","header":"War of 1812 soldier at Oswego frontier","body":"Thomas Hooker Gridley served as a soldier at Oswego NY during the War of 1812. The Lake Ontario port was captured by the British in May 1814 and the fort burned. His specific role and fate during the engagement are not documented in EH 1909."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"thomas-gridley-1775"},"H00410":{"id":"H00410","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"birth":{"year":1734,"month":4,"day":16,"city":"Kensington","county":"Hartford","state":"Connecticut","country":"United States"},"death":{"year":1757,"month":6,"day":10,"country":"United States","cause":"Killed in action — shot by Native American sharp-shooter at sentry post"},"parents":{"father_id":"H00223","mother_id":"I00149"},"tags":["french_indian_war"],"sources":[{"short":"Edward Hooker 1909","page":"Entry 410"},{"short":"Berlin-Peck F&I War PDF","url":"https://berlinpeck.org/wp-content/uploads/2022/08/Berlin-in-the-French-and-Indian-War-1753-%E2%80%93-1763.pdf","source_id":"berlin_peck_french_indian_war"}],"gender":"unknown","marriages":[],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[{"type":"military","related_id":"H00228","display_label":"Uncle Samuel Jr enlisted weeks after his June death.","link_text":"Samuel Hooker Jr."}],"military_service":[{"war":"French and Indian Wars","war_id":"WAR003","rank":"Private","rank_start":"Private","rank_end":"Private","rank_year_start":1757,"rank_year_end":1757,"unit":"10th Company under Capt. Eliphalet Whittlesey of Newington, Col. Phineas Lyman's Regiment","service_years":"March 8 – June 10, 1757","notes":"Enlisted March 8, 1757 at age 22. Killed in action June 10, 1757 while volunteering for a sentry post where multiple soldiers had previously been picked off by Native American sharp-shooters. Served alongside John Beckley (mar 28-Nov 24, 1757) and Silas Beckley (mar 28-Nov 11, 1757, also died). See notable_story 'martin_hooker_sentry_revenge_1757' for the family-tradition sequel preserved in EH 1909."}],"bio":{"display_name":"Martin Hooker","first_name":"Martin","last_name":"Hooker","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"narrative_blocks":[{"number":1,"category":"death","header":"Killed by Native American sharpshooter at sentry post","body":"Martin enlisted March 8, 1757 in Capt. Eliphalet Whittlesey's 10th Company under Col. Phineas Lyman's Regiment. He was killed June 10, 1757 while volunteering for a sentry post where multiple soldiers had previously been picked off by Native American sharp-shooters."},{"number":2,"category":"character","header":"Family tradition: avenged by friend's hog stratagem","body":"Edward Hooker's 1909 genealogy preserved a tradition that days after Martin's death a close friend volunteered for the same post and shot a hog he saw rooting nearby. Inside the hog skin lay the body of the Native American assassin who had been using it as cover; Martin was reportedly the last sentry killed at that post."}],"slug":"martin-hooker-1734"},"H00411":{"id":"H00411","