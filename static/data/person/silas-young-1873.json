type":"death","end_year":1953,"children_ids":["HD4288","HD4297","HD4298","HD4299","HD4300","HD4301","HD4302","HD4303","HD4304","HD4305"]}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["pennsylvania_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"silas-young-1873"},"HD4276":{"id":"HD4276","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Bertha","middle_name":"Mae","last_name":"Young","maiden_name":"Unger","married_names":["Lybarger","Young"],"gender":"female","display_name":"Bertha Mae Unger Young"},"birth":{"year":1884,"month":12,"day":15,"city":"Meadville","county":"Crawford County","state":"Pennsylvania","country":"United States"},"baptism":{},"death":{"year":1959,"month":3,"day":19,"city":"Hollywood","county":"Broward County","state":"Florida","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM339","plot_notes":"Greendale Cemetery, Meadville Crawford County PA — body returned from Florida."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":10,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00668","mother_id":"HD4273"},"number_of_marriages":2,"marriages":[{"marriage_number":1,"spouse_id":"I00671","date_year":1902,"location_state":"Pennsylvania","location_country":"United States","end_type":"death_of_spouse","end_year":1913,"children_ids":["HD4281","HD4282","HD4296"],"spouse_research_notes":"Freeman Delbert Lybarger (I00671, 1874 MN - 1913 PA). Two confirmed sons: Freeman Wilbur Lybarger (1906-1988, WWII vet), Irvin Clarence Lybarger (1908-1973). Per Gertrude Winger's 2014 obit there may have been additional siblings: 'Chester, Irvin, and Wilbur Lybarger' — Chester (and possibly others) to be researched. Children built later stages."},{"marriage_number":2,"spouse_id":"I00672","date_year":1925,"location_state":"Pennsylvania","location_country":"United States","end_type":"death_of_spouse","end_year":1953,"children_ids":["HD4288","HD4297","HD4298","HD4299","HD4300","HD4301","HD4302","HD4303","HD4304","HD4305"],"spouse_research_notes":"Silas Howard Young (I00672, 1873-1953). Multiple children — confirmed Gertrude Virginia Young Winger (1926-2014); per Gertrude's obit also Joseph, Noble, Leah, Austin, Reno, David Young, Lois Stanley, Paul Young, Dortha Free. Children to be built later stages."}],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["pennsylvania_migration","florida_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Twice widowed, ended life far from home","body":"Bertha Mae Unger was widowed twice — first when Freeman Delbert Lybarger died in 1913 at thirty-nine, then when second husband Silas Howard Young died in 1953 after twenty-eight years of marriage. She moved south to Florida in her later years and died in Hollywood Broward County in 1959 at seventy-four. Her body was returned to Meadville and buried at Greendale Cemetery."},{"number":2,"category":"family","header":"Two husbands, many children across both marriages","body":"Bertha's first marriage to Freeman Lybarger produced at least two confirmed sons before his 1913 death — Freeman Wilbur (1906) and Irvin Clarence (1908). Her second marriage to Silas Young in 1925 produced multiple Young children including Gertrude Virginia born 1926. Per a later family obituary at least ten siblings spanned the two marriages — many remain unbuilt pending research."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"bertha-young-1884"},"HD4288":{"id":"HD4288","former_ids":[],"is_placeholder":false,"has_descendants_documented":true,"bio":{"first_name":"Gertrude","middle_name":"Virginia","last_name":"Winger","maiden_name":"Young","married_names":[],"gender":"female","display_name":"Gertrude Virginia Young Winger","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778725743/gertrude_gcgaxk.jpg","photo_notes":"Portrait of Gertrude Virginia Young Winger (1926-2014)."},"birth":{"year":1926,"month":2,"day":14,"city":"Meadville","county":"Crawford County","state":"Pennsylvania","country":"United States"},"baptism":{},"death":{"year":2014,"month":1,"day":16,"city":"Gerry","county":"Chautauqua County","state":"New York","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM359","plot_notes":"Grove Hill Cemetery, Oil City Venango County PA — with husband William Burton Winger."},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":11,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00672","mother_id":"HD4276"},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I00680","date_year":1951,"date_month":12,"date_day":7,"location_city":"Cochranton","location_county":"Crawford County","location_state":"Pennsylvania","location_country":"United States","end_type":"death_of_spouse","end_year":2012,"children_ids":[],"spouse_research_notes":"William Burton Winger (I00680, 1922-2012). Five children per Gertrude's 2014 obit: Michael Winger (Lakewood CO), Luann Valdesalice (Franklin PA), Laura Winger (Spring Lake NC), Gerald Winger (Gaston SC), Amy Liddle (Rochester NY). Seven grandchildren also named in obit."}],"education":[{"school_name":"Meadville High School","type":"high school","notes":"Graduate."},{"school_name":"Meadville School of Nursing","type":"nursing","notes":"Trained as registered nurse."}],"career":[{"role":"Registered Nurse (retired)","organization":"Franklin Hospital","location":"Franklin, Venango County, Pennsylvania","notes":"Employed many years as a nurse, retiring from Franklin Hospital. Multiple Methodist church memberships across Venango County and Chautauqua County NY."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["pennsylvania_migration","new_york_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"family","header":"Same Valentine's Day birthday as uncle Ransom Unger","body":"Gertrude was born February 14, 1926 in Meadville Pennsylvania — sharing a Valentine's Day birthday with her maternal uncle Ransom Andrew Unger, born exactly thirty-eight years earlier on February 14, 1888. Both members of the same extended Crawford County Ellis-Unger family separated by a generation. Her mother Bertha would have known the family date."},{"number":2,"category":"marriage","header":"Wedding date was tenth anniversary of Pearl Harbor","body":"Gertrude married William Burton Winger on December 7, 1951 at Cochranton Pennsylvania — the ten-year anniversary of the Pearl Harbor attack. She was twenty-five, he was twenty-nine. They celebrated their sixtieth wedding anniversary in 2011, the year before his death."},{"number":3,"category":"family","header":"Last surviving among eleven predeceased siblings","body":"When Gertrude died in January 2014, she had outlived eleven documented half-siblings — nine Young, Stanley, and Free half-siblings from her mother's second marriage, plus Chester, Irvin, and Wilbur Lybarger from her mother's first marriage. Her own marriage to William Winger lasted sixty years until his June 2012 death, and she followed him eighteen months later."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"gertrude-winger-1926"},"I00680":{"id":"I00680","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"bio":{"first_name":"William","middle_name":"Burton","last_name":"Winger","married_names":[],"gender":"male","display_name":"William Burton Winger","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1778725800/williamwingeer_yjborr.jpg","photo_notes":"Portrait of William Burton Winger (1922-2012)."},"birth":{"year":1922,"month":2,"day":6,"city":"Oil City","county":"Venango County","state":"Pennsylvania","country":"United States"},"baptism":{},"death":{"year":2012,"month":6,"day":29,"city":"Gerry","county":"Chautauqua County","state":"New York","country":"United States"},"residence":{},"burial":{"cemetery_id":"CEM359","plot_notes":"Grove Hill Cemetery, Oil City Venango County PA — with wife Gertrude."},"classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"include_in_path_calculation":false,"descent_paths_to_thomas":0,"descent_from_thomas_hooker":false,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD4288","date_year":1951,"date_month":12,"date_day":7,"location_city":"Cochranton","location_county":"Crawford County","location_state":"Pennsylvania","location_country":"United States","end_type":"death","end_year":2012,"children_ids":[]}],"education":[],"career":[{"role":"Shipping department employee (retired)","organization":"Pennzoil Refinery","location":"Rouseville, Venango County, Pennsylvania","start_year":1946,"end_year":1986,"notes":"Forty years in the shipping department of Pennzoil Refinery at Rouseville, retiring in 1986. Hobbies: lawn care + landscape, woodworking, H-O scale model railroads."}],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["pennsylvania_migration","new_york_migration"],"research_tags":[],"cross_connections":[],"narrative_blocks":[{"number":1,"category":"career","header":"Born Oil City, forty years at Pennzoil Refinery","body":"William Winger was born February 6, 1922 in Oil City Pennsylvania — the same Venango County oil region where his wife's great-grandmother Florence Hannah Ellis had been born at Pithole fifty-eight years earlier. He spent forty years at Pennzoil Refinery's shipping department in Rouseville, retiring in 1986. The Pennsylvania oil industry that had briefly turned Pithole into a fifteen-thousand-person boomtown in 1865 became the family livelihood three generations later."},{"number":2,"category":"family","header":"Sixty year marriage, hobbyist woodworker and railroader","body":"William married Gertrude Virginia Young on December 7, 1951 — the tenth anniversary of Pearl Harbor. They celebrated their sixtieth anniversary in 2011 and he died the following year on June 29, 2012 at ninety. He enjoyed lawn care, woodworking, and H-O scale model railroads in retirement."}],"quotes":[],"sources":[],"research_sources":[],"documents":[],"slug":"william-winger-1922"},"HD4297":{"id":"HD4297","former_ids":[],"is_placeholder":true,"has_descendants_documented":false,"bio":{"first_name":"Joseph","last_name":"Young","married_names":[],"gender":"male","display_name":"Joseph Young"},"birth":{},"baptism":{},"death":{},"residence":{},"burial":{},"classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"is_thomas_spouse":false,"is_talcott_spouse":false,"generation_from_thomas":11,"include_in_path_calculation":true,"descent_paths_to_thomas":1,"descent_from_thomas_hooker":true,"is_progenitor":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I00672","mother_id":"HD4276"},"marriages":[],"education":[],"career":[],"military_service":[],"institutions":[],"landmarks":[],"naming_inspiration":[],"artworks":[],"tags":["pennsylvania_migrati