escendant":false,"is_easter_egg":false},"birth":{"year":1863,"month":9,"day":8,"city":"Philadelphia","state":"Pennsylvania"},"death":{"year":1935,"city":"Philadelphia","state":"PA"},"parents":{"mother_id":"HD0731","father_research_notes":"Charles Henry Smith","father_id":"X01295"},"tags":["artist"],"sources":[],"prominent_name_reason":"Jessie Willcox Smith (1863-1935) — celebrated American illustrator of the Golden Age. Studied at Pennsylvania Academy of Fine Arts under Thomas Eakins; studied under Howard Pyle at Drexel University 1894. Illustrated 60+ books including Louisa May Alcott's Little Women, Robert Louis Stevenson's A Child's Garden of Verses, and Longfellow's Evangeline. Created all Good Housekeeping covers Dec 1917 to 1933. \"One of the greatest pure illustrators\" of the early 20th century. Lived with \"The Red Rose Girls\" (Elizabeth Shippen Green, Violet Oakley) — a celebrated artistic household in Villanova PA. Never married; no children. Descendant of Thomas Hooker through: Jesse Hart → Harriet Hart Willcox → Katherine Willcox Smith → Jessie Willcox Smith. Wikipedia: https://en.wikipedia.org/wiki/Jessie_Willcox_Smith","gender":"female","marriages":[],"notable":{"is_notable":true,"notable_category":["arts"],"notable_blurb":"Foremost American children's-book illustrator of her era","primary_url":"https://en.wikipedia.org/wiki/Jessie_Willcox_Smith","primary_url_label":"Wikipedia"},"cross_connections":[{"type":"parallel_careers","related_id":"TD0241","display_label":"Followed at PAFA next generation; Mary Smith Prize 1908 and 1912","link_text":"Elizabeth Sparhawk-Jones"},{"type":"parallel_careers","related_id":"HD5941","display_label":"a fellow woman who broke into commercial art"}],"bio":{"display_name":"Jessie Willcox Smith","first_name":"Jessie","middle_name":"Willcox","maiden_name":"Smith","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST141","relationship":"alumnus","years":"1885-1888","institution_blurb":"Studied at the Pennsylvania Academy of the Fine Arts under Thomas Eakins."}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"career","header":"Sixteen years of Good Housekeeping covers","body":"She illustrated every monthly cover of Good Housekeeping from December 1917 through April 1933 — nearly two hundred paintings of children, mothers, and seasonal moments. Those covers shaped a generation's image of American childhood."},{"number":2,"category":"career","header":"Defined the look of Heidi and Mother Goose","body":"Her illustrations for The Water-Babies (1916), Little Women (1915), Heidi (1922), and A Child's Garden of Verses (1905) became the definitive editions of those books for two generations of American readers. She turned down film and theater commissions to keep illustration as her sole career."},{"number":3,"category":"education","header":"Studied under Eakins and Howard Pyle","body":"She trained at the Pennsylvania Academy of the Fine Arts under Thomas Eakins and at Drexel under Howard Pyle, the foremost American illustrator of his generation. Pyle reportedly called her one of his most gifted students."},{"number":4,"category":"family","header":"Three women artists ran a household together","body":"She lived with fellow illustrators Violet Oakley and Elizabeth Shippen Green at 'Cogslea,' a converted inn outside Philadelphia. The three built independent careers, traveled together, and supported each other's work for nearly thirty years."}],"education":[{"institution_id":"INST141","type":"art_academy","dates":"1885-1888","notes":"Studied under Thomas Eakins; later trained with Howard Pyle at Drexel."}],"career":[{"role":"Illustrator","start_year":1888,"end_year":1935,"notes":"Good Housekeeping cover artist for sixteen years; illustrated Heidi, Mother Goose, and other classics."}],"slug":"jessie-smith-1863"}},"burialCemeter