rd); claimed to be the longest-running family law firm in Wisconsin."},{"role":"Owner/Operator","organization":"Hooker-Dunham Building, East Main Street, Waupun Wisconsin","notes":"Owned and operated the Hooker-Dunham building on East Main Street Waupun. Per Waupun/Brattleboro history sources."}],"military_service":[{"war":"World War I","war_id":"WAR007","rank":"Enlisted","unit":"US Army (unit unknown)","notes":"Per Waupun city history records: \"Hooker, Edward — 1914-1918, Served in WW I.\" American service likely 1917-1918. No specific unit or rank documented."}],"institutions":[],"landmarks":[],"naming_inspiration":[{"name_element":"Wight","description":"Middle name 'Wight' honors his mother Mary Augusta Wight Hooker's family surname."}],"artworks":[],"tags":["wwi"],"research_tags":[],"cross_connections":[],"narrative_blocks":[],"quotes":[],"sources":[{"label":"Edward Hooker, Descendants of Rev. Thomas Hooker (1909)","url":"https://archive.org/details/descendantsofrev00hook"}],"research_sources":[],"documents":[],"slug":"edward-hooker-1899"}},"burialCemetery":null,"institutionsById":{},"crossConnections":[]}