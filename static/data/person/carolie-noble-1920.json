1896,"month":6,"day":12,"city":"Ramapo","county":"Rockland County","state":"New York","country":"United States"},"death":{"year":1985,"month":1,"day":25,"city":"Mystic","state":"Connecticut","country":"United States","age":88,"cause":"cardiac arrest"},"marriages":[{"marriage_number":1,"spouse_id":"X00385","date_year":1916,"date_month":6,"date_day":10,"children_ids":["HD1234","HD1235","HD1236","HD1237"]}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":true,"notable_category":["military_officer","historic_preservation","public_service"],"notable_blurb":"WAC deputy director WWII; National Trust founding trustee","primary_url":"https://en.wikipedia.org/wiki/Helen_Morgan_Hamilton","primary_url_label":"Helen Morgan Hamilton — Wikipedia"},"cross_connections":[],"bio":{"display_name":"Helen Morgan Hamilton Burgess","first_name":"Helen","last_name":"Burgess","maiden_name":"Hamilton","middle_name":"Morgan","married_names":["Burgess"]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[{"war":"World War II","war_id":"WAR008","side":"United States","rank":"Lieutenant Colonel","rank_start":"Officer","rank_end":"Lieutenant Colonel","rank_year_start":1942,"rank_year_end":1947,"unit":"Women's Army Corps — Deputy Director 1945-1947","notes":"Entered United States Army during WWII after first husband's 1942 death. Active in formation of Women's Auxiliary Army Corps (later WAC). Served as Deputy Director WAC 1945-1947. Achieved rank of Lieutenant Colonel. Awarded Legion of Merit and Army Commendation Medal."}],"narrative_blocks":[{"number":1,"category":"military","header":"Deputy Director Women's Army Corps, World War II","body":"After her first husband's 1942 death, Helen entered the United States Army and served as Deputy Director of the Women's Army Corps from 1945 to 1947 — one of the highest positions held by any woman in the U.S. Army during the immediate postwar period. She achieved the rank of Lieutenant Colonel and was awarded the Legion of Merit and the Army Commendation Medal for her service. Her three sons had already entered military service when she joined them."},{"number":2,"category":"career","header":"Founding trustee, National Trust for Historic Preservation","body":"Helen was a founding trustee of the National Trust for Historic Preservation in 1953 — the Congressionally-chartered nonprofit established that year to preserve America's historic places — and served in that role for twenty-five years until 1978. She also served as president of the Foundation for the Preservation of Historic Georgetown, where she lived for many years, and as Fellow of the Pierpont Morgan Library in New York."},{"number":3,"category":"career","header":"Director of public liaison, Marshall Plan administration","body":"In 1949 Helen became Director of Public Liaison for the Economic Cooperation Administration — the U.S. government agency that administered the Marshall Plan to rebuild postwar Europe. The role placed her at the center of one of the most consequential American foreign-policy programs of the twentieth century. In 1957 she was appointed consultant to U.S. Secretary of War Robert P. Patterson on the proposed universal military training program."},{"number":4,"category":"family","header":"J.P. Morgan granddaughter, Alexander Hamilton great-great-granddaughter","body":"Helen's maternal grandfather was financier J.P. Morgan; her maternal grandmother was Fanny Tracy Morgan. She was also a great-great-granddaughter of Alexander Hamilton, the first U.S. Secretary of the Treasury. The Hamilton-Morgan-Hooker confluence in her ancestry placed her in three of the most prominent American family lines of the eighteenth, nineteenth, and twentieth centuries."},{"number":5,"category":"family","header":"Born Ramapo NY 1896, died Mystic CT 1985","body":"Helen Morgan Hamilton was born June 12, 1896 in Ramapo, Rockland County New York — the eldest of five children of William Pierson Hamilton and Juliet Pierpont Morgan. She died of cardiac arrest on January 25, 1985 in Mystic Connecticut at age eighty-eight. Her four children with Col. Arthur Hale Woods included Distinguished Flying Cross naval aviator John Pierpont Woods (1918-2012) and OSS officer Alexander Hamilton Woods (1922-2008)."}],"slug":"helen-burgess-1896"},"X00384":{"id":"X00384","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1869},"death":{"year":1950},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD1173","children_ids":["HD1229","HD1230","HD1231","HD1232","HD1233"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"William Pierson Hamilton","first_name":"William","last_name":"Hamilton","middle_name":"Pierson","married_names":[]},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"slug":"william-hamilton-1869"},"HD1173":{"id":"HD1173","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":9,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD1170","mother_id":"X00360"},"tags":[],"sources":[],"birth":{"year":1870},"death":{"year":1952},"marriages":[{"spouse_id":"X00384","children_ids":["HD1229","HD1230","HD1231","HD1232","HD1233"],"marriage_number":1}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections"