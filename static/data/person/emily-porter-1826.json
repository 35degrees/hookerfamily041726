{"person":{"id":"HD2542","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":8,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"HD2524","mother_id":"X00844"},"tags":["oregon_migration"],"sources":[],"birth":{"year":1826,"city":"Worcester","county":"Worcester County","state":"Massachusetts","country":"United States"},"death":{"year":1901,"month":9,"day":11,"city":"Portland","county":"Multnomah County","state":"Oregon","country":"United States","age":75},"gender":"female","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"I01297","date_year":1844,"date_month":3,"date_day":20,"children_ids":[]}],"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Emily Porter","first_name":"Emily","maiden_name":"Porter","married_names":[],"photo_url":"https://images.findagrave.com/photos/2018/172/102670317_6b2df1a3-50f3-453f-a5de-948749fab791.jpeg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[{"institution_id":"INST023"}],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"family","header":"Husband oldest homeopathic physician on Pacific coast","body":"Emily's husband Dr. Ziba Bass Nichols was described at his 1897 death as 'oldest practicing homeopathic physician on the Pacific coast' — a Dartmouth-trained physician who had worked the homeopathy revolution from its Minnesota mid-century days through to its Oregon-frontier late-century practice. He had served as physician and surgeon of the Minnesota state asylum for the deaf, dumb, and blind for eighteen years before the family's move to Portland."},{"number":2,"category":"family","header":"Husband preceptor of the Mayo brothers","body":"Dr. Nichols was described in a descendant biographical sketch as 'preceptor of the Mayo brothers' — placing the Porter-Nichols family in proximity to Charles Mayo and William Mayo, the founders of the Mayo Clinic. The preceptor-and-student relationship in nineteenth-century American medicine was a formal apprenticeship; if accurate, this placed Emily's household near the formative training of two of America's most consequential physicians."},{"number":3,"category":"family","header":"Three sons became Portland physicians","body":"Three of Emily and Dr. Nichols's ten children became Portland physicians in turn: Dr. Ammi Sibley Nichols (1854-1931), Dr. Clarence Lincoln Nichols (1861-1911), and Dr. Herbert Strong Nichols (1868-1948). The three-physician second generation extended the family's medical-practice continuity from 1844 marriage to mid-twentieth-century Oregon care."},{"number":4,"category":"family","header":"Worcester MA 1826 to Portland OR 1901","body":"Emily Porter was born in 1826 in Worcester, Worcester County Massachusetts, daughter of Benjamin Porter and Clementina Lamb. She died September 11, 1901 in Portland Oregon at about age seventy-five and is buried at River View Cemetery, Portland. She had been a resident of Portland eighteen years prior to her death."}],"slug":"emily-porter-1826"},"neighborhood":{"focus":{"id":"HD2542","slug":"emily-porter-1826","n":"Emily Porter","by":1826,"dy":1901,"sx":"f","hd":true,"td":false,"ee":false,"g":8},"spouses":[{"order":1,"spouse":{"id":"I01297","slug":"ziba-nichols-1821","n":"Dr. Ziba Bass Nichols","by":1821,"dy":1897,"sx":"u","hd":false,"td":false,"ee":false,"g":null},"year":1844,"children":[]}],"parents":{"father":{"id":"HD2524","slug":"benjamin-porter-1795","n":"Benjamin Porter","by":1795,"dy":1875,"sx":"m","hd":true,"td":false,"ee":false,"g":7},"mother":{"id":"X00844","slug":"clementina-lamb-1801","n":"Clementina Lamb","by":1801,"dy":1837,"sx":"f","hd":false,"td":false,"ee":false,"g":null}},"grandparents":{"paternal":{"father"