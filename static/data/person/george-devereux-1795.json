],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780853457/LILLIE_DEVEREUX_BLAKE_ulv7s1.jpg"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"category":"social_reform","header":"She was a leader of New York suffrage","body":"Lillie Devereux Blake became a prominent voice in the nineteenth-century women's rights movement and a leading figure in New York's suffrage campaign. She combined that activism with a working career as a novelist.","number":1},{"category":"literature","header":"She wrote novels alongside her activism","body":"Beyond the lecture hall, Blake published novels and sketches that reached a wide popular audience. Her fiction often carried the reformer's concern for women's independence.","number":2},{"category":"social_reform","header":"Her fight opened the way to Barnard","body":"In 1873 Blake petitioned to open Columbia College to women, citing the charter's dedication to the city's youth. Though rebuffed, her long campaign helped lead to the founding of Barnard College in 1889.","number":3}],"burial":{"cemetery_name":"Union Cemetery","city":"Stratford","state":"Connecticut","country":"United States"},"education":[{"school_name":"Miss Apthorp's School for Girls","location":"New Haven, Connecticut","type":"school"},{"school_name":"Yale College curriculum (with a private tutor)","type":"tutored"}],"number_of_marriages":2,"slug":"lillie-blake-1833"},"I01583":{"id":"I01583","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"male","classification":{"is_thomas_descendant":false,"is_talcott_descendant":false,"is_thomas_spouse":true,"include_in_path_calculation":false,"is_easter_egg":false},"notable":{"is_notable":false,"notable_category":[]},"parents":{},"number_of_marriages":1,"marriages":[{"spouse_id":"HD2595","children_ids":["HD5932","HD5933"]