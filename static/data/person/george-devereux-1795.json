ounty":"Cumberland","state":"Maine","country":"United States"},"death":{"year":1896,"month":3,"day":10,"state":"New Jersey","country":"United States"},"burial":{"cemetery_name":"Harrison Village Cemetery","city":"Harrison","state":"Maine","country":"United States"},"career":[{"role":"Merchant","location":"New York, New York"}],"slug":"grinfill-blake-1835"},"HD5932":{"id":"HD5932","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"female","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"include_in_path_calculation":true,"is_easter_egg":false,"generation_from_thomas":9},"notable":{"is_notable":false,"notable_category":[]},"parents":{"father_id":"I01583","mother_id":"HD2595"},"number_of_marriages":1,"marriages":[{"spouse_id":"I01585","children_ids":["HD5934","HD5935"]}],"tags":[],"narrative_blocks":[{"number":1,"category":"character","header":"She chose the art world over activism","body":"Unlike her suffragist mother and educator sister, Elizabeth Robinson was known not for reform but for the art circles of St. Louis, where her husband John Beverly Robinson led Washington University's school of architecture. The family's intellectual energy resurfaced two generations later in anthropology."}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Elizabeth Johnson Devereux","last_name":"Robinson","display_name":"Elizabeth Johnson Devereux Robinson","gender":"female","married_names":[],"maiden_name":"Devereux"},"military_service":[],"career":[],"birth":{"year":1857,"month":2,"day":15,"city":"New York","state":"New York","country":"United States"},"death":{"year":1940,"month":6,"day":7,"city":"Albany","county":"Albany","state":"New York","country":"United States"},"slug":"elizabeth-johnson-devereux-robinson-1857"},"HD5933":{"id":"HD5933","former_ids":[],"is_placeholder":false,"has_descendants_documented":false,"gender":"female","classification":{"is_thomas_descendant":true,"is_talcott_descendant":false,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"include_in_path_calculation":true,"is_easter_egg":false,"generation_from_thomas":9},"notable":{"is_notable":true,"notable_category":["education"],"notable_blurb":"Educator, suffragist, and peace activist","primary_url":"https://en.wikipedia.org/wiki/Katherine_Devereux_Blake"},"parents":{"father_id":"I01583","mother_id":"HD2595"},"number_of_marriages":0,"marriages":[],"tags":["educator","suffragist","womens_rights","author","extraordinary_longevity","died_unmarried"],"narrative_blocks":[{"number":1,"category":"education","header":"She led one school for thirty-four years","body":"Katherine Blake became principal of the girls' department of Public School 6 in 1894 and held the post for thirty-four years. In 1916 the school was renamed for her mother, the suffragist Lillie Devereux Blake."},{"number":2,"category":"social_reform","header":"She marshaled fifteen thousand teachers for suffrage","body":"Blake organized New York's teachers behind the vote and each summer from 1911 to 1919 was sent by the national suffrage association to campaign in states weighing the question. She marched at the head of the teachers' contingent in the 1915 New York parade."},{"number":3,"category":"career","header":"She was the board's first woman treasurer","body":"Blake became the first female treasurer of the New York Board of Education and rose to the presidency of the National Education Association. She founded the city's first evening high school for women in 1897."},{"number":4,"category":"social_reform","header":"She carried seven million names against war","body":"As a leader of the Women's International League for Peace and Freedom, Blake was chief spokesperson for the Disarmament Caravan that brought a petition of nearly seven million signatures to President Hoover in 1931 and to Geneva in 1932. In 1928 she was among nineteen educators chosen to accompany John Dewey to Russia."},{"number":5,"category":"family","header":"Her activism doubled her famous mother's","body":"Both Katherine and her widowed mother took the surname Blake when Lillie remarried in 1866, and both became suffragists. Katherine later co-wrote her mother's biography, Champion of Women."}],"sources":[],"institutions":[],"landmarks":[],"artworks":[],"research_tags":[],"cross_connections":[{"type":"civic_peer","related_id":"H00597","display_label":"pioneered American women's education a century earlier"},{"type":"civic_peer","related_id":"X01980","display_label":"founded Miss Porter's School for the education of girls"}],"quotes":[],"research_sources":[],"documents":[],"statues":[],"bio":{"first_name":"Katherine Devereux","last_name":"Blake","display_name":"Katherine Devereux Blake","gender":"female","married_names":[],"maiden_name":"Umsted","photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780853948/Photo_of_Katherine_Devereux_Blake_msueep.jpg"},"military_service":[],"career":[{"role":"Principal","organization":"Public School 6 (girls' department), New York","start_year":1894},{"role":"Treasurer","organization":"New York Board of Education"}],"birth":{"year":1858,"month":7,"day":10,"city":"New York","state":"New York","country":"United States"},"death":{"year":1950,"month":2,"day":2,"city":"St. Louis","state":"Missouri","country":"United States"},"education":[{"school_name":"Normal College (now Hunter College)","type":"college","dates":"1876"},{"school_name":"School of Pedagogy, New York University","type":"graduate","dates":"1887-1888"},{"school_name":"Miss Walker's School","type":"school"},{"school_name":"Saint Mary's School","type":"school"}],"slug":"katherine-devereux-blake-1858"},"X00866":{"id":"X00866","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":[],"sources":[],"birth":{"year":1761,"month":3,"day":12,"country":"Ireland","county":"County Wexford"},"death":{"year":1844,"month":7,"day":7,"city":"Raleigh","county":"Wake","state":"North Carolina","country":"United States"},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id":"HD2591","date_year":1790,"location_city":"New Bern","location_state":"North Carolina","children_ids":["HD2592","HD2593","HD2594"]}],"parents":{},"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"John Devereux","first_name":"John","last_name":"Devereux","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780858437/14086980_134217821296_s2jza3.jpg","bio_blurb":"Irish-born New Bern merchant and shipowner"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"burial":{"cemetery_name":"City Cemetery","city":"Raleigh","county":"Wake","state":"North Carolina","country":"United States"},"narrative_blocks":[{"category":"character","header":"A shipwreck made him a Carolina merchant","body":"An Irish former British naval officer, John Devereux was wrecked off New Bern and stayed, building a fleet that traded between Boston and Barbados. There he married the heiress Frances Pollock, founding a family that would reach into Connecticut and beyond.","number":1}],"slug":"john-devereux-1761"},"HD2591":{"id":"HD2591","has_descendants_documented":true,"classification":{"include_in_path_calculation":true,"generation_from_thomas":6,"descent_from_thomas_hooker":true,"descent_from_john_talcott":false,"is_thomas_descendant":true,"is_talcott_descendant":false,"is_easter_egg":false},"parents":{"father_id":"X00864","mother_id":"H00383"},"tags":["slaveholder"],"sources":[{"short":"Online vital records; The Record LXXI; EH 1909"}],"birth":{"year":1771,"month":3,"day":18,"city":"New Bern","county":"Craven","state":"North Carolina","country":"United States"},"death":{"year":1849,"month":6,"day":3,"city":"Raleigh","county":"Wake","state":"North Carolina","country":"United States"},"marriages":[{"spouse_id":"X00866","children_ids":["HD2592","HD2593","HD2594"],"marriage_number":1,"date_year":1790,"location_city":"New Bern","location_state":"North Carolina"}],"gender":"female","number_of_marriages":1,"notable":{"is_notable":false,"notable_category":[]},"cross_connections":[],"bio":{"display_name":"Frances Pollock","first_name":"Frances","maiden_name":"Pollock","married_names":[],"photo_url":"https://res.cloudinary.com/dc5clrqtw/image/upload/v1780858344/14087012_e2348499-9034-46a5-8801-2f454a46258e_kjjadp.png","bio_blurb":"New Bern heiress; matriarch of the Devereux family"},"residence":{},"baptism":{},"research_tags":[],"research_sources":[],"documents":[],"naming_inspiration":[],"institutions":[],"landmarks":[],"artworks":[],"quotes":[],"military_service":[],"narrative_blocks":[{"number":1,"category":"business","header":"Husband described as 'Rothschild' of American business","body":"Frances Pollock's husband John Devereux — Irish-born, trained for the Catholic priesthood at Saint Omer's monastery in France before rejecting priesthood, served as a British Navy midshipman and then 1st Lieutenant during the American Revolution, then sailed penniless to America after his family rejected him — built an estate of approximately eight hundred thousand dollars combined with her Pollock plantation property. Per the North Carolina Biography Project, 'in business circles his name was similar to that of Rothschild in Europe.' Their sons Thomas and George were both sent to Yale."},{"number":2,"category":"family","header":"Inherited eight plantations and Spanish pieces of eight","body":"Frances Pollock inherited eight plantations plus 7,500 'milled Spanish pieces of eight' from her father Thomas Pollock III's estate. The Spanish pieces of eight were the silver dollars that circulated as the de facto currency of post-Revolutionary North Carolina before the federal Mint produced enough US coinage. Combined with husband John Devereux's substantial Charleston business holdings, the couple became one of the wealthiest planter-merchant families in the Carolinas."},{"number":3,"category":"religion","header":"Co-founded First Presbyterian Church, New Bern","body":"Frances Pollock Devereux co-founded the First Presbyterian Church in New Bern North Carolina, the family's antebellum home. Her daughter Frances Ann Devereux Polk would later marry Bishop Leonidas Polk in 1830 and become the wife of one of the most prominent Episcopal bishops of the antebellum South — carrying the family religious commitment into the next denomination and the next generation."},{"number":4,"category":"family","header":"Born New Bern 1771, died Raleigh 1849","body":"Frances Pollock was born March 18, 1771 in New Bern North Carolina, daughter of Thomas Pollock III and Eunice Edwards — making her granddaughter of Jonathan Edwards and great-great-granddaughter of Rev. Thomas Hooker through Sarah Pierpont Edwards. She died June 3, 1849 in Raleigh North Carolina at age seventy-eight and was buried in City Cemetery Raleigh."}],"burial":{"cemetery_name":"City Cemetery","city":"Raleigh","county":"Wake","state":"North Carolina","country":"United States"},"slug":"frances-pollock-1771"},"X00864":{"id":"X00864","has_descendants_documented":false,"classification":{"include_in_path_calculation":false,"descent_from_thomas_hooker":false,"descent_from_john_talcott":false,"is_thomas_descendant":false,"is_talcott_descendant":false,"is_easter_egg":false},"tags":["slaveholder"],"sources":[],"birth":{"year":1730},"death":{"year":1777},"gender":"male","number_of_marriages":1,"marriages":[{"marriage_number":1,"spouse_id"